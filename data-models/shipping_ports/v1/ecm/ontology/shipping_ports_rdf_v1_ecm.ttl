    rdfs:subClassOf ind:Marine ;
    rdfs:label 'Pilotage Route' ;
    rdfs:comment 'Master reference table for pilotage_route. Referenced by pilotage_route_id.' .

ind:WasteReceptionFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Infrastructure ;
    rdfs:label 'Waste Reception Facility' ;
    rdfs:comment 'Master reference table for waste_reception_facility. Referenced by reception_facility_id.' .

ind:FacilityBuilding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Infrastructure ;
    rdfs:label 'Facility Building' ;
    rdfs:comment 'Master reference table for facility_building. Referenced by facility_building_id.' .

ind:PatrolRoute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Patrol Route' ;
    rdfs:comment 'Master reference table for patrol_route. Referenced by route_id.' .

ind:GateLane rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Terminal ;
    rdfs:label 'Gate Lane' ;
    rdfs:comment 'Master reference table for gate_lane. Referenced by gate_lane_id.' .

ind:Terminal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Terminal ;
    rdfs:label 'Terminal' ;
    rdfs:comment 'Master reference table for terminal. Referenced by terminal_id.' .

ind:CalibrationSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Calibration Session' ;
    rdfs:comment 'Master reference table for calibration_session. Referenced by calibration_session_id.' .

ind:Port rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Infrastructure ;
    rdfs:label 'Port' ;
    rdfs:comment 'Master reference table for port. Referenced by port_id.' .

# --- Attribute Properties ---
ind:acquisitionId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Id' ;
    rdfs:comment 'Unique identifier for the asset acquisition record. Primary key for the asset acquisition lifecycle tracking from procurement through commissioning.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquisitionAssetManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Asset Manager Employee Id' ;
    rdfs:comment 'Reference to the employee designated as the asset manager responsible for the lifecycle management of this asset post-acquisition. Links to workforce employee master data.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acquisitionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for managing the procurement process for this asset acquisition. Links to workforce employee master data.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:facilitySecurityPlanId rdf:type rdf:Property ;
    rdfs:label 'Facility Security Plan Id' ;
    rdfs:comment 'Foreign key linking to security.facility_security_plan. Business justification: Acquisition of new security equipment (scanners, CCTV, access control systems) requires FSP amendment documentation under ISPS Code. Regulatory compliance for port facility security plan updates and P' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FacilitySecurityPlan .

ind:internalOrderId rdf:type rdf:Property ;
    rdfs:label 'Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Asset acquisitions may be funded through internal orders for capex cost collection and settlement. Used when acquisitions are not part of formal projects but need cost tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:portAssetId rdf:type rdf:Property ;
    rdfs:label 'Port Asset Id' ;
    rdfs:comment 'Reference to the asset that was acquired. Links to the master asset registry for the equipment unit (crane, RTG, ASC, AGV, MHC, forklift, or port vehicle) that was procured.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortAsset .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to safety.risk_assessment. Business justification: New asset commissioning requires pre-operational risk assessment per ISO 45001 and port safety management systems. Links acquisition to mandatory safety evaluation before equipment enters service. Cri' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:supplierPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Supplier Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Asset suppliers (equipment manufacturers, marine equipment dealers) are often registered as port community participants for delivery coordination, commissioning support, and warranty service access. C' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the supplier or manufacturer from whom the asset was procured. Links to the vendor master data in SAP MM.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Foreign key linking to finance.wbs_element. Business justification: Capital asset acquisitions are tracked under WBS elements in project accounting for capex budget control and project cost tracking. Standard practice in port infrastructure investment management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:acceptanceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Acceptance Certificate Number' ;
    rdfs:comment 'The unique reference number of the formal acceptance certificate issued upon successful handover of the asset from vendor to port authority.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date on which the asset was legally acquired or ownership transferred to the port authority. This is the principal business event timestamp for the acquisition transaction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'The SAP FI-AA asset class code that categorizes the asset for accounting, depreciation, and reporting purposes (e.g., cranes, vehicles, IT equipment).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocationCode rdf:type rdf:Property ;
    rdfs:label 'Asset Location Code' ;
    rdfs:comment 'The code identifying the physical location or berth where the asset is deployed within the port facility (e.g., terminal yard, berth number, maintenance depot).' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'The date on which the asset was capitalized in the financial accounting system (SAP FI-AA), marking the start of depreciation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'The date on which the asset was commissioned and became operational for port activities. Marks the transition from capital project to operational asset.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'The total cost paid for acquiring the asset, including purchase price, delivery, installation, and commissioning costs. Represents the capitalized value in SAP FI-AA.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The timestamp when this asset acquisition record was first created in the system. Audit trail for data governance and compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the acquisition cost was denominated (e.g., USD, EUR, GBP, SGD).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'The accounting method used to depreciate the asset over its useful life. Determines how the acquisition cost is expensed over time in SAP FI-AA.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'The financial mechanism used to fund the asset acquisition. Indicates whether the asset was purchased using internal capital, external financing, or alternative funding arrangements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Handover Acceptance Date' ;
    rdfs:comment 'The date on which the asset was formally accepted by the port authority from the vendor, signifying completion of all acceptance tests and readiness for operational deployment.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:handoverAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Handover Acceptance Status' ;
    rdfs:comment 'The current status of the asset handover and acceptance process from the vendor to the port operations team. Tracks the final stage of the acquisition lifecycle before operational deployment.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialSwlCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Initial Swl Certification Date' ;
    rdfs:comment 'The date on which the initial Safe Working Load certification was issued for the asset by a qualified marine surveyor or certification authority. Critical for cranes, lifting equipment, and cargo handling machinery.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Installation Completion Date' ;
    rdfs:comment 'The date on which physical installation of the asset at the port site was completed, preceding commissioning and acceptance testing.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installationContractorName rdf:type rdf:Property ;
    rdfs:label 'Installation Contractor Name' ;
    rdfs:comment 'The name of the contractor responsible for installing and commissioning the asset at the port facility. May differ from the equipment vendor.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'The total insured value or coverage amount for the asset under the insurance policy.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'The insurance policy number covering the asset against damage, loss, or liability. Critical for high-value port equipment such as STS cranes and RTGs.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The timestamp when this asset acquisition record was last updated in the system. Audit trail for data governance and compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional notes, comments, or special conditions related to the asset acquisition, including any deviations from standard procurement processes or unique contractual terms.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'The purchase order number issued to the vendor for procurement of the asset. Integrates with SAP MM purchase order management system.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'The estimated salvage or residual value of the asset at the end of its useful life, used in depreciation calculations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swlRatingTonnes rdf:type rdf:Property ;
    rdfs:label 'Swl Rating Tonnes' ;
    rdfs:comment 'The certified Safe Working Load capacity of the asset in metric tonnes. Applicable to cranes (STS, QC, MHC), RTG, ASC, and other lifting equipment. Defines the maximum load the equipment is certified to handle safely.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'The estimated useful economic life of the asset in years, used for depreciation calculation and lifecycle planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyEndDate rdf:type rdf:Property ;
    rdfs:label 'Warranty End Date' ;
    rdfs:comment 'The date on which the manufacturer or vendor warranty coverage expires for the acquired asset.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'The date on which the manufacturer or vendor warranty coverage begins for the acquired asset.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Detailed description of the warranty coverage terms, including scope of coverage, exclusions, service level commitments, and claim procedures provided by the vendor.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalId rdf:type rdf:Property ;
    rdfs:label 'Disposal Id' ;
    rdfs:comment 'Unique identifier for the asset disposal record. Primary key for the asset disposal entity.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyerPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Buyer Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Asset buyers (equipment brokers, scrap dealers, other port operators) must be registered port community participants for disposal authorization, asset removal from port facilities, environmental compl' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:disposalPortAssetId rdf:type rdf:Property ;
    rdfs:label 'Disposal Port Asset Id' ;
    rdfs:comment 'Reference to the port asset being disposed (crane, RTG, ASC, AGV, MHC, forklift, vehicle, or other equipment). Links to the asset registry master data.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortAsset .

ind:disposalReplacementAssetPortAssetId rdf:type rdf:Property ;
    rdfs:label 'Disposal Replacement Asset Port Asset Id' ;
    rdfs:comment 'Reference to the new asset that replaced the disposed asset, if applicable. Links disposal to capital investment and fleet renewal planning. Null if no direct replacement.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortAsset .

ind:personnelId rdf:type rdf:Property ;
    rdfs:label 'Personnel Id' ;
    rdfs:comment 'Foreign key linking to security.security_personnel. Business justification: Disposal of security equipment requires security officer authorization for chain of custody, data sanitization verification, and ISPS compliance. Operational requirement for decommissioning security-c' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Personnel .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'The date on which the disposal was formally authorized. Must precede or equal the disposal date.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Reference' ;
    rdfs:comment 'Reference to the approval document, board resolution, or management authorization that approved the asset disposal. Required for governance and audit compliance.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedBy rdf:type rdf:Property ;
    rdfs:label 'Authorized By' ;
    rdfs:comment 'Name or identifier of the person or role who authorized the disposal (e.g., CFO, Asset Manager, Port Director). Part of the approval audit trail.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractor rdf:type rdf:Property ;
    rdfs:label 'Contractor' ;
    rdfs:comment 'Name of the third-party contractor or service provider who executed the physical disposal (scrap dealer, recycling company, transport company, or demolition contractor). Null if disposal handled internally.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'The date on which the asset was officially disposed, decommissioned, or transferred. Represents the principal business event timestamp for the disposal transaction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'The method by which the asset was disposed. Scrap indicates physical destruction or recycling; sale indicates sold to third party; transfer indicates moved to another entity or division; donation indicates gifted; write-off indicates accounting removal without physical disposal; trade-in indicates exchanged as part of new asset acquisition.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalStatus rdf:type rdf:Property ;
    rdfs:label 'Disposal Status' ;
    rdfs:comment 'Current lifecycle status of the disposal transaction. Pending indicates awaiting approval; approved indicates authorized for disposal; in-progress indicates disposal activities underway; completed indicates disposal finalized; cancelled indicates disposal cancelled.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Indicates whether the disposal complied with environmental regulations including MARPOL (Marine Pollution Convention), hazardous waste disposal regulations, and local environmental laws. True indicates compliant disposal; false indicates non-compliance or pending investigation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalDisposalCertificate rdf:type rdf:Property ;
    rdfs:label 'Environmental Disposal Certificate' ;
    rdfs:comment 'Reference number or identifier of the environmental disposal certificate or hazardous waste manifest issued by regulatory authorities confirming compliant disposal of hazardous materials (e.g., oils, batteries, chemicals from port equipment).' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gainLoss rdf:type rdf:Property ;
    rdfs:label 'Gain Loss' ;
    rdfs:comment 'The financial gain (positive) or loss (negative) on disposal, calculated as disposal proceeds minus net book value. Impacts the income statement and is reported in financial accounting.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the disposed asset contained hazardous materials requiring special handling and disposal procedures (e.g., hydraulic fluids, batteries, asbestos, refrigerants). True indicates hazardous materials present; false indicates non-hazardous.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Reference' ;
    rdfs:comment 'Reference number of the insurance claim if the disposal was due to insured damage or loss. Links disposal to Protection and Indemnity (P&I) or property insurance claims.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier or name of the person who last modified the disposal record. Part of the audit trail for change tracking and accountability.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'The physical location where the asset was disposed (scrap yard, recycling facility, buyer location, or transfer destination). Includes facility name and address for audit trail.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximoWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Maximo Work Order Number' ;
    rdfs:comment 'Reference to the Maximo Asset Management work order that executed the physical disposal activities (decommissioning, dismantling, removal, transport). Links disposal record to maintenance system of record.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'The carrying value of the asset on the balance sheet at the time of disposal, calculated as original cost less accumulated depreciation. Used to determine gain or loss on disposal.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proceeds rdf:type rdf:Property ;
    rdfs:label 'Proceeds' ;
    rdfs:comment 'The monetary amount received from the disposal of the asset (sale price, scrap value, or trade-in value). Zero for write-offs, donations, or transfers without consideration.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'The business rationale for disposing the asset. End-of-life indicates asset reached end of useful life; obsolescence indicates technology or operational obsolescence; damage indicates irreparable damage; strategic-divestment indicates business strategy change; regulatory-compliance indicates disposal mandated by regulation; upgrade indicates replacement with newer equipment; redundancy indicates excess capacity. [ENUM-REF-CANDIDATE: end-of-life|obsolescence|damage|strategic-divestment|regulatory-compliance|upgrade|redundancy — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPartyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Identifier' ;
    rdfs:comment 'Business identifier for the receiving party (tax ID, company registration number, or internal customer/vendor code). Used for audit trail and compliance documentation.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPartyName rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Name' ;
    rdfs:comment 'The name of the organization or individual who received the asset (buyer, transferee, or recipient). Applicable for sale, transfer, donation, or trade-in disposal methods. Null for scrap or write-off.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Business identifier for the disposal transaction, used for tracking and audit purposes. May align with SAP FI-AA retirement document number or Maximo work order reference.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiAaDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Aa Document Number' ;
    rdfs:comment 'The SAP FI-AA retirement document number that records the asset disposal transaction in the financial system. Links the physical disposal to the accounting system of record for asset retirement and financial reporting.' ;
    rdfs:domain ind:Disposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or name of the person who created the disposal record. Part of the audit trail for accountability and data governance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Unique identifier for each asset location assignment record. Primary key. Inferred role: TRANSACTION_HEADER (each location assignment is a discrete business event with lifecycle). This entity tracks location assignment events for port assets.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:zoneId rdf:type rdf:Property ;
    rdfs:label 'Zone Id' ;
    rdfs:comment 'Foreign key linking to security.security_zone. Business justification: Asset location assignments must reference security zone for access control enforcement, patrol planning, and MARSEC-level restrictions. Operational requirement for security personnel dispatch and cred' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Level of access control required for personnel and equipment entering this location. Public for unrestricted areas; authorized for credentialed staff; escort required for visitor areas; permit only for special authorization zones; emergency only for restricted emergency access.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally-known business identifier for this location assignment event. Used for tracking and audit purposes across NAVIS N4 and TOPS Expert systems.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Business priority level for this location assignment. Critical for emergency response or safety-critical equipment; high for revenue-generating operations; medium for routine redeployment; low for optimization or non-urgent transfers.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the location assignment. Active indicates the asset is currently deployed at this location; pending indicates scheduled future assignment; completed indicates historical assignment; cancelled indicates assignment was revoked; suspended indicates temporary hold.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Precise date and time when the location assignment was executed or recorded in the Terminal Operating System (TOS). Principal business event timestamp for this location assignment transaction.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorizingOfficer rdf:type rdf:Property ;
    rdfs:label 'Authorizing Officer' ;
    rdfs:comment 'Name or identifier of the port authority officer, terminal manager, or operations supervisor who approved the asset location assignment or transfer. Used for accountability and audit trail.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthCode rdf:type rdf:Property ;
    rdfs:label 'Berth Code' ;
    rdfs:comment 'Identifier for the specific berth where the asset is assigned, if applicable. Relevant for quayside equipment such as Ship-to-Shore (STS) cranes and Quay Cranes (QC). Null for non-berth locations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCostCentre rdf:type rdf:Property ;
    rdfs:label 'Destination Cost Centre' ;
    rdfs:comment 'Financial cost centre code to which the asset is being assigned. Used for inter-departmental cost allocation and Capital Expenditure (CAPEX) / Operational Expenditure (OPEX) tracking in SAP S/4HANA Controlling (CO) module.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Order Number' ;
    rdfs:comment 'Reference number of the equipment dispatch order that initiated this location assignment. Links to NAVIS N4 or TOPS Expert dispatch management for operational coordination.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceFromPreviousLocationM rdf:type rdf:Property ;
    rdfs:label 'Distance From Previous Location M' ;
    rdfs:comment 'Physical distance in meters between the previous location and current location. Used for transfer cost estimation, fuel consumption tracking, and logistics planning.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date when the asset location assignment becomes effective. Marks the start of the assets deployment at this location. Used for historical tracking and yard planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date when the asset location assignment ends or is scheduled to end. Null for current active assignments. Used for transfer planning and historical analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalZone rdf:type rdf:Property ;
    rdfs:label 'Environmental Zone' ;
    rdfs:comment 'Environmental classification of the location area. Standard for normal operations; controlled emission for Greenhouse Gas (GHG) monitoring zones; noise restricted for residential proximity; hazmat for International Maritime Dangerous Goods (IMDG) handling; marine protected for environmentally sensitive areas per Marine Pollution Convention (MARPOL).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the asset location in decimal degrees. Supports real-time equipment positioning and dispatch routing. Integrates with Vessel Traffic Management System (VTMS) and Terminal Operating System (TOS).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the asset location in decimal degrees. Supports real-time equipment positioning and dispatch routing. Integrates with Vessel Traffic Management System (VTMS) and Terminal Operating System (TOS).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isTemporaryAssignment rdf:type rdf:Property ;
    rdfs:label 'Is Temporary Assignment' ;
    rdfs:comment 'Flag indicating whether this location assignment is temporary (True) or permanent (False). Temporary assignments are typically for short-term operational needs, maintenance, or project work.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Date and time when this asset location assignment record was most recently modified. Audit trail timestamp for record updates.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadBearingCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Load Bearing Capacity Tonnes' ;
    rdfs:comment 'Maximum load bearing capacity of the location surface in metric tonnes. Critical for ensuring Safe Working Load (SWL) compliance when deploying heavy equipment such as Mobile Harbour Cranes (MHC), Rubber Tyred Gantry (RTG) cranes, or loaded vehicles.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Standardized alphanumeric code identifying the specific physical location within the terminal footprint. May represent berth, quay zone, yard block, Container Yard (CY), maintenance bay, or equipment staging area.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or description of the physical location where the asset is deployed. Examples: Berth 5 North, Yard Block A3, Maintenance Bay 2, Quay Crane Rail 7.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkConnectivityAvailable rdf:type rdf:Property ;
    rdfs:label 'Network Connectivity Available' ;
    rdfs:comment 'Flag indicating whether data network connectivity (wired or wireless) is available at this location (True) or not (False). Required for Radio Frequency Identification (RFID) tracking, Terminal Operating System (TOS) integration, and real-time equipment monitoring.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextScheduledLocationCode rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Location Code' ;
    rdfs:comment 'Location code where the asset is scheduled to be transferred next. Null if no future transfer is planned. Supports forward planning and equipment dispatch optimization.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalArea rdf:type rdf:Property ;
    rdfs:label 'Operational Area' ;
    rdfs:comment 'Functional designation of the operational area where the asset is deployed. Container terminal for Twenty-foot Equivalent Unit (TEU) / Forty-foot Equivalent Unit (FEU) handling; bulk cargo for dry/liquid bulk; Roll-on Roll-off (RoRo) for vehicle shipping; general cargo for break-bulk; intermodal for rail/road transfer; maintenance depot for repair facilities; administration for support functions. [ENUM-REF-CANDIDATE: container_terminal|bulk_cargo|roro|general_cargo|intermodal|maintenance_depot|administration — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingCostCentre rdf:type rdf:Property ;
    rdfs:label 'Originating Cost Centre' ;
    rdfs:comment 'Financial cost centre code from which the asset is being transferred. Used for inter-departmental cost allocation and Capital Expenditure (CAPEX) / Operational Expenditure (OPEX) tracking in SAP S/4HANA Controlling (CO) module.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerSupplyAvailable rdf:type rdf:Property ;
    rdfs:label 'Power Supply Available' ;
    rdfs:comment 'Flag indicating whether electrical power supply infrastructure is available at this location (True) or not (False). Relevant for electrically-powered equipment such as Ship-to-Shore (STS) cranes, Automated Stacking Cranes (ASC), and charging stations for Automated Guided Vehicles (AGV).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousLocationCode rdf:type rdf:Property ;
    rdfs:label 'Previous Location Code' ;
    rdfs:comment 'Location code where the asset was deployed immediately prior to this assignment. Null for initial deployment. Supports transfer history tracking and equipment movement analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyZoneClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Zone Classification' ;
    rdfs:comment 'Safety and security classification of the location area. Unrestricted for general access; restricted for authorized personnel only; hazardous for dangerous goods areas; International Ship and Port Facility Security (ISPS) controlled for security zones; confined space for Occupational Health and Safety (OHS) regulated areas.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Operational system of record that originated this location assignment. NAVIS N4 for yard management; TOPS Expert for container tracking; Maximo for maintenance-driven transfers; SAP PM for plant maintenance work orders; Vessel Traffic Management System (VTMS) for marine equipment; manual for operator-entered assignments.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceType rdf:type rdf:Property ;
    rdfs:label 'Surface Type' ;
    rdfs:comment 'Physical surface type of the location area. Concrete for paved quay and yard; asphalt for roadways; gravel for unpaved areas; rail for rail-mounted equipment zones; water for floating equipment; mixed for composite surfaces. Relevant for equipment compatibility and Safe Working Load (SWL) considerations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalZone rdf:type rdf:Property ;
    rdfs:label 'Terminal Zone' ;
    rdfs:comment 'High-level operational area designation within the port terminal. Quayside for berth and crane operations; yard for container stacking; gate for entry/exit; maintenance for repair facilities; intermodal for rail/road transfer; storage for warehousing; administration for office areas. [ENUM-REF-CANDIDATE: quayside|yard|gate|maintenance|intermodal|storage|administration — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDescription rdf:type rdf:Property ;
    rdfs:label 'Transfer Description' ;
    rdfs:comment 'Detailed narrative explanation of the location assignment or transfer, including context, operational requirements, and any special instructions for equipment dispatch or maintenance crew routing.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDurationHours rdf:type rdf:Property ;
    rdfs:label 'Transfer Duration Hours' ;
    rdfs:comment 'Actual or estimated time in hours required to physically relocate the asset from the previous location to the current location. Includes mobilization, transit, and positioning time.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'Business justification for the asset location assignment or transfer. Operational demand for workload balancing; maintenance for scheduled service; breakdown for repair; redeployment for strategic repositioning; seasonal for peak period adjustments; project for infrastructure work; emergency for incident response; optimization for efficiency improvement. [ENUM-REF-CANDIDATE: operational_demand|maintenance|breakdown|redeployment|seasonal|project|emergency|optimization — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Reference number of the maintenance work order associated with this location assignment, if the transfer is for maintenance purposes. Links to Maximo Asset Management or SAP PM work order system.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardBlock rdf:type rdf:Property ;
    rdfs:label 'Yard Block' ;
    rdfs:comment 'Identifier for the yard block or stacking area where the asset is deployed. Relevant for Rubber Tyred Gantry (RTG) cranes, Automated Stacking Cranes (ASC), and yard handling equipment. Null for non-yard locations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterId rdf:type rdf:Property ;
    rdfs:label 'Meter Id' ;
    rdfs:comment 'Unique identifier for the asset meter reading record. Primary key for the asset meter entity.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Identifier of the maintenance technician or operator who captured the manual meter reading. Null for automated readings.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:terminalEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Terminal Equipment Id' ;
    rdfs:comment 'Foreign key linking to terminal.terminal_equipment. Business justification: Meter readings (operating hours, crane cycles, fuel consumption) are captured from operational equipment for real-time telemetry, operational monitoring, and preventive maintenance triggering. While a' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalEquipment .

ind:tugId rdf:type rdf:Property ;
    rdfs:label 'Tug Id' ;
    rdfs:comment 'Foreign key linking to marine.tug. Business justification: Operating hours, fuel consumption, and bollard pull cycles on tugs are metered for condition-based maintenance triggers, performance monitoring, and utilization billing. Links asset meter readings to ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tug .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Identifier of the maintenance work order during which this meter reading was captured. Links meter reading to preventive or corrective maintenance activity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:alertGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Generated Flag' ;
    rdfs:comment 'Indicates whether a maintenance alert has been generated based on this meter reading. True if alert was triggered, false otherwise.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertThreshold rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold' ;
    rdfs:comment 'Meter reading value at which an alert or notification should be generated to prompt maintenance planning. Typically set before the PM threshold to allow lead time.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeTotal rdf:type rdf:Property ;
    rdfs:label 'Cumulative Total' ;
    rdfs:comment 'Lifetime cumulative total for the meter since asset commissioning. Accounts for rollovers and resets to provide true lifetime usage.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentReading rdf:type rdf:Property ;
    rdfs:label 'Current Reading' ;
    rdfs:comment 'The current meter reading value captured at the reading date. Represents the cumulative total at the time of observation.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Calculated data quality score for this meter reading (0-100). Based on factors such as reading source reliability, variance from expected, and validation status.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalUsage rdf:type rdf:Property ;
    rdfs:label 'Incremental Usage' ;
    rdfs:comment 'Calculated incremental usage between current and previous reading. Used to trigger usage-based preventive maintenance (PM) schedules.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterType rdf:type rdf:Property ;
    rdfs:label 'Meter Type' ;
    rdfs:comment 'Type of meter or counter being tracked. Operating hours for RTGs and AGVs, lift cycles for STS cranes and QCs, distance travelled for AGVs, load cycles for handling equipment, fuel consumption for diesel-powered equipment, engine hours for vehicles.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPmThreshold rdf:type rdf:Property ;
    rdfs:label 'Next Pm Threshold' ;
    rdfs:comment 'Meter reading value at which the next preventive maintenance activity is scheduled to be triggered. Used for condition-based and usage-based PM scheduling.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmInterval rdf:type rdf:Property ;
    rdfs:label 'Pm Interval' ;
    rdfs:comment 'Standard interval between preventive maintenance activities for this meter type. For example, 500 operating hours for RTG inspection, 10000 lift cycles for STS crane service.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousReading rdf:type rdf:Property ;
    rdfs:label 'Previous Reading' ;
    rdfs:comment 'The previous meter reading value before the current reading. Used to calculate incremental usage since last reading.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Reading Accuracy' ;
    rdfs:comment 'Assessed accuracy level of the meter reading. High for direct sensor readings, medium for manual observations, low for estimated or interpolated values.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingDate rdf:type rdf:Property ;
    rdfs:label 'Reading Date' ;
    rdfs:comment 'Date and time when the meter reading was captured. Primary business event timestamp for condition-based and usage-based maintenance scheduling.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readingMethod rdf:type rdf:Property ;
    rdfs:label 'Reading Method' ;
    rdfs:comment 'Method used to obtain the meter reading. Direct observation by technician, remote telemetry from IoT device, system integration from TOS or SCADA, estimated based on usage patterns, or interpolated from adjacent readings.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingNotes rdf:type rdf:Property ;
    rdfs:label 'Reading Notes' ;
    rdfs:comment 'Free-text notes or comments about the meter reading. May include technician observations, anomalies detected, or contextual information about operating conditions.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingSource rdf:type rdf:Property ;
    rdfs:label 'Reading Source' ;
    rdfs:comment 'Source or method by which the meter reading was captured. Manual entry by technician, automated system reading, IoT sensor transmission, telematics device, or SCADA system integration.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingStatus rdf:type rdf:Property ;
    rdfs:label 'Reading Status' ;
    rdfs:comment 'Status of the meter reading. Valid for confirmed accurate readings, invalid for erroneous data, estimated for interpolated values, adjusted for corrected readings, pending verification for unconfirmed readings.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverCount rdf:type rdf:Property ;
    rdfs:label 'Rollover Count' ;
    rdfs:comment 'Number of times the meter has rolled over since asset commissioning. Used to calculate true cumulative total.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rolloverFlag rdf:type rdf:Property ;
    rdfs:label 'Rollover Flag' ;
    rdfs:comment 'Indicates whether the meter has rolled over (reset to zero after reaching maximum value). True if rollover occurred, false otherwise.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sensorCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Code' ;
    rdfs:comment 'Identifier of the IoT sensor or telematics device that transmitted the automated meter reading. Null for manual readings.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Unique identifier of the meter reading record in the source system. Used for data lineage and reconciliation with operational systems.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unit rdf:type rdf:Property ;
    rdfs:label 'Unit' ;
    rdfs:comment 'Unit of measure for the meter reading. Hours for operating time, cycles for lift/load operations, kilometers or meters for distance, liters or gallons for fuel consumption.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when this meter reading record was last updated in the lakehouse. Used for change tracking and data freshness monitoring.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:usageRatePerDay rdf:type rdf:Property ;
    rdfs:label 'Usage Rate Per Day' ;
    rdfs:comment 'Calculated average daily usage rate for this meter. Used to forecast when PM thresholds will be reached and to schedule proactive maintenance.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFromExpected rdf:type rdf:Property ;
    rdfs:label 'Variance From Expected' ;
    rdfs:comment 'Percentage variance between the actual reading and the expected reading based on historical usage patterns. Used to identify anomalies or equipment issues.' ;
    rdfs:domain ind:Meter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationScheduleId rdf:type rdf:Property ;
    rdfs:label 'Depreciation Schedule Id' ;
    rdfs:comment 'Unique identifier for the depreciation schedule record. Primary key for the depreciation schedule entity.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCentreId rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Depreciation expense must post to specific cost centres for management accounting and P&L reporting. Required for monthly financial close and cost centre performance analysis in port operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Depreciation schedules must link to the financial fixed asset register for financial reporting and asset accounting. Required for balance sheet reporting and accumulated depreciation tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'The cumulative total of all depreciation expense recognized to date since the asset was placed in service. This contra-asset account reduces the gross book value to arrive at net book value.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'The original purchase price or capitalized cost of the asset, including all costs necessary to bring the asset to working condition (purchase price, freight, installation, commissioning). This is the depreciable base before residual value.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Depreciation Amount' ;
    rdfs:comment 'The calculated depreciation expense allocated to each fiscal year. For straight-line method, this is depreciable amount divided by useful life years. For other methods, this varies by year.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appraiserName rdf:type rdf:Property ;
    rdfs:label 'Appraiser Name' ;
    rdfs:comment 'The name of the professional appraiser or valuation firm that performed the asset valuation, if applicable. Used for audit trail and valuation credibility.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraiserReference rdf:type rdf:Property ;
    rdfs:label 'Appraiser Reference' ;
    rdfs:comment 'The reference number or document identifier for the appraisal report. Used to trace back to the source valuation documentation.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetRetirementObligation rdf:type rdf:Property ;
    rdfs:label 'Asset Retirement Obligation' ;
    rdfs:comment 'The present value of the estimated future cost to retire, dismantle, or remove the asset at the end of its useful life. Relevant for port infrastructure such as berths, wharves, and environmental remediation obligations.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciableAmount rdf:type rdf:Property ;
    rdfs:label 'Depreciable Amount' ;
    rdfs:comment 'The net amount subject to depreciation, calculated as acquisition cost minus residual value. This is the total amount that will be expensed over the asset\'s useful life.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'The accounting perspective or valuation area for which this depreciation schedule is maintained. Book depreciation follows local GAAP, tax follows tax authority rules, IFRS follows International Financial Reporting Standards, group is for consolidated reporting, cost accounting for internal management, and consolidated for group-level financial statements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationEndDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation End Date' ;
    rdfs:comment 'The date on which depreciation calculation ends for this asset. This is the date when the asset is fully depreciated or retired from service.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationPercentage rdf:type rdf:Property ;
    rdfs:label 'Depreciation Percentage' ;
    rdfs:comment 'The depreciation rate applied for declining balance or percentage-based methods. For example, 20% for a 5-year straight-line equivalent, or 40% for double-declining balance.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationRunDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Date' ;
    rdfs:comment 'The date on which the depreciation calculation was executed in the source system (SAP FI-AA). Used for audit trail and reconciliation.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationStartDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Start Date' ;
    rdfs:comment 'The date on which depreciation calculation begins for this asset. Typically the asset capitalization date or the date the asset is placed in service.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationStatus rdf:type rdf:Property ;
    rdfs:label 'Depreciation Status' ;
    rdfs:comment 'The current status of the depreciation schedule. Active indicates ongoing depreciation, suspended indicates temporary halt (e.g., asset under repair), completed indicates fully depreciated, reversed indicates a depreciation reversal, and adjusted indicates a schedule modification.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month or quarter) within the fiscal year to which this depreciation schedule record applies. Typically 1-12 for monthly periods or 1-4 for quarterly periods.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this depreciation schedule record applies. Used for year-over-year depreciation tracking and financial statement preparation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The general ledger account code to which depreciation expense is posted. Typically an expense account in the chart of accounts.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentDate rdf:type rdf:Property ;
    rdfs:label 'Impairment Date' ;
    rdfs:comment 'The date on which the impairment loss was recognized. Used for financial statement disclosure and audit trail.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impairmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator' ;
    rdfs:comment 'Flag indicating whether there are indicators that the asset may be impaired (carrying amount exceeds recoverable amount). Triggers impairment testing per IAS 36.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'The amount by which the carrying amount of the asset exceeds its recoverable amount. Impairment loss is recognized as an expense and reduces the asset\'s net book value.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The timestamp when this depreciation schedule record was last modified in the lakehouse. Used for change tracking and audit trail.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Period Depreciation Amount' ;
    rdfs:comment 'The depreciation expense allocated to a specific accounting period (month or quarter). This is the periodic depreciation charge posted to the general ledger.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationDate rdf:type rdf:Property ;
    rdfs:label 'Revaluation Date' ;
    rdfs:comment 'The date on which the asset was revalued to fair value under the revaluation model. Used for tracking revaluation frequency and compliance with IAS 16.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revaluationSurplus rdf:type rdf:Property ;
    rdfs:label 'Revaluation Surplus' ;
    rdfs:comment 'The amount by which the asset\'s fair value exceeds its carrying amount under the revaluation model. Revaluation surplus is recognized in other comprehensive income and accumulated in equity.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAssetDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Document Number' ;
    rdfs:comment 'The SAP FI-AA document number that records the depreciation posting or asset transaction. Used for reconciliation between the lakehouse and SAP S/4HANA Asset Accounting.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeUnits rdf:type rdf:Property ;
    rdfs:label 'Useful Life Units' ;
    rdfs:comment 'The estimated total units of production or operating hours over the asset\'s useful life, used when depreciation method is units-of-production. For example, total TEU capacity for a crane, or total operating hours for an AGV.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'The monetary value of the asset according to the specified valuation type. Used for insurance coverage determination, impairment testing, and financial reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The effective date of the asset valuation. For fair market value or appraisal value, this is the date the valuation was performed.' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'The basis or method used for asset valuation. Book value is the accounting carrying amount, fair market value is the price in an orderly transaction, insurance replacement value is the cost to replace the asset, liquidation value is the forced-sale value, and appraisal value is a professional third-party valuation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeRecordId rdf:type rdf:Property ;
    rdfs:label 'Downtime Record Id' ;
    rdfs:comment 'Unique identifier for the equipment downtime record. Primary key for the downtime tracking system.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Asset downtime affecting contracted throughput commitments must reference the agreement for SLA measurement, penalty assessment, and dispute resolution. Essential for terminal operators tracking equip' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:failureReportId rdf:type rdf:Property ;
    rdfs:label 'Failure Report Id' ;
    rdfs:comment 'Reference to the failure or incident report documenting the root cause of unplanned downtime. Used for failure analysis and reliability improvement.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureReport .

ind:primaryDowntimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Downtime Employee Id' ;
    rdfs:comment 'Identifier of the employee or system user who reported or logged the downtime event. Links to workforce management system for accountability and audit trail.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:securityIncidentId rdf:type rdf:Property ;
    rdfs:label 'Security Incident Id' ;
    rdfs:comment 'Foreign key linking to security.security_incident. Business justification: Downtime of security equipment (access barriers, screening devices, surveillance systems) must be logged as security incidents for ISPS audit trails and PFSO review. Regulatory compliance requirement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityIncident .

ind:shiftPatternId rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern Id' ;
    rdfs:comment 'Identifier of the operational shift during which the downtime occurred. Used for shift-based performance analysis and workforce planning. Links to workforce roster system.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftPattern .

ind:tertiaryDowntimeApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Downtime Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the maintenance manager or supervisor who approved and closed the downtime record. Used for audit trail and data quality assurance.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:vesselId rdf:type rdf:Property ;
    rdfs:label 'Vessel Id' ;
    rdfs:comment 'Identifier of the vessel being serviced at the time of downtime, if applicable. Used to assess impact on vessel turnaround time and potential demurrage claims. Links to vessel operations domain.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vessel .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the downtime event was acknowledged by maintenance management. Used to calculate response time and escalation metrics.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedBerth rdf:type rdf:Property ;
    rdfs:label 'Affected Berth' ;
    rdfs:comment 'Berth number or identifier where the equipment downtime occurred, if applicable. Relevant for ship-to-shore cranes and quay cranes. Used to assess impact on vessel operations and berth utilization.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedTerminal rdf:type rdf:Property ;
    rdfs:label 'Affected Terminal' ;
    rdfs:comment 'Name or code of the marine terminal or container yard where the downtime occurred. Used for location-based downtime analysis and terminal performance benchmarking.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the downtime record was approved and closed by management. Used for audit trail and record lifecycle tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of the corrective actions implemented to resolve the downtime and restore equipment to operational status. Includes repair procedures, parts replaced, adjustments made, or temporary workarounds applied.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'Classification of the downtime event type. Planned maintenance includes scheduled preventive maintenance. Unplanned breakdown covers equipment failures. Operational standby represents idle time due to no cargo operations. Weather hold indicates suspension due to adverse weather conditions. Regulatory inspection covers mandatory safety or compliance inspections. Operator unavailable indicates downtime due to workforce constraints.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Hours' ;
    rdfs:comment 'Total duration of the downtime event measured in hours. Calculated as the difference between end and start timestamps. Critical for calculating equipment availability, MTTR (Mean Time To Repair), and OEE (Overall Equipment Effectiveness).' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime End Timestamp' ;
    rdfs:comment 'Date and time when the equipment was restored to operational status and downtime ended. Null if downtime is ongoing. Used to calculate total downtime duration.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Code' ;
    rdfs:comment 'Standardized code representing the specific reason or root cause of the downtime event. Aligned with Maximo failure codes and maintenance taxonomy. Used for failure mode analysis and reliability improvement initiatives.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Description' ;
    rdfs:comment 'Detailed narrative description of the downtime cause, symptoms observed, and corrective actions taken. Provides context for root cause analysis and knowledge management.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Timestamp' ;
    rdfs:comment 'Date and time when the equipment downtime event began. Captured from TOS or asset monitoring systems. Used as the primary business event timestamp for calculating downtime duration and availability metrics.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeStatus rdf:type rdf:Property ;
    rdfs:label 'Downtime Status' ;
    rdfs:comment 'Current lifecycle status of the downtime record. Open indicates newly reported. In progress indicates active repair or investigation. Resolved indicates equipment restored but record under review. Closed indicates record finalized and approved. Cancelled indicates false alarm or duplicate entry.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentRecord rdf:type rdf:Property ;
    rdfs:label 'Is Current Record' ;
    rdfs:comment 'Flag indicating whether this is the current active version of the downtime record. True for the latest version. False for historical versions. Used for SCD Type 2 queries and current-state reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Flag indicating whether the downtime event must be reported to regulatory authorities such as Port State Control (PSC) or maritime safety agencies. True if reportable under IMO, SOLAS, or national regulations.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyRelated rdf:type rdf:Property ;
    rdfs:label 'Is Safety Related' ;
    rdfs:comment 'Flag indicating whether the downtime event was caused by or resulted in a safety hazard or incident. True if safety-related. Used for OHS (Occupational Health and Safety) reporting and compliance with SOLAS and ISPS requirements.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceCostAmount rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cost Amount' ;
    rdfs:comment 'Total cost incurred for resolving the downtime event, including labor, spare parts, and contractor fees. Expressed in the port\'s functional currency. Used for OPEX (Operational Expenditure) tracking and cost-benefit analysis of reliability improvements.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtbfImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Mtbf Impact Flag' ;
    rdfs:comment 'Flag indicating whether this downtime event should be included in MTBF (Mean Time Between Failures) calculations. True for unplanned breakdowns and failures. False for planned maintenance and operational standby. Used for reliability KPI derivation.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mttrImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Mttr Impact Flag' ;
    rdfs:comment 'Flag indicating whether this downtime event should be included in MTTR (Mean Time To Repair) calculations. True for events requiring corrective maintenance. False for planned maintenance and non-repair downtime. Used for maintenance efficiency KPI derivation.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Oee Impact Flag' ;
    rdfs:comment 'Flag indicating whether this downtime event should be included in OEE (Overall Equipment Effectiveness) calculations. True for all downtime that reduces equipment availability. Used for productivity and efficiency benchmarking.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalImpactTeu rdf:type rdf:Property ;
    rdfs:label 'Operational Impact Teu' ;
    rdfs:comment 'Estimated number of TEUs (Twenty-foot Equivalent Units) that could not be handled due to this downtime event. Used to quantify the cargo handling impact and calculate productivity loss.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalImpactVesselMoves rdf:type rdf:Property ;
    rdfs:label 'Operational Impact Vessel Moves' ;
    rdfs:comment 'Estimated number of vessel container moves lost due to this downtime event. Applicable primarily to ship-to-shore cranes and quay cranes. Used to assess impact on vessel turnaround time and berth productivity.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preventiveActionRecommended rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Recommended' ;
    rdfs:comment 'Recommendations for preventive actions to avoid recurrence of similar downtime events. May include changes to maintenance schedules, operator training, design modifications, or spare parts stocking strategies.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Urgency classification of the downtime event based on operational impact and asset criticality. Critical indicates immediate vessel or terminal operations impact. High indicates significant productivity loss. Medium indicates moderate impact. Low indicates minimal operational disruption.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Record Effective Date' ;
    rdfs:comment 'Date from which this version of the downtime record is effective. Used for slowly changing dimension (SCD) Type 2 historization and temporal queries.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Record Expiry Date' ;
    rdfs:comment 'Date until which this version of the downtime record is valid. Null for current active records. Used for slowly changing dimension (SCD) Type 2 historization and temporal queries.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the downtime event was first reported or logged in the system. May differ from actual downtime start time. Used for response time analysis.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the root cause was identified and corrective action was completed. May differ from downtime end timestamp if testing or commissioning is required. Used for MTTR calculation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Entity or party responsible for the downtime event. Internal maintenance indicates port maintenance team responsibility. External contractor indicates third-party service provider. Equipment manufacturer indicates warranty or design defect issues. Operator error indicates human factor. Force majeure covers uncontrollable events like extreme weather. Third party damage indicates damage caused by external parties.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of the root cause of downtime based on failure mode analysis. Categories may include mechanical failure, electrical failure, hydraulic failure, structural damage, software malfunction, operator error, or external factors. Used for reliability improvement and preventive maintenance planning. [ENUM-REF-CANDIDATE: mechanical_failure|electrical_failure|hydraulic_failure|structural_damage|software_malfunction|operator_error|external_factors|design_defect|wear_and_tear — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Flag indicating whether the downtime event caused a breach of service level agreements with shipping lines or terminal customers. True if SLA targets for vessel turnaround time or container handling were not met due to this downtime.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sparePartsUsed rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Used' ;
    rdfs:comment 'List or description of spare parts consumed during the repair or maintenance activity. Links to spare parts inventory in Maximo. Used for parts consumption analysis and inventory planning.' ;
    rdfs:domain ind:DowntimeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'Description of weather conditions at the time of downtime, if weather was a contributing factor. Includes wind speed, visibility, precipitation, or sea state. Used for weather-related downtime analysis and force majeure claims.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentClassId rdf:type rdf:Property ;
    rdfs:label 'Equipment Class Id' ;
    rdfs:comment 'Unique identifier for the equipment class. Primary key for the equipment classification hierarchy.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentClass .

ind:equipmentTypeId rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.equipment_type. Business justification: Asset equipment classes reference standardized equipment type master data. Currently equipment_class has equipment_type as a string. Adding FK to masterdata.equipment_type enables standardized equipme' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentType .

ind:materialGroupId rdf:type rdf:Property ;
    rdfs:label 'Material Group Id' ;
    rdfs:comment 'Foreign key linking to procurement.material_group. Business justification: Equipment classes map to procurement material groups for CAPEX budgeting, sourcing strategy definition, and spend analysis. Ports use this link for category management (consolidating crane parts suppl' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialGroup .

ind:acquisitionCostRangeUsd rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Range Usd' ;
    rdfs:comment 'Typical acquisition cost range for new equipment in this class, expressed in USD. Used for budgeting, procurement planning, and asset valuation. Business-confidential.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualOperatingCostUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Operating Cost Usd' ;
    rdfs:comment 'Estimated annual operating cost (OPEX) for equipment in this class, including fuel, maintenance, labor, and consumables. Used for total cost of ownership analysis. Business-confidential.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation for equipment in this class. Impacts operator requirements, productivity metrics, and technology integration.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityTeu rdf:type rdf:Property ;
    rdfs:label 'Capacity Teu' ;
    rdfs:comment 'Operational capacity of the equipment class expressed in TEU. Applicable to container handling equipment (cranes, stackers, carriers). Null for non-container equipment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Certification Requirements' ;
    rdfs:comment 'Mandatory certifications, inspections, or regulatory approvals required for equipment in this class (e.g., annual SWL certification, ISPS compliance, pressure vessel inspection).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the equipment class across the terminal. Used for reporting, spare parts mapping, and maintenance planning.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classDescription rdf:type rdf:Property ;
    rdfs:label 'Class Description' ;
    rdfs:comment 'Detailed description of the equipment class, including typical use cases, operational characteristics, and distinguishing features.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Full descriptive name of the equipment class (e.g., Ship-to-Shore Crane, Rubber Tyred Gantry Crane, Automated Guided Vehicle).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsStandard rdf:type rdf:Property ;
    rdfs:label 'Emissions Standard' ;
    rdfs:comment 'Applicable emissions standard or tier for this equipment class (e.g., EPA Tier 4, Euro Stage V). Required for environmental compliance and GHG reporting.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Category' ;
    rdfs:comment 'Classification of environmental impact for equipment in this class based on emissions, noise, and resource consumption. Used for EMS reporting and sustainability planning.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'High-level categorization of equipment class by operational function within the terminal.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumptionRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Rate' ;
    rdfs:comment 'Typical fuel or energy consumption rate for this equipment class (e.g., liters per hour, kWh per move). Used for OPEX planning and environmental impact assessment.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imdgComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Imdg Compliance Required' ;
    rdfs:comment 'Indicates whether equipment in this class must comply with IMDG Code requirements for handling dangerous goods. Critical for cargo operations and regulatory compliance.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Days' ;
    rdfs:comment 'Standard inspection interval for equipment in this class, measured in days. Drives preventive maintenance scheduling in Maximo and SAP PM.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interoperabilityStandard rdf:type rdf:Property ;
    rdfs:label 'Interoperability Standard' ;
    rdfs:comment 'Communication or integration standards supported by equipment in this class (e.g., ISO 18186 RFID, EDI BAPLIE, TOS API). Enables system integration and data exchange.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Isps Security Level' ;
    rdfs:comment 'ISPS security level classification for equipment in this class. Determines access control, monitoring, and security protocol requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiBenchmarkMovesPerHour rdf:type rdf:Property ;
    rdfs:label 'Kpi Benchmark Moves Per Hour' ;
    rdfs:comment 'Industry benchmark productivity rate for equipment in this class, measured in moves per hour. Used for performance target setting and operational efficiency analysis.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle status of the equipment class in the classification hierarchy. Deprecated or obsolete classes are retained for historical asset tracking but not used for new acquisitions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceComplexity rdf:type rdf:Property ;
    rdfs:label 'Maintenance Complexity' ;
    rdfs:comment 'Relative complexity of maintenance operations for this equipment class. Influences spare parts inventory levels, technician skill requirements, and maintenance cost forecasting.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerStandard rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Standard' ;
    rdfs:comment 'Typical or recommended manufacturers for this equipment class (e.g., Liebherr, Konecranes, Kalmar, ZPMC). Used for procurement and spare parts compatibility.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Industry benchmark or historical average MTBF for equipment in this class, measured in operational hours. Used for reliability planning and spare parts optimization.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Industry benchmark or historical average MTTR for equipment in this class, measured in hours. Critical for downtime forecasting and service level planning.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobilityType rdf:type rdf:Property ;
    rdfs:label 'Mobility Type' ;
    rdfs:comment 'Mobility characteristic of equipment in this class. Influences yard planning, operational flexibility, and infrastructure requirements.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseLevelDb rdf:type rdf:Property ;
    rdfs:label 'Noise Level Db' ;
    rdfs:comment 'Typical operational noise level for equipment in this class, measured in decibels. Required for occupational health compliance and environmental monitoring.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalSpeedRange rdf:type rdf:Property ;
    rdfs:label 'Operational Speed Range' ;
    rdfs:comment 'Typical operational speed range for this equipment class (e.g., 20-30 moves/hour for STS cranes, 15-25 km/h for AGVs). Used for performance benchmarking and KPI target setting.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Operator Certification Required' ;
    rdfs:comment 'Indicates whether specialized operator certification or licensing is required to operate equipment in this class. Drives workforce training and competency management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorSkillLevel rdf:type rdf:Property ;
    rdfs:label 'Operator Skill Level' ;
    rdfs:comment 'Minimum operator skill level required for safe and efficient operation of equipment in this class. Used for workforce planning and training program design.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerSource rdf:type rdf:Property ;
    rdfs:label 'Power Source' ;
    rdfs:comment 'Primary power source for equipment in this class. Critical for environmental reporting, energy management, and emissions tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualValuePercentage rdf:type rdf:Property ;
    rdfs:label 'Residual Value Percentage' ;
    rdfs:comment 'Expected residual or salvage value at end of useful life, expressed as a percentage of original acquisition cost. Used in depreciation calculations.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyRiskRating rdf:type rdf:Property ;
    rdfs:label 'Safety Risk Rating' ;
    rdfs:comment 'Inherent safety risk level associated with operation of equipment in this class. Influences safety protocols, training requirements, and incident response planning.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsCategory rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Category' ;
    rdfs:comment 'Standardized spare parts category or family associated with this equipment class. Enables cross-equipment spare parts compatibility mapping and inventory optimization.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swlRatingMaxTonnes rdf:type rdf:Property ;
    rdfs:label 'Swl Rating Max Tonnes' ;
    rdfs:comment 'Maximum Safe Working Load rating for equipment in this class, measured in metric tonnes. Defines upper operational capacity boundary.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swlRatingMinTonnes rdf:type rdf:Property ;
    rdfs:label 'Swl Rating Min Tonnes' ;
    rdfs:comment 'Minimum Safe Working Load rating for equipment in this class, measured in metric tonnes. Critical for operational safety and compliance.' ;
    rdfs:domain ind:EquipmentClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceViolationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Id' ;
    rdfs:comment 'Foreign key linking to compliance.violation. Business justification: Equipment failures causing oil spills, cargo damage, or safety incidents trigger regulatory violations. Port authorities must link failure reports to compliance violation records for incident investig' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Violation .

ind:ohsIncidentId rdf:type rdf:Property ;
    rdfs:label 'Ohs Incident Id' ;
    rdfs:comment 'Reference to the associated OHS incident record if the failure resulted in injury, near-miss, or safety event requiring formal investigation and reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OhsIncident .

ind:previousFailureReportId rdf:type rdf:Property ;
    rdfs:label 'Previous Failure Report Id' ;
    rdfs:comment 'Reference to the previous failure report for the same asset or component if this is a recurrence. Enables failure pattern analysis and chronic issue tracking.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureReport .

ind:reportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reported By Employee Id' ;
    rdfs:comment 'Reference to the employee (operator, supervisor, or maintenance technician) who first reported the failure event.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:responsiblePartyPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: When asset failures involve third-party operated equipment or contractor-maintained assets, the responsible port community participant must be formally tracked for liability determination, warranty cl' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:affectedComponent rdf:type rdf:Property ;
    rdfs:label 'Affected Component' ;
    rdfs:comment 'The specific component or part that failed (e.g., motor bearing, hydraulic pump, wire rope, brake pad, PLC module, sensor). Supports root cause analysis and spare parts inventory optimization.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystem rdf:type rdf:Property ;
    rdfs:label 'Affected System' ;
    rdfs:comment 'The major system or subsystem of the asset that was affected by the failure (e.g., hoist system, trolley drive, spreader mechanism, boom structure, control system).' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ambientTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature C' ;
    rdfs:comment 'Ambient temperature in degrees Celsius at the time of failure. Relevant for temperature-sensitive equipment and thermal stress analysis.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:berthDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Berth Delay Minutes' ;
    rdfs:comment 'Total delay in minutes caused to vessel berthing or departure operations as a result of the equipment failure. Impacts SLA (Service Level Agreement) compliance and customer satisfaction.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Recommendation' ;
    rdfs:comment 'Recommended corrective actions to prevent recurrence, such as design modifications, maintenance procedure changes, operator training, or spare parts stocking adjustments.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyclesAtFailure rdf:type rdf:Property ;
    rdfs:label 'Cycles At Failure' ;
    rdfs:comment 'Total cumulative operational cycles (e.g., crane lifts, RTG moves) of the asset at the time of failure. Used for cycle-based reliability and fatigue analysis.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysSinceLastPm rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Pm' ;
    rdfs:comment 'Number of days elapsed between the last preventive maintenance service and the failure event. Key metric for maintenance interval optimization.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectionDatetime rdf:type rdf:Property ;
    rdfs:label 'Detection Datetime' ;
    rdfs:comment 'The date and time when the failure was first detected or reported, which may differ from the actual failure occurrence time.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'Total equipment downtime in hours from failure occurrence to return to service. Critical KPI for MTTR (Mean Time To Repair) and availability calculations.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Flag' ;
    rdfs:comment 'Boolean indicator of whether the equipment failure resulted in environmental impact such as fluid spills, emissions, or other environmental incidents requiring reporting under MARPOL or ISO 14001.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost' ;
    rdfs:comment 'Estimated cost of repair in local currency based on initial assessment. Used for budgeting, financial impact analysis, and CAPEX/OPEX planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureClass rdf:type rdf:Property ;
    rdfs:label 'Failure Class' ;
    rdfs:comment 'Primary classification of the failure type: mechanical, electrical, hydraulic, structural, software, or pneumatic. Enables targeted maintenance strategy and spare parts planning.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDatetime rdf:type rdf:Property ;
    rdfs:label 'Failure Datetime' ;
    rdfs:comment 'The exact date and time when the equipment failure occurred. Critical for MTBF (Mean Time Between Failures) calculation and downtime analysis.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Detailed narrative description of the failure event, including symptoms observed, conditions at time of failure, and any unusual circumstances. Critical for root cause analysis and knowledge management.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Classification of how the equipment failed: complete breakdown, degraded performance, intermittent fault, safety shutdown, overload trip, or component wear. Used for failure mode and effects analysis (FMEA).' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureRecurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Failure Recurrence Flag' ;
    rdfs:comment 'Boolean indicator of whether this failure is a recurrence of a previously reported failure on the same asset or component. Used to identify chronic reliability issues.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureReportNumber rdf:type rdf:Property ;
    rdfs:label 'Failure Report Number' ;
    rdfs:comment 'Business-facing unique identifier for the failure report, typically formatted as FR-YYYYMMDD or similar pattern for external reference and tracking.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureSeverity rdf:type rdf:Property ;
    rdfs:label 'Failure Severity' ;
    rdfs:comment 'Severity classification of the failure impact: critical (complete operational stoppage), major (significant capacity reduction), moderate (partial degradation), or minor (minimal impact).' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of immediate corrective or containment actions taken at the time of failure to mitigate safety risks, prevent further damage, or restore partial operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationAssignedTo rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned To' ;
    rdfs:comment 'Reference to the maintenance engineer or reliability analyst assigned to investigate the root cause of the failure and complete the failure analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Date when the failure investigation and root cause analysis were completed. Used to track investigation cycle time and closure performance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPmDate rdf:type rdf:Property ;
    rdfs:label 'Last Pm Date' ;
    rdfs:comment 'Date of the last completed preventive maintenance service prior to the failure. Used to analyze correlation between maintenance intervals and failure occurrence.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadAtFailureTonnes rdf:type rdf:Property ;
    rdfs:label 'Load At Failure Tonnes' ;
    rdfs:comment 'The load being handled by the equipment in tonnes at the time of failure. Critical for overload analysis and SWL (Safe Working Load) compliance verification.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceStatusAtFailure rdf:type rdf:Property ;
    rdfs:label 'Maintenance Status At Failure' ;
    rdfs:comment 'The preventive maintenance status of the asset at the time of failure: current (up to date), overdue, recently completed, in warranty, or out of warranty. Used to correlate failures with maintenance compliance.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursAtFailure rdf:type rdf:Property ;
    rdfs:label 'Operating Hours At Failure' ;
    rdfs:comment 'Total cumulative operating hours of the asset at the time of failure. Critical for age-based reliability analysis and MTBF calculation.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Operational Impact Description' ;
    rdfs:comment 'Narrative description of the operational impact caused by the failure, including effects on vessel operations, cargo handling, berth availability, and terminal throughput.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority classification for the corrective maintenance work: emergency (immediate safety risk), urgent (critical operations impact), high, medium, or low. Drives work order scheduling and resource allocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the failure report: draft, submitted, under investigation, analysis complete, or closed. Tracks the failure investigation and resolution workflow.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByRole rdf:type rdf:Property ;
    rdfs:label 'Reported By Role' ;
    rdfs:comment 'The role or position of the person who reported the failure: operator, supervisor, maintenance technician, safety officer, or shift manager.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the failure after investigation, such as component fatigue, inadequate lubrication, operator error, design flaw, or environmental factors. May be populated after initial report during failure analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Boolean indicator of whether the equipment failure resulted in or was associated with a safety incident requiring OHS (Occupational Health and Safety) investigation or reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swlExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Swl Exceeded Flag' ;
    rdfs:comment 'Boolean indicator of whether the Safe Working Load rating of the equipment was exceeded at the time of failure. Critical for safety compliance and liability assessment.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teuThroughputLoss rdf:type rdf:Property ;
    rdfs:label 'Teu Throughput Loss' ;
    rdfs:comment 'Estimated loss in container handling capacity measured in TEU due to the equipment failure. Used for productivity impact analysis and financial loss calculation.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyClaimEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether the failure is eligible for warranty claim from the equipment manufacturer or supplier based on warranty terms and failure analysis.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Description of weather conditions at the time of failure (e.g., heavy rain, high wind, extreme temperature) that may have contributed to or influenced the failure event.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRecordId rdf:type rdf:Property ;
    rdfs:label 'Inspection Record Id' ;
    rdfs:comment 'Unique identifier for the inspection record. Primary key for the inspection_record data product.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceAuditId rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit. Business justification: Port facility audits (ISO 9001, ISPS, OHSAS 18001) require inspection records as objective evidence. Auditors verify that statutory inspections (SWL tests, crane certifications) were completed per sch' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceAudit .

ind:inspectionChecklistId rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Id' ;
    rdfs:comment 'Reference to the standardized inspection checklist or template used during the inspection. Ensures consistency and completeness of inspection procedures.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionChecklist .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Internal port asset inspections assign employees as inspectors. Tracks inspector assignment for compliance audits, workload planning, and certification verification. Inspector_name is denormalized emp' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inspectorPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Inspector Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: External inspectors (classification societies like Lloyd\'s, DNV; regulatory surveyors; certification bodies) must be registered port community participants for facility access and accreditation verifi' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:permitToWorkId rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Id' ;
    rdfs:comment 'Foreign key linking to safety.permit_to_work. Business justification: Asset inspections requiring hot work (NDT, welding inspection), confined space entry (tank inspections), or working at height require permits. Maritime regulations mandate permit tracking for inspecti' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitToWork .

ind:serviceEntrySheetId rdf:type rdf:Property ;
    rdfs:label 'Service Entry Sheet Id' ;
    rdfs:comment 'Foreign key linking to procurement.service_entry_sheet. Business justification: Third-party inspections (SWL certification, NDT testing, regulatory surveys) are procured services. Ports must link inspection completion to service entry sheets for payment release, three-way matchin' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceEntrySheet .

ind:swlCertificateId rdf:type rdf:Property ;
    rdfs:label 'Swl Certificate Id' ;
    rdfs:comment 'Foreign key linking to asset.swl_certificate. Business justification: Links SWL-specific inspection records to their corresponding SWL certificates. While inspection_record covers all inspection types (statutory, safety, operational, SWL), SWL inspections specifically v' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SwlCertificate .

ind:assetOperationalStatusAtInspection rdf:type rdf:Property ;
    rdfs:label 'Asset Operational Status At Inspection' ;
    rdfs:comment 'The operational status of the asset at the time of inspection. Indicates whether the asset was in active use, idle, undergoing maintenance, or out of service during the inspection.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'The date on which the inspection certificate expires. After this date, the asset may not be legally operated until re-inspected and re-certified.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Indicates whether the asset meets all applicable regulatory and safety standards based on the inspection findings. Used for regulatory reporting and risk management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'The date by which corrective actions must be completed. Driven by regulatory requirements, safety considerations, or operational impact.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Detailed description of the corrective actions, repairs, or remediation work required to address the inspection findings. Provides guidance for maintenance planning and work order generation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defects Count' ;
    rdfs:comment 'Number of critical severity defects identified. Critical defects pose immediate safety risks or operational hazards requiring urgent corrective action.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectSeverityHighest rdf:type rdf:Property ;
    rdfs:label 'Defect Severity Highest' ;
    rdfs:comment 'The highest severity level among all defects identified during the inspection. Used for prioritization and escalation decisions.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Defects Identified Count' ;
    rdfs:comment 'Total number of defects, non-conformances, or issues identified during the inspection. Used for trend analysis and asset reliability metrics.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'High-level summary of the inspection findings. Provides an overview of the asset condition, compliance status, and key observations made during the inspection.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCost rdf:type rdf:Property ;
    rdfs:label 'Inspection Cost' ;
    rdfs:comment 'Total cost incurred for conducting the inspection, including inspector fees, equipment rental, and administrative expenses. Used for maintenance budget tracking and cost analysis.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the inspection cost. Enables multi-currency financial reporting and analysis.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'The date on which the inspection was conducted. Principal business event timestamp for the inspection activity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Inspection End Time' ;
    rdfs:comment 'Timestamp when the inspection activity was completed. Used to calculate inspection duration and resource utilization.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Business identifier for the inspection record. Externally-known unique reference number assigned to this inspection event for tracking and audit purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Overall pass/fail result of the inspection. Indicates whether the asset meets the required standards and is fit for continued operation. Conditional pass indicates minor issues that must be addressed within a specified timeframe.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportUrl rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Url' ;
    rdfs:comment 'Link or file path to the detailed inspection report document. Provides access to supporting documentation, photographs, and detailed findings.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Detailed description of the areas, systems, and components covered by the inspection. Defines the boundaries and extent of the inspection activity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Time' ;
    rdfs:comment 'Timestamp when the inspection activity commenced. Captures the precise start time for duration tracking and scheduling purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection record. Tracks whether the inspection is scheduled, in progress, completed, cancelled, or overdue.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection. Indicates the nature and purpose of the inspection: statutory (mandated by law), periodic safety (scheduled safety checks), pre-operational (before equipment use), condition assessment (asset health evaluation), Port State Control (PSC), International Ship and Port Facility Security (ISPS), load test, or Safe Working Load (SWL) verification. [ENUM-REF-CANDIDATE: statutory|periodic_safety|pre_operational|condition_assessment|psc|isps|load_test|swl_verification — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspector Authority' ;
    rdfs:comment 'The organization or regulatory body that the inspector represents. Examples include national maritime authority, Port State Control (PSC), International Maritime Organization (IMO), classification society, or internal maintenance department.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'Professional certification or license number of the inspector. Validates the inspectors qualifications and authority to conduct the inspection.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadTestPerformed rdf:type rdf:Property ;
    rdfs:label 'Load Test Performed' ;
    rdfs:comment 'Indicates whether a physical load test was performed during the inspection. Load tests are required for cranes and lifting equipment to verify structural integrity and capacity.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadTestWeight rdf:type rdf:Property ;
    rdfs:label 'Load Test Weight' ;
    rdfs:comment 'The weight in metric tonnes used during the load test. Typically set at a percentage above the Safe Working Load (SWL) to verify safety margins.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:majorDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Major Defects Count' ;
    rdfs:comment 'Number of major severity defects identified. Major defects significantly impact asset performance or compliance but do not pose immediate danger.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Defects Count' ;
    rdfs:comment 'Number of minor severity defects identified. Minor defects have limited impact on operations and can be addressed during routine maintenance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'The date by which the next inspection of this asset must be conducted. Calculated based on inspection frequency requirements, regulatory mandates, and asset condition.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of the specific regulation, standard, or code that mandates or governs this inspection. Examples include SOLAS Chapter V, ISPS Code Part A, national maritime safety regulations, or ISO standards.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional comments, observations, or notes recorded by the inspector. Captures contextual information not covered by structured fields.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swlRatingVerified rdf:type rdf:Property ;
    rdfs:label 'Swl Rating Verified' ;
    rdfs:comment 'The Safe Working Load (SWL) rating verified during the inspection, measured in metric tonnes. Critical for crane and lifting equipment inspections to ensure safe operational limits.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenancePlanId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plan Id' ;
    rdfs:comment 'Unique identifier for the preventive maintenance plan. Primary key. Inferred role: MASTER_RESOURCE (defines a maintenance plan as a managed resource/configuration).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenancePlan .

ind:contractorPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Contractor Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Maintenance plans are frequently executed by external contractors (OEM service providers, specialized marine engineers) who must be registered port community participants for port access and complianc' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:lastCompletedWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Last Completed Work Order Id' ;
    rdfs:comment 'Reference to the most recent work order that completed maintenance under this plan. Provides traceability to execution records.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:primaryMaintenanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for planning and scheduling maintenance under this plan. Links to the workforce employee registry.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_contract. Business justification: Planned maintenance is often executed under service contracts (crane maintenance, dredging, quay wall inspections). Ports link PM plans to contracts for automatic cost allocation, SLA compliance track' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:workOrderTemplateId rdf:type rdf:Property ;
    rdfs:label 'Work Order Template Id' ;
    rdfs:comment 'Reference to the work order template used for auto-generating work orders from this maintenance plan. Ensures consistency in work order structure and content.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrderTemplate .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date when the current revision of the maintenance plan was formally approved. Part of the plan lifecycle audit trail.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Classification of the asset type covered by this plan. STS (Ship-to-Shore crane), RTG (Rubber Tyred Gantry), ASC (Automated Stacking Crane), AGV (Automated Guided Vehicle), MHC (Mobile Harbour Crane), QC (Quay Crane), and other port equipment categories. [ENUM-REF-CANDIDATE: sts_crane|rtg|asc|agv|mhc|qc|forklift|port_vehicle|reach_stacker|terminal_tractor|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoGenerateWorkOrder rdf:type rdf:Property ;
    rdfs:label 'Auto Generate Work Order' ;
    rdfs:comment 'Indicates whether work orders should be automatically generated when the maintenance due date or meter reading is reached. True for routine preventive maintenance, false for plans requiring manual review.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certificate Required' ;
    rdfs:comment 'Indicates whether a compliance certificate or inspection report must be issued upon completion of maintenance under this plan. True for statutory and regulatory maintenance activities.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated total cost of executing maintenance under this plan, including labor, spare parts, consumables, and contractor services. Used for budgeting and CAPEX/OPEX planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Hours' ;
    rdfs:comment 'Estimated duration (in hours) that the asset will be out of service during maintenance execution. Critical for operational planning and berth/yard scheduling.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Estimated total labor hours required to complete the maintenance tasks. Used for resource planning, scheduling, and cost estimation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Last Completed Date' ;
    rdfs:comment 'The date when maintenance under this plan was last successfully completed. Used to calculate the next due date and track maintenance history.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Number of days in advance of the due date that the work order should be generated. Allows time for planning, resource allocation, and spare parts procurement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceFrequencyUnit rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency Unit' ;
    rdfs:comment 'Unit of measure for the maintenance frequency interval. Time-based plans use calendar units (days, weeks, months, years), meter-based plans use operational units (operating hours, cycles, TEU handled, lifts, kilometers). [ENUM-REF-CANDIDATE: days|weeks|months|years|operating_hours|cycles|teu_handled|lifts|kilometers — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceFrequencyValue rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency Value' ;
    rdfs:comment 'Numeric value representing the interval between maintenance activities. Interpreted in conjunction with frequency_unit (e.g., 30 days, 500 operating hours, 1000 TEU handled).' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meterReadingAtLastCompletion rdf:type rdf:Property ;
    rdfs:label 'Meter Reading At Last Completion' ;
    rdfs:comment 'The asset meter reading (operating hours, cycles, TEU handled, etc.) at the time of last maintenance completion. Used for meter-based maintenance scheduling.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'The next scheduled date when maintenance under this plan is due. Calculated based on the last completion date and the maintenance frequency. Used for work order generation and scheduling.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDueMeterReading rdf:type rdf:Property ;
    rdfs:label 'Next Due Meter Reading' ;
    rdfs:comment 'The asset meter reading at which the next maintenance is due. Applicable for meter-based maintenance plans. Triggers work order generation when the asset meter reaches this value.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemReference rdf:type rdf:Property ;
    rdfs:label 'Oem Reference' ;
    rdfs:comment 'Reference to the OEM maintenance manual, technical bulletin, or service recommendation that defines this maintenance plan. Ensures alignment with manufacturer specifications and warranty requirements.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name or title of the maintenance plan, describing the maintenance activity or scope.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known unique identifier for the maintenance plan, typically assigned by Maximo Asset Management. Used for cross-system reference and reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance plan. Active plans generate work orders, inactive plans are disabled, draft plans are under development, suspended plans are temporarily paused, and archived plans are retained for historical reference.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the maintenance plan strategy. Time-based plans trigger on calendar intervals, meter-based on usage counters (e.g., operating hours), condition-based on asset condition monitoring, predictive on analytics, corrective on failure, and statutory on regulatory compliance requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Reference to applicable regulatory or statutory requirements that mandate this maintenance plan (e.g., IMO regulations, PSC requirements, national maritime safety authority directives, environmental compliance).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTradeSkills rdf:type rdf:Property ;
    rdfs:label 'Required Trade Skills' ;
    rdfs:comment 'Comma-separated list of trade skills or certifications required to perform the maintenance tasks (e.g., electrician, hydraulic technician, crane operator, certified welder). Used for workforce planning and assignment.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department or organizational unit responsible for planning, scheduling, and executing maintenance under this plan (e.g., Engineering, Maintenance, Operations).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'The date when the current revision of the maintenance plan was approved and became effective. Tracks plan change history.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Version or revision number of the maintenance plan. Incremented when the plan is updated or modified. Supports change control and audit trail.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyProcedures rdf:type rdf:Property ;
    rdfs:label 'Safety Procedures' ;
    rdfs:comment 'Applicable safety procedures, permits, and precautions required during maintenance execution. Includes lockout/tagout (LOTO), confined space entry, hot work permits, and personal protective equipment (PPE) requirements.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalAdjustment rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment' ;
    rdfs:comment 'Seasonal adjustment factor for maintenance scheduling. Some maintenance activities are preferentially scheduled during specific seasons or operational periods (e.g., off-peak season, favorable weather conditions).' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaRequirement rdf:type rdf:Property ;
    rdfs:label 'Sla Requirement' ;
    rdfs:comment 'Service Level Agreement requirements or performance targets associated with this maintenance plan (e.g., maximum response time, uptime targets, availability guarantees). Aligns maintenance planning with operational commitments.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskChecklist rdf:type rdf:Property ;
    rdfs:label 'Task Checklist' ;
    rdfs:comment 'Structured checklist or step-by-step instructions for executing the maintenance tasks. Ensures consistency and completeness of maintenance activities.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed description of the maintenance tasks and procedures to be performed under this plan. May reference OEM (Original Equipment Manufacturer) maintenance manuals, safety procedures, and technical specifications.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Operator Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Port assets (cranes, tugs, forklifts) are often operated by specific terminal operators or stevedoring companies who are registered port community participants. Essential for: asset responsibility tra' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:owningCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Owning Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Every port asset must be assigned to a cost centre for financial accountability, budget allocation, and management reporting. Essential for asset ownership tracking and cost allocation in port operati' ;
    rdfs:domain ind:PortAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:parentAssetPortAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Port Asset Id' ;
    rdfs:comment 'Reference to the parent asset in a hierarchical asset structure. Used for sub-assemblies and component tracking. Null for top-level assets.' ;
    rdfs:domain ind:PortAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortAsset .

ind:portLocationId rdf:type rdf:Property ;
    rdfs:label 'Port Location Id' ;
    rdfs:comment 'Foreign key linking to masterdata.port_location. Business justification: Every fixed port asset (crane, bollard, fender, gate, building) has a permanent or assigned location within port geography (berth, yard block, terminal zone) - fundamental for asset tracking, maintena' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortLocation .

ind:vesselMasterId rdf:type rdf:Property ;
    rdfs:label 'Vessel Master Id' ;
    rdfs:comment 'Foreign key linking to masterdata.vessel_master. Business justification: Port-owned mobile harbor assets (tugs, pilot boats, survey vessels, floating cranes) are vessels requiring IMO registration, classification society certification, flag state compliance, and insurance ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VesselMaster .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'Detailed sub-classification within the asset class. Examples: STS (Ship-to-Shore crane), QC (Quay Crane), RTG (Rubber Tyred Gantry), ASC (Automated Stacking Crane), AGV (Automated Guided Vehicle), MHC (Mobile Harbour Crane).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed textual description of the asset including make, model, and distinguishing characteristics.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique business identifier for the asset. Used across operational systems and maintenance records. Sourced from Maximo Asset Management or SAP PM.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current operational status of the asset. Indicates availability for operations and maintenance state.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexClassification rdf:type rdf:Property ;
    rdfs:label 'Capex Classification' ;
    rdfs:comment 'Classification of the capital expenditure type that funded the asset acquisition or major enhancement.' ;
    rdfs:domain ind:PortAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityRating rdf:type rdf:Property ;
    rdfs:label 'Criticality Rating' ;
    rdfs:comment 'Business criticality classification indicating the impact of asset failure on port operations. Used for prioritizing maintenance and spare parts inventory.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Current net book value of the asset after accumulated depreciation. Updated periodically based on depreciation schedule.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Operational system of record from which this asset data was sourced. Primary sources are Maximo Asset Management and SAP PM.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the asset was permanently removed from service. Null for assets still in service.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grt rdf:type rdf:Property ;
    rdfs:label 'Grt' ;
    rdfs:comment 'Gross Registered Tonnage for marine assets where applicable. Measure of overall internal volume.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imoNumber rdf:type rdf:Property ;
    rdfs:label 'Imo Number' ;
    rdfs:comment 'IMO identification number for marine assets where applicable. Permanent reference number assigned by the International Maritime Organization.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent safety or compliance inspection performed on the asset.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Primary maintenance approach applied to this asset. Determines scheduling and resource allocation for maintenance activities.' ;
    rdfs:domain ind:PortAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) who produced the asset.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailures rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures' ;
    rdfs:comment 'Average time in hours between asset failures. Key performance indicator for asset reliability and maintenance effectiveness.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeToRepair rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair' ;
    rdfs:comment 'Average time in hours required to restore the asset to operational status after a failure. Indicator of maintenance efficiency.' ;
    rdfs:domain ind:PortAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Manufacturer\'s model number or designation for the asset.' ;
    rdfs:domain ind:PortAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrt rdf:type rdf:Property ;
    rdfs:label 'Nrt' ;
    rdfs:comment 'Net Registered Tonnage for marine assets where applicable. Measure of revenue-earning capacity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Cumulative operating hours logged by the asset since commissioning. Used for usage-based maintenance scheduling and lifecycle analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagCode rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Code' ;
    rdfs:comment 'RFID tag identifier attached to the asset for automated tracking and location monitoring within the port facility.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer\'s unique serial number assigned to this specific asset unit. Used for warranty claims and parts ordering.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swlRating rdf:type rdf:Property ;
    rdfs:label 'Swl Rating' ;
    rdfs:comment 'Maximum load capacity in metric tonnes that the asset is certified to handle safely. Critical for cranes, RTGs, ASCs, and lifting equipment. Compliance with SOLAS and port safety regulations.' ;
    rdfs:domain ind:PortAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturer\'s warranty coverage expires. Null if no warranty or warranty has already expired.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yearOfManufacture rdf:type rdf:Property ;
    rdfs:label 'Year Of Manufacture' ;
    rdfs:comment 'Calendar year in which the asset was manufactured by the OEM.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sparePartId rdf:type rdf:Property ;
    rdfs:label 'Spare Part Id' ;
    rdfs:comment 'Unique identifier for the spare part record. Primary key for the spare part master catalogue.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePart .

ind:commodityCodeId rdf:type rdf:Property ;
    rdfs:label 'Commodity Code Id' ;
    rdfs:comment 'Foreign key linking to masterdata.commodity_code. Business justification: Spare parts are imported/exported goods requiring HS code classification for customs clearance, import duty calculation, trade compliance reporting, and controlled goods licensing (especially for dual' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityCode .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Spare parts inventory must map to GL accounts for balance sheet reporting and inventory valuation. Essential for financial statement preparation and inventory accounting in port operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Foreign key linking to procurement.material_master. Business justification: Spare parts are materials in the procurement master data system. Ports need unified material master records for MRP runs, inventory valuation, procurement planning, and cross-system reconciliation bet' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC inventory classification based on value and usage frequency. A-items are high-value/high-usage, C-items are low-value/low-usage. Used for inventory control strategy.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualUsageQuantity rdf:type rdf:Property ;
    rdfs:label 'Annual Usage Quantity' ;
    rdfs:comment 'Total quantity consumed in the past 12 months. Used for demand forecasting, reorder point calculations, and ABC classification.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalityClassification rdf:type rdf:Property ;
    rdfs:label 'Criticality Classification' ;
    rdfs:comment 'Business criticality rating of the spare part based on impact to port operations if unavailable. Critical parts support STS, QC, and other mission-critical equipment. Used for inventory prioritization and stocking decisions.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgClass rdf:type rdf:Property ;
    rdfs:label 'Imdg Class' ;
    rdfs:comment 'IMDG classification code for hazardous materials (e.g., Class 3 - Flammable Liquids, Class 8 - Corrosives). Required for compliance with maritime safety regulations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeablePartNumber rdf:type rdf:Property ;
    rdfs:label 'Interchangeable Part Number' ;
    rdfs:comment 'Alternative or substitute part number that can be used in place of this spare part. Supports supply chain flexibility and obsolescence management.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Issue Date' ;
    rdfs:comment 'Date when this spare part was last issued from inventory for a work order or maintenance activity. Used for usage pattern analysis and demand forecasting.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the most recent purchase order for this spare part. Used for procurement pattern analysis and supplier performance tracking.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level' ;
    rdfs:comment 'Minimum inventory quantity threshold below which replenishment should be triggered. Safety stock level to prevent stockouts for critical operations.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsolescenceStatus rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Status' ;
    rdfs:comment 'Lifecycle status indicating whether the part is actively supported by the manufacturer or approaching end-of-life. Critical for long-term asset maintenance planning.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partCategory rdf:type rdf:Property ;
    rdfs:label 'Part Category' ;
    rdfs:comment 'High-level classification of the spare part by functional category. Used for inventory organization and procurement planning.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partDescription rdf:type rdf:Property ;
    rdfs:label 'Part Description' ;
    rdfs:comment 'Detailed textual description of the spare part including technical specifications, dimensions, and functional characteristics. Used for identification and procurement purposes.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'Internal part number assigned by the port authority for inventory management and procurement. Unique identifier used across Maximo Asset Management and SAP MM Materials Management systems.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical inventory quantity available in stock across all storage locations. Real-time balance maintained by Maximo Spare Parts Inventory and SAP MM.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnOrder rdf:type rdf:Property ;
    rdfs:label 'Quantity On Order' ;
    rdfs:comment 'Quantity currently on purchase orders awaiting delivery from suppliers. Used for inventory planning and replenishment forecasting.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity currently reserved for planned work orders or maintenance activities but not yet issued. Used for available-to-promise calculations.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory level at which a purchase requisition should be automatically generated. Calculated based on lead time demand and safety stock requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'Standard quantity to order when replenishment is triggered. Economic order quantity (EOQ) or fixed lot size based on procurement strategy.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum storage duration in days before the spare part expires or degrades. Applicable to consumables, lubricants, seals, and time-sensitive components.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sparePartStatus rdf:type rdf:Property ;
    rdfs:label 'Spare Part Status' ;
    rdfs:comment 'Current lifecycle status of the spare part master record. Active parts are available for procurement and issue; inactive parts are blocked from transactions.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical warehouse location identifier including warehouse code, aisle, rack, bin, and shelf position. Supports efficient picking and putaway operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'Total inventory value calculated as quantity on hand multiplied by unit cost. Used for financial reporting and asset valuation per IAS 2 Inventories.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN identification number for hazardous materials (e.g., UN1203 for gasoline). Required for transport documentation and safety data sheets.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard unit cost of the spare part in the port\'s base currency. Used for inventory valuation and budgeting. Sourced from SAP MM Materials Management.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Standard unit of measure for inventory counting and procurement (e.g., each, meter, kilogram, liter, box, set). Aligns with SAP MM Materials Management UOM standards.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Identifier for the warehouse or storage facility where the spare part is stocked. Supports multi-warehouse inventory management across port terminals.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Manufacturer warranty period in months from date of purchase. Used for warranty claim tracking and supplier performance evaluation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableStandard rdf:type rdf:Property ;
    rdfs:label 'Applicable Standard' ;
    rdfs:comment 'The regulatory or technical standard(s) under which the certificate was issued (e.g., SOLAS Chapter II-1, ISO 9927-1, AS 2550, national maritime safety regulations). May list multiple standards separated by semicolons.' ;
    rdfs:domain ind:SwlCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'URL or file path to the digitally stored copy of the physical SWL certificate document (PDF, image, or other format).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate number assigned by the issuing authority or classification society. This is the externally-known identifier for the certificate.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the SWL certificate. Valid = in force, Expired = past expiry date, Suspended = temporarily invalid, Revoked = permanently cancelled, Pending Renewal = renewal in progress.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the equipment is currently in compliance with SWL certification requirements. True = compliant (valid certificate), False = non-compliant (expired, suspended, or revoked certificate).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Manufacturer serial number or asset tag of the equipment being certified. Used for cross-reference and audit trail.' ;
    rdfs:domain ind:SwlCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type of lifting equipment covered by this certificate. STS = Ship-to-Shore crane, QC = Quay Crane, MHC = Mobile Harbour Crane, RTG = Rubber Tyred Gantry, ASC = Automated Stacking Crane, AGV = Automated Guided Vehicle. [ENUM-REF-CANDIDATE: STS|QC|MHC|RTG|ASC|AGV|Forklift|Spreader|Mobile Crane|Gantry Crane|Other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the SWL certificate expires and the equipment must be re-certified. Triggers maintenance or re-certification workflows.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Months' ;
    rdfs:comment 'Required frequency of SWL inspections and re-certification in months (e.g., 12, 24, 60 months) as mandated by regulatory authority or classification society.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the SWL certificate was officially issued by the certifying authority. This is the effective start date of the certificate.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the classification society, accredited surveyor, or regulatory body that issued the SWL certificate (e.g., Lloyd\'s Register, DNV GL, Bureau Veritas, National Maritime Safety Authority).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Sent Date' ;
    rdfs:comment 'Date on which the renewal notification was sent to the responsible maintenance team or asset manager, typically 30-90 days before expiry.' ;
    rdfs:domain ind:SwlCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Surveyor License Number' ;
    rdfs:comment 'Professional license or accreditation number of the surveyor who conducted the inspection.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorName rdf:type rdf:Property ;
    rdfs:label 'Surveyor Name' ;
    rdfs:comment 'Full name of the certified surveyor or inspector who conducted the load test and issued the certificate.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date on which the load test was conducted by the surveyor or classification society.' ;
    rdfs:domain ind:SwlCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testLoadTonnes rdf:type rdf:Property ;
    rdfs:label 'Test Load Tonnes' ;
    rdfs:comment 'The actual test load applied during the load test, typically 125% of the SWL rating, as required by maritime safety regulations.' ;
    rdfs:domain ind:SwlCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testLocation rdf:type rdf:Property ;
    rdfs:label 'Test Location' ;
    rdfs:comment 'Physical location where the load test was conducted (e.g., terminal name, berth number, workshop).' ;
    rdfs:domain ind:SwlCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Method used to conduct the load test and certification (e.g., static load test, dynamic load test, non-destructive testing, visual inspection).' ;
    rdfs:domain ind:SwlCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Outcome of the load test. Pass = equipment meets SWL requirements, Fail = equipment does not meet requirements, Conditional Pass = meets requirements with noted conditions or limitations.' ;
    rdfs:domain ind:SwlCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWorkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Work Employee Id' ;
    rdfs:comment 'Reference to the maintenance supervisor or foreman responsible for overseeing this work order execution. Links to employee entity for contact details and accountability.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_requisition. Business justification: Maintenance work orders trigger procurement requisitions for parts and services not in stock. This is core MRO workflow in ports—linking work orders to requisitions enables tracking of maintenance-dri' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:tertiaryWorkApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Work Approved By Employee Id' ;
    rdfs:comment 'Reference to the maintenance manager or authorized approver who approved this work order for execution. Required for work orders above certain cost thresholds or priority levels.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workforceStevedoreGangId rdf:type rdf:Property ;
    rdfs:label 'Workforce Stevedore Gang Id' ;
    rdfs:comment 'Reference to the maintenance crew or work gang assigned to execute this work order. Links to workforce gang entity for crew composition, skills, and availability.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gang .

ind:actualContractorCost rdf:type rdf:Property ;
    rdfs:label 'Actual Contractor Cost' ;
    rdfs:comment 'Actual cost for external contractor or vendor services consumed during work order execution, captured from vendor invoices. Expressed in the port\'s functional currency. Used for cost accounting and vendor performance evaluation.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when maintenance work was completed. Captured when work order status changes to completed. Used for schedule adherence analysis, downtime calculation, and Mean Time To Repair (MTTR) metrics.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLabourHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labour Hours' ;
    rdfs:comment 'Actual total labour hours consumed to complete the work order, captured from time attendance records. Used for cost accounting, productivity analysis, and future estimation accuracy improvement.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Actual Material Cost' ;
    rdfs:comment 'Actual total cost of spare parts, consumables, and materials consumed during work order execution, captured from inventory transactions and purchase orders. Expressed in the port\'s functional currency. Used for cost accounting and budget variance analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when maintenance work commenced. Captured when work order status changes to in_progress. Used for schedule adherence analysis and downtime tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for why the work order was cancelled. Populated only if work_order_status is cancelled. Used for process improvement and understanding maintenance planning effectiveness.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDatetime rdf:type rdf:Property ;
    rdfs:label 'Completion Datetime' ;
    rdfs:comment 'Date and time when the work order was officially closed and marked as completed in the system. Distinct from actual_end_datetime which captures when physical work finished. Used for work order lifecycle tracking and performance reporting.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdDatetime rdf:type rdf:Property ;
    rdfs:label 'Created Datetime' ;
    rdfs:comment 'Date and time when the work order record was first created in the system. Used for audit trail and work order aging analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentShutdownRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Shutdown Required Flag' ;
    rdfs:comment 'Indicates whether the asset must be completely shut down and de-energized for this maintenance work. True = shutdown required; False = work can be performed while asset is operational or in standby. Used for operational planning and safety risk assessment.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedContractorCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Contractor Cost' ;
    rdfs:comment 'Planned cost for external contractor or vendor services required for the work order, estimated during planning. Expressed in the port\'s functional currency. Null if work is performed entirely by internal crews.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLabourHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labour Hours' ;
    rdfs:comment 'Planned total labour hours required to complete the work order, estimated during work order planning. Used for crew scheduling and cost estimation.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Material Cost' ;
    rdfs:comment 'Planned total cost of spare parts, consumables, and materials required for the work order, estimated during planning. Expressed in the port\'s functional currency.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalWorkOrderReference rdf:type rdf:Property ;
    rdfs:label 'External Work Order Reference' ;
    rdfs:comment 'Reference number or identifier from the source system (Maximo, SAP PM) for cross-system reconciliation and traceability. Used for data integration and audit purposes.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Standardized code identifying the type of failure or maintenance need. Follows ISO 14224 taxonomy for equipment failure modes. Examples: ME-1001 (mechanical failure), EL-2003 (electrical fault), HY-3005 (hydraulic leak). Used for reliability analysis and failure trend reporting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Modified Datetime' ;
    rdfs:comment 'Date and time when the work order record was last updated. Used for audit trail and change tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partsAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Parts Availability Status' ;
    rdfs:comment 'Status of spare parts and materials required for the work order. Available = all parts in stock; On Order = parts ordered but not yet received; Backordered = parts delayed by supplier; Not Required = no parts needed. Used for work order scheduling and inventory planning.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned End Datetime' ;
    rdfs:comment 'Scheduled date and time when maintenance work is planned to be completed. Used for asset availability forecasting and operational planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Datetime' ;
    rdfs:comment 'Scheduled date and time when maintenance work is planned to begin. Used for crew scheduling, asset downtime planning, and operational coordination.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed description of the work performed, findings, corrective actions taken, and final resolution. Captured upon work order completion. Used for maintenance history, knowledge management, and future troubleshooting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the underlying cause of the failure or maintenance need, determined after work completion. Follows ISO 14224 root cause taxonomy. Examples: RC-1001 (wear and tear), RC-2003 (operator error), RC-3005 (design deficiency). Used for root cause analysis and continuous improvement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPermitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Permit Required Flag' ;
    rdfs:comment 'Indicates whether a safety work permit (hot work, confined space, work at height, etc.) is required for this work order per ISO 45001 and port safety regulations. True = permit required; False = no permit required.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalWorkOrderCost rdf:type rdf:Property ;
    rdfs:label 'Total Work Order Cost' ;
    rdfs:comment 'Total actual cost of the work order, including labour, materials, and contractor costs. Calculated as sum of actual_labour_hours * labour_rate + actual_material_cost + actual_contractor_cost. Expressed in the port\'s functional currency. Used for asset lifecycle costing and maintenance budget management.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether this work order is eligible for warranty claim against the equipment manufacturer or vendor. True = warranty claim submitted or eligible; False = no warranty claim. Used for cost recovery and vendor accountability.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyClaimReference rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Reference' ;
    rdfs:comment 'External reference number or identifier for the warranty claim submitted to the manufacturer or vendor. Populated only if warranty_claim_flag is true. Used for tracking warranty claim status and cost recovery.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDescription rdf:type rdf:Property ;
    rdfs:label 'Work Description' ;
    rdfs:comment 'Detailed description of the maintenance work to be performed, including scope, procedures, and safety requirements. Provides instructions to maintenance crews and context for work order execution.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle state of the work order. Draft = created but not approved; Approved = authorized for execution; Scheduled = assigned to crew with planned date; In Progress = work underway; On Hold = temporarily suspended; Completed = work finished and closed; Cancelled = work order voided. [ENUM-REF-CANDIDATE: draft|approved|scheduled|in_progress|on_hold|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the work order based on maintenance strategy. Preventive = scheduled maintenance per maintenance plan; Corrective = repair in response to failure; Emergency = urgent unplanned repair; Inspection = condition assessment; Overhaul = major refurbishment; Calibration = precision adjustment of equipment.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderTaskId rdf:type rdf:Property ;
    rdfs:label 'Work Order Task Id' ;
    rdfs:comment 'Unique identifier for the work order task. Primary key.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrderTask .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when this task was completed. Used for performance tracking and schedule variance analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when work on this task commenced. Used for performance tracking and schedule variance analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assetComponent rdf:type rdf:Property ;
    rdfs:label 'Asset Component' ;
    rdfs:comment 'Specific component or sub-assembly of the asset being maintained in this task, such as hoist motor, boom structure, or hydraulic cylinder on an STS crane.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationReference rdf:type rdf:Property ;
    rdfs:label 'Certification Reference' ;
    rdfs:comment 'Reference number of the certification or inspection report issued upon completion of this task. Links to regulatory compliance documentation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Indicates whether this task requires formal certification or sign-off by a qualified inspector or regulatory authority, such as Safe Working Load (SWL) certification for lifting equipment.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Detailed notes recorded by the technician upon task completion, including observations, issues encountered, corrective actions taken, and recommendations for future maintenance.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactNotes rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Notes' ;
    rdfs:comment 'Notes on environmental considerations or impacts related to this task, such as hazardous material handling, waste disposal, or emissions. Supports ISO 14001 compliance.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDowntimeRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Downtime Required' ;
    rdfs:comment 'Indicates whether the equipment must be taken out of service to perform this task. Critical for operational planning and berth allocation.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Outcome of inspection tasks. Indicates whether the inspected component meets operational and safety standards.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementReading rdf:type rdf:Property ;
    rdfs:label 'Measurement Reading' ;
    rdfs:comment 'Quantitative measurement or reading taken during the task, such as vibration levels, temperature, pressure, or electrical resistance. Stored as string to accommodate various units and formats.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who last modified this task record. Used for audit trail and accountability.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned End Timestamp' ;
    rdfs:comment 'Scheduled date and time when this task is planned to be completed. Used for maintenance scheduling and downtime planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedLabourHours rdf:type rdf:Property ;
    rdfs:label 'Planned Labour Hours' ;
    rdfs:comment 'Estimated number of labour hours required to complete this task. Used for resource planning and scheduling.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled date and time when this task is planned to begin. Used for maintenance scheduling and resource allocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:safetyPermitReference rdf:type rdf:Property ;
    rdfs:label 'Safety Permit Reference' ;
    rdfs:comment 'Reference number of the safety permit or work authorization required for this task, such as lock-out/tag-out (LOTO), hot work permit, confined space entry, or height work permit.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskPriority rdf:type rdf:Property ;
    rdfs:label 'Task Priority' ;
    rdfs:comment 'Priority level assigned to this task within the work order. Determines execution sequence when multiple tasks compete for resources.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Task Sequence Number' ;
    rdfs:comment 'Sequential ordering of this task within the parent work order. Defines the execution order of multi-step maintenance operations.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance task. Tracks progression from assignment through completion.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the maintenance task activity. Categorizes the nature of work to be performed. [ENUM-REF-CANDIDATE: inspection|repair|replacement|lubrication|calibration|testing|cleaning|adjustment — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLabourCost rdf:type rdf:Property ;
    rdfs:label 'Total Labour Cost' ;
    rdfs:comment 'Total labour cost for this task, calculated from actual labour hours and technician hourly rates. Used for maintenance cost allocation and budgeting.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaskCost rdf:type rdf:Property ;
    rdfs:label 'Total Task Cost' ;
    rdfs:comment 'Total cost of this task including labour, parts, and any additional charges. Rolls up to the overall work order cost.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeSkillRequired rdf:type rdf:Property ;
    rdfs:label 'Trade Skill Required' ;
    rdfs:comment 'Specialized trade or skill set required to perform this task, such as electrical, mechanical, hydraulic, or structural engineering expertise.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorServiceProvider rdf:type rdf:Property ;
    rdfs:label 'Vendor Service Provider' ;
    rdfs:comment 'Name of external vendor or contractor who performed this task, if not completed by internal workforce. Used for outsourced maintenance tracking.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Primary key for adjustment' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:billingCycleId rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_cycle. Business justification: Credit adjustments are posted to specific billing cycles for period accounting. The billing_cycle table contains fiscal_year and fiscal_period. This FK enables period-based adjustment reporting. Keeps' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCycle .

ind:closureId rdf:type rdf:Property ;
    rdfs:label 'Closure Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.infrastructure_closure. Business justification: Credits and adjustments for infrastructure outages (berth closure, channel restriction, gate downtime) must reference the specific closure event for revenue impact analysis and SLA-based compensation ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Closure .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Foreign key linking to billing.dispute. Business justification: Credit adjustments are often issued to resolve customer disputes. The adjustment table has dispute_reference_number (STRING), and dispute table has reference_number. Adding dispute_id FK enables direc' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:dredgingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Dredging Campaign Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.dredging_campaign. Business justification: Credits issued for service disruptions during dredging (berth closures, draft restrictions) must reference the dredging campaign for cost recovery tracking and customer dispute resolution. Links reven' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DredgingCampaign .

ind:exceptionId rdf:type rdf:Property ;
    rdfs:label 'Exception Id' ;
    rdfs:comment 'Foreign key linking to tariff.tariff_exception. Business justification: Credit notes issued for approved tariff exceptions (waivers, special rates, free time extensions) must reference the exception record for audit trail, revenue variance analysis, and to ensure adjustme' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Exception .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Reference to the original invoice being credited or adjusted. Links this credit note to the source billing document generated from NAVIS N4 billing module.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice_line. Business justification: Credit adjustments often apply to specific invoice line items (not just invoice headers). This FK enables line-level credit tracking. Keeps invoice_id on adjustment as adjustments can apply to entire ' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:participantAccountId rdf:type rdf:Property ;
    rdfs:label 'Participant Account Id' ;
    rdfs:comment 'Reference to the port community participant account receiving the credit adjustment. Identifies the customer or service recipient in the billing relationship.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParticipantAccount .

ind:portCallId rdf:type rdf:Property ;
    rdfs:label 'Port Call Id' ;
    rdfs:comment 'Reference to the vessel visit if the credit note relates to vessel-based services. Enables analysis of billing adjustments by vessel operation and service delivery performance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Call .

ind:reversalCreditNoteAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversal Credit Note Adjustment Id' ;
    rdfs:comment 'Reference to the reversing credit note if this credit note was subsequently cancelled. Creates bidirectional link for complete reversal audit trail.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:runId rdf:type rdf:Property ;
    rdfs:label 'Run Id' ;
    rdfs:comment 'Foreign key linking to billing.run. Business justification: Credit adjustments can be batch-generated during billing runs (e.g., automated credit processing). This FK enables tracking which billing run generated each adjustment, supporting batch processing and' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'Date when the credit note was applied to the customer\'s accounts receivable balance. Marks the effective date of revenue reversal in financial systems.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or identifier of the authorized person or role who approved the credit note issuance. Provides audit trail for financial control and segregation of duties compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Bill of Lading reference number if the credit note relates to cargo handling or Terminal Handling Charge (THC) adjustments. Links billing adjustment to specific cargo shipment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO 6346 standard container identification number if the credit relates to container handling charges. Follows format AAAA1234567 with owner code and serial number.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP S/4HANA CO cost center responsible for the service that generated the original charge. Enables operational performance analysis by business unit.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Gross monetary value of the credit being issued before tax adjustments. Represents the base revenue reversal amount in the port\'s operating currency.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditNoteDate rdf:type rdf:Property ;
    rdfs:label 'Credit Note Date' ;
    rdfs:comment 'Official issue date of the credit note document. Determines the accounting period for revenue reversal and financial reporting under IFRS 15 standards.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Note Number' ;
    rdfs:comment 'Externally visible business identifier for the credit note document. Follows port billing numbering convention CN-XXXXXXXX for audit trail and customer reference.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Note Status' ;
    rdfs:comment 'Current lifecycle state of the credit note in the billing adjustment workflow. Tracks progression from draft creation through approval, application to accounts receivable, or cancellation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Code' ;
    rdfs:comment 'Standardized classification code indicating the business reason for issuing the credit note. Used for revenue adjustment analysis, dispute tracking, and service quality monitoring. [ENUM-REF-CANDIDATE: billing_error|service_failure|tariff_adjustment|commercial_concession|dispute_resolution|overcharge|damaged_cargo|delayed_service|contract_amendment|goodwill — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the specific circumstances justifying the credit adjustment. Provides business context for audit, dispute resolution, and customer communication.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent' ;
    rdfs:comment 'Flag indicating whether formal notification of the credit note has been sent to the customer via Port Community System or EDI. Tracks communication compliance.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerReference rdf:type rdf:Property ;
    rdfs:label 'Customer Reference' ;
    rdfs:comment 'Customer-provided reference number or purchase order number associated with the original transaction. Facilitates customer reconciliation and accounts payable matching.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Confidential internal comments and notes regarding the credit note decision, approval rationale, or special handling instructions. Not shared with customer.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified the credit note record. Maintains complete audit trail of changes to billing adjustments.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when customer notification was transmitted. Provides audit trail for customer communication and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Original Charge Amount' ;
    rdfs:comment 'Original billed amount from the source invoice before credit adjustment. Provides reference for calculating credit percentage and analyzing billing accuracy.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'SAP S/4HANA CO profit center for revenue adjustment allocation. Supports segment reporting and EBITDA analysis by terminal or business division.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this credit note itself has been reversed or cancelled. Supports correction of erroneous credit notes and maintains complete audit trail.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapCreditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Credit Memo Number' ;
    rdfs:comment 'SAP S/4HANA FI credit memo document number generated upon posting to the financial accounting system. Provides integration reference between TOS billing and ERP financial records.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingDate rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Date' ;
    rdfs:comment 'Date when the credit memo was posted to SAP S/4HANA FI general ledger. Determines the accounting period for financial statement impact and EBITDA reporting.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the port service category for which the credit is being issued. Enables revenue adjustment analysis by service line and operational performance tracking. [ENUM-REF-CANDIDATE: vessel_services|cargo_handling|storage|equipment_rental|pilotage|towage|mooring|wharfage|terminal_handling|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Code' ;
    rdfs:comment 'Port tariff classification code for the service being credited. References the published port tariff schedule and enables tariff adjustment analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Amount' ;
    rdfs:comment 'Tax component of the credit adjustment, reversing previously charged VAT, GST, or other applicable port service taxes. Ensures compliance with tax authority reporting requirements.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'Total credit value including base credit amount and tax credit amount. Represents the full accounts receivable reduction applied to the customer account.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedHandlerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Handler Employee Id' ;
    rdfs:comment 'Reference to the internal employee assigned to investigate and resolve the dispute. Links to workforce employee record.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:crmServiceRequestId rdf:type rdf:Property ;
    rdfs:label 'Crm Service Request Id' ;
    rdfs:comment 'Reference to the associated service request record in Microsoft Dynamics 365 CRM. Links the billing dispute to the broader customer service case.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRequest .

ind:customsHoldId rdf:type rdf:Property ;
    rdfs:label 'Customs Hold Id' ;
    rdfs:comment 'Foreign key linking to compliance.customs_hold. Business justification: Billing disputes frequently arise from customs holds causing demurrage/detention charges. Dispute resolution requires linking to the hold record to verify legitimacy of charges, hold duration, and res' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomsHold .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the dispute was assigned to an internal handler for investigation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditNoteReference rdf:type rdf:Property ;
    rdfs:label 'Credit Note Reference' ;
    rdfs:comment 'Reference number of the credit note issued if the dispute was accepted (fully or partially). Links to the credit note record in SAP S/4HANA FI.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Email' ;
    rdfs:comment 'Email address of the customer contact who lodged the dispute. Primary channel for dispute correspondence.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactName rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Name' ;
    rdfs:comment 'Full name of the customer representative who lodged the dispute. Used for follow-up communications.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number of the customer contact for verbal follow-up on the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Post-resolution satisfaction rating provided by the customer on a scale of 1-5. Used for service quality monitoring and Key Performance Indicator (KPI) reporting.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeCategory rdf:type rdf:Property ;
    rdfs:label 'Dispute Category' ;
    rdfs:comment 'High-level categorization of the disputed charges by port service type. Enables dispute trend analysis by service line.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the dispute. Tracks progression from lodgement through investigation to final resolution. [ENUM-REF-CANDIDATE: lodged|under_investigation|pending_customer_response|pending_internal_review|resolved_accepted|resolved_rejected|resolved_partial_credit|withdrawn|escalated — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Total monetary value being disputed by the customer. Represents the portion of the invoice amount that the customer contests.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputedCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Disputed Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the disputed amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the dispute was escalated to a higher management level. Null if no escalation occurred.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Indicates the management level to which the dispute has been escalated, if applicable. Used for complex or high-value disputes requiring senior review.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Internal notes and findings recorded by the dispute handler during the investigation process. May include references to supporting documentation, system checks, and communication history.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who last modified the dispute record. Supports audit and accountability requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodgedDate rdf:type rdf:Property ;
    rdfs:label 'Lodged Date' ;
    rdfs:comment 'Date when the customer formally lodged the dispute against the invoice. Represents the business event timestamp for dispute initiation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lodgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lodged Timestamp' ;
    rdfs:comment 'Precise timestamp when the dispute was lodged in the system, including time zone. Used for SLA tracking and audit purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preventiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Taken' ;
    rdfs:comment 'Description of any preventive or corrective actions implemented to prevent recurrence of similar disputes. Supports continuous improvement initiatives.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Categorized reason for the dispute. Includes port-specific charge types such as Terminal Handling Charge (THC), Demurrage (DMG), Detention (DET), and Wharfage (WHR) disputes. [ENUM-REF-CANDIDATE: incorrect_rate|wrong_quantity|service_not_rendered|duplicate_charge|tariff_misapplication|thc_dispute|demurrage_dispute|detention_dispute|wharfage_dispute|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed free-text explanation provided by the customer describing the nature and basis of the dispute.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the dispute was formally resolved and closed. Used for SLA compliance reporting and dispute lifecycle analytics.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed explanation of the resolution decision, including rationale, policy references, and any corrective actions taken.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Final outcome classification of the dispute resolution. Indicates whether the dispute was accepted (full credit), rejected (no credit), partially accepted, withdrawn, or escalated.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualResolutionDays rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Resolution Days' ;
    rdfs:comment 'Actual number of business days taken to resolve the dispute. Calculated from lodged date to resolution date for SLA compliance reporting.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetResolutionDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Days' ;
    rdfs:comment 'Number of business days within which the dispute should be resolved according to the applicable SLA. Used for performance tracking.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingDocumentsReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents Reference' ;
    rdfs:comment 'Reference identifiers or file paths to supporting documentation provided by the customer (e.g., Bill of Lading (BOL), Delivery Order (D/O), email correspondence).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rerunOfBillingRunId rdf:type rdf:Property ;
    rdfs:label 'Rerun Of Billing Run Id' ;
    rdfs:comment 'Reference to the original billing run ID if this run is a rerun or correction of a previous failed or cancelled run. Null for original runs.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:runApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Run Approved By User Employee Id' ;
    rdfs:comment 'User identifier of the finance manager or authorized approver who approved the billing run for release. Null if approval is not required or not yet granted.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:runEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Run Employee Id' ;
    rdfs:comment 'User identifier or system account that initiated or executed the billing run. For scheduled runs, this may be a system service account; for ad-hoc runs, this is the manual operator.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this billing run requires manual approval before invoices are released to customers. True for high-value or adjustment runs; false for routine periodic runs.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the billing run was approved for invoice release. Null if approval is not required or not yet granted.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargeSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Charge Source System' ;
    rdfs:comment 'Source system from which billing charges were extracted: NAVIS-N4 (primary TOS), TOPS-EXPERT (alternate TOS), MANUAL (manual entry), or PCS (Port Community System for customs/trade charges).' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from run start to run end. Used for performance monitoring and capacity planning of billing batch jobs.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Date and time when the billing run execution completed or terminated. Null if run is still in-progress or suspended.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Number of errors or exceptions encountered during billing run execution. Zero indicates a clean run; non-zero requires review of error logs.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorSummary rdf:type rdf:Property ;
    rdfs:label 'Error Summary' ;
    rdfs:comment 'High-level summary description of errors encountered during the billing run. Null if no errors occurred. Detailed error logs are maintained separately.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date on which the billing run revenue was posted to the General Ledger in SAP S/4HANA FI. Null if GL posting has not yet occurred.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Invoice Release Timestamp' ;
    rdfs:comment 'Date and time when invoices from this billing run were released and made available to customers via EDI, email, or customer portal. Null if not yet released.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:navisExportBatchReference rdf:type rdf:Property ;
    rdfs:label 'Navis Export Batch Reference' ;
    rdfs:comment 'Reference identifier of the NAVIS N4 TOS charge export batch that sourced the billing data for this run. Provides traceability back to the Terminal Operating System.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionPeriod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Period' ;
    rdfs:comment 'Accounting period (YYYY-MM format) to which revenue from this billing run is recognized for financial reporting and EBITDA calculation purposes.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the billing run: scheduled (queued for execution), in-progress (actively processing), completed (successfully finished), failed (error encountered), cancelled (manually aborted), or suspended (paused pending resolution).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the billing run execution type: periodic (scheduled monthly/weekly), vessel-call (per vessel departure), ad-hoc (manual trigger), final (end-of-period close), adjustment (correction run), or reversal (cancellation run).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingBatchReference rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Batch Reference' ;
    rdfs:comment 'Reference identifier of the SAP S/4HANA FI posting batch where generated invoices were posted for financial accounting. Null if posting has not yet occurred or failed.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledRunDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Run Date' ;
    rdfs:comment 'Date on which this billing run was originally scheduled to execute. May differ from actual run start date if the run was delayed or rescheduled.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the billing run execution began processing charges from NAVIS N4 Terminal Operating System (TOS). Represents the actual start of the batch job.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalChargeLinesProcessed rdf:type rdf:Property ;
    rdfs:label 'Total Charge Lines Processed' ;
    rdfs:comment 'Total number of individual charge line items processed and aggregated into invoices during this billing run.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCustomersBilled rdf:type rdf:Property ;
    rdfs:label 'Total Customers Billed' ;
    rdfs:comment 'Distinct count of customer accounts that received at least one invoice in this billing run.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalInvoiceValue rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Value' ;
    rdfs:comment 'Aggregate monetary value of all invoices generated in this billing run, representing gross revenue before adjustments. Used for EBITDA-level revenue reporting.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoicesGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Invoices Generated' ;
    rdfs:comment 'Total number of invoices successfully generated and created during this billing run execution.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargeEventId rdf:type rdf:Property ;
    rdfs:label 'Charge Event Id' ;
    rdfs:comment 'Unique identifier for the charge event record. Primary key for the charge event entity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChargeEvent .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Charge approval is a critical authorization control point. Port operations require tracking which supervisor/manager approved each charge event for audit compliance and dispute resolution.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:chargeCallId rdf:type rdf:Property ;
    rdfs:label 'Charge Call Id' ;
    rdfs:comment 'FK to vessel.call.call_id — Revenue reconciliation requires joining every chargeable event to the vessel call that triggered it. Without this FK, billing disputes cannot be correlated to vessel visits — a daily operational requi' ;
    rdfs:domain ind:ChargeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Call .

ind:chargeVesselCallId rdf:type rdf:Property ;
    rdfs:label 'Charge Vessel Call Id' ;
    rdfs:comment 'Reference to the vessel call during which this charge event occurred. Links to the vessel operations domain.' ;
    rdfs:domain ind:ChargeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Call .

ind:complianceHsCodeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Hs Code Id' ;
    rdfs:comment 'Foreign key linking to compliance.hs_code. Business justification: Charge calculation for cargo services depends on commodity classification (dangerous goods handling, CITES-regulated cargo, dual-use items). Charge events reference HS codes for rate determination and' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HsCode .

ind:contractorSafetyId rdf:type rdf:Property ;
    rdfs:label 'Contractor Safety Id' ;
    rdfs:comment 'Foreign key linking to safety.contractor_safety. Business justification: Contractor safety induction fees, qualification verification charges, and safety compliance audit fees are billable services in port operations. Real business process: contractor safety service charge' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractorSafety .

ind:customsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Id' ;
    rdfs:comment 'Foreign key linking to compliance.customs_declaration. Business justification: Charge events for customs-related services (documentation fees, inspection charges, clearance processing) directly reference the declaration. Essential for real-time billing of customs services and fo' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomsDeclaration .

ind:drayageOrderId rdf:type rdf:Property ;
    rdfs:label 'Drayage Order Id' ;
    rdfs:comment 'Foreign key linking to intermodal.drayage_order. Business justification: Drayage services generate billable charge events. Ports must link charges to specific drayage orders for revenue reconciliation, service verification, and dispute resolution with hauliers. Essential f' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrayageOrder .

ind:legId rdf:type rdf:Property ;
    rdfs:label 'Leg Id' ;
    rdfs:comment 'Foreign key linking to intermodal.intermodal_leg. Business justification: Each intermodal leg (rail/truck segment) generates handling and transport charges. Ports track which charges apply to which leg for multi-modal billing, cost allocation across transport modes, and rev' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Leg .

ind:masterdataContainerTypeId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Container Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.container_type. Business justification: Charge events for container services require container type classification for accurate tariff lookup and TEU conversion. Essential for container terminal billing automation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerType .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Foreign key linking to billing.performance_obligation. Business justification: Each charge event satisfies a specific IFRS 15 performance obligation. The performance_obligation table defines revenue_recognition_method, satisfaction_criteria, and revenue account codes. This FK en' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:portGateId rdf:type rdf:Property ;
    rdfs:label 'Port Gate Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.port_gate. Business justification: Gate transaction charges (truck processing fees, RFID/OCR service charges) must reference which gate processed the transaction for gate-level revenue analysis and throughput-based billing validation. ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortGate .

ind:railVisitId rdf:type rdf:Property ;
    rdfs:label 'Rail Visit Id' ;
    rdfs:comment 'Foreign key linking to intermodal.rail_visit. Business justification: Rail terminal handling generates billable events (loading, unloading, storage). Linking charge events to rail visits enables service verification, supports billing accuracy audits, and facilitates dis' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RailVisit .

ind:rateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Id' ;
    rdfs:comment 'Foreign key linking to contract.rate_schedule. Business justification: Charge events (container handling, berth occupancy, pilotage) are priced per contracted rate schedules. Required for real-time tariff application, billing accuracy, and automated charge calculation in' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateSchedule .

ind:sanctionsScreeningId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_screening. Business justification: Charge events for sanctioned vessels/parties must be screened before billing. Real-time screening at charge capture prevents service provision to sanctioned entities and creates audit trail for compli' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsScreening .

ind:serviceCodeId rdf:type rdf:Property ;
    rdfs:label 'Service Code Id' ;
    rdfs:comment 'Code identifying the specific port service rendered that generated this charge event (e.g., container move, gate transaction, crane hire, reefer connection, hazardous handling).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCode .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to cargo.shipment. Business justification: Charge events capture billable activities; linking to shipment enables direct cargo-to-charge traceability for freight charges, surcharges, and ancillary fees. Supports charge validation against shipm' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:tradeDocumentId rdf:type rdf:Property ;
    rdfs:label 'Trade Document Id' ;
    rdfs:comment 'Foreign key linking to compliance.trade_document. Business justification: Charge events for document processing fees (certificate issuance, document verification, legalization services) reference specific trade documents. Essential for real-time billing of documentary servi' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeDocument .

ind:truckVisitId rdf:type rdf:Property ;
    rdfs:label 'Truck Visit Id' ;
    rdfs:comment 'Foreign key linking to intermodal.truck_visit. Business justification: Gate transactions and truck handling generate charges (gate fees, weighbridge, inspection). Linking charge_event to truck_visit enables automated billing from gate systems, supports haulier invoicing,' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TruckVisit .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current billing status of the charge event indicating whether it has been invoiced, is pending billing, has been disputed, waived, cancelled, or reversed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'Bill of Lading number associated with the cargo related to this charge event, if applicable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Cbm' ;
    rdfs:comment 'Volume of the cargo in cubic meters associated with this charge event, used for volume-based wharfage calculations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoWeightKg rdf:type rdf:Property ;
    rdfs:label 'Cargo Weight Kg' ;
    rdfs:comment 'Weight of the cargo in kilograms associated with this charge event, used for wharfage and weight-based charge calculations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Amount' ;
    rdfs:comment 'Calculated charge amount for this event before any adjustments, discounts, or taxes. Represents the base charge value.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyRate rdf:type rdf:Property ;
    rdfs:label 'Daily Rate' ;
    rdfs:comment 'Daily rate applied for demurrage or detention charges per excess day.' ;
    rdfs:domain ind:ChargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Discount amount applied to this charge event based on customer agreements or promotional tariffs.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean flag indicating whether this charge event is currently under dispute by the customer.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Description or code indicating the reason for the billing dispute, if the dispute flag is true.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the chargeable service event occurred in the operational system. This is the business event time, not the record creation time.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the charge event indicating whether it is a commercial service charge, statutory/regulatory charge, demurrage, detention, wharfage, or port dues.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessDays rdf:type rdf:Property ;
    rdfs:label 'Excess Days' ;
    rdfs:comment 'Number of days beyond the free time period for which demurrage or detention charges are calculated.' ;
    rdfs:domain ind:ChargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Flag' ;
    rdfs:comment 'Boolean flag indicating whether this charge event is exempt from billing due to contractual agreements, regulatory exemptions, or special circumstances.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Explanation or code indicating the reason for charge exemption, if the exemption flag is true.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeTimeDays rdf:type rdf:Property ;
    rdfs:label 'Free Time Days' ;
    rdfs:comment 'Number of free days allowed before demurrage or detention charges begin to accrue, as per tariff or customer agreement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freeTimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Free Time End Timestamp' ;
    rdfs:comment 'Date and time when the free time period ends and chargeable demurrage or detention time begins.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freeTimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Free Time Start Timestamp' ;
    rdfs:comment 'Date and time when the free time period begins for demurrage or detention calculation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Boolean flag indicating whether this charge event is related to hazardous cargo handling, which may attract additional charges per IMDG Code requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Charge Amount' ;
    rdfs:comment 'Net charge amount after applying discounts and adding taxes. This is the final billable amount for this charge event.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of the service unit rendered (e.g., number of moves, number of days, number of connections).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reeferFlag rdf:type rdf:Property ;
    rdfs:label 'Reefer Flag' ;
    rdfs:comment 'Boolean flag indicating whether this charge event is related to a refrigerated (reefer) container requiring power connection and monitoring services.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Business-facing unique reference number for the charge event, used for tracking and reconciliation across systems.' ;
    rdfs:domain ind:ChargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'Unique identifier or reference key from the source operational system that generated this charge event, used for traceability and reconciliation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statutoryAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Statutory Authority Reference' ;
    rdfs:comment 'Reference to the statutory authority, regulation, or legal framework under which statutory charges (wharfage, port dues, pilotage levies, navigation fees) are assessed.' ;
    rdfs:domain ind:ChargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Tax amount applied to this charge event based on applicable tax regulations and jurisdictions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'Rate per unit of measure applied from the tariff schedule to calculate the charge amount.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselGrt rdf:type rdf:Property ;
    rdfs:label 'Vessel Grt' ;
    rdfs:comment 'Gross Registered Tonnage of the vessel, used as a basis for calculating port dues and other vessel-based statutory charges.' ;
    rdfs:domain ind:ChargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselNrt rdf:type rdf:Property ;
    rdfs:label 'Vessel Nrt' ;
    rdfs:comment 'Net Registered Tonnage of the vessel, used for certain statutory charge calculations and regulatory reporting.' ;
    rdfs:domain ind:ChargeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitNoteId rdf:type rdf:Property ;
    rdfs:label 'Debit Note Id' ;
    rdfs:comment 'Unique identifier for the debit note record. Primary key.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DebitNote .

ind:ediMessageId rdf:type rdf:Property ;
    rdfs:label 'Edi Message Id' ;
    rdfs:comment 'Unique identifier for the EDI message used to transmit this debit note to the customer via Port Community System. Null if not transmitted via EDI.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiMessage .

ind:itemId rdf:type rdf:Property ;
    rdfs:label 'Item Id' ;
    rdfs:comment 'Foreign key linking to tariff.tariff_item. Business justification: Debit notes for additional charges (demurrage, detention, storage escalation) must reference the tariff item that defines the rate and calculation basis. Required for customer dispute resolution and t' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Item .

ind:primaryDebitApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Debit Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved the debit note for issuance. Null if not yet approved or if approval is not required.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDebitModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Debit Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who last modified the debit note record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'The date when the customer formally acknowledged or responded to the debit note. Null if not yet acknowledged.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The cost center or profit center code associated with the service that generated the debit note. Used for internal management accounting and profitability analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAcknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledgement Status' ;
    rdfs:comment 'Tracks whether the customer has acknowledged receipt and acceptance of the debit note. Values: not_sent (not yet transmitted), sent (transmitted but not acknowledged), acknowledged (customer accepted), rejected (customer disputed), pending_review (under customer review).' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Debit Note Number' ;
    rdfs:comment 'Externally-known unique business identifier for the debit note, typically formatted as DN- followed by numeric sequence. Used for customer communication and reference.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitReasonCode rdf:type rdf:Property ;
    rdfs:label 'Debit Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for issuing the debit note. Common values: DMG (Demurrage adjustment), DET (Detention extension), THC_ADJ (Terminal Handling Charge adjustment), BAF_ADJ (Bunker Adjustment Factor correction), SURCHARGE (Additional surcharge), PORT_DUES (Supplementary port dues), LATE_FEE (Late payment fee), PENALTY (Contractual penalty). [ENUM-REF-CANDIDATE: DMG|DET|THC_ADJ|BAF_ADJ|SURCHARGE|PORT_DUES|LATE_FEE|PENALTY — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Debit Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the debit note was issued, providing context beyond the reason code. Includes specific circumstances, dates, and reference information.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitStatus rdf:type rdf:Property ;
    rdfs:label 'Debit Status' ;
    rdfs:comment 'Current lifecycle status of the debit note in the billing workflow. Tracks progression from draft through approval, issuance, customer acknowledgement, and potential dispute or reversal. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|acknowledged|disputed|cancelled|reversed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which payment of the debit note amount is expected from the customer. Calculated based on payment terms.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Code representing the payment terms applicable to this debit note (e.g., NET30, NET60, COD). Determines due date calculation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date when the debit note was posted to the general ledger in SAP S/4HANA FI. Used for financial period assignment and revenue recognition.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date when the debit note was reversed or cancelled. Null if not reversed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this debit note has been reversed or cancelled. True if reversed, False if active. Reversed debit notes do not contribute to accounts receivable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Explanation for why the debit note was reversed. Null if not reversed. Documents the business justification for cancellation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDebitMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Debit Memo Number' ;
    rdfs:comment 'The SAP S/4HANA FI debit memo document number generated when the debit note is posted to the financial system. Links billing document to accounting records.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'The ending date of the service period or event that triggered the additional charge. Used for calculating duration-based fees.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'The beginning date of the service period or event that triggered the additional charge. Used for demurrage, detention, and time-based charges.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'The total amount of the debit note including all charges and taxes. Represents the net amount to be collected from the customer.' ;
    rdfs:domain ind:DebitNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningNoticeId rdf:type rdf:Property ;
    rdfs:label 'Dunning Notice Id' ;
    rdfs:comment 'Unique identifier for the dunning notice record. Primary key.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningRunId rdf:type rdf:Property ;
    rdfs:label 'Dunning Run Id' ;
    rdfs:comment 'Identifier for the batch dunning run that generated this notice, allowing grouping of notices issued in the same collections cycle.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the customer contact person for dunning correspondence.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'Name of the customer contact person to whom the dunning notice was addressed, typically the accounts payable manager or financial controller.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the customer contact person for follow-up on the dunning notice.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Block Flag' ;
    rdfs:comment 'Indicates whether the customer account has been placed on credit hold due to overdue receivables, preventing further service provisioning until payment is received.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'The approved credit limit for the customer account at the time of dunning notice issuance, used to assess credit risk exposure.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Date' ;
    rdfs:comment 'The date on which the customer provided a response to the dunning notice, if applicable.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Response Status' ;
    rdfs:comment 'Indicates whether and how the customer has responded to the dunning notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of days since the oldest invoice payment due date, calculated as the aging period for the most delinquent receivable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'The date on which the dunning notice was issued to the customer. This is the principal business event timestamp for the notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Dunning Fee Amount' ;
    rdfs:comment 'Administrative fee charged to the customer for issuing the dunning notice, as per port tariff schedule and credit policy.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Escalation level of the dunning notice (1=first reminder, 2=second reminder, 3=final notice, 4=legal action). Higher levels indicate increased severity and urgency.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningMethod rdf:type rdf:Property ;
    rdfs:label 'Dunning Method' ;
    rdfs:comment 'The communication channel and delivery method used to send the dunning notice to the customer.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningNoticeNumber rdf:type rdf:Property ;
    rdfs:label 'Dunning Notice Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the dunning notice, used in customer correspondence and legal proceedings.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningStatus rdf:type rdf:Property ;
    rdfs:label 'Dunning Status' ;
    rdfs:comment 'Current lifecycle status of the dunning notice indicating its processing state and customer response.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningText rdf:type rdf:Property ;
    rdfs:label 'Dunning Text' ;
    rdfs:comment 'The body text or message content of the dunning notice sent to the customer, including payment instructions and consequences of non-payment.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this dunning notice has been escalated to legal or external collections agencies due to non-response or non-payment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAgencyName rdf:type rdf:Property ;
    rdfs:label 'External Agency Name' ;
    rdfs:comment 'Name of the external collections agency to which the account has been referred, if escalation has occurred.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'Late payment interest accrued on the overdue receivables, calculated per the credit agreement terms.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalActionThreatenedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Action Threatened Flag' ;
    rdfs:comment 'Indicates whether the dunning notice includes a threat of legal action or litigation if payment is not received by the deadline.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfOverdueInvoices rdf:type rdf:Property ;
    rdfs:label 'Number Of Overdue Invoices' ;
    rdfs:comment 'Count of distinct invoices that are overdue and included in this dunning notice.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oldestOverdueInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Oldest Overdue Invoice Date' ;
    rdfs:comment 'The invoice date of the oldest unpaid invoice included in this dunning notice, indicating how long receivables have been outstanding.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPlanOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Offered Flag' ;
    rdfs:comment 'Indicates whether a payment plan or installment arrangement has been offered to the customer as part of the dunning resolution process.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'The original payment terms applicable to the overdue invoices (e.g., Net 30, Net 60), providing context for the delinquency.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'The date by which the customer must respond or settle the outstanding amount to avoid further escalation.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapDunningDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Sap Dunning Document Reference' ;
    rdfs:comment 'The SAP S/4HANA FI dunning document number that corresponds to this dunning notice, providing traceability to the source ERP system.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'The negotiated settlement amount if the customer and port have agreed to a reduced payment to resolve the overdue receivables.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the overdue receivables were settled or paid in full, closing the dunning case.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalOverdueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Overdue Amount' ;
    rdfs:comment 'The total monetary value of all outstanding receivables included in this dunning notice, representing the sum of all overdue invoices.' ;
    rdfs:domain ind:DunningNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the overdue receivables were written off, if applicable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'Indicates whether the overdue receivables have been written off as uncollectible bad debt.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Invoice creation audit trail requires tracking which billing clerk prepared each invoice for dispute resolution, compliance audits, and performance management. Maritime ports require strict financial ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:flagStateId rdf:type rdf:Property ;
    rdfs:label 'Flag State Id' ;
    rdfs:comment 'Foreign key linking to masterdata.flag_state. Business justification: Vessel flag state determines applicable port charge exemptions, bilateral agreements, and regulatory fee structures. Critical for international maritime billing compliance and tariff application.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlagState .

ind:portTariffId rdf:type rdf:Property ;
    rdfs:label 'Port Tariff Id' ;
    rdfs:comment 'Foreign key linking to tariff.port_tariff. Business justification: Invoices must reference the published port tariff schedule under which charges were calculated for regulatory compliance, audit trail, and dispute resolution. Maritime port authorities require invoice' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortTariff .

ind:profitCentreId rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_centre. Business justification: Maritime ports operate multiple profit centers (container terminal, bulk cargo, passenger services). Invoice revenue must be attributed for segment reporting and divisional P&L analysis required by po' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCentre .

ind:rateCardId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Id' ;
    rdfs:comment 'Foreign key linking to tariff.rate_card. Business justification: When invoicing under negotiated commercial agreements, invoice must reference the applicable rate card for contract compliance, audit trail, and to distinguish negotiated rates from published tariff r' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:shippingLineId rdf:type rdf:Property ;
    rdfs:label 'Shipping Line Id' ;
    rdfs:comment 'Foreign key linking to masterdata.shipping_line. Business justification: Invoices are often addressed to shipping lines as the commercial party responsible for vessel operations charges. Essential for shipping line account management and consolidated billing processes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShippingLine .

ind:vesselCallId rdf:type rdf:Property ;
    rdfs:label 'Vessel Call Id' ;
    rdfs:comment 'Reference to the vessel call for which services were rendered. Links invoice to specific vessel visit and berth allocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Call .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Net adjustment amount for credits, chargebacks, or billing corrections. Can be positive or negative.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bafAmount rdf:type rdf:Property ;
    rdfs:label 'Baf Amount' ;
    rdfs:comment 'Bunker Adjustment Factor surcharge applied to compensate for fuel price fluctuations. Common in maritime billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cafAmount rdf:type rdf:Property ;
    rdfs:label 'Caf Amount' ;
    rdfs:comment 'Currency Adjustment Factor surcharge applied to compensate for exchange rate fluctuations. Common in international maritime billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Channel through which the invoice was delivered to the customer. Supports multi-channel billing communication.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date the invoice was formally disputed by the customer. Triggers dispute resolution workflow.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the invoice was officially issued to the customer. Principal business event timestamp for revenue recognition and accounts receivable aging.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-known unique invoice number issued to port community participants. Generated from NAVIS N4 TOS billing module and synchronized with SAP S/4HANA FI document number.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the billing workflow. Tracks progression from draft through payment or dispute resolution. [ENUM-REF-CANDIDATE: draft|issued|paid|partially_paid|disputed|cancelled|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method by which payment is expected or received. Instrument used for settlement of the invoice. [ENUM-REF-CANDIDATE: bank_transfer|wire_transfer|credit_card|debit_card|check|cash|edi_payment|direct_debit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date payment was received and cleared in the port authority bank account. Used for cash flow reporting and revenue recognition.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Bank transaction reference or remittance advice number provided with payment. Used for payment reconciliation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podCode rdf:type rdf:Property ;
    rdfs:label 'Pod Code' ;
    rdfs:comment 'UN/LOCODE five-character code identifying the port of discharge for the cargo. Used for trade lane analysis and tariff determination.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polCode rdf:type rdf:Property ;
    rdfs:label 'Pol Code' ;
    rdfs:comment 'UN/LOCODE five-character code identifying the port of loading for the cargo. Used for trade lane analysis and tariff determination.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue from this invoice is recognized in financial statements per IFRS 15 criteria. May differ from invoice date.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP S/4HANA FI accounting document number for this invoice. Links billing record to financial accounting system of record.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Total amount of all line items before taxes, adjustments, and discounts. Base amount for revenue calculation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Reference number of the tax exemption certificate on file justifying tax exemption status. Required for audit compliance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Flag' ;
    rdfs:comment 'Indicates whether this invoice is exempt from taxation due to customer status, service type, or regulatory exemption.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction code determining which tax rates and rules apply to this invoice. ISO country code or regional tax authority identifier.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final total amount due including subtotal, taxes, discounts, and adjustments. Net amount payable by customer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:anchorageAreaId rdf:type rdf:Property ;
    rdfs:label 'Anchorage Area Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.anchorage_area. Business justification: Anchorage occupancy charges (daily fees for vessels waiting at anchorage) must reference which anchorage area was used for accurate billing and anchorage utilization revenue tracking. Standard practic' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnchorageArea .

ind:berthId rdf:type rdf:Property ;
    rdfs:label 'Berth Id' ;
    rdfs:comment 'Reference to the berth where the service was rendered. Applicable for berth-related charges and terminal operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Berth .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.channel. Business justification: Channel-dependent charges (pilotage fees varying by channel depth/length, channel maintenance levies) must reference which channel was used. Essential for ports with multiple approach channels having ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:marpolWasteRecordId rdf:type rdf:Property ;
    rdfs:label 'Marpol Waste Record Id' ;
    rdfs:comment 'Foreign key linking to safety.marpol_waste_record. Business justification: Line items for waste disposal services billed to vessels per MARPOL requirements. Standard port billing practice requiring detailed traceability from invoice line to specific waste reception record fo' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarpolWasteRecord .

ind:originalInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Line Id' ;
    rdfs:comment 'Reference to the original invoice line if this is an adjustment or correction. Enables audit trail for billing changes and credit notes.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:rateCardLineId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Line Id' ;
    rdfs:comment 'Foreign key linking to tariff.rate_card_line. Business justification: Line items invoiced under negotiated rates must link to the specific rate card line that defines the agreed unit rate, volume tiers, and service level. Required for contract compliance verification an' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCardLine .

ind:terminalZoneId rdf:type rdf:Property ;
    rdfs:label 'Terminal Zone Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.terminal_zone. Business justification: Container handling and ground slot charges must reference the terminal zone where services occurred for zone-level revenue analysis and operational cost allocation. Critical for multi-terminal port op' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalZone .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.warehouse. Business justification: Cargo storage charges must reference which warehouse facility provided the service for accurate billing and warehouse-level revenue tracking. Essential for bonded vs non-bonded storage differentiation' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:adjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Flag' ;
    rdfs:comment 'Indicates whether this line item is a billing adjustment or correction. True for adjustments (credit notes, rebills), False for original charges.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargeCategory rdf:type rdf:Property ;
    rdfs:label 'Charge Category' ;
    rdfs:comment 'Classification of the charge type. THC=Terminal Handling Charge, WHR=Wharfage, DMG=Demurrage, DET=Detention, BAF=Bunker Adjustment Factor, CAF=Currency Adjustment Factor. Enables revenue analysis by charge category. [ENUM-REF-CANDIDATE: THC|WHR|DMG|DET|BAF|CAF|PILOTAGE|TOWAGE|STORAGE|HANDLING|BERTH|SECURITY — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountCode rdf:type rdf:Property ;
    rdfs:label 'Discount Code' ;
    rdfs:comment 'Code identifying any discount applied to this line item. References promotional discounts, volume discounts, or contractual rate reductions.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Gross amount for this line item before tax. Calculated as quantity multiplied by unit rate, plus any applicable adjustments.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the invoice. Determines the ordering and display sequence of line items on the invoice document.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net amount for this line item including tax. Sum of line amount and tax amount. Contributes to the invoice total.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service End Timestamp' ;
    rdfs:comment 'Timestamp when the service was completed. Used to calculate duration-based charges and service level agreement compliance.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service Start Timestamp' ;
    rdfs:comment 'Timestamp when the service commenced. Used for time-based charges such as storage, demurrage, and detention calculations.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax code determining the tax treatment for this line item. References the tax jurisdiction and rate applicable to the service.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Tax rate percentage applied to this line item. Expressed as a percentage (e.g., 10.00 for 10% tax).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment record. Primary key for the payment entity.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:reconciledByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reconciled By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Payment reconciliation is a critical financial control requiring employee accountability. Port finance teams need to track who reconciled each payment for audit trails and segregation of duties compli' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'Portion of the payment amount that has been allocated to specific invoices. May be less than amount_paid if payment is partially applied or held on account.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Total amount paid in the transaction currency. Represents the gross payment received before any adjustments or allocations.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReference rdf:type rdf:Property ;
    rdfs:label 'Bank Reference' ;
    rdfs:comment 'Bank transaction reference or confirmation number provided by the financial institution. Used for payment tracing and dispute resolution.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'Payment amount converted to the port\'s base reporting currency using the exchange rate. Used for consolidated financial reporting and EBITDA calculation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Channel or interface through which the payment was submitted (online portal, bank transfer, Port Community System, SAP, manual entry, or Electronic Data Interchange).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date when the payment was cleared and funds were confirmed available in the port\'s bank account. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountTaken rdf:type rdf:Property ;
    rdfs:label 'Discount Taken' ;
    rdfs:comment 'Early payment discount amount claimed by the customer and deducted from the invoice total. Reflects payment terms incentives.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'Reference number for payment dispute case if reconciliation status is disputed. Links to dispute resolution workflow.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Exchange rate applied to convert payment currency to port base currency. Used for multi-currency payment reconciliation and financial reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAdvancePayment rdf:type rdf:Property ;
    rdfs:label 'Is Advance Payment' ;
    rdfs:comment 'Boolean flag indicating whether this is an advance payment received before services are rendered. True if advance, False otherwise.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:navisBillingReference rdf:type rdf:Property ;
    rdfs:label 'Navis Billing Reference' ;
    rdfs:comment 'Reference to the NAVIS N4 Terminal Operating System billing transaction that generated the invoice. Links payment back to operational billing source.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Account Number' ;
    rdfs:comment 'Bank account number from which the payment originated. Used for payment verification and reconciliation. Business-confidential financial information.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerBankName rdf:type rdf:Property ;
    rdfs:label 'Payer Bank Name' ;
    rdfs:comment 'Name of the financial institution from which the payment was sent. Used for payment tracing and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date when the payment was received or processed by the port authority. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment in the accounts receivable lifecycle. Tracks payment from receipt through clearing and application to invoices.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of payment purpose. Distinguishes between advance payments, payments on account, invoice settlements, refunds, and credit note applications.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the payment was first received or recorded in the system. Principal business event timestamp. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciled Timestamp' ;
    rdfs:comment 'Date and time when the payment was reconciled. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of payment reconciliation against bank statements and invoice records. Tracks whether payment has been matched and verified.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Reference' ;
    rdfs:comment 'Reference number from the remittance advice document sent by the payer. Links payment to payer\'s accounts payable records.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapClearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Clearing Document Number' ;
    rdfs:comment 'SAP FI clearing document number generated when payment is applied against open invoice items. Links to SAP accounts receivable clearing process.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPaymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Payment Document Number' ;
    rdfs:comment 'SAP FI payment document number created during payment posting. Primary reference for financial audit trail in SAP S/4HANA.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'Portion of the payment amount not yet allocated to invoices. Held on account for future invoice settlement or refund.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Payment Allocation Id' ;
    rdfs:comment 'Unique identifier for the payment allocation record. Primary key for the payment allocation entity.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Financial period (YYYY-MM format) to which this allocation is posted. Critical for period-end close, revenue recognition, and financial reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The date when the payment was allocated to the invoice. Critical for accounts receivable aging and financial period assignment.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationReference rdf:type rdf:Property ;
    rdfs:label 'Allocation Reference' ;
    rdfs:comment 'Business reference number for the payment allocation transaction. Used for tracking and reconciliation purposes across systems.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationSource rdf:type rdf:Property ;
    rdfs:label 'Allocation Source' ;
    rdfs:comment 'System or process that created the allocation. Manual: user-entered; Automated: system-matched; EDI: electronic data interchange; Lockbox: bank lockbox service; API: external system integration.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current processing status of the allocation. Pending: awaiting confirmation; Confirmed: successfully applied; Reversed: allocation undone; Cancelled: allocation voided; Disputed: under review for billing dispute.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Precise date and time when the allocation was processed in the system. Used for audit trail and reconciliation timing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the allocation transaction. Full: entire invoice paid; Partial: portion of invoice paid; Advance: payment before invoice; Overpayment: payment exceeds invoice; On-account: unallocated payment held for future invoices; Credit-note: allocation from credit memo.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankReconciliationReference rdf:type rdf:Property ;
    rdfs:label 'Bank Reconciliation Reference' ;
    rdfs:comment 'Reference number from bank statement used to match and reconcile this allocation. Critical for automated cash application and bank reconciliation processes.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'Business area code for cross-company financial reporting. Enables consolidated financial statements across multiple legal entities.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity for which the allocation is recorded. Critical for multi-entity financial consolidation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Allocated amount converted to the company code local currency using the exchange rate. Used for financial reporting in local GAAP.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'The remaining unpaid balance on the invoice after this allocation is applied. Zero indicates invoice is fully paid. Critical for accounts receivable aging reports.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDocument rdf:type rdf:Property ;
    rdfs:label 'Reversal Document' ;
    rdfs:comment 'SAP FI document number of the reversal transaction. Links to the offsetting entry that undoes the original allocation. Nullable for non-reversed allocations.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapClearingDocument rdf:type rdf:Property ;
    rdfs:label 'Sap Clearing Document' ;
    rdfs:comment 'SAP S/4HANA FI clearing document number that links the payment and invoice in the financial system. Critical for financial close and reconciliation.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapClearingItem rdf:type rdf:Property ;
    rdfs:label 'Sap Clearing Item' ;
    rdfs:comment 'Line item number within the SAP clearing document. Enables precise traceability to specific line-level clearing entries in SAP FI.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxDeducted rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Deducted' ;
    rdfs:comment 'Tax amount withheld at source during payment allocation as per jurisdictional tax regulations. Common in international maritime trade transactions.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proformaInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Proforma Invoice Id' ;
    rdfs:comment 'Unique identifier for the proforma invoice record. Primary key.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProformaInvoice .

ind:finalInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Id' ;
    rdfs:comment 'Reference to the final invoice generated upon conversion of this proforma invoice. Null if not yet converted.' ;
    rdfs:domain ind:ProformaInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:slotBookingId rdf:type rdf:Property ;
    rdfs:label 'Slot Booking Id' ;
    rdfs:comment 'Foreign key linking to intermodal.slot_booking. Business justification: Slot bookings for rail/truck services trigger proforma invoices before service delivery. Standard practice in intermodal terminal operations for advance billing, deposit collection, and service confir' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlotBooking .

ind:acknowledgedBy rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By' ;
    rdfs:comment 'Name or identifier of the customer representative who acknowledged the proforma invoice.' ;
    rdfs:domain ind:ProformaInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Status' ;
    rdfs:comment 'Status indicating whether the customer has acknowledged receipt and acceptance of the proforma invoice. Used for pre-clearance and financial planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthName rdf:type rdf:Property ;
    rdfs:label 'Berth Name' ;
    rdfs:comment 'Name or identifier of the berth allocated to the vessel for this call. Used for berth-specific tariff calculation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the billing contact person for proforma invoice delivery and correspondence.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Name of the primary billing contact person at the customer organization to whom the proforma invoice is addressed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'Phone number of the billing contact person for proforma invoice inquiries and clarifications.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date on which the proforma invoice was cancelled. Null if not cancelled.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date on which the proforma invoice was converted to a final invoice. Null if not yet converted.' ;
    rdfs:domain ind:ProformaInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Status indicating whether the proforma invoice has been converted to a final invoice, expired without conversion, or cancelled.' ;
    rdfs:domain ind:ProformaInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Timestamp when the proforma invoice was delivered to the customer via the specified delivery method.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eta rdf:type rdf:Property ;
    rdfs:label 'Eta' ;
    rdfs:comment 'Estimated time of arrival of the vessel at the port. Used to calculate time-based charges such as berth occupancy and pilotage.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:etd rdf:type rdf:Property ;
    rdfs:label 'Etd' ;
    rdfs:comment 'Estimated time of departure of the vessel from the port. Used to calculate duration-based charges.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proformaInvoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Proforma Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the proforma invoice. Tracks progression from draft through issuance, customer acknowledgement, conversion to final invoice, expiration, or cancellation.' ;
    rdfs:domain ind:ProformaInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proformaNumber rdf:type rdf:Property ;
    rdfs:label 'Proforma Number' ;
    rdfs:comment 'Externally visible unique proforma invoice number used for customer reference and tracking. Typically follows port-specific numbering convention.' ;
    rdfs:domain ind:ProformaInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Primary service category for which charges are estimated. Includes vessel dues, berth charges, pilotage, towage, Terminal Handling Charge (THC), and wharfage.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Start date of the proforma invoice validity period. Charges are estimated as of this date.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validUntilDate rdf:type rdf:Property ;
    rdfs:label 'Valid Until Date' ;
    rdfs:comment 'Expiration date of the proforma invoice. After this date, the proforma is no longer valid and must be reissued or converted to final invoice.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivableAccountId rdf:type rdf:Property ;
    rdfs:label 'Receivable Account Id' ;
    rdfs:comment 'Unique identifier for the receivable account. Primary key for the customer billing and accounts receivable master record.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReceivableAccount .

ind:ediPartnerId rdf:type rdf:Property ;
    rdfs:label 'Edi Partner Id' ;
    rdfs:comment 'Unique identifier for this customer in the port\'s EDI network. Used for automated invoice transmission via EDIFACT or X12 protocols.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiPartner .

ind:haulierId rdf:type rdf:Property ;
    rdfs:label 'Haulier Id' ;
    rdfs:comment 'Foreign key linking to intermodal.haulier. Business justification: Hauliers are billed customers for drayage and gate services. Ports maintain receivable accounts for hauliers to track outstanding balances, credit limits, payment terms, and aging. Essential for credi' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Haulier .

ind:parentAccountReceivableAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Receivable Account Id' ;
    rdfs:comment 'Reference to the parent receivable account if this is a subsidiary or branch account. Enables hierarchical billing and consolidated statements.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReceivableAccount .

ind:railOperatorId rdf:type rdf:Property ;
    rdfs:label 'Rail Operator Id' ;
    rdfs:comment 'Foreign key linking to intermodal.rail_operator. Business justification: Rail operators are billed for terminal services (loading, unloading, storage, track usage). Ports maintain receivable accounts to manage rail operator billing, credit terms, payment tracking, and dunn' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RailOperator .

ind:accountClassification rdf:type rdf:Property ;
    rdfs:label 'Account Classification' ;
    rdfs:comment 'Business classification of the account holder based on their role in the port community ecosystem. Determines applicable tariff structures and service entitlements.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountClosedDate rdf:type rdf:Property ;
    rdfs:label 'Account Closed Date' ;
    rdfs:comment 'Date when this receivable account was closed or terminated. Null for active accounts.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'Business-assigned unique alphanumeric code identifying the receivable account. Used for operational reference and reporting.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Legal or trading name of the customer organization or individual holding this receivable account.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Account Opened Date' ;
    rdfs:comment 'Date when this receivable account was first established and activated in the billing system.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the receivable account. Active accounts can transact; suspended/blocked accounts require approval; closed accounts are archived.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingBucket030Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 0 30 Days' ;
    rdfs:comment 'Total outstanding balance for invoices aged 0 to 30 days past due date. Used for accounts receivable aging analysis and collections prioritization.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket3160Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 31 60 Days' ;
    rdfs:comment 'Total outstanding balance for invoices aged 31 to 60 days past due date. Indicates moderate collection risk.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket6190Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 61 90 Days' ;
    rdfs:comment 'Total outstanding balance for invoices aged 61 to 90 days past due date. Indicates elevated collection risk requiring escalation.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucketOver90Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket Over 90 Days' ;
    rdfs:comment 'Total outstanding balance for invoices aged over 90 days past due date. Indicates high collection risk; may require legal action or write-off consideration.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Payment Flag' ;
    rdfs:comment 'Indicates whether this account is enrolled in automatic payment via direct debit or standing order. True means invoices are auto-settled on due date.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageDaysToPay rdf:type rdf:Property ;
    rdfs:label 'Average Days To Pay' ;
    rdfs:comment 'Rolling average number of days from invoice date to payment receipt over the last 12 months. Key metric for credit risk assessment.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the postal address to which invoices and statements are sent. Typically contains street number and name.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing postal address. Used for suite/floor/building details or additional address information.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City or municipality component of the billing address.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountry rdf:type rdf:Property ;
    rdfs:label 'Billing Country' ;
    rdfs:comment 'Three-letter ISO country code for the billing address country.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Email' ;
    rdfs:comment 'Primary email address for sending invoices, statements, and billing-related communications.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Phone' ;
    rdfs:comment 'Primary phone number for billing inquiries and dispute resolution. Format varies by country.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code component of the billing address. Format varies by country.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State, province, or region component of the billing address. Format varies by country.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether invoices for this account should be consolidated with parent account for statement purposes. True enables group-level billing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether this account is currently on credit hold. True means no new services can be rendered until outstanding balance is reduced.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal or external credit rating assessment for this account. Used to determine credit limits and payment terms. D indicates default risk. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D|unrated — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeCountYtd rdf:type rdf:Property ;
    rdfs:label 'Dispute Count Ytd' ;
    rdfs:comment 'Number of billing disputes raised by this account in the current calendar year. High counts indicate service quality or billing accuracy issues.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Preferred channel for delivering invoices to the customer. EDI is common for large shipping lines; email for smaller customers.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date of the most recent invoice issued to this account. Used to identify dormant accounts.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment received from this account in the account\'s base currency.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received from this account. Used to calculate average days to pay and payment behavior trends.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for invoicing this account. All invoices will be issued in this currency unless overridden at transaction level.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Number' ;
    rdfs:comment 'SAP S/4HANA customer master number (KNA1/KNB1) linking this receivable account to the ERP financial accounting module. Ten-digit numeric identifier.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'Frequency at which account statements summarizing all invoices and payments are generated and sent to the customer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the primary tax jurisdiction for this account. Determines applicable tax rates and compliance requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Tax registration identifier for VAT/GST purposes. Required for invoicing and tax compliance reporting. Format varies by jurisdiction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmountYtd rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount Ytd' ;
    rdfs:comment 'Total amount written off as bad debt for this account in the current calendar year. Impacts credit rating and future credit decisions.' ;
    rdfs:domain ind:ReceivableAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueEventId rdf:type rdf:Property ;
    rdfs:label 'Revenue Event Id' ;
    rdfs:comment 'Unique identifier for the revenue recognition event. Primary key.' ;
    rdfs:domain ind:RevenueEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marineServiceOrderId rdf:type rdf:Property ;
    rdfs:label 'Marine Service Order Id' ;
    rdfs:comment 'Reference to the underlying service order or work order that generated the revenue. May link to vessel services, terminal handling, or other port operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarineServiceOrder .

ind:originalRevenueEventId rdf:type rdf:Property ;
    rdfs:label 'Original Revenue Event Id' ;
    rdfs:comment 'Reference to the original revenue event that is being reversed or adjusted. Populated only when reversal_flag is True. Enables audit trail for revenue corrections.' ;
    rdfs:domain ind:RevenueEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueEvent .

ind:sustainabilityInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Sustainability Initiative Id' ;
    rdfs:comment 'Foreign key linking to safety.sustainability_initiative. Business justification: Revenue recognition for green tariff premiums, carbon offset programs, shore power incentives, and sustainability-linked service fees. Emerging port revenue model (WPSP-aligned) requiring traceability' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SustainabilityInitiative .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Free-text explanation of the reason for any revenue adjustment (e.g., volume discount applied, BAF surcharge for fuel cost, contractual rebate, billing correction, dispute resolution credit).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Approval workflow status for the revenue recognition event. Pending approval indicates awaiting finance manager review; Approved indicates cleared for GL posting; Rejected indicates the event was declined and must be corrected.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Amount' ;
    rdfs:comment 'The amount of revenue deferred to future accounting periods. Applicable for services delivered over time (e.g., storage, lease agreements, long-term contracts).' ;
    rdfs:domain ind:RevenueEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Document Number' ;
    rdfs:comment 'The SAP S/4HANA FI document number assigned to the general ledger posting for this revenue recognition event. Used for financial audit and reconciliation. 10-digit numeric format.' ;
    rdfs:domain ind:RevenueEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The date on which revenue is recognized in the accounting system. This is the business event date for revenue realization, distinct from invoice date or service delivery date.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionEventNumber rdf:type rdf:Property ;
    rdfs:label 'Recognition Event Number' ;
    rdfs:comment 'Business-readable unique identifier for the revenue recognition event, formatted as REV- followed by 10 digits. Used for audit trails and financial reporting.' ;
    rdfs:domain ind:RevenueEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'The method used to recognize revenue for this event. Point-in-time applies to discrete services (THC, pilotage, towage); Over-time applies to continuous services (storage, lease); Milestone applies to project-based services; Proportional applies to usage-based services; Straight-line applies to subscription or fixed-term contracts.' ;
    rdfs:domain ind:RevenueEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition event. Pending indicates awaiting approval; Recognized indicates revenue has been posted to GL; Deferred indicates revenue is held for future periods; Reversed indicates a correction or cancellation; Adjusted indicates a modification post-recognition; Cancelled indicates the event was voided.' ;
    rdfs:domain ind:RevenueEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Revenue Amount' ;
    rdfs:comment 'The amount of revenue recognized in this event, posted to the general ledger. Represents the portion of the invoice or service order value that is realized in the current accounting period.' ;
    rdfs:domain ind:RevenueEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueStreamCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Category' ;
    rdfs:comment 'High-level categorization of the revenue stream for strategic reporting and EBITDA analysis. Vessel services include pilotage, towage, berth fees; Cargo handling includes THC, stevedoring; Storage/demurrage includes container yard charges; Marine services include launch, survey; Facility lease includes terminal, warehouse rental; Ancillary services include utilities, security.' ;
    rdfs:domain ind:RevenueEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Date' ;
    rdfs:comment 'The date on which the underlying port service was delivered or completed (e.g., vessel departure, container discharge completion, pilotage service completion). Used to determine point-in-time vs over-time recognition.' ;
    rdfs:domain ind:RevenueEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'The unique identifier of the transaction in the source system (e.g., NAVIS N4 billing transaction ID, SAP FI document number). Used for data lineage and reconciliation back to the source system.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementOfAccountId rdf:type rdf:Property ;
    rdfs:label 'Statement Of Account Id' ;
    rdfs:comment 'Unique identifier for the statement of account record. Primary key.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'The system user identifier of the person or automated process that last modified the statement record.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgedByContactName rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By Contact Name' ;
    rdfs:comment 'The name of the customer contact person who acknowledged the statement on behalf of the customer organization.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aging3160Days rdf:type rdf:Property ;
    rdfs:label 'Aging 31 60 Days' ;
    rdfs:comment 'The portion of the closing balance representing invoices that are overdue by 31-60 days from their due date.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aging6190Days rdf:type rdf:Property ;
    rdfs:label 'Aging 61 90 Days' ;
    rdfs:comment 'The portion of the closing balance representing invoices that are overdue by 61-90 days from their due date.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingCurrent rdf:type rdf:Property ;
    rdfs:label 'Aging Current' ;
    rdfs:comment 'The portion of the closing balance representing invoices that are current or overdue by 0-30 days from their due date.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingOver90Days rdf:type rdf:Property ;
    rdfs:label 'Aging Over 90 Days' ;
    rdfs:comment 'The portion of the closing balance representing invoices that are overdue by more than 90 days from their due date. Indicates high collection risk.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'The outstanding accounts receivable balance at the end of the statement period. Calculated as opening balance plus invoices and debit adjustments minus payments and credit adjustments.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAdjustmentCount rdf:type rdf:Property ;
    rdfs:label 'Credit Adjustment Count' ;
    rdfs:comment 'The total number of credit adjustment transactions applied to the customer account during the statement period.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:debitAdjustmentCount rdf:type rdf:Property ;
    rdfs:label 'Debit Adjustment Count' ;
    rdfs:comment 'The total number of debit adjustment transactions applied to the customer account during the statement period.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference Number' ;
    rdfs:comment 'The unique reference number of the billing dispute case raised by the customer in relation to this statement, if applicable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceCount rdf:type rdf:Property ;
    rdfs:label 'Invoice Count' ;
    rdfs:comment 'The total number of invoices issued to the customer during the statement period.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The outstanding accounts receivable balance at the beginning of the statement period. Represents carried-forward balance from prior period.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCount rdf:type rdf:Property ;
    rdfs:label 'Payment Count' ;
    rdfs:comment 'The total number of payment transactions received from the customer during the statement period.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statementDate rdf:type rdf:Property ;
    rdfs:label 'Statement Date' ;
    rdfs:comment 'The date on which the statement was generated and issued to the customer. Represents the as-of date for all balances and transactions included.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally visible unique statement reference number issued to the customer. Format: SOA-YYYYMMDD-NNNNNN.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the statement. Tracks progression from draft through issuance, customer acknowledgement, and closure.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAdjustments rdf:type rdf:Property ;
    rdfs:label 'Total Credit Adjustments' ;
    rdfs:comment 'The aggregate value of all credit notes, credit memos, and favorable adjustments applied to the customer account during the statement period.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAdjustments rdf:type rdf:Property ;
    rdfs:label 'Total Debit Adjustments' ;
    rdfs:comment 'The aggregate value of all debit notes, debit memos, and unfavorable adjustments applied to the customer account during the statement period.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoicesRaised rdf:type rdf:Property ;
    rdfs:label 'Total Invoices Raised' ;
    rdfs:comment 'The aggregate value of all invoices issued to the customer during the statement period. Increases the receivable balance.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Payments Received' ;
    rdfs:comment 'The aggregate value of all payments received from the customer during the statement period. Reduces the receivable balance.' ;
    rdfs:domain ind:StatementOfAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingAnchorageBookingId rdf:type rdf:Property ;
    rdfs:label 'Booking Anchorage Booking Id' ;
    rdfs:comment 'Unique identifier for the anchorage booking record. Primary key for this entity.' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Agent Appointment Id' ;
    rdfs:comment 'Reference to the shipping agent or representative who submitted the anchorage booking request on behalf of the vessel owner or operator.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgentAppointment .

ind:bookingBerthReservationId rdf:type rdf:Property ;
    rdfs:label 'Booking Berth Reservation Id' ;
    rdfs:comment 'Reference to the associated berth reservation if the vessel is anchoring while awaiting berth availability. Links anchorage to the planned berth allocation. Null if no berth reservation exists.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BookingBerthReservation .

ind:ispsFacilityRecordId rdf:type rdf:Property ;
    rdfs:label 'Isps Facility Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.isps_facility_record. Business justification: Anchorage area assignments require ISPS security level validation and DoS coordination. Anchorage areas are designated port facilities under ISPS Code. Maritime security requirement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IspsFacilityRecord .

ind:portDuesScheduleId rdf:type rdf:Property ;
    rdfs:label 'Port Dues Schedule Id' ;
    rdfs:comment 'Foreign key linking to tariff.port_dues_schedule. Business justification: Anchorage bookings incur port dues based on vessel GRT, anchorage duration, and applicable port dues schedule. Real business process: anchorage charge calculation and billing to vessel agent.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortDuesSchedule .

ind:actualAnchorDropTime rdf:type rdf:Property ;
    rdfs:label 'Actual Anchor Drop Time' ;
    rdfs:comment 'Actual recorded date and time when the vessel dropped anchor, as reported by VTS or pilot. Used for billing and performance tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualAnchorageDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Anchorage Duration Hours' ;
    rdfs:comment 'Actual duration of anchorage in hours, calculated from actual anchor drop and weigh anchor times. Used for billing and performance analysis.' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualWeighAnchorTime rdf:type rdf:Property ;
    rdfs:label 'Actual Weigh Anchor Time' ;
    rdfs:comment 'Actual recorded date and time when the vessel weighed anchor and departed anchorage, as reported by VTS or pilot. Marks end of anchorage occupancy.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:anchorageChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Anchorage Charge Amount' ;
    rdfs:comment 'Total anchorage fee charged for this booking, calculated based on vessel size, duration, and applicable tariff rates. Excludes additional service charges.' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:anchorageChargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Anchorage Charge Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the anchorage charge amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anchorageReasonCode rdf:type rdf:Property ;
    rdfs:label 'Anchorage Reason Code' ;
    rdfs:comment 'Primary reason for the vessel requesting anchorage. Determines operational handling and priority. STS = Ship-to-Ship transfer. [ENUM-REF-CANDIDATE: awaiting_berth|tidal_window|customs_clearance|bunkering|sts_transfer|crew_change|repairs|quarantine|weather|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anchorageReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Anchorage Reason Description' ;
    rdfs:comment 'Free-text detailed explanation of the anchorage reason, providing additional context beyond the reason code.' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingCancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the anchorage booking was cancelled, either by the vessel agent or port authority. Null if booking was not cancelled.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the anchorage booking was confirmed and allocated by VTS or port operations. Represents formal acceptance of the request.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Booking Reference Number' ;
    rdfs:comment 'Externally-visible unique reference number for the anchorage booking, used in communications with vessel agents and VTS. Format: ANC-YYYYMMDD-XXXX.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingRequestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Requested Timestamp' ;
    rdfs:comment 'Date and time when the anchorage booking request was initially submitted to the port authority or VTS. Marks the start of the booking lifecycle.' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle status of the anchorage booking. Tracks progression from initial request through confirmation, occupation, and departure. [ENUM-REF-CANDIDATE: requested|confirmed|allocated|occupied|departed|cancelled|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buoyNumber rdf:type rdf:Property ;
    rdfs:label 'Buoy Number' ;
    rdfs:comment 'Specific buoy or mooring point assigned within the anchorage area, if applicable. Format varies by port (e.g., A-12, NW-5).' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedAnchorDropTime rdf:type rdf:Property ;
    rdfs:label 'Confirmed Anchor Drop Time' ;
    rdfs:comment 'VTS-confirmed date and time when the vessel is authorized to drop anchor. May differ from requested time due to capacity or operational constraints.' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedWeighAnchorTime rdf:type rdf:Property ;
    rdfs:label 'Confirmed Weigh Anchor Time' ;
    rdfs:comment 'VTS-confirmed date and time when the vessel is expected or authorized to weigh anchor and depart. Subject to operational adjustments.' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazmatCargoFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Cargo Flag' ;
    rdfs:comment 'Indicates whether the vessel is carrying hazardous or dangerous goods as defined by IMDG Code. True if hazmat cargo is present, requiring special anchorage area assignment and safety protocols.' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imdgClassCodes rdf:type rdf:Property ;
    rdfs:label 'Imdg Class Codes' ;
    rdfs:comment 'Comma-separated list of IMDG hazard class codes for dangerous goods on board (e.g., 1.1, 3, 5.1). Null if no hazmat cargo. Used for anchorage area segregation and emergency response planning.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pilot Required Flag' ;
    rdfs:comment 'Indicates whether pilotage service is required for the vessel to navigate to or from the anchorage area. True if pilot is mandatory per port regulations or vessel characteristics.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedAnchorageDurationHours rdf:type rdf:Property ;
    rdfs:label 'Planned Anchorage Duration Hours' ;
    rdfs:comment 'Estimated duration of anchorage in hours, calculated from requested anchor drop and weigh anchor times. Used for capacity planning.' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the vessel is under quarantine or health hold, requiring isolation anchorage. True if quarantine is in effect, restricting vessel movement and requiring health authority clearance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedAnchorDropTime rdf:type rdf:Property ;
    rdfs:label 'Requested Anchor Drop Time' ;
    rdfs:comment 'Vessel agent\'s requested date and time for the vessel to drop anchor and commence anchorage. Used for capacity planning and VTS coordination.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedWeighAnchorTime rdf:type rdf:Property ;
    rdfs:label 'Requested Weigh Anchor Time' ;
    rdfs:comment 'Vessel agent\'s requested date and time for the vessel to weigh anchor and depart anchorage. Used for duration estimation and capacity release planning.' ;
    rdfs:domain ind:BookingAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Current ISPS security level applicable to this anchorage booking. Level 1 = normal, Level 2 = heightened, Level 3 = exceptional. Affects anchorage area access and monitoring requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for any special operational instructions, requirements, or notes related to this anchorage booking. Used for coordination between vessel agent, VTS, and port operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tugAssistanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tug Assistance Required Flag' ;
    rdfs:comment 'Indicates whether tug (towage) assistance is required for the vessel to safely anchor or depart the anchorage area. True if tugs are needed due to vessel size, weather, or operational constraints.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vtsCoordinationReference rdf:type rdf:Property ;
    rdfs:label 'Vts Coordination Reference' ;
    rdfs:comment 'Reference number assigned by the Vessel Traffic Service for coordination and tracking of this anchorage event. Links to VTS operational logs.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Restriction Flag' ;
    rdfs:comment 'Indicates whether the anchorage booking is subject to weather-related restrictions or holds. True if adverse weather conditions (wind, swell, visibility) prevent safe anchoring or departure.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dosRecordId rdf:type rdf:Property ;
    rdfs:label 'Dos Record Id' ;
    rdfs:comment 'Foreign key linking to security.dos_record. Business justification: Declaration of Security (DoS) is mandatory ISPS requirement for ship-to-port interface. Links specific berth reservation to the DoS document covering that berthing period, enabling compliance verifica' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DosRecord .

ind:handlingOrderId rdf:type rdf:Property ;
    rdfs:label 'Handling Order Id' ;
    rdfs:comment 'Foreign key linking to cargo.handling_order. Business justification: Berth reservations enable specific handling operations - planning-to-execution link for berth utilization tracking, operational scheduling, and resource coordination. Berth allocation must reference h' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandlingOrder .

ind:mooringTariffId rdf:type rdf:Property ;
    rdfs:label 'Mooring Tariff Id' ;
    rdfs:comment 'Foreign key linking to tariff.mooring_tariff. Business justification: Berth reservations include mooring services - link to mooring tariff for gang size and time-based charges. Real business process: mooring service charge calculation and gang allocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MooringTariff .

ind:pilotageTariffId rdf:type rdf:Property ;
    rdfs:label 'Pilotage Tariff Id' ;
    rdfs:comment 'Foreign key linking to tariff.pilotage_tariff. Business justification: Berth reservations requiring pilotage services must reference pilotage tariff for cost calculation based on vessel LOA, GRT, port zone, and time of day. Real business process: pilotage charge estimati' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PilotageTariff .

ind:towageTariffId rdf:type rdf:Property ;
    rdfs:label 'Towage Tariff Id' ;
    rdfs:comment 'Foreign key linking to tariff.towage_tariff. Business justification: Berth reservations requiring towage must link to towage tariff based on vessel size, number of tugs required, and port zone. Real business process: towage charge estimation and tug resource planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TowageTariff .

ind:vesselCallBookingId rdf:type rdf:Property ;
    rdfs:label 'Vessel Call Booking Id' ;
    rdfs:comment 'Foreign key linking to booking.call_booking. Business justification: Berth reservations are created as part of vessel call bookings - they represent the physical berth slot allocation for a commercial booking. berth_reservation currently links to vessel_call_id (cross-' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CallBooking .

ind:atb rdf:type rdf:Property ;
    rdfs:label 'Atb' ;
    rdfs:comment 'Actual timestamp when the vessel completed berthing and mooring operations. Recorded for performance measurement and billing purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:atd rdf:type rdf:Property ;
    rdfs:label 'Atd' ;
    rdfs:comment 'Actual timestamp when the vessel departed the berth and the berth slot was released. Recorded for performance measurement and billing purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:beamMeters rdf:type rdf:Property ;
    rdfs:label 'Beam Meters' ;
    rdfs:comment 'Maximum width of the vessel at its widest point in meters. Used to validate berth width constraints and safe maneuvering clearances.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:berthSide rdf:type rdf:Property ;
    rdfs:label 'Berth Side' ;
    rdfs:comment 'Indicates which side of the vessel will be positioned alongside the berth face. Critical for crane positioning and cargo handling planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthUtilizationHours rdf:type rdf:Property ;
    rdfs:label 'Berth Utilization Hours' ;
    rdfs:comment 'Planned duration in hours that the berth will be occupied by this vessel. Calculated from ETB to ETD for capacity planning and billing purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when the berth reservation was cancelled. Used for berth slot release and capacity reallocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Timestamp when the berth reservation status was changed to confirmed. Marks the point when the berth slot became a firm commitment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dangerousGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Flag' ;
    rdfs:comment 'Indicates whether the vessel is carrying IMDG-classified dangerous goods requiring special berth allocation and safety protocols. True if dangerous cargo is present.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:draftMeters rdf:type rdf:Property ;
    rdfs:label 'Draft Meters' ;
    rdfs:comment 'Vertical distance between the waterline and the bottom of the vessel hull in meters. Critical for under-keel clearance calculations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dwtTonnes rdf:type rdf:Property ;
    rdfs:label 'Dwt Tonnes' ;
    rdfs:comment 'Total weight capacity of the vessel including cargo, fuel, water, stores, and crew in metric tonnes. Used for berth load capacity validation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etb rdf:type rdf:Property ;
    rdfs:label 'Etb' ;
    rdfs:comment 'Planned timestamp when the vessel is expected to berth and commence mooring operations. Used for berth slot planning and resource allocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedTeuVolume rdf:type rdf:Property ;
    rdfs:label 'Expected Teu Volume' ;
    rdfs:comment 'Anticipated number of TEU containers to be handled during this berth visit. Used for resource planning and berth productivity forecasting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:highTideTime rdf:type rdf:Property ;
    rdfs:label 'High Tide Time' ;
    rdfs:comment 'Timestamp of the next high tide event relevant to this berth reservation. Used for tidal window planning when vessel draft requires maximum water depth.' ;
    rdfs:domain ind:BookingBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loaMeters rdf:type rdf:Property ;
    rdfs:label 'Loa Meters' ;
    rdfs:comment 'Maximum length of the vessel from bow to stern in meters. Used to validate berth length capacity and ensure adequate berth space allocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowTideTime rdf:type rdf:Property ;
    rdfs:label 'Low Tide Time' ;
    rdfs:comment 'Timestamp of the next low tide event relevant to this berth reservation. Used to validate minimum under-keel clearance during the berthing period.' ;
    rdfs:domain ind:BookingBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mooringGangSize rdf:type rdf:Property ;
    rdfs:label 'Mooring Gang Size' ;
    rdfs:comment 'Number of mooring personnel required for line handling operations during berthing and unberthing. Based on vessel size and mooring configuration.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfTugs rdf:type rdf:Property ;
    rdfs:label 'Number Of Tugs' ;
    rdfs:comment 'Number of tugboats required to assist with berthing and unberthing operations. Determined by vessel size, weather conditions, and port regulations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pilotageRequired rdf:type rdf:Property ;
    rdfs:label 'Pilotage Required' ;
    rdfs:comment 'Indicates whether marine pilotage services are mandatory for this vessel berthing operation based on vessel size, cargo type, or port regulations. True if pilot is required.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningSource rdf:type rdf:Property ;
    rdfs:label 'Planning Source' ;
    rdfs:comment 'Identifies the system or module that created or last updated this berth reservation. Tracks data lineage for berth planning decisions.' ;
    rdfs:domain ind:BookingBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Created Timestamp' ;
    rdfs:comment 'Timestamp when this berth reservation record was first created in the system. Used for audit trail and booking lead time analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Human-readable unique business identifier for the berth reservation. Used for external communication and tracking. Format: BR followed by 10 digits.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle status of the berth reservation. Tracks progression from initial booking through vessel departure or cancellation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Updated Timestamp' ;
    rdfs:comment 'Timestamp when this berth reservation record was last modified. Tracks changes to berth allocation, timing, or status throughout the booking lifecycle.' ;
    rdfs:domain ind:BookingBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Requirements' ;
    rdfs:comment 'Free-text field capturing any special handling, equipment, or operational requirements for this berth reservation. Examples include reefer power, fresh water supply, or security protocols.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tidalWindowRequired rdf:type rdf:Property ;
    rdfs:label 'Tidal Window Required' ;
    rdfs:comment 'Indicates whether the vessel requires specific tidal conditions for safe berthing or departure due to draft constraints. True if tidal window planning is mandatory.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:towageRequired rdf:type rdf:Property ;
    rdfs:label 'Towage Required' ;
    rdfs:comment 'Indicates whether tugboat assistance is required for safe berthing or unberthing operations. True if towage services are needed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:underKeelClearanceMeters rdf:type rdf:Property ;
    rdfs:label 'Under Keel Clearance Meters' ;
    rdfs:comment 'Minimum required clearance between the vessel keel and the seabed in meters. Ensures safe navigation and berthing operations considering tidal variations.' ;
    rdfs:domain ind:BookingBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Unique identifier for the booking amendment record. Primary key.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalBookingId rdf:type rdf:Property ;
    rdfs:label 'Original Booking Id' ;
    rdfs:comment 'Reference to the original booking entity (vessel call booking, cargo booking, or service order) that is being amended. Links to the parent booking record in the booking system.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CallBooking .

ind:portCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Port Community Participant Id' ;
    rdfs:comment 'Reference to the party (shipping line, freight forwarder, cargo owner, or agent) who submitted the amendment request. Links to customer or stakeholder master data.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Externally-known unique amendment reference number assigned by the Port Community System (PCS) or Terminal Operating System (TOS). Format: AMD-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current status of the amendment request in the approval workflow. Tracks lifecycle from submission through approval or rejection. Superseded indicates a newer amendment has replaced this one.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the type of amendment being requested. Indicates which aspect of the original booking is being modified: ETA (Estimated Time of Arrival) change, ETB (Estimated Time of Berthing) change, ETD (Estimated Time of Departure) change, berth allocation change, cargo manifest revision, service order modification, quantity adjustment, equipment type change, full cancellation of booking, or partial cancellation. [ENUM-REF-CANDIDATE: eta_change|etb_change|etd_change|berth_change|cargo_revision|service_change|quantity_change|equipment_change|full_cancellation|partial_cancellation — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingEntityType rdf:type rdf:Property ;
    rdfs:label 'Booking Entity Type' ;
    rdfs:comment 'Identifies the type of booking entity being amended: vessel call booking, cargo booking, service order, berth reservation, or slot booking. Enables polymorphic amendment tracking across different booking types.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Amount' ;
    rdfs:comment 'Monetary amount of the cancellation or amendment fee charged to the customer. Null if no fee applies. Used for billing and revenue recognition.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Applicable' ;
    rdfs:comment 'Boolean flag indicating whether a cancellation fee or penalty charge applies to this amendment based on the amendment type, timing, and contractual terms. True if fee applies, False otherwise.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cancellation fee amount (e.g., USD, EUR, SGD). Null if no fee applies.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demurrageImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Demurrage Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether this amendment affects demurrage calculations or liability. True if the amendment impacts demurrage charges, False otherwise. Used for billing dispute resolution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediMessageType rdf:type rdf:Property ;
    rdfs:label 'Edi Message Type' ;
    rdfs:comment 'Type of EDI message sent to communicate the amendment to external systems and stakeholders. COPARN (Container Pre-Announcement), BAPLIE (Bayplan/Stowage Plan), IFTMIN (Instruction Message), CODECO (Container Discharge/Loading Order).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date when the approved amendment becomes effective and the revised booking values take effect. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldNameAmended rdf:type rdf:Property ;
    rdfs:label 'Field Name Amended' ;
    rdfs:comment 'Name of the specific booking field being amended (e.g., estimated_time_arrival, berth_code, cargo_quantity, service_type). Enables precise tracking of what aspect of the booking changed.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Boolean flag indicating whether automated notification has been sent to affected stakeholders (shipping line, cargo owner, customs, etc.) about this amendment. True if notification sent, False otherwise.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Date and time when stakeholder notification was sent via EDI (Electronic Data Interchange) or PCS messaging. Null if notification not yet sent. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalValue rdf:type rdf:Property ;
    rdfs:label 'Original Value' ;
    rdfs:comment 'The original value of the field being amended, stored as string to accommodate various data types (dates, berth codes, quantities, service codes). Provides audit trail of what was changed.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingNotes rdf:type rdf:Property ;
    rdfs:label 'Processing Notes' ;
    rdfs:comment 'Free-text notes added by port operations staff during amendment review and processing. Captures operational context, coordination details, and special handling instructions.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided by the approver when an amendment request is rejected. Null if approved or still pending. Used for customer communication and dispute resolution.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the amendment request was submitted by the requestor. Represents the principal business event timestamp for this transaction. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestorContactName rdf:type rdf:Property ;
    rdfs:label 'Requestor Contact Name' ;
    rdfs:comment 'Full name of the individual contact person who submitted the amendment request on behalf of the requestor party. Used for communication and dispute resolution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address of the requestor contact person for amendment-related communication and notifications.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorPhone rdf:type rdf:Property ;
    rdfs:label 'Requestor Phone' ;
    rdfs:comment 'Contact phone number of the requestor for urgent amendment coordination and clarification.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedValue rdf:type rdf:Property ;
    rdfs:label 'Revised Value' ;
    rdfs:comment 'The new requested value for the field being amended, stored as string to accommodate various data types. Represents the desired state after amendment approval.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationId rdf:type rdf:Property ;
    rdfs:label 'Confirmation Id' ;
    rdfs:comment 'Unique identifier for the booking confirmation record. Primary key for this entity.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmationApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Confirmation Approved By User Employee Id' ;
    rdfs:comment 'Reference to the port authority user who approved this booking confirmation before issuance. May be null if approval is not required or is automated.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:confirmationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Confirmation Employee Id' ;
    rdfs:comment 'Reference to the port authority user or system account that issued this booking confirmation.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySupersededByConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Confirmation Id' ;
    rdfs:comment 'Reference to the newer booking confirmation that supersedes this one. Null if this is the current active confirmation.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Confirmation .

ind:amendmentAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Allowed Flag' ;
    rdfs:comment 'Indicates whether amendments to this confirmation are permitted under the current terms. True if amendments can be requested; false if the confirmation is locked.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationPolicy rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy' ;
    rdfs:comment 'Description of the cancellation policy and associated fees or penalties that apply if the shipping line cancels or amends this confirmed booking.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Charges Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary amounts in this confirmation (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Externally-visible unique confirmation reference number issued to the shipping line or agent. This is the business identifier used in all communications and documentation.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current lifecycle status of the booking confirmation. Tracks whether the confirmation is active, has been amended, superseded by a newer version, or cancelled.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation document. Indicates whether this is the initial confirmation, an amendment to a prior confirmation, or a reconfirmation after schedule changes.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedBerthCode rdf:type rdf:Property ;
    rdfs:label 'Confirmed Berth Code' ;
    rdfs:comment 'The berth location code that has been confirmed and allocated for this vessel call. This is the binding berth assignment communicated to the shipping line.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedEta rdf:type rdf:Property ;
    rdfs:label 'Confirmed Eta' ;
    rdfs:comment 'The confirmed estimated time of arrival at the port as acknowledged in this confirmation. This is the ETA that the port commits to planning for.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedEtb rdf:type rdf:Property ;
    rdfs:label 'Confirmed Etb' ;
    rdfs:comment 'The confirmed estimated time of berthing as committed in this confirmation. This is the berth window that the port guarantees to the vessel.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedEtd rdf:type rdf:Property ;
    rdfs:label 'Confirmed Etd' ;
    rdfs:comment 'The confirmed estimated time of departure as committed in this confirmation. Represents the planned completion of all port operations.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedTerminalCode rdf:type rdf:Property ;
    rdfs:label 'Confirmed Terminal Code' ;
    rdfs:comment 'The terminal facility code where the vessel will be handled. Confirms the terminal assignment for cargo operations.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'The customs clearance status for this vessel call at the time of confirmation. Indicates whether pre-clearance has been obtained or if customs holds apply.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Approved Flag' ;
    rdfs:comment 'Indicates whether the port has approved the handling of dangerous goods declared in the booking. True if IMDG cargo has been reviewed and approved.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediMessageReference rdf:type rdf:Property ;
    rdfs:label 'Edi Message Reference' ;
    rdfs:comment 'The unique reference number or control number of the EDI message that transmitted this confirmation. Used for EDI reconciliation and tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Charges Amount' ;
    rdfs:comment 'The estimated total amount of all port charges and service fees for this vessel call as communicated in the confirmation. Provides cost transparency to the shipping line.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when the booking confirmation was officially issued to the shipping line or agent. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mooringServicesConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Mooring Services Confirmed Flag' ;
    rdfs:comment 'Indicates whether mooring gang services have been confirmed for berthing and unberthing operations.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfTugsConfirmed rdf:type rdf:Property ;
    rdfs:label 'Number Of Tugs Confirmed' ;
    rdfs:comment 'The number of tug vessels confirmed for this vessel call. Null if towage is not required or not yet confirmed.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pilotageConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Pilotage Confirmed Flag' ;
    rdfs:comment 'Indicates whether pilotage services have been confirmed as part of this booking. True if pilotage is confirmed and scheduled.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceOrdersConfirmedCount rdf:type rdf:Property ;
    rdfs:label 'Service Orders Confirmed Count' ;
    rdfs:comment 'The total number of service orders (pilotage, towage, mooring, etc.) that are included and confirmed as part of this booking confirmation.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaCompletionCommitmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Completion Commitment Minutes' ;
    rdfs:comment 'The committed service completion time in minutes from berthing as per the SLA terms accepted in this confirmation.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseCommitmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Response Commitment Minutes' ;
    rdfs:comment 'The committed response time in minutes for initial service acknowledgment as per the SLA terms accepted in this confirmation.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialRequirementsNotes rdf:type rdf:Property ;
    rdfs:label 'Special Requirements Notes' ;
    rdfs:comment 'Free-text field capturing any special handling requirements, operational constraints, or unique conditions confirmed for this vessel call.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAcceptedBy rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted By' ;
    rdfs:comment 'Name of the individual or role at the shipping line or agent who accepted the terms and conditions on behalf of their organization.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Flag' ;
    rdfs:comment 'Indicates whether the shipping line or agent has formally accepted the terms and conditions associated with this confirmation. True if terms have been accepted.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAcceptedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Timestamp' ;
    rdfs:comment 'Date and time when the terms and conditions were formally accepted by the shipping line or agent.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:termsAndConditionsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Version' ;
    rdfs:comment 'The version identifier of the port terms and conditions that apply to this booking confirmation. References the specific T&C document accepted by the shipping line.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:towageConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Towage Confirmed Flag' ;
    rdfs:comment 'Indicates whether towage (tug) services have been confirmed as part of this booking. True if tug assistance is confirmed and scheduled.' ;
    rdfs:domain ind:Confirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vesselName rdf:type rdf:Property ;
    rdfs:label 'Vessel Name' ;
    rdfs:comment 'Name of the vessel for which the booking is confirmed. Captured at confirmation time for reference and audit purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Number' ;
    rdfs:comment 'The voyage identifier for this specific vessel call. Captured at confirmation time to uniquely identify the voyage being confirmed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingServiceOrderId rdf:type rdf:Property ;
    rdfs:label 'Booking Service Order Id' ;
    rdfs:comment 'Unique identifier for the booking service order. Primary key for this entity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BookingServiceOrder .

ind:serviceScopeId rdf:type rdf:Property ;
    rdfs:label 'Service Scope Id' ;
    rdfs:comment 'Foreign key linking to contract.service_scope. Business justification: Service orders (pilotage, towage, mooring, waste disposal) must reference contracted service scope to validate service entitlement, apply correct rates, verify equipment/crew requirements, and ensure ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceScope .

ind:slaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Id' ;
    rdfs:comment 'Foreign key linking to contract.sla_definition. Business justification: Service orders have SLA targets (response time, completion time) that should reference master SLA definitions in contracts for consistency. Required for SLA compliance measurement, performance trackin' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual cost incurred for the service after completion. Used for final billing and financial reconciliation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the person who approved the service order. Populated when approval_required_flag is True.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedCrewCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Crew Count' ;
    rdfs:comment 'Number of crew members or personnel assigned to execute the service. Used for resource planning and cost allocation.' ;
    rdfs:domain ind:BookingServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the service order was cancelled. Used for audit trail and cancellation fee calculation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed End Timestamp' ;
    rdfs:comment 'The date and time when the port confirmed the service would be completed. Represents the committed service appointment end.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Start Timestamp' ;
    rdfs:comment 'The date and time when the port confirmed the service would begin. Represents the committed service appointment start.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Estimated cost for the service at the time of booking. Used for budgeting and customer quotation purposes.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousCargoFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Cargo Flag' ;
    rdfs:comment 'Indicates whether the service involves handling or supporting hazardous cargo as defined by International Maritime Dangerous Goods (IMDG) Code. True if hazardous, False otherwise.' ;
    rdfs:domain ind:BookingServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested End Timestamp' ;
    rdfs:comment 'The date and time when the customer or vessel agent requested the service to be completed. Defines the requested service window end.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Start Timestamp' ;
    rdfs:comment 'The date and time when the customer or vessel agent requested the service to begin. Represents the initial service window request.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestingPartyContact rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Contact' ;
    rdfs:comment 'Contact information (phone or email) for the party who requested the service. Used for operational coordination and confirmation.' ;
    rdfs:domain ind:BookingServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingPartyName rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Name' ;
    rdfs:comment 'Name of the organization or individual who requested the service. Typically the vessel agent, shipping line, or cargo owner.' ;
    rdfs:domain ind:BookingServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Service Order Number' ;
    rdfs:comment 'Externally visible unique business identifier for the service order. Used for customer communication and operational tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceQuantity rdf:type rdf:Property ;
    rdfs:label 'Service Quantity' ;
    rdfs:comment 'Quantitative measure of the service being provided. Unit depends on service type (e.g., cubic meters for bunkering, hours for pilotage, number of containers for stevedoring).' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle status of the service order. Tracks the progression from initial request through to completion or cancellation. [ENUM-REF-CANDIDATE: requested|confirmed|scheduled|in_progress|completed|cancelled|no_show — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Service Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the service quantity. Defines how the service is quantified for billing and operational tracking. [ENUM-REF-CANDIDATE: hours|cubic_meters|metric_tons|teu|feu|moves|trips|units — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BookingServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Completion Minutes' ;
    rdfs:comment 'The actual time in minutes taken to complete the service from the confirmed start time. Used for SLA compliance measurement.' ;
    rdfs:domain ind:BookingServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaActualResponseMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Response Minutes' ;
    rdfs:comment 'The actual time in minutes taken to respond to and confirm the service request. Used for SLA compliance measurement.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether the service order met all SLA commitments (response time and completion time). True if compliant, False if breached.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Minutes' ;
    rdfs:comment 'The contractual target time in minutes for the service to be completed from the confirmed start time. Part of the SLA commitment.' ;
    rdfs:domain ind:BookingServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetResponseMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Response Minutes' ;
    rdfs:comment 'The contractual target time in minutes for the port to respond to and confirm the service request. Part of the SLA commitment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callBookingId rdf:type rdf:Property ;
    rdfs:label 'Call Booking Id' ;
    rdfs:comment 'Primary key for call_booking' ;
    rdfs:domain ind:CallBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceMarpolRecordId rdf:type rdf:Property ;
    rdfs:label 'Compliance Marpol Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.marpol_record. Business justification: Vessel calls generate MARPOL waste disposal records at port (ballast water, oily waste, garbage). Port reception facilities log waste operations. Environmental compliance and IMO MARPOL requirement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarpolRecord .

ind:lastPortUnLocodeId rdf:type rdf:Property ;
    rdfs:label 'Last Port Un Locode Id' ;
    rdfs:comment 'Foreign key linking to masterdata.un_locode. Business justification: last_port_of_call field exists. FK to un_locode master enables port validation, voyage tracking, customs reporting, health declaration processing, and quarantine requirement determination for vessel c' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnLocode .

ind:primaryPortCallId rdf:type rdf:Property ;
    rdfs:label 'Primary Port Call Id' ;
    rdfs:comment 'Foreign key linking to vessel.call. Business justification: Vessel call booking represents the reservation/request for a port call, must link to the actual vessel.call record for berth planning, VTS coordination, and operational execution. Port operations team' ;
    rdfs:domain ind:CallBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Call .

ind:ata rdf:type rdf:Property ;
    rdfs:label 'Ata' ;
    rdfs:comment 'Actual timestamp when the vessel arrived at the port anchorage or pilot boarding area. Populated after arrival event occurs.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Submitted Timestamp' ;
    rdfs:comment 'Timestamp when the vessel call booking request was initially submitted by the shipping line or agent to the port.' ;
    rdfs:domain ind:CallBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedContainerMoves rdf:type rdf:Property ;
    rdfs:label 'Expected Container Moves' ;
    rdfs:comment 'Estimated total number of container handling moves (load + discharge) for this vessel call. Used for resource planning and berth time estimation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedTeu rdf:type rdf:Property ;
    rdfs:label 'Expected Teu' ;
    rdfs:comment 'Estimated total TEU volume (standardized container unit) for this vessel call. Used for yard planning and capacity management.' ;
    rdfs:domain ind:CallBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextPortOfCall rdf:type rdf:Property ;
    rdfs:label 'Next Port Of Call' ;
    rdfs:comment 'UN/LOCODE of the next port the vessel will visit after departing this port. Used for cargo planning and customs clearance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferContainerCount rdf:type rdf:Property ;
    rdfs:label 'Reefer Container Count' ;
    rdfs:comment 'Number of refrigerated containers requiring power supply and temperature monitoring during the vessel call.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceRequirements rdf:type rdf:Property ;
    rdfs:label 'Service Requirements' ;
    rdfs:comment 'Summary of requested port services for the vessel call (e.g., pilotage, towage, mooring, bunkering, waste disposal, fresh water supply).' ;
    rdfs:domain ind:CallBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRotation rdf:type rdf:Property ;
    rdfs:label 'Service Rotation' ;
    rdfs:comment 'Shipping line service route or rotation code that this vessel call is part of (e.g., Asia-Europe Express, Pacific Loop).' ;
    rdfs:domain ind:CallBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoBookingId rdf:type rdf:Property ;
    rdfs:label 'Cargo Booking Id' ;
    rdfs:comment 'Unique identifier for the cargo booking record. Primary key for the cargo booking entity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CargoBooking .

ind:cargoAgentPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Cargo Agent Port Community Participant Id' ;
    rdfs:comment 'Reference to the agent or representative who submitted the booking request on behalf of the customer.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:imdgClassId rdf:type rdf:Property ;
    rdfs:label 'Imdg Class Id' ;
    rdfs:comment 'Foreign key linking to masterdata.imdg_class. Business justification: imdg_class field exists. FK to imdg_class master enables segregation rule enforcement, stowage requirement lookup, handling procedure retrieval, EMS code reference, and SOLAS/MARPOL compliance checkin' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImdgClass .

ind:masterdataShippingLineId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Shipping Line Id' ;
    rdfs:comment 'Reference to the shipping line or slot operator who has allocated vessel capacity for this cargo booking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShippingLine .

ind:polUnLocodeId rdf:type rdf:Property ;
    rdfs:label 'Pol Un Locode Id' ;
    rdfs:comment 'Foreign key linking to masterdata.un_locode. Business justification: pol_code field exists. FK to un_locode master enables port of loading validation, origin country identification, routing verification, customs origin documentation, and freight rate zone determination' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnLocode .

ind:primaryCargoPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Primary Cargo Port Community Participant Id' ;
    rdfs:comment 'Reference to the shipper (consignor) party responsible for sending the cargo. Links to customer or stakeholder master data.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:quaternaryCargoFreightForwarderPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Cargo Freight Forwarder Port Community Participant Id' ;
    rdfs:comment 'Reference to the freight forwarder or logistics provider coordinating the cargo movement on behalf of shipper.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:screeningRecordId rdf:type rdf:Property ;
    rdfs:label 'Screening Record Id' ;
    rdfs:comment 'Foreign key linking to security.screening_record. Business justification: Cargo screening is mandatory for dangerous goods, high-value shipments, and ISPS compliance. Links booking to physical screening event outcome for customs clearance, security audit trail, and regulato' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScreeningRecord .

ind:storageTariffId rdf:type rdf:Property ;
    rdfs:label 'Storage Tariff Id' ;
    rdfs:comment 'Foreign key linking to tariff.storage_tariff. Business justification: Cargo bookings need storage tariff reference for calculating free storage days and tiered storage charges on containers based on dwell time. Real business process: demurrage/storage billing and free t' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageTariff .

ind:tertiaryCargoNotifyPartyPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Cargo Notify Party Port Community Participant Id' ;
    rdfs:comment 'Reference to the party to be notified upon cargo arrival. May be freight forwarder, customs broker, or consignee representative.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:thcScheduleId rdf:type rdf:Property ;
    rdfs:label 'Thc Schedule Id' ;
    rdfs:comment 'Foreign key linking to tariff.thc_schedule. Business justification: Terminal handling charges are fundamental to cargo booking pricing - direct link to applicable THC schedule based on container type, size, cargo category, and movement type. Core business process: THC' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThcSchedule .

ind:wharfageScheduleId rdf:type rdf:Property ;
    rdfs:label 'Wharfage Schedule Id' ;
    rdfs:comment 'Foreign key linking to tariff.wharfage_schedule. Business justification: Wharfage (cargo dues) must be calculated per cargo booking based on commodity type, weight, and applicable wharfage schedule. Real business process: wharfage charge calculation and regulatory complian' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WharfageSchedule .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date when the cargo arrived at the port of discharge. Used for demurrage calculation and performance tracking.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingDate rdf:type rdf:Property ;
    rdfs:label 'Booking Date' ;
    rdfs:comment 'Date when the cargo booking was initially created or requested by the customer.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingNumber rdf:type rdf:Property ;
    rdfs:label 'Booking Number' ;
    rdfs:comment 'Externally-known unique booking reference number issued to customer. Used for tracking and communication across stakeholders.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoType rdf:type rdf:Property ;
    rdfs:label 'Cargo Type' ;
    rdfs:comment 'Classification of cargo handling method. FCL (Full Container Load), LCL (Less than Container Load), RoRo (Roll-on Roll-off), LoLo (Lift-on Lift-off), bulk, or breakbulk.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Number' ;
    rdfs:comment 'Delivery order number authorizing release of cargo to consignee or designated party. Required for cargo pickup.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Estimated date when the cargo will arrive at the port of discharge. Used for planning and customer notification.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feuCount rdf:type rdf:Property ;
    rdfs:label 'Feu Count' ;
    rdfs:comment 'Number of Forty-foot Equivalent Units for this cargo booking. Alternative measure of container capacity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the cargo including packaging and container tare weight, measured in kilograms.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Handling Instructions' ;
    rdfs:comment 'Special handling instructions or operational notes for terminal operators. May include stacking restrictions, priority handling, or safety precautions.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDangerousGoods rdf:type rdf:Property ;
    rdfs:label 'Is Dangerous Goods' ;
    rdfs:comment 'Indicates whether the cargo contains dangerous goods requiring special handling and compliance with IMDG Code.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOversized rdf:type rdf:Property ;
    rdfs:label 'Is Oversized' ;
    rdfs:comment 'Indicates whether cargo exceeds standard container dimensions requiring special handling equipment or stowage planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverweight rdf:type rdf:Property ;
    rdfs:label 'Is Overweight' ;
    rdfs:comment 'Indicates whether cargo exceeds standard weight limits requiring heavy-duty handling equipment or special permits.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether the cargo requires temperature-controlled (reefer) container with active refrigeration or heating.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stowagePosition rdf:type rdf:Property ;
    rdfs:label 'Stowage Position' ;
    rdfs:comment 'Six-digit stowage position code from BAPLIE message. Format: BBRRTT (Bay-Row-Tier) indicating container location on vessel.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureSetpointCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Setpoint Celsius' ;
    rdfs:comment 'Target temperature setpoint for reefer cargo in degrees Celsius. Critical for perishable goods and pharmaceuticals.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teuCount rdf:type rdf:Property ;
    rdfs:label 'Teu Count' ;
    rdfs:comment 'Number of Twenty-foot Equivalent Units for this cargo booking. Standard measure of container capacity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Cbm' ;
    rdfs:comment 'Total volume of the cargo measured in cubic meters. Critical for LCL and breakbulk cargo planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preArrivalId rdf:type rdf:Property ;
    rdfs:label 'Pre Arrival Id' ;
    rdfs:comment 'Primary key for pre_arrival' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voyageId rdf:type rdf:Property ;
    rdfs:label 'Voyage Id' ;
    rdfs:comment 'Reference to the specific voyage for which this pre-arrival notification applies.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Voyage .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the port authority or maritime single window acknowledged receipt of the pre-arrival notification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bunkerFuelRequired rdf:type rdf:Property ;
    rdfs:label 'Bunker Fuel Required' ;
    rdfs:comment 'Indicates whether the vessel requires bunker fuel supply services during the port call.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cargoManifestSummary rdf:type rdf:Property ;
    rdfs:label 'Cargo Manifest Summary' ;
    rdfs:comment 'High-level summary of cargo manifest including total TEU, FEU, breakbulk tonnage, and cargo types for customs pre-clearance.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewCount rdf:type rdf:Property ;
    rdfs:label 'Crew Count' ;
    rdfs:comment 'Total number of crew members on board the vessel at the time of pre-arrival notification submission.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dangerousGoodsDeclaration rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Declaration' ;
    rdfs:comment 'Summary declaration of dangerous goods cargo including UN numbers, classes, and quantities as required by IMDG Code.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsOnboard rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Onboard' ;
    rdfs:comment 'Indicates whether the vessel is carrying dangerous goods as classified under IMDG Code.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freshWaterRequired rdf:type rdf:Property ;
    rdfs:label 'Fresh Water Required' ;
    rdfs:comment 'Indicates whether the vessel requires fresh water supply services during the port call.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthDeclarationRemarks rdf:type rdf:Property ;
    rdfs:label 'Health Declaration Remarks' ;
    rdfs:comment 'Additional remarks or details regarding the health status of crew, passengers, or sanitary conditions on board.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthDeclarationStatus rdf:type rdf:Property ;
    rdfs:label 'Health Declaration Status' ;
    rdfs:comment 'Health status declaration indicating whether any illness, disease, or health concerns exist on board requiring port health authority attention.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pan Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this pre-arrival notification by the submitting party or port authority.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCount rdf:type rdf:Property ;
    rdfs:label 'Passenger Count' ;
    rdfs:comment 'Total number of passengers on board the vessel at the time of pre-arrival notification submission.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portHealthClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Port Health Clearance Status' ;
    rdfs:comment 'Current status of port health authority clearance based on the health declaration submitted in the pre-arrival notification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDeclaration rdf:type rdf:Property ;
    rdfs:label 'Security Declaration' ;
    rdfs:comment 'Security-related declaration including last 10 ports of call, security incidents, and compliance with ISPS Code requirements.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the pre-arrival notification submission. Tracks progression from draft through approval or rejection.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the pre-arrival notification was officially submitted to the port authority or maritime single window.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submittedByEmail rdf:type rdf:Property ;
    rdfs:label 'Submitted By Email' ;
    rdfs:comment 'Email address of the individual who submitted the pre-arrival notification for communication and verification purposes.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedByName rdf:type rdf:Property ;
    rdfs:label 'Submitted By Name' ;
    rdfs:comment 'Full name of the individual (vessel master, agent representative, or shipping line officer) who submitted the pre-arrival notification.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedByPhone rdf:type rdf:Property ;
    rdfs:label 'Submitted By Phone' ;
    rdfs:comment 'Contact phone number of the individual who submitted the pre-arrival notification for urgent communication.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCargoWeightTonnes rdf:type rdf:Property ;
    rdfs:label 'Total Cargo Weight Tonnes' ;
    rdfs:comment 'Total weight of all cargo on board in metric tonnes as declared in the pre-arrival notification.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTeu rdf:type rdf:Property ;
    rdfs:label 'Total Teu' ;
    rdfs:comment 'Total container capacity in TEU (Twenty-foot Equivalent Units) declared in the cargo manifest for this vessel call.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vtsCoordinationStatus rdf:type rdf:Property ;
    rdfs:label 'Vts Coordination Status' ;
    rdfs:comment 'Status of coordination with Vessel Traffic Service for vessel arrival, pilotage scheduling, and anchorage management.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDisposalRequired rdf:type rdf:Property ;
    rdfs:label 'Waste Disposal Required' ;
    rdfs:comment 'Indicates whether the vessel requires waste disposal services (garbage, oily waste, sewage) as per MARPOL Convention.' ;
    rdfs:domain ind:PreArrival ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resourceAllocationId rdf:type rdf:Property ;
    rdfs:label 'Resource Allocation Id' ;
    rdfs:comment 'Unique identifier for the resource allocation record. Primary key for this entity.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resourceId rdf:type rdf:Property ;
    rdfs:label 'Resource Id' ;
    rdfs:comment 'Reference to the specific port asset or crew resource being allocated (crane unit, tug vessel, pilot, gang).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Resource .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual duration in hours that the resource was deployed, used for billing and performance analysis.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'Number of resource units allocated (e.g., 2 cranes, 3 tugs, 1 pilot, 4 gang members).' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Human-readable unique reference number for this resource allocation, used for operational tracking and communication.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Unit' ;
    rdfs:comment 'Unit of measure for the allocated resource quantity (individual units, gangs, crews, shifts, hours, container moves).' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingReference rdf:type rdf:Property ;
    rdfs:label 'Billing Reference' ;
    rdfs:comment 'Reference number linking this resource allocation to billing and invoicing systems for revenue capture.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'Number of personnel assigned to the resource for this allocation (e.g., gang size, tug crew complement).' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Planned duration in hours for this resource allocation, used for scheduling and capacity planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the allocated resource is certified to handle dangerous goods per IMDG Code requirements.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceNotes rdf:type rdf:Property ;
    rdfs:label 'Performance Notes' ;
    rdfs:comment 'Operational notes capturing performance observations, issues, or exceptional circumstances during resource deployment.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceType rdf:type rdf:Property ;
    rdfs:label 'Resource Type' ;
    rdfs:comment 'Category of port resource being allocated. Includes equipment (cranes, tugs, RTG, MHC) and labor (pilots, gangs). [ENUM-REF-CANDIDATE: crane|tug|pilot|mooring_gang|lashing_gang|stevedore_gang|mobile_harbour_crane|reach_stacker|forklift|rtg — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftAssignment rdf:type rdf:Property ;
    rdfs:label 'Shift Assignment' ;
    rdfs:comment 'Work shift during which the resource is allocated (day shift, night shift, swing shift, or continuous operation).' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorName rdf:type rdf:Property ;
    rdfs:label 'Supervisor Name' ;
    rdfs:comment 'Name of the supervisor or foreman responsible for overseeing this resource allocation during operations.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swlComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Swl Compliance Flag' ;
    rdfs:comment 'Indicates whether the allocated equipment resource is within its certified Safe Working Load limits for this operation.' ;
    rdfs:domain ind:ResourceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceRequirementId rdf:type rdf:Property ;
    rdfs:label 'Service Requirement Id' ;
    rdfs:comment 'Unique identifier for the service requirement record. Primary key for the service requirement entity.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingId rdf:type rdf:Property ;
    rdfs:label 'Booking Id' ;
    rdfs:comment 'Reference to the parent vessel call booking that this service requirement is part of. Links the service requirement to the overall booking context.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CallBooking .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field documenting regulatory compliance considerations, customs requirements, or trade documentation needs associated with the service requirement. May reference SOLAS, MARPOL, or local port authority regulations.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Required' ;
    rdfs:comment 'Specific type of terminal equipment required to fulfill the service. Critical for equipment dispatch planning and capacity validation. STS = Ship-to-Shore crane, MHC = Mobile Harbour Crane, RTG = Rubber Tyred Gantry, AGV = Automated Guided Vehicle.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Identifier from the source system or customer system that originated this service requirement. Enables cross-system traceability and reconciliation with external booking platforms or EDI messages.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oogCargoFlag rdf:type rdf:Property ;
    rdfs:label 'Oog Cargo Flag' ;
    rdfs:comment 'Indicates whether the service requirement involves Out of Gauge cargo that exceeds standard container dimensions. Triggers specialized handling procedures and equipment requirements.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oogDimensions rdf:type rdf:Property ;
    rdfs:label 'Oog Dimensions' ;
    rdfs:comment 'Detailed dimensional specifications for OOG cargo in format Length x Width x Height (meters). Required when oog_cargo_flag is true for safe handling and stowage planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the service quantity field. Defines how the service volume is quantified for billing and resource allocation purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferHumidityRequired rdf:type rdf:Property ;
    rdfs:label 'Reefer Humidity Required' ;
    rdfs:comment 'Target humidity level as percentage for refrigerated container monitoring. Applicable for specific cargo types requiring controlled atmosphere.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reeferTemperatureRequired rdf:type rdf:Property ;
    rdfs:label 'Reefer Temperature Required' ;
    rdfs:comment 'Target temperature setting in Celsius for refrigerated container monitoring service. Critical for maintaining cold chain integrity for perishable cargo.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedServiceDate rdf:type rdf:Property ;
    rdfs:label 'Requested Service Date' ;
    rdfs:comment 'Target date when the service is required to be performed, typically aligned with vessel ETB (Estimated Time of Berthing) or cargo operation schedule.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedServiceTime rdf:type rdf:Property ;
    rdfs:label 'Requested Service Time' ;
    rdfs:comment 'Precise timestamp when the service is required to commence, providing hour-level scheduling granularity for operational planning.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requesterContactEmail rdf:type rdf:Property ;
    rdfs:label 'Requester Contact Email' ;
    rdfs:comment 'Primary email address of the requester contact person for service requirement communication and confirmation.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterContactName rdf:type rdf:Property ;
    rdfs:label 'Requester Contact Name' ;
    rdfs:comment 'Full name of the individual submitting or responsible for the service requirement on behalf of the requester organization.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterContactPhone rdf:type rdf:Property ;
    rdfs:label 'Requester Contact Phone' ;
    rdfs:comment 'Primary telephone number of the requester contact person for urgent service coordination and operational communication.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterOrganization rdf:type rdf:Property ;
    rdfs:label 'Requester Organization' ;
    rdfs:comment 'Name of the shipping line, cargo owner, or freight forwarder organization submitting the service requirement. Acts as the commercial counterparty for the service request.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementNumber rdf:type rdf:Property ;
    rdfs:label 'Requirement Number' ;
    rdfs:comment 'Business-facing unique identifier for the service requirement, typically formatted as SR-YYYYMMDD-NNNN for external communication and tracking.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current lifecycle state of the service requirement. Tracks progression from initial declaration through approval or rejection.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text field capturing specific operational instructions, safety requirements, or handling procedures that must be followed during service execution. May include temperature settings for reefer cargo, securing requirements for OOG (Out of Gauge) cargo, or IMDG class-specific protocols.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the service requirement was formally submitted by the shipping line or cargo owner for processing. Represents the official business event timestamp for requirement intake.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vesselDwt rdf:type rdf:Property ;
    rdfs:label 'Vessel Dwt' ;
    rdfs:comment 'Deadweight Tonnage of the vessel, representing total carrying capacity. Used for berth allocation validation and service fee calculation. DWT = Deadweight Tonnage in metric tons.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselLoa rdf:type rdf:Property ;
    rdfs:label 'Vessel Loa' ;
    rdfs:comment 'Length Overall of the vessel for which services are being requested. Critical for pilotage and towage resource planning. LOA = Length Overall, measured in meters.' ;
    rdfs:domain ind:ServiceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slotReservationId rdf:type rdf:Property ;
    rdfs:label 'Slot Reservation Id' ;
    rdfs:comment 'Unique identifier for the container slot reservation record. Primary key.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerId rdf:type rdf:Property ;
    rdfs:label 'Container Id' ;
    rdfs:comment 'Foreign key linking to cargo.container. Business justification: Slot reservations allocate specific containers in vessel stowage - direct operational link for slot management, container tracking, and load planning. Slot allocation systems require container_id for ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Container .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Priority ranking for slot allocation when multiple bookings compete for limited space. Lower numbers indicate higher priority. Typically based on booking time, customer tier, contract terms, or cargo urgency. Used by auto-allocation algorithms.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bayPosition rdf:type rdf:Property ;
    rdfs:label 'Bay Position' ;
    rdfs:comment 'Longitudinal bay number on the vessel where the container is stowed. Part of the BAPLIE stowage coordinate system (bay-row-tier). Odd numbers typically indicate 20ft bays, even numbers indicate 40ft bays.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledAt rdf:type rdf:Property ;
    rdfs:label 'Cancelled At' ;
    rdfs:comment 'Date and time when the slot reservation was cancelled. Null if not cancelled. Cancellation releases the slot back to available inventory and may trigger rebooking or penalty assessment.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedAt rdf:type rdf:Property ;
    rdfs:label 'Confirmed At' ;
    rdfs:comment 'Date and time when the shipping line confirmed the slot reservation. Null if not yet confirmed. Confirmation locks the slot and triggers downstream gate and yard planning processes.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'System timestamp when this slot reservation record was first created in the terminal operating system. Used for audit trail and data lineage tracking.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID or system account that created this slot reservation record. Used for audit trail, accountability, and operational quality tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'Date and time when the unconfirmed reservation will automatically expire and be released. Typically set based on terminal policy (e.g., 24-48 hours from reservation). Null for confirmed reservations.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalDestination rdf:type rdf:Property ;
    rdfs:label 'Final Destination' ;
    rdfs:comment 'UN/LOCODE of the ultimate destination for the cargo, which may differ from port of discharge if transshipment or inland transport is involved. Used for end-to-end supply chain visibility.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversizeIndicator rdf:type rdf:Property ;
    rdfs:label 'Oversize Indicator' ;
    rdfs:comment 'Indicates whether the cargo exceeds standard container dimensions. Standard: fits within ISO container envelope. Out of Gauge: exceeds one or more dimensions. Over Height: exceeds standard height. Over Width: exceeds standard width. Over Length: exceeds standard length. OOG cargo requires special stowage planning and may incur surcharges.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfDischarge rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge' ;
    rdfs:comment 'UN/LOCODE of the port where the container will be discharged from the vessel. Five-character code. Determines discharge sequence planning and onward transport coordination.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoading rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading' ;
    rdfs:comment 'UN/LOCODE of the port where the container will be loaded onto the vessel. Five-character code (2-letter country + 3-letter location). Used for routing, customs, and manifest generation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferRequired rdf:type rdf:Property ;
    rdfs:label 'Reefer Required' ;
    rdfs:comment 'Indicates whether this slot requires a reefer plug connection for refrigerated container power supply. True for temperature-controlled cargo requiring continuous power during voyage.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reeferTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Reefer Temperature Celsius' ;
    rdfs:comment 'Required temperature setting in degrees Celsius for refrigerated containers. Null for non-reefer slots. Typical range: -30°C to +30°C. Critical for perishable cargo integrity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedAt rdf:type rdf:Property ;
    rdfs:label 'Reserved At' ;
    rdfs:comment 'Date and time when the slot was initially reserved. Marks the start of the reservation lifecycle. Used for reservation expiry calculations and slot utilization analytics.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restowIndicator rdf:type rdf:Property ;
    rdfs:label 'Restow Indicator' ;
    rdfs:comment 'Indicates whether this container requires restowing (shifting) during the voyage or at an intermediate port to access containers beneath it. True for containers that will be temporarily moved and re-stowed. Impacts operational cost and vessel schedule.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rowPosition rdf:type rdf:Property ;
    rdfs:label 'Row Position' ;
    rdfs:comment 'Transverse row number on the vessel where the container is stowed. Part of the BAPLIE stowage coordinate system. Odd numbers port side, even numbers starboard side, with 00 at centerline.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Unique seal number applied to the container door to ensure cargo integrity and detect tampering. Recorded at stuffing and verified at unstuffing. Required for customs and security compliance (ISPS, C-TPAT).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingLineCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Line Code' ;
    rdfs:comment 'Standard Carrier Alpha Code (SCAC) of the shipping line that nominated or owns this slot. Four-letter code assigned by NMFTA. Used for carrier identification, billing, and slot allocation tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotRateAmount rdf:type rdf:Property ;
    rdfs:label 'Slot Rate Amount' ;
    rdfs:comment 'Commercial rate charged for this slot reservation. May be per TEU, per container, or per booking depending on tariff structure. Null if slot is allocated under volume contract without per-slot pricing. Used for revenue recognition and billing.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slotRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Slot Rate Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the slot rate amount. Examples: USD, EUR, GBP. Null if slot_rate_amount is null.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotType rdf:type rdf:Property ;
    rdfs:label 'Slot Type' ;
    rdfs:comment 'Physical container type and size for which the slot is allocated. Determines TEU/FEU calculation, stowage constraints, and handling requirements. Standard: dry cargo. High Cube: 9ft 6in height. Reefer: refrigerated. Open Top: removable roof. Flat Rack: collapsible sides. Tank: liquid cargo. Platform: flat base only. [ENUM-REF-CANDIDATE: standard_20|standard_40|high_cube_40|high_cube_45|reefer_20|reefer_40|open_top_20|open_top_40|flat_rack_20|flat_rack_40|tank_20|platform_20|platform_40 — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stowageLocation rdf:type rdf:Property ;
    rdfs:label 'Stowage Location' ;
    rdfs:comment 'General stowage area classification on the vessel. Below Deck: in cargo holds. On Deck: above deck stacked. Hatch Cover: on top of cargo hold covers. Affects cargo safety, insurance, and handling sequence.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierPosition rdf:type rdf:Property ;
    rdfs:label 'Tier Position' ;
    rdfs:comment 'Vertical tier number on the vessel where the container is stowed. Part of the BAPLIE stowage coordinate system. 02, 04, 06 etc. for below deck; 82, 84, 86 etc. for on deck.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transshipmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Transshipment Indicator' ;
    rdfs:comment 'Indicates whether this container will be transshipped to another vessel at the port of discharge rather than being delivered to final consignee. True for transshipment cargo requiring onward vessel connection.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'System timestamp when this slot reservation record was last modified. Updated on any field change. Used for change tracking and data synchronization.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'User ID or system account that last modified this slot reservation record. Used for change audit trail and operational accountability.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedGrossMassKg rdf:type rdf:Property ;
    rdfs:label 'Verified Gross Mass Kg' ;
    rdfs:comment 'Verified Gross Mass of the container in kilograms, as required by SOLAS VGM regulation. Mandatory for all packed containers since July 2016. Used for vessel stability calculations and safe stowage planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vgmMethod rdf:type rdf:Property ;
    rdfs:label 'Vgm Method' ;
    rdfs:comment 'Method used to verify the container gross mass per SOLAS VGM regulation. Method 1: weighing the packed container. Method 2: weighing all contents and adding tare weight. Both methods are acceptable; method must be documented.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vgmVerifiedAt rdf:type rdf:Property ;
    rdfs:label 'Vgm Verified At' ;
    rdfs:comment 'Date and time when the VGM was verified. Must be before vessel loading per SOLAS requirements. Used for compliance audit trail and operational gate planning.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vgmVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Vgm Verified By' ;
    rdfs:comment 'Name or identifier of the party responsible for VGM verification (shipper, freight forwarder, or authorized agent). Required for SOLAS VGM compliance and liability tracking.' ;
    rdfs:domain ind:SlotReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightClass rdf:type rdf:Property ;
    rdfs:label 'Weight Class' ;
    rdfs:comment 'Weight category of the container for stowage planning. Light: <10 tonnes. Medium: 10-20 tonnes. Heavy: 20-30 tonnes. Super Heavy: >30 tonnes. Determines bottom-tier placement and stack height limits per vessel stability rules.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:truckGateBookingId rdf:type rdf:Property ;
    rdfs:label 'Truck Gate Booking Id' ;
    rdfs:comment 'Unique identifier for the truck gate appointment booking record. Primary key for the truck gate booking entity.' ;
    rdfs:domain ind:TruckGateBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessEventId rdf:type rdf:Property ;
    rdfs:label 'Access Event Id' ;
    rdfs:comment 'Foreign key linking to security.access_event. Business justification: Gate appointments generate access control events when truck physically enters/exits terminal. Links booking to actual access event for dwell time analysis, no-show detection, security audit trail, and' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessEvent .

ind:truckingCompanyPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Trucking Company Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Gate appointments require linking trucking company as port community participant for ISPS access control, billing integration, and customs broker validation. Trucking companies are registered particip' ;
    rdfs:domain ind:TruckGateBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual timestamp when the truck arrived at the terminal gate. Used for appointment adherence tracking and gate performance KPIs.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Date' ;
    rdfs:comment 'Scheduled date for the truck gate appointment. Used for daily gate capacity planning and slot allocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the gate appointment. Tracks progression from initial request through confirmation, arrival, processing, and completion or cancellation. [ENUM-REF-CANDIDATE: requested|confirmed|checked_in|in_progress|completed|cancelled|no_show — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentTimeSlotEnd rdf:type rdf:Property ;
    rdfs:label 'Appointment Time Slot End' ;
    rdfs:comment 'End timestamp of the scheduled appointment window. Defines the latest time the truck should arrive to honor the appointment.' ;
    rdfs:domain ind:TruckGateBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentTimeSlotStart rdf:type rdf:Property ;
    rdfs:label 'Appointment Time Slot Start' ;
    rdfs:comment 'Start timestamp of the scheduled appointment window. Defines the earliest time the truck should arrive at the gate.' ;
    rdfs:domain ind:TruckGateBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of the gate appointment based on the transaction purpose. Import delivery (container leaving terminal), export receival (container entering terminal for loading), empty return (returning empty container), empty pickup (collecting empty container), inspection, or repair movements. [ENUM-REF-CANDIDATE: import_delivery|export_receival|empty_return|empty_pickup|inspection|repair_gate_in|repair_gate_out — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Timestamp when the truck completed check-in procedures at the gate and was authorized to enter the terminal. Marks the start of gate transaction processing.' ;
    rdfs:domain ind:TruckGateBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerCondition rdf:type rdf:Property ;
    rdfs:label 'Container Condition' ;
    rdfs:comment 'Physical and cargo status of the container at the time of gate appointment. Full indicates laden container, empty indicates no cargo, damaged indicates equipment requiring inspection or repair.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerSizeType rdf:type rdf:Property ;
    rdfs:label 'Container Size Type' ;
    rdfs:comment 'ISO 6346 container size and type code. Indicates physical dimensions and equipment type (e.g., 20GP = 20-foot general purpose, 40HC = 40-foot high cube, 20RF = 20-foot refrigerated). [ENUM-REF-CANDIDATE: 20GP|40GP|40HC|45HC|20RF|40RF|20OT|40OT|20FR|40FR — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coparnMessageReference rdf:type rdf:Property ;
    rdfs:label 'Coparn Message Reference' ;
    rdfs:comment 'EDI COPARN message reference number for container pre-advice. Links the gate appointment to the electronic pre-notification received from the shipping line or freight forwarder.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Driver License Number' ;
    rdfs:comment 'Government-issued driver license number for identity verification and security screening at the port facility.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Full legal name of the truck driver assigned to the appointment. Required for security clearance and access control compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Driver Phone Number' ;
    rdfs:comment 'Mobile phone number of the driver for real-time communication regarding appointment changes, delays, or gate instructions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'Total time in minutes the truck spent inside the terminal from check-in to gate-out. Key performance indicator for gate efficiency and truck turnaround time.' ;
    rdfs:domain ind:TruckGateBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gate Out Timestamp' ;
    rdfs:comment 'Timestamp when the truck exited the terminal after completing the container transaction. Marks the completion of the gate appointment lifecycle.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:iftminMessageReference rdf:type rdf:Property ;
    rdfs:label 'Iftmin Message Reference' ;
    rdfs:comment 'EDI IFTMIN message reference number for transport instruction. Links the gate appointment to electronic shipping instructions received via EDI.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardousCargo rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Cargo' ;
    rdfs:comment 'Boolean flag indicating whether the container holds dangerous goods requiring special handling and compliance with IMDG Code regulations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOversize rdf:type rdf:Property ;
    rdfs:label 'Is Oversize' ;
    rdfs:comment 'Boolean flag indicating whether the container or cargo exceeds standard dimensions, requiring special handling equipment or routing through the terminal.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefrigerated rdf:type rdf:Property ;
    rdfs:label 'Is Refrigerated' ;
    rdfs:comment 'Boolean flag indicating whether the container is a reefer unit requiring temperature-controlled handling and power connection at the terminal.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noShowFlag rdf:type rdf:Property ;
    rdfs:label 'No Show Flag' ;
    rdfs:comment 'Boolean flag indicating whether the truck failed to arrive during the scheduled appointment window. Used for carrier performance tracking and slot utilization analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:truckLicensePlate rdf:type rdf:Property ;
    rdfs:label 'Truck License Plate' ;
    rdfs:comment 'Vehicle registration license plate number of the truck making the gate appointment. Used for vehicle identification and access control at the terminal gate.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageNominationId rdf:type rdf:Property ;
    rdfs:label 'Voyage Nomination Id' ;
    rdfs:comment 'Unique identifier for the voyage nomination record. Primary key for the voyage nomination entity.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerPreadviceId rdf:type rdf:Property ;
    rdfs:label 'Container Preadvice Id' ;
    rdfs:comment 'Unique identifier of the COPARN EDI message that originated this nomination. Enables traceability back to source system and message audit trail.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerPreadvice .

ind:nominatedBerthId rdf:type rdf:Property ;
    rdfs:label 'Nominated Berth Id' ;
    rdfs:comment 'Reference to the preferred berth requested by the shipping line for this vessel call. Subject to port authority approval based on availability and operational constraints.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Berth .

ind:processedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Voyage nominations are reviewed and processed by port planning staff who assess berth availability, terminal capacity, and service feasibility before acceptance/rejection. Tracks accountability for no' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByNominationVoyageNominationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Nomination Voyage Nomination Id' ;
    rdfs:comment 'Reference to the newer nomination that replaced this one. Null if this is the current active nomination. Used to track nomination revision history.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VoyageNomination .

ind:acceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the port authority accepted the nomination and confirmed the berth allocation. Null if nomination is still pending or was rejected.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emptyCount rdf:type rdf:Property ;
    rdfs:label 'Empty Count' ;
    rdfs:comment 'Number of empty containers nominated for repositioning during this call. Impacts yard utilization and vessel weight distribution.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exportTeu rdf:type rdf:Property ;
    rdfs:label 'Export Teu' ;
    rdfs:comment 'Nominated volume of export containers to be loaded at this port, expressed in TEU. Used for gate planning and vessel stowage preparation.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatCount rdf:type rdf:Property ;
    rdfs:label 'Hazmat Count' ;
    rdfs:comment 'Number of containers carrying dangerous goods (IMDG cargo) nominated for this call. Triggers special handling, segregation, and compliance requirements.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:importTeu rdf:type rdf:Property ;
    rdfs:label 'Import Teu' ;
    rdfs:comment 'Nominated volume of import containers to be discharged at this port, expressed in TEU. Critical for yard planning and equipment allocation.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominatedEta rdf:type rdf:Property ;
    rdfs:label 'Nominated Eta' ;
    rdfs:comment 'Shipping line\'s initial estimate of vessel arrival time at port limits. First signal in the vessel scheduling process, typically provided 7-14 days before arrival.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nominatedEtb rdf:type rdf:Property ;
    rdfs:label 'Nominated Etb' ;
    rdfs:comment 'Requested berthing time window start. Represents the shipping line\'s preferred time to commence cargo operations.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nominatedEtd rdf:type rdf:Property ;
    rdfs:label 'Nominated Etd' ;
    rdfs:comment 'Planned departure time from berth as nominated by the shipping line. Used for berth occupancy planning and resource allocation.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nominationNumber rdf:type rdf:Property ;
    rdfs:label 'Nomination Number' ;
    rdfs:comment 'Business identifier for the voyage nomination, typically provided by the shipping line or generated by the Port Community System (PCS). Used for external communication and tracking.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Nomination Received Timestamp' ;
    rdfs:comment 'Date and time when the nomination was first received by the port system. Used for SLA tracking and nomination lead-time analysis.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nominationSource rdf:type rdf:Property ;
    rdfs:label 'Nomination Source' ;
    rdfs:comment 'Channel or system through which the nomination was received. Tracks data quality and integration pathway.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationStatus rdf:type rdf:Property ;
    rdfs:label 'Nomination Status' ;
    rdfs:comment 'Current lifecycle status of the voyage nomination. Tracks progression from initial nomination through acceptance or rejection by port authority.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversizedCount rdf:type rdf:Property ;
    rdfs:label 'Oversized Count' ;
    rdfs:comment 'Number of out-of-gauge or oversized containers (open-top, flat-rack, or containers with cargo exceeding standard dimensions) nominated for this call. Requires special yard slots and handling equipment.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reeferCount rdf:type rdf:Property ;
    rdfs:label 'Reefer Count' ;
    rdfs:comment 'Number of refrigerated containers (reefers) nominated for this call. Requires special yard planning for power plug availability and monitoring.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejection Timestamp' ;
    rdfs:comment 'Date and time when the nomination was rejected by the port authority. Null if nomination was accepted or is still pending.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restowTeu rdf:type rdf:Property ;
    rdfs:label 'Restow Teu' ;
    rdfs:comment 'Nominated volume of containers requiring restow operations (discharge and reload on same vessel for improved stowage). Impacts berth time and crane productivity.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMoves rdf:type rdf:Property ;
    rdfs:label 'Total Moves' ;
    rdfs:comment 'Total number of container handling moves nominated for this vessel call (sum of all discharge and load operations). Key metric for crane hour estimation and berth productivity planning.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transhipmentTeu rdf:type rdf:Property ;
    rdfs:label 'Transhipment Teu' ;
    rdfs:comment 'Nominated volume of transhipment containers (discharge and reload) at this port, expressed in TEU. Represents containers moving between vessels without leaving port custody.' ;
    rdfs:domain ind:VoyageNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billOfLadingId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Id' ;
    rdfs:comment 'Unique identifier for the Bill of Lading record. Primary key.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfLading .

ind:packagingTypeId rdf:type rdf:Property ;
    rdfs:label 'Packaging Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.packaging_type. Business justification: BOLs must declare standardized package types for customs declarations, SOLAS VGM compliance, and cargo handling instructions. Linking to packaging_type master enables automated customs validation, dan' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingType .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'The number of amendments or corrections that have been made to this Bill of Lading since original issuance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bolStatus rdf:type rdf:Property ;
    rdfs:label 'Bol Status' ;
    rdfs:comment 'Current lifecycle status of the BOL document in the cargo handling workflow.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolType rdf:type rdf:Property ;
    rdfs:label 'Bol Type' ;
    rdfs:comment 'Classification of the BOL document type indicating the method of release and title transfer mechanism.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoDescription rdf:type rdf:Property ;
    rdfs:label 'Cargo Description' ;
    rdfs:comment 'Detailed textual description of the cargo being shipped, including commodity type, packaging, and any special characteristics.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeAddress rdf:type rdf:Property ;
    rdfs:label 'Consignee Address' ;
    rdfs:comment 'The full postal address of the consignee including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'The full legal name of the consignee (receiver) to whom the cargo is being shipped. This is the party entitled to take delivery of the goods.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCount rdf:type rdf:Property ;
    rdfs:label 'Container Count' ;
    rdfs:comment 'The total number of shipping containers (TEU/FEU) associated with this Bill of Lading.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'The total freight charge amount for transporting the cargo under this Bill of Lading.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which freight charges are denominated.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Indicates whether freight charges are prepaid by the shipper, collect from the consignee, or billed to a third party.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'The internationally standardized Harmonized System code used to classify the traded cargo for customs and tariff purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgentName rdf:type rdf:Property ;
    rdfs:label 'Issuing Agent Name' ;
    rdfs:comment 'The name of the authorized agent or freight forwarder who issued the BOL on behalf of the carrier.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Carrier Code' ;
    rdfs:comment 'The Standard Carrier Alpha Code (SCAC) of the carrier that issued the Bill of Lading.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCarrierName rdf:type rdf:Property ;
    rdfs:label 'Issuing Carrier Name' ;
    rdfs:comment 'The full legal name of the carrier or shipping line that issued the Bill of Lading.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'The date of the most recent amendment or correction to this Bill of Lading.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'The net weight of the cargo excluding packaging, measured in kilograms.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notifyPartyAddress rdf:type rdf:Property ;
    rdfs:label 'Notify Party Address' ;
    rdfs:comment 'The full postal address of the notify party including contact details for cargo arrival notification.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifyPartyName rdf:type rdf:Property ;
    rdfs:label 'Notify Party Name' ;
    rdfs:comment 'The name of the party to be notified upon arrival of the cargo at the destination port. Often the consignee or their agent.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'The total number of packages, cartons, pallets, or shipping units included in this Bill of Lading.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placeOfDelivery rdf:type rdf:Property ;
    rdfs:label 'Place Of Delivery' ;
    rdfs:comment 'The final destination location where the cargo will be delivered to the consignee, which may differ from the port of discharge in multimodal transport.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfReceipt rdf:type rdf:Property ;
    rdfs:label 'Place Of Receipt' ;
    rdfs:comment 'The location where the carrier received the cargo from the shipper, which may differ from the port of loading in multimodal transport.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podName rdf:type rdf:Property ;
    rdfs:label 'Pod Name' ;
    rdfs:comment 'The full name of the port where the cargo will be discharged from the vessel.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polName rdf:type rdf:Property ;
    rdfs:label 'Pol Name' ;
    rdfs:comment 'The full name of the port where the cargo was loaded onto the vessel.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Current status of the cargo release process indicating whether the cargo is cleared for delivery to the consignee.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseType rdf:type rdf:Property ;
    rdfs:label 'Release Type' ;
    rdfs:comment 'The method by which the cargo will be released to the consignee (original BOL surrender, telex release, express release, etc.).' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperAddress rdf:type rdf:Property ;
    rdfs:label 'Shipper Address' ;
    rdfs:comment 'The full postal address of the shipper including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'The full legal name of the shipper (consignor) who is sending the cargo. This is the party that delivers the goods to the carrier.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transhipmentPort1 rdf:type rdf:Property ;
    rdfs:label 'Transhipment Port 1' ;
    rdfs:comment 'The first intermediate port where cargo is transferred from one vessel to another during the voyage.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transhipmentPort2 rdf:type rdf:Property ;
    rdfs:label 'Transhipment Port 2' ;
    rdfs:comment 'The second intermediate port where cargo is transferred from one vessel to another during the voyage, if applicable.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselImoNumber rdf:type rdf:Property ;
    rdfs:label 'Vessel Imo Number' ;
    rdfs:comment 'The unique seven-digit IMO number assigned to the vessel for identification purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageClaimId rdf:type rdf:Property ;
    rdfs:label 'Damage Claim Id' ;
    rdfs:comment 'Unique identifier for the cargo damage or loss claim record. Primary key for the cargo damage claim entity.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimantPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Claimant Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Claim processing requires linking claimant_name to participant account for settlement payment, credit note issuance, dispute resolution workflows, and customer service case management. Essential for b' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:primaryDamageEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Damage Employee Id' ;
    rdfs:comment 'Identifier of the system user who created the cargo damage claim record.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:provisionId rdf:type rdf:Property ;
    rdfs:label 'Provision Id' ;
    rdfs:comment 'Foreign key linking to finance.provision. Business justification: Cargo damage claims require financial provisions under IFRS 37 / IAS 37 for probable obligations. Port operators create provisions when liability is probable and estimable. Direct link enables trackin' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provision .

ind:responsibleAssetPortAssetId rdf:type rdf:Property ;
    rdfs:label 'Responsible Asset Port Asset Id' ;
    rdfs:comment 'Foreign key linking to asset.port_asset. Business justification: Damage claim investigation requires identifying which specific asset (crane, forklift, RTG) caused the damage for root cause analysis, liability assessment, insurance claims, operator training needs, ' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortAsset .

ind:claimLodgementDate rdf:type rdf:Property ;
    rdfs:label 'Claim Lodgement Date' ;
    rdfs:comment 'Date when the cargo damage or loss claim was formally lodged with the port authority or terminal operator.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimLodgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Claim Lodgement Timestamp' ;
    rdfs:comment 'Precise timestamp when the cargo damage claim was received and registered in the system.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the cargo damage or loss claim for tracking and communication purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the cargo damage claim indicating its progression through the claims management workflow.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantAddress rdf:type rdf:Property ;
    rdfs:label 'Claimant Address' ;
    rdfs:comment 'Full postal address of the claimant organization or individual for formal correspondence.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactEmail rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Email' ;
    rdfs:comment 'Primary email address of the claimant for claim correspondence and updates.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactPhone rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Phone' ;
    rdfs:comment 'Primary telephone number of the claimant for claim-related communication.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantType rdf:type rdf:Property ;
    rdfs:label 'Claimant Type' ;
    rdfs:comment 'Classification of the party raising the cargo damage claim, indicating their role in the supply chain.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the cargo damage claim was formally closed and removed from active claims management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Detailed narrative description of the cargo damage or loss, including observed conditions and circumstances.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDiscoveryLocation rdf:type rdf:Property ;
    rdfs:label 'Damage Discovery Location' ;
    rdfs:comment 'Physical location within the port or terminal where the cargo damage or loss was first discovered.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDiscoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Damage Discovery Timestamp' ;
    rdfs:comment 'Precise date and time when the cargo damage or loss was first identified and reported.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:damageType rdf:type rdf:Property ;
    rdfs:label 'Damage Type' ;
    rdfs:comment 'Classification of the type of damage or loss sustained by the cargo, critical for liability assessment and insurance processing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLossValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Loss Value' ;
    rdfs:comment 'Initial estimated monetary value of the cargo damage or loss as declared by the claimant.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionRecordReference rdf:type rdf:Property ;
    rdfs:label 'Inspection Record Reference' ;
    rdfs:comment 'Reference to the formal inspection record or report conducted to assess the cargo damage.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurer Claim Reference' ;
    rdfs:comment 'Insurance company or P&I club reference number for their parallel claim processing.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerName rdf:type rdf:Property ;
    rdfs:label 'Insurer Name' ;
    rdfs:comment 'Name of the insurance company or Protection and Indemnity (P&I) club involved in the claim.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Liability Assessment' ;
    rdfs:comment 'Determination of which party bears liability for the cargo damage or loss based on investigation findings.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Liability Assessment Date' ;
    rdfs:comment 'Date when the liability determination was formally made and documented.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityAssessorName rdf:type rdf:Property ;
    rdfs:label 'Liability Assessor Name' ;
    rdfs:comment 'Name of the claims officer or assessor who conducted the liability investigation and determination.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photographicEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photographic Evidence Url' ;
    rdfs:comment 'Document management system URL or reference to photographic evidence of the cargo damage.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stevedoreCompanyName rdf:type rdf:Property ;
    rdfs:label 'Stevedore Company Name' ;
    rdfs:comment 'Name of the stevedoring company responsible for cargo handling operations at the time of damage.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyReportReference rdf:type rdf:Property ;
    rdfs:label 'Survey Report Reference' ;
    rdfs:comment 'Reference number or identifier of the independent cargo survey report documenting the damage or loss.' ;
    rdfs:domain ind:DamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Terminal Operator Code' ;
    rdfs:comment 'Code identifying the terminal operator managing the facility where the damage occurred.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Id' ;
    rdfs:comment 'Unique identifier for the delivery order record. Primary key for the cargo delivery order entity.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactPersonId rdf:type rdf:Property ;
    rdfs:label 'Contact Person Id' ;
    rdfs:comment 'Reference to the party authorized by the consignee to collect the cargo on their behalf. May be the consignee themselves or a nominated third party.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContactPerson .

ind:importExportPermitId rdf:type rdf:Property ;
    rdfs:label 'Import Export Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.import_export_permit. Business justification: Delivery orders for controlled goods must reference valid import/export permits. Real business process: terminal gate release procedures require permit validation before cargo handover; gate systems v' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImportExportPermit .

ind:issuingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Issuing Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Delivery orders are legal cargo release documents requiring documented issuing officer for regulatory compliance, fraud prevention, dispute resolution, and audit trail. Port operations track which aut' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originalDeliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Original Delivery Order Id' ;
    rdfs:comment 'Self-referencing foreign key to the original delivery order if this D/O is a reissue, amendment, or replacement. Null for original D/Os.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryOrder .

ind:primaryDeliveryPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Port Community Participant Id' ;
    rdfs:comment 'Reference to the shipping line agent or freight forwarder who issued the delivery order on behalf of the carrier.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:visitorLogId rdf:type rdf:Property ;
    rdfs:label 'Visitor Log Id' ;
    rdfs:comment 'Foreign key linking to security.visitor_log. Business justification: Delivery order collection by external parties (freight forwarders, trucking companies) logged as visitor access. Links cargo release to visitor record, enabling verification of authorized collector id' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisitorLog .

ind:authorizedCollectorIdNumber rdf:type rdf:Property ;
    rdfs:label 'Authorized Collector Id Number' ;
    rdfs:comment 'The government-issued identification number of the authorized collector presented at the gate for verification. May be passport, national ID, or driver license number.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedCollectorName rdf:type rdf:Property ;
    rdfs:label 'Authorized Collector Name' ;
    rdfs:comment 'The full name of the individual authorized to collect the cargo on behalf of the consignee. Used for gate verification and security purposes.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDatetime rdf:type rdf:Property ;
    rdfs:label 'Cancellation Datetime' ;
    rdfs:comment 'The date and time when the delivery order was cancelled. Null if the D/O has not been cancelled.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Status' ;
    rdfs:comment 'Current lifecycle status of the delivery order. Tracks the D/O from issuance through presentation at the terminal to final cargo release or cancellation.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demurrageClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Demurrage Cleared Flag' ;
    rdfs:comment 'Boolean flag indicating whether any demurrage charges for container detention beyond free time have been paid or waived. True if cleared, false if outstanding.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detentionClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Detention Cleared Flag' ;
    rdfs:comment 'Boolean flag indicating whether any detention charges for container usage beyond free time outside the terminal have been paid or waived. True if cleared, false if outstanding.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Freight Clearance Status' ;
    rdfs:comment 'Indicates whether all freight charges have been paid or cleared by the consignee or shipper. Cargo release is typically conditional on freight clearance.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portDuesClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Port Dues Clearance Status' ;
    rdfs:comment 'Indicates whether all port-related charges including Terminal Handling Charges (THC), wharfage, and Port Infrastructure Levy (PIL) have been cleared.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfDischargeCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge Code' ;
    rdfs:comment 'The UN/LOCODE five-character code identifying the port where the cargo is being discharged and released. Typically the port operating this delivery order system.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationDatetime rdf:type rdf:Property ;
    rdfs:label 'Presentation Datetime' ;
    rdfs:comment 'The date and time when the delivery order was first presented at the terminal gate or Container Freight Station (CFS) for cargo collection.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseDatetime rdf:type rdf:Property ;
    rdfs:label 'Release Datetime' ;
    rdfs:comment 'The precise date and time when the cargo was physically released to the authorized collector at the terminal gate or Container Yard (CY).' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseLocation rdf:type rdf:Property ;
    rdfs:label 'Release Location' ;
    rdfs:comment 'The physical location within the port where the cargo was released. May be terminal gate, Container Yard (CY), Container Freight Station (CFS), warehouse, or berth.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revalidationCount rdf:type rdf:Property ;
    rdfs:label 'Revalidation Count' ;
    rdfs:comment 'The number of times this delivery order has been revalidated or extended beyond its original validity date. Tracks D/O lifecycle complexity.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminalCode rdf:type rdf:Property ;
    rdfs:label 'Terminal Code' ;
    rdfs:comment 'The code identifying the specific terminal within the port where the cargo is located and from which it will be released.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityDate rdf:type rdf:Property ;
    rdfs:label 'Validity Date' ;
    rdfs:comment 'The expiration date until which the delivery order remains valid for cargo release. After this date, the D/O may require revalidation or reissuance.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vehicleRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration Number' ;
    rdfs:comment 'The registration plate number of the truck or vehicle used to collect the cargo from the terminal. Captured at gate-out for security and tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoDocumentId rdf:type rdf:Property ;
    rdfs:label 'Cargo Document Id' ;
    rdfs:comment 'Unique identifier for the cargo document record. Primary key.' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holderPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Holder Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Cargo documents (certificates of origin, insurance, phytosanitary) are issued to/held by specific participants. Essential for customs clearance workflows, compliance audits, document release authoriza' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:verifyingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verifying Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customs clearance, phytosanitary certificates, and origin documents require documented verifying officer for compliance audit trail, customs disputes, and regulatory inspections. Port community system' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Detailed textual description of the commodity or cargo covered by this document.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIssue rdf:type rdf:Property ;
    rdfs:label 'Country Of Issue' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country where the document was issued.' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country where the cargo originated or was manufactured.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Number' ;
    rdfs:comment 'Unique customs entry or declaration number assigned by the customs authority. Applicable to customs entry documents.' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValue rdf:type rdf:Property ;
    rdfs:label 'Declared Value' ;
    rdfs:comment 'Declared commercial value of the cargo covered by this document, used for customs and insurance purposes.' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalCopyReference rdf:type rdf:Property ;
    rdfs:label 'Digital Copy Reference' ;
    rdfs:comment 'URI, file path, or document management system reference pointing to the digital copy or scanned image of the cargo document.' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The unique document number or reference code assigned by the issuing authority or system. Business identifier for the cargo document.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the cargo document in the trade compliance and customs clearance workflow.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the cargo document type. Excludes BOL, DGD (Dangerous Goods Declaration), and VGM (Verified Gross Mass) which have dedicated products. [ENUM-REF-CANDIDATE: packing_list|certificate_of_origin|phytosanitary_certificate|fumigation_certificate|weight_certificate|customs_entry|inspection_certificate|insurance_certificate|commercial_invoice — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Total customs duty amount assessed for the cargo covered by this document. Applicable to customs entry documents.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOriginal rdf:type rdf:Property ;
    rdfs:label 'Is Original' ;
    rdfs:comment 'Boolean flag indicating whether this record represents the original document (True) or a copy (False).' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Code' ;
    rdfs:comment 'Standardized code or identifier for the issuing authority, if applicable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the cargo document was submitted to the port authority, customs, or relevant regulatory body.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittedBy rdf:type rdf:Property ;
    rdfs:label 'Submitted By' ;
    rdfs:comment 'Name or identifier of the party (shipping line, freight forwarder, customs broker) that submitted the cargo document.' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Date' ;
    rdfs:comment 'Date on which the treatment (fumigation, inspection, etc.) was performed on the cargo.' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentType rdf:type rdf:Property ;
    rdfs:label 'Treatment Type' ;
    rdfs:comment 'Type of treatment applied to the cargo, applicable to fumigation and phytosanitary certificates (e.g., methyl bromide fumigation, heat treatment).' ;
    rdfs:domain ind:CargoDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which the cargo document was verified by the relevant authority.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status indicating whether the cargo document has been verified by customs or port authorities for authenticity and compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestId rdf:type rdf:Property ;
    rdfs:label 'Manifest Id' ;
    rdfs:comment 'Unique identifier for the cargo manifest record. Primary key for the cargo manifest entity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manifest .

ind:manifestEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manifest Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that created the manifest record. Used for audit and accountability purposes.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:manifestLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manifest Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that last modified the manifest record. Used for audit and accountability purposes.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:vesselTypeId rdf:type rdf:Property ;
    rdfs:label 'Vessel Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.vessel_type. Business justification: Cargo manifests have vessel-type-specific regulatory requirements (SOLAS chapters, MARPOL annexes vary by vessel category). Linking enables automated manifest validation rules, customs submission form' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VesselType .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Business justification for manifest amendment. Documents why corrections were required after initial submission.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentVersion rdf:type rdf:Property ;
    rdfs:label 'Amendment Version' ;
    rdfs:comment 'Version number tracking manifest amendments. Increments with each correction or update submitted after initial filing. Version 1 represents original submission.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Date and time when the manifest was finalized and closed for further amendments. Represents completion of cargo documentation for this vessel call.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Inspection Required Flag' ;
    rdfs:comment 'Indicates whether customs authority has flagged this manifest for physical inspection. True if inspection required.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Reference Number' ;
    rdfs:comment 'Unique reference number assigned by customs authority upon manifest submission. Used for customs clearance tracking and compliance verification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Submission Status' ;
    rdfs:comment 'Status of the manifest submission to customs authority. Tracks customs clearance workflow from initial submission through final clearance or rejection.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the digitally stored manifest document in the document management system. Provides access to original manifest filing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emptyContainerCount rdf:type rdf:Property ;
    rdfs:label 'Empty Container Count' ;
    rdfs:comment 'Number of empty containers listed in the manifest for repositioning or return to depot.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fclContainerCount rdf:type rdf:Property ;
    rdfs:label 'Fcl Container Count' ;
    rdfs:comment 'Number of Full Container Load (FCL) shipments in the manifest where a single shipper uses the entire container.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:highValueCargoFlag rdf:type rdf:Property ;
    rdfs:label 'High Value Cargo Flag' ;
    rdfs:comment 'Indicates whether the manifest contains high-value cargo requiring enhanced security measures and insurance coverage. True if high-value cargo present.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this manifest record is currently active and valid. False if the manifest has been superseded, cancelled, or archived.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lclContainerCount rdf:type rdf:Property ;
    rdfs:label 'Lcl Container Count' ;
    rdfs:comment 'Number of Less than Container Load (LCL) shipments in the manifest where multiple shippers share container space through consolidation.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Unique business identifier for the cargo manifest as assigned by the submitting agent or Port Community System (PCS). Used for external reference and customs tracking.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Status' ;
    rdfs:comment 'Current lifecycle status of the manifest. Draft: being prepared; Submitted: sent to customs/PCS; Acknowledged: received by authority; Accepted: approved for processing; Rejected: contains errors; Amended: corrections applied; Closed: finalized and archived. [ENUM-REF-CANDIDATE: draft|submitted|acknowledged|accepted|rejected|amended|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestType rdf:type rdf:Property ;
    rdfs:label 'Manifest Type' ;
    rdfs:comment 'Classification of the manifest based on cargo movement direction and trade type. Import: cargo arriving at port of discharge; Export: cargo departing from port of loading; Transshipment: cargo transferred between vessels; Coastal: domestic cargo movement.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversizedCargoFlag rdf:type rdf:Property ;
    rdfs:label 'Oversized Cargo Flag' ;
    rdfs:comment 'Indicates whether the manifest contains out-of-gauge (OOG) or oversized cargo exceeding standard container dimensions. True if oversized cargo present.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcsAcknowledgementReference rdf:type rdf:Property ;
    rdfs:label 'Pcs Acknowledgement Reference' ;
    rdfs:comment 'Unique reference number issued by the Port Community System (PCS) upon successful receipt of the manifest. Used for tracking and audit purposes.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podPortCode rdf:type rdf:Property ;
    rdfs:label 'Pod Port Code' ;
    rdfs:comment 'UN/LOCODE five-character code identifying the port where cargo will be discharged from the vessel. Format: 2-letter country code + 3-letter location code.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polPortCode rdf:type rdf:Property ;
    rdfs:label 'Pol Port Code' ;
    rdfs:comment 'UN/LOCODE five-character code identifying the port where cargo was originally loaded onto the vessel. Format: 2-letter country code + 3-letter location code.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Required Flag' ;
    rdfs:comment 'Indicates whether cargo in this manifest requires quarantine inspection by biosecurity or agricultural authorities. True if quarantine required.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reeferCargoFlag rdf:type rdf:Property ;
    rdfs:label 'Reefer Cargo Flag' ;
    rdfs:comment 'Indicates whether the manifest contains refrigerated (reefer) containers requiring temperature-controlled storage and monitoring. True if reefer cargo present.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalBolCount rdf:type rdf:Property ;
    rdfs:label 'Total Bol Count' ;
    rdfs:comment 'Total number of Bill of Lading (BOL) entries included in this manifest. Used for manifest reconciliation and completeness verification.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalContainerCount rdf:type rdf:Property ;
    rdfs:label 'Total Container Count' ;
    rdfs:comment 'Total number of containers (TEU and FEU combined) listed in this manifest. Includes all container types and sizes.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDeclaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Declared Value Usd' ;
    rdfs:comment 'Total declared customs value of all cargo in the manifest, expressed in United States Dollars (USD). Used for duty calculation and insurance purposes.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTeuCount rdf:type rdf:Property ;
    rdfs:label 'Total Teu Count' ;
    rdfs:comment 'Total cargo volume expressed in Twenty-foot Equivalent Units (TEU). Standard measure for container capacity where one 40-foot container equals 2 TEU.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cbm' ;
    rdfs:comment 'Total cargo volume measured in cubic meters (CBM). Used for capacity planning and freight calculation.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightMt rdf:type rdf:Property ;
    rdfs:label 'Total Weight Mt' ;
    rdfs:comment 'Total gross weight of all cargo listed in the manifest, measured in metric tons (MT). Includes container tare weight and cargo weight.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transhipmentContainerCount rdf:type rdf:Property ;
    rdfs:label 'Transhipment Container Count' ;
    rdfs:comment 'Number of containers in the manifest designated for transshipment to another vessel at this port.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moveId rdf:type rdf:Property ;
    rdfs:label 'Move Id' ;
    rdfs:comment 'Unique identifier for each individual cargo or container handling move transaction. Primary key for the cargo move record.' ;
    rdfs:domain ind:Move ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetPortAssetId rdf:type rdf:Property ;
    rdfs:label 'Asset Port Asset Id' ;
    rdfs:comment 'Foreign key linking to asset.port_asset. Business justification: Asset performance reporting requires linking cargo moves to specific port assets (cranes, RTGs, reach stackers) for utilization analysis, MTBF/MTTR calculation, maintenance correlation, and cost alloc' ;
    rdfs:domain ind:Move ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortAsset .

ind:gangId rdf:type rdf:Property ;
    rdfs:label 'Gang Id' ;
    rdfs:comment 'Reference to the stevedore gang or work crew assigned to this move. Used for gang productivity analysis and labor costing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gang .

ind:originTerminalZoneId rdf:type rdf:Property ;
    rdfs:label 'Origin Terminal Zone Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.terminal_zone. Business justification: Cargo moves have origin zones (yard, CFS, gate); essential for move tracking, equipment routing, and operational analytics. Origin_location_code is unstructured; zone FK enables proper operational rep' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalZone .

ind:originWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Origin Warehouse Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.warehouse. Business justification: Cargo moves originating from warehouses (LCL destuffing, bonded release) are fundamental port operations; required for warehouse inventory reconciliation, billing, and operational tracking of CFS acti' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:containerSizeTeu rdf:type rdf:Property ;
    rdfs:label 'Container Size Teu' ;
    rdfs:comment 'Container size expressed in TEU. Standard 20ft = 1.0 TEU, 40ft = 2.0 TEU, 45ft = 2.25 TEU. Used for productivity normalization.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerTypeIso rdf:type rdf:Property ;
    rdfs:label 'Container Type Iso' ;
    rdfs:comment 'ISO 6346 4-character container type code indicating size and type (e.g., 22G1 for 20ft general purpose, 45R1 for 40ft high cube reefer).' ;
    rdfs:domain ind:Move ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Status' ;
    rdfs:comment 'Current customs clearance status of the cargo. Indicates whether cargo has been released by customs authorities for movement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageReported rdf:type rdf:Property ;
    rdfs:label 'Damage Reported' ;
    rdfs:comment 'Boolean flag indicating whether container or cargo damage was reported during this move. Triggers damage assessment workflow.' ;
    rdfs:domain ind:Move ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Specific location code where the container was placed. May be berth number, yard block-bay-row-tier, gate lane, or rail track identifier.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationType rdf:type rdf:Property ;
    rdfs:label 'Destination Location Type' ;
    rdfs:comment 'Classification of the destination facility where the move ended. Defines the target context for the move.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPosition rdf:type rdf:Property ;
    rdfs:label 'Destination Position' ;
    rdfs:comment 'Detailed position coordinates at destination. For vessel: bay-row-tier from BAPLIE. For yard: block-bay-row-tier. For gate: lane number.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from move start to completion. Key metric for crane productivity (Moves Per Hour) and operational efficiency analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code identifying any exception or deviation that occurred during the move (e.g., damage, delay, equipment failure). Null for normal moves.' ;
    rdfs:domain ind:Move ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed description of any exception or issue encountered during the move execution. Free text field for operational notes.' ;
    rdfs:domain ind:Move ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Boolean flag indicating whether the cargo is classified as dangerous goods under IMDG Code. True if hazardous, false otherwise.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReefer rdf:type rdf:Property ;
    rdfs:label 'Is Reefer' ;
    rdfs:comment 'Boolean flag indicating whether the container is a refrigerated (reefer) unit requiring temperature control and power connection.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kind rdf:type rdf:Property ;
    rdfs:label 'Kind' ;
    rdfs:comment 'Classification indicating whether container is full or empty and the business purpose of the move. Distinguishes Full Container Load (FCL) from empty repositioning.' ;
    rdfs:domain ind:Move ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moveStatus rdf:type rdf:Property ;
    rdfs:label 'Move Status' ;
    rdfs:comment 'Current lifecycle status of the cargo move. Tracks progression from planning through execution to completion. [ENUM-REF-CANDIDATE: planned|dispatched|in_progress|completed|cancelled|failed|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Move ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moveType rdf:type rdf:Property ;
    rdfs:label 'Move Type' ;
    rdfs:comment 'Classification of the cargo handling move operation. Defines the nature of the container movement within terminal operations. [ENUM-REF-CANDIDATE: discharge|load|shift|restow|yard_move|gate_in|gate_out|rail_in|rail_out|empty_pickup|empty_return — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Move ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Specific location code where the container was picked up. May be berth number, yard block-bay-row-tier, gate lane, or rail track identifier.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationType rdf:type rdf:Property ;
    rdfs:label 'Origin Location Type' ;
    rdfs:comment 'Classification of the origin facility where the move started. Defines the source context for the move.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPosition rdf:type rdf:Property ;
    rdfs:label 'Origin Position' ;
    rdfs:comment 'Detailed position coordinates at origin. For vessel: bay-row-tier from BAPLIE. For yard: block-bay-row-tier. For gate: lane number.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Specific stage or leg of the move indicating origin and destination facility types. Defines the operational context of the move. [ENUM-REF-CANDIDATE: vessel_to_yard|yard_to_vessel|yard_to_yard|yard_to_gate|gate_to_yard|vessel_to_vessel|rail_to_yard|yard_to_rail — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Move ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transhipmentPort rdf:type rdf:Property ;
    rdfs:label 'Transhipment Port' ;
    rdfs:comment 'UN/LOCODE for intermediate transhipment port if cargo is being transferred between vessels. Null for direct shipments.' ;
    rdfs:domain ind:Move ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stowagePlanId rdf:type rdf:Property ;
    rdfs:label 'Stowage Plan Id' ;
    rdfs:comment 'Unique identifier for the cargo stowage plan record. Primary key for the vessel stowage plan associated with a specific vessel call.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StowagePlan .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Identifier of the supervisor or operations manager who approved the stowage plan. Ensures accountability in the approval workflow.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryStowageEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stowage Employee Id' ;
    rdfs:comment 'Identifier of the vessel planner or stowage coordinator responsible for creating this plan. Links to workforce management system.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baplieMessageReference rdf:type rdf:Property ;
    rdfs:label 'Baplie Message Reference' ;
    rdfs:comment 'Unique reference number for the BAPLIE EDI message transmitted for this stowage plan. BAPLIE is the standard EDI message format for vessel stowage plans in maritime logistics.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeCount rdf:type rdf:Property ;
    rdfs:label 'Discharge Count' ;
    rdfs:comment 'Total number of containers to be discharged at this port according to the stowage plan. Used for berth productivity planning.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatContainerCount rdf:type rdf:Property ;
    rdfs:label 'Hazmat Container Count' ;
    rdfs:comment 'Total number of containers carrying dangerous goods according to IMDG classification. Used for safety planning and regulatory compliance.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatSegregationCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Segregation Compliant Flag' ;
    rdfs:comment 'Indicates whether the stowage plan complies with IMDG Code segregation requirements for dangerous goods. True means all hazmat containers are properly segregated according to their class.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ladenContainerCount rdf:type rdf:Property ;
    rdfs:label 'Laden Container Count' ;
    rdfs:comment 'Number of loaded (full) containers in the stowage plan. Represents containers carrying cargo as opposed to empty repositioning units.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listValueDegrees rdf:type rdf:Property ;
    rdfs:label 'List Value Degrees' ;
    rdfs:comment 'Lateral inclination of the vessel from vertical measured in degrees. Indicates port or starboard tilt. Must be within safe limits for vessel operations.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadCount rdf:type rdf:Property ;
    rdfs:label 'Load Count' ;
    rdfs:comment 'Total number of containers to be loaded at this port according to the stowage plan. Used for yard and gate operations planning.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oogCount rdf:type rdf:Property ;
    rdfs:label 'Oog Count' ;
    rdfs:comment 'Number of out-of-gauge containers in the stowage plan. OOG containers exceed standard dimensions and require special stowage considerations.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planApprovalDatetime rdf:type rdf:Property ;
    rdfs:label 'Plan Approval Datetime' ;
    rdfs:comment 'Date and time when the stowage plan was officially approved for execution. Marks the transition from planning to operational phase.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planCompletionDatetime rdf:type rdf:Property ;
    rdfs:label 'Plan Completion Datetime' ;
    rdfs:comment 'Date and time when the actual loading operations according to this plan were completed. Used for operational performance tracking.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planRemarks rdf:type rdf:Property ;
    rdfs:label 'Plan Remarks' ;
    rdfs:comment 'Free-text field for planner notes, special instructions, or operational considerations related to this stowage plan. Captures context not represented in structured fields.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planSubmissionDatetime rdf:type rdf:Property ;
    rdfs:label 'Plan Submission Datetime' ;
    rdfs:comment 'Date and time when the stowage plan was submitted for approval. Tracks the planning timeline and compliance with submission deadlines.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number of the stowage plan. Increments with each revision to track changes and updates to the plan during the planning lifecycle.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferPlugCapacity rdf:type rdf:Property ;
    rdfs:label 'Reefer Plug Capacity' ;
    rdfs:comment 'Total number of refrigerated container electrical connection points available on the vessel. Defines the maximum number of reefer containers that can be powered simultaneously.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reeferPlugCountUsed rdf:type rdf:Property ;
    rdfs:label 'Reefer Plug Count Used' ;
    rdfs:comment 'Number of refrigerated container electrical connection points (plugs) utilized in this stowage plan. Used to manage vessel power capacity for temperature-controlled cargo.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restowCount rdf:type rdf:Property ;
    rdfs:label 'Restow Count' ;
    rdfs:comment 'Number of containers that need to be temporarily moved (restowed) to access containers underneath. Indicates stowage plan efficiency and operational complexity.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stabilityCalculationReference rdf:type rdf:Property ;
    rdfs:label 'Stability Calculation Reference' ;
    rdfs:comment 'Reference identifier for the vessel stability calculation document or system record. Links to detailed stability analysis ensuring safe loading conditions.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFeuLoaded rdf:type rdf:Property ;
    rdfs:label 'Total Feu Loaded' ;
    rdfs:comment 'Number of forty-foot equivalent containers loaded on the vessel. Complements TEU count for detailed capacity tracking.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTeuCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Teu Capacity' ;
    rdfs:comment 'Maximum container capacity of the vessel expressed in TEU. Represents the total number of twenty-foot equivalent containers the vessel can carry.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTeuLoaded rdf:type rdf:Property ;
    rdfs:label 'Total Teu Loaded' ;
    rdfs:comment 'Actual number of TEU loaded on the vessel according to this stowage plan. Used to calculate vessel utilization and capacity management.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trimValueMeters rdf:type rdf:Property ;
    rdfs:label 'Trim Value Meters' ;
    rdfs:comment 'Difference in draft between the forward and aft of the vessel measured in meters. Positive value indicates stern trim, negative indicates bow trim. Critical for vessel stability and navigation safety.' ;
    rdfs:domain ind:StowagePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stowagePositionId rdf:type rdf:Property ;
    rdfs:label 'Stowage Position Id' ;
    rdfs:comment 'Unique identifier for the cargo stowage position record. Primary key for individual container slot assignments within vessel stowage plans.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStowagePortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Primary Stowage Port Community Participant Id' ;
    rdfs:comment 'Reference to the shipper (consignor) party responsible for the cargo in this container. Links to customer/participant master data.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:primaryStowageVesselId rdf:type rdf:Property ;
    rdfs:label 'Primary Stowage Vessel Id' ;
    rdfs:comment 'Reference to the vessel on which this container is stowed. Links to vessel master data for ship identification.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vessel .

ind:bayNumber rdf:type rdf:Property ;
    rdfs:label 'Bay Number' ;
    rdfs:comment 'Longitudinal position identifier on the vessel from bow to stern. Two or three-digit numeric code representing the bay location in the vessel\'s cell structure.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingReference rdf:type rdf:Property ;
    rdfs:label 'Booking Reference' ;
    rdfs:comment 'Shipping line booking number or reservation reference associated with this container. Links stowage position to commercial booking and Bill of Lading (BOL).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerHeightMm rdf:type rdf:Property ;
    rdfs:label 'Container Height Mm' ;
    rdfs:comment 'Physical height of the container in millimeters. Standard values include 2591mm (standard), 2896mm (high cube). Used for clearance and stacking calculations.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerWeightKg rdf:type rdf:Property ;
    rdfs:label 'Container Weight Kg' ;
    rdfs:comment 'Verified gross mass of the container including cargo and tare weight, measured in kilograms. Critical for vessel stability calculations and SOLAS VGM compliance.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discharged Timestamp' ;
    rdfs:comment 'Date and time when the container was physically discharged from this stowage position. Null for containers still on board. Captured from terminal operating system crane operations.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isoPositionCode rdf:type rdf:Property ;
    rdfs:label 'Iso Position Code' ;
    rdfs:comment 'Six-digit ISO 9711 compliant position code combining bay, row, and tier numbers. Standard format for container slot identification in BAPLIE messages.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lashingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lashing Required Flag' ;
    rdfs:comment 'Boolean indicator whether this container requires special lashing or securing beyond standard cell guides. True for deck cargo, OOG, or heavy containers requiring additional securing.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loaded Timestamp' ;
    rdfs:comment 'Date and time when the container was physically loaded into this stowage position on the vessel. Captured from terminal operating system crane operations.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oogFlag rdf:type rdf:Property ;
    rdfs:label 'Oog Flag' ;
    rdfs:comment 'Boolean indicator whether this container carries out-of-gauge cargo exceeding standard container dimensions. True for OOG cargo requiring special handling and stowage considerations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overhangAftMm rdf:type rdf:Property ;
    rdfs:label 'Overhang Aft Mm' ;
    rdfs:comment 'Aft overhang dimension in millimeters for out-of-gauge cargo extending beyond the container rear. Null for standard cargo. Used for clearance and lashing calculations.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overhangForeMm rdf:type rdf:Property ;
    rdfs:label 'Overhang Fore Mm' ;
    rdfs:comment 'Forward overhang dimension in millimeters for out-of-gauge cargo extending beyond the container front. Null for standard cargo. Used for clearance and lashing calculations.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overhangHeightMm rdf:type rdf:Property ;
    rdfs:label 'Overhang Height Mm' ;
    rdfs:comment 'Vertical overhang dimension in millimeters for out-of-gauge cargo extending above the container top. Null for standard cargo. Used for clearance and bridge height calculations.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overhangPortMm rdf:type rdf:Property ;
    rdfs:label 'Overhang Port Mm' ;
    rdfs:comment 'Port side overhang dimension in millimeters for out-of-gauge cargo extending beyond the container left side. Null for standard cargo. Used for clearance and lashing calculations.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overhangStarboardMm rdf:type rdf:Property ;
    rdfs:label 'Overhang Starboard Mm' ;
    rdfs:comment 'Starboard side overhang dimension in millimeters for out-of-gauge cargo extending beyond the container right side. Null for standard cargo. Used for clearance and lashing calculations.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Timestamp' ;
    rdfs:comment 'Date and time when this stowage position was initially planned and assigned in the vessel planning system. Represents the planning event in the position lifecycle.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the stowage position assignment. Tracks progression from planning through execution: planned (initial assignment), confirmed (verified by planner), loaded (physically loaded), discharged (removed from vessel), restowed (repositioned), cancelled (assignment voided).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowNumber rdf:type rdf:Property ;
    rdfs:label 'Row Number' ;
    rdfs:comment 'Transverse position identifier across the vessel from port to starboard. Two-digit numeric code with odd numbers on port side and even numbers on starboard side.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stowageCategory rdf:type rdf:Property ;
    rdfs:label 'Stowage Category' ;
    rdfs:comment 'General stowage location category on the vessel: deck (above deck), hold (cargo hold), underdeck (below deck), hatch (hatch cover area). Affects cargo protection and accessibility.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureSettingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Setting Celsius' ;
    rdfs:comment 'Target temperature setting for refrigerated containers in degrees Celsius. Null for non-reefer containers. Range typically -30°C to +30°C for perishable cargo.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierNumber rdf:type rdf:Property ;
    rdfs:label 'Tier Number' ;
    rdfs:comment 'Vertical position identifier from keel to deck. Two-digit numeric code representing the tier level in the vessel\'s stacking structure.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transhipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Transhipment Flag' ;
    rdfs:comment 'Boolean indicator whether this container is in transit and will be transferred to another vessel at this port. True for transhipment cargo, False for origin/destination cargo.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ventilationSettingCbmPerHour rdf:type rdf:Property ;
    rdfs:label 'Ventilation Setting Cbm Per Hour' ;
    rdfs:comment 'Ventilation airflow rate for reefer containers measured in cubic meters per hour. Null for non-reefer containers. Critical for cargo requiring fresh air exchange.' ;
    rdfs:domain ind:StowagePosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compatibleVesselTypeId rdf:type rdf:Property ;
    rdfs:label 'Compatible Vessel Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.vessel_type. Business justification: Container-vessel compatibility validation is critical for stowage planning (e.g., reefer containers require vessels with reefer plug capacity, oversized containers require specific vessel configuratio' ;
    rdfs:domain ind:Container ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VesselType .

ind:containerTypeId rdf:type rdf:Property ;
    rdfs:label 'Container Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.container_type. Business justification: Cargo containers reference standardized container types. Currently container has iso_type_code and container_type as strings. Adding FK to masterdata.container_type enables standardized container clas' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerType .

ind:gateInAccessEventId rdf:type rdf:Property ;
    rdfs:label 'Gate In Access Event Id' ;
    rdfs:comment 'Foreign key linking to security.access_event. Business justification: Container gate-in generates access event linking container arrival to physical gate access. Enables verification of authorized entry, driver identification, and security compliance. Supports audit tra' ;
    rdfs:domain ind:Container ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessEvent .

ind:inspectionId rdf:type rdf:Property ;
    rdfs:label 'Inspection Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_inspection. Business justification: Container structural inspections (CSC plate compliance, damage assessment, corner casting integrity, reefer unit electrical safety, hazmat placarding verification) are mandatory safety inspections tra' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:stowawayCaseId rdf:type rdf:Property ;
    rdfs:label 'Stowaway Case Id' ;
    rdfs:comment 'Foreign key linking to security.stowaway_case. Business justification: Stowaways are typically discovered in containers during inspection or discharge. Direct linkage essential for container security review, shipper accountability, origin port security assessment, and st' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StowawayCase .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Physical condition grade assigned during inspection: A (excellent), B (good), C (fair - minor repairs needed), D (poor - major repairs needed), E (unserviceable). Used for maintenance planning and commercial decisions.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerStatus rdf:type rdf:Property ;
    rdfs:label 'Container Status' ;
    rdfs:comment 'Current operational status of the container: full (loaded with cargo), empty (available for loading), damaged (requires inspection/repair), under_repair (in maintenance), retired (out of service), in_transit (moving between locations).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cscPlateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Csc Plate Expiry Date' ;
    rdfs:comment 'Expiry date of the CSC safety approval plate. Containers must be re-certified before this date to remain in service. Critical for regulatory compliance and port acceptance.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cubicCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Cubic Capacity Cbm' ;
    rdfs:comment 'Internal cubic capacity of the container in cubic meters (CBM). Used for cargo stowage planning and freight calculations.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentLocationCode rdf:type rdf:Property ;
    rdfs:label 'Current Location Code' ;
    rdfs:comment 'Code identifying the current physical location of the container within the terminal (e.g., yard block, berth, gate, CFS). Used for real-time container tracking and retrieval.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Current Position Timestamp' ;
    rdfs:comment 'Timestamp when the container was last positioned at its current location. Used for dwell time calculation and operational tracking.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalDestinationCode rdf:type rdf:Property ;
    rdfs:label 'Final Destination Code' ;
    rdfs:comment 'Five-character UN/LOCODE identifying the final inland destination for the container cargo. May differ from POD for transshipment or intermodal movements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gate In Timestamp' ;
    rdfs:comment 'Timestamp when the container entered the terminal through the gate. Marks the start of terminal custody and dwell time calculation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazmatCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certification Number' ;
    rdfs:comment 'Certification or approval number for containers authorized to carry dangerous goods. Null for non-certified or non-hazmat containers. Required for IMDG compliance.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightFt rdf:type rdf:Property ;
    rdfs:label 'Height Ft' ;
    rdfs:comment 'Physical height of the container in feet. Standard values: 8.5 ft (standard), 9.5 ft (high cube).' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Boolean flag indicating whether the container holds dangerous goods requiring special handling, stowage, and documentation per IMDG Code. True if hazmat cargo present, False otherwise.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthFt rdf:type rdf:Property ;
    rdfs:label 'Length Ft' ;
    rdfs:comment 'Physical length of the container in feet. Standard values: 20, 40, 45 feet.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date when the container was manufactured. Used to determine container age, depreciation, and remaining service life.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Gross Weight Kg' ;
    rdfs:comment 'Maximum allowable gross weight (container + cargo) in kilograms as per ISO standards. Typically 30,480 kg for standard containers.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Payload Kg' ;
    rdfs:comment 'Maximum cargo weight capacity in kilograms, calculated as max gross weight minus tare weight. Represents the maximum cargo load the container can safely carry.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorCode rdf:type rdf:Property ;
    rdfs:label 'Operator Code' ;
    rdfs:comment 'Four-letter code identifying the shipping line or container operator (first 4 characters of container number). Represents the company operating or leasing the container.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerCode rdf:type rdf:Property ;
    rdfs:label 'Owner Code' ;
    rdfs:comment 'Four-letter code identifying the legal owner of the container. May differ from operator_code if container is leased.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferPlugRequired rdf:type rdf:Property ;
    rdfs:label 'Reefer Plug Required' ;
    rdfs:comment 'Boolean flag indicating whether the reefer container requires electrical power connection at the terminal. True if plug-in required, False if not applicable or self-powered.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reeferSetTempCelsius rdf:type rdf:Property ;
    rdfs:label 'Reefer Set Temp Celsius' ;
    rdfs:comment 'Target temperature setting for refrigerated containers in degrees Celsius. Null for non-reefer containers. Critical for maintaining cargo cold chain integrity.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sealType rdf:type rdf:Property ;
    rdfs:label 'Seal Type' ;
    rdfs:comment 'Type of security seal applied: bolt (high security bolt seal), cable (cable seal), electronic (e-seal with tracking), barrier (barrier seal). Determines security level and customs acceptance.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeTeu rdf:type rdf:Property ;
    rdfs:label 'Size Teu' ;
    rdfs:comment 'Container size expressed in TEU (Twenty-foot Equivalent Units). Standard values: 1.0 for 20ft, 2.0 for 40ft, 2.25 for 45ft containers. Used for capacity planning and billing calculations.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swlKg rdf:type rdf:Property ;
    rdfs:label 'Swl Kg' ;
    rdfs:comment 'Safe Working Load in kilograms - the maximum load that can be safely lifted by the container\'s lifting points. Critical for crane operations and cargo handling safety.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'Empty weight of the container in kilograms. Used to calculate net cargo weight and verify VGM (Verified Gross Mass) compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthFt rdf:type rdf:Property ;
    rdfs:label 'Width Ft' ;
    rdfs:comment 'Physical width of the container in feet. Standard value: 8 feet.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoStatus rdf:type rdf:Property ;
    rdfs:label 'Cargo Status' ;
    rdfs:comment 'Indicates whether the container is full (laden with cargo) or empty (unladen) for this movement.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerIsoTypeCode rdf:type rdf:Property ;
    rdfs:label 'Container Iso Type Code' ;
    rdfs:comment 'Four-character ISO 6346 code specifying the container size and type (e.g., 22G1 for 20ft general purpose, 45G1 for 40ft high cube).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerSizeFeet rdf:type rdf:Property ;
    rdfs:label 'Container Size Feet' ;
    rdfs:comment 'Length of the container in feet, typically 20, 40, or 45 feet.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Container Type Description' ;
    rdfs:comment 'Human-readable description of the container type (e.g., General Purpose, High Cube, Refrigerated, Open Top, Flat Rack, Tank).' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Datetime' ;
    rdfs:comment 'Expected date and time when the container will arrive at the terminal gate or berth for the announced operation.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedArrivalWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Window End' ;
    rdfs:comment 'End of the time window during which the container is expected to arrive at the terminal.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedArrivalWindowStart rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Window Start' ;
    rdfs:comment 'Start of the time window during which the container is expected to arrive at the terminal.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageDatetime rdf:type rdf:Property ;
    rdfs:label 'Message Datetime' ;
    rdfs:comment 'Date and time when the COPARN message was created and transmitted by the sending party.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageFunctionCode rdf:type rdf:Property ;
    rdfs:label 'Message Function Code' ;
    rdfs:comment 'Indicates the function of this COPARN message: original announcement, cancellation of previous message, replacement, addition, or deletion.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Message Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the sender to identify this specific COPARN message transmission. Used for message tracking and reconciliation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageVersion rdf:type rdf:Property ;
    rdfs:label 'Message Version' ;
    rdfs:comment 'Version of the COPARN EDI message standard used for this transmission (e.g., D95B, D01B).' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'Type of container operation being pre-announced: gate-in (truck arrival), gate-out (truck departure), vessel load, vessel discharge, transhipment, rail-in, or rail-out. [ENUM-REF-CANDIDATE: gate_in|gate_out|vessel_load|vessel_discharge|transhipment|rail_in|rail_out — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversizedFlag rdf:type rdf:Property ;
    rdfs:label 'Oversized Flag' ;
    rdfs:comment 'Indicates whether the container carries oversized cargo exceeding standard container dimensions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the COPARN message was successfully processed and integrated into the terminal operating system.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing status of the COPARN message within the terminal operating system: received from EDI gateway, validated against business rules, accepted for planning, rejected due to errors, or successfully processed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingTerminalCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Terminal Code' ;
    rdfs:comment 'Identifier of the port terminal receiving and processing this COPARN message.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingTerminalName rdf:type rdf:Property ;
    rdfs:label 'Receiving Terminal Name' ;
    rdfs:comment 'Full name of the port terminal facility receiving this container pre-announcement.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingPartyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Party Code' ;
    rdfs:comment 'Identifier of the party sending the COPARN message, typically the shipping line, freight forwarder, or agent.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingPartyName rdf:type rdf:Property ;
    rdfs:label 'Sending Party Name' ;
    rdfs:comment 'Full name of the organization or entity that sent the COPARN message.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teuEquivalent rdf:type rdf:Property ;
    rdfs:label 'Teu Equivalent' ;
    rdfs:comment 'TEU equivalent value of this container for capacity planning and billing purposes (e.g., 1.0 for 20ft, 2.0 for 40ft).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Validation Error Message' ;
    rdfs:comment 'Error message or reason code if the COPARN message was rejected or failed validation.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vgmVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Vgm Verified Flag' ;
    rdfs:comment 'Indicates whether the container gross weight has been verified according to SOLAS VGM requirements.' ;
    rdfs:domain ind:ContainerPreadvice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Declaration Id' ;
    rdfs:comment 'Unique identifier for the dangerous goods declaration record. Primary key.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DangerousGoodsDeclaration .

ind:declarantPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Declarant Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: IMDG Code requires traceable declarant identity for dangerous goods liability and emergency response. Links declarant_name/company text to participant record for compliance verification, accreditation' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:emergencyResponsePlanId rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Plan Id' ;
    rdfs:comment 'Foreign key linking to safety.emergency_response_plan. Business justification: Each DG shipment must reference applicable emergency response procedures per IMDG Code Chapter 7 requirements for spill response, fire suppression, evacuation protocols, and EMS/MFAG activation. Port ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyResponsePlan .

ind:hazardRegisterId rdf:type rdf:Property ;
    rdfs:label 'Hazard Register Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard_register. Business justification: DG cargo creates specific IMDG-classified hazards that must be registered in the port\'s hazard register for regulatory compliance, emergency response planning, segregation management, and terminal ris' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardRegister .

ind:threatAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Threat Assessment Id' ;
    rdfs:comment 'Foreign key linking to security.threat_assessment. Business justification: DG shipments undergo threat assessment for terrorism/sabotage risk, especially dual-use chemicals and explosives precursors. Links DG declaration to formal threat evaluation, supporting PFSO decision-' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThreatAssessment .

ind:tradeRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Trade Restriction Id' ;
    rdfs:comment 'Foreign key linking to compliance.trade_restriction. Business justification: Dangerous goods may be subject to trade restrictions (dual-use goods, chemical weapons precursors, prohibited substances). Real regulatory requirement: export control compliance officers must screen D' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeRestriction .

ind:declarantEmail rdf:type rdf:Property ;
    rdfs:label 'Declarant Email' ;
    rdfs:comment 'Email address of the declarant for official correspondence and declaration queries.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date when the dangerous goods declaration was signed and submitted by the declarant. Critical for compliance audit trail.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declarationPlace rdf:type rdf:Property ;
    rdfs:label 'Declaration Place' ;
    rdfs:comment 'City or location where the dangerous goods declaration was signed and issued.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgdNumber rdf:type rdf:Property ;
    rdfs:label 'Dgd Number' ;
    rdfs:comment 'Unique externally-known dangerous goods declaration document number issued by the shipper or freight forwarder.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the person or organization to contact in case of emergency involving this dangerous goods shipment. Required 24/7 availability.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment '24-hour emergency telephone number for technical advice on the dangerous goods. Must be monitored at all times during transport.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emsCode rdf:type rdf:Property ;
    rdfs:label 'Ems Code' ;
    rdfs:comment 'Emergency response procedures for fires (F-code) and spillage (S-code). Format: F-X,S-Y where X and Y are letters (e.g., F-E,S-D). Guides crew emergency response.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptedQuantityFlag rdf:type rdf:Property ;
    rdfs:label 'Excepted Quantity Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods are shipped in excepted quantities per IMDG Code Chapter 3.5, allowing maximum packaging and documentation relief. True if excepted quantity, False otherwise.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flashPointCelsius rdf:type rdf:Property ;
    rdfs:label 'Flash Point Celsius' ;
    rdfs:comment 'Lowest temperature at which vapors ignite when exposed to an ignition source, measured in degrees Celsius. Critical for Class 3 flammable liquids.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossQuantity rdf:type rdf:Property ;
    rdfs:label 'Gross Quantity' ;
    rdfs:comment 'Total weight or volume of the dangerous goods including packaging. Used for cargo manifests and capacity planning.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imdgSubsidiaryRisk rdf:type rdf:Property ;
    rdfs:label 'Imdg Subsidiary Risk' ;
    rdfs:comment 'Secondary hazard class(es) if the substance presents additional risks beyond the primary IMDG class. Pipe-separated if multiple (e.g., 6.1|8).' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Timestamp' ;
    rdfs:comment 'Date and time when physical inspection of the dangerous goods container was completed by port authority or customs officials.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether port authority or customs requires physical inspection of the dangerous goods container before acceptance. True if inspection required, False otherwise.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitedQuantityFlag rdf:type rdf:Property ;
    rdfs:label 'Limited Quantity Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods are shipped in limited quantities per IMDG Code Chapter 3.4, allowing certain packaging and labeling exemptions. True if limited quantity, False otherwise.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marinePollutantFlag rdf:type rdf:Property ;
    rdfs:label 'Marine Pollutant Flag' ;
    rdfs:comment 'Indicates whether the substance is identified as a marine pollutant under MARPOL Annex III. True if marine pollutant, False otherwise.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mfagReference rdf:type rdf:Property ;
    rdfs:label 'Mfag Reference' ;
    rdfs:comment 'MFAG table number providing first aid guidance for exposure to this substance. Used by ship medical officers and port emergency responders.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netQuantity rdf:type rdf:Property ;
    rdfs:label 'Net Quantity' ;
    rdfs:comment 'Net weight or volume of the dangerous goods excluding packaging. Used for segregation and stowage calculations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfPackages rdf:type rdf:Property ;
    rdfs:label 'Number Of Packages' ;
    rdfs:comment 'Total count of individual packages, drums, cylinders, or units containing the dangerous goods within the container or shipment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'Degree of danger: I=High danger, II=Medium danger, III=Low danger. Determines packaging and handling requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portAuthorityAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Port Authority Acceptance Status' ;
    rdfs:comment 'Current status of port authority review and acceptance of the dangerous goods declaration: pending=awaiting review, accepted=approved for handling, rejected=not compliant, conditional=accepted with restrictions, under_review=in validation process.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:properShippingName rdf:type rdf:Property ;
    rdfs:label 'Proper Shipping Name' ;
    rdfs:comment 'Official UN proper shipping name of the dangerous goods as listed in the IMDG Code Dangerous Goods List. Must be used on all transport documents.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationGroup rdf:type rdf:Property ;
    rdfs:label 'Segregation Group' ;
    rdfs:comment 'Segregation group code(s) determining stowage separation requirements from incompatible dangerous goods (e.g., acids, alkalis, ammonium compounds). Used for BAPLIE stowage planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProvisions rdf:type rdf:Property ;
    rdfs:label 'Special Provisions' ;
    rdfs:comment 'Comma-separated list of IMDG special provision codes (e.g., SP23, SP274) that modify standard requirements for packing, stowage, or handling of this specific substance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalName rdf:type rdf:Property ;
    rdfs:label 'Technical Name' ;
    rdfs:comment 'Chemical or technical name of the substance, required when the proper shipping name is a generic N.O.S. (Not Otherwise Specified) entry.' ;
    rdfs:domain ind:DangerousGoodsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demurrageDetentionId rdf:type rdf:Property ;
    rdfs:label 'Demurrage Detention Id' ;
    rdfs:comment 'Unique identifier for the demurrage and detention charge record.' ;
    rdfs:domain ind:DemurrageDetention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demurrageScheduleId rdf:type rdf:Property ;
    rdfs:label 'Demurrage Schedule Id' ;
    rdfs:comment 'Foreign key linking to tariff.demurrage_schedule. Business justification: Demurrage charges are calculated based on demurrage schedules (free time, daily rates). Currently demurrage_detention has tariff_id (unlinked). Adding specific FK to tariff.demurrage_schedule enables ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemurrageSchedule .

ind:detentionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Detention Schedule Id' ;
    rdfs:comment 'Foreign key linking to tariff.detention_schedule. Business justification: Detention charges are calculated based on detention schedules (free time, daily rates). Adding FK to tariff.detention_schedule enables proper rate lookup for container detention outside port. No redun' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DetentionSchedule .

ind:tariffId rdf:type rdf:Property ;
    rdfs:label 'Tariff Id' ;
    rdfs:comment 'Reference to the applicable tariff rate schedule used for charge calculation.' ;
    rdfs:domain ind:DemurrageDetention ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortTariff .

ind:terminalZoneId rdf:type rdf:Property ;
    rdfs:label 'Terminal Terminal Zone Id' ;
    rdfs:comment 'Reference to the container terminal where the demurrage or detention event occurred.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalZone .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Method used to calculate charges: calendar_days (all days count), working_days (excludes weekends/holidays), tiered_rate (escalating rates over time).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeStatus rdf:type rdf:Property ;
    rdfs:label 'Charge Status' ;
    rdfs:comment 'Current lifecycle state of the demurrage/detention charge: accruing (charges accumulating), finalized (calculation complete), disputed (under review), waived (forgiven), invoiced (billed), settled (paid), cancelled (voided). [ENUM-REF-CANDIDATE: accruing|finalized|disputed|waived|invoiced|settled|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DemurrageDetention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeStopTimestamp rdf:type rdf:Property ;
    rdfs:label 'Charge Stop Timestamp' ;
    rdfs:comment 'Date and time when charges cease to accrue, typically at container pickup or return.' ;
    rdfs:domain ind:DemurrageDetention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of the charge: demurrage (container remains at terminal beyond free time), detention (container held outside terminal beyond free time), or combined (both charges apply).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeableEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Chargeable Event Timestamp' ;
    rdfs:comment 'Date and time of the triggering event for charge calculation, such as container discharge for demurrage or gate-out for detention.' ;
    rdfs:domain ind:DemurrageDetention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dailyRateAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Rate Amount' ;
    rdfs:comment 'Per-day charge rate applied for demurrage or detention, expressed in the billing currency.' ;
    rdfs:domain ind:DemurrageDetention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysExceeded rdf:type rdf:Property ;
    rdfs:label 'Days Exceeded' ;
    rdfs:comment 'Number of days beyond the free time allowance for which charges are applicable.' ;
    rdfs:domain ind:DemurrageDetention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'Date when the dispute was formally lodged by the shipping line or cargo owner.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolvedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolved Date' ;
    rdfs:comment 'Date when the dispute was resolved and final charge determination was made.' ;
    rdfs:domain ind:DemurrageDetention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment of the demurrage or detention charge is contractually due.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Payment status of the charge: outstanding (unpaid), partial (partially paid), settled (fully paid), overdue (past due date).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charge Amount' ;
    rdfs:comment 'Total accrued demurrage or detention charge calculated as days exceeded multiplied by daily rate.' ;
    rdfs:domain ind:DemurrageDetention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverAmount rdf:type rdf:Property ;
    rdfs:label 'Waiver Amount' ;
    rdfs:comment 'Portion of the total charge amount that has been waived or forgiven due to dispute resolution or commercial agreement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'Date when the waiver was formally approved and applied to the charge.' ;
    rdfs:domain ind:DemurrageDetention ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the port authority or commercial manager who authorized the waiver.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business justification for granting the waiver, such as operational disruption, commercial goodwill, or contractual agreement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stevedoreGangId rdf:type rdf:Property ;
    rdfs:label 'Stevedore Gang Id' ;
    rdfs:comment 'Reference to the stevedore gang (labor crew) assigned to execute this handling order. Links to workforce management for labor cost allocation and productivity tracking.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gang .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Load/discharge operations require documented shift supervisor for operational accountability, safety incident response, customs queries, and shift handover beyond gang-level assignment. Maritime termi' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:craneAllocation rdf:type rdf:Property ;
    rdfs:label 'Crane Allocation' ;
    rdfs:comment 'Comma-separated list of crane identifiers allocated to this handling order. May include STS (Ship-to-Shore), MHC (Mobile Harbour Crane), or QC (Quay Crane) equipment codes.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Hold Flag' ;
    rdfs:comment 'Boolean indicator whether any cargo in this handling order is subject to customs hold or inspection requirements. True if customs clearance is pending for any containers.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Equipment Delay Minutes' ;
    rdfs:comment 'Total minutes of delay attributed to equipment breakdown or malfunction during the execution of this handling order. Used for maintenance planning and performance analysis.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossCraneProductivityTarget rdf:type rdf:Property ;
    rdfs:label 'Gross Crane Productivity Target' ;
    rdfs:comment 'Target gross crane productivity for this handling order expressed as moves per hour. Gross productivity includes all operational time from first to last move. Used for SLA monitoring.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hatchCoverMoves rdf:type rdf:Property ;
    rdfs:label 'Hatch Cover Moves' ;
    rdfs:comment 'Number of hatch cover handling operations required for this order. Hatch covers must be removed before accessing cargo holds and replaced after loading/discharge. Impacts handling time and cost.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Modified Datetime' ;
    rdfs:comment 'Timestamp when this handling order record was last modified. Updated whenever any attribute changes. Used for audit trail and data synchronization.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationalNotes rdf:type rdf:Property ;
    rdfs:label 'Operational Notes' ;
    rdfs:comment 'Free-text field for operational instructions, special handling requirements, safety alerts, or other contextual information relevant to the execution of this handling order.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the handling order, typically a human-readable sequence number or code used in operational communications and TOS systems.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the handling order: planned (created but not yet released), released (authorized for execution), in_progress (actively being worked), suspended (temporarily halted), completed (all moves finished), or cancelled (order voided).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portStateControlInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Port State Control Inspection Flag' ;
    rdfs:comment 'Boolean indicator whether this handling order is subject to Port State Control inspection requirements. True if PSC inspection is scheduled or in progress.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prioritySequence rdf:type rdf:Property ;
    rdfs:label 'Priority Sequence' ;
    rdfs:comment 'Numeric priority ranking for this handling order relative to other orders for the same vessel call. Lower numbers indicate higher priority. Used for operational sequencing and resource allocation.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restowMoves rdf:type rdf:Property ;
    rdfs:label 'Restow Moves' ;
    rdfs:comment 'Number of restow operations (repositioning containers on the same vessel) included in this handling order. Restows are required to access cargo or optimize vessel stability.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftMoves rdf:type rdf:Property ;
    rdfs:label 'Shift Moves' ;
    rdfs:comment 'Number of shift operations (moving containers within the terminal yard) associated with this handling order. Shifts may be required for yard optimization or pre-positioning cargo.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftReference rdf:type rdf:Property ;
    rdfs:label 'Shift Reference' ;
    rdfs:comment 'Identifier for the operational shift during which this handling order is scheduled or executed. Used for labor cost allocation and shift performance analysis.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Terminal Delay Minutes' ;
    rdfs:comment 'Total minutes of delay attributed to terminal-side operational issues (labor shortage, yard congestion, gate delays) during the execution of this handling order. Used for internal performance analysis.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thcApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Thc Applicable Flag' ;
    rdfs:comment 'Boolean indicator whether Terminal Handling Charges are applicable to this handling order. True if THC should be assessed per tariff schedule.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalMovesCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Moves Completed' ;
    rdfs:comment 'Actual number of container moves completed for this handling order. Updated in real-time as operations progress. Used for progress tracking and performance measurement.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMovesPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Moves Planned' ;
    rdfs:comment 'Total number of container moves (lifts) planned for this handling order. Each TEU or FEU movement counts as one move. Used for productivity planning and resource allocation.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTeuCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Teu Completed' ;
    rdfs:comment 'Actual container volume completed for this handling order expressed in TEU. Updated as operations progress. Used for performance tracking and billing.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTeuPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Teu Planned' ;
    rdfs:comment 'Total container volume planned for this handling order expressed in TEU (Twenty-foot Equivalent Units). FEU containers count as 2 TEU. Used for capacity planning and productivity measurement.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Vessel Delay Minutes' ;
    rdfs:comment 'Total minutes of delay attributed to vessel-side issues (crew availability, hatch cover problems, vessel equipment failure) during the execution of this handling order. Used for dispute resolution.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Weather Delay Minutes' ;
    rdfs:comment 'Total minutes of delay attributed to adverse weather conditions during the execution of this handling order. Used for performance analysis and demurrage dispute resolution.' ;
    rdfs:domain ind:HandlingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lclConsolidationId rdf:type rdf:Property ;
    rdfs:label 'Lcl Consolidation Id' ;
    rdfs:comment 'Unique identifier for the LCL consolidation or deconsolidation job. Primary key for the LCL consolidation master record.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:masterBillOfLadingId rdf:type rdf:Property ;
    rdfs:label 'Master Bill Of Lading Id' ;
    rdfs:comment 'Foreign key linking to cargo.bill_of_lading. Business justification: LCL consolidation is covered by a master BOL. Master_bol_number is denormalized and should be retrieved via FK. This links the consolidation job to the master transport document. FK column name uses \'' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfLading .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual date and time when the consolidation or deconsolidation job was completed. Recorded when all cargo has been stuffed into or stripped from the container and the job is closed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:commodityMix rdf:type rdf:Property ;
    rdfs:label 'Commodity Mix' ;
    rdfs:comment 'Description of the types of commodities included in the consolidation. May include general cargo, textiles, electronics, machinery parts, or other goods. Used for stowage planning and compatibility assessment.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationJobNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Job Number' ;
    rdfs:comment 'Business identifier for the consolidation or deconsolidation job. Externally-known reference number used in Container Freight Station (CFS) operations and documentation.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsDangerousGoods rdf:type rdf:Property ;
    rdfs:label 'Contains Dangerous Goods' ;
    rdfs:comment 'Indicates whether the consolidation includes any dangerous goods requiring special handling per International Maritime Dangerous Goods (IMDG) Code. True if any house BOL contains IMDG cargo.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryOrderIssued rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Issued' ;
    rdfs:comment 'Indicates whether delivery orders have been issued for the deconsolidated cargo. True when all house BOLs have corresponding delivery orders issued for cargo release.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'Three-letter UN/LOCODE representing the destination location or Port of Discharge (POD) for the consolidated cargo. Indicates the final destination after deconsolidation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentUsed rdf:type rdf:Property ;
    rdfs:label 'Equipment Used' ;
    rdfs:comment 'Description of material handling equipment used during the consolidation or deconsolidation operations. May include forklifts, pallet jacks, or other CFS equipment identifiers.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBolCount rdf:type rdf:Property ;
    rdfs:label 'House Bol Count' ;
    rdfs:comment 'Total number of individual house Bills of Lading included in this consolidation job. Each house BOL represents a separate shipper\'s cargo within the consolidated container.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text field capturing observations from quality inspection. May include cargo condition notes, discrepancies, damage reports, or compliance findings.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobStatus rdf:type rdf:Property ;
    rdfs:label 'Job Status' ;
    rdfs:comment 'Current lifecycle status of the consolidation or deconsolidation job. Tracks progression from planning through completion or cancellation.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobType rdf:type rdf:Property ;
    rdfs:label 'Job Type' ;
    rdfs:comment 'Type of LCL job being performed. Consolidation combines multiple LCL shipments into a single container; deconsolidation unpacks a container into individual LCL shipments.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Three-letter UN/LOCODE representing the origin location or Port of Loading (POL) for the consolidated cargo. Indicates where the cargo originates before consolidation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStrippingDate rdf:type rdf:Property ;
    rdfs:label 'Planned Stripping Date' ;
    rdfs:comment 'Scheduled date for container stripping (unloading) during deconsolidation operations. Represents the planned date when the container will be unpacked at the CFS.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStuffingDate rdf:type rdf:Property ;
    rdfs:label 'Planned Stuffing Date' ;
    rdfs:comment 'Scheduled date for container stuffing (loading) during consolidation operations. Represents the planned date when LCL cargo will be loaded into the container at the CFS.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionCompleted rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Completed' ;
    rdfs:comment 'Indicates whether quality inspection of the consolidation or deconsolidation job has been completed. True when cargo condition and documentation have been verified.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminalHandlingChargeApplied rdf:type rdf:Property ;
    rdfs:label 'Terminal Handling Charge Applied' ;
    rdfs:comment 'Indicates whether Terminal Handling Charges have been applied to this consolidation job. True when THC billing has been processed for the CFS operations.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCargoVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Cargo Volume Cbm' ;
    rdfs:comment 'Total volume of all cargo included in the consolidation job, measured in cubic meters. Sum of all individual shipment volumes within the job.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCargoWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Cargo Weight Kg' ;
    rdfs:comment 'Total weight of all cargo included in the consolidation job, measured in kilograms. Sum of all individual shipment weights within the job.' ;
    rdfs:domain ind:LclConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manifestLineId rdf:type rdf:Property ;
    rdfs:label 'Manifest Line Id' ;
    rdfs:comment 'Unique identifier for the manifest line item. Primary key for this entity.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Cargo Value Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the declared cargo value. Supports multi-currency cargo valuation.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoValueUsd rdf:type rdf:Property ;
    rdfs:label 'Cargo Value Usd' ;
    rdfs:comment 'Declared commercial value of the cargo in US dollars. Used for insurance, customs valuation, and liability calculations.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Official customs declaration reference number assigned by customs authority. Used for tracking customs processing and clearance.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Status' ;
    rdfs:comment 'Current status of customs clearance processing for this manifest line. Tracks progression through customs workflow.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential ordering of this line item within the parent manifest. Used for display and processing order.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadStatus rdf:type rdf:Property ;
    rdfs:label 'Load Status' ;
    rdfs:comment 'Cargo load type classification. FCL = Full Container Load, LCL = Less than Container Load, breakbulk = non-containerized, RoRo = Roll-on Roll-off.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestLineStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Line Status' ;
    rdfs:comment 'Current lifecycle status of this manifest line item. Tracks progression from planning through delivery.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marksAndNumbers rdf:type rdf:Property ;
    rdfs:label 'Marks And Numbers' ;
    rdfs:comment 'Shipping marks, labels, and identification numbers on cargo packages. Used for cargo identification and handling instructions.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRequirementCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement Celsius' ;
    rdfs:comment 'Required storage temperature in degrees Celsius for refrigerated (reefer) cargo. Null for non-temperature-controlled cargo.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsBrokerId rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Id' ;
    rdfs:comment 'Foreign key linking to compliance.customs_broker. Business justification: Shipments are cleared by customs brokers. Real business process: broker assignment, declaration submission, clearance coordination. Shippers appoint brokers per shipment; port community systems track ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomsBroker .

ind:cyberIncidentId rdf:type rdf:Property ;
    rdfs:label 'Cyber Incident Id' ;
    rdfs:comment 'Foreign key linking to security.cyber_incident. Business justification: Cyber incidents affecting cargo systems (TOS, PCS, EDI) must reference impacted shipments for operational recovery, customer notification, and business continuity. Links cyber-attack to affected cargo' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CyberIncident .

ind:dischargeBerthId rdf:type rdf:Property ;
    rdfs:label 'Discharge Berth Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.berth. Business justification: Shipments are discharged at specific berths; essential for vessel operations planning, berth allocation, and cargo tracking. Port operators must know which berth each shipment was handled at for opera' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Berth .

ind:shipmentConsigneePortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Shipment Consignee Port Community Participant Id' ;
    rdfs:comment 'Reference to the party (organization or individual) receiving the cargo. The consignee to whom the goods are being shipped and who will take delivery at destination.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:shipmentNotifyPartyPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Shipment Notify Party Port Community Participant Id' ;
    rdfs:comment 'Reference to the party to be notified upon cargo arrival at the port. Often the consignee\'s agent, customs broker, or freight forwarder who will arrange delivery.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:shipmentOnwardVesselCallId rdf:type rdf:Property ;
    rdfs:label 'Shipment Onward Vessel Call Id' ;
    rdfs:comment 'Reference to the next vessel call for transshipment cargo. Links the shipment to the outbound vessel on which it will continue its journey. Populated only when is_transshipment is true.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Call .

ind:shipmentPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Shipment Port Community Participant Id' ;
    rdfs:comment 'Reference to the party (organization or individual) shipping the cargo. The consignor who is sending the goods and typically appears on the Bill of Lading as the shipper.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:shipmentVesselCallId rdf:type rdf:Property ;
    rdfs:label 'Shipment Vessel Call Id' ;
    rdfs:comment 'Reference to the vessel call (voyage) on which this shipment is being transported. Links the cargo to the specific vessel arrival/departure event at the port.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Call .

ind:cargoCondition rdf:type rdf:Property ;
    rdfs:label 'Cargo Condition' ;
    rdfs:comment 'Physical condition of the cargo as observed during handling operations. Documented for liability, insurance claims, and dispute resolution. Updated during discharge, inspection, and delivery.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Declared Value Usd' ;
    rdfs:comment 'Declared commercial value of the cargo in US Dollars. Used for customs valuation, insurance coverage, and liability limits. May differ from actual market value.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryOrderIssueDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Issue Date' ;
    rdfs:comment 'Date when the Delivery Order was issued by the shipping line or port authority. Marks the point when cargo becomes available for pickup by the consignee.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dischargeDate rdf:type rdf:Property ;
    rdfs:label 'Discharge Date' ;
    rdfs:comment 'Date when the cargo was physically discharged from the vessel at the berth. Key operational milestone for calculating vessel turnaround time and initiating yard operations.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalDestinationPortCode rdf:type rdf:Property ;
    rdfs:label 'Final Destination Port Code' ;
    rdfs:comment 'UN/LOCODE for the ultimate destination port if different from POD. Used for transshipment cargo where the current port is an intermediate stop.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateOutDate rdf:type rdf:Property ;
    rdfs:label 'Gate Out Date' ;
    rdfs:comment 'Date when the cargo exited the port terminal through the gate. Marks final delivery or transfer to inland transport. Used for dwell time calculation and billing finalization.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossWeightMt rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Mt' ;
    rdfs:comment 'Total gross weight of the shipment including packaging and container tare weight, measured in metric tons. Used for vessel stowage planning, berth load calculations, and billing.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'Three-letter Incoterm code defining the division of costs, risks, and responsibilities between shipper and consignee. Determines liability boundaries and insurance requirements. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTransshipment rdf:type rdf:Property ;
    rdfs:label 'Is Transshipment' ;
    rdfs:comment 'Boolean flag indicating whether this cargo is being transshipped (transferred to another vessel) rather than being delivered locally. Affects yard allocation, customs procedures, and operational workflow.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netWeightMt rdf:type rdf:Property ;
    rdfs:label 'Net Weight Mt' ;
    rdfs:comment 'Net weight of the cargo excluding packaging and container tare weight, measured in metric tons. Used for customs valuation, trade statistics, and commercial invoicing.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preArrivalNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Pre Arrival Notification Date' ;
    rdfs:comment 'Date when the shipment was first pre-advised to the port via COPARN or other EDI message. Enables advance planning for berth allocation, yard space, and resource scheduling.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current status of the shipment in its lifecycle through the port. Tracks progression from pre-arrival notification through final delivery or transshipment. Updated by TOS and PCS systems as cargo moves through operational milestones. [ENUM-REF-CANDIDATE: Pre-Advised|In-Transit|Arrived|Discharged|Customs-Cleared|Ready-for-Delivery|Delivered|Transshipped — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardLocation rdf:type rdf:Property ;
    rdfs:label 'Yard Location' ;
    rdfs:comment 'Alphanumeric code identifying the specific yard block, row, and slot where the cargo is stored in the container yard or warehouse. Used for retrieval operations and inventory management.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedGrossMassId rdf:type rdf:Property ;
    rdfs:label 'Verified Gross Mass Id' ;
    rdfs:comment 'Unique identifier for the VGM declaration record. Primary key for the verified gross mass entity.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalVgmVerifiedGrossMassId rdf:type rdf:Property ;
    rdfs:label 'Original Vgm Verified Gross Mass Id' ;
    rdfs:comment 'Reference to the original VGM declaration record if this is an amended version. Null for initial submissions.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VerifiedGrossMass .

ind:primaryVerifiedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Verified Employee Id' ;
    rdfs:comment 'Identifier of the system user or operator who created this VGM declaration record.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:weighingStationId rdf:type rdf:Property ;
    rdfs:label 'Weighing Station Id' ;
    rdfs:comment 'Reference to the weighing station or facility where the VGM weighing was performed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WeighingStation .

ind:authorizedSignatoryContact rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Contact' ;
    rdfs:comment 'Contact phone number or email of the authorized signatory for verification purposes.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Full name of the person authorized by the shipper to sign and submit the VGM declaration on behalf of the shipper.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Job title or position of the authorized signatory within the shipper organization.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossMassKg rdf:type rdf:Property ;
    rdfs:label 'Gross Mass Kg' ;
    rdfs:comment 'The verified gross mass of the packed container in kilograms, as declared by the shipper. This is the total weight including the container tare weight and all cargo contents.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pcsSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Pcs Submission Reference' ;
    rdfs:comment 'Reference number assigned by the Port Community System when the VGM declaration is submitted electronically through the PCS platform.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperReference rdf:type rdf:Property ;
    rdfs:label 'Shipper Reference' ;
    rdfs:comment 'Internal reference number used by the shipper to track this VGM declaration within their own systems.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingLineAcknowledgementReference rdf:type rdf:Property ;
    rdfs:label 'Shipping Line Acknowledgement Reference' ;
    rdfs:comment 'Reference number or acknowledgement code provided by the shipping line upon receipt and acceptance of the VGM declaration.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Submission Compliance Flag' ;
    rdfs:comment 'Indicates whether the VGM declaration was submitted before the required deadline. True if compliant (submitted on time), False if non-compliant (late submission).' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDatetime rdf:type rdf:Property ;
    rdfs:label 'Submission Datetime' ;
    rdfs:comment 'The date and time when the VGM declaration was submitted to the shipping line or terminal operator.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'The deadline by which the VGM declaration must be submitted to the shipping line or terminal operator, as per SOLAS requirements and carrier cut-off times.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vgmReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vgm Reference Number' ;
    rdfs:comment 'Unique business reference number assigned to the VGM declaration for tracking and audit purposes. Externally-known identifier used in communications with shipping lines and port authorities.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weighingCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Weighing Certificate Number' ;
    rdfs:comment 'Certificate number issued by the certified weighing facility as proof of the VGM measurement.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weighingDatetime rdf:type rdf:Property ;
    rdfs:label 'Weighing Datetime' ;
    rdfs:comment 'The date and time when the container was weighed to obtain the verified gross mass.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weighingFacilityName rdf:type rdf:Property ;
    rdfs:label 'Weighing Facility Name' ;
    rdfs:comment 'Name of the certified weighing facility or weighbridge where the container was weighed. Denormalized for operational reporting.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weighingMethod rdf:type rdf:Property ;
    rdfs:label 'Weighing Method' ;
    rdfs:comment 'The method used to determine the verified gross mass. Method 1: weighing the packed container. Method 2: weighing all packages and cargo items, including pallets, dunnage, and other packing material, and adding the tare weight of the container.' ;
    rdfs:domain ind:VerifiedGrossMass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance audits require qualified lead auditors. This links the audit to the employee conducting it, enabling auditor scheduling, competency verification, certification tracking, and workload manage' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Primary regulatory framework or compliance domain being audited. ISPS (International Ship and Port Facility Security) covers security compliance, MARPOL (Marine Pollution Convention) covers environmental pollution prevention, customs covers trade and clearance processes, OHS (Occupational Health and Safety) covers workforce safety, environmental covers ISO 14001 and emissions, trade_compliance covers import/export controls and sanctions screening.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit. Scheduled indicates audit is planned but not started, in_progress indicates audit fieldwork is underway, fieldwork_complete indicates on-site work is done but report is pending, report_draft indicates preliminary findings are documented, report_final indicates audit report is issued, closed indicates all corrective actions are verified, cancelled indicates audit was terminated before completion. [ENUM-REF-CANDIDATE: scheduled|in_progress|fieldwork_complete|report_draft|report_final|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on the auditing party and purpose. Internal audits are conducted by port staff, external audits by third parties, regulatory audits by government authorities, certification audits for ISO/ISPS compliance, surveillance audits for ongoing certification maintenance, and special audits triggered by incidents or complaints.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBodyName rdf:type rdf:Property ;
    rdfs:label 'Auditing Body Name' ;
    rdfs:comment 'Name of the organization or authority conducting the audit. May be internal audit department, external certification body (e.g., Lloyd\'s Register, DNV GL, Bureau Veritas), regulatory authority (e.g., National Maritime Safety Authority, Port State Control), or industry association.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBodyType rdf:type rdf:Property ;
    rdfs:label 'Auditing Body Type' ;
    rdfs:comment 'Classification of the auditing organization. Internal department refers to port\'s own audit team, certification body refers to accredited third-party auditors for ISO/ISPS certification, regulatory authority refers to government maritime or customs agencies, port state control refers to PSC inspection teams, industry association refers to IAPH or similar bodies.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBodyReference rdf:type rdf:Property ;
    rdfs:label 'Certification Body Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the certification body for audits related to ISO or ISPS certification. Used to track certification status and link to certificate records. Null for non-certification audits.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Reference' ;
    rdfs:comment 'Reference number or identifier of the corrective action plan developed in response to audit findings. The CAP documents specific actions, responsible parties, and timelines to address non-conformities and observations.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred for the audit, including auditor fees, travel expenses, and administrative costs. Applicable primarily for external and certification audits. Null for internal audits where costs are absorbed by internal departments.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost amount (e.g., USD, EUR, GBP). Null if audit cost is not tracked.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteriaReference rdf:type rdf:Property ;
    rdfs:label 'Criteria Reference' ;
    rdfs:comment 'Reference to the standard, regulation, or policy against which the audit was conducted. Examples include ISO 28000:2022, ISO 14001:2015, ISO 45001:2018, ISPS Code Part A, MARPOL Annex VI, national maritime regulations, or internal port policies.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Detention Issued Flag' ;
    rdfs:comment 'Indicates whether a detention order was issued as a result of the audit findings. True if detention was issued (typically for serious safety or security violations), False otherwise. Detention prevents vessel departure or facility operations until deficiencies are corrected.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total duration of the audit fieldwork in days, calculated from audit start date to audit end date. Includes on-site inspection time but excludes report preparation time.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the audit fieldwork concluded. Represents the last day of on-site activities before report preparation. May differ from report issue date.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Due Date' ;
    rdfs:comment 'Target date by which the follow-up audit must be conducted to verify corrective action completion. Typically set based on the severity of findings and regulatory requirements. Null if no follow-up audit is required.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up audit is required to verify implementation and effectiveness of corrective actions. True if follow-up is mandated (typically for major findings or conditional outcomes), False if no follow-up is required.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAuditorCertification rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Certification' ;
    rdfs:comment 'Professional certification or accreditation held by the lead auditor (e.g., ISO 9001 Lead Auditor, IRCA Certified Auditor, ISPS Auditor Certification). Demonstrates auditor qualifications and authority to conduct the audit.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major non-conformities identified during the audit. Major findings represent significant deviations from requirements that could compromise safety, security, environmental protection, or regulatory compliance. Major findings typically require immediate corrective action and may result in certification suspension.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementResponseDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Date' ;
    rdfs:comment 'Date when port management formally responded to the audit report. Null if no response has been received.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Management Response Received Flag' ;
    rdfs:comment 'Indicates whether port management has formally responded to the audit findings and accepted the corrective action plan. True if response received, False if pending.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor non-conformities identified during the audit. Minor findings represent isolated or less significant deviations from requirements that do not pose immediate risk but require corrective action within a defined timeframe.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Audit Date' ;
    rdfs:comment 'Planned date for the next audit of the same scope and facility. Used for surveillance audits (typically annual for ISO certifications) and periodic internal audits. Null if no future audit is scheduled.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationsCount rdf:type rdf:Property ;
    rdfs:label 'Observations Count' ;
    rdfs:comment 'Number of observations or opportunities for improvement noted during the audit. Observations are not non-conformities but represent areas where processes could be enhanced or best practices could be adopted. No mandatory corrective action required.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallAuditOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Outcome' ;
    rdfs:comment 'Summary conclusion of the audit. Satisfactory indicates full compliance with no major findings, satisfactory_with_observations indicates compliance with minor improvements recommended, conditional indicates compliance pending resolution of specific findings, unsatisfactory indicates significant non-compliance requiring major corrective action, certification_recommended indicates audit supports certification/recertification, certification_denied indicates audit does not support certification.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processAudited rdf:type rdf:Property ;
    rdfs:label 'Process Audited' ;
    rdfs:comment 'Specific business process or operational procedure that was audited. Examples include vessel traffic management, cargo handling procedures, customs clearance workflow, security screening, environmental monitoring, maintenance planning, or billing processes.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pscDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Psc Deficiency Count' ;
    rdfs:comment 'Number of deficiencies identified during a PSC inspection. Deficiencies are non-compliances with SOLAS, MARPOL, or other international maritime conventions. High deficiency counts can result in vessel detention or port facility sanctions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pscInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Psc Inspection Flag' ;
    rdfs:comment 'Indicates whether this audit was conducted as part of a Port State Control inspection. True if the audit was a PSC inspection, False otherwise. PSC inspections are regulatory audits of vessels and port facilities by national maritime authorities.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number for any regulatory filing or submission made to authorities based on audit results. Applicable for audits conducted by or reported to IMO, WCO, national maritime authorities, or Port State Control.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Reference to the location or document management system identifier where the full audit report is stored. Enables retrieval of detailed findings, evidence, and recommendations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssueDate rdf:type rdf:Property ;
    rdfs:label 'Report Issue Date' ;
    rdfs:comment 'Date when the final audit report was formally issued to the port management. Represents the official communication of audit findings and recommendations.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the audit fieldwork commenced. Represents the first day of on-site inspection, document review, or interviews. Used to calculate audit duration and schedule follow-up activities.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Number of auditors in the audit team, including the lead auditor. Team size varies based on audit scope, facility complexity, and duration.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'Reason or event that triggered the audit. Examples include scheduled surveillance audit, recertification due, incident investigation, customer complaint, regulatory requirement, management review, or process change. Provides context for why the audit was conducted.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoAuditFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Aeo Audit Findings Summary' ;
    rdfs:comment 'Summary of key findings, observations, and corrective actions from the most recent AEO compliance audit.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoBenefitsApplied rdf:type rdf:Property ;
    rdfs:label 'Aeo Benefits Applied' ;
    rdfs:comment 'Description of specific customs simplifications and benefits the broker is entitled to under their AEO certification (e.g., reduced inspections, priority processing, deferred duty payment).' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Aeo Certificate Number' ;
    rdfs:comment 'Unique certificate number issued by the customs authority for the broker\'s AEO certification.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Aeo Certified Flag' ;
    rdfs:comment 'Indicator of whether the broker holds at least one active AEO certification under the WCO SAFE Framework.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aeoCountryOfIssue rdf:type rdf:Property ;
    rdfs:label 'Aeo Country Of Issue' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction that issued the AEO certificate.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Aeo Expiry Date' ;
    rdfs:comment 'Date on which the AEO certificate expires and requires renewal or revalidation.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeoIssueDate rdf:type rdf:Property ;
    rdfs:label 'Aeo Issue Date' ;
    rdfs:comment 'Date on which the AEO certificate was originally issued to the broker.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeoIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Aeo Issuing Authority' ;
    rdfs:comment 'Name of the customs authority that issued the AEO certificate to the broker.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoLastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Aeo Last Audit Date' ;
    rdfs:comment 'Date of the most recent compliance audit conducted by the customs authority to validate the broker\'s AEO status.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeoMraApplicable rdf:type rdf:Property ;
    rdfs:label 'Aeo Mra Applicable' ;
    rdfs:comment 'Comma-separated list of country codes or trade blocs with which the broker\'s AEO certificate has mutual recognition, enabling simplified customs procedures in those jurisdictions.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoNextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Aeo Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next compliance audit required to maintain the broker\'s AEO certification.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeoStatus rdf:type rdf:Property ;
    rdfs:label 'Aeo Status' ;
    rdfs:comment 'Current operational status of the AEO certificate indicating whether the broker retains AEO benefits and privileges.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoType rdf:type rdf:Property ;
    rdfs:label 'Aeo Type' ;
    rdfs:comment 'Classification of the AEO certification: AEO-C (Customs Simplification), AEO-S (Security and Safety), AEO-F (Full - both customs and security).' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedPorts rdf:type rdf:Property ;
    rdfs:label 'Authorized Ports' ;
    rdfs:comment 'Comma-separated list of port codes or names where the broker is authorized to submit customs declarations and operate.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Bond Expiry Date' ;
    rdfs:comment 'Expiration date of the customs bond or insurance policy, after which the broker must renew to maintain authorization.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bondInsuranceReference rdf:type rdf:Property ;
    rdfs:label 'Bond Insurance Reference' ;
    rdfs:comment 'Reference number of the customs bond or insurance policy held by the broker to guarantee payment of duties and compliance with customs regulations.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'Primary street address line of the customs brokerage firm\'s registered office or operational headquarters.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'Secondary address line for suite, floor, or building details of the brokerage firm\'s registered office.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'City or municipality where the customs brokerage firm\'s registered office is located.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRating rdf:type rdf:Property ;
    rdfs:label 'Compliance Rating' ;
    rdfs:comment 'Performance rating assigned by port or customs authorities based on the broker\'s compliance history, accuracy of declarations, and adherence to regulations.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the broker\'s authorization to operate at the port was suspended, revoked, or voluntarily terminated.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Explanation or justification for the suspension, revocation, or termination of the broker\'s authorization to operate at the port.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationsRejectedCount rdf:type rdf:Property ;
    rdfs:label 'Declarations Rejected Count' ;
    rdfs:comment 'Total number of customs declarations submitted by the broker that were rejected or returned by customs authorities for errors or non-compliance.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction that issued the broker license.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDeclarationDate rdf:type rdf:Property ;
    rdfs:label 'Last Declaration Date' ;
    rdfs:comment 'Date of the most recent customs declaration submitted by the broker through the port.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date on which the customs broker license expires and requires renewal to maintain authorization.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseIssueDate rdf:type rdf:Property ;
    rdfs:label 'License Issue Date' ;
    rdfs:comment 'Date on which the customs broker license was originally issued by the authority.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Official license or registration number issued by the national customs authority authorizing the broker to submit customs declarations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseRenewalDate rdf:type rdf:Property ;
    rdfs:label 'License Renewal Date' ;
    rdfs:comment 'Most recent date on which the broker license was renewed or revalidated by the issuing authority.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current operational status of the customs broker license indicating whether the broker is authorized to submit declarations.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the broker license indicating the scope of authorized customs and trade activities.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcsRegistrationReference rdf:type rdf:Property ;
    rdfs:label 'Pcs Registration Reference' ;
    rdfs:comment 'Registration or enrollment reference number assigned by the Port Community System for the broker\'s access and transaction tracking.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date on which the broker was first registered in the port\'s customs broker registry and authorized to operate.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'Date on which the broker was last screened against international sanctions and denied party lists.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'Result of the most recent screening of the broker against international sanctions lists (OFAC, UN, EU) and denied party lists.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeclarationsSubmitted rdf:type rdf:Property ;
    rdfs:label 'Total Declarations Submitted' ;
    rdfs:comment 'Cumulative count of customs declarations submitted by the broker through the port since registration.' ;
    rdfs:domain ind:CustomsBroker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countryId rdf:type rdf:Property ;
    rdfs:label 'Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Country of origin determines duty rates, trade agreement applicability, sanctions screening, and certificate of origin requirements. Master country data provides sanctions_list_flag, trade_agreement_c' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:processingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processing Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customs declarations require a processing officer to assess and clear cargo. This tracks which port authority employee processed each declaration for audit trail, performance metrics, and regulatory c' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Import customs declarations reference the purchase order that triggered the import shipment. Required for three-way match (PO-GR-Invoice-Customs), duty allocation to correct PO, and procurement visibi' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'The date and time when customs authorities completed their assessment of the declaration.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargesCurrency rdf:type rdf:Property ;
    rdfs:label 'Charges Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for all duty, tax, and charge amounts.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearance Timestamp' ;
    rdfs:comment 'The date and time when the customs declaration was officially cleared and the cargo was authorized for release.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consigneeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Consignee Identifier' ;
    rdfs:comment 'The unique identifier or tax registration number of the consignee.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignorAddress rdf:type rdf:Property ;
    rdfs:label 'Consignor Address' ;
    rdfs:comment 'The full postal address of the consignor from where the goods originated.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignorIdentifier rdf:type rdf:Property ;
    rdfs:label 'Consignor Identifier' ;
    rdfs:comment 'The unique identifier or tax registration number of the consignor.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignorName rdf:type rdf:Property ;
    rdfs:label 'Consignor Name' ;
    rdfs:comment 'The full legal name of the party sending the goods (exporter or seller).' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfDestination rdf:type rdf:Property ;
    rdfs:label 'Country Of Destination' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code identifying the final destination country for the goods.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRegime rdf:type rdf:Property ;
    rdfs:label 'Customs Regime' ;
    rdfs:comment 'The customs procedure or regime code under which the goods are being declared (e.g., normal clearance, bonded warehouse, free zone, temporary import).' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Declarant Identifier' ;
    rdfs:comment 'The unique identifier or registration number of the declarant with customs authorities (e.g., customs broker license number, tax ID, or business registration number).' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarantName rdf:type rdf:Property ;
    rdfs:label 'Declarant Name' ;
    rdfs:comment 'The full legal name of the person or organization submitting the customs declaration on behalf of the importer or exporter.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Reference Number' ;
    rdfs:comment 'The externally-known unique reference number assigned by customs authorities to this declaration. Also known as customs reference number or declaration number.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the customs declaration: draft (being prepared), submitted (sent to customs), under_assessment (being reviewed by customs), cleared (approved and released), rejected (not accepted), cancelled (withdrawn), or amended (modified after submission). [ENUM-REF-CANDIDATE: draft|submitted|under_assessment|cleared|rejected|cancelled|amended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'The type of customs declaration indicating the nature of the movement: import (goods entering the country), export (goods leaving the country), transit (goods passing through), re-export (previously imported goods being exported), temporary admission, or inward processing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Value Amount' ;
    rdfs:comment 'The monetary value of the goods as declared by the importer/exporter, used as the basis for calculating customs duties and taxes.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the declared value amount.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falForm3Compliant rdf:type rdf:Property ;
    rdfs:label 'Fal Form 3 Compliant' ;
    rdfs:comment 'Boolean flag indicating whether this declaration meets the requirements of IMO FAL Convention Form 3 (Cargo Declaration) for international maritime reporting.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightForwarderIdentifier rdf:type rdf:Property ;
    rdfs:label 'Freight Forwarder Identifier' ;
    rdfs:comment 'The unique identifier or registration number of the freight forwarder.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightForwarderName rdf:type rdf:Property ;
    rdfs:label 'Freight Forwarder Name' ;
    rdfs:comment 'The name of the freight forwarding company handling the logistics and documentation for this shipment.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'The Incoterms code defining the responsibilities, costs, and risks between buyer and seller for the delivery of goods (e.g., FOB, CIF, DDP). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otherChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Other Charges Amount' ;
    rdfs:comment 'The total amount of other fees, levies, or charges (excluding duty and VAT) assessed on this declaration, such as processing fees or excise taxes.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'The type or description of packaging used for the cargo (e.g., pallets, cartons, drums, containers).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pscInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Psc Inspection Required' ;
    rdfs:comment 'Boolean flag indicating whether this declaration has been flagged for Port State Control inspection based on risk assessment criteria.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charges Amount' ;
    rdfs:comment 'The total amount payable including all duties, taxes, and other charges assessed on this declaration.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vatAmount rdf:type rdf:Property ;
    rdfs:label 'Vat Amount' ;
    rdfs:comment 'The total amount of Value Added Tax (VAT) or Goods and Services Tax (GST) assessed and payable on this declaration.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wcoMessageVersion rdf:type rdf:Property ;
    rdfs:label 'Wco Message Version' ;
    rdfs:comment 'The version of the WCO Data Model standard used for this declaration message (e.g., WCO Data Model 3.9).' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placedByPositionId rdf:type rdf:Property ;
    rdfs:label 'Placed By Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Customs holds require specific position authority levels to place (e.g., Senior Customs Inspector). This validates that the employee placing the hold has the required position authority, supporting re' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:primaryCustomsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Customs Employee Id' ;
    rdfs:comment 'Identifier of the customs officer who initiated the hold. Used for accountability and audit trail.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDelayDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Delay Duration Hours' ;
    rdfs:comment 'Actual duration in hours between hold placement and release. Calculated from hold_placement_timestamp and hold_release_timestamp. Null if hold is still active.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bolReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Reference Number' ;
    rdfs:comment 'Reference number of the Bill of Lading associated with the cargo under customs hold. Links the hold to the shipping documentation.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerName rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Name' ;
    rdfs:comment 'Name of the licensed customs broker handling the clearance process for the cargo under hold. Used for coordination and communication.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demurrageApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Demurrage Applicable Flag' ;
    rdfs:comment 'Indicates whether demurrage charges will apply due to the customs hold delay. True if demurrage is applicable; False otherwise. Used for billing and dispute management.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detentionApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Detention Applicable Flag' ;
    rdfs:comment 'Indicates whether detention charges will apply due to the customs hold delay. True if detention is applicable; False otherwise. Used for billing and dispute management.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDelayDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Delay Duration Hours' ;
    rdfs:comment 'Estimated duration in hours that the customs hold will delay cargo release. Used for terminal operations planning and customer communication. Null if duration cannot be estimated.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinationFindings rdf:type rdf:Property ;
    rdfs:label 'Examination Findings' ;
    rdfs:comment 'Detailed findings from physical examination, scanning, or laboratory testing conducted during the hold. May include discrepancies found, contraband detected, or compliance issues identified.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdPlacementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Placement Timestamp' ;
    rdfs:comment 'Date and time when the customs hold was officially placed on the cargo or container. Critical for calculating delay duration and demurrage impact.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for the customs hold (e.g., random inspection, high-risk cargo, documentation discrepancy, sanctions screening hit, ISPS security concern).' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Detailed textual description of why the customs hold was placed. Provides context beyond the standardized hold_reason_code.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned by customs authority to this hold. Used for tracking and communication with customs agencies.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Release Timestamp' ;
    rdfs:comment 'Date and time when the customs hold was officially released or cleared. Null if hold is still active. Used to calculate total hold duration.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the customs hold. Active indicates hold is in effect; released indicates hold has been cleared; escalated indicates hold requires higher authority review; cancelled indicates hold was withdrawn; expired indicates hold lapsed without resolution.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the customs hold indicating the nature of the examination or detention required. Documentary holds require paperwork review; physical examination requires container inspection; scanning requires X-ray or similar; laboratory requires sample testing; quarantine requires isolation; sanctions require compliance verification.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerExporterName rdf:type rdf:Property ;
    rdfs:label 'Importer Exporter Name' ;
    rdfs:comment 'Name of the importer or exporter associated with the cargo under customs hold. Used for stakeholder communication and compliance tracking.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Scheduled Timestamp' ;
    rdfs:comment 'Date and time when the physical inspection or examination is scheduled to occur. Null if no inspection is scheduled or required.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:placedByAuthority rdf:type rdf:Property ;
    rdfs:label 'Placed By Authority' ;
    rdfs:comment 'Name of the customs authority or agency that placed the hold (e.g., U.S. Customs and Border Protection, Port State Control, National Maritime Safety Authority).' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseReason rdf:type rdf:Property ;
    rdfs:label 'Release Reason' ;
    rdfs:comment 'Explanation or justification provided by customs for releasing the hold. May include reference to documentation provided, inspection results, or clearance conditions met.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Result' ;
    rdfs:comment 'Result of sanctions screening performed on the cargo, shipper, consignee, or vessel. Clear indicates no sanctions match; hit indicates potential sanctions violation; pending indicates screening in progress; escalated indicates manual review required.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seizureFlag rdf:type rdf:Property ;
    rdfs:label 'Seizure Flag' ;
    rdfs:comment 'Indicates whether the hold resulted in seizure of cargo or container by customs authorities. True if cargo was seized; False otherwise.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seizureReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Seizure Reference Number' ;
    rdfs:comment 'Official reference number assigned to the seizure case if cargo was confiscated. Null if no seizure occurred. Links to customs enforcement case management systems.' ;
    rdfs:domain ind:CustomsHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeId rdf:type rdf:Property ;
    rdfs:label 'Hs Code Id' ;
    rdfs:comment 'Primary key for hs_code' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HsCode .

ind:antiDumpingDutyFlag rdf:type rdf:Property ;
    rdfs:label 'Anti Dumping Duty Flag' ;
    rdfs:comment 'Indicates whether anti-dumping duties are applicable to this commodity to protect domestic industry from unfairly priced imports.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chapter rdf:type rdf:Property ;
    rdfs:label 'Chapter' ;
    rdfs:comment 'The first two digits of the HS code representing the chapter-level classification (e.g., Chapter 01 = Live Animals, Chapter 84 = Machinery). Highest level of HS hierarchy.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citesFlag rdf:type rdf:Property ;
    rdfs:label 'Cites Flag' ;
    rdfs:comment 'Indicates whether this commodity is subject to CITES regulations governing international trade in endangered species of wild fauna and flora. True if CITES-controlled, False otherwise.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityDescriptionShort rdf:type rdf:Property ;
    rdfs:label 'Commodity Description Short' ;
    rdfs:comment 'Abbreviated or short-form description of the commodity for display in space-constrained interfaces and reports.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countervailingDutyFlag rdf:type rdf:Property ;
    rdfs:label 'Countervailing Duty Flag' ;
    rdfs:comment 'Indicates whether countervailing duties are applicable to this commodity to offset foreign government subsidies.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the jurisdiction for which this HS code classification and tariff rates apply (e.g., USA, GBR, SGP, AUS).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualUseFlag rdf:type rdf:Property ;
    rdfs:label 'Dual Use Flag' ;
    rdfs:comment 'Indicates whether this commodity is classified as dual-use goods (items that can be used for both civilian and military purposes), subject to export controls and licensing requirements.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Percentage' ;
    rdfs:comment 'The standard customs duty rate applied to imports of this commodity, expressed as a percentage of the customs value. Used for duty calculation in customs clearance.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exciseDutyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Excise Duty Rate Percentage' ;
    rdfs:comment 'Additional excise duty rate applicable to specific commodity categories (e.g., alcohol, tobacco, fuel), expressed as a percentage.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heading rdf:type rdf:Property ;
    rdfs:label 'Heading' ;
    rdfs:comment 'The first four digits of the HS code representing the heading-level classification. Provides intermediate granularity between chapter and subheading.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Hs Code Status' ;
    rdfs:comment 'Current lifecycle status of this HS code record. Active = currently in use, Inactive = temporarily disabled, Superseded = replaced by a newer code, Pending = awaiting activation, Deprecated = phased out.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsVersion rdf:type rdf:Property ;
    rdfs:label 'Hs Version' ;
    rdfs:comment 'The version year of the WCO Harmonized System nomenclature that this code is based on (e.g., HS2017, HS2022). The HS is updated every 5 years.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgDangerousGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Imdg Dangerous Goods Flag' ;
    rdfs:comment 'Indicates whether this commodity is classified as dangerous goods under the IMDG Code, requiring special handling, stowage, and documentation in maritime transport.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'License Required Flag' ;
    rdfs:comment 'Indicates whether an import or export license is required for this commodity. True if licensing is mandatory, False if no license needed.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originCertificateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Origin Certificate Required Flag' ;
    rdfs:comment 'Indicates whether a certificate of origin is required for customs clearance of this commodity to verify the country of manufacture or production.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phytosanitaryCertificateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Phytosanitary Certificate Required Flag' ;
    rdfs:comment 'Indicates whether a phytosanitary certificate is required for plant and plant product commodities to certify they are free from pests and diseases.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferentialTariffFlag rdf:type rdf:Property ;
    rdfs:label 'Preferential Tariff Flag' ;
    rdfs:comment 'Indicates whether this commodity is eligible for preferential tariff treatment under free trade agreements or preferential trade arrangements.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prohibitedFlag rdf:type rdf:Property ;
    rdfs:label 'Prohibited Flag' ;
    rdfs:comment 'Indicates whether import or export of this commodity is prohibited under national or international law. True if prohibited, False if allowed.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaFlag rdf:type rdf:Property ;
    rdfs:label 'Quota Flag' ;
    rdfs:comment 'Indicates whether this commodity is subject to import or export quotas limiting the quantity that can be traded within a specific period.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Flag' ;
    rdfs:comment 'Indicates whether import or export of this commodity is subject to restrictions, licensing requirements, or special permits. True if restricted, False if unrestricted.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sanctionsScreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Required Flag' ;
    rdfs:comment 'Indicates whether shipments of this commodity require sanctions screening against restricted parties, countries, or entities (e.g., OFAC, UN, EU sanctions lists).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statisticalSuffix rdf:type rdf:Property ;
    rdfs:label 'Statistical Suffix' ;
    rdfs:comment 'Additional national statistical suffix digits appended to the 6-digit HS code for more granular trade statistics and reporting purposes. Length varies by country.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subheading rdf:type rdf:Property ;
    rdfs:label 'Subheading' ;
    rdfs:comment 'The first six digits of the HS code representing the internationally standardized subheading-level classification. This is the core 6-digit HS code recognized globally.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Code' ;
    rdfs:comment 'Code identifying the applicable free trade agreement or preferential trade arrangement that may provide reduced duty rates for this commodity (e.g., USMCA, CPTPP, EU-FTA).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percentage' ;
    rdfs:comment 'The applicable VAT or sales tax rate for this commodity category, expressed as a percentage. Used for tax calculation on imported goods.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veterinaryCertificateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Veterinary Certificate Required Flag' ;
    rdfs:comment 'Indicates whether a veterinary health certificate is required for animal and animal product commodities to certify they meet health and safety standards.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Issued By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Import/export permits must be issued by authorized port authority officers. This tracks which employee issued each permit for regulatory audit trail, authorization validation, and workload distributio' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originCountryId rdf:type rdf:Property ;
    rdfs:label 'Origin Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Permit origin country determines license requirements, dual-use controls, and CITES applicability. Master country data provides sanctions_list_flag, WCO membership, and trade agreement codes for autom' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The date on which the permit application was submitted to the issuing authority. Used for processing time tracking and audit purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billOfLadingReference rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Reference' ;
    rdfs:comment 'Reference number of the Bill of Lading associated with the cargo movement covered by this permit. Links the permit to the specific shipment documentation.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsRestrictions rdf:type rdf:Property ;
    rdfs:label 'Conditions Restrictions' ;
    rdfs:comment 'Free-text field capturing any special conditions, restrictions, or requirements attached to the permit. May include usage limitations, handling requirements, inspection mandates, or reporting obligations.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Controlled Goods Flag' ;
    rdfs:comment 'Boolean indicator of whether the goods covered by this permit are subject to strategic trade controls, dual-use export restrictions, or other special regulatory oversight. True indicates controlled goods requiring enhanced compliance procedures.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the final destination country for the goods. Used for export control compliance and trade statistics.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseStatement rdf:type rdf:Property ;
    rdfs:label 'End Use Statement' ;
    rdfs:comment 'Declaration of the intended end use of the imported or exported goods. Required for certain controlled commodities to ensure compliance with export control regulations and prevent diversion to unauthorized uses.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUserName rdf:type rdf:Property ;
    rdfs:label 'End User Name' ;
    rdfs:comment 'Name of the ultimate consignee or end user of the goods. May differ from the permit holder if the permit holder is an intermediary or freight forwarder.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completion Date' ;
    rdfs:comment 'The date on which the required inspection was completed. Nullable if inspection is not required or has not yet been performed.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcsTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Pcs Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the Port Community System when the permit data was exchanged with customs authorities and other stakeholders. Used for message tracking and reconciliation.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitHolderIdentifier rdf:type rdf:Property ;
    rdfs:label 'Permit Holder Identifier' ;
    rdfs:comment 'Official business registration number, tax identification number, or customs trader identifier for the permit holder. Used for regulatory cross-referencing and compliance verification.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'The official permit or license number issued by the regulatory authority. This is the externally-known unique identifier used in customs declarations and trade documentation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the permit. Tracks the permit from application through issuance, active use, expiration, or revocation. Critical for compliance validation and operational decision-making. [ENUM-REF-CANDIDATE: applied|issued|active|expired|revoked|suspended|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the permit based on the nature of the authorization. Distinguishes between import permits, export licenses, re-export certificates, CITES (Convention on International Trade in Endangered Species) permits, dual-use export licenses, strategic goods permits, phytosanitary import permits, and quarantine clearances. [ENUM-REF-CANDIDATE: import_permit|export_license|re_export_certificate|cites_permit|dual_use_export_license|strategic_goods_permit|phytosanitary_permit|quarantine_clearance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAuthorized rdf:type rdf:Property ;
    rdfs:label 'Quantity Authorized' ;
    rdfs:comment 'The maximum quantity of goods authorized for import or export under this permit. Measured in the unit specified in the quantity_unit field.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The date on which the permit was revoked by the issuing authority. Nullable for permits that have not been revoked. Revocation may occur due to non-compliance, false declarations, or changes in regulatory requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation provided by the issuing authority for revoking the permit. Captures the regulatory or compliance basis for the revocation action.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'The date on which the permit expires and can no longer be used for import or export transactions. Nullable for permits with indefinite validity subject to other conditions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'The date from which the permit becomes valid and can be used for import or export transactions. Permits cannot be used before this date.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valueAuthorized rdf:type rdf:Property ;
    rdfs:label 'Value Authorized' ;
    rdfs:comment 'The maximum monetary value of goods authorized for import or export under this permit, expressed in the currency specified in the currency_code field.' ;
    rdfs:domain ind:ImportExportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pfsoEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Pfso Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Port Facility Security Officer (PFSO) is a designated employee requiring ISPS certification tracking. This links ISPS facility records to the PFSO employee for certification management, competency ver' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertAffectedZone rdf:type rdf:Property ;
    rdfs:label 'Alert Affected Zone' ;
    rdfs:comment 'Specific area or zone within the port facility affected by the security alert, such as berth number, cargo yard, gate, or perimeter section.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertEscalationChain rdf:type rdf:Property ;
    rdfs:label 'Alert Escalation Chain' ;
    rdfs:comment 'Record of the escalation path followed for the security alert, listing the sequence of personnel and authorities notified (PFSO, CSO, port authority, national maritime security center, law enforcement).' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertIssuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Issued Timestamp' ;
    rdfs:comment 'Date and time when the security alert was officially issued and communicated to facility security personnel and relevant stakeholders.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertResolutionDetails rdf:type rdf:Property ;
    rdfs:label 'Alert Resolution Details' ;
    rdfs:comment 'Comprehensive description of how the security alert was resolved, including investigation findings, corrective actions taken, and lessons learned for future prevention.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertResolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Resolution Timestamp' ;
    rdfs:comment 'Date and time when the security alert was resolved, threat neutralized, or incident closed, and normal security posture was restored.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertResponseActions rdf:type rdf:Property ;
    rdfs:label 'Alert Response Actions' ;
    rdfs:comment 'Detailed description of the security response actions taken in response to the alert, including personnel deployment, access restrictions, enhanced surveillance, or coordination with law enforcement.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertSeverity rdf:type rdf:Property ;
    rdfs:label 'Alert Severity' ;
    rdfs:comment 'Assessed severity level of the security alert indicating the degree of threat and urgency of response required: low, medium, high, or critical.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertSource rdf:type rdf:Property ;
    rdfs:label 'Alert Source' ;
    rdfs:comment 'Origin or reporting entity of the security alert: national maritime security center, port state control, vessel, facility surveillance system, or external intelligence agency.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the security alert based on the nature of the threat or incident: security threat, suspicious activity, unauthorized access, cyber incident, vessel security alert system activation, or terrorism threat.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csoContactEmail rdf:type rdf:Property ;
    rdfs:label 'Cso Contact Email' ;
    rdfs:comment 'Official email address of the Company Security Officer for security policy communication and corporate security reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csoContactPhone rdf:type rdf:Property ;
    rdfs:label 'Cso Contact Phone' ;
    rdfs:comment 'Primary contact phone number for the Company Security Officer for escalation and corporate-level security coordination.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csoName rdf:type rdf:Property ;
    rdfs:label 'Cso Name' ;
    rdfs:comment 'Name of the Company Security Officer designated by the port operating company to coordinate security matters at the corporate level and liaise with facility-level security officers.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Current Security Level' ;
    rdfs:comment 'Current MARSEC security level in effect at the port facility. Level 1 = normal operations, Level 2 = heightened risk, Level 3 = exceptional risk requiring special security measures.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dosActivitiesCovered rdf:type rdf:Property ;
    rdfs:label 'Dos Activities Covered' ;
    rdfs:comment 'Detailed description of the security-sensitive activities covered under the Declaration of Security agreement, such as cargo operations, bunkering, passenger embarkation, or ship-to-ship transfers.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosPortSignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dos Port Signed Timestamp' ;
    rdfs:comment 'Date and time when the port facility representative signed the Declaration of Security, establishing the facility\'s commitment to the security agreement.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dosPortSigningOfficer rdf:type rdf:Property ;
    rdfs:label 'Dos Port Signing Officer' ;
    rdfs:comment 'Name of the authorized port facility representative (typically the PFSO or deputy) who signed the Declaration of Security on behalf of the facility.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dos Reference Number' ;
    rdfs:comment 'Unique reference number for the most recent Declaration of Security agreement between the port facility and a vessel. Format: DOS- followed by alphanumeric identifier.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosShipSignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dos Ship Signed Timestamp' ;
    rdfs:comment 'Date and time when the vessel representative signed the Declaration of Security, completing the bilateral security agreement.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dosShipSigningOfficer rdf:type rdf:Property ;
    rdfs:label 'Dos Ship Signing Officer' ;
    rdfs:comment 'Name of the authorized vessel representative (typically the Ship Security Officer or Master) who signed the Declaration of Security on behalf of the vessel.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosType rdf:type rdf:Property ;
    rdfs:label 'Dos Type' ;
    rdfs:comment 'Classification of the Declaration of Security based on the parties involved: ship-to-port (vessel and facility), ship-to-ship (two vessels at facility), or port-to-port (interfacility transfer).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosValidFrom rdf:type rdf:Property ;
    rdfs:label 'Dos Valid From' ;
    rdfs:comment 'Date and time when the Declaration of Security becomes effective and security coordination measures are activated.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dosValidUntil rdf:type rdf:Property ;
    rdfs:label 'Dos Valid Until' ;
    rdfs:comment 'Date and time when the Declaration of Security expires or when the covered activities are completed and security coordination is no longer required.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dosVesselImoNumber rdf:type rdf:Property ;
    rdfs:label 'Dos Vessel Imo Number' ;
    rdfs:comment 'IMO number of the vessel party to the current Declaration of Security. Seven-digit unique vessel identifier assigned by the International Maritime Organization.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official name of the port facility as registered with the national maritime authority and recognized under ISPS Code compliance framework.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the port facility based on primary cargo handling operations and terminal specialization under ISPS jurisdiction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Isps Reference Number' ;
    rdfs:comment 'Unique ISPS Code compliance reference number issued by the national maritime authority for this port facility. Format: country code (3 letters) followed by alphanumeric facility identifier.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPscInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Psc Inspection Date' ;
    rdfs:comment 'Date of the most recent Port State Control inspection of the facility\'s ISPS Code compliance, conducted by the national maritime authority or designated inspection body.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPscInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Last Psc Inspection Result' ;
    rdfs:comment 'Outcome of the most recent PSC inspection: compliant (no issues), deficiency noted (minor issues requiring correction), major non-conformity (serious violations), or detention (operations suspended).' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalAuthorityContact rdf:type rdf:Property ;
    rdfs:label 'National Authority Contact' ;
    rdfs:comment 'Primary contact phone number or communication channel for the national maritime authority for ISPS compliance reporting, incident notification, and regulatory coordination.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalAuthorityName rdf:type rdf:Property ;
    rdfs:label 'National Authority Name' ;
    rdfs:comment 'Name of the national maritime authority or designated government agency responsible for ISPS Code enforcement and facility security oversight in the port\'s jurisdiction.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory ISPS Code compliance audit or Port Facility Security Plan review by the national maritime authority or recognized security organization.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pfsoCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pfso Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the PFSO certification, after which recertification or renewal training is required to maintain ISPS compliance.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pfsoCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Pfso Certification Number' ;
    rdfs:comment 'Official certification or license number issued to the PFSO by the national maritime authority or approved training institution, validating their qualification under ISPS Code requirements.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoContactEmail rdf:type rdf:Property ;
    rdfs:label 'Pfso Contact Email' ;
    rdfs:comment 'Official email address of the Port Facility Security Officer for security notifications, DoS documentation, and regulatory correspondence.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoContactPhone rdf:type rdf:Property ;
    rdfs:label 'Pfso Contact Phone' ;
    rdfs:comment 'Primary 24/7 contact phone number for the Port Facility Security Officer for emergency security coordination and Declaration of Security communications.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfspApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Pfsp Approval Date' ;
    rdfs:comment 'Date on which the current Port Facility Security Plan was officially approved by the national maritime authority or designated security organization.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pfspExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pfsp Expiry Date' ;
    rdfs:comment 'Date on which the current Port Facility Security Plan expires and requires renewal or revalidation by the competent authority.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pfspVersion rdf:type rdf:Property ;
    rdfs:label 'Pfsp Version' ;
    rdfs:comment 'Current approved version number of the Port Facility Security Plan as mandated by ISPS Code. Format: v[major].[minor] (e.g., v2.1).' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Date and time when this ISPS facility record was first created in the port security management system.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Date and time when this ISPS facility record was most recently updated, reflecting changes to security status, personnel, or compliance information.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securityAlertReference rdf:type rdf:Property ;
    rdfs:label 'Security Alert Reference' ;
    rdfs:comment 'Unique reference number for the most recent security alert or threat notification issued for this facility. Format: ALERT- followed by alphanumeric identifier.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevelEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Security Level Effective Date' ;
    rdfs:comment 'Date and time when the current MARSEC security level was activated at the facility. Critical for Declaration of Security (DoS) coordination and incident timeline reconstruction.' ;
    rdfs:domain ind:IspsFacilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marpolRecordId rdf:type rdf:Property ;
    rdfs:label 'Marpol Record Id' ;
    rdfs:comment 'Primary key for marpol_record' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: MARPOL operations require a responsible officer with environmental compliance certifications. This links MARPOL records to the employee for competency verification, certification tracking, and account' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ballastWaterDischargeLocation rdf:type rdf:Property ;
    rdfs:label 'Ballast Water Discharge Location' ;
    rdfs:comment 'Geographic location (port name or coordinates) where the ballast water was discharged, required for BWM Convention compliance.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ballastWaterExchangeLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Ballast Water Exchange Location Latitude' ;
    rdfs:comment 'Latitude coordinate (decimal degrees) where ballast water exchange was performed, typically at least 200 nautical miles from shore.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ballastWaterExchangeLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Ballast Water Exchange Location Longitude' ;
    rdfs:comment 'Longitude coordinate (decimal degrees) where ballast water exchange was performed, typically at least 200 nautical miles from shore.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ballastWaterManagementMethod rdf:type rdf:Property ;
    rdfs:label 'Ballast Water Management Method' ;
    rdfs:comment 'Method used to manage ballast water: exchange (mid-ocean exchange), treatment (onboard treatment system), or retention (ballast water retained onboard without discharge).' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ballastWaterSourceLocation rdf:type rdf:Property ;
    rdfs:label 'Ballast Water Source Location' ;
    rdfs:comment 'Geographic location (port name or coordinates) where the ballast water was originally taken onboard, required for BWM Convention compliance.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ballastWaterTreatmentSystemImoApproval rdf:type rdf:Property ;
    rdfs:label 'Ballast Water Treatment System Imo Approval' ;
    rdfs:comment 'IMO type approval number for the ballast water treatment system, certifying compliance with IMO standards.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ballastWaterTreatmentSystemType rdf:type rdf:Property ;
    rdfs:label 'Ballast Water Treatment System Type' ;
    rdfs:comment 'Type or model of the ballast water treatment system installed onboard (e.g., UV treatment, electrolysis, filtration), if applicable.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ciiRating rdf:type rdf:Property ;
    rdfs:label 'Cii Rating' ;
    rdfs:comment 'Carbon Intensity Indicator (CII) rating for the vessel (A, B, C, D, or E), measuring operational carbon efficiency under MARPOL Annex VI.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Target or actual date by which corrective actions must be or were completed to achieve MARPOL compliance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Description of corrective actions required to address non-compliance or deficiencies identified in this MARPOL record.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Disposal Certificate Reference' ;
    rdfs:comment 'Reference number of the disposal certificate or waste treatment certificate issued by the disposal contractor confirming proper waste handling.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalContractor rdf:type rdf:Property ;
    rdfs:label 'Disposal Contractor' ;
    rdfs:comment 'Name of the licensed waste disposal contractor responsible for final disposal or treatment of the waste.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eediValue rdf:type rdf:Property ;
    rdfs:label 'Eedi Value' ;
    rdfs:comment 'Energy Efficiency Design Index (EEDI) value for the vessel, measuring CO2 emissions per ton-mile, required for new ships under MARPOL Annex VI.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eexiValue rdf:type rdf:Property ;
    rdfs:label 'Eexi Value' ;
    rdfs:comment 'Energy Efficiency Existing Ship Index (EEXI) value for the vessel, measuring technical energy efficiency for existing ships under MARPOL Annex VI.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marpolAnnex rdf:type rdf:Property ;
    rdfs:label 'Marpol Annex' ;
    rdfs:comment 'The specific MARPOL annex or BWM Convention under which this compliance record is filed. Annex I: oil pollution; Annex II: noxious liquid substances; Annex IV: sewage; Annex V: garbage; Annex VI: air emissions; BWM Convention: ballast water management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceReason rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason' ;
    rdfs:comment 'Detailed explanation of the reason for non-compliance, if applicable, including specific MARPOL regulation violated and nature of the violation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noxEmissionsMt rdf:type rdf:Property ;
    rdfs:label 'Nox Emissions Mt' ;
    rdfs:comment 'Quantity of nitrogen oxides (NOx) emitted in metric tons during the reporting period, applicable to MARPOL Annex VI air emissions compliance.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Operation Location Latitude' ;
    rdfs:comment 'Latitude coordinate (decimal degrees) where the MARPOL operation occurred, required for at-sea discharges and ballast water exchange.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Operation Location Longitude' ;
    rdfs:comment 'Longitude coordinate (decimal degrees) where the MARPOL operation occurred, required for at-sea discharges and ballast water exchange.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation Timestamp' ;
    rdfs:comment 'Date and time when the MARPOL operation (discharge, reception, treatment, exchange) was performed, recorded in ISO 8601 format.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:particulateMatterEmissionsMt rdf:type rdf:Property ;
    rdfs:label 'Particulate Matter Emissions Mt' ;
    rdfs:comment 'Quantity of particulate matter (PM) emitted in metric tons during the reporting period, applicable to MARPOL Annex VI air emissions compliance.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portAuthorityEndorsementFlag rdf:type rdf:Property ;
    rdfs:label 'Port Authority Endorsement Flag' ;
    rdfs:comment 'Indicates whether the port authority has endorsed or verified this MARPOL record (True) or not (False).' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portAuthorityEndorsementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Port Authority Endorsement Timestamp' ;
    rdfs:comment 'Date and time when the port authority endorsed or verified the MARPOL record, recorded in ISO 8601 format.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portAuthorityInspectorName rdf:type rdf:Property ;
    rdfs:label 'Port Authority Inspector Name' ;
    rdfs:comment 'Name of the port authority inspector who endorsed or verified the MARPOL record.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfOperation rdf:type rdf:Property ;
    rdfs:label 'Port Of Operation' ;
    rdfs:comment 'Name or UN/LOCODE of the port where the waste reception or discharge operation took place, if applicable.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pscInspectionReference rdf:type rdf:Property ;
    rdfs:label 'Psc Inspection Reference' ;
    rdfs:comment 'Reference number of the associated Port State Control (PSC) inspection during which this MARPOL record was reviewed or a deficiency was identified.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityMassMt rdf:type rdf:Property ;
    rdfs:label 'Quantity Mass Mt' ;
    rdfs:comment 'Mass of waste in metric tons (MT) involved in this operation, applicable to solid waste and sludge.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Quantity Volume M3' ;
    rdfs:comment 'Volume of waste or ballast water in cubic meters (m³) involved in this operation.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receptionFacilityOperator rdf:type rdf:Property ;
    rdfs:label 'Reception Facility Operator' ;
    rdfs:comment 'Name of the port waste reception facility operator or contractor that received the waste from the vessel.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordBookEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Record Book Entry Number' ;
    rdfs:comment 'Sequential entry number from the vessel\'s Oil Record Book (ORB), Garbage Record Book (GRB), or Ballast Water Record Book (BWRB) corresponding to this operation.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficerRank rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Rank' ;
    rdfs:comment 'Rank or position of the responsible officer (e.g., Master, Chief Engineer, Chief Officer) who signed off on the MARPOL operation.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficerSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Signature Timestamp' ;
    rdfs:comment 'Date and time when the responsible officer signed the MARPOL record book entry or waste manifest, recorded in ISO 8601 format.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:soxEmissionsMt rdf:type rdf:Property ;
    rdfs:label 'Sox Emissions Mt' ;
    rdfs:comment 'Quantity of sulfur oxides (SOx) emitted in metric tons during the reporting period, applicable to MARPOL Annex VI air emissions compliance.' ;
    rdfs:domain ind:MarpolRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteManifestNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Manifest Number' ;
    rdfs:comment 'Unique reference number of the waste manifest or transfer document issued by the reception facility upon waste receipt.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteType rdf:type rdf:Property ;
    rdfs:label 'Waste Type' ;
    rdfs:comment 'Detailed classification of the waste or substance: oily bilge water, sludge, noxious liquid substance cargo residue, sewage, plastics, food waste, domestic waste, cooking oil, incinerator ash, operational waste, cargo residue, ballast water, SOx emissions, NOx emissions, particulate matter, or other MARPOL-regulated material.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistEntryId rdf:type rdf:Property ;
    rdfs:label 'Watchlist Entry Id' ;
    rdfs:comment 'Foreign key linking to security.watchlist_entry. Business justification: Sanctions screening matches against security watchlist entries for vessel, entity, and individual checks. Core operational link for integrated sanctions and security screening at port entry points, re' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WatchlistEntry .

ind:additionalIdentifiers rdf:type rdf:Property ;
    rdfs:label 'Additional Identifiers' ;
    rdfs:comment 'Supplementary identifiers used in the screening check (e.g., aliases, former names, associated addresses, tax IDs). Stored as structured text or JSON for flexible matching.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Status' ;
    rdfs:comment 'Status of manual analyst review for potential or confirmed matches. Tracks human oversight and decision-making in the compliance workflow.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Authority Reference Number' ;
    rdfs:comment 'Reference or case number assigned by the external authority when the screening result was escalated. Null if no escalation or reference not yet assigned.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCountryOfRegistration rdf:type rdf:Property ;
    rdfs:label 'Company Country Of Registration' ;
    rdfs:comment 'Three-letter ISO country code where the company is legally registered. Applicable for company-type entities.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Company Registration Number' ;
    rdfs:comment 'Official business registration or tax identification number of the company being screened. Applicable when screened_entity_type is company, freight_forwarder, cargo_owner, consignee, shipper, or agent.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToAuthority rdf:type rdf:Property ;
    rdfs:label 'Escalated To Authority' ;
    rdfs:comment 'Name of the external authority or regulatory body to which the screening result was escalated (e.g., national customs, port state control, OFAC). Null if no external escalation.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the screening result was escalated to senior compliance officers or external authorities. Null if no escalation occurred.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:individualNationality rdf:type rdf:Property ;
    rdfs:label 'Individual Nationality' ;
    rdfs:comment 'Three-letter ISO country code of the individual\'s nationality. Applicable only when screened_entity_type is individual.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualPassportNumber rdf:type rdf:Property ;
    rdfs:label 'Individual Passport Number' ;
    rdfs:comment 'Passport number of the individual being screened. Applicable only when screened_entity_type is individual.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHighRiskCargo rdf:type rdf:Property ;
    rdfs:label 'Is High Risk Cargo' ;
    rdfs:comment 'Boolean flag indicating whether the cargo is classified as high-risk based on HS code, origin, or other risk factors. Drives enhanced screening protocols.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score (0.00 to 100.00) indicating the likelihood that the screened entity matches a sanctions list entry. Higher scores indicate stronger matches requiring analyst review.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Result of the screening check indicating whether the entity matched any sanctions list entries. Drives compliance decision-making and escalation workflows.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListEntry rdf:type rdf:Property ;
    rdfs:label 'Matched List Entry' ;
    rdfs:comment 'Full text of the sanctions list entry that matched the screened entity, including name, aliases, and identifiers. Null if no match found.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListIdentifier rdf:type rdf:Property ;
    rdfs:label 'Matched List Identifier' ;
    rdfs:comment 'Unique identifier or reference number of the matched entry within the sanctions list (e.g., OFAC UID, UN Reference Number). Null if no match.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedListName rdf:type rdf:Property ;
    rdfs:label 'Matched List Name' ;
    rdfs:comment 'Name of the specific sanctions list where the match was found (e.g., OFAC SDN, UN 1267, EU Consolidated). Null if no match.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Final action taken based on the screening result. Documents compliance decision and operational response.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Reviewing Officer Name' ;
    rdfs:comment 'Full name of the compliance officer or analyst who reviewed and resolved the screening check. Null if automated clearance or pending review.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Overall risk classification assigned to this screening result based on match score, entity type, and business context. Drives escalation and approval workflows.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsListUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Update Date' ;
    rdfs:comment 'Date when the sanctions lists used for this screening were last updated. Ensures screening was performed against current regulatory data.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screenedEntityType rdf:type rdf:Property ;
    rdfs:label 'Screened Entity Type' ;
    rdfs:comment 'Classification of the entity being screened. Determines which screening protocols and risk thresholds apply. [ENUM-REF-CANDIDATE: vessel|company|individual|freight_forwarder|cargo_owner|consignee|shipper|agent|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningListsChecked rdf:type rdf:Property ;
    rdfs:label 'Screening Lists Checked' ;
    rdfs:comment 'Comma-separated list of sanctions and restricted party lists checked during this screening (e.g., OFAC SDN, UN Consolidated, EU Consolidated, national lists). Ensures comprehensive coverage of applicable regulatory lists.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningNotes rdf:type rdf:Property ;
    rdfs:label 'Screening Notes' ;
    rdfs:comment 'Free-text notes and comments added by compliance analysts during review and resolution. Documents decision rationale and supporting evidence.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the sanctions screening check, used for audit trails and compliance reporting.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current lifecycle status of the sanctions screening check. Tracks progression from initiation through resolution. [ENUM-REF-CANDIDATE: pending|in_progress|clear|potential_match|confirmed_match|false_positive|escalated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystemName rdf:type rdf:Property ;
    rdfs:label 'Screening System Name' ;
    rdfs:comment 'Name or identifier of the automated sanctions screening system or service that performed the check (e.g., Dow Jones Risk & Compliance, Refinitiv World-Check, internal PCS module).' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Screening System Version' ;
    rdfs:comment 'Version number of the screening system or sanctions list database used at the time of screening. Critical for audit trails and compliance verification.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Date and time when the sanctions screening check was initiated. Critical for compliance audit trails and regulatory reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Screening Trigger Event' ;
    rdfs:comment 'Business event or process that initiated this sanctions screening check. Supports root cause analysis and process optimization. [ENUM-REF-CANDIDATE: vessel_arrival|cargo_declaration|booking_request|gate_entry|customs_clearance|manual_check|periodic_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselFlagState rdf:type rdf:Property ;
    rdfs:label 'Vessel Flag State' ;
    rdfs:comment 'Three-letter ISO country code of the vessel\'s flag state. Applicable only when screened_entity_type is vessel.' ;
    rdfs:domain ind:SanctionsScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Trade documents require verification and approval by authorized port authority officers. This links the document to the employee who verified it, supporting audit trails, document workflow tracking, a' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customsClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Date' ;
    rdfs:comment 'The date on which customs clearance was granted for the cargo covered by this trade document. Nullable until clearance is obtained.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileReference rdf:type rdf:Property ;
    rdfs:label 'File Reference' ;
    rdfs:comment 'The file path, URI, or document management system reference for the electronic or scanned copy of this trade document. Used for document retrieval and audit trail.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isElectronic rdf:type rdf:Property ;
    rdfs:label 'Is Electronic' ;
    rdfs:comment 'Flag indicating whether this trade document was submitted electronically (true) or as a paper document (false). Used to track digitalization of trade documentation.' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Isps Compliance Flag' ;
    rdfs:comment 'Flag indicating whether this trade document has been verified for ISPS Code security compliance (true) or requires additional security screening (false).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingPartyCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Party Code' ;
    rdfs:comment 'The standardized code or identifier for the issuing party (e.g., SCAC code for shipping lines, customs broker license number, chamber of commerce registration number).' ;
    rdfs:domain ind:TradeDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedCountryId rdf:type rdf:Property ;
    rdfs:label 'Affected Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Trade restrictions target specific countries (sanctions, embargoes, tariffs). Master country data provides sanctions_list_flag, effective dates, MOU membership, and flag state performance for automate' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:affectedPartyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Affected Party Identifier' ;
    rdfs:comment 'Unique identifier for the affected party such as IMO number for vessels, tax ID for companies, or passport number for individuals.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPartyName rdf:type rdf:Property ;
    rdfs:label 'Affected Party Name' ;
    rdfs:comment 'Name of the specific vessel, company, individual, or entity subject to the trade restriction.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPartyType rdf:type rdf:Property ;
    rdfs:label 'Affected Party Type' ;
    rdfs:comment 'Classification of the party type subject to the restriction, indicating whether it applies to vessels, companies, individuals, or other entities.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedTerritory rdf:type rdf:Property ;
    rdfs:label 'Affected Territory' ;
    rdfs:comment 'Specific territory, region, or administrative area within a country that is subject to the restriction, if applicable.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Declaration Required Flag' ;
    rdfs:comment 'Indicates whether a formal customs declaration or compliance statement is required for goods or parties subject to this restriction.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:derogationAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Derogation Available Flag' ;
    rdfs:comment 'Indicates whether exemptions or derogations from the restriction can be granted under specific conditions.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:derogationConditions rdf:type rdf:Property ;
    rdfs:label 'Derogation Conditions' ;
    rdfs:comment 'Detailed conditions, criteria, and procedures under which an exemption or derogation from the restriction may be granted.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Level' ;
    rdfs:comment 'Classification of the enforcement rigor and compliance obligation associated with the restriction.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeFrom rdf:type rdf:Property ;
    rdfs:label 'Hs Code From' ;
    rdfs:comment 'Starting Harmonized System code defining the lower bound of the commodity range affected by the restriction.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeTo rdf:type rdf:Property ;
    rdfs:label 'Hs Code To' ;
    rdfs:comment 'Ending Harmonized System code defining the upper bound of the commodity range affected by the restriction.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction where the issuing authority is based.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Name of the government agency, international body, or regulatory authority that issued the trade restriction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when the trade restriction was last reviewed or updated by the issuing authority or compliance team.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'Reference to the legal instrument, resolution, regulation, act, or treaty that establishes the authority for the trade restriction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Legal Reference Number' ;
    rdfs:comment 'Official citation or reference number of the legal instrument establishing the restriction.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseRequirementType rdf:type rdf:Property ;
    rdfs:label 'License Requirement Type' ;
    rdfs:comment 'Type of trade license or permit required to conduct transactions involving goods or parties subject to this restriction.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next review or reassessment of the trade restriction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether stakeholders must be formally notified when this restriction is triggered or applied.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of penalties, fines, or sanctions applicable for violations of the trade restriction.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when the trade restriction was officially published or announced by the issuing authority.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionAuthority rdf:type rdf:Property ;
    rdfs:label 'Restriction Authority' ;
    rdfs:comment 'The governing body or jurisdiction that issued and enforces the trade restriction. [ENUM-REF-CANDIDATE: UN|EU|OFAC|national|IMO|bilateral|multilateral — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionCode rdf:type rdf:Property ;
    rdfs:label 'Restriction Code' ;
    rdfs:comment 'Unique business identifier code for the trade restriction, used for external reference and system integration.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Restriction Description' ;
    rdfs:comment 'Detailed narrative description of the trade restriction including scope, conditions, and enforcement requirements.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionScope rdf:type rdf:Property ;
    rdfs:label 'Restriction Scope' ;
    rdfs:comment 'Defines the trade flow direction and activities covered by the restriction.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionStatus rdf:type rdf:Property ;
    rdfs:label 'Restriction Status' ;
    rdfs:comment 'Current lifecycle status of the trade restriction indicating its enforceability and operational state.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of the trade restriction mechanism applied to control or prohibit trade activities.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Screening Required Flag' ;
    rdfs:comment 'Indicates whether automated sanctions screening is required for transactions potentially affected by this restriction.' ;
    rdfs:domain ind:TradeRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source Reference Code' ;
    rdfs:comment 'Unique identifier of the trade restriction record in the source operational system.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationId rdf:type rdf:Property ;
    rdfs:label 'Violation Id' ;
    rdfs:comment 'Primary key for violation' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigatingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigating Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance violations require investigation by qualified officers. This links the violation to the investigating employee for case management, workload tracking, and competency verification. Essential' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:associatedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Associated Entity Reference' ;
    rdfs:comment 'Unique identifier or reference number of the entity associated with the violation (e.g., IMO number, BOL number, container number, facility code, party ID).' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedEntityType rdf:type rdf:Property ;
    rdfs:label 'Associated Entity Type' ;
    rdfs:comment 'Type of entity associated with the violation (e.g., vessel, cargo shipment, container, port facility, trading party, document). [ENUM-REF-CANDIDATE: vessel|cargo|container|facility|party|document|equipment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Closure Timestamp' ;
    rdfs:comment 'Date and time when the violation case was officially closed after all corrective actions and penalties were resolved.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Overall lifecycle status of the violation case from detection through closure.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of the corrective action implementation and completion.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedByOfficer rdf:type rdf:Property ;
    rdfs:label 'Detected By Officer' ;
    rdfs:comment 'Name or identifier of the compliance officer, inspector, or authority who detected the violation.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedBySystem rdf:type rdf:Property ;
    rdfs:label 'Detected By System' ;
    rdfs:comment 'Name of the automated system or screening tool that flagged the violation (e.g., PCS Sanctions Screening, TOS Gate Alert, VTMS Compliance Monitor).' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method by which the violation was identified (e.g., physical inspection, automated screening, system alert, audit finding).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the violation was first detected or identified. Principal business event timestamp for this violation record.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectorNotes rdf:type rdf:Property ;
    rdfs:label 'Inspector Notes' ;
    rdfs:comment 'Internal notes and observations recorded by the inspector or compliance officer during the violation investigation.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty or fine amount assessed for the violation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty amount.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Penalty Payment Status' ;
    rdfs:comment 'Current payment status of the assessed penalty.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyReference rdf:type rdf:Property ;
    rdfs:label 'Penalty Reference' ;
    rdfs:comment 'Reference number or identifier for the penalty assessment or fine issued by the regulatory authority.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this violation is a repeat occurrence for the same entity or party.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Specific regulatory framework or convention that was breached (e.g., ISPS Code, SOLAS Chapter XI-2, MARPOL Annex VI, WCO SAFE Framework, national customs act).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingAuthority rdf:type rdf:Property ;
    rdfs:label 'Reporting Authority' ;
    rdfs:comment 'Name of the regulatory authority or governing body to which the violation was reported (e.g., national customs, IMO, port state control authority).' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reporting Timestamp' ;
    rdfs:comment 'Date and time when the violation was formally reported to the regulatory authority.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Quantitative risk score assigned to the violation based on severity, frequency, and potential impact on port operations and security.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Severity classification of the violation indicating the level of risk and urgency for remediation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier for supporting documentation, evidence, or attachments related to the violation (e.g., inspection reports, photos, certificates).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the violation, including specific non-conformance details, circumstances, and evidence observed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Category of compliance violation detected. Classifies the violation by regulatory domain.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedByPortAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Signed By Port Authority Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Contract execution requires tracking which port authority employee signed the agreement for legal accountability and audit compliance. Port authority signatory is an internal employee, not external pa' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:slaProfileId rdf:type rdf:Property ;
    rdfs:label 'Sla Profile Id' ;
    rdfs:comment 'Foreign key reference to the SLA profile defining performance commitments, KPIs, and penalty/bonus structures for this agreement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaProfile .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known business identifier for the agreement, typically generated by SAP S/4HANA or CRM system. Used in all stakeholder communications and invoicing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the agreement. Draft: initial preparation; Under Negotiation: terms being discussed; Active: in force and binding; Suspended: temporarily inactive; Expired: reached end date; Terminated: ended before expiry.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the commercial agreement. Service agreements cover shipping line commitments; concession agreements grant terminal operating rights; stevedoring contracts define cargo handling services; PIL (Port Infrastructure Levy) arrangements establish infrastructure fee structures; lease agreements cover facility/equipment rental; marine services agreements cover pilotage, towage, and mooring services.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allianceMembership rdf:type rdf:Property ;
    rdfs:label 'Alliance Membership' ;
    rdfs:comment 'For shipping-line-type agreements: name of the global shipping alliance the line belongs to (e.g., 2M Alliance, THE Alliance, Ocean Alliance). Affects service string coordination and slot allocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the agreement automatically renews for an additional term unless either party provides termination notice within the specified notice period.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concessionTermYears rdf:type rdf:Property ;
    rdfs:label 'Concession Term Years' ;
    rdfs:comment 'For concession-type agreements: duration of the concession grant in years. Typical maritime concessions range from 10 to 50 years.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'Total monetary value of the agreement over its full term. For concession agreements, represents minimum annual guarantee revenue (MAGR) multiplied by term years. For service agreements, represents committed volume multiplied by tariff rates.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding receivables balance allowed for the contracting party before services are suspended. Managed in conjunction with credit assessment records.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmOpportunityReference rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Reference' ;
    rdfs:comment 'Reference to the originating sales opportunity in Microsoft Dynamics 365 CRM that led to this agreement. Enables tracking from lead to contract.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'File path or document management system reference to the signed contract PDF or scanned original. Enables retrieval of the full legal document.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Required Flag' ;
    rdfs:comment 'For shipping-line-type agreements: indicates whether the shipping line is required to exchange cargo manifests, BAPLIE stowage plans, and COPARN pre-announcements via EDI (Electronic Data Interchange) with the port community system.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the interpretation and enforcement of the agreement (e.g., Singapore Law, English Law, UAE Federal Law).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the contracting party is required to maintain Protection and Indemnity (P&I) insurance or general liability insurance as a condition of the agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investmentCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Investment Commitment Amount' ;
    rdfs:comment 'For concession-type agreements: total capital expenditure (CAPEX) the concessionaire commits to invest in port infrastructure and equipment over the concession term.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Court or arbitration body with authority to resolve disputes arising from the agreement (e.g., Singapore International Arbitration Centre, London Maritime Arbitrators Association).' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:magrAmount rdf:type rdf:Property ;
    rdfs:label 'Magr Amount' ;
    rdfs:comment 'For concession-type agreements: minimum annual revenue the concessionaire guarantees to pay the port authority regardless of actual throughput. Key financial metric for concession valuation.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date within which the contracting party must settle payment. Common maritime terms are Net 30, Net 45, or Net 60 days.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productivityTargetMovesPerHour rdf:type rdf:Property ;
    rdfs:label 'Productivity Target Moves Per Hour' ;
    rdfs:comment 'For stevedoring-type agreements: contractual minimum container moves per hour that the stevedoring company must achieve. Typical targets range from 25 to 40 moves/hour for STS cranes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days before expiry date by which either party must provide written notice to prevent auto-renewal. Typically 90, 180, or 365 days for maritime agreements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'For concession-type agreements: percentage of gross revenue above MAGR threshold that the concessionaire pays to the port authority. Typically ranges from 10% to 40%.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'Source system contract identifier from SAP S/4HANA ERP system. Used for financial integration and billing run generation.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Refundable deposit held by the port authority as security against non-payment or breach of contract terms. Typically equivalent to 1-3 months of estimated charges.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceStrings rdf:type rdf:Property ;
    rdfs:label 'Service Strings' ;
    rdfs:comment 'For shipping-line-type agreements: comma-separated list of vessel service routes the shipping line operates through this port (e.g., Asia-Europe Loop 1, Transpacific Express, Middle East Shuttle).' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date when the agreement was formally executed by both parties. May differ from effective_date if the agreement has a future commencement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signedByCounterparty rdf:type rdf:Property ;
    rdfs:label 'Signed By Counterparty' ;
    rdfs:comment 'Name and title of the counterparty signatory who executed the agreement on behalf of the contracting organization.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date when the agreement was terminated before its natural expiry. Populated only for agreements with status = terminated. Null for active, expired, or suspended agreements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Business reason for early termination of the agreement (e.g., breach of contract, mutual consent, force majeure, insolvency, regulatory change). Populated only when termination_date is not null.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementPartyId rdf:type rdf:Property ;
    rdfs:label 'Agreement Party Id' ;
    rdfs:comment 'Unique identifier for the agreement party association record. Primary key for this entity.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementParty .

ind:accessCredentialId rdf:type rdf:Property ;
    rdfs:label 'Access Credential Id' ;
    rdfs:comment 'Foreign key linking to security.access_credential. Business justification: Agreement parties (shipping lines, terminal operators, service providers) receive facility access credentials upon contract execution. Credential lifecycle management requires linking to agreement par' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessCredential .

ind:authorizedRepresentativeEmail rdf:type rdf:Property ;
    rdfs:label 'Authorized Representative Email' ;
    rdfs:comment 'The email address of the authorized representative for operational communications and contract administration.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Authorized Representative Name' ;
    rdfs:comment 'The name of the individual authorized to act on behalf of this party for day-to-day contract administration and operational matters. May differ from the signatory.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedRepresentativePhone rdf:type rdf:Property ;
    rdfs:label 'Authorized Representative Phone' ;
    rdfs:comment 'The telephone contact number for the authorized representative. Used for operational escalations and urgent contract matters.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications Required' ;
    rdfs:comment 'Comma-separated list of compliance certifications this party must maintain as a condition of the agreement. Examples: ISO 9001, ISO 14001, ISO 45001, ISPS certification, customs AEO status.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the credit limit amount. Examples: USD, EUR, GBP, SGD.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'The agreed method for resolving disputes involving this party. Negotiation is direct discussion, mediation uses neutral facilitator, arbitration is binding third-party decision, litigation is court proceedings, expert determination uses technical specialist.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction whose laws govern this partys obligations under the agreement. Examples: Singapore, England and Wales, New York, Hong Kong.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Guarantee Amount' ;
    rdfs:comment 'The financial guarantee or security amount provided by this party to secure performance. Applicable primarily to guarantor role. Expressed in the agreement currency.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeCurrency rdf:type rdf:Property ;
    rdfs:label 'Guarantee Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the guarantee amount. Examples: USD, EUR, GBP, SGD.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Guarantee Expiry Date' ;
    rdfs:comment 'The date on which the financial guarantee expires and is no longer enforceable. Typically extends beyond the agreement end date to cover tail liabilities.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteeInstrumentType rdf:type rdf:Property ;
    rdfs:label 'Guarantee Instrument Type' ;
    rdfs:comment 'The type of financial instrument used to secure the guarantee. Bank guarantee is issued by financial institution, letter of credit is trade finance instrument, performance bond is surety bond, parent company guarantee is corporate backing, cash deposit is held funds, insurance policy is underwritten coverage.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnityScope rdf:type rdf:Property ;
    rdfs:label 'Indemnity Scope' ;
    rdfs:comment 'Textual description of the scope of indemnity obligations this party has agreed to. Defines what losses, damages, or claims this party will cover for other parties.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageCurrency rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the insurance minimum coverage amount. Examples: USD, EUR, GBP, SGD.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageTypes rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Types' ;
    rdfs:comment 'Comma-separated list of required insurance coverage types. Examples: public liability, professional indemnity, marine cargo, hull and machinery, workers compensation, environmental liability.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceMinimumCoverage rdf:type rdf:Property ;
    rdfs:label 'Insurance Minimum Coverage' ;
    rdfs:comment 'The minimum insurance coverage amount this party must maintain. Expressed in the agreement currency. Null if no specific minimum is stipulated.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'The maximum financial liability this party has agreed to under the contract terms. Expressed in the agreement currency. Null if unlimited liability or not applicable to this party role.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the liability cap amount. Examples: USD, EUR, GBP, SGD.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationAddress rdf:type rdf:Property ;
    rdfs:label 'Notification Address' ;
    rdfs:comment 'The full postal address for sending formal legal notices and registered correspondence to this party. Required for contractual notice provisions.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEmail rdf:type rdf:Property ;
    rdfs:label 'Notification Email' ;
    rdfs:comment 'The primary email address for sending contractual notices, amendments, and communications to this party. Must be monitored regularly per agreement terms.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyEntryDate rdf:type rdf:Property ;
    rdfs:label 'Party Entry Date' ;
    rdfs:comment 'The date this party became bound by the agreement. May differ from signing date if the agreement has a deferred effective date or if the party was added via amendment.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partyExitDate rdf:type rdf:Property ;
    rdfs:label 'Party Exit Date' ;
    rdfs:comment 'The date this party ceased to be bound by the agreement. Populated when party status changes to terminated, novated, or released. Null for active parties.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partyRole rdf:type rdf:Property ;
    rdfs:label 'Party Role' ;
    rdfs:comment 'The functional role this party plays within the agreement. Port authority is the service provider, counterparty is the primary customer or contractor, guarantor provides financial backing, sub-contractor performs delegated work, co-signatory shares obligations, beneficiary receives rights without direct obligations.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'The current lifecycle status of this party within the agreement. Active means obligations are in force, suspended means temporary halt, terminated means party has exited, defaulted means breach of obligations, novated means replaced by another party, released means obligations discharged early.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'The business classification of the party entity. Shipping line operates vessels, freight forwarder arranges cargo movement, cargo owner holds title to goods, stevedore provides cargo handling services, concessionaire operates terminal facilities under lease, government agency represents regulatory or customs authority.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsOverride rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Override' ;
    rdfs:comment 'Party-specific payment terms that override the standard agreement payment terms. Examples: net 30 days, advance payment, milestone-based, letter of credit. Null if standard terms apply.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'The value of the performance bond required from this party. Typically a percentage of the total contract value. Expressed in the agreement currency.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondCurrency rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the performance bond amount. Examples: USD, EUR, GBP, SGD.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required Flag' ;
    rdfs:comment 'Indicates whether this party is required to provide a performance bond to guarantee fulfillment of contractual obligations. True if bond is mandatory, false otherwise.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatoryAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Signatory Authority Level' ;
    rdfs:comment 'The hierarchical authority level of the signatory within their organization. Board level requires board resolution, executive is C-suite, senior management is VP or director level, middle management is department head, delegated is authorized representative with power of attorney.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'The full legal name of the individual who signed the agreement on behalf of this party. Required for contract enforceability and audit trail.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'The official job title or position of the signatory within their organization at the time of signing. Examples: Chief Executive Officer, Managing Director, Port Director, Operations Manager.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'The calendar date on which this party executed the agreement. May differ across parties in multi-party agreements with sequential signing. Critical for determining contract formation and effective date.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signingLocation rdf:type rdf:Property ;
    rdfs:label 'Signing Location' ;
    rdfs:comment 'The city and country where the signatory executed the agreement. Relevant for determining governing law and jurisdiction in international contracts.' ;
    rdfs:domain ind:AgreementParty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementVersionId rdf:type rdf:Property ;
    rdfs:label 'Agreement Version Id' ;
    rdfs:comment 'Unique identifier for each version of a commercial agreement. Primary key for the agreement version entity.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementVersion .

ind:changeRequestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Change Requested By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Contract amendment audit trail requires tracking which employee requested each version change for governance and accountability in contract lifecycle management.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededVersionAgreementVersionId rdf:type rdf:Property ;
    rdfs:label 'Superseded Version Agreement Version Id' ;
    rdfs:comment 'Reference to the previous agreement version that this version replaces. Nullable for the initial version of an agreement.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementVersion .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business justification or trigger for creating this version. May reference regulatory changes, commercial renegotiation, operational requirements, or dispute resolution.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'Brief executive summary of the key changes introduced in this version compared to the previous version. Provides quick reference for stakeholders.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the type of change that created this version. Amendment modifies existing terms, addendum adds new terms, renewal extends duration, novation replaces parties, restatement consolidates prior changes.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Counterparty Acceptance Date' ;
    rdfs:comment 'Date when the counterparty formally accepted or signed this version. Nullable if acceptance not required or not yet received.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyAcceptanceRequired rdf:type rdf:Property ;
    rdfs:label 'Counterparty Acceptance Required' ;
    rdfs:comment 'Indicates whether this version requires explicit acceptance or signature from the counterparty (shipping line, stevedore, concessionaire). True if bilateral approval needed.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'Format of the stored agreement version document. Indicates whether the record is digital, scanned, or paper-based.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Flag' ;
    rdfs:comment 'Indicates whether this version introduces changes to pricing, tariffs, payment terms, or other financial obligations. True if financial terms changed.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialImpactSummary rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Summary' ;
    rdfs:comment 'Description of the financial changes introduced in this version, including revenue impact, cost changes, or payment term modifications. Confidential business information.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date when legal review of this version was completed. Nullable if no legal review was required.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required' ;
    rdfs:comment 'Flag indicating whether this version required formal legal counsel review before approval. True for material changes, false for administrative updates.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewer rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer' ;
    rdfs:comment 'Name or identifier of the legal counsel or law firm that reviewed this version. Nullable if no legal review was required.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date when stakeholder notification was distributed to affected parties. Nullable if notification not yet sent.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this version was created to address regulatory changes, compliance requirements, or industry standard updates. True if driven by regulatory mandate.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when all parties executed this version of the agreement. Represents the legal commitment date.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaChangesFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Changes Flag' ;
    rdfs:comment 'Indicates whether this version modifies service level commitments, performance targets, or operational obligations. True if SLA terms changed.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaChangesSummary rdf:type rdf:Property ;
    rdfs:label 'Sla Changes Summary' ;
    rdfs:comment 'Description of the service level changes introduced in this version, including modified KPIs, performance targets, or operational commitments.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Version Effective Date' ;
    rdfs:comment 'Date when this version of the agreement becomes legally binding and operationally effective. Marks the start of this version\'s validity period.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Version Expiry Date' ;
    rdfs:comment 'Date when this version of the agreement ceases to be valid, either due to supersession by a new version or contract termination. Nullable for open-ended versions.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionNotes rdf:type rdf:Property ;
    rdfs:label 'Version Notes' ;
    rdfs:comment 'Additional free-text notes, comments, or context about this version. May include negotiation history, special conditions, or implementation instructions.' ;
    rdfs:domain ind:AgreementVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version identifier for the agreement (e.g., 1.0, 1.1, 2.0). Increments with each amendment, addendum, or renewal.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of this agreement version. Tracks progression from draft through approval to active use and eventual supersession.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentId rdf:type rdf:Property ;
    rdfs:label 'Contract Document Id' ;
    rdfs:comment 'Unique identifier for the contract document record. Primary key for the contract document registry.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uploadedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Uploaded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Document management audit trail requires employee reference for accountability in contract document lifecycle and compliance record-keeping.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessCount rdf:type rdf:Property ;
    rdfs:label 'Access Count' ;
    rdfs:comment 'Total number of times the document has been accessed or viewed. Indicates document importance and usage frequency.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'Cryptographic hash of the document file content, typically SHA-256 or MD5. Ensures document integrity and detects unauthorized modifications.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Security classification level governing access control, distribution, and handling procedures. Aligns with port authority information security policy and International Ship and Port Facility Security (ISPS) Code requirements.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Eligible Date' ;
    rdfs:comment 'Calculated date after which the document may be disposed of in accordance with retention policy. Derived from effective date plus retention period.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'Official date of the document as recorded on the document itself, typically the execution date, issuance date, or effective date depending on document type.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Digital file format of the stored document. Determines rendering requirements, archival strategy, and long-term accessibility. [ENUM-REF-CANDIDATE: pdf|docx|doc|xlsx|xls|tiff|jpeg|png|msg|eml — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the document file in bytes. Used for storage capacity planning, transmission bandwidth estimation, and integrity verification.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags associated with the document to facilitate search, discovery, and categorization.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Primary language in which the document is written, using ISO 639-1 two-letter language codes. Supports multilingual document management and translation requirements.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Accessed Timestamp' ;
    rdfs:comment 'Date and time when the document was last accessed or viewed by any user. Supports usage analytics and compliance monitoring.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notarisationDate rdf:type rdf:Property ;
    rdfs:label 'Notarisation Date' ;
    rdfs:comment 'Date on which the document was notarized. Applicable only when notarisation_flag is true.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notarisationFlag rdf:type rdf:Property ;
    rdfs:label 'Notarisation Flag' ;
    rdfs:comment 'Indicates whether the document has been notarized by a licensed notary public or equivalent authority. Required for certain legal instruments and international agreements.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notaryName rdf:type rdf:Property ;
    rdfs:label 'Notary Name' ;
    rdfs:comment 'Name of the notary public who notarized the document. Applicable only when notarisation_flag is true.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notaryRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Notary Registration Number' ;
    rdfs:comment 'Official registration or license number of the notary public. Enables verification of notary credentials and authority.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document. Relevant for printing, scanning, and document completeness verification.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'Official reference number assigned by the regulatory authority for approved documents. Applicable to regulatory approvals, permits, and compliance certificates.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the document must be retained to comply with legal, regulatory, and business requirements. Drives archival and disposal scheduling.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatoryOrganization rdf:type rdf:Property ;
    rdfs:label 'Signatory Organization' ;
    rdfs:comment 'Legal name of the organization represented by the signatory. Identifies the party bound by the document.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Full descriptive title of the document as it appears on the document itself. Provides human-readable identification of document content and purpose.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Required Flag' ;
    rdfs:comment 'Indicates whether the document requires translation to another language for legal, operational, or regulatory purposes.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'Date and time when the document was uploaded to the document management system. Establishes audit trail for document receipt and processing.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier for the document, tracking revisions and amendments over time. Supports version control and audit trail requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessContact rdf:type rdf:Property ;
    rdfs:label 'Witness Contact' ;
    rdfs:comment 'Contact details for the witness, typically phone number or email address. Enables verification and follow-up if required for legal proceedings.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Name of the witness who attested to the signing of the document. Required for certain legal instruments and jurisdictions.' ;
    rdfs:domain ind:ContractDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRecordId rdf:type rdf:Property ;
    rdfs:label 'Dispute Record Id' ;
    rdfs:comment 'Unique identifier for the commercial dispute record. Primary key for the dispute_record product.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Penalty Assessment Id' ;
    rdfs:comment 'Foreign key linking to contract.penalty_assessment. Business justification: Commercial disputes often arise from penalty assessments (e.g., customer disputes the penalty calculation or applicability). This FK links the dispute to the assessment that triggered it, providing tr' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PenaltyAssessment .

ind:primaryDisputeAssignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Dispute Assigned To Employee Id' ;
    rdfs:comment 'Reference to the port employee responsible for managing and resolving the dispute. Links to the employee product.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:slaBreachId rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Id' ;
    rdfs:comment 'Foreign key linking to contract.sla_breach. Business justification: Disputes can arise from SLA breach events (e.g., customer disputes whether a breach actually occurred or disputes the root cause). Currently dispute_record links to sla_profile (the definition catalog' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaBreach .

ind:arbitrationBody rdf:type rdf:Property ;
    rdfs:label 'Arbitration Body' ;
    rdfs:comment 'Name of the arbitration institution or body handling the dispute if resolution_method is arbitration (e.g., \'International Chamber of Commerce (ICC)\', \'Singapore International Arbitration Centre (SIAC)\', \'London Maritime Arbitrators Association (LMAA)\').' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Indicates whether the dispute and its resolution are subject to confidentiality or non-disclosure obligations. True if confidential, False if not.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Detailed narrative description of the dispute, including the nature of the disagreement, the facts in contention, and the basis for the claim or defense.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally-known unique business identifier for the dispute, used in correspondence and legal documentation. Format: DSP-YYYYNNNN.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the dispute by its nature: billing disputes (invoice disagreements), SLA breach disputes (service level violations), penalty disputes (demurrage/detention/wharfage disagreements), interpretation disputes (contractual clause ambiguity), tariff disputes (rate disagreements), or service quality disputes.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedClauseReference rdf:type rdf:Property ;
    rdfs:label 'Disputed Clause Reference' ;
    rdfs:comment 'Reference to the specific contract clause, section, or schedule that is the subject of the dispute (e.g., \'Section 5.3 - SLA Performance Metrics\', \'Schedule B - Tariff Rates\').' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalSettledAmount rdf:type rdf:Property ;
    rdfs:label 'Final Settled Amount' ;
    rdfs:comment 'The final monetary amount agreed upon or awarded as part of the dispute resolution. May differ from disputed_amount. Expressed in the contract currency. Null if no monetary settlement.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactOnRelationship rdf:type rdf:Property ;
    rdfs:label 'Impact On Relationship' ;
    rdfs:comment 'Assessment of the disputes impact on the ongoing commercial relationship between the port and the counterparty: none (no impact), minor (temporary strain), moderate (requires relationship repair), significant (long-term damage), or relationship_terminated (contract ended as result).' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRepresentativeCounterparty rdf:type rdf:Property ;
    rdfs:label 'Legal Representative Counterparty' ;
    rdfs:comment 'Name of the law firm or legal counsel representing the counterparty in the dispute.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRepresentativePort rdf:type rdf:Property ;
    rdfs:label 'Legal Representative Port' ;
    rdfs:comment 'Name of the law firm or legal counsel representing Shipping Ports in the dispute.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediatorName rdf:type rdf:Property ;
    rdfs:label 'Mediator Name' ;
    rdfs:comment 'Name of the mediator or mediation firm facilitating the dispute resolution if resolution_method is mediation.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedByParty rdf:type rdf:Property ;
    rdfs:label 'Raised By Party' ;
    rdfs:comment 'Indicates which party initiated the dispute: port (Shipping Ports raised the dispute) or counterparty (the contract counterparty raised the dispute).' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedDate rdf:type rdf:Property ;
    rdfs:label 'Raised Date' ;
    rdfs:comment 'The date on which the dispute was formally raised by either party. This is the principal business event timestamp for the dispute lifecycle.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'The method being used or planned to resolve the dispute: negotiation (direct party-to-party discussion), mediation (facilitated by neutral third party), arbitration (binding decision by arbitrator), or litigation (court proceedings).' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'The outcome of the dispute resolution: port_favor (decision in favor of Shipping Ports), counterparty_favor (decision in favor of counterparty), mutual_settlement (negotiated compromise), withdrawn (dispute retracted by raising party), or dismissed (dispute rejected without merit).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTargetDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Target Date' ;
    rdfs:comment 'The target or expected date by which the dispute is planned to be resolved, based on contractual timelines or resolution process schedules.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'The date by which a formal response to the dispute notification is required, as stipulated in the contract or by the resolution process.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Response Received Date' ;
    rdfs:comment 'The date on which a formal response to the dispute was received from the counterparty or sent by the port.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Narrative description of the terms and conditions of the settlement or resolution, including any non-monetary remedies, service adjustments, or future commitments agreed upon.' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingEvidenceReferences rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence References' ;
    rdfs:comment 'Comma-separated list of document references, file paths, or document management system identifiers for evidence supporting the dispute (e.g., invoices, emails, performance reports, vessel logs, gate records).' ;
    rdfs:domain ind:DisputeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeBondId rdf:type rdf:Property ;
    rdfs:label 'Guarantee Bond Id' ;
    rdfs:comment 'Unique identifier for the guarantee bond record. Primary key for the guarantee bond entity.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'Name of the party entitled to claim against the bond. Typically the port authority or terminal operator who is protected by the guarantee.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Bond Fee Amount' ;
    rdfs:comment 'Fee charged by the bond provider for issuing and maintaining the guarantee. May be a one-time issuance fee or recurring annual premium.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Bond Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the bond fee is denominated. May differ from the bond value currency.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondFeeFrequency rdf:type rdf:Property ;
    rdfs:label 'Bond Fee Frequency' ;
    rdfs:comment 'Frequency at which bond fees are charged. One-time fees are paid at issuance, while recurring fees are paid periodically throughout the bond\'s life.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondNumber rdf:type rdf:Property ;
    rdfs:label 'Bond Number' ;
    rdfs:comment 'Externally-known unique reference number or certificate number assigned by the bond provider (bank, insurer, or parent entity). Used for identification and claim processing.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondProviderCreditRating rdf:type rdf:Property ;
    rdfs:label 'Bond Provider Credit Rating' ;
    rdfs:comment 'Credit rating of the bond provider as assessed by recognized rating agencies (e.g., AAA, AA+, BBB). Used to evaluate the financial strength and reliability of the guarantee.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondStatus rdf:type rdf:Property ;
    rdfs:label 'Bond Status' ;
    rdfs:comment 'Current lifecycle status of the guarantee bond. Active bonds are in force, expired bonds have passed their validity period, claimed bonds have had claims submitted, released bonds have been discharged, suspended bonds are temporarily inactive, and cancelled bonds have been terminated before expiry.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondType rdf:type rdf:Property ;
    rdfs:label 'Bond Type' ;
    rdfs:comment 'Classification of the guarantee instrument type. Performance bonds secure contract performance obligations, bank guarantees provide financial security from banking institutions, parent company guarantees are corporate commitments, bid bonds secure tender participation, advance payment bonds protect advance payments, and retention bonds replace retention money.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondValue rdf:type rdf:Property ;
    rdfs:label 'Bond Value' ;
    rdfs:comment 'The maximum monetary amount that can be claimed under the guarantee bond. Represents the financial exposure covered by the instrument.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimConditions rdf:type rdf:Property ;
    rdfs:label 'Claim Conditions' ;
    rdfs:comment 'Detailed description of the conditions and circumstances under which the beneficiary is entitled to make a claim against the bond. Defines triggering events and claim procedures.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Claim Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required before submitting a formal claim. Allows the bond provider and principal to respond to potential claims.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimProcedure rdf:type rdf:Property ;
    rdfs:label 'Claim Procedure' ;
    rdfs:comment 'Step-by-step process and documentation requirements for submitting a claim against the bond. Includes notice periods, required evidence, and submission channels.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Regulatory or industry compliance framework that this bond must adhere to (e.g., ISPS Code, IMO Guidelines, local port authority regulations). Defines compliance obligations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastClaimDate rdf:type rdf:Property ;
    rdfs:label 'Last Claim Date' ;
    rdfs:comment 'Date of the most recent claim submitted against this bond. Used to track claim activity and bond performance.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required' ;
    rdfs:comment 'Indicates whether regulatory approval or registration is required for this bond to be valid. True if regulatory oversight applies, false otherwise.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the government agency or regulatory body that oversees or approves this bond. Applicable when regulatory approval is required.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBondValue rdf:type rdf:Property ;
    rdfs:label 'Remaining Bond Value' ;
    rdfs:comment 'Available bond value remaining after deducting all paid claims. Represents the current financial protection still available under the guarantee.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Terms and conditions governing the renewal or extension of the bond beyond its original expiry date. Includes renewal notice periods, fee structures, and conditions precedent.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Scheduled date for periodic review of the bond\'s adequacy, provider creditworthiness, and alignment with contract requirements. Ensures ongoing risk management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAssessmentRating rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Rating' ;
    rdfs:comment 'Internal risk rating assigned to this bond based on provider creditworthiness, claim history, and contract exposure. Used for portfolio risk management.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Security Registration Number' ;
    rdfs:comment 'Official registration number assigned by regulatory authorities or security registries. Required for certain types of financial guarantees in regulated jurisdictions.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claimed Amount' ;
    rdfs:comment 'Cumulative monetary amount that has been claimed against this bond across all claims. Tracks the financial exposure realized from the guarantee.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalClaimsCount rdf:type rdf:Property ;
    rdfs:label 'Total Claims Count' ;
    rdfs:comment 'Total number of claims that have been submitted against this bond throughout its lifecycle. Used to track claim frequency and bond utilization.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Paid Amount' ;
    rdfs:comment 'Cumulative monetary amount that has been paid out by the bond provider in settlement of claims. May differ from claimed amount due to disputes or partial settlements.' ;
    rdfs:domain ind:GuaranteeBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseId rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Id' ;
    rdfs:comment 'Foreign key linking to contract.penalty_clause. Business justification: Penalty assessments are triggered by contractual penalty clauses. This FK links the transactional assessment record to the master clause definition, enabling traceability from financial consequence ba' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PenaltyClause .

ind:volumeCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Id' ;
    rdfs:comment 'Foreign key linking to contract.volume_commitment. Business justification: Some penalty assessments are triggered by volume commitment shortfalls (e.g., customer failed to meet minimum throughput guarantee). This FK links the assessment to the specific commitment that was br' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VolumeCommitment .

ind:adjustedAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Amount' ;
    rdfs:comment 'The revised financial amount after dispute resolution, reflecting any negotiated reductions or increases to the net amount.' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which the assessment was formally approved for issuance by the authorized manager.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessedMetricName rdf:type rdf:Property ;
    rdfs:label 'Assessed Metric Name' ;
    rdfs:comment 'The name of the performance metric or operational measure that was assessed (e.g., Vessel Turnaround Time, TEU Throughput, Berth Utilization, Gate Processing Time).' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessedUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Assessed Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the assessed value: TEU (Twenty-foot Equivalent Unit), FEU (Forty-foot Equivalent Unit), CBM (Cubic Meter), MT (Metric Ton), hours, days, percent, count, or moves. [ENUM-REF-CANDIDATE: TEU|FEU|CBM|MT|hours|days|percent|count|moves — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessedValue rdf:type rdf:Property ;
    rdfs:label 'Assessed Value' ;
    rdfs:comment 'The actual measured value of the metric or throughput that was assessed (e.g., 1250.5 TEU, 48.75 hours, 85.3 percent).' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The date on which the penalty or incentive assessment was formally raised and recorded in the system.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Externally visible unique business identifier for the penalty assessment, formatted as PA-YYYYNNNN.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Assessment Period End' ;
    rdfs:comment 'The end date of the billing or performance period to which this assessment applies.' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Assessment Period Start' ;
    rdfs:comment 'The start date of the billing or performance period to which this assessment applies.' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the penalty assessment: draft (under review), issued (formally communicated to participant), disputed (under dispute resolution), settled (dispute resolved), waived (cancelled by management), or paid (financially settled).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the financial assessment: penalty (contractual breach), incentive (performance bonus), PIL (Port Infrastructure Levy), liquidated_damages (pre-agreed compensation), demurrage (vessel delay charge), or detention (container overstay charge).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which the dispute was formally resolved, either through negotiation, arbitration, or management decision.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptionAmount rdf:type rdf:Property ;
    rdfs:label 'Exemption Amount' ;
    rdfs:comment 'The monetary value of the exemption or waiver applied, reducing the gross amount.' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Applied Flag' ;
    rdfs:comment 'Indicates whether a contractual exemption or waiver clause was applied to reduce or eliminate the assessment (True if exemption applied, False otherwise).' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalAmount rdf:type rdf:Property ;
    rdfs:label 'Final Amount' ;
    rdfs:comment 'The final confirmed amount payable or receivable, representing the settled value after all exemptions, disputes, and adjustments have been applied.' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The gross financial amount of the assessment before any exemptions, adjustments, or disputes are applied.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuedDate rdf:type rdf:Property ;
    rdfs:label 'Issued Date' ;
    rdfs:comment 'The date on which the assessment was formally issued to the participant, triggering the payment due date calculation.' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateApplied rdf:type rdf:Property ;
    rdfs:label 'Rate Applied' ;
    rdfs:comment 'The penalty or incentive rate applied per unit of variance or per occurrence, as defined in the contract (e.g., USD 50 per TEU shortfall, USD 100 per hour of delay).' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'The unit basis for the applied rate: per TEU, per FEU, per hour, per day, per occurrence, per metric ton, per move, or flat fee. [ENUM-REF-CANDIDATE: per_TEU|per_FEU|per_hour|per_day|per_occurrence|per_MT|per_move|flat_fee — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The contractual threshold or target value that was breached or achieved, triggering the assessment (e.g., minimum throughput commitment, maximum turnaround time).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggeringEventReference rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Reference' ;
    rdfs:comment 'Reference identifier to the specific operational event that triggered this assessment, such as an SLA (Service Level Agreement) breach incident number, vessel delay record, or throughput shortfall report.' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventType rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Type' ;
    rdfs:comment 'Classification of the event that triggered the assessment: SLA breach, volume shortfall, delay, throughput target miss, safety violation, environmental breach, or other contractual non-compliance. [ENUM-REF-CANDIDATE: sla_breach|volume_shortfall|delay|throughput_target|safety_violation|environmental_breach|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PenaltyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'The calculated variance between the assessed value and the threshold value (assessed minus threshold), indicating the magnitude of over-performance or under-performance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Assessment Frequency' ;
    rdfs:comment 'How often the penalty or incentive is calculated and assessed (e.g., per_occurrence for immediate assessment after each trigger event, monthly for aggregated monthly assessment, at_contract_end for final reconciliation).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Clause Reference Number' ;
    rdfs:comment 'The externally-known clause identifier or section number within the contract document (e.g., \'Section 7.3.2\', \'Clause P-04\', \'Annex B Item 5\').' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseStatus rdf:type rdf:Property ;
    rdfs:label 'Clause Status' ;
    rdfs:comment 'Current lifecycle state of the penalty or incentive clause: active (in force), suspended (temporarily not enforced), waived (permanently forgiven by mutual agreement), expired (no longer applicable).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseType rdf:type rdf:Property ;
    rdfs:label 'Clause Type' ;
    rdfs:comment 'Classification of the consequence clause: liquidated_damages (pre-agreed compensation for breach), performance_penalty (underperformance charge), shortfall_penalty (volume/commitment shortfall), delay_penalty (time-based penalty), incentive_bonus (reward for exceeding targets), rebate (volume-based discount).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Cumulative Trigger Flag' ;
    rdfs:comment 'Indicates whether the trigger condition is evaluated cumulatively over multiple measurement periods (True) or independently for each period (False). For example, True if three consecutive months of underperformance are required to trigger the penalty.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionProcess rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Process' ;
    rdfs:comment 'Description of the agreed process for resolving disputes related to the application or calculation of this penalty or incentive clause (e.g., \'Escalation to Port Director and Shipping Line VP Operations\', \'Third-party arbitration per ICC rules\', \'Joint review committee within 30 days\').' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'The date on which this penalty or incentive clause ceases to be enforceable. Aligns with contract expiry, renewal, or amendment date. Null for open-ended clauses.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gracePeriodUnit rdf:type rdf:Property ;
    rdfs:label 'Grace Period Unit' ;
    rdfs:comment 'Unit of measure for the grace period (e.g., \'days\', \'hours\', \'vessel_calls\', \'occurrences\'). Null if no grace period applies.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodValue rdf:type rdf:Property ;
    rdfs:label 'Grace Period Value' ;
    rdfs:comment 'The number of time units (days, hours, vessel calls) allowed before the penalty or incentive clause becomes enforceable after the trigger condition is first met. Provides a buffer for minor or transient deviations. Null if no grace period applies.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveMaximumCapAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Maximum Cap Amount' ;
    rdfs:comment 'The maximum total incentive or bonus amount that can be earned under this clause, regardless of the level of overperformance. Null if no cap applies.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveRateValue rdf:type rdf:Property ;
    rdfs:label 'Incentive Rate Value' ;
    rdfs:comment 'The numeric rate or amount used to calculate the incentive or bonus when the trigger condition is met. For per_unit method, this is the rate per excess unit; for percentage_of_contract_value, this is the percentage; for fixed_amount, this is the flat bonus amount.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'The time window or event basis over which performance is measured and the trigger condition is evaluated (e.g., per_vessel_call for individual vessel performance, monthly for aggregate monthly metrics, annually for volume commitments). [ENUM-REF-CANDIDATE: per_vessel_call|daily|weekly|monthly|quarterly|annually|contract_term — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyMaximumCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Maximum Cap Amount' ;
    rdfs:comment 'The maximum total penalty amount that can be assessed under this clause, regardless of the severity of underperformance. Protects against unlimited liability. Null if no cap applies.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyRateValue rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Value' ;
    rdfs:comment 'The numeric rate or amount used to calculate the penalty when the trigger condition is met. For per_unit method, this is the rate per unit; for percentage_of_contract_value, this is the percentage (e.g., 2.5 for 2.5%); for fixed_amount, this is the flat penalty amount.' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerComparisonOperator rdf:type rdf:Property ;
    rdfs:label 'Trigger Comparison Operator' ;
    rdfs:comment 'The logical operator used to evaluate the trigger condition (e.g., less_than for penalties when performance drops below threshold, greater_than for incentives when performance exceeds target).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Trigger Condition Description' ;
    rdfs:comment 'Detailed narrative of the business condition that activates this penalty or incentive (e.g., \'Crane productivity falls below 28 moves per hour for three consecutive vessel calls\', \'Annual TEU throughput exceeds committed volume by 10%\').' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerMetric rdf:type rdf:Property ;
    rdfs:label 'Trigger Metric' ;
    rdfs:comment 'The specific Key Performance Indicator (KPI) or measurement that is evaluated to determine if the trigger condition is met (e.g., \'crane_moves_per_hour\', \'annual_teu_throughput\', \'vessel_turnaround_time_hours\', \'berth_utilization_percent\').' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Unit' ;
    rdfs:comment 'Unit of measure for the trigger threshold (e.g., \'moves_per_hour\', \'TEU\', \'hours\', \'percent\', \'days\', \'vessel_calls\').' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Value' ;
    rdfs:comment 'The numeric threshold that, when crossed, activates the penalty or incentive clause (e.g., 28.0 for crane moves per hour, 500000 for annual TEU commitment).' ;
    rdfs:domain ind:PenaltyClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Date' ;
    rdfs:comment 'Date on which the waiver or suspension of this clause was formally approved. Populated only when clause_status is waived or suspended.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pilArrangementId rdf:type rdf:Property ;
    rdfs:label 'Pil Arrangement Id' ;
    rdfs:comment 'Unique identifier for the Port Infrastructure Levy arrangement record. Primary key.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrangementCode rdf:type rdf:Property ;
    rdfs:label 'Arrangement Code' ;
    rdfs:comment 'Business identifier for the PIL arrangement, typically formatted as PIL- followed by alphanumeric code for external reference and reporting.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementName rdf:type rdf:Property ;
    rdfs:label 'Arrangement Name' ;
    rdfs:comment 'Descriptive name of the PIL arrangement for business users, typically indicating the counterparty and levy type.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementStatus rdf:type rdf:Property ;
    rdfs:label 'Arrangement Status' ;
    rdfs:comment 'Current lifecycle status of the PIL arrangement. Draft indicates pending approval, active indicates in force, suspended indicates temporarily halted, expired indicates past end date, terminated indicates early cancellation, under_review indicates regulatory or compliance review in progress.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether detailed transaction-level audit trail must be maintained for PIL assessments under this arrangement. True indicates audit trail mandatory, False indicates summary reporting sufficient.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'The underlying metric or measure upon which the PIL is assessed. Cargo_value for ad-valorem levies, vessel tonnage measures for vessel-based levies, throughput measures for container-based levies, berth_hours for time-based levies, cargo_tonnage for weight-based levies. [ENUM-REF-CANDIDATE: cargo_value|vessel_grt|vessel_nrt|vessel_dwt|teu_throughput|feu_throughput|berth_hours|cargo_tonnage — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionResponsibility rdf:type rdf:Property ;
    rdfs:label 'Collection Responsibility' ;
    rdfs:comment 'Party responsible for collecting the PIL. Port_collects indicates the port authority directly invoices and collects, operator_remits indicates the terminal operator or concessionaire collects and remits to the port, third_party_collects indicates a customs broker or agent collects, self_assessed indicates the liable party self-reports and pays.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Agreed mechanism for resolving disputes related to PIL assessment, calculation, or payment under this arrangement.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationClause rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause' ;
    rdfs:comment 'Method by which the PIL rate may be adjusted over time. None indicates no automatic escalation, cpi_indexed indicates annual adjustment by consumer price index, fixed_annual indicates predetermined percentage increase, negotiated indicates periodic renegotiation, regulatory_review indicates adjustment subject to regulatory approval.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRate rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate' ;
    rdfs:comment 'Annual percentage rate of escalation for fixed_annual escalation clause. Nullable for other escalation types.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Exemption Percentage' ;
    rdfs:comment 'Percentage of PIL exempted or waived under this arrangement. 100.00 indicates full exemption, values less than 100 indicate partial exemption. Nullable when exemption_flag is False.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastEscalationDate rdf:type rdf:Property ;
    rdfs:label 'Last Escalation Date' ;
    rdfs:comment 'Date on which the PIL rate was last escalated or adjusted. Used to track escalation history and determine next escalation due date.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumLevyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Levy Amount' ;
    rdfs:comment 'Maximum PIL amount payable per assessment period or transaction, capping the levy for high-value or high-volume transactions. Nullable if no cap applies.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLevyAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Levy Amount' ;
    rdfs:comment 'Minimum PIL amount payable per assessment period or transaction, regardless of calculated amount. Ensures a floor levy for small transactions. Nullable if no minimum applies.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the PIL rate is denominated (e.g., USD, EUR, AUD).' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Method by which the PIL is calculated. Fixed indicates a flat fee per transaction or period, ad_valorem indicates percentage of cargo value, per_teu/per_feu indicates per container unit, per_grt/per_nrt/per_dwt indicates per vessel tonnage measure, tiered indicates variable rate based on volume thresholds. [ENUM-REF-CANDIDATE: fixed|ad_valorem|per_teu|per_feu|per_grt|per_nrt|per_dwt|tiered — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'Numeric value of the PIL rate. Interpretation depends on rate_type: for fixed, the flat amount; for ad_valorem, the percentage (e.g., 2.5 for 2.5%); for per-unit rates, the amount per unit.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryInstrument rdf:type rdf:Property ;
    rdfs:label 'Regulatory Instrument' ;
    rdfs:comment 'Legal or regulatory instrument under which the PIL is authorized and governed, such as Port Authority Act, Maritime Services Regulation, or specific statutory instrument number.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceDueDay rdf:type rdf:Property ;
    rdfs:label 'Remittance Due Day' ;
    rdfs:comment 'Day of the period (e.g., day of month for monthly remittance) by which PIL remittance must be completed. Nullable for per-transaction remittance.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remittanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Remittance Frequency' ;
    rdfs:comment 'Frequency at which collected PIL amounts must be remitted to the port authority or designated account. Per_transaction indicates immediate remittance upon collection. [ENUM-REF-CANDIDATE: daily|weekly|fortnightly|monthly|quarterly|annually|per_transaction — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCategory rdf:type rdf:Property ;
    rdfs:label 'Reporting Category' ;
    rdfs:comment 'Classification of the PIL for financial and regulatory reporting purposes. Aligns with statutory reporting requirements and revenue recognition standards.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Allocation Code' ;
    rdfs:comment 'General Ledger or financial system code to which collected PIL revenue is allocated for accounting and reporting purposes.' ;
    rdfs:domain ind:PilArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterdataVesselTypeId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Vessel Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.vessel_type. Business justification: Port tariffs are vessel-type-specific (grt_lower_bound, grt_upper_bound fields present). Vessel type determines applicable rate bands and is core to maritime tariff structures and port dues calculatio' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VesselType .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency at which charges under this rate schedule are invoiced to the customer.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount applied to the base rate value for this schedule entry. Null if no discount applies. Used for volume discounts or promotional pricing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause Flag' ;
    rdfs:comment 'Indicates whether this rate is subject to automatic escalation based on an index or formula. True if escalation applies, False otherwise.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationFrequency rdf:type rdf:Property ;
    rdfs:label 'Escalation Frequency' ;
    rdfs:comment 'Frequency at which the rate escalation is reviewed and applied. Null or none if no escalation applies.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationIndex rdf:type rdf:Property ;
    rdfs:label 'Escalation Index' ;
    rdfs:comment 'The index or benchmark used for automatic rate escalation (e.g., Consumer Price Index, fuel price index, exchange rate). Null or none if no escalation applies.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Percentage' ;
    rdfs:comment 'Fixed percentage by which the rate increases at each escalation event. Null if escalation is index-based rather than fixed percentage.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gracePeriodHours rdf:type rdf:Property ;
    rdfs:label 'Grace Period Hours' ;
    rdfs:comment 'Additional grace period in hours beyond free time before charges begin. Null if no grace period applies.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grtLowerBound rdf:type rdf:Property ;
    rdfs:label 'Grt Lower Bound' ;
    rdfs:comment 'Minimum Gross Registered Tonnage for which this rate applies. Used in conjunction with GRT upper bound to define vessel size bands for rate calculation. Null if rate is not GRT-based.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grtUpperBound rdf:type rdf:Property ;
    rdfs:label 'Grt Upper Bound' ;
    rdfs:comment 'Maximum Gross Registered Tonnage for which this rate applies. Null indicates no upper limit for the band.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatSurchargeFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Surcharge Flag' ;
    rdfs:comment 'Indicates whether an additional surcharge applies for hazardous materials handling under this rate. True if surcharge applies, False otherwise.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumCharge rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge' ;
    rdfs:comment 'Maximum charge amount that caps the calculated rate. Null if no ceiling applies.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'Minimum charge amount that applies regardless of calculated rate. Ensures a floor revenue for the service. Null if no minimum applies.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakSeasonSurcharge rdf:type rdf:Property ;
    rdfs:label 'Peak Season Surcharge' ;
    rdfs:comment 'Additional surcharge amount applied during peak season periods. Null if no peak season surcharge applies.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pilCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Pil Calculation Basis' ;
    rdfs:comment 'Specific calculation method for Port Infrastructure Levy rates. Applicable only when rate_type is pil_levy. Null or not_applicable for non-PIL rates.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilCollectionResponsibility rdf:type rdf:Property ;
    rdfs:label 'Pil Collection Responsibility' ;
    rdfs:comment 'Entity responsible for collecting the PIL from the end customer. Applicable only for PIL-type rates. Null or not_applicable for non-PIL rates.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Pil Exemption Flag' ;
    rdfs:comment 'Indicates whether this rate schedule entry includes an exemption from PIL charges. True if exempt, False otherwise. Applicable for PIL-related rate schedules.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pilRemittanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Pil Remittance Frequency' ;
    rdfs:comment 'Frequency at which collected PIL amounts must be remitted to the port authority or regulatory body. Applicable only for PIL-type rates.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the rate schedule entry. Indicates whether the rate is currently in use, pending approval, or no longer applicable.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferTemperatureRange rdf:type rdf:Property ;
    rdfs:label 'Reefer Temperature Range' ;
    rdfs:comment 'Temperature range specification for refrigerated container rates (e.g., -25C to -18C, 2C to 8C). Applicable only for reefer_surcharge rate types. Null for non-reefer rates.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this rate is subject to seasonal variation or is a seasonal rate. True if seasonal, False otherwise.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Applicable Flag' ;
    rdfs:comment 'Indicates whether tax (VAT, GST, sales tax) applies to this rate. True if taxable, False if tax-exempt.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'Percentage rate of tax applied to this rate schedule entry. Null if tax_applicable_flag is False or if tax rate is defined elsewhere.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThreshold rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold' ;
    rdfs:comment 'Minimum volume or quantity required to qualify for this rate or discount. Null if no threshold applies. Unit of measure is defined by calculation_basis.' ;
    rdfs:domain ind:RateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingBasis rdf:type rdf:Property ;
    rdfs:label 'Billing Basis' ;
    rdfs:comment 'Unit basis on which charges for this service scope are calculated and invoiced. Defines the pricing metric for the service.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewCompetencyRequired rdf:type rdf:Property ;
    rdfs:label 'Crew Competency Required' ;
    rdfs:comment 'Minimum crew competency level or certification required to perform this service scope, ensuring compliance with safety and operational standards.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Included' ;
    rdfs:comment 'Indicates whether customs clearance facilitation and documentation services are included in this service scope. True if included, False otherwise.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Required' ;
    rdfs:comment 'Specific environmental standards, certifications, or compliance requirements that must be met when delivering this service scope, such as ISO 14001 or MARPOL compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Narrative description of specific activities, conditions, or scenarios explicitly excluded from this service scope. Defines service boundaries and limitations.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgHandlingAuthorized rdf:type rdf:Property ;
    rdfs:label 'Imdg Handling Authorized' ;
    rdfs:comment 'Indicates whether this service scope includes authorization to handle dangerous goods under IMDG Code. True if authorized, False otherwise.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAmendedDate rdf:type rdf:Property ;
    rdfs:label 'Last Amended Date' ;
    rdfs:comment 'Date on which this service scope line item was most recently amended or modified. Null if no amendments have been made since original creation.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceBonusApplicable rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Applicable' ;
    rdfs:comment 'Indicates whether performance bonuses or incentive payments apply if SLA targets for this service scope are exceeded. True if bonuses apply, False otherwise.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performancePenaltyApplicable rdf:type rdf:Property ;
    rdfs:label 'Performance Penalty Applicable' ;
    rdfs:comment 'Indicates whether performance penalties or liquidated damages apply if SLA targets for this service scope are not met. True if penalties apply, False otherwise.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateCardReference rdf:type rdf:Property ;
    rdfs:label 'Rate Card Reference' ;
    rdfs:comment 'Reference code or identifier linking this service scope to the applicable rate card or pricing schedule in the tariff management system.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferServiceIncluded rdf:type rdf:Property ;
    rdfs:label 'Reefer Service Included' ;
    rdfs:comment 'Indicates whether refrigerated container monitoring and power supply services are included in this service scope. True if included, False otherwise.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed narrative description of the specific service activities, deliverables, and operational parameters covered under this service scope line item.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLineNumber rdf:type rdf:Property ;
    rdfs:label 'Service Line Number' ;
    rdfs:comment 'Sequential line number identifying the position of this service scope item within the parent contract. Used for ordering and reference.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceWindow rdf:type rdf:Property ;
    rdfs:label 'Service Window' ;
    rdfs:comment 'Operational availability window during which the service is committed to be provided under this scope. Defines temporal service boundaries.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Turnaround Hours' ;
    rdfs:comment 'Contracted target turnaround time in hours for completing the service from initiation to completion. Null if not applicable to the service type.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Additional terms, conditions, or operational requirements specific to this service scope line item that modify or supplement standard service delivery terms.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Throughput Guarantee Amount' ;
    rdfs:comment 'Minimum throughput quantity guaranteed by the port for this service scope, expressed in the applicable unit of measure. Null if no guarantee applies.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Throughput Guarantee Flag' ;
    rdfs:comment 'Indicates whether the port has committed to a minimum throughput guarantee for this service scope. True if guarantee applies, False otherwise.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:throughputGuaranteeUnit rdf:type rdf:Property ;
    rdfs:label 'Throughput Guarantee Unit' ;
    rdfs:comment 'Unit of measure for the throughput guarantee amount. Aligns with the service type and volume commitment metrics.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentDwt rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Dwt' ;
    rdfs:comment 'Contracted minimum or target cargo volume commitment expressed in deadweight tonnage for bulk or general cargo services. Null if not applicable.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentTeu rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Teu' ;
    rdfs:comment 'Contracted minimum or target volume commitment expressed in TEU for container handling services. Null if not applicable to the service type.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentVesselCalls rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Vessel Calls' ;
    rdfs:comment 'Contracted minimum or target number of vessel calls per period for marine services such as pilotage or towage. Null if not applicable.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousBreachSlaBreachId rdf:type rdf:Property ;
    rdfs:label 'Previous Breach Sla Breach Id' ;
    rdfs:comment 'Reference to the prior breach event if this is a recurrence, enabling trend analysis and pattern detection in SLA performance.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaBreach .

ind:slaMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Sla Measurement Id' ;
    rdfs:comment 'Reference to the specific SLA measurement event that triggered this breach, linking to the actual performance data that fell outside contracted thresholds.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaMeasurement .

ind:terminalBerthAllocationId rdf:type rdf:Property ;
    rdfs:label 'Terminal Berth Allocation Id' ;
    rdfs:comment 'Foreign key linking to terminal.berth_allocation. Business justification: When SLA breaches occur (vessel turnaround exceeded, productivity targets missed), linking to the specific berth allocation enables root cause analysis, identifies responsible operational events, and ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalBerthAllocation .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual measured performance value that triggered the breach, enabling calculation of deviation magnitude and penalty amounts.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachDate rdf:type rdf:Property ;
    rdfs:label 'Breach Date' ;
    rdfs:comment 'The calendar date on which the SLA breach was confirmed to have occurred, based on the measurement period end date.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachDurationHours rdf:type rdf:Property ;
    rdfs:label 'Breach Duration Hours' ;
    rdfs:comment 'The total duration in hours that the service performance remained outside the contracted SLA threshold, calculated from breach start to resolution or measurement period end.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Date' ;
    rdfs:comment 'The date on which the counterparty was formally notified of the SLA breach, as required by contract terms and for compliance with notification timeframes.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachNumber rdf:type rdf:Property ;
    rdfs:label 'Breach Number' ;
    rdfs:comment 'Externally-visible unique reference number assigned to this breach event for tracking, communication, and dispute resolution purposes.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Classification of the breach impact based on the magnitude of deviation from the SLA threshold and business criticality. Minor breaches may trigger warnings, major breaches require remediation plans, and critical breaches may invoke penalty clauses or contract review.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachStatus rdf:type rdf:Property ;
    rdfs:label 'Breach Status' ;
    rdfs:comment 'Current lifecycle status of the breach record. Open indicates newly detected breach; under_review indicates investigation in progress; remediated indicates corrective actions completed; disputed indicates counterparty challenge; closed indicates final resolution and record archival.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Timestamp' ;
    rdfs:comment 'The precise date and time when the SLA breach was detected and recorded in the system, supporting audit trail and notification workflows.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:communicationLog rdf:type rdf:Property ;
    rdfs:label 'Communication Log' ;
    rdfs:comment 'Chronological record of all formal communications with the counterparty regarding this breach, including notifications, acknowledgements, remediation updates, and dispute correspondence.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Counterparty Acknowledgement Date' ;
    rdfs:comment 'The date on which the counterparty formally acknowledged receipt and acceptance of the breach notification, establishing the start of any contractual remedy or dispute periods.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Deviation Percentage' ;
    rdfs:comment 'The percentage deviation from the contracted SLA threshold, calculated as (deviation_value / threshold_value) * 100, used for severity classification and penalty calculation.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationValue rdf:type rdf:Property ;
    rdfs:label 'Deviation Value' ;
    rdfs:comment 'The calculated difference between the actual performance value and the contracted threshold, representing the magnitude of the breach. Positive or negative depending on whether the metric is a minimum or maximum threshold.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeOutcome rdf:type rdf:Property ;
    rdfs:label 'Dispute Outcome' ;
    rdfs:comment 'Final determination of the dispute resolution process. Upheld confirms the original breach determination; overturned nullifies the breach; partially_upheld adjusts severity or penalty; withdrawn indicates counterparty retraction.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Flag' ;
    rdfs:comment 'Boolean indicator of whether the counterparty has formally disputed the breach determination, severity classification, or penalty calculation, triggering dispute resolution workflows.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Qualitative or quantitative assessment of the business impact of the breach on port operations, counterparty operations, and broader supply chain, supporting severity classification and remediation prioritization.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'The unit of measure for the threshold and actual values (e.g., hours, minutes, TEU, percentage, moves_per_hour), copied from the SLA definition for clarity in breach reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable Flag' ;
    rdfs:comment 'Boolean indicator of whether contractual penalty clauses apply to this breach based on severity, responsible party determination, and contract terms.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationDeadline rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline' ;
    rdfs:comment 'The target date by which remediation actions must be completed, as agreed with the counterparty or mandated by contract terms.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Detailed description of the corrective actions, process improvements, or operational changes planned or implemented to prevent recurrence of similar breaches.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative explanation of the specific circumstances, events, or failures that led to the SLA breach, supporting dispute resolution and process improvement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Business Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: SLA ownership assignment requires employee reference for accountability in SLA performance monitoring and breach escalation processes.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:slaRateCardId rdf:type rdf:Property ;
    rdfs:label 'Sla Rate Card Id' ;
    rdfs:comment 'Foreign key linking to tariff.sla_rate_card. Business justification: SLA definitions in agreements link to tariff-published SLA rate cards defining performance-based pricing. SLA rate cards specify premiums/penalties for performance levels. Critical for performance-bas' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaRateCard .

ind:supersededBySlaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Sla Definition Id' ;
    rdfs:comment 'Reference to the SLA definition that replaces this one when a new version is created. Null if this is the current version.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:criticalThreshold rdf:type rdf:Property ;
    rdfs:label 'Critical Threshold' ;
    rdfs:comment 'The threshold value at which performance is considered critically below acceptable levels, triggering escalation and potential penalty application.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'The customer segment or tier to which this SLA definition applies (e.g., \'Premium Shipping Lines\', \'Standard Carriers\', \'Occasional Users\'). Allows differentiated service levels by customer importance. [ENUM-REF-CANDIDATE: premium|standard|occasional|strategic_partner|spot_customer|government|military — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether SLA breaches require formal escalation to management or customer relationship teams. True if escalation procedures are defined, False otherwise.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'Frequency at which the SLA metric is measured and evaluated: real_time (continuous monitoring), hourly, daily, weekly, monthly, per_transaction (each gate/cargo transaction), per_vessel_call (each vessel visit). [ENUM-REF-CANDIDATE: real_time|hourly|daily|weekly|monthly|per_transaction|per_vessel_call — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Detailed description of how the SLA metric is calculated, including data sources, calculation formula, exclusions, and measurement boundaries. Ensures consistent interpretation between port and customer.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'Method used to calculate penalties for SLA breaches: fixed_amount (flat fee), percentage_of_charge (percentage of service charge), tiered (escalating based on severity), per_unit_deviation (penalty per unit below target), service_credit (future service discount).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which SLA performance reports are generated and delivered to stakeholders: daily, weekly, monthly, quarterly, on_demand (ad-hoc requests).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCategory rdf:type rdf:Property ;
    rdfs:label 'Sla Category' ;
    rdfs:comment 'Classification of the SLA by operational domain: vessel_turnaround (time from arrival to departure), crane_productivity (container moves per hour), gate_processing_time (truck processing duration), berth_availability (berth readiness percentage), reefer_uptime (refrigerated container power availability), documentation_turnaround (customs and trade document processing time).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Unique business identifier code for the SLA definition, used for external reference and system integration.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Description' ;
    rdfs:comment 'Detailed textual description of the SLA definition, including business context, rationale, and any special conditions or exclusions.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition: draft (being developed), active (in use), suspended (temporarily inactive), retired (no longer applicable), under_review (being evaluated for changes).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable name of the SLA definition describing the service commitment.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Type of service level commitment: performance (operational efficiency), availability (uptime/readiness), response_time (speed of service), throughput (volume capacity), quality (accuracy/completeness), compliance (regulatory adherence).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricName rdf:type rdf:Property ;
    rdfs:label 'Target Metric Name' ;
    rdfs:comment 'Name of the specific performance metric being measured for this SLA (e.g., \'Vessel Turnaround Time\', \'Quay Crane (QC) Moves Per Hour\', \'Gate Transaction Time\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThreshold rdf:type rdf:Property ;
    rdfs:label 'Target Threshold' ;
    rdfs:comment 'The committed target value that must be achieved to meet the SLA. Represents the contractual service level commitment.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'The comparison operator used to evaluate performance against thresholds: less_than (performance must be below target, e.g., turnaround time), greater_than (performance must exceed target, e.g., crane productivity), equal (exact match), between (range-based).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningThreshold rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold' ;
    rdfs:comment 'The threshold value at which performance triggers a warning alert, indicating risk of SLA breach. Typically set between target and critical thresholds.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedInInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Included In Invoice Id' ;
    rdfs:comment 'Reference to the invoice that includes penalties or incentives calculated from this measurement. Null if not yet invoiced.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:measurementApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Measurement Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: SLA measurement validation requires employee sign-off for data quality assurance and dispute resolution in performance reporting and penalty assessment.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustedActualValue rdf:type rdf:Property ;
    rdfs:label 'Adjusted Actual Value' ;
    rdfs:comment 'Revised actual value after dispute resolution or manual adjustment. Null if no adjustment was made. Used for recalculating penalties and performance status.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriod rdf:type rdf:Property ;
    rdfs:label 'Billing Period' ;
    rdfs:comment 'The billing period (YYYY-MM format) to which this measurement and any associated penalties or incentives will be applied. Aligns with invoice generation cycles.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Timestamp' ;
    rdfs:comment 'Timestamp when the breach notification was sent to contract stakeholders. Null if no notification was triggered.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachNotificationTriggered rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Triggered' ;
    rdfs:comment 'Indicates whether an automated breach notification was triggered and sent to stakeholders when this measurement recorded an SLA breach.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'Calculated financial incentive or bonus amount due to over-performance or volume surplus, as per contractual incentive clauses. Null if no incentive applies.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Approved Timestamp' ;
    rdfs:comment 'Timestamp when the measurement was officially approved and locked for billing. Marks the end of the measurement lifecycle.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The business date on which the measurement was taken or the performance event occurred. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementNotes rdf:type rdf:Property ;
    rdfs:label 'Measurement Notes' ;
    rdfs:comment 'Free-text field for capturing contextual information, exceptions, or explanations related to the measurement (e.g., force majeure events, system outages, disputed measurements).' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'End date of the measurement period window for aggregated metrics.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'Start date of the measurement period window for aggregated metrics (e.g., monthly or quarterly measurements).' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement Source System' ;
    rdfs:comment 'The operational system from which the measurement data was extracted. Ensures traceability and auditability of performance data. [ENUM-REF-CANDIDATE: NAVIS_N4|VTMS|TOPS|TOS|PCS|GATE_SYSTEM|MANUAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Lifecycle status of the measurement record. Tracks whether the measurement is preliminary, confirmed by both parties, under dispute, or finalized for billing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Precise timestamp when the measurement data was captured from the source system. Distinct from measurement_date which represents the business date.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for penalty and incentive amounts.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Categorical assessment of whether the SLA or volume commitment was achieved. Met indicates compliance, breached indicates failure, at_risk indicates near-miss, shortfall/surplus apply to volume commitments.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The contractually committed or target performance value that was expected to be achieved. Baseline for variance calculation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAbsolute rdf:type rdf:Property ;
    rdfs:label 'Variance Absolute' ;
    rdfs:comment 'Absolute difference between actual and target values (actual minus target). Positive indicates over-performance, negative indicates under-performance.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Percentage variance between actual and target values, calculated as (actual - target) / target * 100. Enables normalized performance comparison across different metrics.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeShortfall rdf:type rdf:Property ;
    rdfs:label 'Volume Shortfall' ;
    rdfs:comment 'For volume commitment measurements, the amount by which actual throughput fell short of the committed volume. Null if target was met or exceeded.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeSurplus rdf:type rdf:Property ;
    rdfs:label 'Volume Surplus' ;
    rdfs:comment 'For volume commitment measurements, the amount by which actual throughput exceeded the committed volume. May trigger incentive payments per contract terms.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualVolumeToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Volume To Date' ;
    rdfs:comment 'Cumulative actual volume or throughput achieved against this commitment as of the last measurement date. Used for performance tracking and shortfall calculation.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether this volume commitment automatically renews for subsequent periods upon expiry (True) or requires explicit renegotiation (False).' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentPeriodType rdf:type rdf:Property ;
    rdfs:label 'Commitment Period Type' ;
    rdfs:comment 'Frequency or duration basis for measuring the volume commitment (annual, quarterly, monthly, or custom period).' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this volume commitment, used in commercial correspondence and billing reconciliation.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle state of the volume commitment. Indicates whether the commitment is actively enforced, temporarily waived, under dispute, suspended, expired, or terminated.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Classification of the volume commitment metric. Defines what unit of throughput or activity the commitment is measured in (TEU, FEU, vessel calls, DWT, cargo tonnes, or revenue).' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentUnit rdf:type rdf:Property ;
    rdfs:label 'Commitment Unit' ;
    rdfs:comment 'Unit of measure for the committed volume. Aligns with commitment_type and defines how the committed_volume is quantified (TEU, FEU, vessel calls, DWT, tonnes, CBM, or revenue in USD). [ENUM-REF-CANDIDATE: TEU|FEU|vessel_calls|DWT|tonnes|CBM|revenue_usd — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Volume' ;
    rdfs:comment 'The minimum volume or throughput quantity that the stakeholder has committed to deliver or utilize during the commitment period. Measured in the unit specified by commitment_unit.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessVolume rdf:type rdf:Property ;
    rdfs:label 'Excess Volume' ;
    rdfs:comment 'The amount by which actual_volume_to_date exceeds committed_volume. Used to calculate incentive payments or rebates. Nullable if commitment is not exceeded.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveAmountEarned rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount Earned' ;
    rdfs:comment 'The total monetary incentive or rebate earned for exceeding the commitment in the current or most recent commitment period. Calculated based on incentive_type and incentive_rate. Business-confidential commercial term.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Incentive Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the incentive amount (e.g., USD, EUR, SGD).' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveRate rdf:type rdf:Property ;
    rdfs:label 'Incentive Rate' ;
    rdfs:comment 'The rate or amount applied to calculate the incentive for exceeding the commitment. Interpretation depends on incentive_type (e.g., USD per TEU, percentage, or fixed USD amount). Business-confidential commercial term.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Classification of the incentive or rebate structure applied when the commitment is exceeded. Defines whether the incentive is a per-unit rebate, percentage discount, fixed bonus, tiered rebate, or none.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Last Measurement Date' ;
    rdfs:comment 'The date on which the actual_volume_to_date was last calculated or updated. Used for performance tracking and reporting.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementBasis rdf:type rdf:Property ;
    rdfs:label 'Measurement Basis' ;
    rdfs:comment 'Defines the operational metric or data source used to measure performance against the commitment (e.g., actual throughput, billed throughput, manifested cargo, vessel arrivals, or gross revenue).' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmountAssessed rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Assessed' ;
    rdfs:comment 'The total monetary penalty assessed for shortfall in the current or most recent commitment period. Calculated based on penalty_type and penalty_rate. Business-confidential commercial term.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyRate rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate' ;
    rdfs:comment 'The rate or amount applied to calculate the penalty for shortfall. Interpretation depends on penalty_type (e.g., USD per TEU, percentage, or fixed USD amount). Business-confidential commercial term.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'Classification of the penalty structure applied when the commitment is not met. Defines whether the penalty is calculated per unit of shortfall, as a percentage, a fixed amount, tiered based on shortfall magnitude, or none.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days prior to effective_to_date that either party must provide notice if they wish to terminate or renegotiate the commitment. Nullable if auto-renewal is not applicable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortfallVolume rdf:type rdf:Property ;
    rdfs:label 'Shortfall Volume' ;
    rdfs:comment 'The difference between committed_volume and actual_volume_to_date when actual performance falls below the commitment. Nullable if commitment is met or exceeded.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accreditationId rdf:type rdf:Property ;
    rdfs:label 'Accreditation Id' ;
    rdfs:comment 'Unique surrogate identifier for each accreditation, certification, permit, or official document record held by a port community participant or their personnel/vehicle. Primary key for the accreditation data product.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Accreditation .

ind:accreditationCategory rdf:type rdf:Property ;
    rdfs:label 'Accreditation Category' ;
    rdfs:comment 'High-level category grouping for the accreditation. Security covers ISPS and access control documents. Trade Compliance covers customs, freight forwarder, and broker licences. Operational covers stevedoring, dangerous goods, and vessel operator certifications. Insurance covers P&I and liability certificates. Environmental covers ISO 14001 and MARPOL compliance certificates. Health and Safety covers OHS and ISO 45001 certifications.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current lifecycle status of the accreditation or permit. Active indicates the document is valid and in force. Expired indicates the document has passed its expiry date without renewal. Suspended indicates temporary withdrawal of privileges pending investigation or compliance action. Revoked indicates permanent cancellation by the issuing authority. Pending indicates the application has been submitted and is awaiting approval. Cancelled indicates the holder voluntarily withdrew the application.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationType rdf:type rdf:Property ;
    rdfs:label 'Accreditation Type' ;
    rdfs:comment 'Classification of the accreditation or document type. Covers entity-level accreditations (e.g., ISPS facility security certificate, customs broker licence, freight forwarder registration, dangerous goods handling certification, stevedoring company accreditation), official documents (trade licence, P&I insurance certificate, vessel operator certificate), and individual/vehicle-level permits (port access permit, ISPS security zone authorisation, biometric access credential, contractor access pass). [ENUM-REF-CANDIDATE: isps_facility_certificate|customs_broker_licence|freight_forwarder_registration|dangerous_goods_certification|stevedoring_accreditation|trade_licence|pi_insurance_certificate|vessel_operator_certificate|port_access_permit|security_zone_authorisation|biometric_credential|contractor_access_pass — promote to reference product]' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Application Reference Number' ;
    rdfs:comment 'The internal or external application reference number assigned when the accreditation application was lodged with the issuing authority or the port. Used to track the application through the approval workflow and to correspond with the issuing authority during the renewal or initial application process.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricReference rdf:type rdf:Property ;
    rdfs:label 'Biometric Reference' ;
    rdfs:comment 'Tokenised reference identifier linking this access credential to the holder\'s biometric record stored in the port\'s biometric access control system. This is a non-reversible token, not raw biometric data. Populated only for biometric-linked access credentials. Classified as restricted PII biometric data.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Coverage Scope Description' ;
    rdfs:comment 'Free-text description of the specific operational scope, geographic coverage, or service categories covered by this accreditation (e.g., \'Authorised for FCL and LCL customs clearance at Port of Melbourne\', \'Stevedoring operations limited to container terminal berths 1-6\'). Provides context beyond the accreditation type classification.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmRecordReference rdf:type rdf:Property ;
    rdfs:label 'Crm Record Reference' ;
    rdfs:comment 'The record identifier from Microsoft Dynamics 365 CRM corresponding to this accreditation. Enables bidirectional synchronisation between the accreditation data product and the CRM system for customer-facing compliance status visibility and service request management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the insurance coverage amount (e.g., USD, EUR, AUD). Populated only when insurance_coverage_amount is present.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Boolean flag indicating whether this accreditation is a mandatory regulatory or port bylaw requirement for the participant to conduct operations. True indicates the accreditation is legally or contractually required. False indicates it is voluntary or supplementary. Used in compliance gating logic to determine whether a missing or expired accreditation blocks operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevoked rdf:type rdf:Property ;
    rdfs:label 'Is Revoked' ;
    rdfs:comment 'Boolean flag indicating whether this accreditation has been formally revoked by the issuing authority or the port. True indicates the accreditation is revoked and must not be used for compliance gating. Provides a fast-path check for access control systems independent of the full status field.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityCountry rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the jurisdiction under which the accreditation was issued. Critical for cross-border trade compliance, mutual recognition agreements, and Port State Control verification.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'The most recent date on which the accreditation was verified against the issuing authority\'s records or through a formal audit process. Used to determine whether re-verification is required and to support Port State Control inspection readiness.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedComplianceRequirement rdf:type rdf:Property ;
    rdfs:label 'Linked Compliance Requirement' ;
    rdfs:comment 'Reference code or description of the specific regulatory or contractual compliance requirement that mandates this accreditation (e.g., \'ISPS Code Section 2.1.4\', \'Customs Act Section 183\', \'Port Bylaws Clause 12.3\'). Links the accreditation to the governing regulatory framework for audit readiness.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcsDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Pcs Document Reference' ;
    rdfs:comment 'The document identifier assigned by the Port Community System (PCS) to this accreditation record. Enables direct cross-reference between the accreditation data product and the PCS for customs integration, cargo manifest compliance gating, and stakeholder messaging workflows.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitHolderIdNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Holder Id Number' ;
    rdfs:comment 'Government-issued identity document number (passport, national ID, seafarer\'s identity document) of the individual permit holder. Populated only when scope_level is \'individual\'. Used for identity verification at port access control points and ISPS security zone entry. Classified as restricted PII.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitHolderName rdf:type rdf:Property ;
    rdfs:label 'Permit Holder Name' ;
    rdfs:comment 'Full legal name of the individual person (personnel, contractor, driver) who holds this permit or access credential when scope_level is \'individual\'. Null for entity-level or vehicle-level accreditations. Classified as restricted PII as it directly identifies a natural person.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Pi Insurance Policy Number' ;
    rdfs:comment 'The Protection and Indemnity (P&I) Club insurance policy number associated with this insurance certificate accreditation. Populated only when accreditation_type is \'pi_insurance_certificate\'. P&I cover is a mandatory requirement for vessel operators and stevedoring companies operating within the port. Classified as confidential business data.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which the renewal application must be submitted to the issuing authority to avoid a lapse in accreditation. Typically calculated as a fixed lead-time before the expiry_date (e.g., 30 or 60 days prior). Drives automated renewal reminder workflows and compliance monitoring dashboards.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Tracks the current state of the renewal process for this accreditation. Not Due indicates the document is current and renewal is not yet required. Renewal Initiated indicates internal renewal preparation has begun. Renewal Submitted indicates the renewal application has been lodged with the issuing authority. Renewal Approved indicates the renewed document has been received. Renewal Overdue indicates the document has expired and renewal has not been completed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagNumber rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Number' ;
    rdfs:comment 'The Radio Frequency Identification (RFID) tag number embedded in the physical access card or vehicle transponder associated with this accreditation. Used for automated gate access control and security zone entry tracking in NAVIS N4 gate operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeLevel rdf:type rdf:Property ;
    rdfs:label 'Scope Level' ;
    rdfs:comment 'Indicates whether this accreditation applies at the entity (organisation/company) level, individual (person/personnel) level, or vehicle level. Drives compliance gating logic in PCS and VTMS workflows and determines which permit holder reference fields are populated.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date on which the accreditation was suspended by the issuing authority or the port. Null when the accreditation has not been suspended. Used in compliance investigations and audit trails to track the duration of suspension periods.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Free-text description of the reason for suspension of the accreditation, as recorded by the suspending authority or port compliance officer. Null when not suspended. Required for ISPS Code enforcement documentation and Port State Control audit readiness.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Classification of the vehicle for which the access permit is issued. Populated only when scope_level is \'vehicle\'. Determines applicable port zones, weight restrictions, and operational areas within the terminal. [ENUM-REF-CANDIDATE: truck|trailer|forklift|reach_stacker|agv|private_vehicle|motorcycle|other — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationLogId rdf:type rdf:Property ;
    rdfs:label 'Communication Log Id' ;
    rdfs:comment 'Unique surrogate identifier for each communication log record in the port community system. Primary key for the communication_log data product.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCommunicationCommunicationLogId rdf:type rdf:Property ;
    rdfs:label 'Parent Communication Communication Log Id' ;
    rdfs:comment 'Self-referencing identifier linking this communication to a parent communication record, enabling threading of reply chains and follow-up correspondence. Null for original (non-reply) communications.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunicationLog .

ind:relatedIncidentOhsIncidentId rdf:type rdf:Property ;
    rdfs:label 'Related Incident Ohs Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.ohs_incident. Business justification: Communications with participants about safety incidents (incident notification letters, investigation updates, corrective action requests) require formal linkage for regulatory compliance, audit trail' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OhsIncident .

ind:senderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sender Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Audit trail for port-initiated communications. Required for dispute resolution, regulatory compliance reporting, and employee performance tracking. No denormalized column exists to remove.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceRequestId rdf:type rdf:Property ;
    rdfs:label 'Service Request Id' ;
    rdfs:comment 'Reference to the service request or CRM case linked to this communication. Populated for service alerts, complaint responses, and operational service correspondence managed in Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRequest .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of documents or files attached to this communication. Supports audit completeness checks and document management workflows. Zero for communications with no attachments.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyReference rdf:type rdf:Property ;
    rdfs:label 'Body Reference' ;
    rdfs:comment 'Reference pointer (document store path, object key, or external document ID) to the full body content of the communication. The actual message body is stored externally (e.g., document management system or object storage) to avoid large text in the lakehouse silver layer.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationStatus rdf:type rdf:Property ;
    rdfs:label 'Communication Status' ;
    rdfs:comment 'Current lifecycle state of the communication record. Tracks progression from draft through sent, delivered, failed, acknowledged, or rejected. Supports SLA monitoring and dispute resolution.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationType rdf:type rdf:Property ;
    rdfs:label 'Communication Type' ;
    rdfs:comment 'Classification of the communication by its business purpose. Covers vessel call notifications, ETA/ETB/ETD advisories, documentation requests, compliance notices, billing notifications, service alerts, regulatory correspondence, and ISPS security notices. [ENUM-REF-CANDIDATE: vessel_call_notification|eta_etb_etd_advisory|documentation_request|compliance_notice|billing_notification|service_alert|regulatory_correspondence|security_notice — promote to reference product]' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the specific contact person at the port community participant organisation who is the addressee or originator of this communication. Business-confidential as it identifies a named individual within a commercial counterparty.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmActivityReference rdf:type rdf:Property ;
    rdfs:label 'Crm Activity Reference' ;
    rdfs:comment 'The activity or interaction record identifier from Microsoft Dynamics 365 CRM corresponding to this communication. Enables bidirectional traceability between the lakehouse silver layer and the CRM system of record for customer-facing communications.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFailureReason rdf:type rdf:Property ;
    rdfs:label 'Delivery Failure Reason' ;
    rdfs:comment 'Descriptive reason for delivery failure when delivery_status is \'failed\', \'bounced\', or \'undeliverable\'. Captures error codes or descriptions from the transmission channel (e.g., invalid email address, EDI partner not reachable, SMS gateway error). Null when delivery is successful.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Technical delivery outcome of the communication transmission. Distinct from communication_status (which tracks the business lifecycle), delivery_status reflects the channel-level transmission result (e.g., email bounce, EDI acknowledgement failure, SMS undeliverable).' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the communication was sent by the port to a port community participant (outbound) or received by the port from a participant (inbound). Critical for audit trail and regulatory compliance reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediInterchangeReference rdf:type rdf:Property ;
    rdfs:label 'Edi Interchange Reference' ;
    rdfs:comment 'The unique interchange control reference number from the EDI transmission envelope (UNB segment in UN/EDIFACT). Used to correlate EDI messages with their functional acknowledgements (CONTRL) and for EDI error resolution. Null for non-EDI channels.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Indicates whether this communication has been escalated due to non-response, SLA breach, or compliance risk. Supports dispute resolution workflows and management reporting on overdue regulatory correspondence.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Is Acknowledged' ;
    rdfs:comment 'Indicates whether the recipient has formally acknowledged receipt of this communication. True when acknowledgement has been received; False when pending. Supports ISPS compliance and SLA reporting.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatory rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory' ;
    rdfs:comment 'Indicates whether this communication is classified as regulatory correspondence subject to mandatory retention and audit requirements. True for ISPS security notices, Port State Control (PSC) correspondence, customs compliance notices, and MARPOL/SOLAS regulatory communications.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isResponseRequired rdf:type rdf:Property ;
    rdfs:label 'Is Response Required' ;
    rdfs:comment 'Indicates whether this communication requires a formal response from the recipient. True for documentation requests, compliance notices, and regulatory correspondence. False for informational advisories and one-way notifications.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsClassification rdf:type rdf:Property ;
    rdfs:label 'Isps Classification' ;
    rdfs:comment 'ISPS Code security classification level applicable to this communication. Security Level 1 is normal operations; Level 2 is heightened security; Level 3 is exceptional threat. Non-ISPS for communications not subject to ISPS requirements. Mandatory for ISPS audit trail.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code (optionally with ISO 3166-1 country subtag) indicating the language in which the communication was composed. Supports multilingual port community operations and regulatory correspondence in required languages.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcsMessageReference rdf:type rdf:Property ;
    rdfs:label 'Pcs Message Reference' ;
    rdfs:comment 'Unique message identifier assigned by the Port Community System (PCS) for communications transmitted via the PCS channel. Enables traceability back to the originating PCS transaction for customs integration, cargo manifest, and trade documentation workflows.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portCode rdf:type rdf:Property ;
    rdfs:label 'Port Code' ;
    rdfs:comment 'United Nations Code for Trade and Transport Locations (UN/LOCODE) identifying the port facility from which or to which this communication pertains. Supports multi-port operations and regulatory reporting by port authority.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Recipient Identifier' ;
    rdfs:comment 'Identifier of the receiving party for this communication. For EDI, this is the EDI recipient ID (UNB/S003). For email, this is the recipient email address. For PCS messages, this is the PCS participant code. Enables audit trail of communication destination.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'The date after which this communication record may be purged or archived in accordance with the applicable data retention policy. Calculated based on communication type and regulatory requirements (e.g., ISPS records retained for minimum 5 years, customs records per WCO guidelines).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:senderIdentifier rdf:type rdf:Property ;
    rdfs:label 'Sender Identifier' ;
    rdfs:comment 'Identifier of the sending party for this communication. For EDI, this is the EDI sender ID (UNB/S002). For email, this is the sender email address. For PCS messages, this is the PCS participant code. Enables audit trail of communication origin.' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'The date and time when the communication was dispatched or transmitted by the sending party. This is the principal business event timestamp for outbound communications. Stored in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:CommunicationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'The subject line or title of the communication, providing a concise description of the communication\'s topic. Used for search, classification, and audit trail purposes.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentContactContactPersonId rdf:type rdf:Property ;
    rdfs:label 'Parent Contact Contact Person Id' ;
    rdfs:comment 'Self-referencing identifier supporting contact hierarchy structures within a participant organisation. Points to the supervising or parent contact person (e.g., an operations manager who supervises multiple shipping agents). Enables hierarchical escalation routing for SLA breaches and operational exceptions.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContactPerson .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date on which the contact person\'s port access accreditation or security clearance expires. Triggers renewal workflow notifications to the participant and port security team. Null if accreditation is not required for this contact type.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactPersonStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Person Status' ;
    rdfs:comment 'Current lifecycle status of the contact person record. Active contacts are eligible to receive port notifications and access PCS services. Inactive contacts have been deactivated (e.g., staff departure). Suspended contacts are temporarily blocked pending re-verification. Pending_verification contacts are awaiting identity or accreditation confirmation.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRoleType rdf:type rdf:Property ;
    rdfs:label 'Contact Role Type' ;
    rdfs:comment 'Functional role classification of the contact person within the port community context. Drives role-based notification routing: operations contacts receive ETA alerts and vessel call confirmations; finance contacts receive invoices and THC statements; customs contacts receive cargo manifest and trade compliance notifications; emergency contacts receive ISPS and safety alerts. [ENUM-REF-CANDIDATE: operations|finance|customs|emergency|commercial|technical|legal|environmental|security|management — promote to reference product]' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact person\'s standing within the participant account hierarchy. Primary contacts are the main account representatives; billing contacts receive financial documents (THC invoices, demurrage statements); emergency contacts are notified for ISPS security incidents and safety events; technical contacts handle operational system integrations.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactReference rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Reference' ;
    rdfs:comment 'Source system identifier for this contact person in Microsoft Dynamics 365 CRM (Contact entity). Used for cross-system reconciliation and data lineage tracing between the lakehouse silver layer and the CRM source of record.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Licence Number' ;
    rdfs:comment 'Official customs broker licence or registration number issued by the national customs authority for contact persons acting as licensed customs brokers. Required for trade compliance validation and customs clearance authorisation within the Port Community System.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Business department or functional unit within the participant organisation to which this contact person belongs (e.g., Operations, Finance, Customs, Logistics). Supports departmental routing of port notifications and invoices.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates whether this contact person has opted out of all non-essential communications. When True, the contact is excluded from marketing, commercial outreach, and non-operational notifications. Mandatory for GDPR and privacy regulation compliance.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotEmail rdf:type rdf:Property ;
    rdfs:label 'Do Not Email' ;
    rdfs:comment 'Indicates whether this contact person has opted out of email communications specifically. When True, the contact is excluded from email-based notifications and marketing campaigns. Supports granular GDPR consent management at the channel level.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotSms rdf:type rdf:Property ;
    rdfs:label 'Do Not Sms' ;
    rdfs:comment 'Indicates whether this contact person has opted out of SMS/text message communications. When True, the contact is excluded from SMS-based vessel arrival alerts and operational notifications. Supports granular GDPR consent management.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact person. Used as the principal digital channel for ETA/ETD alerts, vessel call confirmations, invoice delivery, EDI notifications, and Port Community System (PCS) messaging.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailSecondary rdf:type rdf:Property ;
    rdfs:label 'Email Secondary' ;
    rdfs:comment 'Secondary or alternate business email address for the contact person. Used as a failover channel when the primary email is undeliverable, or for routing specific notification categories (e.g., invoice copies to a shared finance mailbox).' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fax rdf:type rdf:Property ;
    rdfs:label 'Fax' ;
    rdfs:comment 'Facsimile number for the contact person. Retained for legacy trade documentation workflows where certain customs authorities and port state control bodies still require fax-based submission of manifests and declarations.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the contact person as recorded in the CRM system. Used for personalised communications including ETA alerts, vessel call confirmations, and invoice delivery.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full display name of the contact person as it appears in official port communications, vessel call notifications, and trade documentation. May include salutation or professional title prefix.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date on which the contact person provided explicit consent for the port operator to process their personal data for specified purposes. Required for GDPR Article 7 compliance documentation and data subject rights management.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isEdiContact rdf:type rdf:Property ;
    rdfs:label 'Is Edi Contact' ;
    rdfs:comment 'Indicates whether this contact person is designated as the EDI technical contact for the participant organisation. EDI contacts receive BAPLIE, COPARN, IFTMIN, and other UN/EDIFACT message acknowledgements and error notifications from the Port Community System.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIspsContact rdf:type rdf:Property ;
    rdfs:label 'Is Isps Contact' ;
    rdfs:comment 'Indicates whether this contact person is designated as the ISPS security contact for the participant organisation. ISPS contacts receive security level change notifications, port facility security alerts, and are included in emergency communication trees as required by the ISPS Code.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact person is designated as the primary representative for the associated port community participant. Only one contact per participant should hold this flag as True. Used to determine the default recipient for vessel call confirmations and account-level communications.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or designation of the contact person within their organisation (e.g., Operations Manager, Shipping Agent, Customs Broker, Finance Controller, Port Agent). Used for role-based notification routing and SLA escalation.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the contact person as recorded in the CRM system. Combined with first_name to form the full display name for correspondence and notification routing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfile rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile' ;
    rdfs:comment 'LinkedIn professional profile URL for the contact person. Used by the commercial team for relationship management, stakeholder engagement tracking, and business development activities within Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobile rdf:type rdf:Property ;
    rdfs:label 'Mobile' ;
    rdfs:comment 'Mobile or cellular phone number of the contact person in E.164 format. Primary channel for urgent SMS/push notifications including vessel arrival alerts, berth allocation changes, and emergency ISPS security notifications.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the nationality of the contact person. Relevant for port access control, ISPS security screening, and compliance with national maritime security regulations governing port facility access.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEtaAlert rdf:type rdf:Property ;
    rdfs:label 'Notification Eta Alert' ;
    rdfs:comment 'Indicates whether this contact person is subscribed to receive automated ETA (Estimated Time of Arrival) alert notifications when a vessel associated with their participant organisation is approaching the port. Sourced from CRM notification preference settings.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationInvoice rdf:type rdf:Property ;
    rdfs:label 'Notification Invoice' ;
    rdfs:comment 'Indicates whether this contact person is designated to receive invoice delivery notifications including Terminal Handling Charges (THC), wharfage (WHR), demurrage (DMG), and detention (DET) billing statements generated by the NAVIS N4 billing module.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationVesselCall rdf:type rdf:Property ;
    rdfs:label 'Notification Vessel Call' ;
    rdfs:comment 'Indicates whether this contact person is subscribed to receive vessel call confirmation notifications including berth allocation, ETB (Estimated Time of Berthing), and vessel call number assignments from the Port Management Information System (PMIS).' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcsContactReference rdf:type rdf:Property ;
    rdfs:label 'Pcs Contact Reference' ;
    rdfs:comment 'Identifier assigned to this contact person within the Port Community System (PCS) for stakeholder messaging, cargo manifest communications, and trade documentation routing.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business telephone number of the contact person including country and area code in E.164 format. Used for voice communications regarding vessel operations, berth scheduling, and cargo handling coordination.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portAccessBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Port Access Badge Number' ;
    rdfs:comment 'Physical or RFID-enabled port access badge number issued to the contact person for entry into controlled port facility zones. Links to the port access control system for audit trail and ISPS compliance reporting.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Channel' ;
    rdfs:comment 'The contact person\'s preferred channel for receiving port notifications and operational communications. Drives the notification dispatch logic in the Port Management Information System (PMIS) and PCS messaging engine. Valid values: email (electronic mail), sms (short message service), phone (voice call), fax (facsimile), pcs_portal (Port Community System web portal), edi (Electronic Data Interchange automated message).' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 or BCP-47 language code representing the contact person\'s preferred language for receiving communications, documents, and notifications (e.g., \'en\' for English, \'zh-CN\' for Simplified Chinese, \'ar\' for Arabic). Supports multilingual port community operations.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal salutation or honorific prefix for the contact person (e.g., Mr, Ms, Dr, Capt). Used in formal port correspondence, bill of lading communications, and official maritime documentation where professional titles are required.' ;
    rdfs:domain ind:ContactPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the contact person\'s operational location (e.g., \'Asia/Singapore\', \'Europe/Rotterdam\', \'America/Los_Angeles\'). Used to schedule notifications and communications at appropriate local times, particularly for ETA/ETD alerts across international shipping routes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Credit Assessment Id' ;
    rdfs:comment 'Unique system-generated identifier for each credit assessment record within the port community participant credit management system.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCreditAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Assessor Employee Id' ;
    rdfs:comment 'Identifier of the port employee or credit analyst who conducted the credit assessment. Used for accountability, audit trail, and workload reporting in Oracle HCM Cloud and SAP S/4HANA.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'The port community participant\'s most recently reported annual revenue, sourced from submitted financial statements and used as a key input to the credit assessment and limit determination.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'The organisational approval authority level at which the credit assessment was approved, reflecting the port\'s delegated authority framework based on credit limit thresholds. [ENUM-REF-CANDIDATE: credit_officer|credit_manager|finance_director|cfo|board — promote to reference product]' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Limit' ;
    rdfs:comment 'The final credit limit formally approved by the authorised approver, which may differ from the assessed limit following management review or escalation. This is the enforceable credit ceiling for the participant.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the authorised approver who approved or rejected the credit assessment, captured at the time of decision for audit trail and governance reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Assessed Credit Limit' ;
    rdfs:comment 'The credit limit amount determined by the assessor following evaluation of the participant\'s financial standing, payment history, and risk profile. This is the operative limit used by the billing domain for credit control.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'The methodology or combination of methods used to conduct the credit assessment, such as financial statement analysis, external credit bureau reports, trade references, or the port\'s internal scoring model. [ENUM-REF-CANDIDATE: financial_statement_analysis|credit_bureau_report|trade_reference|internal_scoring_model|combined|external_agency — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text narrative notes recorded by the assessor documenting key findings, risk factors, qualitative observations, and rationale for the credit decision. Supports audit trail and future review context.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number assigned to this credit assessment, used in correspondence with the port community participant and referenced in billing and commercial onboarding workflows.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the credit assessor who conducted the evaluation, captured at the time of assessment for audit and reporting purposes. Complements the assessor_employee_id for human-readable audit trails.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditBureauReference rdf:type rdf:Property ;
    rdfs:label 'Credit Bureau Reference' ;
    rdfs:comment 'Reference number or report identifier from an external credit bureau or trade credit agency report obtained as part of the assessment process. Enables traceability back to the source credit report.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Number' ;
    rdfs:comment 'Policy number of any trade credit insurance arrangement covering the port community participant\'s credit exposure, where the port has obtained insurance to mitigate default risk. Null if no insurance is in place.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Numeric credit score derived from the assessment methodology, representing the port community participant\'s creditworthiness on the port\'s internal scoring scale. Used to determine credit rating tier and approved limit.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysPastDueCount rdf:type rdf:Property ;
    rdfs:label 'Days Past Due Count' ;
    rdfs:comment 'The number of days the port community participant\'s outstanding invoices were past due at the time of assessment, sourced from SAP S/4HANA accounts receivable. A key input to the credit scoring model.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialStatementYear rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Year' ;
    rdfs:comment 'The fiscal year of the financial statements submitted by the port community participant as supporting documentation for the credit assessment (e.g., 2023). Used to assess recency and relevance of financial data.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isWatchList rdf:type rdf:Property ;
    rdfs:label 'Is Watch List' ;
    rdfs:comment 'Indicates whether the port community participant has been placed on the credit watch list due to deteriorating payment behaviour, adverse financial news, or elevated risk signals, triggering enhanced monitoring.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentHistoryRating rdf:type rdf:Property ;
    rdfs:label 'Payment History Rating' ;
    rdfs:comment 'Qualitative rating of the port community participant\'s historical payment behaviour based on analysis of invoice settlement patterns in SAP S/4HANA accounts receivable. A primary input to the credit scoring model.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Previous Credit Limit' ;
    rdfs:comment 'The credit limit that was in effect prior to this assessment, enabling tracking of credit limit changes over time and trend analysis of the participant\'s credit standing.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousCreditRating rdf:type rdf:Property ;
    rdfs:label 'Previous Credit Rating' ;
    rdfs:comment 'The credit rating assigned in the immediately preceding assessment, enabling tracking of rating migrations and trend analysis. Null for initial assessments. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D — promote to reference product]' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Requested Credit Limit' ;
    rdfs:comment 'The credit limit amount requested by the port community participant in their credit application, expressed in the port\'s operating currency. Used as the baseline for the assessor\'s evaluation.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Broad risk classification assigned to the port community participant based on the credit assessment outcome, used to determine credit control measures, payment terms, and security deposit requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCreditAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Credit Account Number' ;
    rdfs:comment 'The SAP S/4HANA customer credit account number associated with this assessment, enabling direct linkage between the credit assessment record and the operative credit master data in the ERP system.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositRequired rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Required' ;
    rdfs:comment 'Indicates whether the credit assessment outcome requires the port community participant to lodge a security deposit (cash, bank guarantee, or letter of credit) before credit facilities are activated.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityDepositType rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Type' ;
    rdfs:comment 'The form of security instrument lodged or required from the port community participant as collateral for the credit facility, such as cash deposit, bank guarantee, or letter of credit.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchListReason rdf:type rdf:Property ;
    rdfs:label 'Watch List Reason' ;
    rdfs:comment 'Narrative description of the reason the port community participant was placed on the credit watch list. Populated only when is_watch_list is True. Used for enhanced monitoring and escalation decisions.' ;
    rdfs:domain ind:CreditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Edi Subscription Id' ;
    rdfs:comment 'Unique surrogate identifier for each EDI subscription configuration record within the Port Community System. Primary key for this entity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiSubscription .

ind:pcsChannelId rdf:type rdf:Property ;
    rdfs:label 'Pcs Channel Id' ;
    rdfs:comment 'The internal channel or queue identifier assigned by the Port Community System to route messages for this subscription. Used for operational monitoring and message tracing within the PCS.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:receiverEdiPartnerId rdf:type rdf:Property ;
    rdfs:label 'Receiver Edi Partner Id' ;
    rdfs:comment 'The EDI interchange receiver identifier (ISA08 in ANSI X12, UNB receiver in UN/EDIFACT, or AS2-To header) that uniquely identifies the receiving party in the EDI message envelope. Used for message routing and delivery confirmation.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiPartner .

ind:serviceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Service Agreement Id' ;
    rdfs:comment 'Reference to the service agreement or contract under which this EDI subscription is provisioned, linking the technical configuration to the commercial terms and SLA obligations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:acknowledgementRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required' ;
    rdfs:comment 'Indicates whether a functional acknowledgement (e.g., CONTRL in UN/EDIFACT, 997/999 in ANSI X12, MDN in AS2) is required from the receiving party upon successful receipt and processing of each EDI message.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgementTimeoutMinutes rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timeout Minutes' ;
    rdfs:comment 'The maximum number of minutes the Port Community System will wait for a functional acknowledgement before flagging the transmission as unacknowledged and triggering an alert or retry. Applicable when acknowledgement_required is true.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateThumbprint rdf:type rdf:Property ;
    rdfs:label 'Certificate Thumbprint' ;
    rdfs:comment 'The SHA-1 or SHA-256 thumbprint of the digital certificate used for AS2 message signing or SFTP public key authentication. Used to validate the identity of the communicating party and ensure message integrity.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterSet rdf:type rdf:Property ;
    rdfs:label 'Character Set' ;
    rdfs:comment 'The character set encoding used for EDI message content under this subscription. UTF-8 is the standard for modern integrations; ISO-8859-1 is common in legacy UN/EDIFACT implementations.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'The transport/communication protocol used to exchange EDI messages between the port community participant and the Port Community System. AS2 (Applicability Statement 2) and SFTP are the most common in maritime logistics. [ENUM-REF-CANDIDATE: AS2|SFTP|FTP|FTPS|API_REST|SMTP — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSubscriptionRef rdf:type rdf:Property ;
    rdfs:label 'Crm Subscription Ref' ;
    rdfs:comment 'The corresponding subscription or service agreement reference number in Microsoft Dynamics 365 CRM, enabling cross-system traceability between the EDI configuration and the commercial relationship record.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Customs Integration Enabled' ;
    rdfs:comment 'Indicates whether EDI messages under this subscription are automatically forwarded to the Customs authority integration layer within the Port Community System. Applicable for CUSCAR (Customs Cargo Report) and related trade compliance message types.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediStandard rdf:type rdf:Property ;
    rdfs:label 'Edi Standard' ;
    rdfs:comment 'The EDI data interchange standard used for this subscription. UN/EDIFACT is the dominant standard in maritime logistics per IMO and WCO guidelines. XML and JSON are used for modern API-based integrations. [ENUM-REF-CANDIDATE: UN/EDIFACT|XML|JSON|ANSI X12|TRADACOMS — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediVersion rdf:type rdf:Property ;
    rdfs:label 'Edi Version' ;
    rdfs:comment 'The specific version of the EDI standard in use for this subscription (e.g., D96A, D00B for UN/EDIFACT; 4010, 5010 for ANSI X12). Ensures correct message parsing and validation at the Port Community System gateway.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this EDI subscription configuration becomes active and the Port Community System begins routing messages according to this configuration.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date on which this EDI subscription configuration expires or is scheduled to be deactivated. Null indicates an open-ended subscription with no planned termination date.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endpointAddress rdf:type rdf:Property ;
    rdfs:label 'Endpoint Address' ;
    rdfs:comment 'The network endpoint address (URL, hostname, IP address, or AS2 station identifier) to which EDI messages are sent or from which they are received. Classified as confidential as it reveals integration infrastructure details.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointPort rdf:type rdf:Property ;
    rdfs:label 'Endpoint Port' ;
    rdfs:comment 'The TCP/IP port number used for the EDI communication endpoint (e.g., 22 for SFTP, 443 for HTTPS/AS2). Required for firewall configuration and connectivity management.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:imoCompanyNumber rdf:type rdf:Property ;
    rdfs:label 'Imo Company Number' ;
    rdfs:comment 'The IMO-assigned unique company identification number for the port community participant, used in EDI message headers for shipping lines and ship operators to ensure regulatory traceability per IMO Resolution A.1078(28).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipWhitelist rdf:type rdf:Property ;
    rdfs:label 'Ip Whitelist' ;
    rdfs:comment 'Comma-separated list of approved source IP addresses or CIDR ranges permitted to connect to the EDI endpoint for this subscription. Enforced at the Port Community System firewall for ISPS Code and ISO 28000 supply chain security compliance.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEncrypted rdf:type rdf:Property ;
    rdfs:label 'Is Encrypted' ;
    rdfs:comment 'Indicates whether EDI messages transmitted under this subscription are encrypted in transit (e.g., using TLS/SSL for SFTP or S/MIME for AS2). Required for ISPS Code compliance and ISO 28000 supply chain security.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSigned rdf:type rdf:Property ;
    rdfs:label 'Is Signed' ;
    rdfs:comment 'Indicates whether EDI messages transmitted under this subscription are digitally signed to ensure non-repudiation and message integrity. Relevant for customs cargo reports (CUSCAR) and trade compliance under WCO standards.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastErrorCode rdf:type rdf:Property ;
    rdfs:label 'Last Error Code' ;
    rdfs:comment 'The error code returned by the most recent failed EDI transmission or processing attempt under this subscription. Supports operational troubleshooting and incident management.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Error Timestamp' ;
    rdfs:comment 'The timestamp of the most recent EDI transmission or processing error for this subscription. Used alongside last_error_code for incident tracking and SLA breach analysis.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastMessageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Message Timestamp' ;
    rdfs:comment 'The timestamp of the most recently transmitted or received EDI message under this subscription. Used for monitoring subscription activity, detecting stale connections, and SLA reporting.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxMessageSizeKb rdf:type rdf:Property ;
    rdfs:label 'Max Message Size Kb' ;
    rdfs:comment 'The maximum allowable size in kilobytes for a single EDI message transmitted under this subscription. Enforced at the Port Community System gateway to prevent oversized transmissions that could impact system performance.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageDirection rdf:type rdf:Property ;
    rdfs:label 'Message Direction' ;
    rdfs:comment 'Indicates whether the port community participant is configured to SEND (OUTBOUND) or RECEIVE (INBOUND) this EDI message type via the Port Community System.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageFrequency rdf:type rdf:Property ;
    rdfs:label 'Message Frequency' ;
    rdfs:comment 'The expected frequency or trigger mode for EDI message transmission under this subscription. Real-time = event-driven immediate dispatch; Scheduled = at defined intervals; On-demand = manually triggered; Batch daily/weekly = aggregated periodic transmissions.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageType rdf:type rdf:Property ;
    rdfs:label 'Message Type' ;
    rdfs:comment 'The EDI message type this subscription covers. COPARN = Container Pre-Announcement, IFTMIN = Instruction Message for Transport, BAPLIE = Bayplan/Stowage Plan, CUSCAR = Customs Cargo Report, INVOIC = Invoice, COARRI = Container Arrival/Departure, CODECO = Container Gate-In/Gate-Out, IFTSTA = Transport Status. [ENUM-REF-CANDIDATE: COPARN|IFTMIN|BAPLIE|CUSCAR|INVOIC|COARRI|CODECO|IFTSTA — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPhone rdf:type rdf:Property ;
    rdfs:label 'Notification Phone' ;
    rdfs:comment 'The phone number (in E.164 international format) for SMS or voice alerts related to critical EDI failures or connectivity issues for this subscription.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantRole rdf:type rdf:Property ;
    rdfs:label 'Participant Role' ;
    rdfs:comment 'The operational role of the port community participant in the context of this EDI subscription, determining which message types are applicable and the direction of data flow. [ENUM-REF-CANDIDATE: shipping_line|freight_forwarder|customs_broker|cargo_owner|trucking_company|port_agent|terminal_operator — promote to reference product]' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryAttemptsMax rdf:type rdf:Property ;
    rdfs:label 'Retry Attempts Max' ;
    rdfs:comment 'The maximum number of automatic retransmission attempts the Port Community System will make if an EDI message delivery fails or times out. Governs resilience of the EDI channel.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retryIntervalMinutes rdf:type rdf:Property ;
    rdfs:label 'Retry Interval Minutes' ;
    rdfs:comment 'The number of minutes between successive automatic retransmission attempts when an EDI message delivery fails. Works in conjunction with retry_attempts_max to define the retry schedule.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleCronExpression rdf:type rdf:Property ;
    rdfs:label 'Schedule Cron Expression' ;
    rdfs:comment 'The CRON expression defining the scheduled transmission window for batch or scheduled EDI messages (e.g., \'0 6 * * *\' for daily at 06:00 UTC). Applicable when message_frequency is \'scheduled\', \'batch_daily\', or \'batch_weekly\'.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Minutes' ;
    rdfs:comment 'The maximum number of minutes within which the Port Community System must process and deliver an inbound EDI message or confirm receipt of an outbound message, as defined in the participant\'s service agreement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionCode rdf:type rdf:Property ;
    rdfs:label 'Subscription Code' ;
    rdfs:comment 'Externally-known unique business identifier for the EDI subscription, used in operational communications and referenced in the Port Community System configuration. Follows the format EDI-{alphanumeric}.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionName rdf:type rdf:Property ;
    rdfs:label 'Subscription Name' ;
    rdfs:comment 'Human-readable descriptive name for the EDI subscription configuration, typically identifying the participant and message type combination (e.g., \'Maersk COPARN Inbound AS2\').' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionNotes rdf:type rdf:Property ;
    rdfs:label 'Subscription Notes' ;
    rdfs:comment 'Free-text operational notes or remarks about this EDI subscription, capturing special configuration requirements, known issues, or onboarding instructions for the integration team.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle status of the EDI subscription. Active = operational and processing messages; Inactive = configured but not processing; Suspended = temporarily halted (e.g., due to connectivity issues or compliance hold); Pending = awaiting activation/testing; Terminated = permanently decommissioned.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of the EDI subscription tier. Standard = regular production subscription; Premium = high-volume or priority-routed subscription with enhanced SLA; Test = non-production testing environment; Pilot = limited trial configuration for new message types or participants.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMode rdf:type rdf:Property ;
    rdfs:label 'Test Mode' ;
    rdfs:comment 'Indicates whether this subscription is operating in test/sandbox mode, where messages are processed but do not trigger live operational actions in the Terminal Operating System or Customs systems. Used during onboarding and integration testing.' ;
    rdfs:domain ind:EdiSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingApplicationId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Application Id' ;
    rdfs:comment 'Unique system-generated identifier for each port community participant onboarding application record. Primary key for this entity.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedRelationshipManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Relationship Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customer onboarding workflow assigns account managers to new applications. Essential for workload distribution, SLA tracking, and handover management. assigned_relationship_manager is denormalized emp' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ispsScreeningSecurityPersonnelId rdf:type rdf:Property ;
    rdfs:label 'Isps Screening Security Personnel Id' ;
    rdfs:comment 'Foreign key linking to security.security_personnel. Business justification: Security personnel conduct ISPS background screening during participant onboarding. Tracks which security officer performed screening for audit trail and accountability. Role prefix distinguishes from' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Personnel .

ind:priorApplicationOnboardingApplicationId rdf:type rdf:Property ;
    rdfs:label 'Prior Application Onboarding Application Id' ;
    rdfs:comment 'Reference to the previous onboarding application record if this is a resubmission (is_resubmission = true). Enables lineage tracking across multiple application attempts by the same entity.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnboardingApplication .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date on which the applicant was formally activated as a port community participant, granting access to port services, the Port Community System (PCS), and Terminal Operating System (TOS) integrations. Populated upon successful completion of the onboarding lifecycle.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicantAddress rdf:type rdf:Property ;
    rdfs:label 'Applicant Address' ;
    rdfs:comment 'Full registered business address of the applicant entity, including street, city, state/province, and postal code. Required for legal correspondence, sanctions screening, and regulatory compliance.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantLegalName rdf:type rdf:Property ;
    rdfs:label 'Applicant Legal Name' ;
    rdfs:comment 'The full registered legal name of the applying entity as it appears on official incorporation or registration documents. Used for identity verification, contract formation, and regulatory compliance checks.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantTradingName rdf:type rdf:Property ;
    rdfs:label 'Applicant Trading Name' ;
    rdfs:comment 'The trading or doing-business-as (DBA) name of the applicant entity, if different from the legal name. Used in operational communications and Port Community System (PCS) messaging.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationChannel rdf:type rdf:Property ;
    rdfs:label 'Application Channel' ;
    rdfs:comment 'The channel through which the onboarding application was submitted by the applicant. Supports channel analytics and process improvement initiatives.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number assigned to the onboarding application at submission (e.g., OBA-2024-000123). Used in all correspondence with the applicant and referenced in the Port Community System (PCS).' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle state of the onboarding application within the registration workflow. Tracks progression from initial submission through document verification, security screening, credit assessment, and final activation. [ENUM-REF-CANDIDATE: draft|submitted|under_review|pending_documents|approved|rejected|activated|withdrawn — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of the background check conducted on the applicant entity, including sanctions list screening, adverse media checks, and anti-money laundering (AML) verification. Distinct from ISPS screening which is port-facility-specific.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'The official government-issued business registration or company number of the applicant entity, as issued by the relevant national authority. Required for identity verification and customs compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Credit Assessment Reference' ;
    rdfs:comment 'External reference number assigned by the credit assessment team or third-party credit bureau for the pre-assessment conducted on this applicant. Links to the detailed credit assessment report in SAP S/4HANA FI.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Assessment Status' ;
    rdfs:comment 'Status of the credit pre-assessment conducted to evaluate the financial standing of the applicant entity prior to granting access to port services on credit terms. Informs the credit limit and payment terms assigned upon activation.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmLeadReference rdf:type rdf:Property ;
    rdfs:label 'Crm Lead Reference' ;
    rdfs:comment 'Reference identifier of the corresponding lead or opportunity record in Microsoft Dynamics 365 CRM from which this onboarding application originated. Enables traceability between the sales pipeline and the registration lifecycle.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Document Checklist Status' ;
    rdfs:comment 'Overall status of the submitted documents checklist for this onboarding application, indicating whether all required documents have been received and verified. Drives workflow progression to the security screening stage.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightForwarderLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Forwarder Licence Number' ;
    rdfs:comment 'The official freight forwarder licence or accreditation number issued by the relevant national transport authority, applicable to applicants of participant type \'freight_forwarder\'.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isResubmission rdf:type rdf:Property ;
    rdfs:label 'Is Resubmission' ;
    rdfs:comment 'Indicates whether this onboarding application is a resubmission following a prior rejection or withdrawal. True if the applicant has previously submitted an application that was rejected or withdrawn.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Isps Screening Date' ;
    rdfs:comment 'Date on which the ISPS security screening was completed for the applicant entity. Used for compliance audit trails and screening validity period tracking.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ispsScreeningReference rdf:type rdf:Property ;
    rdfs:label 'Isps Screening Reference' ;
    rdfs:comment 'External reference number or case identifier assigned by the ISPS screening authority for the security check conducted on this applicant. Enables cross-referencing with the port security management system.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Isps Screening Status' ;
    rdfs:comment 'Outcome status of the ISPS security screening conducted on the applicant entity as part of the port community onboarding process. Mandatory for all participant types under the ISPS Code to ensure port facility security compliance.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantType rdf:type rdf:Property ;
    rdfs:label 'Participant Type' ;
    rdfs:comment 'Classification of the applicant entity by their role in the port community. Determines the applicable onboarding workflow, required documents, and service entitlements. [ENUM-REF-CANDIDATE: shipping_line|freight_forwarder|customs_broker|trucking_company|port_agent|cargo_owner|consignee — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcsEntityCode rdf:type rdf:Property ;
    rdfs:label 'Pcs Entity Code' ;
    rdfs:comment 'The entity code assigned within the Port Community System (PCS) upon activation, used for EDI messaging, cargo manifest submissions, and stakeholder communications. Populated after activation.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact person at the applicant organisation. Used for all official onboarding correspondence, document requests, and status notifications via the Port Community System (PCS).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the applicant organisation responsible for managing the onboarding application and subsequent port community participation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct telephone number of the primary contact person at the applicant organisation, including international dialling code. Used for urgent onboarding communications and verification callbacks.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedCreditLimit rdf:type rdf:Property ;
    rdfs:label 'Proposed Credit Limit' ;
    rdfs:comment 'The credit limit (in the port\'s base currency) proposed by the credit assessment team for the applicant entity upon activation. Determines the maximum outstanding balance permitted before pre-payment is required for port services.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionCategory rdf:type rdf:Property ;
    rdfs:label 'Rejection Category' ;
    rdfs:comment 'Structured categorical classification of the rejection reason, enabling reporting and trend analysis on onboarding failure modes. Populated only when application_status is \'rejected\'.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningOutcome rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Outcome' ;
    rdfs:comment 'Result of the sanctions list screening conducted against international sanctions databases (e.g., OFAC, UN, EU) for the applicant entity. A \'confirmed_match\' outcome results in automatic rejection of the application.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Date' ;
    rdfs:comment 'The target date by which the onboarding application should be fully processed and the applicant activated, as defined by the port\'s SLA for participant registration. Used for SLA compliance monitoring and KPI reporting.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'The tax identification number (TIN) or VAT registration number of the applicant entity, as issued by the relevant tax authority. Required for billing, tariff management, and trade compliance reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDocumentsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Documents Received' ;
    rdfs:comment 'Count of documents that have been physically or electronically received from the applicant against the required document checklist. Compared against total_documents_required to assess completeness.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDocumentsRequired rdf:type rdf:Property ;
    rdfs:label 'Total Documents Required' ;
    rdfs:comment 'Total number of documents required for this onboarding application based on the participant type and applicable regulatory requirements. Used to track document submission completeness.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDocumentsVerified rdf:type rdf:Property ;
    rdfs:label 'Total Documents Verified' ;
    rdfs:comment 'Count of received documents that have been reviewed and verified as authentic and compliant by the port authority\'s document verification team.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleOperatorLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Operator Licence Number' ;
    rdfs:comment 'The road transport or vehicle operator licence number issued by the relevant national authority, applicable to applicants of participant type \'trucking_company\'. Required for gate access authorisation and intermodal transport coordination.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStage rdf:type rdf:Property ;
    rdfs:label 'Workflow Stage' ;
    rdfs:comment 'Current stage within the multi-step onboarding approval workflow. Tracks the sequential progression of the application through internal review gates: initial review, document verification, ISPS security screening, credit pre-assessment, final approval, and activation.' ;
    rdfs:domain ind:OnboardingApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Org Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each parent-child corporate hierarchy relationship record between port community participants in the Databricks Silver Layer.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childOrgPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Child Org Port Community Participant Id' ;
    rdfs:comment 'Reference to the child or subsidiary organisation entity in the hierarchy (e.g., regional subsidiary, local freight forwarder branch, subsidiary cargo owner). Used to traverse downward in the corporate tree.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:primaryRootOrgPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Primary Root Org Port Community Participant Id' ;
    rdfs:comment 'Reference to the ultimate parent (root) organisation at the top of the corporate hierarchy tree. Enables direct group-level consolidation for billing, credit management, and enterprise reporting without full tree traversal.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:billingConsolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Consolidation Flag' ;
    rdfs:comment 'Indicates whether charges and invoices for the child organisation are consolidated and billed to the parent organisation under this hierarchy relationship. True = consolidated billing applies (e.g., THC, WHR, DMG charges rolled up to parent); False = child is billed independently.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child organisation inherits master contract terms (tariff schedules, service agreements, credit terms) from the parent organisation. True = contract terms cascade; False = child operates under its own independently negotiated contracts.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditConsolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Consolidation Flag' ;
    rdfs:comment 'Indicates whether the credit limit and credit exposure of the child organisation is managed at the parent group level under this hierarchy. True = group credit management applies; False = child has independent credit management.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmAccountHierarchyReference rdf:type rdf:Property ;
    rdfs:label 'Crm Account Hierarchy Reference' ;
    rdfs:comment 'The source system identifier for this hierarchy relationship as recorded in Microsoft Dynamics 365 CRM Account Hierarchy module. Enables traceability and reconciliation between the CRM system of record and the Databricks Silver Layer.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governance Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the primary legal jurisdiction governing this hierarchy relationship. Relevant for regulatory compliance, ISPS Code administration, and Port State Control (PSC) reporting.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCategory rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Category' ;
    rdfs:comment 'Classifies the port community participant category to which this hierarchy relationship belongs. Enables segment-specific analytics and reporting (e.g., shipping line parent-subsidiary networks, freight forwarder global networks, conglomerate cargo owner structures). [ENUM-REF-CANDIDATE: shipping_line|freight_forwarder|cargo_owner|customs_broker|trucking_company|port_agent — promote to reference product if additional values required]' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known unique business code identifying this specific hierarchy relationship, used for cross-system referencing in Port Community System (PCS) and Microsoft Dynamics 365 CRM. Follows the format ORG-HIER-[alphanumeric].' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepthLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth Level' ;
    rdfs:comment 'Numeric depth level of this relationship within the overall corporate hierarchy tree, where level 1 represents the ultimate parent (root node). Enables efficient tree traversal, roll-up reporting, and enterprise-level consolidated analytics across related port community participants.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialised path string representing the full ancestry chain from root to this node (e.g., \'/1001/1045/1078\'), enabling efficient subtree queries and hierarchy traversal without recursive joins. Populated and maintained by the TOS/CRM integration pipeline.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of the hierarchy relationship. \'active\' = currently valid and in use; \'inactive\' = relationship exists but not currently operative; \'pending\' = awaiting approval or activation; \'suspended\' = temporarily halted (e.g., credit hold); \'terminated\' = permanently ended.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classifies the nature of the parent-child relationship. \'corporate\' = legal ownership/shareholding structure; \'operational\' = operational reporting line; \'billing\' = consolidated billing and invoicing group; \'regulatory\' = regulatory compliance grouping (e.g., ISPS, IMO); \'commercial\' = commercial/contractual grouping for tariff and SLA management.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryHierarchy rdf:type rdf:Property ;
    rdfs:label 'Is Primary Hierarchy' ;
    rdfs:comment 'Indicates whether this hierarchy relationship is the primary (canonical) hierarchy for the child organisation when multiple hierarchy types exist. True = primary hierarchy used for default roll-up reporting and consolidated billing; False = secondary or supplementary hierarchy.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'The percentage of equity ownership the parent organisation holds in the child organisation for corporate hierarchy types. Relevant for regulatory reporting, group credit exposure assessment, and consolidated financial reporting. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pcsHierarchyRef rdf:type rdf:Property ;
    rdfs:label 'Pcs Hierarchy Ref' ;
    rdfs:comment 'The external reference identifier for this hierarchy relationship as recorded in the Port Community System (PCS). Used for cross-system reconciliation between the Databricks Silver Layer and the PCS for customs integration, cargo manifest, and trade documentation purposes.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryGroupCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Group Code' ;
    rdfs:comment 'Regulatory grouping code assigned by the port authority or national maritime safety authority to identify this hierarchy for compliance reporting purposes (e.g., ISPS security group, PSC inspection group, IMO company identification grouping).' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRole rdf:type rdf:Property ;
    rdfs:label 'Relationship Role' ;
    rdfs:comment 'Describes the specific role of the child organisation relative to the parent within this hierarchy link. For example, a shipping line regional office may be a \'subsidiary\', while a port agent acting on behalf of a shipping line is an \'agent\'.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child organisation inherits the Service Level Agreement (SLA) terms and conditions from the parent organisation under this hierarchy relationship. True = SLA terms cascade from parent to child; False = child has independently negotiated SLA terms.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Account management structure requires linking accounts to responsible port employees. Drives performance metrics, commission calculations, and customer escalation routing. account_manager_name is deno' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Multi-entity port operators manage participant accounts under specific legal entities for financial reporting, tax compliance, and regulatory segregation. Essential for consolidated financial statemen' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'Calendar date on which the participant account was closed or terminated. Null for active accounts. Used for lifecycle reporting and regulatory record retention compliance.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-known unique alphanumeric account number assigned to the participant account. Used on invoices, billing statements, and Terminal Handling Charge (THC) documentation. Sourced from NAVIS N4 billing module and Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'Calendar date on which the participant account was formally opened and activated for trading with the port. Marks the effective start of the billing and commercial relationship.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Commercial tier classification of the participant account reflecting volume, strategic importance, and service priority. Determines priority berthing, dedicated account management, and preferential Terminal Handling Charge (THC) rates.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the participant account by the type of port community role. Determines applicable tariff schedules, service entitlements, and regulatory obligations. [ENUM-REF-CANDIDATE: shipping_line|freight_forwarder|cargo_owner|customs_broker|trucking_company|port_agent|consignee|importer|exporter — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualTeuVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Teu Volume Commitment' ;
    rdfs:comment 'Contracted annual Twenty-foot Equivalent Unit (TEU) throughput volume committed by the participant under their service agreement. Basis for volume-based discount tiers and tariff schedule assignment.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoSuspensionEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Suspension Enabled' ;
    rdfs:comment 'Indicates whether the account is configured for automatic suspension when credit utilisation exceeds the defined threshold or invoices become overdue beyond the permitted days. Controlled by NAVIS N4 billing credit management rules.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAddress rdf:type rdf:Property ;
    rdfs:label 'Billing Address' ;
    rdfs:comment 'Full postal billing address for invoice delivery to this participant account. Used for physical invoice dispatch and regulatory correspondence. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiry date of the master service agreement or port access contract governing this account. Null for open-ended agreements. Triggers renewal workflow in Microsoft Dynamics 365 CRM when approaching.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number of the master service agreement or port access contract governing this account\'s commercial relationship with the port. Links to the contract management module in Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the master service agreement or port access contract governing this account. Determines when contracted tariff rates, SLA commitments, and volume discounts become applicable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Credit Review Date' ;
    rdfs:comment 'Scheduled or last-completed date for periodic credit limit review of this account. Ensures credit limits remain aligned with participant trading volumes and financial standing.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditUtilisationPct rdf:type rdf:Property ;
    rdfs:label 'Credit Utilisation Pct' ;
    rdfs:comment 'Percentage of the credit limit currently consumed by the outstanding balance (outstanding_balance / credit_limit × 100). Used for credit risk monitoring and automated suspension triggers in NAVIS N4 billing.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmAccountReference rdf:type rdf:Property ;
    rdfs:label 'Crm Account Reference' ;
    rdfs:comment 'Source system account identifier from Microsoft Dynamics 365 CRM corresponding to this participant account. Used for data lineage, cross-system reconciliation, and CRM integration.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicence rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Licence' ;
    rdfs:comment 'Regulatory licence number issued by the national customs authority to the participant where the account type is \'customs_broker\'. Required for Port Community System (PCS) customs integration and trade compliance validation.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSalesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding' ;
    rdfs:comment 'Average number of days taken by this account to settle invoices, calculated over a rolling period. Key accounts receivable Key Performance Indicator (KPI) for port commercial and finance teams.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'Cash security deposit (in account currency) held by the port against this account to cover potential non-payment of port dues, Demurrage (DMG), Detention (DET), or damage liabilities.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRatePct rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Pct' ;
    rdfs:comment 'Negotiated percentage discount applied to standard tariff charges for this account. Reflects volume commitments, strategic partnerships, or long-term service agreements. Commercially sensitive.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediEnabled rdf:type rdf:Property ;
    rdfs:label 'Edi Enabled' ;
    rdfs:comment 'Indicates whether this account is configured for Electronic Data Interchange (EDI) message exchange via the Port Community System (PCS) for automated cargo manifests, container pre-announcements (COPARN), and delivery orders (D/O).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediParticipantCode rdf:type rdf:Property ;
    rdfs:label 'Edi Participant Code' ;
    rdfs:comment 'Unique Electronic Data Interchange (EDI) identifier assigned to this account for automated message exchange via the Port Community System (PCS). Used in COPARN, IFTMIN, and BAPLIE message sets for container pre-announcement and vessel planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Isps Accreditation Number' ;
    rdfs:comment 'Accreditation number issued under the International Ship and Port Facility Security (ISPS) Code confirming the participant\'s security compliance for port access. Required for shipping lines and port agents operating under SOLAS Chapter XI-2.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent financial transaction (invoice, payment, or credit note) posted against this account. Used for dormancy detection and account review scheduling.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:navisAccountCode rdf:type rdf:Property ;
    rdfs:label 'Navis Account Code' ;
    rdfs:comment 'Account code as configured in the NAVIS N4 Terminal Operating System billing module. Used for charge posting, invoice generation, and Terminal Handling Charge (THC) allocation in terminal operations.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total amount (in account currency) of invoices past their due date on this account. Triggers automated dunning, service suspension, or escalation workflows in SAP S/4HANA and NAVIS N4.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueDays rdf:type rdf:Property ;
    rdfs:label 'Overdue Days' ;
    rdfs:comment 'Number of calendar days the oldest unpaid invoice on this account has been overdue. Used for dunning level determination and credit suspension escalation.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLine rdf:type rdf:Property ;
    rdfs:label 'Service Line' ;
    rdfs:comment 'Port service line under which this account operates, determining applicable operational procedures, equipment allocation, and tariff structures. Roll-on Roll-off (RoRo) and container accounts have distinct billing and operational profiles. [ENUM-REF-CANDIDATE: container|bulk|roro|general_cargo|liquid_bulk|cruise|offshore — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTierCode rdf:type rdf:Property ;
    rdfs:label 'Sla Tier Code' ;
    rdfs:comment 'Code identifying the Service Level Agreement (SLA) tier applicable to this account, governing guaranteed berth turnaround times, crane productivity rates, and gate processing commitments.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Schedule Code' ;
    rdfs:comment 'Code identifying the applicable port tariff schedule for this account, governing Terminal Handling Charges (THC), Wharfage (WHR), Port Infrastructure Levy (PIL), and other dues. Linked to the port\'s published tariff book.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'Government-issued tax registration or VAT number for the participant account entity. Required for invoice compliance, customs documentation, and World Customs Organization (WCO) trade reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ytdTeuVolume rdf:type rdf:Property ;
    rdfs:label 'Ytd Teu Volume' ;
    rdfs:comment 'Actual Twenty-foot Equivalent Unit (TEU) throughput processed under this account in the current calendar or fiscal year. Used to track progress against annual volume commitments and trigger tier reclassification.' ;
    rdfs:domain ind:ParticipantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantAddressId rdf:type rdf:Property ;
    rdfs:label 'Participant Address Id' ;
    rdfs:comment 'Unique surrogate identifier for each participant address record in the port community system. Primary key for the participant_address data product.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressFormatType rdf:type rdf:Property ;
    rdfs:label 'Address Format Type' ;
    rdfs:comment 'Indicates the structural format of the address. Structured addresses follow standard street/city/postal hierarchy; unstructured addresses are free-form (common in some Asian and Middle Eastern jurisdictions); po_box and private_bag are postal delivery formats used for correspondence addresses.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line including building number, street name, or PO Box. Used in trade documentation, customs declarations, and invoice delivery per WCO data model requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, unit, building name, or additional location detail. Supplements address_line_1 for complete postal addressing on customs declarations and trade documents.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine3 rdf:type rdf:Property ;
    rdfs:label 'Address Line 3' ;
    rdfs:comment 'Tertiary address line for district, suburb, or additional locality detail. Used for complex international addresses where two lines are insufficient for complete postal addressing on BOL and customs documentation.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are used in trade documentation and invoice delivery. Pending_verification addresses are awaiting confirmation from the participant or customs authority. Superseded addresses have been replaced by a newer record but retained for historical audit.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose within port community operations. Registered office is the legal entity address; operational is the day-to-day working address; billing is used for invoice delivery and THC/WHR/DMG charge correspondence; correspondence is for general trade documentation and BOL/D/O dispatch; port_agent is the local port agent\'s operational address.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionTo rdf:type rdf:Property ;
    rdfs:label 'Attention To' ;
    rdfs:comment 'Name of the specific person, department, or role to whom correspondence should be directed at this address. Used on trade documents, BOL, D/O, and invoice delivery to ensure correct routing within large organisations such as shipping lines or freight forwarders.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality of the address. Required field for customs declarations, trade documentation, and invoice delivery. Used in Port Community System (PCS) for cargo manifest address validation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Full English name of the country corresponding to the ISO 3166-1 alpha-2 country_code. Stored for display purposes on trade documents, invoices, and customs declarations without requiring a lookup join.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRegisteredAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Registered Address Flag' ;
    rdfs:comment 'Indicates whether this address is the officially registered address with the national customs authority for the participant. Customs-registered addresses are used on import/export declarations and must match the address held in the customs authority\'s trader registration system.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Registration Number' ;
    rdfs:comment 'Customs authority registration or trader identification number associated with this address. Required for customs declarations and trade compliance submissions. Corresponds to the Economic Operator Registration and Identification (EORI) number or equivalent national customs trader ID.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Email address associated with this specific address record. Used for electronic delivery of invoices, D/O, trade documentation, and customs correspondence to the correct department or location within the participant organisation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number associated with this address. Retained for legacy trade documentation workflows and customs authorities that still require fax-based submission of cargo manifests and customs declarations in certain jurisdictions.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the primary address for the given address type for the participant. Only one address per participant per address_type should be flagged as primary at any point in time. Used to determine the default address for invoice generation and trade documentation.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether the address has been verified against an authoritative postal or customs registry. Verified addresses are required for customs declarations and official trade documentation submissions to national customs authorities.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Isps Facility Code' ;
    rdfs:comment 'ISPS facility code assigned to the address if it is a port facility or secure logistics facility. Required for ISPS Code compliance and port security declarations. Applicable to port agent addresses and operational addresses at ISPS-designated facilities.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude of the address in decimal degrees (WGS84). Used for geospatial analytics, port logistics routing, and intermodal transport coordination. Particularly relevant for container yard (CY), ICD, and CFS addresses.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude of the address in decimal degrees (WGS84). Used for geospatial analytics, port logistics routing, and intermodal transport coordination. Particularly relevant for container yard (CY), ICD, and CFS addresses.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pcsAddressReference rdf:type rdf:Property ;
    rdfs:label 'Pcs Address Reference' ;
    rdfs:comment 'Address reference code assigned by the Port Community System for use in EDI messaging, cargo manifests, and customs integration. Used in COPARN, IFTMIN, and other EDI message types to identify the participant\'s address without transmitting full address details.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary telephone number associated with this address location. Used for operational contact at the specific address, particularly for port agent addresses and operational addresses. Formatted in E.164 international format where possible.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the address. Used for invoice delivery, trade documentation, and customs declarations. Format varies by country; validated against country-specific postal code standards in the Port Community System.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAddressReference rdf:type rdf:Property ;
    rdfs:label 'Source System Address Reference' ;
    rdfs:comment 'The native identifier of this address record in the originating source system (e.g., Dynamics 365 CRM address GUID, SAP Business Partner address sequence number, PCS address reference). Used for data lineage, reconciliation, and back-integration with operational systems.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the address. Captured as ISO 3166-2 subdivision code where applicable. Required for customs declarations in jurisdictions with state-level trade compliance requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unLocode rdf:type rdf:Property ;
    rdfs:label 'Un Locode' ;
    rdfs:comment 'UN/LOCODE for the city or port location associated with this address. Particularly relevant for port agent addresses and operational addresses at seaport locations. Used in EDI messaging (IFTMIN, COPARN) and PCS cargo manifest submissions.' ;
    rdfs:domain ind:ParticipantAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method by which the address was verified. Manual verification is performed by port operations staff; postal_registry uses national postal authority data; customs_registry uses WCO or national customs authority data; third_party uses a commercial address validation service; self_declared is provided by the participant without independent verification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantDocumentId rdf:type rdf:Property ;
    rdfs:label 'Participant Document Id' ;
    rdfs:comment 'Unique surrogate identifier for each participant document record in the port community system. Primary key for the participant_document data product.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupersededByDocumentParticipantDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Document Participant Document Id' ;
    rdfs:comment 'Reference to the newer participant_document record that replaces this document upon renewal or reissuance. Enables document version chain tracking and ensures compliance systems reference the current valid document.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParticipantDocument .

ind:certifiedCopy rdf:type rdf:Property ;
    rdfs:label 'Certified Copy' ;
    rdfs:comment 'Indicates whether the document on file is a certified true copy (True) or an original (False). Certified copies may have different evidentiary weight for regulatory compliance purposes.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceGateBlocked rdf:type rdf:Property ;
    rdfs:label 'Compliance Gate Blocked' ;
    rdfs:comment 'Indicates whether this document is currently blocking the participant from accessing port services or completing accreditation (True = blocked). Set to True when a mandatory document is expired, rejected, or pending verification. Drives real-time compliance gating in the Port Community System.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'The monetary value of insurance coverage or financial guarantee stated in the document (e.g., P&I cover limit, cargo insurance sum insured). Applicable primarily to insurance certificates. Used for risk assessment and minimum coverage compliance checks.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Coverage Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the coverage amount stated in the document (e.g., USD, EUR, AUD). Required to normalise coverage values across multi-currency insurance instruments.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentScope rdf:type rdf:Property ;
    rdfs:label 'Document Scope' ;
    rdfs:comment 'Indicates the operational scope to which the document applies — whether it covers the entire participant entity, a specific vessel, a cargo consignment, a port facility, or an individual person (e.g., a named customs broker). Determines how the document is applied during compliance gating.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'The full descriptive title of the document as stated on the official instrument (e.g., \'Protection and Indemnity Insurance Certificate\', \'Dangerous Goods Handling Authorisation\'). Provides human-readable identification beyond the document type code.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version identifier of the document as issued by the authority (e.g., \'v2\', \'Amendment 3\', \'2024 Edition\'). Tracks amendments and reissues of the same document number without full replacement.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsRelevant rdf:type rdf:Property ;
    rdfs:label 'Isps Relevant' ;
    rdfs:comment 'Indicates whether this document is relevant to ISPS Code compliance requirements (True), such as port facility security certificates, vessel security plans, or security officer designations. Enables targeted ISPS compliance reporting.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'The insurance policy or P&I cover entry number associated with the insurance certificate document. Enables cross-referencing with insurer records for claims and coverage verification.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pscNotified rdf:type rdf:Property ;
    rdfs:label 'Psc Notified' ;
    rdfs:comment 'Indicates whether Port State Control authorities have been notified of a document deficiency or non-compliance finding related to this document (True = notified). Supports PSC inspection management and regulatory reporting obligations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this document requires periodic renewal (True) or is a one-time permanent issuance (False). Drives automated renewal reminder workflows and compliance calendar management.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'The channel through which the document was submitted to the port authority (e.g., Port Community System portal, EDI message, email, manual counter submission, API integration). Supports process analytics and EDI compliance tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationRequired rdf:type rdf:Property ;
    rdfs:label 'Translation Required' ;
    rdfs:comment 'Indicates whether a certified translation of this document is required for port authority compliance review (True). Triggered when the document language is not an accepted official language of the port jurisdiction.' ;
    rdfs:domain ind:ParticipantDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portAccessPermitId rdf:type rdf:Property ;
    rdfs:label 'Port Access Permit Id' ;
    rdfs:comment 'Unique surrogate identifier for each port access permit record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedAccessPointId rdf:type rdf:Property ;
    rdfs:label 'Authorized Access Point Id' ;
    rdfs:comment 'Foreign key linking to security.access_point. Business justification: Permits specify which access points holder may use for entry/exit. Essential for access control system integration and permit validation at gates. Role prefix clarifies this is authorized entry point,' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessPoint .

ind:issuingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Issuing Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ISPS security compliance requires tracking which port security officer issued each access permit. Critical for audit trails, security incident investigations, and regulatory inspections. issuing_offic' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:issuingSecurityPersonnelId rdf:type rdf:Property ;
    rdfs:label 'Issuing Security Personnel Id' ;
    rdfs:comment 'Foreign key linking to security.security_personnel. Business justification: Port access permits are issued by security personnel under ISPS Code requirements. Tracks which security officer issued/approved each permit for audit trail and accountability. Role prefix distinguish' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Personnel .

ind:pcsPermitId rdf:type rdf:Property ;
    rdfs:label 'Pcs Permit Id' ;
    rdfs:comment 'Source system identifier for this permit record in the Port Community System (PCS). Used for data lineage, reconciliation, and integration between the PCS and the lakehouse silver layer.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:accessTimeRestriction rdf:type rdf:Property ;
    rdfs:label 'Access Time Restriction' ;
    rdfs:comment 'Time-of-day restriction applied to this permit. Unrestricted permits allow 24/7 access; other values limit access to defined operational windows. Enforced at gate entry systems and ISPS checkpoints.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationReference rdf:type rdf:Property ;
    rdfs:label 'Application Reference' ;
    rdfs:comment 'Reference number of the original permit application submitted through the Port Community System (PCS) or port authority portal. Links the issued permit back to the application workflow for audit and traceability.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date on which the security background check was completed for this permit holder. Used to determine whether a re-check is required at renewal based on the port\'s ISPS security policy interval.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:badgeNumber rdf:type rdf:Property ;
    rdfs:label 'Badge Number' ;
    rdfs:comment 'Physical badge or access card number printed on the permit holder\'s port ID badge. Used by gate access control systems, RFID readers, and security checkpoints to validate physical access. May differ from permit_number.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Biometric Reference Code' ;
    rdfs:comment 'Unique reference token linking this permit to the holder\'s biometric record stored in the port\'s secure biometric identity management system (fingerprint, iris, or facial recognition template). The actual biometric template is NOT stored here — only the reference token. Null for vehicle permits.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escortRequired rdf:type rdf:Property ;
    rdfs:label 'Escort Required' ;
    rdfs:comment 'Indicates whether the permit holder must be accompanied by an authorised port escort at all times while within restricted ISPS zones. True for visitor and certain contractor permit types; False for credentialed personnel with full unescorted access.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holderDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Holder Date Of Birth' ;
    rdfs:comment 'Date of birth of the individual permit holder in yyyy-MM-dd format. Used for identity verification, background screening, and ISPS compliance records. Null for vehicle permits.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holderEmployerName rdf:type rdf:Property ;
    rdfs:label 'Holder Employer Name' ;
    rdfs:comment 'Name of the organisation that employs or sponsors the permit holder (e.g., shipping line, stevedoring company, customs broker, trucking company). Used to link the individual to their sponsoring port community participant for accountability and audit.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderFullName rdf:type rdf:Property ;
    rdfs:label 'Holder Full Name' ;
    rdfs:comment 'Full legal name of the individual permit holder (person) as it appears on their government-issued identity document. Populated for personnel, contractor, visitor, crew, and emergency permit types. Null for vehicle-only permits.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderIdDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Holder Id Document Number' ;
    rdfs:comment 'The unique number of the government-issued identity document (passport number, national ID number, seafarer book number, etc.) used to verify the permit holder\'s identity during the application process.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderIdDocumentType rdf:type rdf:Property ;
    rdfs:label 'Holder Id Document Type' ;
    rdfs:comment 'Type of government-issued identity document presented by the permit holder at the time of application and verification. Used for ISPS compliance audit and background check records.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderNationality rdf:type rdf:Property ;
    rdfs:label 'Holder Nationality' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the nationality of the individual permit holder. Required for ISPS background screening and customs/immigration compliance reporting.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsZoneAccess rdf:type rdf:Property ;
    rdfs:label 'Isps Zone Access' ;
    rdfs:comment 'Pipe-delimited list of ISPS-designated restricted port zones to which this permit grants access (e.g., berth_side|container_yard|gate_complex|bonded_warehouse|control_room). Defined per the port\'s ISPS Port Facility Security Plan (PFSP). [ENUM-REF-CANDIDATE: berth_side|container_yard|gate_complex|bonded_warehouse|control_room|vessel_deck|hazmat_area — promote to reference product for zone management]' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxEntryCount rdf:type rdf:Property ;
    rdfs:label 'Max Entry Count' ;
    rdfs:comment 'Maximum number of gate entries permitted under this access permit within its validity period. Null indicates unlimited entries (applicable to permanent and multi-entry permits). Enforced by the gate access control system.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitCategory rdf:type rdf:Property ;
    rdfs:label 'Permit Category' ;
    rdfs:comment 'Operational category of the permit defining its usage scope. Permanent permits are issued for long-term employees; temporary permits cover short-term contractors or visitors; single-entry permits are for one-time access events; multi-entry permits allow repeated access within the validity period.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Permit Number' ;
    rdfs:comment 'Permit number of the immediately preceding permit that this record renews or replaces. Enables lineage tracing across permit renewal cycles for ISPS audit and compliance history.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Count' ;
    rdfs:comment 'Number of times this permit has been renewed since its original issuance. Tracks the renewal history for compliance reporting and to identify long-standing permit holders who may require periodic re-vetting under ISPS policy.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsoringVesselImoNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Vessel Imo Number' ;
    rdfs:comment 'IMO vessel identification number of the vessel whose call is the basis for issuing this permit (e.g., for crew shore passes or vessel-specific contractor access). Null for permits not tied to a specific vessel call.' ;
    rdfs:domain ind:PortAccessPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeoCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification Expiry Date' ;
    rdfs:comment 'Expiry date of the participant\'s AEO certification. Customs compliance teams must monitor this date to ensure continued eligibility for expedited customs clearance. Null if AEO certification is not held.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeoCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Aeo Certification Number' ;
    rdfs:comment 'Authorised Economic Operator (AEO) certification number issued by the national customs authority. AEO status indicates a trusted trader with streamlined customs clearance privileges. Applicable to importers, exporters, freight forwarders, and customs brokers.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualTeuVolumeEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Teu Volume Estimate' ;
    rdfs:comment 'Estimated annual container throughput volume in Twenty-foot Equivalent Units (TEU) for this participant. Used for capacity planning, berth scheduling, equipment allocation, and commercial negotiations. Sourced from CRM account profiling.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Standard Carrier Alpha Code (SCAC) or Bureau International des Containers (BIC) operator code assigned to shipping lines and transport operators. Used in BAPLIE stowage plans, COPARN pre-announcements, and IFTMIN transport instructions for EDI interoperability.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the credit limit and financial transactions with this participant (e.g., USD, EUR, SGD). Determines the currency basis for invoicing and accounts receivable.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTier rdf:type rdf:Property ;
    rdfs:label 'Customer Tier' ;
    rdfs:comment 'Commercial segmentation tier assigned to the participant based on volume, revenue contribution, and strategic importance to the port. Determines applicable service level agreements (SLA), tariff schedules, and priority berth allocation. Managed in Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsApproved rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Approved' ;
    rdfs:comment 'Indicates whether the participant is approved to handle, declare, or transport International Maritime Dangerous Goods (IMDG) classified cargo through the port. Approval requires IMDG certification and compliance with SOLAS Chapter VII.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsAccreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Isps Accreditation Expiry Date' ;
    rdfs:comment 'Date on which the participant\'s ISPS accreditation expires. Port security management must be notified prior to expiry to ensure uninterrupted access to secure port areas. Null if ISPS accreditation is not applicable.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ispsAccreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Isps Accreditation Status' ;
    rdfs:comment 'Current ISPS Code accreditation status of the participant. Determines eligibility for access to restricted port security zones and handling of security-sensitive cargo. Mandatory for shipping lines and port agents operating under SOLAS Chapter XI-2.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent operational activity recorded for this participant (e.g., vessel call, container gate-in/out, cargo manifest submission). Used to identify dormant participants and support account review processes.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the port community participant as recorded in the official business registry of the country of incorporation. Used for all formal documentation, contracts, and regulatory filings.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the participant was formally onboarded and approved to conduct operations within the port community. Marks the start of the participant\'s active relationship with the port for SLA measurement and tenure reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle status of the participant\'s account within the port community system. Controls access to port services, gate entry, and TOS operations. \'suspended\' indicates temporary restriction; \'blacklisted\' indicates permanent exclusion pending regulatory review.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pAndIClubName rdf:type rdf:Property ;
    rdfs:label 'P And I Club Name' ;
    rdfs:comment 'Name of the Protection and Indemnity (P&I) insurance club providing liability coverage to the participant, particularly relevant for shipping lines and port agents. Used in claims management and incident response coordination.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pAndIPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'P And I Policy Number' ;
    rdfs:comment 'Policy number of the participant\'s P&I insurance coverage. Required for port entry of vessels and for processing liability claims arising from cargo damage, pollution incidents, or port infrastructure damage.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcsParticipantCode rdf:type rdf:Property ;
    rdfs:label 'Pcs Participant Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the participant within the Port Community System (PCS) for EDI messaging, cargo manifest submissions, and stakeholder communications. Used as the primary operational identifier in PCS integrations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredEdiFormat rdf:type rdf:Property ;
    rdfs:label 'Preferred Edi Format' ;
    rdfs:comment 'Preferred EDI message format used by the participant for electronic communications with the port, including cargo manifests, COPARN pre-announcements, BAPLIE stowage plans, and IFTMIN transport instructions. Drives PCS integration configuration.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressCity rdf:type rdf:Property ;
    rdfs:label 'Registered Address City' ;
    rdfs:comment 'City of the participant\'s official registered business address. Used in conjunction with registered_address_line1 and country_of_incorporation for complete address resolution.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the participant\'s official registered business address as recorded in the company registry. Used for formal correspondence, legal notices, and regulatory filings.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the participant\'s official registered business address. Required for formal correspondence and regulatory submissions.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsLastScreenedDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Last Screened Date' ;
    rdfs:comment 'Date on which the participant was most recently screened against international sanctions lists. Compliance policy typically requires periodic re-screening (e.g., quarterly or upon each vessel call). Supports audit trail for trade compliance reporting.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapCustomerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Account Number' ;
    rdfs:comment 'Customer account number assigned in SAP S/4HANA Financial Accounting (FI) module. Used for invoicing, accounts receivable management, and financial reconciliation of port charges including THC, wharfage, and pilotage fees.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tosAccountCode rdf:type rdf:Property ;
    rdfs:label 'Tos Account Code' ;
    rdfs:comment 'Account code assigned to the participant in the Terminal Operating System (NAVIS N4 or TOPS Expert). Used for container tracking, equipment dispatch authorisation, yard management, and billing within the TOS. Links participant master data to TOS operational records.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Commercial or operating name used by the participant in day-to-day port operations, which may differ from the registered legal name. Used in operational communications and TOS displays.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:truckingLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Trucking Licence Number' ;
    rdfs:comment 'Road transport operator licence number issued by the national transport authority. Required for trucking companies accessing the port gate for container pickup and delivery. Used in gate management within NAVIS N4 for vehicle pre-registration.' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselOperatorFlag rdf:type rdf:Property ;
    rdfs:label 'Vessel Operator Flag' ;
    rdfs:comment 'Indicates whether the participant operates vessels calling at the port. When true, the participant is subject to vessel scheduling, berth allocation, and VTMS coordination requirements. Drives integration with the Vessel Traffic Management System (VTMS).' ;
    rdfs:domain ind:PortCommunityParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipManagerId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Id' ;
    rdfs:comment 'Unique surrogate identifier for each relationship manager assignment record linking a port community participant to a designated port organisation staff member.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRelationshipEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Relationship Employee Id' ;
    rdfs:comment 'Reference to the internal port organisation employee (account manager, commercial manager, or port agent liaison) assigned to manage the customer relationship. Sourced from Oracle HCM Cloud workforce records.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'The annual revenue target in the port\'s base currency assigned to this relationship manager for the customer account. Supports commercial performance management and EBITDA contribution tracking.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualTeuVolumeTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Teu Volume Target' ;
    rdfs:comment 'The agreed annual container volume target in Twenty-foot Equivalent Units (TEU) for this customer under the current relationship manager assignment. Used for commercial planning, KPI tracking, and revenue forecasting.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date on which the relationship manager assignment is scheduled to end or was terminated. Null for open-ended active assignments. Used for succession planning and historical reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'The business reason for creating or modifying this relationship manager assignment. Supports audit trail, workforce planning, and CRM change management reporting. [ENUM-REF-CANDIDATE: new_customer|reassignment|staff_departure|restructure|volume_growth|escalation|rotation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Reference' ;
    rdfs:comment 'Externally-known unique business reference code for this assignment record, used in CRM workflow routing, correspondence, and escalation management. Format: RM-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The date on which the relationship manager assignment became effective. Used for tenure tracking, SLA accountability, and CRM reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classifies the nature of the relationship manager assignment. Permanent indicates a long-term designated assignment; interim indicates a temporary cover arrangement; acting indicates a stand-in during absence; backup indicates a secondary escalation contact; co_managed indicates shared responsibility.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Flag' ;
    rdfs:comment 'Indicates whether the customer has been flagged as at risk of reducing or ceasing port service usage. Set by the relationship manager or CRM system based on engagement signals, volume trends, or competitor activity. Triggers escalation workflows.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageScope rdf:type rdf:Property ;
    rdfs:label 'Coverage Scope' ;
    rdfs:comment 'Defines whether the relationship manager assignment covers all port services or is restricted to specific service lines such as container terminal operations, vessel operations, cargo handling, intermodal logistics, marine services, or trade compliance. [ENUM-REF-CANDIDATE: all_services|container_terminal|vessel_operations|cargo_handling|intermodal|marine_services|trade_compliance — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmOwnerTeam rdf:type rdf:Property ;
    rdfs:label 'Crm Owner Team' ;
    rdfs:comment 'The name of the CRM team or business unit within the port organisation responsible for this relationship assignment. Used for CRM workflow routing, queue management, and team-level performance reporting.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the customer has provided consent for their relationship data to be shared with third-party port community system participants or regulatory bodies. Supports privacy compliance and data governance obligations.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationTier rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier' ;
    rdfs:comment 'Numeric tier indicating the escalation level of this assignment within the CRM workflow routing hierarchy. Tier 1 is the primary point of contact; higher tiers represent escalation paths to senior management. Used for automated CRM escalation routing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handoverDate rdf:type rdf:Property ;
    rdfs:label 'Handover Date' ;
    rdfs:comment 'The date on which the relationship manager assignment was formally handed over from the previous staff member to the current assignee. Null if this is an original assignment with no prior holder.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:handoverNotes rdf:type rdf:Property ;
    rdfs:label 'Handover Notes' ;
    rdfs:comment 'Free-text notes documenting key customer context, open issues, relationship history, and action items transferred during the assignment handover. Classified as confidential due to commercially sensitive customer relationship intelligence.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Isps Clearance Required' ;
    rdfs:comment 'Indicates whether the assigned relationship manager requires International Ship and Port Facility Security (ISPS) Code clearance to access restricted port areas when meeting with this customer. Supports security compliance and access management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredContactChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Channel' ;
    rdfs:comment 'The customer\'s preferred communication channel for engagement with their assigned relationship manager. Supports CRM workflow configuration and communication preference management. EDI and PCS messaging are standard channels in maritime logistics.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Language' ;
    rdfs:comment 'The ISO 639-1 language code representing the customer\'s preferred language for communication with their relationship manager (e.g., en, zh-CN, ar, fr). Supports multilingual port community engagement.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHealthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Health Score' ;
    rdfs:comment 'A manually assessed or CRM-system-generated integer score (typically 1-100) reflecting the overall health and strength of the customer relationship at the time of last review. Used for portfolio risk management and proactive engagement prioritisation.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseTimeTargetHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Target Hours' ;
    rdfs:comment 'The contractually or operationally agreed maximum response time in hours for the assigned relationship manager to respond to customer enquiries or service requests under this assignment. Supports SLA compliance monitoring.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'The agreed frequency at which the relationship manager conducts formal account review meetings with the customer. Supports scheduling of Key Performance Indicator (KPI) reviews and service performance discussions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Classification of the assigned staff member\'s role in managing the customer relationship. Defines the nature of engagement and authority level within the port organisation. [ENUM-REF-CANDIDATE: key_account_manager|commercial_manager|port_agent_liaison|customer_success_manager|trade_development_manager|operations_liaison — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'The SLA tier applicable to this customer relationship assignment, determining response time commitments, service priority, and escalation thresholds. Platinum and gold tiers typically apply to major shipping lines and key accounts.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Account Flag' ;
    rdfs:comment 'Indicates whether the customer is classified as a strategic account requiring executive-level engagement and enhanced service delivery. Strategic accounts typically represent major shipping lines or high-volume cargo owners critical to port revenue.' ;
    rdfs:domain ind:RelationshipManager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentRequestServiceRequestId rdf:type rdf:Property ;
    rdfs:label 'Parent Request Service Request Id' ;
    rdfs:comment 'Self-referencing identifier linking this service request to a parent case when it has been created as a child or sub-case of a larger investigation or grouped complaint. Supports hierarchical case management for complex multi-party disputes.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRequest .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the service request was formally closed after resolution confirmation or customer acceptance. Distinct from resolved_timestamp — a case may be resolved but remain open pending customer confirmation before closure.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmCaseReference rdf:type rdf:Property ;
    rdfs:label 'Crm Case Reference' ;
    rdfs:comment 'The native case identifier from Microsoft Dynamics 365 CRM, the system of record for service requests. Enables bidirectional traceability between the lakehouse silver layer and the operational CRM system for reconciliation and audit purposes.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Post-resolution customer satisfaction rating provided by the customer, typically on a scale of 1 to 5. Captured via automated survey sent after case closure. Used for port service quality KPI reporting and continuous improvement programmes.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Amount' ;
    rdfs:comment 'The monetary value under dispute for billing disputes, demurrage (DMG) claims, detention (DET) charges, Terminal Handling Charge (THC) disputes, or wharfage (WHR) fee challenges. Null for non-financial service requests. Expressed in the port\'s operating currency.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'The reason code for escalation of the service request. Supports root cause analysis of escalation patterns and identification of systemic operational issues.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgRelated rdf:type rdf:Property ;
    rdfs:label 'Imdg Related' ;
    rdfs:comment 'Indicates whether this service request involves dangerous goods classified under the IMDG Code, including misdeclaration complaints, handling incidents, documentation disputes, or storage compliance issues for hazardous cargo.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsRelated rdf:type rdf:Property ;
    rdfs:label 'Isps Related' ;
    rdfs:comment 'Indicates whether this service request relates to an ISPS Code security matter, including access control breaches, security level changes, security incidents, or ISPS compliance complaints. Triggers mandatory security officer review and potential regulatory notification.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lodgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lodgement Timestamp' ;
    rdfs:comment 'The exact date and time when the service request was formally lodged by the customer or captured in the system. This is the principal business event timestamp and the anchor point for all SLA response time calculations.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the regulatory authority to which this service request must be or has been notified (e.g., IMO, National Maritime Safety Authority, Port State Control, WCO, ILO). Populated when regulatory_notification_required is true.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether this service request requires formal notification to a regulatory authority such as the National Maritime Safety Authority, Port State Control (PSC), IMO, or customs authority. Triggered for ISPS security incidents, MARPOL environmental complaints, SOLAS safety violations, or customs fraud allegations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedVesselName rdf:type rdf:Property ;
    rdfs:label 'Related Vessel Name' ;
    rdfs:comment 'Name of the vessel associated with this service request, where the request relates to vessel operations, berth allocation, pilotage, towage, or vessel-related billing disputes. Supports cross-referencing with VTMS and NAVIS N4 vessel records.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenCount rdf:type rdf:Property ;
    rdfs:label 'Reopen Count' ;
    rdfs:comment 'Number of times this service request has been reopened after a previous resolution or closure. A high reopen count indicates unresolved root causes or customer dissatisfaction with the initial resolution. Used in quality and recurrence analysis.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle state of the service request from lodgement through investigation to resolution. Drives workflow routing and SLA monitoring. [ENUM-REF-CANDIDATE: new|open|in_progress|pending_customer|resolved|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the nature of the customer interaction. Distinguishes between general enquiries, formal complaints, billing disputes, operational service requests, incident reports, permit applications, and documentation requests. [ENUM-REF-CANDIDATE: enquiry|complaint|dispute|service_request|incident_report|permit_application|documentation_request — promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standardised outcome code applied at case closure indicating how the service request was resolved (e.g., resolved_in_favour_of_customer, resolved_in_favour_of_port, partial_credit_issued, no_action_required, referred_to_regulator, withdrawn_by_customer). [ENUM-REF-CANDIDATE: resolved_customer_favour|resolved_port_favour|partial_credit|no_action|referred_regulator|withdrawn|information_provided — promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the service request was formally resolved and a resolution communicated to the customer. Used to calculate total resolution time and SLA compliance for resolution targets.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceRequestCategory rdf:type rdf:Property ;
    rdfs:label 'Service Request Category' ;
    rdfs:comment 'Primary business domain category of the service request (e.g., Vessel Operations, Container Handling, Billing and Tariffs, Customs Clearance, Gate Operations, Yard Management, Berth Allocation, Marine Services). Aligns with port operational domains for routing and reporting. [ENUM-REF-CANDIDATE: vessel_operations|container_handling|billing_tariffs|customs_clearance|gate_operations|yard_management|berth_allocation|marine_services|infrastructure|safety — promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRequestDescription rdf:type rdf:Property ;
    rdfs:label 'Service Request Description' ;
    rdfs:comment 'Full narrative description of the service request, complaint, dispute, or enquiry as provided by the customer. Captures the complete context of the issue including relevant operational details such as vessel name, container numbers, BOL references, or terminal locations.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Breached' ;
    rdfs:comment 'Indicates whether the SLA resolution target was breached for this service request. True if the resolved_timestamp exceeded sla_resolution_target or if the case remains unresolved past the target. Used for SLA compliance reporting and penalty calculations.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResolutionTarget rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Target' ;
    rdfs:comment 'The contractual deadline by which the port must fully resolve this service request, calculated from lodgement_timestamp based on the applicable SLA tier, request type, and priority level.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaResponseBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Response Breached' ;
    rdfs:comment 'Indicates whether the SLA first-response target was breached for this service request. True if the acknowledged_timestamp exceeded sla_response_target or if no acknowledgement was sent before the target. Used for SLA compliance reporting and KPI dashboards.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResponseTarget rdf:type rdf:Property ;
    rdfs:label 'Sla Response Target' ;
    rdfs:comment 'The contractual deadline by which the port must send an initial response to the customer for this service request, calculated from lodgement_timestamp based on the applicable SLA tier and priority level.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing granular context within the primary category. Examples include: THC dispute, demurrage claim, container damage, vessel delay, ISPS access, dangerous goods documentation, BOL amendment. Supports detailed analytics and specialist routing.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Sla Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each SLA performance measurement record. Primary key for the sla_performance data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kpiId rdf:type rdf:Property ;
    rdfs:label 'Kpi Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_kpi. Business justification: SLA performance metrics for safety-related service commitments (incident response time, inspection turnaround, permit processing) should reference underlying safety KPIs for integrated performance rep' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Kpi .

ind:breachDirection rdf:type rdf:Property ;
    rdfs:label 'Breach Direction' ;
    rdfs:comment 'Indicates whether the actual value exceeded or fell below the SLA target. Critical for metrics where both over and under performance may be contractually significant (e.g., crane productivity above target is positive, but vessel turnaround time above target is a breach).' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Indicates whether this SLA measurement event constitutes a breach of the committed target. True when actual performance fails to meet the contractual SLA threshold. Drives penalty/credit calculation and escalation workflows in Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'The date and time at which the port community participant was formally notified of this SLA breach or performance event. Populated only when customer_notified_flag is True. Supports contractual notification timeline compliance.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Indicates whether the port community participant has been formally notified of this SLA breach event. Notification may be via Port Community System (PCS) messaging, EDI, or Microsoft Dynamics 365 CRM email. Required for contractual transparency obligations.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Event Timestamp' ;
    rdfs:comment 'The precise real-world timestamp at which this SLA performance measurement was captured or triggered. Represents the principal business event time distinct from audit timestamps. For example, the moment a vessel berth operation completed and the metric was evaluated.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'The end date and time of the measurement period over which SLA performance is evaluated. Defines the closing boundary of the observation window.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'The start date and time of the measurement period over which SLA performance is evaluated. Defines the beginning boundary of the observation window (e.g., start of a vessel call, start of a billing cycle, start of a gate operation window).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this SLA performance measurement event, used for cross-referencing with CRM service records, billing disputes, and customer communications. Sourced from Microsoft Dynamics 365 CRM SLA KPI Instance ID.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricCategory rdf:type rdf:Property ;
    rdfs:label 'Metric Category' ;
    rdfs:comment 'Operational category classifying the SLA metric into a port business domain. Enables domain-level SLA reporting and benchmarking across vessel operations, terminal operations, cargo handling, documentation, billing, and marine services.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Human-readable name of the SLA metric being measured, such as \'Vessel Turnaround Time\', \'Container Gate-In Processing Time\', \'Berth Waiting Time\', \'Crane Productivity (moves/hour)\', \'Documentation Processing Time\', or \'Cargo Availability Notification Lead Time\'.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Description of the corrective or remediation action taken in response to the SLA breach or performance deviation. Examples include \'Additional crane deployed\', \'Priority berth allocation granted\', \'Expedited customs clearance arranged\', \'Service credit issued\'. Supports continuous improvement tracking.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation action for this SLA breach event. \'not_required\' — no breach or waived; \'pending\' — action identified but not started; \'in_progress\' — action underway; \'completed\' — action resolved; \'escalated\' — escalated to senior management or commercial team.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Name or identifier of the port operations staff member or system process that validated this SLA measurement record. Populated when measurement_status transitions to \'validated\'. Supports audit trail and accountability.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'The date and time at which this SLA measurement record was formally validated by port operations staff or an automated validation process. Populated when measurement_status transitions to \'validated\'.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Indicates whether the SLA breach for this measurement event has been formally waived by the port authority. Waivers may be granted for force majeure events, weather disruptions, or commercial goodwill. When True, penalty_applicable_flag should be False.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bolReference rdf:type rdf:Property ;
    rdfs:label 'Bol Reference' ;
    rdfs:comment 'The Bill of Lading reference number associated with the cargo or container for which this SLA measurement applies. Relevant for cargo handling, documentation processing, and customs clearance SLA types. Links to PCS cargo manifest and trade documentation records.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCount rdf:type rdf:Property ;
    rdfs:label 'Breach Count' ;
    rdfs:comment 'The cumulative number of SLA breach events recorded within the current measurement_window period. Used to determine if escalating penalty tiers apply (e.g., first breach = warning, third breach = critical escalation) and to track chronic underperformance patterns.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachThreshold rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold' ;
    rdfs:comment 'The value at which an SLA breach is formally triggered. May differ from target_value to allow a tolerance band (e.g., target vessel turnaround = 24 hours, breach threshold = 28 hours). Expressed in the same unit_of_measure as target_value. Used for automated breach alerting in NAVIS N4 and PCS.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditCapValue rdf:type rdf:Property ;
    rdfs:label 'Credit Cap Value' ;
    rdfs:comment 'The maximum cumulative credit or penalty amount that can be applied within a single measurement_window period, expressed in penalty_currency_code. Protects the port operator from unlimited financial exposure under a single SLA agreement. Confidential commercial contract term.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this SLA profile definition ceases to be binding. Nullable for open-ended profiles. When populated, triggers profile_status transition to \'expired\'. Aligns with contract expiry management in SAP S/4HANA and Microsoft Dynamics 365 CRM.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this SLA profile definition becomes binding and applicable to assigned service agreements. Aligns with contract commencement dates in Microsoft Dynamics 365 CRM and SAP S/4HANA contract management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationContact rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact' ;
    rdfs:comment 'Name or role designation of the primary escalation contact responsible for managing SLA breach resolution on behalf of the port operator. Typically a Port Operations Manager or Commercial Manager. Confidential internal business contact information.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureApplicable rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Applicable' ;
    rdfs:comment 'Indicates whether force majeure clauses apply to this SLA profile, suspending breach penalties during declared force majeure events (e.g., severe weather, port closures, ISPS security incidents). When True, breach measurements are paused during force majeure periods.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementWindow rdf:type rdf:Property ;
    rdfs:label 'Measurement Window' ;
    rdfs:comment 'The time window over which SLA performance is measured and evaluated. \'per_call\' applies to individual vessel calls or gate transactions; \'daily\', \'weekly\', \'monthly\' apply to aggregated operational periods. Determines the frequency of SLA reporting cycles.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'The specific performance metric being governed by this SLA profile (e.g., \'vessel_turnaround_time\', \'container_dwell_time\', \'gate_in_processing_time\', \'documentation_processing_window\', \'billing_dispute_resolution_time\', \'crane_productivity_moves_per_hour\', \'customs_clearance_time\'). Aligns with IAPH KPI framework and NAVIS N4 performance reporting. [ENUM-REF-CANDIDATE: vessel_turnaround_time|container_dwell_time|gate_processing_time|documentation_processing_window|billing_dispute_resolution_time|crane_productivity|customs_clearance_time|berth_occupancy_time — promote to reference product]' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmountApplied rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Applied' ;
    rdfs:comment 'The actual financial penalty or credit amount applied for this specific breach event, expressed in penalty_currency_code. May differ from the standard penalty_value if partial waivers, caps, or commercial adjustments were applied. Feeds into SAP S/4HANA FI credit memo or debit note processing.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Penalty Basis' ;
    rdfs:comment 'The basis on which the penalty_value is calculated when an SLA breach occurs. \'per_event\' applies a flat fee per breach; \'per_hour\' or \'per_day\' applies a rate for each unit of time in breach; \'per_teu\' applies to container volume; \'percentage_of_invoice\' applies a percentage of the relevant THC or service charge.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyValue rdf:type rdf:Property ;
    rdfs:label 'Penalty Value' ;
    rdfs:comment 'The financial penalty or credit amount applied per SLA breach event, expressed in the currency defined by penalty_currency_code. For percentage-based penalties, this represents the percentage of the applicable invoice or THC charge. Confidential as it reflects commercial contract terms.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyWaiverReason rdf:type rdf:Property ;
    rdfs:label 'Penalty Waiver Reason' ;
    rdfs:comment 'Free-text justification for waiving or reducing the standard penalty_value for a breach event. Common reasons include force majeure, port congestion beyond operator control, mutual agreement, or first-time breach goodwill waiver. Required for audit trail in SAP S/4HANA and compliance reporting.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the SLA profile, used in Port Community System (PCS) messaging, EDI exchanges, and customer-facing documentation. Follows the format SLA-[ALPHANUMERIC].' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name of the SLA profile (e.g., \'Premium Shipping Line Tier 1\', \'Standard Freight Forwarder SLA\'). Used in Microsoft Dynamics 365 CRM service agreement records and customer-facing communications.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the SLA profile definition. \'draft\' indicates the profile is under review; \'active\' means it is currently governing service agreements; \'suspended\' means temporarily paused (e.g., during force majeure); \'expired\' means the profile has passed its effective_end_date.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the SLA profile by operational domain. Determines which port business process the SLA governs: vessel operations (turnaround, berthing), container terminal (dwell time, crane productivity), gate processing, documentation (customs, manifests), billing dispute resolution, or cargo handling. [ENUM-REF-CANDIDATE: vessel_operations|container_terminal|gate_processing|documentation|billing_dispute|cargo_handling — promote to reference product]' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'The target date by which the remediation_action must be completed and verified. Drives service request SLA tracking in Microsoft Dynamics 365 CRM and ensures timely resolution of performance issues.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teuVolume rdf:type rdf:Property ;
    rdfs:label 'Teu Volume' ;
    rdfs:comment 'The TEU volume of containers associated with this SLA measurement event. Used for per-TEU penalty calculations, throughput-based SLA assessments, and volume-weighted performance reporting. Sourced from NAVIS N4 TOS container movement records.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFromTarget rdf:type rdf:Property ;
    rdfs:label 'Variance From Target' ;
    rdfs:comment 'The arithmetic difference between actual_value and target_value (actual_value minus target_value). A positive variance indicates underperformance (actual exceeded target); a negative variance indicates overperformance. Expressed in unit_of_measure. Used for SLA performance trending and continuous improvement analysis.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualId rdf:type rdf:Property ;
    rdfs:label 'Accrual Id' ;
    rdfs:comment 'Unique identifier for the financial accrual record. Primary key for the accrual entity.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: Goods received not invoiced (GRNI) accruals link to goods receipts. Port finance accrues for received materials pending vendor invoice. Enables period-end GRNI accrual calculation and reconciliation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:accrualCategory rdf:type rdf:Property ;
    rdfs:label 'Accrual Category' ;
    rdfs:comment 'Business category of the accrual such as port service revenue, demurrage (DMG), wharfage (WHR), terminal handling charge (THC), vendor services, employee entitlements, or other operational categories.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Date' ;
    rdfs:comment 'The date on which the accrual is recognized for accounting purposes. Represents the business event date when the revenue or expense is deemed to have occurred.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualType rdf:type rdf:Property ;
    rdfs:label 'Accrual Type' ;
    rdfs:comment 'Classification of the accrual entry indicating whether it represents revenue accrual, expense accrual, prepayment, deferred revenue, provision, or reversal.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The monetary value of the accrual entry in the transaction currency. Represents the gross amount before any adjustments or allocations.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'The business area code representing the line of business or operational division to which this accrual belongs. Used for cross-company code reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the accrual entry indicating whether it is in draft, posted to the general ledger, reversed, or cancelled.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingText rdf:type rdf:Property ;
    rdfs:label 'Posting Text' ;
    rdfs:comment 'Free-text description providing additional context and explanation for the accrual entry. Used for audit trail and user reference.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference document number such as a purchase order, delivery order (D/O), bill of lading (BOL), or service request number that provides business context for the accrual.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey1 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 1' ;
    rdfs:comment 'First flexible reference field for capturing additional business identifiers such as vessel visit number, container number, or booking reference.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey2 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 2' ;
    rdfs:comment 'Second flexible reference field for capturing supplementary business identifiers or cross-reference keys.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey3 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 3' ;
    rdfs:comment 'Third flexible reference field for capturing tertiary business identifiers or cross-reference keys.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalPeriod rdf:type rdf:Property ;
    rdfs:label 'Reversal Period' ;
    rdfs:comment 'The fiscal period in which the accrual is scheduled to be reversed. Used in conjunction with reversal_date for period-end automation.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The difference between the accrued amount and the actual invoiced or settled amount. Used for variance analysis and accrual accuracy assessment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts payable invoice record. Primary key for the AP invoice entity.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Identifier of the payment run batch in which this invoice was included for payment processing. Used to group invoices paid together in a single payment cycle.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:securityEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Security Equipment Id' ;
    rdfs:comment 'Foreign key linking to security.security_equipment. Business justification: Vendor invoices for security equipment purchases must be matched to equipment records for three-way matching (PO-GR-IR), asset capitalization decisions, and warranty tracking in procurement-to-pay pro' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityEquipment .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Identifier of the vendor bank account to which payment should be made. Links to vendor banking details for electronic payment execution.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The baseline date used for calculating payment due dates based on payment terms. Typically the invoice date or posting date depending on configuration.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The financial document number generated during the clearing process that links the invoice to its payment transaction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'High-level classification of the expense type for this invoice, distinguishing between operational expenditure (OPEX), capital expenditure (CAPEX), and specific operational categories. [ENUM-REF-CANDIDATE: opex|capex|maintenance|fuel|contractor_services|equipment_parts|dredging|pilotage|stevedoring|utilities|professional_services — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The goods receipt document number confirming physical receipt of goods or completion of services. Used in three-way matching to validate invoice against delivery.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the invoice content, services rendered, or goods supplied. Provides business context for the payable obligation.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type indicating the nature of the vendor obligation (standard invoice, credit memo for returns, debit memo for additional charges, etc.). [ENUM-REF-CANDIDATE: standard|credit_memo|debit_memo|prepayment|down_payment|recurring|adjustment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Flag indicating whether this is a recurring invoice that is generated automatically on a regular schedule (e.g., monthly lease payments, annual maintenance contracts).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'The remaining unpaid balance on the invoice. Calculated as net_amount minus paid_amount. Used for AP aging and cash flow forecasting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'The cumulative amount that has been paid against this invoice to date. Used to track partial payments and calculate outstanding balance.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlock rdf:type rdf:Property ;
    rdfs:label 'Payment Block' ;
    rdfs:comment 'A code indicating if payment is blocked for this invoice and the reason (e.g., pending approval, dispute, quality issue, missing documentation). Empty if no block exists.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'The external payment reference number or transaction ID from the bank or payment system (e.g., SWIFT reference, EFT confirmation number, check number).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax deducted from the payment to the vendor as required by tax regulations. This amount is remitted directly to tax authorities.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts payable payment transaction. Primary key.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryApEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ap Employee Id' ;
    rdfs:comment 'The user ID of the person or system account that created the payment record. Used for audit trail and accountability.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bankCharges rdf:type rdf:Property ;
    rdfs:label 'Bank Charges' ;
    rdfs:comment 'Bank fees and charges incurred for processing the payment (wire fees, SWIFT charges, intermediary bank fees). May be borne by company or vendor.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankClearingDate rdf:type rdf:Property ;
    rdfs:label 'Bank Clearing Date' ;
    rdfs:comment 'The date on which the payment cleared through the banking system and funds were credited to the vendor account. Used for reconciliation.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'The date on which the exchange rate was determined. Typically the payment date or value date depending on company policy.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenditureType rdf:type rdf:Property ;
    rdfs:label 'Expenditure Type' ;
    rdfs:comment 'Classification of the payment as operational expenditure (OPEX) or capital expenditure (CAPEX) for financial analysis and EBITDA calculation.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'House Bank Account Number' ;
    rdfs:comment 'The company bank account number from which funds were debited. May be IBAN format for international payments.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankCode rdf:type rdf:Property ;
    rdfs:label 'House Bank Code' ;
    rdfs:comment 'Identifier of the company house bank account from which the payment was made. Links to bank master data.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code of the company code local currency used for statutory reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The net amount actually disbursed to the vendor after deducting discounts, withholding tax, and bank charges. Equals payment_amount minus all deductions.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAdviceSentFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Advice Sent Flag' ;
    rdfs:comment 'Indicates whether remittance advice was sent to the vendor. True if sent, False if not sent or pending.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentAdviceSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Advice Sent Timestamp' ;
    rdfs:comment 'The date and time when remittance advice was transmitted to the vendor via email, EDI, or portal.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The total gross amount disbursed to the vendor in the payment currency. Represents the sum of all invoice amounts cleared by this payment.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Code indicating if payment was blocked for manual review. Blank if no block. Common values: A (payment block), R (manual review required).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the payment was made (e.g., USD, EUR, GBP, SGD). May differ from invoice currency if foreign exchange conversion occurred.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'The externally-known unique payment document number generated by SAP FI-AP payment program. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments about the payment. Used for special instructions, exceptions, or audit trail documentation.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'The priority level assigned to this payment for processing sequence. URGENT (same-day), HIGH (next-day), NORMAL (standard cycle), LOW (deferred).' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProposalNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Proposal Number' ;
    rdfs:comment 'The payment proposal run identifier that selected this payment for processing. Used to trace payment run execution history.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Number' ;
    rdfs:comment 'The unique identifier of the remittance advice document sent to the vendor detailing which invoices were cleared by this payment.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The document number of the reversal transaction if this payment was reversed. Null if not reversed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for payment reversal (e.g., duplicate payment, incorrect amount, vendor request). Null if not reversed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The date on which funds are actually debited from the company bank account. May differ from payment_date due to bank processing delays.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Number' ;
    rdfs:comment 'The vendor account number in the accounts payable sub-ledger. Used for vendor reconciliation and statement generation.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account Number' ;
    rdfs:comment 'The vendor bank account number to which funds were credited. May be IBAN format for international payments.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Swift Code' ;
    rdfs:comment 'The SWIFT/BIC code of the vendor bank for international wire transfers. 8 or 11 character ISO 9362 format.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'The project WBS element for CAPEX payments related to port infrastructure development or capital projects. Links to SAP PS project structure.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTransactionId rdf:type rdf:Property ;
    rdfs:label 'Asset Transaction Id' ;
    rdfs:comment 'Unique identifier for the fixed asset financial transaction record in SAP FI-AA. Primary key for asset transaction tracking.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Reference to the capital project or infrastructure development program associated with the asset transaction. Links CAPEX spending to strategic port development initiatives.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:reversedTransactionAssetTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Asset Transaction Id' ;
    rdfs:comment 'Reference to the original asset transaction that this entry reverses. Null for original postings. Maintains audit trail for corrections.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetTransaction .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'SAP user ID of the approver for transactions requiring workflow approval (large acquisitions, write-downs, disposals). Null for auto-approved transactions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetValueDate rdf:type rdf:Property ;
    rdfs:label 'Asset Value Date' ;
    rdfs:comment 'Date from which the asset transaction affects asset valuation and depreciation calculation. May differ from posting date for backdated transactions.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capexOpexIndicator rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Indicator' ;
    rdfs:comment 'Indicates whether the transaction represents capital expenditure (asset acquisition, major improvement) or operational expenditure (maintenance, repair). Critical for financial analysis and EBITDA calculation.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeAmount rdf:type rdf:Property ;
    rdfs:label 'Company Code Amount' ;
    rdfs:comment 'Transaction amount converted to the company code currency for consolidated financial reporting. Used when transaction currency differs from reporting currency.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCodeCurrency rdf:type rdf:Property ;
    rdfs:label 'Company Code Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the company code reporting currency.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Originating Document Number' ;
    rdfs:comment 'Reference number of the source document that triggered the asset transaction (purchase order, invoice, work order, transfer document). Provides audit trail to originating business event.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingDocumentType rdf:type rdf:Property ;
    rdfs:label 'Originating Document Type' ;
    rdfs:comment 'Type of source document that initiated the asset transaction. Indicates the business process context (procurement, maintenance, internal transfer, manual adjustment). [ENUM-REF-CANDIDATE: purchase_order|invoice|work_order|transfer_order|journal_entry|disposal_document|revaluation_document — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedByUser rdf:type rdf:Property ;
    rdfs:label 'Posted By User' ;
    rdfs:comment 'SAP user ID of the person who posted the asset transaction. Provides accountability and audit trail.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey rdf:type rdf:Property ;
    rdfs:label 'Reference Key' ;
    rdfs:comment 'Additional reference field for external system integration or cross-reference to non-SAP documents (contract numbers, regulatory filing references).' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Monetary value of the asset transaction in the company currency. Represents acquisition cost, depreciation amount, write-down value, or disposal proceeds depending on transaction type.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transaction amount. Typically local port operating currency or USD for international transactions.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business identifier for the asset transaction as recorded in SAP FI-AA. Externally visible transaction reference number.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the asset transaction in the financial system workflow.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionText rdf:type rdf:Property ;
    rdfs:label 'Transaction Text' ;
    rdfs:comment 'Free-text description or notes about the asset transaction. Provides business context, justification, or additional details for audit and reporting.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Type of asset financial transaction: acquisition (new asset purchase), retirement (asset removal), transfer (asset movement between cost centers), write-down (value reduction), depreciation (periodic value allocation), revaluation (fair value adjustment), impairment (loss recognition), disposal (sale), or capitalization (WIP to asset). [ENUM-REF-CANDIDATE: acquisition|retirement|transfer|write_down|depreciation|revaluation|impairment|disposal|capitalization — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique identifier for the budget line item. Primary key.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Id' ;
    rdfs:comment 'Reference to the parent budget plan that contains this line item. Links to the budget plan header.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlan .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Budget lines roll up to org units for detailed budget tracking, variance analysis, and organizational performance measurement in port financial planning and control processes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'Actual amount spent against this budget line to date. Updated from posted financial transactions for budget vs. actual variance analysis.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableBudget rdf:type rdf:Property ;
    rdfs:label 'Available Budget' ;
    rdfs:comment 'Available budget amount calculated as planned amount minus commitment amount minus actual amount. Represents remaining funds available for spending.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level budget category distinguishing capital expenditure from operational expenditure for financial planning and reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetOwner rdf:type rdf:Property ;
    rdfs:label 'Budget Owner' ;
    rdfs:comment 'User ID or name of the budget owner responsible for managing and monitoring this budget line. Typically the cost centre manager or project manager.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget line item. Controls whether the line can be modified or used for budget checking. [ENUM-REF-CANDIDATE: draft|submitted|approved|active|frozen|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Detailed budget type classification for granular expense categorization and analysis. [ENUM-REF-CANDIDATE: personnel|materials|services|equipment|infrastructure|maintenance|utilities|overhead|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Budget version identifier distinguishing original budget from reforecasts and revisions (e.g., V0 for original, V1 for Q1 reforecast, V2 for Q2 reforecast).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Business unit or division code for consolidated reporting and multi-entity budget management.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'Committed amount against this budget line from purchase orders or contracts. Tracks funds encumbered but not yet spent.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area code for cross-organizational cost allocation and reporting (e.g., operations, administration, sales, marine services).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundCode rdf:type rdf:Property ;
    rdfs:label 'Fund Code' ;
    rdfs:comment 'Fund or grant code for tracking restricted or designated funds, particularly for government-funded port infrastructure projects.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentProgramCode rdf:type rdf:Property ;
    rdfs:label 'Investment Program Code' ;
    rdfs:comment 'Investment program or portfolio code for grouping related CAPEX projects and infrastructure development initiatives.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCarryForward rdf:type rdf:Property ;
    rdfs:label 'Is Carry Forward' ;
    rdfs:comment 'Boolean flag indicating whether unused budget from this line should be carried forward to the next fiscal period or year.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Boolean flag indicating whether this budget line is locked from further modifications. Used during budget freeze periods or after final approval.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'Planned budget amount for this line item in the budget plan currency. Represents the approved spending allocation for the fiscal period.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicInitiativeCode rdf:type rdf:Property ;
    rdfs:label 'Strategic Initiative Code' ;
    rdfs:comment 'Strategic initiative or corporate objective code linking budget allocation to strategic planning and KPI targets.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Planned unit price or rate used to calculate the planned amount. Derived from quantity multiplied by unit price.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to procurement.procurement_plan. Business justification: Annual budget planning drives procurement planning. Port procurement plans (bunker fuel, spare parts, services) align with approved budgets. Enables budget-to-procurement plan reconciliation and commi' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:primaryBudgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Employee Id' ;
    rdfs:comment 'Identifier of the employee or manager responsible for this budget plan. Typically a department head or cost center manager.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryBudgetModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Budget Modified By Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the budget plan record. Provides accountability for changes.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of total budget allocated to this line item. Used for proportional distribution and variance analysis (0.00 to 100.00).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineVersionFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Version Flag' ;
    rdfs:comment 'Indicates whether this is the baseline/original approved budget version (True) or a subsequent revision (False). Used for variance analysis.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetLineDescription rdf:type rdf:Property ;
    rdfs:label 'Budget Line Description' ;
    rdfs:comment 'Detailed textual description of the budget line item explaining the purpose and scope of the planned expenditure or investment.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersionCode rdf:type rdf:Property ;
    rdfs:label 'Budget Version Code' ;
    rdfs:comment 'Version identifier for the budget plan (e.g., ORIGINAL, REVISED_Q1, FORECAST_Q2). Distinguishes between original budget, revised budgets, and rolling forecasts.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Business case or rationale for the budgeted amount. Explains strategic alignment, expected benefits, or operational necessity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Contingency Percentage' ;
    rdfs:comment 'Contingency reserve as percentage of planned amount (e.g., 5.00 for 5%). Provides buffer for risk and uncertainty in budget estimates.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'Date when the budget plan was locked to prevent further changes. Establishes baseline for variance reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:multiYearFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Year Flag' ;
    rdfs:comment 'Indicates whether this budget plan spans multiple fiscal years (True) or is single-year (False). Used for long-term CAPEX projects.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningScenario rdf:type rdf:Property ;
    rdfs:label 'Planning Scenario' ;
    rdfs:comment 'Scenario type for budget planning (base case, optimistic, pessimistic, or reforecast). Supports scenario-based planning and sensitivity analysis.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarterlyDistributionQ1 rdf:type rdf:Property ;
    rdfs:label 'Quarterly Distribution Q1' ;
    rdfs:comment 'Planned budget amount allocated to first quarter (Q1). Supports quarterly phasing and cash flow planning.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarterlyDistributionQ2 rdf:type rdf:Property ;
    rdfs:label 'Quarterly Distribution Q2' ;
    rdfs:comment 'Planned budget amount allocated to second quarter (Q2). Supports quarterly phasing and cash flow planning.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarterlyDistributionQ3 rdf:type rdf:Property ;
    rdfs:label 'Quarterly Distribution Q3' ;
    rdfs:comment 'Planned budget amount allocated to third quarter (Q3). Supports quarterly phasing and cash flow planning.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarterlyDistributionQ4 rdf:type rdf:Property ;
    rdfs:label 'Quarterly Distribution Q4' ;
    rdfs:comment 'Planned budget amount allocated to fourth quarter (Q4). Supports quarterly phasing and cash flow planning.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reforecastCycle rdf:type rdf:Property ;
    rdfs:label 'Reforecast Cycle' ;
    rdfs:comment 'Identifies the reforecast cycle when budget was revised (quarterly or mid-year/year-end). Supports rolling forecast process.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'Acceptable variance threshold for budget vs. actual comparison (e.g., 10.00 means ±10%). Triggers alerts when exceeded.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessAreaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Business Area Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether business area assignment is mandatory for all financial postings. Used for cross-company code segment reporting and divisional analysis.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'Four-character code identifying the chart of accounts assigned to this company code. Determines the general ledger (GL) account structure and financial statement mapping.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Code identifying the consolidation group or reporting segment to which this entity belongs. Used for segment reporting under IFRS 8 and management consolidation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'Four-character code identifying the controlling area for management accounting. Links company code to cost centers, profit centers, and internal orders for OPEX and CAPEX tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the jurisdiction where the legal entity is incorporated. Determines applicable tax law, statutory reporting requirements, and regulatory oversight.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'Four-character code identifying the credit control area for accounts receivable (AR) management. Determines credit limit checking, dunning procedures, and payment terms enforcement.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational status of the legal entity. Active entities participate in financial consolidation; inactive entities are excluded from operational reporting but retained for historical analysis.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity by its primary business function within the port authority corporate group. Determines consolidation treatment and reporting hierarchy.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementVersion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Version' ;
    rdfs:comment 'Four-character code identifying the financial statement version used for statutory reporting. Defines the mapping of GL accounts to balance sheet and income statement line items.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearStartMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Start Month' ;
    rdfs:comment 'Numeric month (1-12) when the fiscal year begins. Used for period calculations, budget planning cycles, and year-end close procedures.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Two-character code defining the fiscal year structure (calendar year, April-March, July-June, etc.) and number of posting periods. Determines period-end close schedules and financial reporting cycles.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the primary economic environment in which the entity operates. Used for local currency accounting and translation to group reporting currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for consolidated financial statements at the corporate group level. All entity results are translated into this currency for consolidation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date when the legal entity was officially incorporated or registered with the national corporate registry. Used for entity age calculations and historical analysis.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyClearingAccount rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Account' ;
    rdfs:comment 'Ten-digit GL account number used for intercompany receivables and payables. Used in consolidation eliminations and intercompany reconciliation processes.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier' ;
    rdfs:comment '20-character ISO 17442 Legal Entity Identifier used for global financial reporting, regulatory compliance, and counterparty identification in financial transactions.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Parent Company Code' ;
    rdfs:comment 'Company code of the immediate parent entity in the corporate hierarchy. Used for consolidation rollup, intercompany eliminations, and management reporting structures. Null for the ultimate parent entity.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether profit center assignment is mandatory for all financial postings in this company code. True enforces profit center-based segment reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the legal registered address (suite, floor, building name). Optional field for additional address detail.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City or municipality of the legal registered address. Used for jurisdiction determination and tax domicile classification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the legal registered address. May differ from country of incorporation for entities with cross-border registrations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the legal registered address. Used for mail delivery and geographic classification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'State, province, or administrative region of the legal registered address. Used for sub-national tax reporting and regulatory compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainedEarningsAccount rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account' ;
    rdfs:comment 'Ten-digit GL account number for retained earnings. Used in year-end close procedures to carry forward profit or loss to equity.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or trading name used in operational reports, internal communications, and management dashboards.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationArea rdf:type rdf:Property ;
    rdfs:label 'Valuation Area' ;
    rdfs:comment 'Four-character code defining the valuation area for asset accounting and inventory valuation. Determines depreciation methods, useful life, and asset capitalization thresholds.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for the cost allocation record. Primary key for the cost allocation transaction.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationCycleId rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle Id' ;
    rdfs:comment 'Unique identifier for the allocation cycle or rule set in SAP CO. Groups multiple allocation transactions executed together in a single assessment or distribution run.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationCycle .

ind:initiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Cost allocation runs (overhead distribution, service charge-backs, intercompany recharges) require audit trail of who executed the allocation for financial control, dispute resolution, and SOX complia' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySenderCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Primary Sender Cost Centre Id' ;
    rdfs:comment 'Cost centre from which costs are being allocated. Typically represents shared service departments such as finance, HR, IT, facilities, or shared equipment pools.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:receiverProfitCentreId rdf:type rdf:Property ;
    rdfs:label 'Receiver Profit Centre Id' ;
    rdfs:comment 'Profit centre receiving the allocated costs. Used when allocation targets a profit centre directly for segment reporting and profitability analysis.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCentre .

ind:receiverWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Receiver Wbs Element Id' ;
    rdfs:comment 'WBS element receiving the allocated costs. Used when allocation targets a capital project or infrastructure development initiative tracked in SAP PS.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:reversedAllocationCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Reversed Allocation Cost Allocation Id' ;
    rdfs:comment 'Reference to the original cost allocation record that this transaction reverses. Populated only when reversal_indicator is True.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:allocationBasisQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Quantity' ;
    rdfs:comment 'Quantity of the allocation basis driver consumed by the receiver. For example, number of TEUs handled, number of vessel calls, square metres of floor space, or kilowatt-hours of power consumed.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasisType rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Type' ;
    rdfs:comment 'Statistical key figure or driver used to allocate costs from sender to receiver. TEU/FEU throughput allocates based on container volume handled; vessel calls allocate based on number of ship visits; berth-metres allocate based on berth occupancy; headcount allocates based on employee count; floor area allocates based on square metres occupied; equipment hours allocate based on crane or machinery usage; utility consumption allocates based on power or water usage; fixed percentage or amount allocates based on predetermined rates. [ENUM-REF-CANDIDATE: teu_throughput|feu_throughput|vessel_calls|berth_metres|headcount|floor_area_sqm|equipment_hours|power_consumption_kwh|water_consumption_m3|fixed_percentage|fixed_amount — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationBasisUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Unit' ;
    rdfs:comment 'Unit of measure for the allocation basis quantity. TEU = Twenty-foot Equivalent Unit; FEU = Forty-foot Equivalent Unit; CALLS = vessel calls; METRES = berth-metres; HEADCOUNT = number of employees; SQM = square metres; HOURS = equipment operating hours; KWH = kilowatt-hours; M3 = cubic metres; PERCENT = percentage; AMOUNT = fixed monetary amount. [ENUM-REF-CANDIDATE: TEU|FEU|CALLS|METRES|HEADCOUNT|SQM|HOURS|KWH|M3|PERCENT|AMOUNT — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Description' ;
    rdfs:comment 'Detailed description of the allocation rule or methodology applied. Explains the business logic, allocation basis, and rationale for the cost distribution.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Timestamp' ;
    rdfs:comment 'Date and time when the allocation cycle was executed in SAP CO. Used for audit trail and to distinguish between multiple runs in the same period.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP controlling area in which the allocation is executed. Represents the organizational unit for management accounting and cost controlling.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCode rdf:type rdf:Property ;
    rdfs:label 'Cost Element Code' ;
    rdfs:comment 'Business code of the cost element. Human-readable identifier used in management accounting and cost reporting.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-text description or reference entered at the document header level. Provides context for the allocation run, such as \'Q1 2024 Corporate Overhead Allocation\' or \'Monthly Utilities Distribution - March 2024\'.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderOriginalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Sender Original Cost Amount' ;
    rdfs:comment 'Total original cost amount in the sender cost centre before allocation. Provides context for the allocation and enables reconciliation of sender balances.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Centre Id' ;
    rdfs:comment 'Reference to the parent cost centre in the organizational hierarchy. Enables roll-up reporting from operational teams to divisional and corporate levels for consolidated management accounting.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The primary activity type or service output produced by this cost centre for activity-based costing. Examples include TEU handled, vessel movements, maintenance hours, or administrative transactions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'The approved annual operating expenditure (OPEX) budget allocated to this cost centre for the current fiscal year. Used for budget vs. actual variance analysis and cost control.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used to allocate overhead costs to or from this cost centre. Direct allocation assigns costs directly, activity-based uses cost drivers, proportional uses percentage splits, fixed percentage uses predetermined rates, and driver-based uses volume or activity metrics.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Category' ;
    rdfs:comment 'Functional category grouping cost centres by business domain. Aligns with port operational divisions including terminal operations, marine services (pilotage, towage), infrastructure maintenance, port security (ISPS compliance), administration, commercial and tariffs, finance, human resources, information technology, and safety and environment management. [ENUM-REF-CANDIDATE: terminal_operations|marine_services|infrastructure_maintenance|port_security|administration|commercial|finance|hr|it|safety_environment — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreCode rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying the cost centre in financial systems and reports. Used as the business identifier across SAP FI/CO modules and management accounting reports.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Description' ;
    rdfs:comment 'Extended textual description of the cost centre\'s purpose, scope of operations, and key responsibilities. Provides additional context beyond the cost centre name for reporting and analysis.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreName rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Name' ;
    rdfs:comment 'The full descriptive name of the cost centre representing the organisational unit or functional area (e.g., Container Terminal Operations, Marine Pilotage Services, Port Security Division).' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Status' ;
    rdfs:comment 'Current lifecycle status of the cost centre. Active centres accept cost postings, inactive centres are closed but retain historical data, blocked centres temporarily cannot accept postings, and planned centres are approved but not yet operational.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreType rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Type' ;
    rdfs:comment 'Classification of the cost centre by its primary business function. Operational centres directly support port operations (terminal, marine services), administrative centres support corporate functions, service centres provide internal services, infrastructure centres manage assets, revenue centres generate income, and support centres provide enabling functions.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'Primary cost element group or category associated with this cost centre\'s typical expenditure pattern (e.g., personnel costs, equipment maintenance, utilities, contracted services). Used for cost structure analysis.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Department code representing the organizational unit within the port authority structure. Used for grouping cost centres by functional department for reporting and analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'The level of this cost centre in the organizational hierarchy. Level 1 represents corporate/port authority level, level 2 represents divisions, level 3 represents departments, and deeper levels represent teams or operational units.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isOverheadCentre rdf:type rdf:Property ;
    rdfs:label 'Is Overhead Centre' ;
    rdfs:comment 'Boolean flag indicating whether this cost centre is an overhead or support centre that allocates costs to other operational cost centres. True for administrative, IT, HR, and other support functions that do not directly generate revenue.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Boolean flag indicating whether this cost centre directly generates revenue through billable services or operations. True for terminal operations, marine services, and other revenue-producing activities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the cost centre is locked for cost postings. True prevents new transactions from being posted, typically used during period-end closing or when restructuring the cost centre hierarchy.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCentreCode rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Code' ;
    rdfs:comment 'The profit centre to which this cost centre is assigned for internal profitability analysis. Profit centres represent revenue-generating or cost-responsible units for management reporting and EBITDA analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalCostCentre rdf:type rdf:Property ;
    rdfs:label 'Statistical Cost Centre' ;
    rdfs:comment 'Boolean flag indicating whether this is a statistical cost centre used only for reporting and analysis purposes without accepting actual cost postings. True for virtual or analytical groupings.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this cost centre record is valid. After this date, the cost centre cannot accept new cost postings. Null value indicates the cost centre is open-ended and currently active.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Every port fixed asset (cranes, RTGs, terminal equipment) requires assigned custodian for maintenance accountability, insurance claims, and asset verification audits. Replaces denormalized responsible' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'Sub-asset identifier for components or modules of a main asset (e.g., crane boom, spreader, trolley). Allows component-level depreciation and maintenance tracking.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Cash or fair value received from the sale or disposal of the asset. Used to calculate gain or loss on disposal for P&L reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grantAmount rdf:type rdf:Property ;
    rdfs:label 'Grant Amount' ;
    rdfs:comment 'Amount of government or public funding received for the asset acquisition. Recognized as deferred income and amortized over the asset\'s useful life per IAS 20.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'Total impairment loss recognized when the recoverable amount of the asset falls below its carrying value. Recorded as a write-down in the P&L.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuredValue rdf:type rdf:Property ;
    rdfs:label 'Insured Value' ;
    rdfs:comment 'Declared value of the asset for insurance purposes. May differ from net book value; typically based on replacement cost.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLeased rdf:type rdf:Property ;
    rdfs:label 'Is Leased' ;
    rdfs:comment 'Indicates whether the asset is held under a lease arrangement (finance lease or operating lease under IFRS 16). True if leased, false if owned outright.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDepreciationDate rdf:type rdf:Property ;
    rdfs:label 'Last Depreciation Date' ;
    rdfs:comment 'Date of the most recent depreciation posting. Used to track depreciation run status and ensure monthly postings are complete.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRevaluationDate rdf:type rdf:Property ;
    rdfs:label 'Last Revaluation Date' ;
    rdfs:comment 'Date of the most recent fair value revaluation. Port authorities may revalue land, berths, and specialized infrastructure periodically.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseContractNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Number' ;
    rdfs:comment 'Reference number of the lease agreement if the asset is leased. Links to the contract management system for lease terms and payment schedules.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date the asset was retired from service or disposed. Triggers final depreciation calculation and removal from the active asset register.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revaluationReserve rdf:type rdf:Property ;
    rdfs:label 'Revaluation Reserve' ;
    rdfs:comment 'Cumulative revaluation surplus recognized in equity when the asset is revalued to fair value under the revaluation model. Common for land and specialized port infrastructure.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxDepreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Depreciation Method' ;
    rdfs:comment 'Depreciation method used for tax reporting purposes. May differ from book depreciation method to optimize tax deductions within regulatory limits.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Tax Useful Life Years' ;
    rdfs:comment 'Useful life prescribed by tax regulations for depreciation deductions. Often differs from accounting useful life.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'The primary financial statement category to which this account belongs: balance sheet (B/S), profit and loss (P&L), cost element (CO), clearing, or statistical.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'The hierarchical grouping or classification code used to organize accounts into logical segments for reporting and analysis (e.g., current assets, fixed assets, operating expenses).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortName rdf:type rdf:Property ;
    rdfs:label 'Account Short Name' ;
    rdfs:comment 'Abbreviated name or label for the account used in condensed reports and system displays.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'An alternative or legacy account number used for mapping, migration, or integration purposes with external systems or previous chart of accounts structures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'For balance sheet accounts, indicates whether the account is classified as current (short-term, within 12 months) or non-current (long-term, beyond 12 months).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'The chart of accounts code to which this account belongs. Defines the account structure and numbering scheme used by the organization.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account' ;
    rdfs:comment 'The account number in the group consolidation chart of accounts to which this account maps for corporate consolidation and group reporting purposes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required Flag' ;
    rdfs:comment 'Indicates whether a cost center assignment is mandatory when posting to this account. True if cost center is required, false otherwise.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Indicates whether the account is a primary cost element (direct posting from FI), secondary cost element (internal allocations in CO), or not applicable for cost accounting purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'The field status variant code that controls which fields are required, optional, or suppressed when posting to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Item' ;
    rdfs:comment 'The line item code on the financial statement (balance sheet or income statement) to which this account maps for statutory and management reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Functional Area Required Flag' ;
    rdfs:comment 'Indicates whether a functional area (e.g., operations, administration, sales) must be specified when posting to this account for segment reporting purposes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:houseBankRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'House Bank Required Flag' ;
    rdfs:comment 'Indicates whether a house bank (company bank account) must be specified when posting to this account, typically for cash and bank accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inflationKey rdf:type rdf:Property ;
    rdfs:label 'Inflation Key' ;
    rdfs:comment 'The key used for inflation accounting adjustments in hyperinflationary economies, as required by IAS 29.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCalculationIndicator rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Indicator' ;
    rdfs:comment 'Indicates whether interest should be calculated on balances in this account for interest on arrears, interest on deposits, or other interest calculation purposes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Flag' ;
    rdfs:comment 'Indicates whether individual line item details are stored and can be displayed for this account. True if line item management is active, false if only totals are maintained.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Flag' ;
    rdfs:comment 'Indicates whether open item management is active for this account, requiring postings to be cleared (e.g., for clearing accounts, receivables, payables).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningBlockedFlag rdf:type rdf:Property ;
    rdfs:label 'Planning Blocked Flag' ;
    rdfs:comment 'Indicates whether planning and budgeting activities are blocked for this account. True if planning is not allowed, false if planning is permitted.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingBlockedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Blocked Flag' ;
    rdfs:comment 'Indicates whether direct postings to this account are currently blocked. True if posting is not allowed, false if posting is permitted.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this is a reconciliation account (subledger control account) that summarizes detailed transactions from subsidiary ledgers such as accounts receivable or accounts payable.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Segment Required Flag' ;
    rdfs:comment 'Indicates whether a segment assignment is mandatory when posting to this account for segment reporting under IFRS 8 or management reporting requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'The default sort field used for organizing and displaying line items within this account (e.g., posting date, document number, reference).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The tax treatment category for this account: input tax (VAT/GST on purchases), output tax (VAT/GST on sales), non-taxable, exempt, or not applicable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'The tolerance group code that defines permissible payment differences, exchange rate differences, and cash discount limits for this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Required Flag' ;
    rdfs:comment 'Indicates whether a trading partner (intercompany counterparty) must be specified when posting to this account for intercompany elimination and consolidation purposes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationGroup rdf:type rdf:Property ;
    rdfs:label 'Valuation Group' ;
    rdfs:comment 'The grouping code used for asset valuation, inventory valuation, or other valuation purposes in financial and management accounting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nettingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Netting Agreement Id' ;
    rdfs:comment 'Reference to the master netting agreement governing the offsetting of intercompany balances between the two legal entities.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:reversedTransactionIntercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Intercompany Transaction Id' ;
    rdfs:comment 'Reference to the original intercompany transaction that this record reverses, establishing audit trail for corrections.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:sendingCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Intercompany transactions link two legal entities - this FK represents the sending company. New FK column sending_company_code_id will be created to properly link to the company_code master. The exist' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Indicates whether this transaction must be eliminated in consolidated financial statements to avoid double-counting revenue and expenses within the group.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Current state of the consolidation elimination process: pending elimination, successfully eliminated, requiring reconciliation, or flagged as exception.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Flag' ;
    rdfs:comment 'Indicates whether this transaction is subject to intercompany netting arrangements where offsetting payables and receivables are settled on a net basis.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Profit center code for segment reporting and profitability analysis of the intercompany transaction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'SAP company code of the legal entity receiving the intercompany transaction (e.g., stevedoring subsidiary, property holding entity, joint venture partner).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Variance Amount' ;
    rdfs:comment 'The monetary difference between the sending entity\'s recorded payable and the receiving entity\'s recorded receivable, requiring investigation and resolution.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'SAP company code of the legal entity initiating the intercompany transaction (e.g., port authority headquarters, terminal operating subsidiary).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the intercompany transaction was originally denominated (e.g., USD, EUR, SGD).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The actual business event date when the intercompany service was rendered, goods transferred, or financial obligation incurred.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferPricingDocumentationRef rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Documentation Ref' ;
    rdfs:comment 'Reference to the supporting transfer pricing study, master file, or local file documentation justifying the transaction pricing for tax authority compliance.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The arm\'s length pricing methodology applied to determine the intercompany transaction value for tax compliance (cost-plus, market price, negotiated rate, comparable uncontrolled price, resale-minus).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requesting Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Internal orders (capex projects, maintenance work, operational initiatives) are initiated by specific employees; tracking requestor is essential for approval workflow, budget accountability, and proje' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:responsibleCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Responsible Cost Centre Id' ;
    rdfs:comment 'Identifier of the cost centre responsible for managing and controlling costs for this internal order. Links to the organizational unit accountable for budget execution.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when work was completed under this internal order. Captures real project completion for schedule variance analysis and closeout.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when work commenced under this internal order. Captures real project start for schedule variance analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Formally approved budget amount for the internal order following Capital Appropriation Request (CAR) or budget approval process. Represents authorized spending limit.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carNumber rdf:type rdf:Property ;
    rdfs:label 'Car Number' ;
    rdfs:comment 'Unique identifier for the Capital Appropriation Request document associated with this internal order. Links the order to the formal CAPEX approval process for governance and audit trail.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Total amount committed through purchase orders, contracts, or reservations against this internal order. Represents obligations not yet invoiced.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalClosureDate rdf:type rdf:Property ;
    rdfs:label 'Final Closure Date' ;
    rdfs:comment 'Date when the internal order was fully closed in SAP CO, preventing any further transactions. Marks administrative and financial closure of the order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area code for cost-of-sales accounting, classifying costs by business function (e.g., Operations, Administration, Sales, Maintenance). Supports functional P&L reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentProgram rdf:type rdf:Property ;
    rdfs:label 'Investment Program' ;
    rdfs:comment 'Name or code of the strategic investment program or portfolio to which this internal order belongs (e.g., \'Terminal Expansion 2024\', \'Green Port Initiative\', \'Digital Transformation\'). Groups related CAPEX projects for executive reporting.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Detailed business description of the internal order scope, objectives, and deliverables. Provides comprehensive context for cost tracking and project governance.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCategory rdf:type rdf:Property ;
    rdfs:label 'Order Category' ;
    rdfs:comment 'Business classification of the internal order by investment or activity category: infrastructure for port facilities, equipment for handling machinery, technology for IT/OT systems, dredging for channel maintenance, environmental for compliance projects, safety for OHS initiatives, administrative for overhead. [ENUM-REF-CANDIDATE: infrastructure|equipment|technology|dredging|environmental|safety|administrative — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the internal order by purpose: capital for CAPEX investments, operational for short-term activities, maintenance for asset upkeep campaigns, project for specific initiatives, campaign for time-bound programmes, overhead for administrative costs.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Planned date for completion of work or activities under this internal order. Used for project scheduling and milestone tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Planned date for commencement of work or activities under this internal order. Used for project scheduling and resource planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Planning Budget Amount' ;
    rdfs:comment 'Initial budget amount allocated to the internal order during planning phase, before formal approval. Represents preliminary cost estimate for the project or activity.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'Current phase of the project lifecycle for this internal order. Tracks progression through planning, design, procurement, construction, commissioning, and closeout stages for infrastructure and equipment projects.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Name or code of the business department that initiated the internal order request (e.g., Terminal Operations, Marine Services, Infrastructure Development).' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the individual responsible for this internal order. Used for notifications, approvals, and budget alerts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the individual responsible for managing and controlling this internal order (project manager, cost centre manager, or activity owner). Accountable for budget execution and deliverables.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether this internal order involves safety-critical infrastructure, equipment, or activities requiring Occupational Health and Safety (OHS) oversight and SOLAS compliance. True if safety assessment is required.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementProfile rdf:type rdf:Property ;
    rdfs:label 'Settlement Profile' ;
    rdfs:comment 'SAP CO settlement profile code defining how costs accumulated on this internal order are settled to receiving cost objects (assets, cost centres, GL accounts). Controls period-end cost allocation rules.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReceiverReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Receiver Reference' ;
    rdfs:comment 'Identifier of the specific cost object (asset number, cost centre code, GL account, WBS element) that receives settled costs from this internal order. Used for period-end cost allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReceiverType rdf:type rdf:Property ;
    rdfs:label 'Settlement Receiver Type' ;
    rdfs:comment 'Type of cost object that receives settled costs from this internal order: asset for capitalization, cost_centre for expense allocation, gl_account for direct posting, wbs_element for project integration.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Brief business description of the internal order purpose, typically 40-60 characters summarizing the project or activity (e.g., \'Berth 5 Crane Replacement\', \'Q2 Dredging Campaign\').' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Technical Completion Date' ;
    rdfs:comment 'Date when the internal order was technically completed in SAP CO, preventing new cost postings but allowing settlement and final adjustments. Marks operational closure of the order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry record. Primary key for the journal entry entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'The accounting standard or principle under which this entry is recorded (e.g., IFRS, GAAP, local GAAP). Used for parallel accounting and multi-standard reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverUserName rdf:type rdf:Property ;
    rdfs:label 'Approver User Name' ;
    rdfs:comment 'The username of the person who approved the journal entry for posting. Populated only when workflow approval is required. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselinePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Payment Date' ;
    rdfs:comment 'The baseline date from which payment terms are calculated for vendor invoices and customer receivables. Used for cash flow forecasting and aging analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'The batch input session name if this entry was created via batch processing or interface. Used for mass upload tracking and error resolution.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentre rdf:type rdf:Property ;
    rdfs:label 'Cost Centre' ;
    rdfs:comment 'The cost centre to which costs or revenues are allocated. Used for operational cost control, OPEX tracking, and departmental budgeting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date when the journal entry was created in the system. Used for audit trail and document lifecycle tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The precise date and time when the journal entry was created in the system. Used for audit trail, process timing analysis, and regulatory compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'The type of exchange rate used for currency conversion (e.g., M=average rate, B=bank buying rate, G=bank selling rate). Determines which rate table is applied.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry involves intercompany transactions between different company codes within the enterprise. Used for intercompany reconciliation and elimination.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOrder rdf:type rdf:Property ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'The internal order number for tracking specific cost objects such as maintenance campaigns, marketing initiatives, or temporary projects. Used for short-term cost collection and analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'The ledger or ledger group to which this entry is posted (e.g., 0L=leading ledger, 2L=IFRS ledger, 3L=management ledger). Supports parallel accounting for different reporting standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Flag indicating whether payment for this entry is blocked pending review or dispute resolution. Used for payment control and exception management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Code or text explaining why payment is blocked (e.g., A=dispute, B=missing documentation, C=quality issue). Populated only when payment_block_indicator is true.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentre rdf:type rdf:Property ;
    rdfs:label 'Profit Centre' ;
    rdfs:comment 'The profit centre responsible for the financial result of this entry. Used for management accounting, EBITDA analysis, and internal performance measurement.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is true.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingDate rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Date' ;
    rdfs:comment 'The date used for tax reporting purposes, which may differ from posting date. Used for GST/VAT returns, Business Activity Statement (BAS) reporting, and withholding tax compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'The company code of the intercompany trading partner when intercompany_indicator is true. Used for intercompany reconciliation and consolidation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'The SAP transaction code used to create or post the journal entry (e.g., FB01=post document, FB50=GL posting, F-02=general posting). Used for audit trail and process analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userName rdf:type rdf:Property ;
    rdfs:label 'User Name' ;
    rdfs:comment 'The username of the person who created or posted the journal entry. Used for audit trail and segregation of duties monitoring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Approval Status' ;
    rdfs:comment 'The approval status of the journal entry within the workflow process. Used for manual journal approval controls and segregation of duties enforcement.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for granular financial transaction line tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'The debit amount posted to the general ledger account in the functional currency. Represents increases to asset and expense accounts or decreases to liability, equity, and revenue accounts.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningBlockCode rdf:type rdf:Property ;
    rdfs:label 'Dunning Block Code' ;
    rdfs:comment 'The dunning block indicator preventing automatic dunning notice generation for this line item.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Descriptive text providing additional context or explanation for this journal entry line item.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'The material or inventory item number when this line item relates to goods movement or inventory valuation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerProfitCentreCode rdf:type rdf:Property ;
    rdfs:label 'Partner Profit Centre Code' ;
    rdfs:comment 'The partner profit centre code for internal transfer pricing and intercompany profit elimination.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'The two-digit posting key that controls the posting characteristics such as debit/credit indicator, account type, and field status.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'The segment code for IFRS segment reporting. Represents an operating segment for external financial reporting purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'The special GL indicator for alternative reconciliation accounts such as down payments, bills of exchange, or guarantees.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'The trading partner code for intercompany transactions. Identifies the counterparty company code in consolidated group reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxType rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Type' ;
    rdfs:comment 'The withholding tax type code for statutory tax withholding requirements on payments to vendors or employees.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseLiabilityId rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Id' ;
    rdfs:comment 'Unique identifier for the lease liability record. Primary key for IFRS 16 lease accounting entries.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accumulatedInterestExpense rdf:type rdf:Property ;
    rdfs:label 'Accumulated Interest Expense' ;
    rdfs:comment 'Total interest expense accrued on the lease liability from commencement to the reporting date. Interest is calculated on the outstanding liability balance each period.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetLocation rdf:type rdf:Property ;
    rdfs:label 'Asset Location' ;
    rdfs:comment 'Physical location or terminal where the leased asset is situated. Critical for port operations spanning multiple terminals and berths.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLeaseLiability rdf:type rdf:Property ;
    rdfs:label 'Current Lease Liability' ;
    rdfs:comment 'Outstanding lease liability balance as of the reporting date. Reduced by lease payments and increased by interest accretion each period.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentRouAssetValue rdf:type rdf:Property ;
    rdfs:label 'Current Rou Asset Value' ;
    rdfs:comment 'Current carrying amount of the right-of-use asset after accumulated depreciation and any impairment losses. Updated monthly as part of the depreciation schedule.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Interest rate used to discount lease payments to present value. Represents the rate the lessee would pay to borrow funds to purchase a similar asset in a similar economic environment. Expressed as a decimal (e.g., 0.0450 for 4.50%).' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes an option to extend the lease term beyond the initial period.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionOptionYears rdf:type rdf:Property ;
    rdfs:label 'Extension Option Years' ;
    rdfs:comment 'Number of years available under the extension option if exercised. Nullable if no extension option exists.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccountLiability rdf:type rdf:Property ;
    rdfs:label 'Gl Account Liability' ;
    rdfs:comment 'General ledger account number where the lease liability balance is recorded. Separate accounts typically maintained for current and non-current portions.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountRouAsset rdf:type rdf:Property ;
    rdfs:label 'Gl Account Rou Asset' ;
    rdfs:comment 'General ledger account number where the right-of-use asset is capitalized. Typically classified under property, plant, and equipment or a separate ROU asset category.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialLeaseLiability rdf:type rdf:Property ;
    rdfs:label 'Initial Lease Liability' ;
    rdfs:comment 'Present value of lease payments at lease commencement, discounted using the incremental borrowing rate. Represents the initial obligation to make lease payments.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialRouAssetValue rdf:type rdf:Property ;
    rdfs:label 'Initial Rou Asset Value' ;
    rdfs:comment 'Initial measurement of the right-of-use asset at lease commencement. Equals the initial lease liability plus any initial direct costs, lease payments made at or before commencement, and estimated restoration costs.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRemeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Last Remeasurement Date' ;
    rdfs:comment 'Date when the lease liability was last remeasured due to a change in lease term, discount rate, or lease payments.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseCommencementDate rdf:type rdf:Property ;
    rdfs:label 'Lease Commencement Date' ;
    rdfs:comment 'Date when the lessor makes the underlying asset available for use by the lessee. This is the effective start date for IFRS 16 lease accounting recognition.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Lease End Date' ;
    rdfs:comment 'Contractual end date of the lease term. For port land leases, this may extend 25-99 years. Nullable for perpetual or indefinite concession arrangements.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Status' ;
    rdfs:comment 'Current lifecycle status of the lease liability. Tracks whether the lease is currently in force, has been modified, or has ended.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Lease Term Months' ;
    rdfs:comment 'Total duration of the lease agreement expressed in months. Includes non-cancellable period plus any extension options reasonably certain to be exercised.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseType rdf:type rdf:Property ;
    rdfs:label 'Lease Type' ;
    rdfs:comment 'Classification of the lease arrangement. Port authorities commonly hold land leases from government entities, equipment leases for terminal machinery, and building leases for administrative facilities.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessorName rdf:type rdf:Property ;
    rdfs:label 'Lessor Name' ;
    rdfs:comment 'Name of the entity providing the leased asset. For port authorities, commonly government entities, port land authorities, or equipment vendors.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longTermLiabilityPortion rdf:type rdf:Property ;
    rdfs:label 'Long Term Liability Portion' ;
    rdfs:comment 'Portion of the lease liability due beyond 12 months. Classified as non-current liability on the balance sheet.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modificationDate rdf:type rdf:Property ;
    rdfs:label 'Modification Date' ;
    rdfs:comment 'Date when the most recent lease modification became effective. Nullable if no modifications have occurred.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationDescription rdf:type rdf:Property ;
    rdfs:label 'Modification Description' ;
    rdfs:comment 'Description of the lease modification, including changes to payment terms, lease scope, or extension/termination of the lease term.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationFlag rdf:type rdf:Property ;
    rdfs:label 'Modification Flag' ;
    rdfs:comment 'Indicates whether the lease has been modified after initial recognition. Modifications include changes to scope, consideration, or term.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthlyLeasePayment rdf:type rdf:Property ;
    rdfs:label 'Monthly Lease Payment' ;
    rdfs:comment 'Fixed monthly payment amount due to the lessor. Excludes variable lease payments based on usage or performance.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPaymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Due Date' ;
    rdfs:comment 'Date when the next lease payment is due to the lessor. Used for cash flow planning and accounts payable scheduling.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which lease payments are made to the lessor.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Flag' ;
    rdfs:comment 'Indicates whether the lease includes an option for the lessee to purchase the underlying asset at the end of the lease term.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remeasurementTrigger rdf:type rdf:Property ;
    rdfs:label 'Remeasurement Trigger' ;
    rdfs:comment 'Event that triggered remeasurement of the lease liability. Examples include change in lease term, change in assessment of purchase option, or change in amounts expected under residual value guarantee.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortTermLiabilityPortion rdf:type rdf:Property ;
    rdfs:label 'Short Term Liability Portion' ;
    rdfs:comment 'Portion of the lease liability due within the next 12 months. Classified as current liability on the balance sheet.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Option Flag' ;
    rdfs:comment 'Indicates whether the lessee has the right to terminate the lease before the end of the contractual term.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variablePaymentBasis rdf:type rdf:Property ;
    rdfs:label 'Variable Payment Basis' ;
    rdfs:comment 'Description of the basis for variable lease payments. Examples include TEU throughput, revenue percentage, or inflation index adjustments.' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variablePaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Variable Payment Flag' ;
    rdfs:comment 'Indicates whether the lease includes variable payments that depend on an index, rate, or usage metric (e.g., throughput-based concession fees).' ;
    rdfs:domain ind:LeaseLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentProfitCentreId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Centre Id' ;
    rdfs:comment 'Reference to the parent profit centre in the hierarchy for roll-up reporting and consolidation. Null for top-level profit centres.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCentre .

ind:analysisPeriod rdf:type rdf:Property ;
    rdfs:label 'Analysis Period' ;
    rdfs:comment 'The fiscal period for which this profit centre configuration is valid, in format YYYY.PPP (e.g., 2024.001 for period 1 of fiscal year 2024). Supports period-dependent profit centre attributes.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetProfile rdf:type rdf:Property ;
    rdfs:label 'Budget Profile' ;
    rdfs:comment 'The budget profile or planning template assigned to this profit centre, defining the budgeting methodology and approval workflow for CAPEX and OPEX planning.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The higher-level business unit or division to which this profit centre is assigned within the organizational hierarchy.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit centre is included in EBITDA analysis and segment reporting. True if included in EBITDA calculations, False if excluded.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'The geographic region or territory in which this profit centre operates (e.g., Asia Pacific, Europe, Americas) for regional performance analysis.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTradingFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Trading Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit centre engages in intercompany transactions requiring transfer pricing and elimination entries. True if intercompany trading is enabled.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'The planning granularity level for this profit centre: strategic (long-term corporate planning), tactical (annual budgeting), or operational (monthly/quarterly forecasting).' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Description' ;
    rdfs:comment 'Detailed textual description of the profit centre\'s business scope, services provided, and operational responsibilities for documentation and reporting purposes.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreGroup rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Group' ;
    rdfs:comment 'The profit centre group or hierarchy node to which this profit centre belongs, enabling roll-up reporting and consolidated EBITDA analysis across multiple profit centres.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreName rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Name' ;
    rdfs:comment 'The full business name of the profit centre (e.g., Container Terminal Operations, Bulk Cargo Services, Marine Pilotage Services, Property and Leasing).' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Status' ;
    rdfs:comment 'Current lifecycle status of the profit centre: active (operational and posting-enabled), inactive (closed but retained for historical reporting), blocked (temporarily suspended), or planned (future profit centre not yet operational).' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreType rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Type' ;
    rdfs:comment 'Classification of the profit centre by its business function: operating (revenue-generating business units), service (internal service providers), administrative (overhead functions), investment (capital projects), holding (consolidation entities), or dummy (technical/system entities).' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The unique identifier of this profit centre in the source system, used for data lineage and reconciliation with upstream systems.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentLiabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Contingent Liability Flag' ;
    rdfs:comment 'Indicates whether this record also represents a contingent liability requiring disclosure. True when probability is possible but not probable, or when amount cannot be reliably measured.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Current Provision Amount' ;
    rdfs:comment 'Current carrying amount of the provision after remeasurements, discount unwinding, and partial settlements. Represents the best estimate of expenditure required to settle the present obligation at the reporting date.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Disclosure Required Flag' ;
    rdfs:comment 'Indicates whether this provision requires specific disclosure in the financial statement notes. Material provisions and contingent liabilities require detailed disclosure.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Percentage' ;
    rdfs:comment 'Pre-tax discount rate applied to future cash flows to calculate present value of the provision. Should reflect current market assessments of the time value of money and risks specific to the liability. Expressed as decimal (e.g., 0.0525 for 5.25%).' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountUnwindingAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Unwinding Amount' ;
    rdfs:comment 'Cumulative amount of discount unwinding (accretion expense) recognized as the provision approaches settlement date. Represents the increase in provision due to passage of time.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimationMethod rdf:type rdf:Property ;
    rdfs:label 'Estimation Method' ;
    rdfs:comment 'Method used to estimate the provision amount. Single best estimate for individual obligations; expected value (probability-weighted) for large populations; range midpoint when no single outcome is more likely; expert valuation for complex obligations.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Settlement Date' ;
    rdfs:comment 'Best estimate of the date when the obligation is expected to be settled or discharged. Used for discounting calculations and current/non-current classification.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReassessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Reassessment Date' ;
    rdfs:comment 'Date of the most recent formal reassessment of the provision amount, timing, and probability. Used to track compliance with reassessment requirements.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Estimate Amount' ;
    rdfs:comment 'Upper bound of the estimated range of possible outcomes. Used for sensitivity analysis and risk assessment.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Estimate Amount' ;
    rdfs:comment 'Lower bound of the estimated range of possible outcomes. Used when there is significant uncertainty in the provision measurement.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReassessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Reassessment Date' ;
    rdfs:comment 'Scheduled date for the next formal reassessment. Typically aligned with annual reporting cycle or significant project milestones.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed narrative description of the nature of the obligation, the circumstances that gave rise to it, and the expected method of settlement. Critical for audit trail and disclosure notes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Original Provision Amount' ;
    rdfs:comment 'Initial provision amount recognized at inception, before any remeasurements, settlements, or unwinding of discount. Recorded in functional currency.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:probabilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Probability Assessment' ;
    rdfs:comment 'Assessment of the likelihood that an outflow of resources will be required to settle the obligation. Probable (>50%) triggers recognition; possible (5-50%) requires disclosure only; remote (<5%) requires no action.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionCategory rdf:type rdf:Property ;
    rdfs:label 'Provision Category' ;
    rdfs:comment 'Balance sheet classification indicating whether the provision is expected to be settled within 12 months (current) or beyond 12 months (non-current).' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionNumber rdf:type rdf:Property ;
    rdfs:label 'Provision Number' ;
    rdfs:comment 'Business-facing unique provision reference number used for tracking and reporting. Format: PRV-YYYYNNNN.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionStatus rdf:type rdf:Property ;
    rdfs:label 'Provision Status' ;
    rdfs:comment 'Current lifecycle status of the provision. Recognized when initially recorded; remeasured after annual reassessment; partially settled when payments made; fully settled when obligation discharged; reversed when no longer required; written off when obligation extinguished.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionType rdf:type rdf:Property ;
    rdfs:label 'Provision Type' ;
    rdfs:comment 'Classification of the provision based on the nature of the obligation. Environmental remediation includes dredge spoil disposal and contaminated land cleanup; employee entitlement covers long service leave and redundancy; legal claim provisions for litigation; asset decommissioning for infrastructure removal obligations.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reassessmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Reassessment Frequency' ;
    rdfs:comment 'Scheduled frequency for reviewing and remeasuring the provision. Annual reassessment is mandatory; more frequent reviews may be required for volatile or material provisions.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Amount' ;
    rdfs:comment 'Expected reimbursement amount from third parties. Recognized as a separate asset when virtually certain, but cannot exceed the provision amount.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementExpectedFlag rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Expected Flag' ;
    rdfs:comment 'Indicates whether the entity expects to receive reimbursement from a third party (e.g., insurance, indemnity, government grant) for some or all of the expenditure required to settle the provision.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reimbursementSource rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Source' ;
    rdfs:comment 'Description of the third party or mechanism from which reimbursement is expected. Examples: insurance policy number, government grant program, contractual indemnity clause.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settledAmount rdf:type rdf:Property ;
    rdfs:label 'Settled Amount' ;
    rdfs:comment 'Total amount paid or applied against the provision to date. Represents actual expenditures incurred in settling the obligation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:undiscountedAmount rdf:type rdf:Property ;
    rdfs:label 'Undiscounted Amount' ;
    rdfs:comment 'Estimated future cash outflows required to settle the obligation without applying any discount rate. Used for disclosure and comparison with discounted carrying amount.' ;
    rdfs:domain ind:Provision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivableId rdf:type rdf:Property ;
    rdfs:label 'Receivable Id' ;
    rdfs:comment 'Primary key for receivable' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Classification of the receivable based on days overdue from due date. Used for aging analysis and credit risk assessment.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Amount' ;
    rdfs:comment 'The early payment discount amount available if payment is made within the discount period per payment terms.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashDiscountDate rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Date' ;
    rdfs:comment 'The last date by which payment must be received to qualify for the cash discount. Null if no discount offered.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Current payment clearing status of the receivable. Indicates whether the customer has paid the outstanding amount.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'The date when the most recent dunning notice was sent to the customer for this overdue receivable. Null if never dunned.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingAmount rdf:type rdf:Property ;
    rdfs:label 'Posting Amount' ;
    rdfs:comment 'The gross receivable amount posted in the document currency. Represents the total amount owed by the customer for this transaction.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffReason rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason' ;
    rdfs:comment 'The business reason for writing off this receivable (e.g., bankruptcy, uncollectible, customer dispute settlement). Null if not written off.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassId rdf:type rdf:Property ;
    rdfs:label 'Asset Class Id' ;
    rdfs:comment 'Foreign key to the asset class for capitalization and depreciation purposes (e.g., Buildings, Quay Cranes, Dredging, IT Infrastructure). Determines useful life and depreciation method.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentClass .

ind:investmentProgramId rdf:type rdf:Property ;
    rdfs:label 'Investment Program Id' ;
    rdfs:comment 'Foreign key to the multi-year investment program or capital plan under which this WBS element is funded (e.g., 5-Year Infrastructure Development Plan).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentProgram .

ind:parentWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Element Id' ;
    rdfs:comment 'Foreign key reference to the parent WBS element, enabling hierarchical project structure (e.g., a sub-phase under a major phase). Null for top-level WBS elements.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:primaryWbsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Wbs Employee Id' ;
    rdfs:comment 'Foreign key to the employee responsible for delivering this WBS element. Accountable for scope, schedule, and budget performance.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWbsLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Wbs Last Modified By Employee Id' ;
    rdfs:comment 'Foreign key to the user who last modified this WBS element record. Used for audit trail and accountability in project financial management.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'The total actual expenditure posted to this WBS element to date, including invoiced costs, internal labor, and overhead allocations. Used for budget variance analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Completion Date' ;
    rdfs:comment 'The original approved completion date at project sanction. Used as the reference point for schedule variance reporting and change control.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetVariance rdf:type rdf:Property ;
    rdfs:label 'Budget Variance' ;
    rdfs:comment 'The difference between planned CAPEX budget and forecast final cost (positive = under budget, negative = over budget). Key performance indicator for project financial control.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedCost rdf:type rdf:Property ;
    rdfs:label 'Committed Cost' ;
    rdfs:comment 'The total value of purchase orders and contracts committed against this WBS element but not yet invoiced. Used for funds availability checking and cash flow forecasting.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eiaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Eia Approval Date' ;
    rdfs:comment 'The date when the environmental impact assessment was approved by the relevant regulatory authority. Prerequisite for construction commencement on environmentally sensitive projects.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalImpactAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment Required' ;
    rdfs:comment 'Flag indicating whether this WBS element requires a formal environmental impact assessment under local or international regulations (e.g., dredging, land reclamation).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedAnnualRevenue rdf:type rdf:Property ;
    rdfs:label 'Expected Annual Revenue' ;
    rdfs:comment 'The projected annual revenue increment from this WBS element once operational. Used for business case validation and payback period calculation.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastFinalCost rdf:type rdf:Property ;
    rdfs:label 'Forecast Final Cost' ;
    rdfs:comment 'The estimated cost at completion (EAC) for this WBS element, combining actual spend to date with forecast remaining costs. Used for budget overrun alerts and re-forecasting.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grantReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Reference Number' ;
    rdfs:comment 'The external reference number for government or international development grants funding this WBS element. Used for grant compliance reporting and audit.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCode rdf:type rdf:Property ;
    rdfs:label 'Network Code' ;
    rdfs:comment 'Foreign key to the project network (activity schedule) associated with this WBS element. Links financial tracking to detailed project scheduling and resource planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCapexBudget rdf:type rdf:Property ;
    rdfs:label 'Planned Capex Budget' ;
    rdfs:comment 'The approved capital budget allocated to this WBS element in the base currency. Represents the total authorized spend for this scope of work.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRanking rdf:type rdf:Property ;
    rdfs:label 'Priority Ranking' ;
    rdfs:comment 'The relative priority of this WBS element within the investment portfolio (1 = highest priority). Used for capital allocation decisions and resource prioritization.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'The method by which costs accumulated on this WBS element are settled to fixed assets or cost centers at project closure (full transfer, percentage allocation, or equivalence number distribution).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'The high-level business objective or strategic goal that this WBS element supports (e.g., \'Increase container throughput capacity by 20%\', \'Achieve ISPS Code compliance\').' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'The externally-known alphanumeric code identifying the WBS element in SAP (e.g., P-12345-001). Used in project documentation, purchase orders, and financial reports.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementDescription rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Description' ;
    rdfs:comment 'Full business description of the WBS element, detailing the scope of work (e.g., \'Berth 7 Quay Wall Extension - Foundation Works\').' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementType rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Type' ;
    rdfs:comment 'Classification of the WBS element by its functional role in the project lifecycle: planning (budget holder), execution (work package), billing (revenue recognition), or milestone (phase gate).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Level' ;
    rdfs:comment 'Hierarchical level of the WBS element within the project structure (1 = top level, 2 = second level, etc.). Used for rollup reporting and project organization.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsStatus rdf:type rdf:Property ;
    rdfs:label 'Wbs Status' ;
    rdfs:comment 'Current lifecycle status of the WBS element. Controls whether costs can be posted and whether the element is active for project execution.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisMonitoringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ais Monitoring Required Flag' ;
    rdfs:comment 'Indicates whether vessels anchored in this area must maintain active AIS transmission for VTS monitoring. True if AIS monitoring is mandatory, False otherwise.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:anchorageCategory rdf:type rdf:Property ;
    rdfs:label 'Anchorage Category' ;
    rdfs:comment 'Functional category of the anchorage area defining its designated use: general (standard commercial), quarantine (health inspection), explosives (dangerous cargo), STS transfer (ship-to-ship operations), waiting (pre-berth queue), emergency, or restricted (special authorization required). [ENUM-REF-CANDIDATE: general|quarantine|explosives|sts_transfer|waiting|emergency|restricted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anchorageCode rdf:type rdf:Property ;
    rdfs:label 'Anchorage Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the anchorage area for operational reference and system integration. Used by VTMS and vessel scheduling systems.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anchorageName rdf:type rdf:Property ;
    rdfs:label 'Anchorage Name' ;
    rdfs:comment 'Official name of the anchorage area as designated in port operational documentation and nautical charts.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSizeSquareMeters rdf:type rdf:Property ;
    rdfs:label 'Area Size Square Meters' ;
    rdfs:comment 'Total surface area of the anchorage in square meters. Used for capacity planning and utilization analysis.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chartReference rdf:type rdf:Property ;
    rdfs:label 'Chart Reference' ;
    rdfs:comment 'Reference to the official nautical chart(s) on which this anchorage area is depicted, including chart number and edition.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannelVhf rdf:type rdf:Property ;
    rdfs:label 'Communication Channel Vhf' ;
    rdfs:comment 'Designated VHF radio channel for communication with vessels in this anchorage area (e.g., VHF 12, VHF 16). Used for VTS coordination and port operations.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentSpeedMaxKnots rdf:type rdf:Property ;
    rdfs:label 'Current Speed Max Knots' ;
    rdfs:comment 'Maximum recorded or expected current speed in knots within the anchorage area. Important for anchor holding and vessel safety assessment.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designatedUseRestrictions rdf:type rdf:Property ;
    rdfs:label 'Designated Use Restrictions' ;
    rdfs:comment 'Text description of any specific restrictions or conditions on the use of this anchorage area (e.g., vessel type restrictions, cargo restrictions, time-of-day limitations, environmental restrictions).' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationAuthority rdf:type rdf:Property ;
    rdfs:label 'Designation Authority' ;
    rdfs:comment 'Name of the regulatory or port authority that officially designated this anchorage area and maintains jurisdiction over its use.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationDate rdf:type rdf:Property ;
    rdfs:label 'Designation Date' ;
    rdfs:comment 'Date on which this anchorage area was officially designated and approved for operational use by the competent authority.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distanceToBerthNm rdf:type rdf:Property ;
    rdfs:label 'Distance To Berth Nm' ;
    rdfs:comment 'Distance in nautical miles from the anchorage area center to the nearest operational berth. Used for transit time estimation and operational planning.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceToPilotBoardingNm rdf:type rdf:Property ;
    rdfs:label 'Distance To Pilot Boarding Nm' ;
    rdfs:comment 'Distance in nautical miles from the anchorage area to the designated pilot boarding ground. Relevant for pilotage service coordination.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dredgingMaintenanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Dredging Maintenance Frequency' ;
    rdfs:comment 'Scheduled frequency of dredging maintenance operations to maintain declared water depths in the anchorage area.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyAnchorageFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Anchorage Flag' ;
    rdfs:comment 'Indicates whether this anchorage area is designated for emergency use (e.g., vessel distress, severe weather refuge). True if designated for emergency use, False for normal operations.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalSensitivityFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Sensitivity Flag' ;
    rdfs:comment 'Indicates whether the anchorage area is located in or adjacent to an environmentally sensitive zone requiring special operational protocols. True if environmentally sensitive, False otherwise.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicBoundaryPolygon rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Polygon' ;
    rdfs:comment 'Geographic boundary of the anchorage area defined as a polygon using coordinate pairs (latitude/longitude in decimal degrees). Format: comma-separated coordinate pairs representing the polygon vertices.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingGroundType rdf:type rdf:Property ;
    rdfs:label 'Holding Ground Type' ;
    rdfs:comment 'Type of seabed material in the anchorage area that affects anchor holding capability. Critical for vessel safety and anchorage suitability assessment. [ENUM-REF-CANDIDATE: mud|sand|clay|rock|gravel|coral|mixed|unknown — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsSecurityZone rdf:type rdf:Property ;
    rdfs:label 'Isps Security Zone' ;
    rdfs:comment 'ISPS security zone classification for the anchorage area. Determines access control and security monitoring requirements.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Last Survey Date' ;
    rdfs:comment 'Date of the most recent hydrographic survey conducted for this anchorage area to verify water depths and seabed conditions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitudeCenterDecimal rdf:type rdf:Property ;
    rdfs:label 'Latitude Center Decimal' ;
    rdfs:comment 'Latitude coordinate of the anchorage area center point in decimal degrees (WGS84). Used for mapping, navigation, and distance calculations.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lightingAidsDescription rdf:type rdf:Property ;
    rdfs:label 'Lighting Aids Description' ;
    rdfs:comment 'Description of navigational lighting aids and markers that define or support the anchorage area (e.g., buoys, beacons, range lights).' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitudeCenterDecimal rdf:type rdf:Property ;
    rdfs:label 'Longitude Center Decimal' ;
    rdfs:comment 'Longitude coordinate of the anchorage area center point in decimal degrees (WGS84). Used for mapping, navigation, and distance calculations.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVesselBeamMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Vessel Beam Meters' ;
    rdfs:comment 'Maximum permissible vessel beam (width) in meters for vessels using this anchorage area.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVesselDwt rdf:type rdf:Property ;
    rdfs:label 'Maximum Vessel Dwt' ;
    rdfs:comment 'Maximum permissible vessel DWT that can safely use this anchorage area. Constraint based on water depth, holding ground, and operational safety considerations.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVesselLoaMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Vessel Loa Meters' ;
    rdfs:comment 'Maximum permissible vessel LOA in meters that can safely anchor in this area. Constraint based on swinging circle radius and anchorage dimensions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVesselsSimultaneously rdf:type rdf:Property ;
    rdfs:label 'Maximum Vessels Simultaneously' ;
    rdfs:comment 'Maximum number of vessels that can safely occupy this anchorage area at the same time, based on area dimensions and swinging circle requirements.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextSurveyDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Survey Due Date' ;
    rdfs:comment 'Scheduled date for the next hydrographic survey of this anchorage area to ensure continued accuracy of depth and seabed data.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pilotageRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pilotage Required Flag' ;
    rdfs:comment 'Indicates whether marine pilotage services are mandatory for vessels entering or departing this anchorage area. True if pilotage is required, False if not required.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swingingCircleRadiusMeters rdf:type rdf:Property ;
    rdfs:label 'Swinging Circle Radius Meters' ;
    rdfs:comment 'Required radius in meters for the swinging circle to accommodate vessel movement while at anchor. Calculated based on vessel LOA plus anchor chain scope.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tidalRangeMeters rdf:type rdf:Property ;
    rdfs:label 'Tidal Range Meters' ;
    rdfs:comment 'Average tidal range in meters at the anchorage location. Difference between mean high water and mean low water. Critical for depth calculations and vessel safety.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vtsMonitoringZoneReference rdf:type rdf:Property ;
    rdfs:label 'Vts Monitoring Zone Reference' ;
    rdfs:comment 'Reference code for the VTS monitoring zone that covers this anchorage area. Links to VTMS operational zones for traffic management.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterDepthMaximumMeters rdf:type rdf:Property ;
    rdfs:label 'Water Depth Maximum Meters' ;
    rdfs:comment 'Maximum water depth within the anchorage area measured in meters at Chart Datum. Defines the depth range of the anchorage.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterDepthMinimumMeters rdf:type rdf:Property ;
    rdfs:label 'Water Depth Minimum Meters' ;
    rdfs:comment 'Minimum water depth within the anchorage area measured in meters at Chart Datum. Used to determine vessel draft limitations.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windExposureCategory rdf:type rdf:Property ;
    rdfs:label 'Wind Exposure Category' ;
    rdfs:comment 'Classification of the anchorage area based on exposure to prevailing winds and weather conditions. Affects vessel safety and anchorage suitability.' ;
    rdfs:domain ind:AnchorageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designVesselTypeId rdf:type rdf:Property ;
    rdfs:label 'Design Vessel Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.vessel_type. Business justification: Berths are designed for specific vessel types (container, tanker, bulk, etc.). Currently berth has design_vessel_type as a string. Adding FK to masterdata.vessel_type enables proper vessel-berth compa' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VesselType .

ind:quayWallId rdf:type rdf:Property ;
    rdfs:label 'Quay Wall Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.quay_wall. Business justification: Berths are physically constructed on quay walls. The existing quay_wall_reference (STRING) is a business code that should be replaced with a proper FK to quay_wall.quay_wall_id. This enables joining t' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuayWall .

ind:annualThroughputCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Annual Throughput Capacity Teu' ;
    rdfs:comment 'The estimated annual container throughput capacity of this berth measured in TEU (Twenty-foot Equivalent Unit). Applicable only to container berths. Used for capacity planning, port expansion initiatives, and commercial planning. Null for non-container berths.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avevaReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Aveva Reference Code' ;
    rdfs:comment 'The unique identifier for this berth in the AVEVA Marine Engineering system. Used for integration with port design, infrastructure planning, and engineering documentation. Links berth master data to detailed engineering models and drawings.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthNumber rdf:type rdf:Property ;
    rdfs:label 'Berth Number' ;
    rdfs:comment 'The official berth number or code assigned by the port authority. This is the externally-known identifier used in vessel planning, NAVIS N4, TOPS Expert TOS, and port documentation.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthType rdf:type rdf:Property ;
    rdfs:label 'Berth Type' ;
    rdfs:comment 'Classification of the berth based on the primary cargo or vessel type it serves. Container berths handle containerized cargo, bulk berths handle dry or liquid bulk commodities, RoRo (Roll-on Roll-off) berths serve vehicle carriers, tanker berths handle liquid cargo vessels, and cruise berths accommodate passenger vessels.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bollardCount rdf:type rdf:Property ;
    rdfs:label 'Bollard Count' ;
    rdfs:comment 'The total number of mooring bollards installed along this berth. Bollards are fixed posts to which vessel mooring lines are secured. The count and spacing of bollards determine the mooring capacity and configuration options.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bollardSwlTonnes rdf:type rdf:Property ;
    rdfs:label 'Bollard Swl Tonnes' ;
    rdfs:comment 'The Safe Working Load (SWL) rating of the mooring bollards at this berth, measured in metric tonnes. SWL represents the maximum load that can be safely applied to a bollard during normal mooring operations. All bollards at a berth typically share the same SWL rating.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cfsProximityFlag rdf:type rdf:Property ;
    rdfs:label 'Cfs Proximity Flag' ;
    rdfs:comment 'Boolean flag indicating whether this berth has direct or immediate proximity to a CFS (Container Freight Station) for LCL (Less than Container Load) cargo consolidation and deconsolidation operations.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fenderCondition rdf:type rdf:Property ;
    rdfs:label 'Fender Condition' ;
    rdfs:comment 'The current physical condition of the fender system based on the most recent inspection. Condition ratings range from excellent (new or like-new) to critical (immediate replacement required). Sourced from inspection records in Maximo Asset Management.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fenderEnergyAbsorptionKj rdf:type rdf:Property ;
    rdfs:label 'Fender Energy Absorption Kj' ;
    rdfs:comment 'The total energy absorption capacity of the fender system, measured in kilojoules (kJ). This represents the maximum kinetic energy that the fender system can safely absorb during vessel berthing without damage.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fenderReactionForceKn rdf:type rdf:Property ;
    rdfs:label 'Fender Reaction Force Kn' ;
    rdfs:comment 'The maximum reaction force that the fender system can exert on a berthing vessel, measured in kilonewtons (kN). This is a critical safety parameter for vessel berthing operations and is used in vessel planning to ensure compatibility.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fenderSystemType rdf:type rdf:Property ;
    rdfs:label 'Fender System Type' ;
    rdfs:comment 'The type of fender system installed at this berth. Fenders absorb the kinetic energy of berthing vessels and protect both the vessel and the quay wall structure. Common types include pneumatic (air-filled rubber), foam-filled, buckling (energy-absorbing steel), cylindrical, cone, cell, arch, and unit fenders. [ENUM-REF-CANDIDATE: pneumatic|foam_filled|buckling|cylindrical|cone|cell|arch|unit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Isps Compliant Flag' ;
    rdfs:comment 'Boolean flag indicating whether this berth meets ISPS (International Ship and Port Facility Security) Code requirements. ISPS compliance is mandatory for berths handling international vessels and includes security fencing, access control, surveillance, and lighting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDredgingDate rdf:type rdf:Property ;
    rdfs:label 'Last Dredging Date' ;
    rdfs:comment 'The date of the most recent dredging operation to maintain the required water depth alongside this berth. Dredging is performed periodically to remove sediment accumulation and maintain draft capacity. Sourced from dredging records.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthM rdf:type rdf:Property ;
    rdfs:label 'Length M' ;
    rdfs:comment 'The total usable length of the berth measured in meters along the quay wall. This is the maximum continuous length available for vessel mooring and determines the LOA (Length Overall) capacity.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loaCapacityM rdf:type rdf:Property ;
    rdfs:label 'Loa Capacity M' ;
    rdfs:comment 'The maximum Length Overall (LOA) of a vessel that can be safely accommodated at this berth, measured in meters. This is a critical constraint for vessel planning and berth allocation in NAVIS N4 and TOPS Expert TOS.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDraftM rdf:type rdf:Property ;
    rdfs:label 'Max Draft M' ;
    rdfs:comment 'The maximum vessel draft (depth of the vessel below the waterline) that can be safely accommodated at this berth, measured in meters. This is constrained by the water depth alongside the berth and channel depth.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDwtTonnes rdf:type rdf:Property ;
    rdfs:label 'Max Dwt Tonnes' ;
    rdfs:comment 'The maximum Deadweight Tonnage (DWT) of a vessel that can be accommodated at this berth, measured in metric tonnes. DWT represents the total weight a vessel can safely carry including cargo, fuel, crew, and provisions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mooringFittingTypes rdf:type rdf:Property ;
    rdfs:label 'Mooring Fitting Types' ;
    rdfs:comment 'Comma-separated list of mooring fitting types installed at this berth beyond bollards, such as hooks, rings, cleats, or quick-release hooks. Different vessel types and mooring configurations require different fitting types.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'The scheduled date for the next planned preventive maintenance activity for this berth. Preventive maintenance includes fender replacement, bollard inspection, quay wall repairs, and equipment servicing. Sourced from Maximo Asset Management maintenance plans.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:railConnectionFlag rdf:type rdf:Property ;
    rdfs:label 'Rail Connection Flag' ;
    rdfs:comment 'Boolean flag indicating whether this berth has direct rail connection for intermodal cargo transfer. Rail connectivity is critical for inland container depots (ICD) and bulk cargo operations.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shoreCraneCount rdf:type rdf:Property ;
    rdfs:label 'Shore Crane Count' ;
    rdfs:comment 'The number of shore-based cranes (STS - Ship-to-Shore cranes, QC - Quay Cranes, or MHC - Mobile Harbour Cranes) assigned to or available at this berth for cargo handling operations. Critical for container terminal berths and determines throughput capacity.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shorePowerAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Shore Power Available Flag' ;
    rdfs:comment 'Boolean flag indicating whether shore power (cold ironing) is available at this berth. Shore power allows vessels to shut down auxiliary engines while berthed, reducing emissions and noise. Increasingly required for environmental compliance.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shorePowerCapacityKw rdf:type rdf:Property ;
    rdfs:label 'Shore Power Capacity Kw' ;
    rdfs:comment 'The total electrical power capacity available for shore power connection at this berth, measured in kilowatts (kW). Null if shore power is not available. Typical container vessel shore power requirements range from 1,000 to 10,000 kW.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tidalConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Tidal Constraint Flag' ;
    rdfs:comment 'Boolean flag indicating whether this berth has operational constraints due to tidal conditions. True indicates that vessel movements (arrival, departure, or cargo operations) are restricted to specific tidal windows.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tidalRangeM rdf:type rdf:Property ;
    rdfs:label 'Tidal Range M' ;
    rdfs:comment 'The average tidal range (difference between high tide and low tide) at this berth location, measured in meters. Tidal constraints impact vessel scheduling, particularly for vessels with drafts close to the maximum depth.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseProximityFlag rdf:type rdf:Property ;
    rdfs:label 'Warehouse Proximity Flag' ;
    rdfs:comment 'Boolean flag indicating whether this berth has direct or immediate proximity to covered warehouse facilities. Important for general cargo and break-bulk operations requiring weather-protected storage.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterDepthAlongsideM rdf:type rdf:Property ;
    rdfs:label 'Water Depth Alongside M' ;
    rdfs:comment 'The measured water depth alongside the berth at chart datum, measured in meters. This depth is maintained through regular dredging operations and determines the maximum draft capacity. Sourced from channel depth surveys and dredging records.' ;
    rdfs:domain ind:Berth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:masterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Master Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Navigation channels require designated authority for depth management, dredging decisions, vessel traffic coordination, and VTS monitoring. Critical for safe navigation and regulatory compliance with ' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bearingDegrees rdf:type rdf:Property ;
    rdfs:label 'Bearing Degrees' ;
    rdfs:comment 'Primary compass bearing in degrees (0-360) along which the channel is aligned, used for navigation and traffic planning.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the channel for operational reference and system integration (e.g., CH-001, MAIN-APP).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Official name of the navigable channel, fairway, or approach route within port waters (e.g., Main Approach Channel, Eastern Fairway).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the channel based on its operational purpose within the port navigation system.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentMaintainedDepthCdM rdf:type rdf:Property ;
    rdfs:label 'Current Maintained Depth Cd M' ;
    rdfs:comment 'Current actual maintained depth of the channel measured in meters below Chart Datum (CD), reflecting the most recent survey or dredging results.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designDepthCdM rdf:type rdf:Property ;
    rdfs:label 'Design Depth Cd M' ;
    rdfs:comment 'Designed depth of the channel measured in meters below Chart Datum (CD), representing the minimum guaranteed depth under normal conditions.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designWidthM rdf:type rdf:Property ;
    rdfs:label 'Design Width M' ;
    rdfs:comment 'Designed navigable width of the channel measured in meters at the channel centerline, representing the safe maneuvering corridor.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dredgingAuthority rdf:type rdf:Property ;
    rdfs:label 'Dredging Authority' ;
    rdfs:comment 'Name of the organization or authority responsible for maintaining channel depth through dredging operations (e.g., Port Authority, National Maritime Agency, contracted dredging company).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPermissibleBeamM rdf:type rdf:Property ;
    rdfs:label 'Max Permissible Beam M' ;
    rdfs:comment 'Maximum beam (width) in meters of vessels permitted to transit this channel, based on channel width and safe passing distance requirements.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPermissibleDraftM rdf:type rdf:Property ;
    rdfs:label 'Max Permissible Draft M' ;
    rdfs:comment 'Maximum vessel draft in meters permitted in this channel, calculated from current maintained depth with appropriate under-keel clearance allowances.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPermissibleDwt rdf:type rdf:Property ;
    rdfs:label 'Max Permissible Dwt' ;
    rdfs:comment 'Maximum Deadweight Tonnage (DWT) of vessels permitted to transit this channel under normal conditions, based on channel depth and width constraints.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPermissibleLoaM rdf:type rdf:Property ;
    rdfs:label 'Max Permissible Loa M' ;
    rdfs:comment 'Maximum Length Overall (LOA) in meters of vessels permitted to transit this channel, based on channel length, turning basin dimensions, and maneuvering requirements.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumDepthCdM rdf:type rdf:Property ;
    rdfs:label 'Minimum Depth Cd M' ;
    rdfs:comment 'Minimum recorded depth along the channel measured in meters below Chart Datum (CD), identifying the controlling depth or shoal point.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navigationalAidsDescription rdf:type rdf:Property ;
    rdfs:label 'Navigational Aids Description' ;
    rdfs:comment 'Description of navigational aids marking this channel, including buoys, beacons, leading lights, range markers, and electronic navigation systems (e.g., Lighted buoys port and starboard, Leading lights at 045°).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Survey Date' ;
    rdfs:comment 'Planned date for the next hydrographic survey of the channel to verify maintained depth and identify sedimentation.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sedimentationRateMPerYear rdf:type rdf:Property ;
    rdfs:label 'Sedimentation Rate M Per Year' ;
    rdfs:comment 'Average annual sedimentation rate in meters per year, indicating the rate at which the channel depth decreases due to sediment accumulation.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Survey Frequency Months' ;
    rdfs:comment 'Standard interval in months between scheduled hydrographic surveys for this channel.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tidalWindowRestriction rdf:type rdf:Property ;
    rdfs:label 'Tidal Window Restriction' ;
    rdfs:comment 'Description of any tidal restrictions or windows during which vessel movements are permitted or restricted in this channel (e.g., High tide only, +/- 2 hours of high water, No restrictions).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLengthNm rdf:type rdf:Property ;
    rdfs:label 'Total Length Nm' ;
    rdfs:comment 'Total navigable length of the channel measured in nautical miles from entrance to terminus.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:towageRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Towage Required Flag' ;
    rdfs:comment 'Indicates whether towage (tug assistance) is mandatory for certain vessel classes transiting this channel.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:twoWayTrafficPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Two Way Traffic Permitted Flag' ;
    rdfs:comment 'Indicates whether simultaneous two-way vessel traffic is permitted in this channel, or if one-way traffic restrictions apply.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:underKeelClearanceM rdf:type rdf:Property ;
    rdfs:label 'Under Keel Clearance M' ;
    rdfs:comment 'Minimum required under-keel clearance in meters between vessel keel and channel bottom, applied as a safety margin when calculating maximum permissible draft.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vtsMonitoringZone rdf:type rdf:Property ;
    rdfs:label 'Vts Monitoring Zone' ;
    rdfs:comment 'Reference code or name of the Vessel Traffic Service (VTS) monitoring zone that covers this channel for traffic management and safety oversight.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthSurveyId rdf:type rdf:Property ;
    rdfs:label 'Depth Survey Id' ;
    rdfs:comment 'Unique identifier for the hydrographic depth survey record. Primary key for the depth survey entity.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Survey Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Surveys require qualified coordinator for data quality, regulatory submission to maritime authorities, and dredging decision support. Ensures competency verification and professional accountability fo' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:surveyEquipmentTypeId rdf:type rdf:Property ;
    rdfs:label 'Survey Equipment Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.equipment_type. Business justification: Depth surveys use specific survey equipment types (multibeam sonar, single beam echo sounders). Required for survey planning, equipment scheduling, contractor evaluation, and tracking survey methodolo' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentType .

ind:chartDatumReference rdf:type rdf:Property ;
    rdfs:label 'Chart Datum Reference' ;
    rdfs:comment 'Vertical datum reference used for depth measurements (e.g., Lowest Astronomical Tide, Mean Lower Low Water, Chart Datum). Critical for standardizing depth readings across surveys.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredDepthM rdf:type rdf:Property ;
    rdfs:label 'Declared Depth M' ;
    rdfs:comment 'Official published depth for the surveyed area in meters, typically the minimum depth minus safety margin. Used for vessel traffic management and berth allocation.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depthVarianceM rdf:type rdf:Property ;
    rdfs:label 'Depth Variance M' ;
    rdfs:comment 'Difference between design depth and minimum recorded depth in meters. Positive values indicate shoaling; negative values indicate over-dredging.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designDepthM rdf:type rdf:Property ;
    rdfs:label 'Design Depth M' ;
    rdfs:comment 'Target or design depth for the surveyed area in meters as per port infrastructure specifications. Used to identify dredging requirements.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dredgingPriority rdf:type rdf:Property ;
    rdfs:label 'Dredging Priority' ;
    rdfs:comment 'Priority classification for required dredging work based on navigation safety impact and operational criticality.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dredgingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dredging Required Flag' ;
    rdfs:comment 'Boolean indicator whether the survey results indicate that dredging operations are required to restore design depth. Triggers CAPEX planning workflows.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:horizontalPositioningSystem rdf:type rdf:Property ;
    rdfs:label 'Horizontal Positioning System' ;
    rdfs:comment 'GNSS or positioning system used for horizontal positioning during the survey (e.g., DGPS, RTK GPS). Affects spatial accuracy of depth measurements.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDepthRecordedM rdf:type rdf:Property ;
    rdfs:label 'Maximum Depth Recorded M' ;
    rdfs:comment 'Deepest depth measurement recorded during the survey in meters. Used for understanding channel profile and dredging effectiveness.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanDepthM rdf:type rdf:Property ;
    rdfs:label 'Mean Depth M' ;
    rdfs:comment 'Average depth across the surveyed area in meters. Provides overall depth profile understanding for capacity planning.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumDepthRecordedM rdf:type rdf:Property ;
    rdfs:label 'Minimum Depth Recorded M' ;
    rdfs:comment 'Shallowest depth measurement recorded during the survey in meters. Critical for determining safe navigation clearances and identifying shoaling hazards.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shoalingAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Shoaling Area Description' ;
    rdfs:comment 'Textual description of locations and extent of shoaling areas identified during the survey. Supports dredging scope definition.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shoalingDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Shoaling Detected Flag' ;
    rdfs:comment 'Boolean indicator whether shoaling (sediment accumulation reducing depth) was identified during the survey. Triggers dredging planning workflows.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shoalingVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Shoaling Volume Cbm' ;
    rdfs:comment 'Estimated volume of sediment accumulation in cubic meters (CBM). Used for dredging cost estimation and contractor tendering.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyAccuracyOrder rdf:type rdf:Property ;
    rdfs:label 'Survey Accuracy Order' ;
    rdfs:comment 'IHO S-44 accuracy classification of the survey (Special Order, Order 1a, Order 1b, Order 2). Determines suitability for navigation safety purposes.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyAreaName rdf:type rdf:Property ;
    rdfs:label 'Survey Area Name' ;
    rdfs:comment 'Name or designation of the specific area surveyed within the port (e.g., Main Channel, Berth 5 Pocket, North Anchorage).' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyAreaType rdf:type rdf:Property ;
    rdfs:label 'Survey Area Type' ;
    rdfs:comment 'Classification of the port area surveyed. Determines the criticality and frequency requirements for depth monitoring.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyContractorName rdf:type rdf:Property ;
    rdfs:label 'Survey Contractor Name' ;
    rdfs:comment 'Name of the hydrographic surveying company or contractor that performed the survey. May be internal port authority team or external specialist firm.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyCostAmount rdf:type rdf:Property ;
    rdfs:label 'Survey Cost Amount' ;
    rdfs:comment 'Total cost of the survey in the port\'s operating currency. Used for OPEX tracking and cost-per-survey benchmarking.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Survey Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the survey cost amount.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyCoverageAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Survey Coverage Area Sqm' ;
    rdfs:comment 'Total area covered by the survey in square meters. Used for survey cost validation and coverage completeness assessment.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyDataFileLocation rdf:type rdf:Property ;
    rdfs:label 'Survey Data File Location' ;
    rdfs:comment 'File path or URI to the raw survey data files (e.g., XYZ point cloud, multibeam data). Used for detailed analysis and archival.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyDate rdf:type rdf:Property ;
    rdfs:label 'Survey Date' ;
    rdfs:comment 'Date when the hydrographic depth survey was conducted. Critical for tracking temporal changes in channel depth and shoaling patterns.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyEndTime rdf:type rdf:Property ;
    rdfs:label 'Survey End Time' ;
    rdfs:comment 'Timestamp when the survey operations concluded. Used for calculating survey duration and operational efficiency.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyMethod rdf:type rdf:Property ;
    rdfs:label 'Survey Method' ;
    rdfs:comment 'Technology or methodology used to conduct the depth survey. Determines accuracy, coverage density, and data quality characteristics.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Survey Reference Number' ;
    rdfs:comment 'External reference number or code assigned to the survey by the surveying authority or contractor. Used for cross-referencing with survey reports and documentation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyReportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Survey Report Document Reference' ;
    rdfs:comment 'Reference number or identifier for the detailed survey report document. Links to document management system for full survey deliverables.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStartTime rdf:type rdf:Property ;
    rdfs:label 'Survey Start Time' ;
    rdfs:comment 'Timestamp when the survey operations commenced. Used for tide correlation and survey duration tracking.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyVesselName rdf:type rdf:Property ;
    rdfs:label 'Survey Vessel Name' ;
    rdfs:comment 'Name of the vessel or platform used to conduct the survey. Important for equipment calibration traceability.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tideGaugeReference rdf:type rdf:Property ;
    rdfs:label 'Tide Gauge Reference' ;
    rdfs:comment 'Identifier or name of the tide gauge station used for tidal corrections during the survey. Ensures depth measurements are reduced to chart datum.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verticalPositioningSystem rdf:type rdf:Property ;
    rdfs:label 'Vertical Positioning System' ;
    rdfs:comment 'System used for vertical positioning and tidal corrections (e.g., tide gauge, RTK vertical, pressure sensor). Critical for datum reduction accuracy.' ;
    rdfs:domain ind:DepthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Dredging campaigns may be sponsored/funded by terminal operators or shipping lines requiring deeper drafts for larger vessels. Essential for cost allocation, beneficiary billing, and investment recove' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:dredgingEquipmentTypeId rdf:type rdf:Property ;
    rdfs:label 'Dredging Equipment Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.equipment_type. Business justification: Dredging campaigns use specific equipment types (cutter suction dredger, trailing suction hopper dredger, backhoe dredger). Essential for equipment planning, contractor evaluation, capacity analysis, ' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentType .

ind:environmentalPermitId rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Id' ;
    rdfs:comment 'Reference to the environmental permit authorizing the dredging campaign and spoil disposal activities. Links to infrastructure permit master data.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:primaryDredgingDepthSurveyId rdf:type rdf:Property ;
    rdfs:label 'Primary Dredging Depth Survey Id' ;
    rdfs:comment 'Reference to the bathymetric depth survey conducted before dredging operations commenced. Links to depth survey master data.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepthSurvey .

ind:projectEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Major dredging requires designated engineer for technical oversight, environmental permit compliance, and spoil disposal monitoring. Critical for regulatory submissions and contractor coordination. Re' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetAnchorageAreaId rdf:type rdf:Property ;
    rdfs:label 'Target Anchorage Area Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.anchorage_area. Business justification: Dredging campaigns can target anchorage areas to maintain water depth and remove shoaling. The existing target_channel_id and target_berth_id cover channels and berths. Adding target_anchorage_area_id' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnchorageArea .

ind:targetBerthId rdf:type rdf:Property ;
    rdfs:label 'Target Berth Id' ;
    rdfs:comment 'Reference to the berth pocket where dredging operations are being conducted. Links to berth master data.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Berth .

ind:targetChannelId rdf:type rdf:Property ;
    rdfs:label 'Target Channel Id' ;
    rdfs:comment 'Reference to the navigation channel where dredging operations are being conducted. Links to channel master data.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:actualVolumeDredgedM3 rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Dredged M3' ;
    rdfs:comment 'Actual volume of material (in cubic meters) removed during the dredging campaign as measured by post-dredge surveys.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedDisposalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Approved Disposal Volume M3' ;
    rdfs:comment 'Maximum volume of dredged material (in cubic meters) approved for disposal at the designated site under the environmental permit.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the dredging campaign for external reference and reporting.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCost rdf:type rdf:Property ;
    rdfs:label 'Campaign Cost' ;
    rdfs:comment 'Total cost of the dredging campaign including contractor fees, equipment mobilization, disposal costs, and environmental monitoring expenses. Represents Capital Expenditure (CAPEX) for capital dredging or Operational Expenditure (OPEX) for maintenance dredging.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Business name or title assigned to the dredging campaign for identification and reference purposes.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignNotes rdf:type rdf:Property ;
    rdfs:label 'Campaign Notes' ;
    rdfs:comment 'Free-text notes capturing additional details, lessons learned, or special circumstances related to the dredging campaign.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the dredging campaign indicating its operational state.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when dredging operations were completed and the target depth was achieved.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Contracted Volume M3' ;
    rdfs:comment 'Total volume of material (in cubic meters) contracted to be dredged under the campaign agreement.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorName rdf:type rdf:Property ;
    rdfs:label 'Contractor Name' ;
    rdfs:comment 'Name of the dredging contractor or company responsible for executing the dredging campaign.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeVolumeDisposedM3 rdf:type rdf:Property ;
    rdfs:label 'Cumulative Volume Disposed M3' ;
    rdfs:comment 'Cumulative volume of dredged material (in cubic meters) disposed at the site during the campaign to date.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Demobilization Date' ;
    rdfs:comment 'Date when the dredging contractor and equipment demobilized from the port site after campaign completion.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designDepthTargetM rdf:type rdf:Property ;
    rdfs:label 'Design Depth Target M' ;
    rdfs:comment 'Target depth (in meters below Chart Datum) to be achieved by the dredging campaign. Represents the design specification for the channel or berth pocket.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalMonitoringRequirements rdf:type rdf:Property ;
    rdfs:label 'Disposal Monitoring Requirements' ;
    rdfs:comment 'Description of environmental monitoring requirements mandated by the disposal permit (e.g., water quality sampling frequency, sediment testing protocols, marine life surveys).' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalPermitReference rdf:type rdf:Property ;
    rdfs:label 'Disposal Permit Reference' ;
    rdfs:comment 'Reference number or code of the specific disposal permit authorizing spoil disposal at the designated site.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalType rdf:type rdf:Property ;
    rdfs:label 'Disposal Type' ;
    rdfs:comment 'Method of spoil disposal: open water dumping, confined disposal facility, beneficial reuse (beach nourishment, habitat creation), or land reclamation.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dredgingType rdf:type rdf:Property ;
    rdfs:label 'Dredging Type' ;
    rdfs:comment 'Classification of the dredging campaign: capital dredging (new depth or expansion), maintenance dredging (routine depth preservation), or emergency dredging (unplanned response to siltation or obstruction).' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Count' ;
    rdfs:comment 'Number of environmental incidents or permit violations recorded during the dredging campaign (e.g., turbidity exceedances, unauthorized disposal, marine life impacts).' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Mobilization Date' ;
    rdfs:comment 'Date when the dredging contractor and equipment mobilized to the port site to commence campaign setup.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalDowntimeDays rdf:type rdf:Property ;
    rdfs:label 'Operational Downtime Days' ;
    rdfs:comment 'Number of days dredging operations were suspended due to operational issues (equipment breakdown, vessel traffic conflicts, permit delays).' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Count' ;
    rdfs:comment 'Number of occupational health and safety incidents recorded during the dredging campaign (injuries, near-misses, equipment damage).' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sedimentContaminationLevel rdf:type rdf:Property ;
    rdfs:label 'Sediment Contamination Level' ;
    rdfs:comment 'Classification of dredged sediment contamination level based on laboratory analysis of heavy metals, hydrocarbons, and other pollutants.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spoilDisposalSiteLatitude rdf:type rdf:Property ;
    rdfs:label 'Spoil Disposal Site Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the spoil disposal site in decimal degrees.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spoilDisposalSiteLongitude rdf:type rdf:Property ;
    rdfs:label 'Spoil Disposal Site Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the spoil disposal site in decimal degrees.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spoilDisposalSiteName rdf:type rdf:Property ;
    rdfs:label 'Spoil Disposal Site Name' ;
    rdfs:comment 'Name or designation of the approved site where dredged material (spoil) is disposed.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterQualityMonitoringResults rdf:type rdf:Property ;
    rdfs:label 'Water Quality Monitoring Results' ;
    rdfs:comment 'Summary of water quality monitoring results during the dredging campaign, including turbidity levels, dissolved oxygen, pH, and contaminant concentrations.' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherDowntimeDays rdf:type rdf:Property ;
    rdfs:label 'Weather Downtime Days' ;
    rdfs:comment 'Number of days dredging operations were suspended due to adverse weather conditions (high winds, rough seas, poor visibility).' ;
    rdfs:domain ind:DredgingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Closures impacting vessel operations require formal authorization by responsible officer for accountability, notification workflows, and revenue impact decisions. Replaces denormalized authorizing_off' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:navigationalAidId rdf:type rdf:Property ;
    rdfs:label 'Navigational Aid Id' ;
    rdfs:comment 'Foreign key reference to the navigational aid asset when infrastructure_type is navigational_aid. Nullable for other infrastructure types.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NavigationalAid .

ind:requestingPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Requesting Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Closures may be requested by specific participants (terminal operator requests maintenance window, shipping line requests dredging). Critical for closure request tracking, impact notification, compens' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:utilityNetworkId rdf:type rdf:Property ;
    rdfs:label 'Utility Network Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.utility_network. Business justification: Infrastructure closures can affect utility networks (e.g., power outages, water supply interruptions, shore power unavailability). Adding utility_network_id FK (nullable) enables direct linkage when c' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UtilityNetwork .

ind:affectedVesselCallsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Vessel Calls Count' ;
    rdfs:comment 'Number of scheduled vessel calls impacted by the closure, requiring rescheduling, berth reallocation, or diversion to alternative facilities.' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternativeInfrastructureReference rdf:type rdf:Property ;
    rdfs:label 'Alternative Infrastructure Reference' ;
    rdfs:comment 'Foreign key reference to alternative infrastructure asset designated for use during the closure. Supports operational continuity and vessel rerouting decisions.' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityReductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Capacity Reduction Percentage' ;
    rdfs:comment 'Percentage reduction in operational capacity during partial restriction or reduced capacity closures. Used for throughput forecasting and resource planning.' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Current lifecycle state of the closure event. Tracks progression from planning through execution to completion or cancellation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRevenueImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact Usd' ;
    rdfs:comment 'Projected financial impact of the closure in USD, including lost terminal handling charges, wharfage, and other port tariffs. Used for financial planning and CAPEX justification.' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionCount rdf:type rdf:Property ;
    rdfs:label 'Extension Count' ;
    rdfs:comment 'Number of times the closure period has been extended beyond the original planned end datetime. Used for performance analysis and contractor accountability.' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:infrastructureType rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Type' ;
    rdfs:comment 'Category of port infrastructure affected by the closure. Determines which asset reference field is populated and operational impact scope.' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDistributionList rdf:type rdf:Property ;
    rdfs:label 'Notification Distribution List' ;
    rdfs:comment 'Comma-separated list of stakeholder groups or systems that received closure notifications, including shipping lines, port agents, customs, pilotage services, and Port Community System subscribers.' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDatetime rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Datetime' ;
    rdfs:comment 'Date and time when the closure notification was distributed to stakeholders. Used to verify compliance with advance notice requirements and Service Level Agreements (SLA).' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reasonDetail rdf:type rdf:Property ;
    rdfs:label 'Reason Detail' ;
    rdfs:comment 'Extended narrative description providing specific details about the closure reason, including technical findings, incident reports, or weather conditions.' ;
    rdfs:domain ind:Closure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Name of the regulatory body or port state control authority notified of the closure, when required by International Ship and Port Facility Security (ISPS) Code or national maritime safety regulations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Unique identifier for the infrastructure permit record. Primary key for the infrastructure permit entity.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'Final date by which an appeal or objection to permit conditions or denial can be lodged with the regulatory authority or administrative tribunal.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:associatedInfrastructureType rdf:type rdf:Property ;
    rdfs:label 'Associated Infrastructure Type' ;
    rdfs:comment 'Type of port infrastructure asset or facility that this permit authorizes construction, modification, operation, or maintenance activities for. [ENUM-REF-CANDIDATE: berth|quay_wall|wharf|channel|dredging_area|reclamation_site|warehouse|terminal|breakwater|fender_system|navigational_aid — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditInspectionSchedule rdf:type rdf:Property ;
    rdfs:label 'Audit Inspection Schedule' ;
    rdfs:comment 'Schedule of regulatory audits, site inspections, or compliance reviews mandated by the permit. Includes frequency, scope, and advance notice requirements.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceMonitoringRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Monitoring Requirements' ;
    rdfs:comment 'Description of ongoing monitoring, measurement, and reporting obligations required to demonstrate permit compliance. Includes frequency, parameters, and submission requirements.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsSummary rdf:type rdf:Property ;
    rdfs:label 'Conditions Summary' ;
    rdfs:comment 'High-level summary of the key conditions, restrictions, and obligations imposed by the permit. Provides an overview of compliance requirements without exhaustive detail.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialSecurityAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Security Amount' ;
    rdfs:comment 'Monetary value of the required financial security instrument in the port operating currency. Nullable if no financial security is required.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialSecurityCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Security Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial security amount. Examples include USD, EUR, GBP.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialSecurityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Security Required Flag' ;
    rdfs:comment 'Indicates whether the permit requires the posting of a financial bond, guarantee, or insurance policy to cover potential environmental remediation or restoration costs. True if financial security is mandated.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Description of the geographic area, zone, or specific infrastructure locations covered by this permit. May reference berth numbers, channel sections, or port facility coordinates.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyConditions rdf:type rdf:Property ;
    rdfs:label 'Key Conditions' ;
    rdfs:comment 'Detailed listing of critical permit conditions that must be met for ongoing compliance. Includes specific technical requirements, operational constraints, monitoring obligations, and reporting deadlines.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Outcome' ;
    rdfs:comment 'Result of the most recent regulatory inspection indicating compliance status. Non-compliant outcomes may trigger corrective action requirements or enforcement proceedings.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Scheduled date for the next regulatory inspection or compliance audit. Used for operational planning and readiness preparation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceCount rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Count' ;
    rdfs:comment 'Total number of non-compliance incidents or violations recorded against this permit since issuance. Used for risk assessment and compliance performance tracking.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonComplianceHistory rdf:type rdf:Property ;
    rdfs:label 'Non Compliance History' ;
    rdfs:comment 'Record of past non-compliance incidents, violations, or breaches associated with this permit. Includes dates, nature of violations, and corrective actions taken.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Target date for permit renewal application or renewal decision. Used for proactive compliance management and to avoid lapses in authorization.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Lead Time Days' ;
    rdfs:comment 'Number of days before expiry that the renewal application must be submitted to the issuing authority. Critical for compliance planning and avoiding operational disruptions.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the infrastructure activities, works, or operations covered under this permit. Includes the nature, scale, and location of authorized activities.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Validity Period Months' ;
    rdfs:comment 'Duration of the permit validity period expressed in months from the effective date. Used for planning renewal cycles and compliance calendars.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Employee identifier for the project manager, linking to HR system for contact details and organizational assignment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryContractorVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Contractor Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Infrastructure projects (berth construction, quay wall upgrades, reclamation) require primary contractor tracking for payment processing, performance evaluation, and audit compliance. Links project ca' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:sponsorPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Major infrastructure projects often have primary beneficiary/sponsor (terminal operator, shipping line consortium) who funds or co-funds development. Essential for project sponsorship tracking, cost r' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the project achieved substantial completion and was handed over to operations. Null if project is not yet complete.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualExpenditureToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Expenditure To Date' ;
    rdfs:comment 'Cumulative actual expenditure incurred on the project to date in local currency. Includes all committed and paid costs across design, procurement, construction, and project management.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedCapexBudget rdf:type rdf:Property ;
    rdfs:label 'Approved Capex Budget' ;
    rdfs:comment 'Total approved capital expenditure budget for the project in local currency. Represents the authorized funding envelope for all project costs including design, construction, equipment, and contingency.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avevaProjectReference rdf:type rdf:Property ;
    rdfs:label 'Aveva Project Reference' ;
    rdfs:comment 'Reference identifier linking to the AVEVA Marine Engineering system project record for design, engineering drawings, and infrastructure planning documentation.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthLengthIncreaseM rdf:type rdf:Property ;
    rdfs:label 'Berth Length Increase M' ;
    rdfs:comment 'Additional berth length in meters created or made available by this project. Applicable to berth construction, expansion, or rehabilitation projects.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all financial amounts in this project record (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityIncreaseTeu rdf:type rdf:Property ;
    rdfs:label 'Capacity Increase Teu' ;
    rdfs:comment 'Projected increase in container handling capacity measured in TEU per annum resulting from this infrastructure project. Null for non-container infrastructure.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelDepthM rdf:type rdf:Property ;
    rdfs:label 'Channel Depth M' ;
    rdfs:comment 'Design or target channel depth below chart datum in meters for dredging or channel deepening projects. Determines maximum vessel draft that can be accommodated.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designGroundLevelM rdf:type rdf:Property ;
    rdfs:label 'Design Ground Level M' ;
    rdfs:comment 'Target elevation above chart datum for reclaimed land or infrastructure platform, measured in meters. Critical for drainage, flood protection, and operational planning.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designVesselDwt rdf:type rdf:Property ;
    rdfs:label 'Design Vessel Dwt' ;
    rdfs:comment 'Maximum vessel deadweight tonnage that the infrastructure is designed to accommodate. Key parameter for berth structural design and channel depth requirements.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designVesselLoaM rdf:type rdf:Property ;
    rdfs:label 'Design Vessel Loa M' ;
    rdfs:comment 'Maximum vessel length overall in meters that the infrastructure is designed to accommodate. Critical design parameter for berth and channel projects.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ispsSecurityAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Isps Security Assessment Required' ;
    rdfs:comment 'Indicates whether an ISPS security assessment and approval is required for this infrastructure project due to impact on port facility security zones or access control.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current project management phase per PMI/ISO 21500 methodology: initiation, planning, execution, monitoring and controlling, or closure.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Planned or baseline completion date for the project, representing the target date for substantial completion and handover to operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectCategory rdf:type rdf:Property ;
    rdfs:label 'Project Category' ;
    rdfs:comment 'Primary infrastructure category being developed or modified: berth, quay wall, wharf, warehouse, container yard, navigational aid, shipping channel, breakwater, terminal building, or utility infrastructure. [ENUM-REF-CANDIDATE: berth|quay_wall|wharf|warehouse|yard|navigation_aid|channel|breakwater|terminal|utility — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known unique business identifier for the infrastructure project, typically following port authority naming convention (e.g., CAP-2024-BERTH).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Full descriptive name of the infrastructure project as known to stakeholders and used in official documentation.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the infrastructure project: concept (initial idea), feasibility (study phase), design (engineering), approved (funding secured), tendering (contractor selection), construction (active build), commissioning (testing), completed (operational handover), suspended (temporarily halted), or cancelled (terminated). [ENUM-REF-CANDIDATE: concept|feasibility|design|approved|tendering|construction|commissioning|completed|suspended|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the infrastructure project by nature of work: new construction (greenfield), rehabilitation (restoration of existing), expansion (capacity increase), upgrade (modernization), reclamation (land creation), or dredging (channel deepening).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclamationFillMethod rdf:type rdf:Property ;
    rdfs:label 'Reclamation Fill Method' ;
    rdfs:comment 'Method used for land reclamation projects: hydraulic fill (pumped slurry), dry fill (trucked material), mixed fill (combination), or not applicable for non-reclamation projects.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall project risk assessment rating based on technical complexity, environmental factors, stakeholder impact, and delivery uncertainty.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Settlement Monitoring Required' ;
    rdfs:comment 'Indicates whether ongoing geotechnical settlement monitoring is required for this project, typically true for reclamation and major foundation works.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsoringBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Business Unit' ;
    rdfs:comment 'Name of the port authority division or business unit sponsoring and funding the project (e.g., Terminal Operations, Marine Services, Commercial Development).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderConsultationRequired rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Consultation Required' ;
    rdfs:comment 'Indicates whether formal stakeholder consultation process is required for this project, typically true for projects with significant community, environmental, or commercial impact.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceTechnicianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Technician Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Critical safety equipment requires assigned qualified technician for maintenance accountability, competency verification, and emergency response. Essential for IALA compliance and port state control i' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:replacementAidNavigationalAidId rdf:type rdf:Property ;
    rdfs:label 'Replacement Aid Navigational Aid Id' ;
    rdfs:comment 'Reference to the navigational aid that replaced this aid if it was decommissioned and superseded. Null if not replaced or still active.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NavigationalAid .

ind:aidCode rdf:type rdf:Property ;
    rdfs:label 'Aid Code' ;
    rdfs:comment 'Externally-known unique code or designation for the navigational aid, used in nautical charts and port documentation. Typically follows port authority or hydrographic office naming conventions.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aidName rdf:type rdf:Property ;
    rdfs:label 'Aid Name' ;
    rdfs:comment 'Human-readable name or designation of the navigational aid (e.g., \'Main Channel Buoy #3\', \'Port Entrance Leading Light\', \'Eastern Breakwater Beacon\').' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aidType rdf:type rdf:Property ;
    rdfs:label 'Aid Type' ;
    rdfs:comment 'Classification of the navigational aid by its physical form and function. Determines the aid\'s role in the port\'s navigational infrastructure. [ENUM-REF-CANDIDATE: buoy|beacon|leading_light|lighthouse|channel_marker|range_light|sector_light|vts_radar|ais_aton|sound_signal|daymark — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisAtonType rdf:type rdf:Property ;
    rdfs:label 'Ais Aton Type' ;
    rdfs:comment 'Classification of AIS AtoN: real (physical aid with AIS transmitter), synthetic (virtual aid broadcast by base station), or virtual (digital-only aid). Null for non-AIS aids.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Availability Target Percent' ;
    rdfs:comment 'Target operational availability percentage for this navigational aid (e.g., 99.8%). Based on IALA availability categories and criticality level.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bodyColor rdf:type rdf:Property ;
    rdfs:label 'Body Color' ;
    rdfs:comment 'Color or color pattern of the navigational aid body/structure (e.g., \'red\', \'green\', \'red-white horizontal bands\', \'yellow-black vertical stripes\'). Used for daytime visual identification.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Chart Reference Number' ;
    rdfs:comment 'Reference number or identifier used on official nautical charts to denote this navigational aid. Enables cross-reference between physical aids and published charts.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Importance classification of the navigational aid based on its role in safe navigation. Critical aids require highest availability and fastest repair response times.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the navigational aid was permanently decommissioned and removed from service. Null for active aids.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:focalHeightM rdf:type rdf:Property ;
    rdfs:label 'Focal Height M' ;
    rdfs:comment 'Height of the light focal plane above mean sea level in meters. Critical for calculating geographic range and visibility. Null for non-illuminated aids.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ialaClassification rdf:type rdf:Property ;
    rdfs:label 'Iala Classification' ;
    rdfs:comment 'IALA buoyage system classification indicating the aid\'s navigational purpose and positioning convention. Critical for international maritime safety compliance. [ENUM-REF-CANDIDATE: lateral_port|lateral_starboard|cardinal_north|cardinal_south|cardinal_east|cardinal_west|isolated_danger|safe_water|special_mark|emergency_wreck|new_danger — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the navigational aid was first installed and commissioned for operational use.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lightCharacter rdf:type rdf:Property ;
    rdfs:label 'Light Character' ;
    rdfs:comment 'Distinctive light pattern or characteristic displayed by the aid (e.g., \'Fl(2)R 10s\', \'Iso G 4s\', \'Q(6)+LFl 15s\'). Describes the rhythm, color, and period of the light signal. Null for non-illuminated aids.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightColor rdf:type rdf:Property ;
    rdfs:label 'Light Color' ;
    rdfs:comment 'Primary color of the light emitted by the navigational aid. Null for non-illuminated aids. Color coding follows IALA conventions for lateral and cardinal marks. [ENUM-REF-CANDIDATE: red|green|white|yellow|blue|amber|orange — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mmsiNumber rdf:type rdf:Property ;
    rdfs:label 'Mmsi Number' ;
    rdfs:comment 'Nine-digit MMSI number assigned to AIS-equipped navigational aids for automatic identification and tracking. Null for non-AIS aids.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer\'s model or product number for the navigational aid. Used for technical specifications lookup and spare parts ordering.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mooringType rdf:type rdf:Property ;
    rdfs:label 'Mooring Type' ;
    rdfs:comment 'Method by which the navigational aid is secured or anchored (e.g., sinker weight, chain mooring, pile-mounted, fixed to structure). Null or \'none\' for shore-based fixed structures.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalRangeNm rdf:type rdf:Property ;
    rdfs:label 'Nominal Range Nm' ;
    rdfs:comment 'Nominal range of the light in nautical miles under standard atmospheric conditions (meteorological visibility of 10 nautical miles). Null for non-illuminated aids.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerSourceType rdf:type rdf:Property ;
    rdfs:label 'Power Source Type' ;
    rdfs:comment 'Primary power source used to operate the navigational aid. Null for passive aids (daymarks, unlit buoys). [ENUM-REF-CANDIDATE: mains_electric|solar|battery|wind|diesel_generator|gas|hybrid|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raconCode rdf:type rdf:Property ;
    rdfs:label 'Racon Code' ;
    rdfs:comment 'Single-letter Morse code identifier transmitted by the radar beacon (RACON) when interrogated by ship radar. Null for aids without RACON capability.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reflectiveMaterial rdf:type rdf:Property ;
    rdfs:label 'Reflective Material' ;
    rdfs:comment 'Indicates whether the navigational aid is equipped with radar-reflective material or retroreflective tape to enhance radar and visual detection.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleAuthority rdf:type rdf:Property ;
    rdfs:label 'Responsible Authority' ;
    rdfs:comment 'Name of the organization or authority responsible for the maintenance and operation of this navigational aid (e.g., port authority, coast guard, hydrographic office).' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soundSignalCharacter rdf:type rdf:Property ;
    rdfs:label 'Sound Signal Character' ;
    rdfs:comment 'Distinctive pattern or rhythm of the sound signal (e.g., \'2 blasts every 30s\', \'continuous\'). Null for aids without sound signals.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soundSignalType rdf:type rdf:Property ;
    rdfs:label 'Sound Signal Type' ;
    rdfs:comment 'Type of audible signal device installed on the navigational aid for use in reduced visibility conditions. Null or \'none\' for aids without sound signals.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureHeightM rdf:type rdf:Property ;
    rdfs:label 'Structure Height M' ;
    rdfs:comment 'Total physical height of the navigational aid structure from base to top in meters. Used for clearance calculations and physical planning.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topmarkShape rdf:type rdf:Property ;
    rdfs:label 'Topmark Shape' ;
    rdfs:comment 'Shape of the topmark (daymark) mounted on top of the aid for daytime identification. Follows IALA conventions for cardinal and lateral marks. Null or \'none\' for aids without topmarks.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchCircleRadiusM rdf:type rdf:Property ;
    rdfs:label 'Watch Circle Radius M' ;
    rdfs:comment 'Radius of the watch circle (swing radius) for floating aids, indicating the maximum distance the aid can drift from its charted position due to mooring scope and tidal/current effects. Null for fixed aids.' ;
    rdfs:domain ind:NavigationalAid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterDepthM rdf:type rdf:Property ;
    rdfs:label 'Water Depth M' ;
    rdfs:comment 'Depth of water at the navigational aid location measured from mean sea level to seabed in meters. Null for shore-based aids.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Gate Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ISPS-compliant gates require designated supervisor for security zone enforcement, access control, hazmat clearance, and customs coordination. Mandatory for port facility security plans and incident re' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryUserPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Primary User Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Gates track primary users (trucking companies, freight forwarders) for dedicated lane allocation and preferential access programs. Supports gate transaction billing, access authorization, and traffic ' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:accessControlSystemReference rdf:type rdf:Property ;
    rdfs:label 'Access Control System Reference' ;
    rdfs:comment 'Reference identifier or integration code linking this gate to the port access control and security management system. Used for ISPS compliance and security zone enforcement.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Appointment Required Flag' ;
    rdfs:comment 'Indicates whether advance appointment or booking is required for gate access. Supports truck appointment systems and congestion management initiatives.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageProcessingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Processing Time Minutes' ;
    rdfs:comment 'Average time in minutes required to process a transaction at this gate. Used for capacity planning, queue management, and service level agreement (SLA) monitoring.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cctvCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Cctv Coverage Flag' ;
    rdfs:comment 'Indicates whether the gate is covered by CCTV surveillance systems for security monitoring and incident investigation. Supports ISPS security requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsInspectionPointFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Inspection Point Flag' ;
    rdfs:comment 'Indicates whether this gate serves as a designated customs inspection and clearance point. Supports trade compliance and customs integration workflows.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyThroughputCapacity rdf:type rdf:Property ;
    rdfs:label 'Daily Throughput Capacity' ;
    rdfs:comment 'Maximum number of transactions or vehicles that can be processed through this gate in a 24-hour period under normal operating conditions. Supports capacity planning and resource allocation.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Access Flag' ;
    rdfs:comment 'Indicates whether the gate is designated for emergency vehicle access and can be opened outside normal operating hours for emergency response. Supports safety and security protocols.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gateCode rdf:type rdf:Property ;
    rdfs:label 'Gate Code' ;
    rdfs:comment 'Business identifier code for the gate used in operational systems and signage. Unique alphanumeric code assigned to each gate for reference in Terminal Operating System (TOS) and gate operations.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateDirection rdf:type rdf:Property ;
    rdfs:label 'Gate Direction' ;
    rdfs:comment 'Primary traffic flow direction supported by the gate. Determines operational procedures and transaction processing logic in TOS.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateName rdf:type rdf:Property ;
    rdfs:label 'Gate Name' ;
    rdfs:comment 'Human-readable name or designation of the gate (e.g., North Truck Gate, Rail Gate 3, Crew Access Gate A). Used for operational communication and wayfinding.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateType rdf:type rdf:Property ;
    rdfs:label 'Gate Type' ;
    rdfs:comment 'Classification of the gate based on its primary operational purpose and the type of traffic it handles. Determines applicable operational procedures and security protocols. [ENUM-REF-CANDIDATE: truck|rail|pedestrian|crew_access|service|emergency|vip — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Clearance Required Flag' ;
    rdfs:comment 'Indicates whether special clearance or documentation is required for vehicles carrying hazardous materials through this gate. Supports IMDG Code compliance and safety protocols.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inboundLanes rdf:type rdf:Property ;
    rdfs:label 'Inbound Lanes' ;
    rdfs:comment 'Number of lanes designated for inbound traffic entering the port facility. Supports directional flow management and throughput analysis.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent maintenance activity performed on the gate infrastructure or systems. Supports preventive maintenance scheduling and compliance tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumVehicleHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Vehicle Height Meters' ;
    rdfs:comment 'Maximum permissible vehicle height in meters that can pass through the gate infrastructure. Used for pre-gate clearance validation and safety compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVehicleLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Vehicle Length Meters' ;
    rdfs:comment 'Maximum permissible vehicle length in meters that can be accommodated at the gate. Used for pre-gate clearance validation and queue management.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVehicleWidthMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Vehicle Width Meters' ;
    rdfs:comment 'Maximum permissible vehicle width in meters that can pass through the gate infrastructure. Used for pre-gate clearance validation and safety compliance.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date when the next planned maintenance activity is scheduled for the gate. Supports proactive maintenance planning and operational continuity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfLanes rdf:type rdf:Property ;
    rdfs:label 'Number Of Lanes' ;
    rdfs:comment 'Total count of traffic lanes at the gate for vehicle or pedestrian throughput. Used for capacity planning and queue management in gate operations.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ocrEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Ocr Enabled Flag' ;
    rdfs:comment 'Indicates whether the gate is equipped with OCR technology for automated license plate recognition and container number capture. Enables automated data capture and validation at gate entry/exit.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Standard daily end time for gate operations in HH:MM format (24-hour clock). Defines the conclusion of the operational window for gate access.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Standard daily start time for gate operations in HH:MM format (24-hour clock). Defines the beginning of the operational window for gate access.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundLanes rdf:type rdf:Property ;
    rdfs:label 'Outbound Lanes' ;
    rdfs:comment 'Number of lanes designated for outbound traffic exiting the port facility. Supports directional flow management and throughput analysis.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portGateDescription rdf:type rdf:Property ;
    rdfs:label 'Port Gate Description' ;
    rdfs:comment 'Detailed textual description of the gate including location details, special features, operational notes, and any unique characteristics relevant to gate operations and planning.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled Flag' ;
    rdfs:comment 'Indicates whether the gate is equipped with RFID technology for automated vehicle or container identification. Supports automated gate processing and reduces manual intervention.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:twentyFourHourOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Hour Operation Flag' ;
    rdfs:comment 'Indicates whether the gate operates continuously 24 hours per day, 7 days per week. Overrides standard operating hours when set to true.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weighbridgeIntegratedFlag rdf:type rdf:Property ;
    rdfs:label 'Weighbridge Integrated Flag' ;
    rdfs:comment 'Indicates whether the gate has an integrated weighbridge system for automated vehicle and cargo weight measurement. Supports compliance with weight regulations and cargo verification.' ;
    rdfs:domain ind:PortGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Structural inspections require certified engineer assignment for regulatory compliance, professional liability, and asset management. Engineer competency verification is mandatory for port authority a' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetOwner rdf:type rdf:Property ;
    rdfs:label 'Asset Owner' ;
    rdfs:comment 'Classification of the legal owner of the quay wall asset: port authority, terminal operator, government, private entity, or joint venture.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bollardSpacingM rdf:type rdf:Property ;
    rdfs:label 'Bollard Spacing M' ;
    rdfs:comment 'Average distance in meters between mooring bollards along the quay wall, used for vessel mooring line configuration planning.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constructionMaterial rdf:type rdf:Property ;
    rdfs:label 'Construction Material' ;
    rdfs:comment 'Primary material used in the construction of the quay wall structure.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craneRailGaugeMm rdf:type rdf:Property ;
    rdfs:label 'Crane Rail Gauge Mm' ;
    rdfs:comment 'Distance in millimeters between crane rails if present, defining the track gauge for quay crane operations.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:craneRailPresent rdf:type rdf:Property ;
    rdfs:label 'Crane Rail Present' ;
    rdfs:comment 'Indicates whether the quay wall is equipped with crane rail infrastructure for Ship-to-Shore (STS) or Mobile Harbour Crane (MHC) operations.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentDepthM rdf:type rdf:Property ;
    rdfs:label 'Current Depth M' ;
    rdfs:comment 'Current actual water depth alongside the quay wall measured in meters from chart datum, as determined by the most recent hydrographic survey. May differ from design depth due to sedimentation or dredging.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designLoadCapacityKnPerM2 rdf:type rdf:Property ;
    rdfs:label 'Design Load Capacity Kn Per M2' ;
    rdfs:comment 'Maximum design load capacity of the quay wall surface expressed in kilonewtons per square meter (kN/m²), representing the safe working load for cargo handling operations and equipment.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designStandard rdf:type rdf:Property ;
    rdfs:label 'Design Standard' ;
    rdfs:comment 'Engineering design standard or code under which the quay wall was designed and constructed (e.g., BS 6349, PIANC guidelines, Eurocode 7).' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoring rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring' ;
    rdfs:comment 'Indicates whether the quay wall area is equipped with environmental monitoring systems for air quality, water quality, noise, or emissions tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCoordinates rdf:type rdf:Property ;
    rdfs:label 'Geographic Coordinates' ;
    rdfs:comment 'Geographic coordinates of the quay wall centerpoint in decimal degrees format (latitude, longitude) for GIS integration and port layout planning.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgCompliant rdf:type rdf:Property ;
    rdfs:label 'Imdg Compliant' ;
    rdfs:comment 'Indicates whether the quay wall infrastructure meets International Maritime Dangerous Goods (IMDG) Code requirements for handling dangerous goods cargo.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsCompliant rdf:type rdf:Property ;
    rdfs:label 'Isps Compliant' ;
    rdfs:comment 'Indicates whether the quay wall facility meets International Ship and Port Facility Security (ISPS) Code requirements for maritime security.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lightingSystemType rdf:type rdf:Property ;
    rdfs:label 'Lighting System Type' ;
    rdfs:comment 'Type of lighting system installed along the quay wall for night operations: LED, halogen, sodium vapor, or none.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Maintenance Responsibility' ;
    rdfs:comment 'Entity responsible for ongoing maintenance of the quay wall structure: port authority, terminal operator, external contractor, or shared responsibility.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVesselDwtTonnes rdf:type rdf:Property ;
    rdfs:label 'Max Vessel Dwt Tonnes' ;
    rdfs:comment 'Maximum Deadweight Tonnage (DWT) in tonnes of vessels that can be safely accommodated at this quay wall.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVesselLoaM rdf:type rdf:Property ;
    rdfs:label 'Max Vessel Loa M' ;
    rdfs:comment 'Maximum Length Overall (LOA) in meters of vessels that can be safely accommodated at this quay wall, based on structural and operational constraints.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedCargoTypes rdf:type rdf:Property ;
    rdfs:label 'Permitted Cargo Types' ;
    rdfs:comment 'Comma-separated list of cargo types permitted for handling at this quay wall (e.g., containers, bulk, breakbulk, RoRo, liquid bulk, dangerous goods). [ENUM-REF-CANDIDATE: containers|bulk_dry|bulk_liquid|breakbulk|roro|general_cargo|dangerous_goods|refrigerated — promote to reference product]' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementValueUsd rdf:type rdf:Property ;
    rdfs:label 'Replacement Value Usd' ;
    rdfs:comment 'Estimated replacement value of the quay wall structure in United States Dollars (USD) for insurance and asset management purposes.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seismicDesignCategory rdf:type rdf:Property ;
    rdfs:label 'Seismic Design Category' ;
    rdfs:comment 'Seismic design classification indicating the level of earthquake resistance incorporated into the quay wall structure based on regional seismic hazard assessment.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuralConditionRating rdf:type rdf:Property ;
    rdfs:label 'Structural Condition Rating' ;
    rdfs:comment 'Current overall structural condition assessment of the quay wall based on the most recent engineering inspection: excellent (no defects), good (minor wear), fair (moderate deterioration), poor (significant defects requiring attention), critical (unsafe, requires immediate intervention).' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLengthM rdf:type rdf:Property ;
    rdfs:label 'Total Length M' ;
    rdfs:comment 'Total linear length of the quay wall structure measured in meters along the waterfront.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilityServices rdf:type rdf:Property ;
    rdfs:label 'Utility Services' ;
    rdfs:comment 'Comma-separated list of utility services available at the quay wall (e.g., electrical power, potable water, fire water, compressed air, telecommunications, sewage).' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallCode rdf:type rdf:Property ;
    rdfs:label 'Wall Code' ;
    rdfs:comment 'Externally-known unique business identifier for the quay wall structure, used in port infrastructure documentation and AVEVA Marine Engineering system integration.' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallName rdf:type rdf:Property ;
    rdfs:label 'Wall Name' ;
    rdfs:comment 'Human-readable name or designation of the quay wall structure (e.g., North Quay Wall, Container Terminal Wharf A).' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wallType rdf:type rdf:Property ;
    rdfs:label 'Wall Type' ;
    rdfs:comment 'Classification of the quay wall based on structural construction method: gravity (mass concrete), sheet pile (interlocking steel), caisson (prefabricated box), piled (supported on piles), diaphragm (continuous reinforced concrete), or cellular (steel sheet pile cells).' ;
    rdfs:domain ind:QuayWall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearBuilt rdf:type rdf:Property ;
    rdfs:label 'Year Built' ;
    rdfs:comment 'Calendar year when the quay wall structure was originally constructed and commissioned.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:structuralInspectionId rdf:type rdf:Property ;
    rdfs:label 'Structural Inspection Id' ;
    rdfs:comment 'Unique identifier for the structural inspection record. Primary key for the structural inspection entity.' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadInspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Inspector Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Inspections require lead inspector FK for competency verification, certification tracking, and professional liability. Enables validation of inspector_certification against employee_certification reco' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetReference rdf:type rdf:Property ;
    rdfs:label 'Asset Reference' ;
    rdfs:comment 'Business identifier or name of the specific infrastructure asset being inspected (e.g., Berth 7, Quay Wall Section A, Warehouse 3).' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Type of port infrastructure asset being inspected. Categorizes the asset for inspection methodology and defect classification purposes. [ENUM-REF-CANDIDATE: quay_wall|berth|fender_system|warehouse|navigational_aid|crane_foundation|jetty|breakwater|mooring_dolphin|channel|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Hours' ;
    rdfs:comment 'Total duration of the inspection activity in hours, from start to completion.' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Primary methodology used to conduct the structural inspection: visual (human observation), underwater ROV (Remotely Operated Vehicle), NDT ultrasonic (Non-Destructive Testing), NDT radiographic, drone survey (aerial inspection), laser scanning (3D measurement), structural load test, or other specialized techniques. [ENUM-REF-CANDIDATE: visual|underwater_rov|ndt_ultrasonic|ndt_radiographic|drone_survey|laser_scanning|structural_load_test|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this structural inspection for tracking and reporting purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportReference rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Reference' ;
    rdfs:comment 'Reference identifier or document number for the formal inspection report. May reference document management system location.' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertification rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification' ;
    rdfs:comment 'Professional certification or accreditation held by the inspector (e.g., Certified Welding Inspector, NDT Level II, Structural Engineer PE).' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCompany rdf:type rdf:Property ;
    rdfs:label 'Inspector Company' ;
    rdfs:comment 'Name of the company or organization that performed the inspection (internal port authority team or external contractor).' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalImpact rdf:type rdf:Property ;
    rdfs:label 'Operational Impact' ;
    rdfs:comment 'Assessment of the impact of identified defects on port operations: none (no impact), minor (negligible impact), moderate (some operational constraints), major (significant operational restrictions), asset closure (asset must be taken out of service).' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallConditionRating rdf:type rdf:Property ;
    rdfs:label 'Overall Condition Rating' ;
    rdfs:comment 'Overall assessment of the asset structural condition based on inspection findings: excellent (no defects, as-new condition), good (minor wear, fully functional), fair (moderate deterioration, functional with monitoring), poor (significant deterioration, remediation required), critical (severe deterioration, immediate action required).' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photographicEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Photographic Evidence Reference' ;
    rdfs:comment 'Reference identifier or file path to photographic evidence captured during the inspection (images, videos, drone footage). May reference document management system location.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDefectType rdf:type rdf:Property ;
    rdfs:label 'Primary Defect Type' ;
    rdfs:comment 'The most significant type of defect identified during the inspection: cracking (structural cracks), spalling (concrete surface deterioration), corrosion (metal degradation), settlement (foundation movement), scour (seabed erosion), impact damage (collision damage), deformation (structural distortion), erosion (material loss), joint failure (expansion joint issues), coating failure (protective coating breakdown), or none (no defects found). [ENUM-REF-CANDIDATE: cracking|spalling|corrosion|settlement|scour|impact_damage|deformation|erosion|joint_failure|coating_failure|none — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Summary of recommended remediation actions based on inspection findings, including repair scope, urgency, and methodology.' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Date on which remediation work for identified defects was completed. Null if remediation is not yet complete.' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPriority rdf:type rdf:Property ;
    rdfs:label 'Remediation Priority' ;
    rdfs:comment 'Priority classification for remediation work: immediate (within 24 hours), urgent (within 1 week), high (within 1 month), medium (within 6 months), low (within 1 year), monitor only (no immediate action, continue monitoring).' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Risk Level' ;
    rdfs:comment 'Assessment of safety risk posed by identified defects: none (no safety concern), low (minimal risk), medium (moderate risk, monitoring required), high (significant risk, action needed), critical (immediate danger, asset closure required).' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuralIntegrityAssessment rdf:type rdf:Property ;
    rdfs:label 'Structural Integrity Assessment' ;
    rdfs:comment 'Engineering assessment of whether the asset structural integrity is intact (fully sound), compromised (reduced capacity but stable), at risk (potential failure), or failed (structural failure occurred).' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tideLevelM rdf:type rdf:Property ;
    rdfs:label 'Tide Level M' ;
    rdfs:comment 'Tide level in meters at the time of inspection, relevant for underwater and waterline structure inspections.' ;
    rdfs:domain ind:StructuralInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalId rdf:type rdf:Property ;
    rdfs:label 'Terminal Id' ;
    rdfs:comment 'Reference to the parent terminal facility that contains this zone. Links zone to its owning terminal for hierarchical port layout management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Terminal .

ind:zoneManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Zone Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Each operational zone requires designated manager for customs-controlled areas, hazmat approvals, security level enforcement, and daily operational decisions. Essential for ISPS compliance and inciden' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessControlSystem rdf:type rdf:Property ;
    rdfs:label 'Access Control System' ;
    rdfs:comment 'Technology used to control personnel and equipment entry to the zone. RFID gate for automated vehicle identification, biometric for high-security areas, card reader for personnel access, manual for guard-controlled entry, none for unrestricted areas. Integrates with Port Access Permit system.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this zone record is currently active in the master data registry. True: active and available for operational use. False: logically deleted or archived. Used for soft-delete pattern and historical record retention without physical deletion.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boundaryCoordinatesWkt rdf:type rdf:Property ;
    rdfs:label 'Boundary Coordinates Wkt' ;
    rdfs:comment 'Geographic boundary of the zone represented as Well-Known Text (WKT) POLYGON geometry. Enables GIS integration with AVEVA Marine Engineering for port layout visualization, spatial analysis, and automated equipment routing in Terminal Operating Systems.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centroidLatitude rdf:type rdf:Property ;
    rdfs:label 'Centroid Latitude' ;
    rdfs:comment 'Latitude coordinate of the zone geometric center in decimal degrees. Used for distance calculations, equipment dispatch optimization, and integration with Vessel Traffic Management System (VTMS) for cargo location tracking.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidLongitude rdf:type rdf:Property ;
    rdfs:label 'Centroid Longitude' ;
    rdfs:comment 'Longitude coordinate of the zone geometric center in decimal degrees. Used for distance calculations, equipment dispatch optimization, and integration with Vessel Traffic Management System (VTMS) for cargo location tracking.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Controlled Flag' ;
    rdfs:comment 'Indicates whether the zone is under customs authority control as a bonded area or free trade zone. True: customs-controlled area requiring special clearance procedures. False: non-bonded domestic area. Impacts cargo movement restrictions and documentation requirements in Port Community System (PCS).' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designCapacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Utilization Pct' ;
    rdfs:comment 'Target operational utilization percentage for the zone as designed by port planners. Typically 70-85% to allow operational flexibility. Used as benchmark for KPI reporting and capacity expansion trigger analysis. Expressed as percentage (e.g., 75.00 for 75%).' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drainageSystemType rdf:type rdf:Property ;
    rdfs:label 'Drainage System Type' ;
    rdfs:comment 'Stormwater management infrastructure type installed in the zone. Storm sewer for direct discharge, retention pond for controlled release, permeable pavement for infiltration, none for natural drainage. Critical for environmental compliance per MARPOL and local water quality regulations tracked in Environmental Monitoring System (EMS).' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Flag' ;
    rdfs:comment 'Indicates whether the zone has installed environmental sensors for air quality, noise, or emissions tracking. True: active monitoring integrated with Environmental Monitoring System (EMS). False: no environmental instrumentation. Required for zones near sensitive receptors or handling bulk materials.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System' ;
    rdfs:comment 'Fire protection infrastructure installed in the zone. Hydrant network for general fire response, foam system for flammable liquid storage, sprinkler for warehouse protection, none for open yard areas. Required for IMDG hazmat zones and insurance compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundSlotCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Ground Slot Capacity Teu' ;
    rdfs:comment 'Number of Twenty-foot Equivalent Unit (TEU) ground slots available for container placement at single-stack height. Represents the base stacking capacity before vertical stacking. Used for yard utilization KPI calculations.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlingEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Handling Equipment Type' ;
    rdfs:comment 'Primary type of cargo handling equipment deployed in this zone. RTG (Rubber Tyred Gantry) for automated container yards, ASC (Automated Stacking Crane) for rail-mounted operations, reach stacker for flexible container handling, forklift for warehouse operations, mobile crane for heavy lift, none for passive storage areas. Determines operational capacity and throughput rates.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Approved Flag' ;
    rdfs:comment 'Indicates whether the zone is certified and equipped for storage and handling of dangerous goods per International Maritime Dangerous Goods (IMDG) Code. True: approved for IMDG cargo with appropriate safety infrastructure. False: non-hazmat zone. Drives cargo acceptance rules in Terminal Operating System.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastResurfacingDate rdf:type rdf:Property ;
    rdfs:label 'Last Resurfacing Date' ;
    rdfs:comment 'Date when the zone pavement was last resurfaced or rehabilitated. Used to calculate pavement age, predict maintenance cycles, and schedule preventive maintenance in Maximo Asset Management system.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lightingType rdf:type rdf:Property ;
    rdfs:label 'Lighting Type' ;
    rdfs:comment 'Type of illumination infrastructure installed in the zone for 24/7 operations. LED high mast for energy-efficient area lighting, halogen flood for legacy installations, none for daylight-only operations. Impacts operational hours, safety compliance, and energy consumption tracking in Environmental Management System (EMS).' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStackHeight rdf:type rdf:Property ;
    rdfs:label 'Maximum Stack Height' ;
    rdfs:comment 'Maximum number of container tiers (vertical stacking levels) permitted in this zone based on pavement strength, equipment Safe Working Load (SWL), and operational safety requirements. Typically ranges from 3-6 tiers for yard operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pavedAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Paved Area Sqm' ;
    rdfs:comment 'Surface area with hard pavement (concrete or asphalt) suitable for heavy equipment operations and container stacking in square meters (m²). Critical for determining operational capacity and maintenance planning.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pavementConditionRating rdf:type rdf:Property ;
    rdfs:label 'Pavement Condition Rating' ;
    rdfs:comment 'Assessment of pavement structural integrity and surface condition. Excellent: no defects, full load capacity. Good: minor wear, full operational capacity. Fair: moderate deterioration, reduced heavy equipment operations. Poor: significant cracking/rutting, maintenance required. Critical: structural failure risk, immediate repair needed. Drives CAPEX maintenance planning.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:railAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Rail Access Flag' ;
    rdfs:comment 'Indicates whether the zone has direct rail track access for intermodal rail operations. True: rail-connected for on-dock rail loading/unloading. False: truck-only access. Critical for intermodal logistics planning and rail operator coordination.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Identifies the operational system of record that originated or last updated this zone record. NAVIS N4 for TOS-managed zones, AVEVA Marine for engineering-designed zones, manual entry for ad-hoc additions, GIS import for spatial data loads, legacy migration for historical data conversion. Supports data lineage and reconciliation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferPlugCount rdf:type rdf:Property ;
    rdfs:label 'Reefer Plug Count' ;
    rdfs:comment 'Number of electrical connection points (reefer plugs) available for refrigerated container (reefer) power supply. Critical for cold chain cargo capacity planning and reefer slot allocation in Terminal Operating System.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Total Area Sqm' ;
    rdfs:comment 'Total surface area of the zone in square meters (m²). Includes paved, unpaved, and built-up areas. Used for capacity planning, lease calculations, and infrastructure investment analysis.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Teu' ;
    rdfs:comment 'Maximum theoretical container capacity in Twenty-foot Equivalent Units (TEU) when stacked to maximum allowable height. Calculated as ground_slot_capacity_teu × maximum_stack_height. Used for strategic capacity planning and terminal expansion analysis.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truckAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Truck Access Flag' ;
    rdfs:comment 'Indicates whether the zone has direct road access for truck operations. True: truck-accessible for drayage and delivery operations. False: restricted access requiring internal transfer. Impacts gate operations and dwell time calculations.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vesselSideFlag rdf:type rdf:Property ;
    rdfs:label 'Vessel Side Flag' ;
    rdfs:comment 'Indicates whether the zone is located directly adjacent to berth/quay for ship-to-shore operations. True: vessel-side zone for direct discharge/loading operations. False: landside zone requiring horizontal transport. Affects Ship-to-Shore (STS) crane reach and vessel operation efficiency.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weighbridgeAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Weighbridge Available Flag' ;
    rdfs:comment 'Indicates whether the zone has an integrated weighbridge (truck scale) for container/cargo weight verification. True: weighbridge installed for SOLAS VGM (Verified Gross Mass) compliance. False: no weighing capability. Mandatory for container export zones per SOLAS Amendment.' ;
    rdfs:domain ind:TerminalZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Classification of the zone by its primary operational function. Determines handling equipment requirements, stacking rules, and capacity calculation methods. Container Yard (CY) for TEU/FEU stacking, Container Freight Station (CFS) for LCL consolidation, RoRo for Roll-on Roll-off operations, bulk storage for dry/liquid bulk, warehouse for covered storage, gate complex for entry/exit processing, rail yard for intermodal rail transfer, intermodal transfer for truck-rail interchange, empty depot for empty container storage. [ENUM-REF-CANDIDATE: container_yard|container_freight_station|roro_ramp|roro_marshalling|bulk_storage|warehouse|gate_complex|rail_yard|intermodal_transfer|empty_depot — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationsManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operations Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Critical infrastructure (power, water, shore power) requires designated manager for emergency response, maintenance coordination, and SCADA system accountability. Essential for business continuity and' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acquisitionCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualOpexBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Opex Budget' ;
    rdfs:comment 'Annual operational expenditure budget allocated for maintenance, repairs, inspections, and operational costs of the utility network infrastructure.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the design capacity value. kVA/MVA for electrical power, cubic meters per hour or liters per minute for fluids, bar/PSI for pressure systems, Gbps/Mbps for telecommunications. [ENUM-REF-CANDIDATE: kva|mva|kw|mw|m3_per_hour|liters_per_minute|bar|psi|gbps|mbps — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionRating rdf:type rdf:Property ;
    rdfs:label 'Condition Rating' ;
    rdfs:comment 'Current physical condition assessment of the utility network infrastructure based on inspection findings, maintenance history, and asset health indicators.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionPointCount rdf:type rdf:Property ;
    rdfs:label 'Connection Point Count' ;
    rdfs:comment 'Total number of connection points, outlets, or service delivery locations along the utility network (e.g., shore power connection points, fire hydrants, fuel bunkering stations, water taps).' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designCapacity rdf:type rdf:Property ;
    rdfs:label 'Design Capacity' ;
    rdfs:comment 'Maximum design capacity of the utility network. Units vary by network type: kVA for electrical/shore power, cubic meters per hour for water/fuel, bar for compressed air, Gbps for telecommunications.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicCoverageArea rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Area' ;
    rdfs:comment 'Description of the port geographic area or terminal zones served by this utility network (e.g., Terminal 1-3, North Berth Complex, Container Yard A-D, Entire Port Facility).' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgEmissionsReductionTonnesCo2Annual rdf:type rdf:Property ;
    rdfs:label 'Ghg Emissions Reduction Tonnes Co2 Annual' ;
    rdfs:comment 'Estimated annual reduction in greenhouse gas emissions measured in tonnes of CO2 equivalent attributable to this utility network. Particularly relevant for shore power networks enabling cold ironing per IMO GHG reduction strategy and MARPOL Annex VI compliance.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisNetworkLayerReference rdf:type rdf:Property ;
    rdfs:label 'Gis Network Layer Reference' ;
    rdfs:comment 'Reference identifier to the GIS layer or spatial dataset containing the detailed geographic mapping and routing of the utility network infrastructure. Supports AVEVA Marine Engineering integration.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationYear rdf:type rdf:Property ;
    rdfs:label 'Installation Year' ;
    rdfs:comment 'Year the utility network infrastructure was originally installed and commissioned for operational use.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastUpgradeYear rdf:type rdf:Property ;
    rdfs:label 'Last Upgrade Year' ;
    rdfs:comment 'Year of the most recent major upgrade, expansion, or modernization of the utility network infrastructure. Null if no upgrades have been performed since installation.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceAuthority rdf:type rdf:Property ;
    rdfs:label 'Maintenance Authority' ;
    rdfs:comment 'Name of the organizational unit, department, or external contractor responsible for maintenance and upkeep of the utility network infrastructure.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'Descriptive name of the utility network (e.g., Terminal 3 High Voltage Distribution, North Berth Water Supply Main, Shore Power Grid A).' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkStatus rdf:type rdf:Property ;
    rdfs:label 'Network Status' ;
    rdfs:comment 'Current operational lifecycle status of the utility network infrastructure.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Classification of the utility network infrastructure. Electrical HV (High Voltage) typically >1kV, LV (Low Voltage) <1kV. Shore power enables cold ironing per IEC/ISO 80005 standards for vessel berthing emissions reduction. [ENUM-REF-CANDIDATE: electrical_hv|electrical_lv|shore_power|water_supply|fire_hydrant|fuel_bunkering|compressed_air|telecommunications|wastewater|stormwater — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingFrequencyHz rdf:type rdf:Property ;
    rdfs:label 'Operating Frequency Hz' ;
    rdfs:comment 'Operating frequency in Hertz for electrical networks. Typically 50Hz or 60Hz depending on regional standards. Applicable to electrical and shore power networks. Null for non-electrical utility types.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingPressureBar rdf:type rdf:Property ;
    rdfs:label 'Operating Pressure Bar' ;
    rdfs:comment 'Operating pressure in bar for fluid and compressed air networks. Applicable to water supply, fire hydrant, fuel bunkering, and compressed air networks. Null for non-pressure utility types.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageKv rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage Kv' ;
    rdfs:comment 'Operating voltage in kilovolts for electrical networks. Applicable to electrical HV, electrical LV, and shore power networks. Null for non-electrical utility types.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'User identifier or system account that last modified this utility network record.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyLevel rdf:type rdf:Property ;
    rdfs:label 'Redundancy Level' ;
    rdfs:comment 'Level of redundancy and backup capacity built into the utility network design to ensure continuity of service during failures or maintenance. N+1 indicates one backup unit, N+2 indicates two backup units.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementValue rdf:type rdf:Property ;
    rdfs:label 'Replacement Value' ;
    rdfs:comment 'Estimated current cost to replace the utility network infrastructure with equivalent modern capacity and functionality. Used for insurance valuation and asset management planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Expiry Date' ;
    rdfs:comment 'Expiration date of current safety certifications for the utility network infrastructure. Null if certification is not required or has no expiry.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Status' ;
    rdfs:comment 'Current status of safety certifications and compliance approvals for the utility network infrastructure per ISPS Code, SOLAS, and ISO 45001 occupational health and safety standards.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Scada Integration Flag' ;
    rdfs:comment 'Indicates whether the utility network is integrated with SCADA systems for real-time monitoring, control, and automated management of network operations.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shorePowerConnectorStandard rdf:type rdf:Property ;
    rdfs:label 'Shore Power Connector Standard' ;
    rdfs:comment 'International standard specification for shore power connection interfaces. IEC 80005-1 for high voltage shore connection, IEC 80005-3 for low voltage. Applicable only to shore power networks.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shorePowerKvaCapacity rdf:type rdf:Property ;
    rdfs:label 'Shore Power Kva Capacity' ;
    rdfs:comment 'Total shore-to-ship power capacity in kVA for cold ironing connections per IEC/ISO 80005 standards. Enables vessels to shut down auxiliary engines while berthed, reducing GHG emissions and air pollution. Null for non-shore-power networks.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smartMeteringEnabled rdf:type rdf:Property ;
    rdfs:label 'Smart Metering Enabled' ;
    rdfs:comment 'Indicates whether the utility network is equipped with smart metering infrastructure for automated consumption tracking, billing, and demand management.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalNetworkLengthM rdf:type rdf:Property ;
    rdfs:label 'Total Network Length M' ;
    rdfs:comment 'Total linear length of the utility network infrastructure measured in meters, including all distribution lines, mains, and conduits.' ;
    rdfs:domain ind:UtilityNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lesseePortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Lessee Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Warehouses are leased to freight forwarders, customs brokers, or cargo owners. Essential for warehouse lease management, rental billing, access control, and capacity allocation. Role prefix \'lessee_\' ' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the warehouse facility including building number and street name.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for additional location details such as building name, suite number, or precinct identifier.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondedStatus rdf:type rdf:Property ;
    rdfs:label 'Bonded Status' ;
    rdfs:comment 'Indicates whether the warehouse is a customs-bonded facility authorized to store imported goods under customs supervision without immediate duty payment. True if bonded, false otherwise.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cctvCoverage rdf:type rdf:Property ;
    rdfs:label 'Cctv Coverage' ;
    rdfs:comment 'Indicates whether the warehouse has comprehensive CCTV surveillance coverage for security monitoring and incident investigation. True if CCTV installed, false otherwise.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constructionYear rdf:type rdf:Property ;
    rdfs:label 'Construction Year' ;
    rdfs:comment 'Year the warehouse facility was originally constructed. Used for asset age analysis, depreciation calculations, and maintenance planning.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Customs License Number' ;
    rdfs:comment 'Official customs authority license or registration number for bonded warehouse operations. Required for customs-controlled storage facilities.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Comma-separated list of environmental management certifications held by the warehouse (e.g., \'ISO_14001,LEED,Green_Port\'). Empty if no certifications.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionSystemType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System Type' ;
    rdfs:comment 'Type of fire suppression system installed. Sprinkler for wet pipe systems, foam for flammable liquid protection, gas for clean agent systems (FM-200, CO2), deluge for high-hazard areas, dry_pipe for freezing environments, pre_action for sensitive cargo. [ENUM-REF-CANDIDATE: none|sprinkler|foam|gas|deluge|dry_pipe|pre_action — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLoadCapacityKnPerSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Load Capacity Kn Per Sqm' ;
    rdfs:comment 'Maximum permissible floor load capacity in kilonewtons per square meter (kN/m²). Determines safe stacking weight limits and equipment usage restrictions.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoLatitude rdf:type rdf:Property ;
    rdfs:label 'Geo Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the warehouse facility in decimal degrees. Used for mapping, navigation, and spatial analytics.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoLongitude rdf:type rdf:Property ;
    rdfs:label 'Geo Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the warehouse facility in decimal degrees. Used for mapping, navigation, and spatial analytics.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightClearanceM rdf:type rdf:Property ;
    rdfs:label 'Height Clearance M' ;
    rdfs:comment 'Maximum internal height clearance in meters from floor to lowest overhead obstruction (beams, lighting, sprinklers). Critical for stacking height calculations and equipment compatibility.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMajorRenovationYear rdf:type rdf:Property ;
    rdfs:label 'Last Major Renovation Year' ;
    rdfs:comment 'Year of the most recent major renovation, refurbishment, or structural upgrade. Null if no major renovation has occurred since construction.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date when the current lease or concession agreement expires. Null for port-owned facilities or perpetual arrangements. Critical for contract renewal planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadingBayCount rdf:type rdf:Property ;
    rdfs:label 'Loading Bay Count' ;
    rdfs:comment 'Number of truck loading/unloading bays or dock doors available for cargo transfer operations. Impacts throughput capacity and dwell time.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialHandlingEquipment rdf:type rdf:Property ;
    rdfs:label 'Material Handling Equipment' ;
    rdfs:comment 'Comma-separated list of material handling equipment types available at the warehouse (e.g., \'forklift,reach_stacker,pallet_jack,overhead_crane\'). Used for operational planning and equipment dispatch.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxForkliftCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Max Forklift Capacity Tonnes' ;
    rdfs:comment 'Maximum lifting capacity in tonnes of the largest forklift equipment available at the warehouse. Determines handling capability for heavy cargo units.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership structure of the warehouse facility. Port_owned for direct port authority ownership, leased for long-term lease arrangements, joint_venture for shared ownership, third_party for private operator facilities, concession for build-operate-transfer arrangements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:railAccessAvailable rdf:type rdf:Property ;
    rdfs:label 'Rail Access Available' ;
    rdfs:comment 'Indicates whether the warehouse has direct rail siding access for intermodal cargo transfer. True if rail-connected, false otherwise. Critical for inland container depot (ICD) operations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureControlCapability rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Capability' ;
    rdfs:comment 'Type of temperature control system installed. None for ambient storage, refrigerated for chilled goods (2-8°C), climate_controlled for humidity and temperature management, frozen for sub-zero storage, multi_zone for facilities with multiple temperature zones.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum operating temperature in Celsius that the warehouse climate control system can maintain. Applicable only for temperature-controlled facilities.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum operating temperature in Celsius that the warehouse climate control system can maintain. Applicable only for temperature-controlled facilities.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFloorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Total Floor Area Sqm' ;
    rdfs:comment 'Total gross floor area of the warehouse facility measured in square meters, including all covered space, aisles, offices, and non-storage areas.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usableStorageAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Usable Storage Area Sqm' ;
    rdfs:comment 'Net usable storage area in square meters available for cargo placement, excluding aisles, offices, equipment rooms, and other non-storage zones. Used for capacity planning and utilization KPIs.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseName rdf:type rdf:Property ;
    rdfs:label 'Warehouse Name' ;
    rdfs:comment 'Official business name of the warehouse facility as used in contracts, signage, and operational documentation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseType rdf:type rdf:Property ;
    rdfs:label 'Warehouse Type' ;
    rdfs:comment 'Classification of warehouse facility by primary function. CFS (Container Freight Station) for LCL consolidation, bonded for customs-controlled storage, hazmat for IMDG dangerous goods, reefer for temperature-controlled cargo, general for standard dry goods, open_yard for uncovered storage, transit_shed for temporary cargo staging. [ENUM-REF-CANDIDATE: CFS|bonded|hazmat|reefer|general|open_yard|transit_shed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationTerminalZoneId rdf:type rdf:Property ;
    rdfs:label 'Destination Terminal Zone Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.terminal_zone. Business justification: Drayage orders specify target terminal zone for container placement, enabling yard planning, slot allocation, and equipment dispatch - core terminal operations process.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalZone .

ind:driverAccessCredentialId rdf:type rdf:Property ;
    rdfs:label 'Driver Access Credential Id' ;
    rdfs:comment 'Foreign key linking to security.access_credential. Business justification: Haulier driver credentials must be verified for container pickup/delivery authorization, background check validation, and MARSEC-level clearance - security clearance process for cargo handling authori' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessCredential .

ind:originBerthId rdf:type rdf:Property ;
    rdfs:label 'Origin Berth Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.berth. Business justification: Drayage from vessel references berth for container pickup during discharge operations, enabling vessel-to-gate coordination and berth turnaround optimization - vessel discharge process.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Berth .

ind:originIcdFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Icd Facility Id' ;
    rdfs:comment 'Foreign key linking to intermodal.icd_facility. Business justification: When origin_location_type = \'ICD\', this FK links to the specific inland container depot. Nullable FK (only populated when origin is an ICD facility). Resolves silo issue for icd_facility. origin_locat' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcdFacility .

ind:originSecurityZoneId rdf:type rdf:Property ;
    rdfs:label 'Origin Security Zone Id' ;
    rdfs:comment 'Foreign key linking to security.security_zone. Business justification: Drayage origin locations (container yards, berths, ICD facilities) are within designated security zones requiring zone-exit authorization, customs clearance verification, and security screening before' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:transportOrderId rdf:type rdf:Property ;
    rdfs:label 'Transport Order Id' ;
    rdfs:comment 'Foreign key linking to intermodal.transport_order. Business justification: Drayage orders execute transport order instructions. The drayage_order is the operational execution record for container movement, while transport_order is the instruction (IFTMIN message). Linking al' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportOrder .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time when the container was delivered to the destination location. Captured via gate system, customer confirmation, or proof of delivery.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Timestamp' ;
    rdfs:comment 'Actual date and time when the container was picked up from the origin location. Captured via gate system or manual confirmation.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationAddress rdf:type rdf:Property ;
    rdfs:label 'Destination Address' ;
    rdfs:comment 'Full street address of the destination location for customer premises or off-port facilities. Required for last-mile delivery coordination.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drayageOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Drayage Order Number' ;
    rdfs:comment 'Business-facing unique drayage order number issued to road hauliers for container movement instructions. Externally referenced identifier for tracking and communication.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drayageStatus rdf:type rdf:Property ;
    rdfs:label 'Drayage Status' ;
    rdfs:comment 'Current lifecycle status of the drayage order. Tracks progression from order creation through assignment, execution, and completion or cancellation.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drayageType rdf:type rdf:Property ;
    rdfs:label 'Drayage Type' ;
    rdfs:comment 'Classification of the drayage movement type. IMPORT = laden container from port to customer, EXPORT = laden container from customer to port, EMPTY_RETURN = empty container return, REPOSITIONING = container relocation between port facilities.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Reason for drayage order failure if status is FAILED (e.g., container not available, access denied, address incorrect). Used for exception management.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether the container contains hazardous materials requiring special handling and routing per IMDG Code.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderPriority rdf:type rdf:Property ;
    rdfs:label 'Order Priority' ;
    rdfs:comment 'Priority level assigned to the drayage order for dispatch sequencing and resource allocation. URGENT orders receive expedited handling.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originAddress rdf:type rdf:Property ;
    rdfs:label 'Origin Address' ;
    rdfs:comment 'Full street address of the origin location for customer premises or off-port facilities. Required for last-mile delivery coordination.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overweightIndicator rdf:type rdf:Property ;
    rdfs:label 'Overweight Indicator' ;
    rdfs:comment 'Flag indicating whether the container exceeds standard weight limits and requires special routing or permits for road transport.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podSignatureName rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Name' ;
    rdfs:comment 'Name of the person who signed for the container delivery at the destination. Captured for delivery verification and dispute resolution.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryReceived rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Received' ;
    rdfs:comment 'Flag indicating whether proof of delivery documentation has been received from the haulier confirming successful container delivery.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proofOfDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Timestamp' ;
    rdfs:comment 'Date and time when proof of delivery was received and validated. Used for billing trigger and service level agreement measurement.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reeferIndicator rdf:type rdf:Property ;
    rdfs:label 'Reefer Indicator' ;
    rdfs:comment 'Flag indicating whether the container is a refrigerated unit requiring temperature-controlled transport and genset-equipped truck.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned date for container delivery to the destination location. Used for customer appointment scheduling and receiving dock planning.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time Window End' ;
    rdfs:comment 'End of the time window for container delivery. Defines the latest time the haulier may arrive for delivery without incurring penalties.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDeliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time Window Start' ;
    rdfs:comment 'Start of the time window for container delivery. Defines the earliest time the haulier may arrive for delivery.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledPickupDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Pickup Date' ;
    rdfs:comment 'Planned date for container pickup from the origin location. Used for truck appointment scheduling and yard planning.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledPickupTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled Pickup Time Window End' ;
    rdfs:comment 'End of the time window for container pickup. Defines the latest time the haulier may arrive for pickup without incurring penalties.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledPickupTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Pickup Time Window Start' ;
    rdfs:comment 'Start of the time window for container pickup. Defines the earliest time the haulier may arrive for pickup.' ;
    rdfs:domain ind:DrayageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerReference rdf:type rdf:Property ;
    rdfs:label 'Container Reference' ;
    rdfs:comment 'ISO 6346 container number referenced in the EDI message, if applicable. Links the message to specific container movements or events.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correlationCode rdf:type rdf:Property ;
    rdfs:label 'Correlation Code' ;
    rdfs:comment 'Unique identifier linking this EDI message to the source transaction or business event that triggered it (e.g., gate transaction ID, booking reference, container movement ID). Enables traceability between EDI messages and operational records.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsReference rdf:type rdf:Property ;
    rdfs:label 'Customs Reference' ;
    rdfs:comment 'Customs declaration or clearance reference number associated with the EDI message, if applicable. Links the message to customs processing.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Standardized error code if the EDI message processing failed. May reference UN/EDIFACT error codes or internal system error codes.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Human-readable description of the error encountered during EDI message processing. Provides context for troubleshooting and partner communication.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeControlReference rdf:type rdf:Property ;
    rdfs:label 'Interchange Control Reference' ;
    rdfs:comment 'Unique control reference for the EDI interchange envelope. Used to track the entire interchange session between sender and receiver.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messagePayload rdf:type rdf:Property ;
    rdfs:label 'Message Payload' ;
    rdfs:comment 'Full EDI message content in UN/EDIFACT format. Contains the complete message body including all segments and data elements. Stored for audit trail and message reconciliation purposes.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Message Size Bytes' ;
    rdfs:comment 'Size of the EDI message payload in bytes. Used for transmission monitoring and capacity planning.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageStandard rdf:type rdf:Property ;
    rdfs:label 'Message Standard' ;
    rdfs:comment 'The EDI standard and version used for this message (e.g., UN/EDIFACT D.95B, UN/EDIFACT D.01B). Identifies the syntax and structure version.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Name of the trading partner organization involved in the EDI exchange.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingOutcome rdf:type rdf:Property ;
    rdfs:label 'Processing Outcome' ;
    rdfs:comment 'Detailed outcome description of the EDI message processing. Captures success confirmation, error details, or business rule validation results.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientIdentification rdf:type rdf:Property ;
    rdfs:label 'Recipient Identification' ;
    rdfs:comment 'Identification code of the message recipient as specified in the EDI interchange header. Combined with recipient_qualifier to uniquely identify the receiving party.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientQualifier rdf:type rdf:Property ;
    rdfs:label 'Recipient Qualifier' ;
    rdfs:comment 'Code identifying the type of recipient identification used in the EDI interchange (e.g., GLN, DUNS, SCAC). Part of the UN/EDIFACT interchange header.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times the system has attempted to reprocess or retransmit this EDI message after initial failure. Used for monitoring message delivery reliability.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:senderIdentification rdf:type rdf:Property ;
    rdfs:label 'Sender Identification' ;
    rdfs:comment 'Identification code of the message sender as specified in the EDI interchange header. Combined with sender_qualifier to uniquely identify the sending party.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderQualifier rdf:type rdf:Property ;
    rdfs:label 'Sender Qualifier' ;
    rdfs:comment 'Code identifying the type of sender identification used in the EDI interchange (e.g., GLN, DUNS, SCAC). Part of the UN/EDIFACT interchange header.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testIndicator rdf:type rdf:Property ;
    rdfs:label 'Test Indicator' ;
    rdfs:comment 'Flag indicating whether this is a test message (true) or production message (false). Test messages are used for partner integration testing and should not trigger operational actions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Date and time when the EDI message was transmitted or received. Represents the actual communication event time.' ;
    rdfs:domain ind:EdiMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transport referenced in the EDI message. Identifies whether the message relates to rail, truck, barge, vessel, or air transport operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalAccessCredentialId rdf:type rdf:Property ;
    rdfs:label 'Organizational Access Credential Id' ;
    rdfs:comment 'Foreign key linking to security.access_credential. Business justification: Haulier companies receive organizational credentials for fleet-wide port facility access, background check validation, and vendor security clearance - vendor security management and organizational acc' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessCredential .

ind:commercialTermsReference rdf:type rdf:Property ;
    rdfs:label 'Commercial Terms Reference' ;
    rdfs:comment 'Reference identifier for the commercial terms, rate card, or pricing agreement governing the haulier\'s services with the port or terminal operator.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediMessageFormats rdf:type rdf:Property ;
    rdfs:label 'Edi Message Formats' ;
    rdfs:comment 'Comma-separated list of EDI message formats supported by the haulier (e.g., IFTMIN, COPARN, BAPLIE) for intermodal transport coordination.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetSize rdf:type rdf:Property ;
    rdfs:label 'Fleet Size' ;
    rdfs:comment 'Total number of vehicles, locomotives, or vessels in the haulier\'s operational fleet available for container transport.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:haulierStatus rdf:type rdf:Property ;
    rdfs:label 'Haulier Status' ;
    rdfs:comment 'Current operational status of the haulier in the port\'s carrier registry: active (approved and operational), inactive (not currently operating), suspended (temporarily barred), pending approval (under review), or terminated (permanently removed).' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastServiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Date' ;
    rdfs:comment 'Date of the most recent transport service or container movement performed by the haulier.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Licence Expiry Date' ;
    rdfs:comment 'Expiration date of the haulier\'s transport operator licence. Operations must cease if licence expires without renewal.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensingAuthority rdf:type rdf:Property ;
    rdfs:label 'Licensing Authority' ;
    rdfs:comment 'Name of the regulatory body or government agency that issued the transport operator licence.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAccessAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Network Access Agreement Ref' ;
    rdfs:comment 'Reference number or identifier for the network access agreement or contract that grants the haulier operational access to port facilities, rail networks, or inland terminals.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Office Address Line1' ;
    rdfs:comment 'First line of the haulier\'s registered office or headquarters street address.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Office Address Line2' ;
    rdfs:comment 'Second line of the haulier\'s registered office or headquarters street address (suite, building, floor).' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCity rdf:type rdf:Property ;
    rdfs:label 'Office City' ;
    rdfs:comment 'City or municipality where the haulier\'s registered office or headquarters is located.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Office Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the country where the haulier\'s registered office or headquarters is located.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officePostalCode rdf:type rdf:Property ;
    rdfs:label 'Office Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the haulier\'s registered office or headquarters address.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeStateProvince rdf:type rdf:Property ;
    rdfs:label 'Office State Province' ;
    rdfs:comment 'State, province, or administrative region where the haulier\'s registered office or headquarters is located.' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorType rdf:type rdf:Property ;
    rdfs:label 'Operator Type' ;
    rdfs:comment 'Classification of the haulier operator type: road haulage company, owner-operator (independent), rail freight operator, barge service provider, or integrated logistics provider.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Performance tier rating assigned to the haulier based on KPIs such as on-time delivery, safety record, and service quality: platinum (top tier), gold, silver, bronze, or unrated (new/insufficient data).' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Licence Number' ;
    rdfs:comment 'Government-issued transport operator licence or permit number authorizing the haulier to conduct commercial freight operations.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCorridors rdf:type rdf:Property ;
    rdfs:label 'Service Corridors' ;
    rdfs:comment 'Geographic service corridors, routes, or regions covered by the haulier\'s transport network (e.g., port-to-ICD, regional shuttle, cross-border).' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleTypes rdf:type rdf:Property ;
    rdfs:label 'Vehicle Types' ;
    rdfs:comment 'Comma-separated list of vehicle, locomotive, or vessel types operated by the haulier (e.g., flatbed truck, chassis, container wagon, push barge).' ;
    rdfs:domain ind:Haulier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdFacilityId rdf:type rdf:Property ;
    rdfs:label 'Icd Facility Id' ;
    rdfs:comment 'Unique system identifier for the ICD or CFS facility record. Primary key.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcdFacility .

ind:envMonitoringStationId rdf:type rdf:Property ;
    rdfs:label 'Env Monitoring Station Id' ;
    rdfs:comment 'Foreign key linking to safety.env_monitoring_station. Business justification: ICD facilities with reefer operations, bonded storage, or dangerous goods handling require environmental monitoring (air quality, noise, refrigerant leaks, emissions). ISO 14001 compliance and regulat' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvMonitoringStation .

ind:facilityManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ICD facilities require on-site manager assignment for operational oversight, vendor coordination, compliance monitoring, and escalation handling. Port networks track facility managers for accountabili' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when the facility became operational and available for container handling in the port\'s intermodal network. Used for historical analysis and facility lifecycle tracking.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'Date when the facility ceased operations or was decommissioned. Nullable for currently active facilities. Used for historical reporting and capacity planning.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageDrayageTimeHours rdf:type rdf:Property ;
    rdfs:label 'Average Drayage Time Hours' ;
    rdfs:comment 'Average transit time for container drayage between the port and the ICD facility, measured in hours. Used for service level agreement (SLA) definition and operational planning.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code used for billing and financial transactions with the facility operator (e.g., USD, EUR, INR). Used in invoice generation and revenue accounting.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBondedFacility rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Facility' ;
    rdfs:comment 'Indicates whether the facility is authorized as a customs bonded warehouse, allowing storage of imported goods before duty payment. True if bonded status is active; False otherwise. Critical for trade compliance and duty deferral operations.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsCertified rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Certified' ;
    rdfs:comment 'Indicates whether the facility is certified to handle IMDG (International Maritime Dangerous Goods) classified cargo. True if IMDG certification is active; False otherwise. Required for hazardous material storage and handling.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distanceFromPortKm rdf:type rdf:Property ;
    rdfs:label 'Distance From Port Km' ;
    rdfs:comment 'Road distance from the main port terminal to the ICD facility measured in kilometers. Used for drayage cost calculation, transit time estimation, and last-mile delivery planning.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediConnectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Connectivity Status' ;
    rdfs:comment 'Current status of EDI integration between the port\'s systems and the ICD facility. CONNECTED indicates active EDI messaging (COPARN, IFTMIN, BAPLIE), NOT_CONNECTED for manual processes, PENDING for integration in progress, SUSPENDED for temporarily disabled connections.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediProtocol rdf:type rdf:Property ;
    rdfs:label 'Edi Protocol' ;
    rdfs:comment 'Technical protocol used for EDI message exchange with the facility. EDIFACT for UN/EDIFACT standard, XML for web services, AS2 for secure file transfer, SFTP for batch file exchange, API for real-time integration.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Unique business identifier code assigned to the ICD or CFS facility, used in operational systems and EDI messaging (COPARN, IFTMIN). Typically alphanumeric, 4-10 characters.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fclServiceAvailable rdf:type rdf:Property ;
    rdfs:label 'Fcl Service Available' ;
    rdfs:comment 'Indicates whether the facility provides FCL (Full Container Load) handling services. True if the facility can receive, store, and dispatch full containers; False otherwise.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imdgLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Imdg License Number' ;
    rdfs:comment 'Official license or certification number for dangerous goods handling issued by maritime safety authorities. Required when dangerous_goods_certified = True. Used in hazmat compliance reporting.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lclServiceAvailable rdf:type rdf:Property ;
    rdfs:label 'Lcl Service Available' ;
    rdfs:comment 'Indicates whether the facility provides LCL (Less than Container Load) consolidation and deconsolidation services. True if the facility operates as a CFS for break-bulk cargo; False otherwise.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Operator Contact Email' ;
    rdfs:comment 'Primary email address for operational coordination and communication with the facility operator. Used for EDI notifications, booking confirmations, and service requests.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Operator Contact Phone' ;
    rdfs:comment 'Primary telephone number for operational coordination with the facility operator, including country code. Used for urgent operational matters and emergency contact.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Legal name of the company or organization operating the ICD or CFS facility. May be a third-party logistics provider, port authority subsidiary, or independent operator.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:railConnectivity rdf:type rdf:Property ;
    rdfs:label 'Rail Connectivity' ;
    rdfs:comment 'Indicates whether the facility has direct rail access for intermodal container transfer. True if rail siding or terminal connection exists; False for truck-only facilities. Critical for rail operations planning and modal shift strategies.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTurnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Turnaround Time Hours' ;
    rdfs:comment 'Contractual maximum turnaround time for container processing at the facility, measured in hours from gate-in to gate-out. Used for SLA compliance monitoring and performance measurement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Teu' ;
    rdfs:comment 'Maximum container storage capacity of the facility measured in TEU (Twenty-foot Equivalent Units). Used for capacity planning, yard management, and operational load balancing across the intermodal network.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truckParkingCapacity rdf:type rdf:Property ;
    rdfs:label 'Truck Parking Capacity' ;
    rdfs:comment 'Maximum number of trucks that can be accommodated simultaneously in the facility\'s parking and staging areas. Used for truck appointment system capacity planning and gate congestion management.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:twentyFourSevenOperations rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Seven Operations' ;
    rdfs:comment 'Indicates whether the facility operates 24 hours a day, 7 days a week. True for round-the-clock operations; False for facilities with limited operating hours. Impacts truck appointment system configuration and service level agreements.' ;
    rdfs:domain ind:IcdFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationNodePortLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Node Port Location Id' ;
    rdfs:comment 'Reference to the ending location node for this leg (port, terminal, inland container depot, rail yard, distribution center).' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortLocation .

ind:journeyTransportOrderId rdf:type rdf:Property ;
    rdfs:label 'Journey Transport Order Id' ;
    rdfs:comment 'Reference to the parent multimodal journey or shipment that this leg is part of. Links this leg to the overall transport chain.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportOrder .

ind:railServiceId rdf:type rdf:Property ;
    rdfs:label 'Rail Service Id' ;
    rdfs:comment 'Reference to the specific rail service or train for rail legs. Null for non-rail transport modes.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Service .

ind:serviceId rdf:type rdf:Property ;
    rdfs:label 'Service Id' ;
    rdfs:comment 'Foreign key linking to intermodal.intermodal_service. Business justification: Each leg is an instance of a specific intermodal service (rail corridor, truck route, etc.). The service defines the route and schedule; the leg is the actual execution. No columns removed because leg' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Service .

ind:truckAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Truck Appointment Id' ;
    rdfs:comment 'Foreign key linking to intermodal.truck_appointment. Business justification: When transport_mode = \'TRUCK\', the leg may be linked to a truck gate appointment. Nullable FK (only populated for truck legs with appointments). Allows linking leg execution to gate slot booking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TruckAppointment .

ind:truckDispatchId rdf:type rdf:Property ;
    rdfs:label 'Truck Dispatch Id' ;
    rdfs:comment 'Reference to the truck dispatch or drayage assignment for road legs. Null for non-road transport modes.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentDispatch .

ind:vesselVoyageId rdf:type rdf:Property ;
    rdfs:label 'Vessel Voyage Id' ;
    rdfs:comment 'Reference to the specific vessel voyage for sea legs. Null for non-maritime transport modes.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Voyage .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'Actual incurred cost for this transport leg in USD. Used for financial reporting and variance analysis.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the transport leg departed from the origin node. Used for performance tracking and delay analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:awbNumber rdf:type rdf:Property ;
    rdfs:label 'Awb Number' ;
    rdfs:comment 'Air Waybill reference number for air transport legs. Null for non-air transport modes.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonEmissionsKgCo2 rdf:type rdf:Property ;
    rdfs:label 'Carbon Emissions Kg Co2' ;
    rdfs:comment 'Estimated carbon dioxide emissions for this transport leg measured in kilograms. Used for environmental reporting and sustainability tracking per GHG protocols.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Minutes' ;
    rdfs:comment 'Total delay time for this leg measured in minutes. Calculated as the difference between scheduled and actual times. Zero if no delay.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for any delay in this transport leg (e.g., weather, equipment failure, congestion). Null if no delay occurred.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeName rdf:type rdf:Property ;
    rdfs:label 'Destination Node Name' ;
    rdfs:comment 'Name of the ending location for this transport leg. Provides human-readable identification of the arrival point.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeType rdf:type rdf:Property ;
    rdfs:label 'Destination Node Type' ;
    rdfs:comment 'Classification of the destination location node. ICD = Inland Container Depot, CFS = Container Freight Station. [ENUM-REF-CANDIDATE: seaport|inland_port|rail_terminal|icd|cfs|distribution_center|warehouse — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Total distance covered during this transport leg measured in kilometers. Used for cost calculation, carbon footprint analysis, and route optimization.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediMessageAcknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edi Message Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when EDI message acknowledgment was received from logistics partners. Used for integration monitoring.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ediMessageSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edi Message Sent Timestamp' ;
    rdfs:comment 'Date and time when EDI message (IFTMIN, COPARN) was sent to logistics partners for this leg. Used for integration tracking.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Usd' ;
    rdfs:comment 'Estimated or planned cost for this transport leg in USD. Used for budgeting and cost analysis.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legStatus rdf:type rdf:Property ;
    rdfs:label 'Leg Status' ;
    rdfs:comment 'Current operational status of this transport leg within its lifecycle. Tracks progression from planning through execution to completion.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originNodeType rdf:type rdf:Property ;
    rdfs:label 'Origin Node Type' ;
    rdfs:comment 'Classification of the origin location node. ICD = Inland Container Depot, CFS = Container Freight Station. [ENUM-REF-CANDIDATE: seaport|inland_port|rail_terminal|icd|cfs|distribution_center|warehouse — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Timestamp' ;
    rdfs:comment 'Planned date and time when the transport leg is scheduled to arrive at the destination node. Used for planning and resource allocation.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned date and time when the transport leg is scheduled to depart from the origin node. Used for planning and coordination.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Sequential order of this transport leg within the multimodal journey (e.g., 1 for first leg, 2 for second leg). Enables reconstruction of the complete journey path.' ;
    rdfs:domain ind:Leg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Hours' ;
    rdfs:comment 'Actual transit time for this leg from departure to arrival measured in hours. Used for performance analysis and service level tracking.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primarySecurityZoneId rdf:type rdf:Property ;
    rdfs:label 'Primary Security Zone Id' ;
    rdfs:comment 'Foreign key linking to security.security_zone. Business justification: Scheduled intermodal services operate through designated secure corridors and primary operational zones requiring route security planning, zone-based access control, and MARSEC-level service authoriza' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:bookingCutoffHours rdf:type rdf:Property ;
    rdfs:label 'Booking Cutoff Hours' ;
    rdfs:comment 'Number of hours before scheduled departure that bookings must be submitted. Used for operational planning and customer service commitments.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:corridorCode rdf:type rdf:Property ;
    rdfs:label 'Corridor Code' ;
    rdfs:comment 'Standardized code representing the origin-destination corridor, typically in format XXX-YYY where XXX is origin and YYY is destination location code.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceSupported rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Supported' ;
    rdfs:comment 'Indicates whether this intermodal service includes customs clearance coordination at origin or destination, critical for international cargo movements.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsAllowed rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Allowed' ;
    rdfs:comment 'Indicates whether this service is certified and equipped to handle IMDG (International Maritime Dangerous Goods) classified cargo.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediMessageTypes rdf:type rdf:Property ;
    rdfs:label 'Edi Message Types' ;
    rdfs:comment 'Pipe-separated list of supported EDI message types for this service, such as COPARN, IFTMIN, IFTMBC (Booking Confirmation), IFTSTA (Status Report).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeSupported rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Supported' ;
    rdfs:comment 'Types of container equipment supported by this service. May include standard dry containers, reefers, open-top, flat-rack, tank containers. Pipe-separated list if multiple types.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Frequency at which the intermodal service operates. Daily: every day. Weekly: once per week. Bi-weekly: twice per week. On-demand: as requested. Scheduled: fixed timetable.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCutoffHours rdf:type rdf:Property ;
    rdfs:label 'Gate Cutoff Hours' ;
    rdfs:comment 'Number of hours before scheduled departure that containers must be delivered to the origin gate or Container Yard (CY). Critical for load planning.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oversizeCargoAllowed rdf:type rdf:Property ;
    rdfs:label 'Oversize Cargo Allowed' ;
    rdfs:comment 'Indicates whether this service can accommodate oversize or out-of-gauge cargo such as open-top or flat-rack containers.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reeferCapable rdf:type rdf:Property ;
    rdfs:label 'Reefer Capable' ;
    rdfs:comment 'Indicates whether this service can handle refrigerated containers with temperature-controlled transport throughout the corridor.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Route Distance Km' ;
    rdfs:comment 'Total distance of the intermodal service route measured in kilometers, used for transit time calculation and tariff determination.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Unique business identifier code for the intermodal service, used in operational systems and customer communications. Typically alphanumeric 6-12 characters.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Human-readable name of the intermodal transport service, used for marketing and operational reference.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaOnTimePerformanceTarget rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Performance Target' ;
    rdfs:comment 'Target percentage for on-time delivery performance as defined in customer Service Level Agreements. Measured as percentage of departures/arrivals within committed transit time window.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weeklyDepartures rdf:type rdf:Property ;
    rdfs:label 'Weekly Departures' ;
    rdfs:comment 'Number of scheduled departures per week for this service. Used for capacity planning and customer service commitments.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMileEventId rdf:type rdf:Property ;
    rdfs:label 'Last Mile Event Id' ;
    rdfs:comment 'Unique identifier for the last-mile delivery tracking event. Primary key for the last_mile_event product.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationPortLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Port Location Id' ;
    rdfs:comment 'Reference to the destination location for this last-mile delivery, such as customer warehouse, distribution center, or final consignee address.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortLocation .

ind:primaryLastPortLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Last Port Location Id' ;
    rdfs:comment 'Reference to the origin location for this last-mile leg, typically an Inland Container Depot (ICD), Container Freight Station (CFS), or port terminal.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortLocation .

ind:appointmentReference rdf:type rdf:Property ;
    rdfs:label 'Appointment Reference' ;
    rdfs:comment 'Reference to the truck appointment system booking for this last-mile delivery. Links to the scheduled delivery time slot.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeContactPerson rdf:type rdf:Property ;
    rdfs:label 'Consignee Contact Person' ;
    rdfs:comment 'Name of the individual at the consignee location who received or was contacted regarding the delivery. Used for delivery confirmation and issue resolution.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Consignee Signature Captured' ;
    rdfs:comment 'Indicates whether a consignee signature was captured as proof of delivery. True if signature was obtained, false otherwise.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPhotoReference rdf:type rdf:Property ;
    rdfs:label 'Delivery Photo Reference' ;
    rdfs:comment 'Reference identifier or storage path for photographic proof of delivery, such as container placement photo or delivery location image.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Departure Timestamp' ;
    rdfs:comment 'Date and time when the vehicle departed from the origin location (depot, ICD, or CFS) for this last-mile delivery leg.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distanceTraveledKm rdf:type rdf:Property ;
    rdfs:label 'Distance Traveled Km' ;
    rdfs:comment 'Total distance traveled in kilometers from origin to the current event location. Calculated from GPS tracking data or route planning system.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverContactNumber rdf:type rdf:Property ;
    rdfs:label 'Driver Contact Number' ;
    rdfs:comment 'Mobile phone number of the driver for real-time communication during last-mile delivery. Enables coordination and issue resolution.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Estimated date and time of arrival at the destination location, calculated based on current location, traffic conditions, and route. Updated dynamically during transit.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the driver or dispatcher at the time of the event. Provides additional context for operational tracking and issue resolution.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Sequential order number of this event within the last-mile delivery journey for the container. Enables chronological ordering and event replay.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'System or channel that captured and reported this last-mile event. Indicates the origin of the event data for data quality and lineage tracking.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedDeliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Failed Delivery Notes' ;
    rdfs:comment 'Free-text notes providing additional details about a failed delivery attempt, including actions taken and next steps planned.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedDeliveryReason rdf:type rdf:Property ;
    rdfs:label 'Failed Delivery Reason' ;
    rdfs:comment 'Reason code for failed delivery attempts. Populated only when event_type is failed_delivery. Enables root cause analysis of delivery failures. [ENUM-REF-CANDIDATE: consignee_unavailable|access_denied|incorrect_address|cargo_refused|documentation_issue|vehicle_breakdown|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy Meters' ;
    rdfs:comment 'Accuracy radius of the GPS coordinates in meters. Indicates the precision of the location data captured at the time of the event.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityPercentage rdf:type rdf:Property ;
    rdfs:label 'Humidity Percentage' ;
    rdfs:comment 'Relative humidity percentage at the time of the event, captured from container monitoring sensors. Applicable for humidity-sensitive cargo.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfDeliveryReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Reference' ;
    rdfs:comment 'Reference number or identifier for the proof of delivery documentation, such as signed delivery receipt, electronic signature ID, or photo evidence reference.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Route Deviation Flag' ;
    rdfs:comment 'Indicates whether the vehicle deviated from the planned route. True if deviation detected, false if following planned route. Used for route optimization and security monitoring.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealStatus rdf:type rdf:Property ;
    rdfs:label 'Seal Status' ;
    rdfs:comment 'Status of the container security seal at the time of this event. Critical for cargo security and customs compliance.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Temperature reading in Celsius at the time of the event, captured from reefer container monitoring or ambient temperature sensor. Applicable for temperature-controlled cargo.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Number' ;
    rdfs:comment 'Reference to the vehicle (truck, trailer, or drayage unit) performing the last-mile delivery.' ;
    rdfs:domain ind:LastMileEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerHandlingCapability rdf:type rdf:Property ;
    rdfs:label 'Container Handling Capability' ;
    rdfs:comment 'Type of container units the operator is equipped to handle, including TEU (Twenty-foot Equivalent Unit), FEU (Forty-foot Equivalent Unit), refrigerated containers, and IMDG (International Maritime Dangerous Goods) certified cargo.' ;
    rdfs:domain ind:RailOperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locomotiveTypes rdf:type rdf:Property ;
    rdfs:label 'Locomotive Types' ;
    rdfs:comment 'Comma-separated list of locomotive types operated by the carrier (e.g., diesel, electric, hybrid), indicating traction capability and environmental profile.' ;
    rdfs:domain ind:RailOperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxGrossWeightTonnes rdf:type rdf:Property ;
    rdfs:label 'Max Gross Weight Tonnes' ;
    rdfs:comment 'Maximum gross train weight in tonnes that the operator is authorized and equipped to haul, based on locomotive capacity and track load limits.' ;
    rdfs:domain ind:RailOperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTrainLengthM rdf:type rdf:Property ;
    rdfs:label 'Max Train Length M' ;
    rdfs:comment 'Maximum train length in meters that the operator can handle, constrained by locomotive power, siding capacity, and network infrastructure.' ;
    rdfs:domain ind:RailOperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkAccessAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Network Access Agreement Reference' ;
    rdfs:comment 'Reference number or identifier for the network access agreement between the rail operator and the rail infrastructure manager, governing track usage rights and charges.' ;
    rdfs:domain ind:RailOperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Composite performance rating score (0.00 to 5.00) based on KPIs such as on-time delivery, cargo handling quality, safety record, and EDI compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the rail operator\'s preferred invoicing and settlement currency (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:RailOperator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL of the rail operator for public information and service inquiries.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Rail visit operations require employee assignment for train coordination, dispatch oversight, and operational accountability. Maritime terminals track which employee manages each rail visit for issue ' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:railTerminalZoneId rdf:type rdf:Property ;
    rdfs:label 'Rail Terminal Zone Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.terminal_zone. Business justification: Rail visits operate within dedicated rail-served terminal zones, enabling rail capacity planning, track allocation, and intermodal transfer coordination - rail operations planning process. Role-prefix' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalZone .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'Actual date and time when the train physically arrived at the port terminal rail facility. Recorded by terminal operations for performance measurement and billing.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Time' ;
    rdfs:comment 'Actual date and time when the train departed from the port terminal rail facility. Recorded for performance measurement, billing, and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the rail visit was marked as completed, indicating all loading/unloading operations finished and the train departed. Used for performance measurement and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerCountDischarged rdf:type rdf:Property ;
    rdfs:label 'Container Count Discharged' ;
    rdfs:comment 'Total number of individual containers unloaded from the train during this visit, regardless of size. Used for operational tracking and billing.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerCountLoaded rdf:type rdf:Property ;
    rdfs:label 'Container Count Loaded' ;
    rdfs:comment 'Total number of individual containers loaded onto the train during this visit, regardless of size. Used for operational tracking and billing.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emptyWagonCount rdf:type rdf:Property ;
    rdfs:label 'Empty Wagon Count' ;
    rdfs:comment 'Number of empty wagons in the train consist. Used for capacity planning and outbound loading operations.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Time' ;
    rdfs:comment 'Current estimated arrival time based on real-time tracking and updates from the rail operator. Updated as the train progresses toward the terminal.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Time' ;
    rdfs:comment 'Current estimated departure time based on operational progress and remaining work. Updated throughout the visit as operations proceed.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadedWagonCount rdf:type rdf:Property ;
    rdfs:label 'Loaded Wagon Count' ;
    rdfs:comment 'Number of wagons carrying containers or cargo upon arrival. Used for workload estimation and equipment planning.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Operator Reference Number' ;
    rdfs:comment 'Rail operator\'s internal reference or booking number for this train visit. Used for reconciliation and communication with the rail carrier.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Time' ;
    rdfs:comment 'Planned date and time when the train is scheduled to arrive at the port terminal rail facility. Used for resource planning and berth allocation.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Time' ;
    rdfs:comment 'Planned date and time when the train is scheduled to depart from the port terminal rail facility after completing loading/unloading operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:teuCapacity rdf:type rdf:Property ;
    rdfs:label 'Teu Capacity' ;
    rdfs:comment 'Total container capacity of the train expressed in Twenty-foot Equivalent Units (TEU). Standard measure for rail capacity planning and performance reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teuDischarged rdf:type rdf:Property ;
    rdfs:label 'Teu Discharged' ;
    rdfs:comment 'Actual number of TEU unloaded from the train during this visit. Used for productivity measurement and billing calculations.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teuLoaded rdf:type rdf:Property ;
    rdfs:label 'Teu Loaded' ;
    rdfs:comment 'Actual number of TEU loaded on the train for this visit. Used for productivity measurement and billing calculations.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackAssignment rdf:type rdf:Property ;
    rdfs:label 'Track Assignment' ;
    rdfs:comment 'Identifier of the rail track or siding where the train is positioned for loading and unloading operations. Critical for yard management and equipment dispatch.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainIdentifier rdf:type rdf:Property ;
    rdfs:label 'Train Identifier' ;
    rdfs:comment 'Unique identifier assigned to the train by the rail operator. Used for tracking the physical train consist throughout its journey.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Train Length Meters' ;
    rdfs:comment 'Total physical length of the train consist in meters. Used for track capacity planning and safety compliance.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainWeightTonnes rdf:type rdf:Property ;
    rdfs:label 'Train Weight Tonnes' ;
    rdfs:comment 'Total weight of the train including wagons and cargo in metric tonnes. Used for infrastructure load management and safety compliance.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitNumber rdf:type rdf:Property ;
    rdfs:label 'Visit Number' ;
    rdfs:comment 'Business identifier for the rail visit. Externally-known unique reference number assigned by the Terminal Operating System (TOS) for tracking and communication purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitStatus rdf:type rdf:Property ;
    rdfs:label 'Visit Status' ;
    rdfs:comment 'Current lifecycle status of the rail visit. Tracks the visit through scheduling, arrival, operations, and departure phases. [ENUM-REF-CANDIDATE: scheduled|confirmed|arrived|in_progress|departed|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitType rdf:type rdf:Property ;
    rdfs:label 'Visit Type' ;
    rdfs:comment 'Classification of the rail visit based on operational purpose. Inbound brings containers to port, outbound removes containers, interchange involves both, shuttle provides regular scheduled service.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wagonCount rdf:type rdf:Property ;
    rdfs:label 'Wagon Count' ;
    rdfs:comment 'Total number of rail wagons (railcars) in the train consist. Used for capacity planning and operational resource allocation.' ;
    rdfs:domain ind:RailVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:railWagonId rdf:type rdf:Property ;
    rdfs:label 'Rail Wagon Id' ;
    rdfs:comment 'Unique system identifier for the rail wagon record. Primary key.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RailWagon .

ind:ghgEmissionRecordId rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Record Id' ;
    rdfs:comment 'Foreign key linking to safety.ghg_emission_record. Business justification: Port-owned or leased rail wagon emissions tracking for Scope 3 GHG reporting under GHG Protocol. Links wagon operational data (tare_weight_kg, gross_weight_limit_kg, operational_status) to emission ca' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GhgEmissionRecord .

ind:axleCount rdf:type rdf:Property ;
    rdfs:label 'Axle Count' ;
    rdfs:comment 'The number of axles on the rail wagon. Affects weight distribution, track wear, and operational restrictions.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bogieType rdf:type rdf:Property ;
    rdfs:label 'Bogie Type' ;
    rdfs:comment 'The type or model of bogie (wheel assembly) fitted to the wagon, affecting ride quality, speed capability, and maintenance requirements.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brakeSystem rdf:type rdf:Property ;
    rdfs:label 'Brake System' ;
    rdfs:comment 'The type of braking system installed on the wagon, critical for train composition and safety compliance.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildDate rdf:type rdf:Property ;
    rdfs:label 'Build Date' ;
    rdfs:comment 'The specific date the rail wagon was completed and released from the manufacturing facility.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'The date when the wagon\'s operational certification expires and requires renewal.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Container Capacity Teu' ;
    rdfs:comment 'The maximum container capacity of the wagon expressed in TEU. For example, a wagon that can carry two 20-foot containers or one 40-foot container would have a capacity of 2.0 TEU.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couplingType rdf:type rdf:Property ;
    rdfs:label 'Coupling Type' ;
    rdfs:comment 'The type of coupling mechanism used to connect the wagon to other rail vehicles, affecting interoperability with different rail systems.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deckHeightM rdf:type rdf:Property ;
    rdfs:label 'Deck Height M' ;
    rdfs:comment 'The height of the loading deck from rail level in meters. Critical for container loading operations and determining stacking feasibility.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doubleStackCapable rdf:type rdf:Property ;
    rdfs:label 'Double Stack Capable' ;
    rdfs:comment 'Indicates whether the wagon design allows for double-stacking of containers, typically applicable to well wagons.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Indicates whether the wagon is equipped with GPS tracking capability for real-time location monitoring.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossWeightLimitKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Limit Kg' ;
    rdfs:comment 'The maximum total weight (tare weight plus payload) in kilograms that the wagon is permitted to operate at, considering track and bridge load limits.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the wagon is certified to transport hazardous materials according to IMDG Code standards.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightM rdf:type rdf:Property ;
    rdfs:label 'Height M' ;
    rdfs:comment 'The height of the rail wagon in meters from rail level to the highest point, used for clearance calculations and tunnel/bridge compatibility.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homeDepotLocation rdf:type rdf:Property ;
    rdfs:label 'Home Depot Location' ;
    rdfs:comment 'The primary rail depot or yard where the wagon is based for maintenance and operational purposes.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'The date when the current insurance policy for the wagon expires and requires renewal.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthOverallM rdf:type rdf:Property ;
    rdfs:label 'Length Overall M' ;
    rdfs:comment 'The total length of the rail wagon in meters from end to end, used for train composition planning and yard space allocation.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufactureYear rdf:type rdf:Property ;
    rdfs:label 'Manufacture Year' ;
    rdfs:comment 'The year the rail wagon was manufactured, used for age-based maintenance planning and depreciation calculations.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'The name of the company that manufactured the rail wagon.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Payload Kg' ;
    rdfs:comment 'The maximum cargo weight in kilograms that the rail wagon is certified to carry safely. Critical for load planning and regulatory compliance.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'The legal name of the organization or entity that owns the rail wagon. May be a rail operator, leasing company, or port authority.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refrigerationCapable rdf:type rdf:Property ;
    rdfs:label 'Refrigeration Capable' ;
    rdfs:comment 'Indicates whether the wagon is equipped to carry refrigerated containers with power supply connections.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationAuthority rdf:type rdf:Property ;
    rdfs:label 'Registration Authority' ;
    rdfs:comment 'The regulatory body or national authority that registered and certified the rail wagon for operation.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registration Country Code' ;
    rdfs:comment 'The three-letter ISO country code of the country where the wagon is registered.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'The official registration number issued by the registration authority, distinct from the wagon number and used for regulatory compliance tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swlRatingKg rdf:type rdf:Property ;
    rdfs:label 'Swl Rating Kg' ;
    rdfs:comment 'The Safe Working Load rating in kilograms, representing the maximum load the wagon can handle under normal operating conditions including dynamic forces during transport.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wagonNumber rdf:type rdf:Property ;
    rdfs:label 'Wagon Number' ;
    rdfs:comment 'The externally-known unique identification number assigned to the rail wagon by the owner or registration authority. This is the business identifier used in operational systems and documentation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wagonType rdf:type rdf:Property ;
    rdfs:label 'Wagon Type' ;
    rdfs:comment 'Classification of the rail wagon based on its structural design and intended cargo type. Flat wagons have a flat deck, well wagons have a recessed center for double-stacking containers, spine wagons have a central spine for container placement.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthM rdf:type rdf:Property ;
    rdfs:label 'Width M' ;
    rdfs:comment 'The width of the rail wagon in meters, important for clearance verification and loading gauge compliance.' ;
    rdfs:domain ind:RailWagon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intermodalRailWagonLoadId rdf:type rdf:Property ;
    rdfs:label 'Intermodal Rail Wagon Load Id' ;
    rdfs:comment 'Unique identifier for the rail wagon load association record. Primary key for this entity.' ;
    rdfs:domain ind:IntermodalRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualLoadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Load Timestamp' ;
    rdfs:comment 'Actual date and time when this container or cargo unit was physically loaded onto the wagon. Captured by TOS or gate systems. Used for performance measurement and billing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consigneeReference rdf:type rdf:Property ;
    rdfs:label 'Consignee Reference' ;
    rdfs:comment 'Consignee-provided reference number for cargo receipt and delivery confirmation. Used for delivery coordination and proof of delivery documentation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lashingInstructions rdf:type rdf:Property ;
    rdfs:label 'Lashing Instructions' ;
    rdfs:comment 'Detailed instructions for securing and lashing the container or cargo unit to the wagon. Includes twist lock positions, chain requirements, and special securing equipment needed for safe rail transport.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Load Sequence Number' ;
    rdfs:comment 'Order in which this container or cargo unit was loaded onto the wagon. Supports operational tracking and unloading sequence planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netCargoWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Cargo Weight Kg' ;
    rdfs:comment 'Net weight of the cargo inside the container in kilograms, calculated as gross weight minus tare weight. Used for billing, customs declarations, and cargo manifests.' ;
    rdfs:domain ind:IntermodalRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedLoadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Load Timestamp' ;
    rdfs:comment 'Scheduled date and time when this container or cargo unit is planned to be loaded onto the wagon. Used for resource planning and operational scheduling.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Secured Timestamp' ;
    rdfs:comment 'Date and time when the load was confirmed as properly secured and ready for rail departure. Represents completion of lashing and safety checks.' ;
    rdfs:domain ind:IntermodalRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securingEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Securing Equipment Type' ;
    rdfs:comment 'Type of equipment used to secure the load to the wagon (e.g., twist locks for containers, chains for heavy cargo, straps for non-standard loads). Ensures proper securing method is applied.' ;
    rdfs:domain ind:IntermodalRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Code indicating special handling requirements for this load (e.g., fragile, top load only, no stacking, temperature sensitive). Drives operational procedures and equipment selection.' ;
    rdfs:domain ind:IntermodalRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unloadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unload Timestamp' ;
    rdfs:comment 'Actual date and time when this container or cargo unit was unloaded from the wagon at the destination. Used for dwell time calculation and performance reporting.' ;
    rdfs:domain ind:IntermodalRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wagonPositionNumber rdf:type rdf:Property ;
    rdfs:label 'Wagon Position Number' ;
    rdfs:comment 'Sequential position number of this wagon within the rail consist or train formation. Used for load planning and operational sequencing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingRateCardId rdf:type rdf:Property ;
    rdfs:label 'Booking Rate Card Id' ;
    rdfs:comment 'Foreign key linking to tariff.rate_card. Business justification: Slot bookings (capacity reservations) are priced using customer-specific rate cards. Critical for booking confirmation, revenue estimation, and capacity management billing in intermodal services.' ;
    rdfs:domain ind:SlotBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:actualTransportDate rdf:type rdf:Property ;
    rdfs:label 'Actual Transport Date' ;
    rdfs:comment 'Actual date when the intermodal transport service was executed. Used for on-time performance measurement and SLA compliance.' ;
    rdfs:domain ind:SlotBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingChannel rdf:type rdf:Property ;
    rdfs:label 'Booking Channel' ;
    rdfs:comment 'Channel through which the booking was submitted. Used for channel performance analysis and digital adoption tracking.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Timestamp' ;
    rdfs:comment 'Precise date and time when the booking was created in the system. Used for audit trail and first-come-first-served slot allocation.' ;
    rdfs:domain ind:SlotBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingType rdf:type rdf:Property ;
    rdfs:label 'Booking Type' ;
    rdfs:comment 'Type of intermodal transport mode for this booking. Determines handling procedures and capacity allocation rules.' ;
    rdfs:domain ind:SlotBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for booking cancellation. Used for root cause analysis and service improvement.' ;
    rdfs:domain ind:SlotBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the booking status changed to confirmed. Used for service level measurement and customer notification tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedSlotDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Slot Date' ;
    rdfs:comment 'Actual date confirmed for the intermodal transport slot. Null if booking is pending or waitlisted.' ;
    rdfs:domain ind:SlotBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedSlotTime rdf:type rdf:Property ;
    rdfs:label 'Confirmed Slot Time' ;
    rdfs:comment 'Precise date and time window confirmed for the intermodal transport departure or pickup. Used for gate appointment coordination.' ;
    rdfs:domain ind:SlotBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'Customer\'s own internal reference or purchase order number for this booking. Used for reconciliation and customer reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Code' ;
    rdfs:comment 'ISO 6346 equipment type code specifying the container or equipment type required for this booking (e.g., 22G1 for 20ft general purpose).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noShowIndicator rdf:type rdf:Property ;
    rdfs:label 'No Show Indicator' ;
    rdfs:comment 'Flag indicating whether the customer failed to utilize the confirmed slot. Used for no-show penalty assessment and capacity planning.' ;
    rdfs:domain ind:SlotBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oversizedIndicator rdf:type rdf:Property ;
    rdfs:label 'Oversized Indicator' ;
    rdfs:comment 'Flag indicating whether this booking includes oversized or out-of-gauge cargo requiring special equipment or routing.' ;
    rdfs:domain ind:SlotBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedTransportDate rdf:type rdf:Property ;
    rdfs:label 'Requested Transport Date' ;
    rdfs:comment 'Date requested by the customer for the intermodal transport service. May differ from confirmed slot date based on availability.' ;
    rdfs:domain ind:SlotBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teuQuantity rdf:type rdf:Property ;
    rdfs:label 'Teu Quantity' ;
    rdfs:comment 'Total capacity of this booking expressed in TEU. Calculated from container sizes (20ft=1 TEU, 40ft=2 TEU, 45ft=2.25 TEU). Used for capacity utilization reporting.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightTonnes rdf:type rdf:Property ;
    rdfs:label 'Weight Tonnes' ;
    rdfs:comment 'Total gross weight of cargo in this booking expressed in metric tonnes. Used for load planning and compliance with weight restrictions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTransportParticipantAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Transport Participant Account Id' ;
    rdfs:comment 'Identifier of the party shipping the cargo. References the port community participant acting as the consignor.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParticipantAccount .

ind:tertiaryTransportCarrierParticipantAccountId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Transport Carrier Participant Account Id' ;
    rdfs:comment 'Identifier of the transport carrier or haulier assigned to execute this transport order. References the logistics service provider.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParticipantAccount .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date and time when cargo was delivered to consignee. Used for SLA compliance and proof of delivery.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPickupDate rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Date' ;
    rdfs:comment 'Actual date and time when cargo was picked up from origin. Used for performance tracking and billing.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Legal name of the carrier organization responsible for transport execution.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Planned date and time for cargo delivery to destination. Used for customer communication and planning.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Pickup Date' ;
    rdfs:comment 'Planned date and time for cargo pickup from origin location. Used for scheduling and coordination.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:iftminReference rdf:type rdf:Property ;
    rdfs:label 'Iftmin Reference' ;
    rdfs:comment 'EDI IFTMIN message reference number for this transport instruction. Links to the electronic data interchange message sent to logistics partners.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date and time when the transport order was created and issued to the carrier. Represents the business event timestamp for order initiation.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryTransportMode rdf:type rdf:Property ;
    rdfs:label 'Primary Transport Mode' ;
    rdfs:comment 'Dominant mode of transport for this order. Used for high-level categorization and reporting.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Target date by which the cargo must be delivered to the final destination. Used for SLA tracking and scheduling.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transportModeSequence rdf:type rdf:Property ;
    rdfs:label 'Transport Mode Sequence' ;
    rdfs:comment 'Ordered sequence of transport modes for this intermodal journey (e.g., sea-rail-road, sea-road, rail-road). Defines the multimodal routing plan.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transport Order Number' ;
    rdfs:comment 'Business-facing unique transport order number issued to carrier or haulier. Externally visible identifier used in communications and documentation.' ;
    rdfs:domain ind:TransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverPortAccessPermitId rdf:type rdf:Property ;
    rdfs:label 'Driver Port Access Permit Id' ;
    rdfs:comment 'Foreign key linking to customer.port_access_permit. Business justification: Truck appointments require valid port access permits for drivers entering secure ISPS-regulated port facilities. Enables permit verification at appointment booking and gate entry, critical for maritim' ;
    rdfs:domain ind:TruckAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortAccessPermit .

ind:appointmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appointment Created Timestamp' ;
    rdfs:comment 'Timestamp when the appointment record was first created in the system. Audit trail for booking lifecycle.' ;
    rdfs:domain ind:TruckAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appointment Modified Timestamp' ;
    rdfs:comment 'Timestamp when the appointment record was last modified. Tracks amendments and updates to the booking.' ;
    rdfs:domain ind:TruckAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for the appointment or booking, generated by the Truck Appointment System (TAS) or intermodal booking portal. Used for customer communication and tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedSlotEndTime rdf:type rdf:Property ;
    rdfs:label 'Confirmed Slot End Time' ;
    rdfs:comment 'End of the confirmed time window allocated by the terminal.' ;
    rdfs:domain ind:TruckAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedSlotStartTime rdf:type rdf:Property ;
    rdfs:label 'Confirmed Slot Start Time' ;
    rdfs:comment 'Start of the confirmed time window allocated by the terminal. May differ from requested time based on capacity availability.' ;
    rdfs:domain ind:TruckAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerSize rdf:type rdf:Property ;
    rdfs:label 'Container Size' ;
    rdfs:comment 'Length of the container in feet. Standard sizes are 20-foot, 40-foot, and 45-foot containers.' ;
    rdfs:domain ind:TruckAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateLaneNumber rdf:type rdf:Property ;
    rdfs:label 'Gate Lane Number' ;
    rdfs:comment 'Specific gate lane assigned for the appointment. Used for traffic management and gate capacity optimization.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedSlotEndTime rdf:type rdf:Property ;
    rdfs:label 'Requested Slot End Time' ;
    rdfs:comment 'End of the requested time window for the appointment. Represents the latest time within the booking window.' ;
    rdfs:domain ind:TruckAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedSlotStartTime rdf:type rdf:Property ;
    rdfs:label 'Requested Slot Start Time' ;
    rdfs:comment 'Start of the requested time window for the appointment. Represents the earliest time the booking party wishes to arrive.' ;
    rdfs:domain ind:TruckAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:yardBlockLocation rdf:type rdf:Property ;
    rdfs:label 'Yard Block Location' ;
    rdfs:comment 'Yard block or stack location where the container is stored or will be placed. Guides driver to container location for pickup.' ;
    rdfs:domain ind:TruckAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Driver Employee Id' ;
    rdfs:comment 'Reference to the registered driver who presented credentials at the gate. Links to the driver master record for identity verification and access control.' ;
    rdfs:domain ind:TruckVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:gateTransactionId rdf:type rdf:Property ;
    rdfs:label 'Gate Transaction Id' ;
    rdfs:comment 'FK to terminal.gate_transaction.gate_transaction_id — Truck lifecycle tracking from intermodal appointment through gate execution requires joining truck_visit to the terminal gate_transaction. Without this, truck turnaround time analytics are impossible.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GateTransaction .

ind:damageReportIndicator rdf:type rdf:Property ;
    rdfs:label 'Damage Report Indicator' ;
    rdfs:comment 'Boolean flag indicating whether visible damage to the container or cargo was observed and documented during the gate transaction. Triggers damage inspection workflow.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Driver Verification Method' ;
    rdfs:comment 'Method used to verify the driver\'s identity at the gate, including biometric scan, RFID access card, manual ID document check, or facial recognition system.' ;
    rdfs:domain ind:TruckVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateInTime rdf:type rdf:Property ;
    rdfs:label 'Gate In Time' ;
    rdfs:comment 'Timestamp when the truck completed all gate-in processing and was authorized to enter the terminal yard. Represents the completion of inbound gate transaction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gateOutTime rdf:type rdf:Property ;
    rdfs:label 'Gate Out Time' ;
    rdfs:comment 'Timestamp when the truck completed all gate-out processing and exited the terminal. Represents the completion of outbound gate transaction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ispsComplianceCheckResult rdf:type rdf:Property ;
    rdfs:label 'Isps Compliance Check Result' ;
    rdfs:comment 'Result of the ISPS security compliance verification performed at the gate, indicating whether the driver and vehicle met all required security protocols for port facility access.' ;
    rdfs:domain ind:TruckVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlateNumber rdf:type rdf:Property ;
    rdfs:label 'License Plate Number' ;
    rdfs:comment 'Vehicle registration plate number of the truck, typically captured via Optical Character Recognition (OCR) system at the gate. Used for vehicle identification and tracking.' ;
    rdfs:domain ind:TruckVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocrConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Ocr Confidence Score' ;
    rdfs:comment 'Confidence percentage (0-100) of the automated OCR system\'s license plate read accuracy. Low scores may trigger manual verification by gate operators.' ;
    rdfs:domain ind:TruckVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sealVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Seal Verification Status' ;
    rdfs:comment 'Result of the container seal inspection at the gate, indicating whether the seal was intact and matched documentation (verified), was found broken, was missing, or was not applicable for this transaction type.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from actual arrival at the gate to final gate-out completion. Key performance indicator (KPI) for gate efficiency and truck dwell time measurement.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marineIncidentId rdf:type rdf:Property ;
    rdfs:label 'Marine Incident Id' ;
    rdfs:comment 'Unique system-generated identifier for each marine incident record. Primary key for the incident data product.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarineIncident .

ind:damagedPortAssetId rdf:type rdf:Property ;
    rdfs:label 'Damaged Port Asset Id' ;
    rdfs:comment 'Foreign key linking to asset.port_asset. Business justification: Marine incidents frequently damage port assets (fenders, cranes, bollards, tugs). Insurance claims, corrective action planning, and root cause analysis require linking incidents to affected assets for' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortAsset .

ind:involvedGangId rdf:type rdf:Property ;
    rdfs:label 'Involved Gang Id' ;
    rdfs:comment 'Foreign key linking to workforce.gang. Business justification: Incidents involving stevedore gangs require gang identification for safety investigation and root cause analysis - real safety management requirement in terminal operations.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gang .

ind:pilotageAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Pilotage Assignment Id' ;
    rdfs:comment 'Reference to the pilotage assignment active at the time of the incident, if a pilot was on board. Links to the pilotage service record.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PilotageAssignment .

ind:amsaNotified rdf:type rdf:Property ;
    rdfs:label 'Amsa Notified' ;
    rdfs:comment 'Indicates whether the Australian Maritime Safety Authority (AMSA) has been formally notified of the incident as required under national maritime safety regulations.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Structured narrative of secondary contributing factors identified during investigation, such as weather conditions, equipment state, crew fatigue, or procedural non-compliance. Supports multi-causal analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActions rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions' ;
    rdfs:comment 'Structured narrative of corrective and preventive actions (CAPAs) identified during the investigation, including responsible parties and target completion dates. Drives safety management system updates.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsCompleted rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Completed' ;
    rdfs:comment 'Indicates whether all corrective and preventive actions identified in the investigation have been fully implemented and verified as effective.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionsDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Due Date' ;
    rdfs:comment 'Target date by which all corrective and preventive actions identified in the investigation must be completed and verified. Used for safety management follow-up tracking.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:datetime rdf:type rdf:Property ;
    rdfs:label 'Datetime' ;
    rdfs:comment 'The precise date and time (UTC) at which the marine incident occurred or was first observed. This is the principal real-world event timestamp used for regulatory reporting and investigation timelines.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDamageCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Damage Cost Usd' ;
    rdfs:comment 'Estimated total financial cost of damage to vessel, cargo, and port infrastructure resulting from the incident, expressed in USD. Used for insurance claims, P&I notifications, and financial reporting.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fatalitiesCount rdf:type rdf:Property ;
    rdfs:label 'Fatalities Count' ;
    rdfs:comment 'Total number of fatalities directly resulting from the incident. A non-zero value triggers mandatory IMO Very Serious Casualty classification and flag-state notification.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flagStateNotified rdf:type rdf:Property ;
    rdfs:label 'Flag State Notified' ;
    rdfs:comment 'Indicates whether the vessel\'s flag state administration has been formally notified of the incident as required under SOLAS Chapter XI-1 Regulation 6.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humanFactorInvolved rdf:type rdf:Property ;
    rdfs:label 'Human Factor Involved' ;
    rdfs:comment 'Indicates whether a human factor (crew error, pilot error, shore-side decision) was identified as a contributing cause of the incident. Used for safety trend analysis and training programme targeting.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immediateCause rdf:type rdf:Property ;
    rdfs:label 'Immediate Cause' ;
    rdfs:comment 'Narrative description of the direct, proximate cause of the incident as determined during initial reporting (e.g., \'Mooring line parted under excessive load\', \'Engine failure during berthing manoeuvre\'). May be updated during formal investigation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoNotified rdf:type rdf:Property ;
    rdfs:label 'Imo Notified' ;
    rdfs:comment 'Indicates whether the IMO has been formally notified of the incident. Required for Very Serious Casualties under the IMO Casualty Investigation Code.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'IMO casualty severity classification of the incident. Very Serious Casualty involves loss of vessel, loss of life, or severe pollution. Drives mandatory flag-state and IMO reporting obligations. [ENUM-REF-CANDIDATE: very_serious_casualty|serious_casualty|less_serious_casualty|marine_incident|near_miss — promote to reference product]' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Operational classification of the type of marine incident. Determines applicable SOLAS/MARPOL regulatory framework and investigation protocol. [ENUM-REF-CANDIDATE: collision|grounding|allision|mooring_failure|pollution_event|fire_explosion|man_overboard|structural_failure|near_miss|flooding — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infrastructureDamageDescription rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Damage Description' ;
    rdfs:comment 'Narrative description of damage to port infrastructure (berth, fender, quay wall, mooring bollard, crane) resulting from the incident. Triggers Maximo work order creation for repair.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuriesCount rdf:type rdf:Property ;
    rdfs:label 'Injuries Count' ;
    rdfs:comment 'Total number of persons sustaining injuries (non-fatal) as a direct result of the incident. Includes crew, port workers, and any other persons on board or in the vicinity.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Close Date' ;
    rdfs:comment 'Date on which the formal investigation was officially closed and findings were finalised. Null if investigation is still open.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationLead rdf:type rdf:Property ;
    rdfs:label 'Investigation Lead' ;
    rdfs:comment 'Name or employee identifier of the designated lead investigator responsible for conducting the formal investigation under the IMO Casualty Investigation Code.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date on which the formal investigation was officially opened. Used to track investigation duration against regulatory and internal SLA targets.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the incident investigation workflow. Tracks progression from initial report through formal investigation under the IMO Casualty Investigation Code to final closure.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationTeam rdf:type rdf:Property ;
    rdfs:label 'Investigation Team' ;
    rdfs:comment 'Comma-separated list of investigation team member names or employee IDs assigned to the formal investigation. Supports accountability and audit trail for the investigation process.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsSecurityImplication rdf:type rdf:Property ;
    rdfs:label 'Isps Security Implication' ;
    rdfs:comment 'Indicates whether the incident has a security dimension requiring notification or action under the ISPS (International Ship and Port Facility Security) Code.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Human-readable description of the incident location referencing port-specific landmarks such as berth number, fairway name, anchorage zone, or channel designation (e.g., \'Berth 7 - North Quay\', \'Main Fairway Km 3.2\').' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationLatitude rdf:type rdf:Property ;
    rdfs:label 'Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (decimal degrees, WGS84) of the incident location within port waters. Used for spatial analysis, VTS replay, and regulatory reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationLongitude rdf:type rdf:Property ;
    rdfs:label 'Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (decimal degrees, WGS84) of the incident location within port waters. Used for spatial analysis, VTS replay, and regulatory reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marpolClassification rdf:type rdf:Property ;
    rdfs:label 'Marpol Classification' ;
    rdfs:comment 'The specific MARPOL annex under which a pollution incident is classified (e.g., Annex I - Oil, Annex II - Noxious Liquid Substances, Annex V - Garbage). Null if no pollution component.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingPersonsCount rdf:type rdf:Property ;
    rdfs:label 'Missing Persons Count' ;
    rdfs:comment 'Number of persons reported missing following the incident (e.g., man-overboard events). Drives search-and-rescue coordination and regulatory notification.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:piClubNotificationDatetime rdf:type rdf:Property ;
    rdfs:label 'Pi Club Notification Datetime' ;
    rdfs:comment 'Date and time the P&I (Protection and Indemnity) club was formally notified of the incident. Used to verify compliance with P&I notification windows.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:piClubNotified rdf:type rdf:Property ;
    rdfs:label 'Pi Club Notified' ;
    rdfs:comment 'Indicates whether the vessel owner\'s P&I (Protection and Indemnity) club has been formally notified of the incident. Mandatory for incidents involving third-party liability, pollution, or personal injury.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pollutionOccurred rdf:type rdf:Property ;
    rdfs:label 'Pollution Occurred' ;
    rdfs:comment 'Indicates whether a pollution event (oil spill, chemical release, garbage discharge) occurred as part of or as a consequence of the incident. Triggers MARPOL reporting obligations.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pollutionSubstance rdf:type rdf:Property ;
    rdfs:label 'Pollution Substance' ;
    rdfs:comment 'Type of substance released into the marine environment (e.g., \'Bunker fuel oil\', \'Bilge water\', \'Noxious liquid substance - Category X\'). Populated only when pollution_occurred is True.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pollutionVolumeLitres rdf:type rdf:Property ;
    rdfs:label 'Pollution Volume Litres' ;
    rdfs:comment 'Estimated or measured volume of pollutant released into port waters, expressed in litres. Used for environmental impact assessment and MARPOL regulatory reporting.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedDatetime rdf:type rdf:Property ;
    rdfs:label 'Reported Datetime' ;
    rdfs:comment 'The date and time the incident was formally reported to port authorities or the duty officer. Used to measure reporting lag and compliance with mandatory notification windows.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:solasClassification rdf:type rdf:Property ;
    rdfs:label 'Solas Classification' ;
    rdfs:comment 'The specific SOLAS chapter or regulation under which this incident is classified for regulatory reporting purposes (e.g., SOLAS Chapter II-1, Chapter III, Chapter XI-1). Null if incident is MARPOL-only.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselDamageDescription rdf:type rdf:Property ;
    rdfs:label 'Vessel Damage Description' ;
    rdfs:comment 'Narrative description of structural or mechanical damage sustained by the primary vessel as a result of the incident. Informs seaworthiness assessment and P&I club notification.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityNauticalMiles rdf:type rdf:Property ;
    rdfs:label 'Visibility Nautical Miles' ;
    rdfs:comment 'Recorded horizontal visibility in nautical miles at the incident location at the time of the incident. Relevant to collision and grounding investigations.' ;
    rdfs:domain ind:MarineIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Knots' ;
    rdfs:comment 'Recorded wind speed in knots at the incident location at the time of the incident. Key environmental factor in casualty investigation and risk modelling.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:launchDispatchId rdf:type rdf:Property ;
    rdfs:label 'Launch Dispatch Id' ;
    rdfs:comment 'Unique surrogate identifier for each launch boat dispatch event record in the silver layer lakehouse. Primary key for the launch_dispatch data product.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationAnchorageAreaId rdf:type rdf:Property ;
    rdfs:label 'Destination Anchorage Area Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.anchorage_area. Business justification: Launch boats transfer pilots and crew to vessels at anchorage; destination_location and anchorage_block currently text. Essential for pilot boat routing, fuel planning, and service coordination.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnchorageArea .

ind:pilotId rdf:type rdf:Property ;
    rdfs:label 'Pilot Id' ;
    rdfs:comment 'Reference to the marine pilot record transported on this dispatch, applicable when dispatch_purpose is \'pilot_transfer\'. Enables traceability between pilot assignments and launch dispatch operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pilot .

ind:servedVesselId rdf:type rdf:Property ;
    rdfs:label 'Served Vessel Id' ;
    rdfs:comment 'Reference to the vessel record that this launch boat dispatch is serving (e.g., the ship receiving the pilot, crew, or surveyor). Links to the vessel master data product.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vessel .

ind:servedVesselMasterId rdf:type rdf:Property ;
    rdfs:label 'Served Vessel Master Id' ;
    rdfs:comment 'Foreign key linking to masterdata.vessel_master. Business justification: Launch dispatch to vessels requires vessel master data for ISPS security verification, pilot boarding ground determination, and P&I club notification protocols. Role-prefixed to distinguish from launc' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VesselMaster .

ind:actualReturnTime rdf:type rdf:Property ;
    rdfs:label 'Actual Return Time' ;
    rdfs:comment 'Actual timestamp when the launch boat returned to the departure jetty after completing the dispatch mission. Used to calculate total mission duration and vessel availability.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coxswainLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Coxswain Licence Number' ;
    rdfs:comment 'Official maritime authority licence number of the coxswain, verified at dispatch to confirm the operator holds a valid and current certification to operate the launch vessel.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coxswainName rdf:type rdf:Property ;
    rdfs:label 'Coxswain Name' ;
    rdfs:comment 'Full name of the coxswain operating the launch boat for this dispatch, retained in the dispatch log for accountability, incident investigation, and regulatory compliance.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureJetty rdf:type rdf:Property ;
    rdfs:label 'Departure Jetty' ;
    rdfs:comment 'Name or code of the jetty, berth, or landing point from which the launch boat departed for this dispatch mission. Used for operational planning and berth utilisation reporting.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchAuthorisedBy rdf:type rdf:Property ;
    rdfs:label 'Dispatch Authorised By' ;
    rdfs:comment 'Name or identifier of the port operations officer or VTS controller who authorised this launch boat dispatch, providing an accountability trail for operational decisions.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchPriority rdf:type rdf:Property ;
    rdfs:label 'Dispatch Priority' ;
    rdfs:comment 'Operational priority classification of this dispatch. \'routine\' = standard scheduled service; \'urgent\' = expedited service required; \'emergency\' = immediate response (e.g., medical evacuation, safety incident).' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchPurpose rdf:type rdf:Property ;
    rdfs:label 'Dispatch Purpose' ;
    rdfs:comment 'Primary operational purpose of the launch boat dispatch. Drives resource allocation, safety protocols, and billing tariff selection. [ENUM-REF-CANDIDATE: pilot_transfer|crew_change|chandler_delivery|inspection|surveyor_boarding|customs_boarding|medical_evacuation — promote to reference product]' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchReference rdf:type rdf:Property ;
    rdfs:label 'Dispatch Reference' ;
    rdfs:comment 'Externally-known business reference number assigned to this dispatch event, used for cross-system tracking and communication with vessel agents, pilots, and port operations. Format: LD-YYYY-NNNNNN.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchStatus rdf:type rdf:Property ;
    rdfs:label 'Dispatch Status' ;
    rdfs:comment 'Current lifecycle state of the launch boat dispatch event. \'scheduled\' = assigned and awaiting departure; \'in_progress\' = launch underway; \'completed\' = mission accomplished and returned; \'cancelled\' = cancelled before departure; \'aborted\' = mission terminated mid-operation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumedLitres rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumed Litres' ;
    rdfs:comment 'Volume of fuel consumed in litres during this dispatch mission, recorded for fleet cost management, GHG emissions tracking, and MARPOL environmental reporting.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentReference rdf:type rdf:Property ;
    rdfs:label 'Incident Reference' ;
    rdfs:comment 'Reference number of the formal marine incident report filed in connection with this dispatch, when incident_reported is True. Links to the marine incident management system for investigation tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReported rdf:type rdf:Property ;
    rdfs:label 'Incident Reported' ;
    rdfs:comment 'Indicates whether a formal marine incident or near-miss report was raised in connection with this dispatch event. True = incident report filed; False = no incident. Triggers P&I club notification workflow when True.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsClearanceVerified rdf:type rdf:Property ;
    rdfs:label 'Isps Clearance Verified' ;
    rdfs:comment 'Indicates whether ISPS security clearance was verified for all persons and cargo on this dispatch prior to departure. Mandatory for port facility security compliance.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifeJacketsWorn rdf:type rdf:Property ;
    rdfs:label 'Life Jackets Worn' ;
    rdfs:comment 'Indicates whether all persons on board the launch boat wore life jackets for the duration of this dispatch, as required by SOLAS and port safety standing orders.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marpolComplianceChecked rdf:type rdf:Property ;
    rdfs:label 'Marpol Compliance Checked' ;
    rdfs:comment 'Indicates whether MARPOL environmental compliance checks (e.g., no illegal discharge, waste handling) were completed for this dispatch. Mandatory for environmental management system (EMS) audit trails.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Mission Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from actual departure to actual return for this dispatch mission. Stored as a raw operational field to support billing, SLA analysis, and fleet utilisation reporting.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nightOperation rdf:type rdf:Property ;
    rdfs:label 'Night Operation' ;
    rdfs:comment 'Indicates whether this dispatch was conducted during night hours (typically between sunset and sunrise as defined by port standing orders). Night operations attract additional safety requirements and may carry premium tariff rates.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengersCarried rdf:type rdf:Property ;
    rdfs:label 'Passengers Carried' ;
    rdfs:comment 'Total number of persons (pilots, crew, surveyors, inspectors, chandlers) transported on this dispatch. Must not exceed the launch boat\'s certified passenger capacity. Critical for SOLAS safety compliance.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pilotBoardingGround rdf:type rdf:Property ;
    rdfs:label 'Pilot Boarding Ground' ;
    rdfs:comment 'Name or code of the designated pilot boarding/disembarking ground where the pilot transfer took place (e.g., anchorage block, outer roads, inner harbour). Defined by port authority standing orders.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyObservation rdf:type rdf:Property ;
    rdfs:label 'Safety Observation' ;
    rdfs:comment 'Free-text field for the coxswain or dispatcher to record any safety observations, near-misses, equipment anomalies, or unusual conditions encountered during the dispatch mission. Feeds into the port safety management system.' ;
    rdfs:domain ind:LaunchDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seaStateCode rdf:type rdf:Property ;
    rdfs:label 'Sea State Code' ;
    rdfs:comment 'Observed sea state at time of dispatch using the Douglas Sea Scale (0=Glassy to 9=Phenomenal). Values 0-6 captured operationally; values above the launch boat\'s operational limit trigger a safety hold. Critical for SOLAS and OHS compliance. [ENUM-REF-CANDIDATE: 0|1|2|3|4|5|6 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Service Charge Amount' ;
    rdfs:comment 'Gross charge amount levied for this launch boat dispatch service as per the port tariff schedule. Expressed in the port\'s operating currency. Used for revenue recognition and billing reconciliation.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visibilityNm rdf:type rdf:Property ;
    rdfs:label 'Visibility Nm' ;
    rdfs:comment 'Observed meteorological visibility in nautical miles at time of dispatch. Low visibility conditions may require additional safety measures or dispatch suspension per port standing orders.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedSecurityZoneId rdf:type rdf:Property ;
    rdfs:label 'Authorized Security Zone Id' ;
    rdfs:comment 'Foreign key linking to security.security_zone. Business justification: Service orders specify which security zones vessel will transit during pilotage/towage; VTS coordinates with PFSO to pre-authorize zone access, issue temporary zone permits, and configure access contr' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:primaryMarinePortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Primary Marine Port Community Participant Id' ;
    rdfs:comment 'Reference to the licensed pilotage service provider assigned to deliver pilotage services for this order. Must be an authorized pilot organization per port regulations.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:tertiaryMarineApprovedMooringProviderPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Marine Approved Mooring Provider Port Community Participant Id' ;
    rdfs:comment 'Reference to the mooring service provider assigned to deliver line handling services for this order. Must be a certified mooring contractor with trained personnel.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:actualServiceEnd rdf:type rdf:Property ;
    rdfs:label 'Actual Service End' ;
    rdfs:comment 'Actual date and time when all marine services were completed. Used for final billing calculation and Key Performance Indicator (KPI) measurement.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualServiceStart rdf:type rdf:Property ;
    rdfs:label 'Actual Service Start' ;
    rdfs:comment 'Actual date and time when marine services commenced. Recorded for billing accuracy, Service Level Agreement (SLA) compliance, and operational performance tracking.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when all marine services in the order were marked as completed and the order was closed. Triggers final billing and invoicing processes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedServiceEnd rdf:type rdf:Property ;
    rdfs:label 'Estimated Service End' ;
    rdfs:comment 'Estimated date and time when all requested marine services are expected to be completed. Used for resource planning and scheduling.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedServiceStart rdf:type rdf:Property ;
    rdfs:label 'Estimated Service Start' ;
    rdfs:comment 'Estimated date and time when the marine services are expected to commence. Typically aligned with vessel Estimated Time of Berthing (ETB) or Estimated Time of Departure (ETD).' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedTotalCharge rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Charge' ;
    rdfs:comment 'Estimated total charge for all marine services in this order, calculated from applicable tariff rates and estimated service parameters. Excludes taxes and adjustments.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:launchServiceRequired rdf:type rdf:Property ;
    rdfs:label 'Launch Service Required' ;
    rdfs:comment 'Indicates whether launch boat services are requested for personnel transfer between shore and vessel, or between vessels.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchTripCount rdf:type rdf:Property ;
    rdfs:label 'Launch Trip Count' ;
    rdfs:comment 'Number of launch boat trips requested for personnel or light cargo transfer. Each round trip between shore and vessel counts as one trip.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mooringRequired rdf:type rdf:Property ;
    rdfs:label 'Mooring Required' ;
    rdfs:comment 'Indicates whether mooring services (line handling and securing vessel to berth) are requested as part of this service order.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pilotBoardingLocation rdf:type rdf:Property ;
    rdfs:label 'Pilot Boarding Location' ;
    rdfs:comment 'Designated location where the marine pilot will board or disembark the vessel. Typically specified as a named pilot station, anchorage, or berth identifier.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotageType rdf:type rdf:Property ;
    rdfs:label 'Pilotage Type' ;
    rdfs:comment 'Specific type of pilotage service requested. Inbound covers entry from sea to berth, outbound covers departure from berth to sea, shifting covers berth-to-berth movements within port.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Service Duration Minutes' ;
    rdfs:comment 'Total duration of marine service delivery in minutes, calculated from actual start to actual end. Used for billing time-based charges and productivity analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyorRequired rdf:type rdf:Property ;
    rdfs:label 'Surveyor Required' ;
    rdfs:comment 'Indicates whether a marine surveyor boarding is requested for cargo inspection, damage assessment, or compliance verification purposes.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyorType rdf:type rdf:Property ;
    rdfs:label 'Surveyor Type' ;
    rdfs:comment 'Type of marine survey requested. Cargo surveys verify quantity and condition, hull surveys assess vessel structure, draft surveys measure cargo weight via vessel displacement. [ENUM-REF-CANDIDATE: cargo|hull|bunker|draft|damage|pre_loading|post_discharge — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tugHorsepowerRequired rdf:type rdf:Property ;
    rdfs:label 'Tug Horsepower Required' ;
    rdfs:comment 'Minimum total horsepower (HP) required for the towage operation, calculated based on vessel deadweight tonnage (DWT), length overall (LOA), and environmental conditions.' ;
    rdfs:domain ind:MarineServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherRestrictions rdf:type rdf:Property ;
    rdfs:label 'Weather Restrictions' ;
    rdfs:comment 'Weather or environmental conditions under which the marine services cannot be safely delivered. Examples: maximum wind speed, minimum visibility, sea state limits.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marpolOperationId rdf:type rdf:Property ;
    rdfs:label 'Marpol Operation Id' ;
    rdfs:comment 'Unique surrogate identifier for each MARPOL-regulated compliance operation record within the port. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarpolOperation .

ind:supervisingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervising Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: MARPOL waste operations require named supervisor for environmental compliance and regulatory accountability - mandatory requirement under international maritime environmental regulations.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wasteCommodityCodeId rdf:type rdf:Property ;
    rdfs:label 'Waste Commodity Code Id' ;
    rdfs:comment 'Foreign key linking to masterdata.commodity_code. Business justification: Waste disposal operations require commodity classification (MARPOL category, UN number, disposal method) for regulatory compliance, facility licensing verification, and environmental monitoring. Role-' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityCode .

ind:ballastWaterTreatmentMethod rdf:type rdf:Property ;
    rdfs:label 'Ballast Water Treatment Method' ;
    rdfs:comment 'Method used to treat or manage ballast water in compliance with the BWM Convention. Applicable when operation_type = ballast_water_management.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ballastWaterVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Ballast Water Volume M3' ;
    rdfs:comment 'Volume of ballast water in cubic metres managed (exchanged, treated, or discharged) during this operation under the BWM Convention. Applicable when operation_type = ballast_water_management.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalMonitoringRef rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Ref' ;
    rdfs:comment 'Reference identifier linking this MARPOL operation to a corresponding record in the Environmental Monitoring System (EMS) for air quality, water quality, or emissions tracking data.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Facility Capacity M3' ;
    rdfs:comment 'Declared storage or processing capacity of the port reception facility in cubic metres at the time of this operation. Used for capacity planning and adequacy assessments per MARPOL requirements.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Inspection Status' ;
    rdfs:comment 'Current inspection and certification status of the port reception facility at the time of the operation. Facilities must maintain valid inspection status to legally receive MARPOL-regulated waste.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Facility Licence Number' ;
    rdfs:comment 'Official licence or permit number issued by the port authority or environmental regulator authorising the reception facility to receive and process specific categories of ship-generated waste.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgEmissionMtCo2e rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Mt Co2e' ;
    rdfs:comment 'Total greenhouse gas (GHG) emissions in metric tonnes of CO₂ equivalent recorded or calculated for this MARPOL Annex VI operation. Supports IMO GHG Strategy reporting and CII (Carbon Intensity Indicator) calculations.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marpolAnnexCode rdf:type rdf:Property ;
    rdfs:label 'Marpol Annex Code' ;
    rdfs:comment 'Identifies the specific MARPOL Annex governing this operation: ANNEX_I (Oil), ANNEX_II (Noxious Liquid Substances), ANNEX_IV (Sewage), ANNEX_V (Garbage), ANNEX_VI (Air Emissions — SOx, NOx, GHG). Drives applicable regulatory requirements and reporting obligations.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceDescription rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Description' ;
    rdfs:comment 'Free-text description of the nature of the MARPOL non-compliance identified during this operation, including the specific regulation breached and observed conditions. Populated only when non_compliance_flag = True.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Flag' ;
    rdfs:comment 'Indicates whether this MARPOL operation was found to be non-compliant with applicable MARPOL Annex requirements. True = non-compliance identified; False = compliant. Triggers escalation to port authority and flag state.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noxEmissionGKwh rdf:type rdf:Property ;
    rdfs:label 'Nox Emission G Kwh' ;
    rdfs:comment 'Measured nitrogen oxide (NOx) emission rate in grams per kilowatt-hour recorded during air emission monitoring under MARPOL Annex VI. Used to verify compliance with Tier I/II/III NOx limits.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oilRecordBookEntryCode rdf:type rdf:Property ;
    rdfs:label 'Oil Record Book Entry Code' ;
    rdfs:comment 'Standardised IMO operation code from the Oil Record Book (Part I — Machinery Space Operations; Part II — Cargo/Ballast Operations) that classifies the specific oil-related activity recorded under MARPOL Annex I. Applicable only when marpol_annex_code = ANNEX_I.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation End Timestamp' ;
    rdfs:comment 'Date and time at which the MARPOL compliance operation was completed or concluded. Used to calculate operation duration and for regulatory log completeness.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number assigned to this MARPOL compliance operation, used in waste manifests, port authority sign-off documents, and regulatory submissions. Format: MARPOL-{PORT_CODE}-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the MARPOL compliance operation, tracking progression from initiation through completion or cancellation. Used for operational dashboards and regulatory reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piClubNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Pi Club Notified Flag' ;
    rdfs:comment 'Indicates whether the vessel\'s Protection and Indemnity (P&I) club has been notified of this MARPOL operation, particularly relevant for incidents, non-compliance events, or significant waste deliveries.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portAuthoritySignoffBy rdf:type rdf:Property ;
    rdfs:label 'Port Authority Signoff By' ;
    rdfs:comment 'Name or identifier of the port authority officer who officially signed off and verified this MARPOL compliance operation. Required for regulatory audit trail and PSC inspection records.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portAuthoritySignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Port Authority Signoff Timestamp' ;
    rdfs:comment 'Date and time at which the port authority officer officially signed off on this MARPOL compliance operation, confirming regulatory requirements were met.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pscDeficiencyNoted rdf:type rdf:Property ;
    rdfs:label 'Psc Deficiency Noted' ;
    rdfs:comment 'Indicates whether a PSC inspector noted a deficiency or non-conformance during inspection of this MARPOL operation. True = deficiency recorded; False = no deficiency. Applicable when psc_inspection_flag = True.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxEmissionPpm rdf:type rdf:Property ;
    rdfs:label 'Sox Emission Ppm' ;
    rdfs:comment 'Measured concentration of sulphur oxide (SOx) emissions in parts per million (ppm) recorded during air emission monitoring operations under MARPOL Annex VI. Applicable when marpol_annex_code = ANNEX_VI.' ;
    rdfs:domain ind:MarpolOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteCategory rdf:type rdf:Property ;
    rdfs:label 'Waste Category' ;
    rdfs:comment 'Specific category of waste or pollutant managed in this operation, aligned with MARPOL waste classification (e.g., oily bilge water, sludge, garbage — food waste, garbage — plastics, sewage, noxious liquid substances, SOx emissions, NOx emissions, GHG). [ENUM-REF-CANDIDATE: oily_bilge_water|oily_sludge|noxious_liquid|sewage|food_waste|plastics|operational_waste|cargo_residues|sox_emissions|nox_emissions|ghg_emissions|ballast_water — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mooringOperationId rdf:type rdf:Property ;
    rdfs:label 'Mooring Operation Id' ;
    rdfs:comment 'Unique surrogate identifier for each mooring or unmooring service event recorded in the port. Primary key for the mooring_operation data product.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billable rdf:type rdf:Property ;
    rdfs:label 'Billable' ;
    rdfs:comment 'Indicates whether this mooring operation is subject to a tariff charge to the vessel operator or shipping agent. Non-billable operations may include emergency services or internal port movements.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bollardsUsedCount rdf:type rdf:Property ;
    rdfs:label 'Bollards Used Count' ;
    rdfs:comment 'Number of shore-side bollards engaged during the mooring operation. Used for infrastructure utilisation tracking, SWL compliance, and berth equipment maintenance scheduling in Maximo.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breastLinesCount rdf:type rdf:Property ;
    rdfs:label 'Breast Lines Count' ;
    rdfs:comment 'Number of breast lines (mooring lines running perpendicular to the vessel\'s centreline) deployed during the mooring operation. Critical for lateral restraint and SWL compliance verification.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capstansUsed rdf:type rdf:Property ;
    rdfs:label 'Capstans Used' ;
    rdfs:comment 'Indicates whether shore-side capstans (powered mooring winches) were utilised during this mooring operation to assist in line tensioning and vessel positioning.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commencementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Commencement Timestamp' ;
    rdfs:comment 'Date and time when the mooring operation physically commenced, i.e., when the first line was passed or the unmooring sequence began. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Current Speed Knots' ;
    rdfs:comment 'Recorded water current speed in knots at the berth location during the mooring operation. Relevant for mooring load assessment and safety compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gangSize rdf:type rdf:Property ;
    rdfs:label 'Gang Size' ;
    rdfs:comment 'Number of mooring personnel deployed for this operation. Used for resource planning, billing calculation, and compliance with minimum manning requirements.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gangSupervisor rdf:type rdf:Property ;
    rdfs:label 'Gang Supervisor' ;
    rdfs:comment 'Name or employee identifier of the supervisor leading the mooring gang for this operation. Used for accountability, incident investigation, and performance management.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headLinesCount rdf:type rdf:Property ;
    rdfs:label 'Head Lines Count' ;
    rdfs:comment 'Number of head lines (forward mooring lines running ahead of the vessel) deployed during the mooring operation. Part of the line configuration record for SWL compliance and operational audit.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentRef rdf:type rdf:Property ;
    rdfs:label 'Incident Ref' ;
    rdfs:comment 'Reference number of the formal marine incident report raised in connection with this mooring operation. Populated when incident_reported is true. Links to the marine incident management record.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irregularityDescription rdf:type rdf:Property ;
    rdfs:label 'Irregularity Description' ;
    rdfs:comment 'Free-text description of any mooring irregularity, safety observation, equipment deficiency, or non-conformance observed during the operation. Populated when irregularity_observed is true. Used for incident investigation and safety reporting.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irregularityObserved rdf:type rdf:Property ;
    rdfs:label 'Irregularity Observed' ;
    rdfs:comment 'Indicates whether any mooring irregularity, safety observation, or non-conformance was recorded during this operation. When true, details are captured in the irregularity_description field.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineMaterialType rdf:type rdf:Property ;
    rdfs:label 'Line Material Type' ;
    rdfs:comment 'Material composition of the mooring lines used in this operation. Relevant for SWL compliance verification and equipment condition assessment. HMPE = High Modulus Polyethylene (e.g., Dyneema).' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mooringLocationType rdf:type rdf:Property ;
    rdfs:label 'Mooring Location Type' ;
    rdfs:comment 'Classification of the physical mooring location type where the vessel is secured: conventional berth alongside a quay, single-point or multi-buoy mooring, dolphin structure, jetty, or open quay face.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationRef rdf:type rdf:Property ;
    rdfs:label 'Operation Ref' ;
    rdfs:comment 'Externally-known business reference number assigned to this mooring or unmooring service event, used in billing, port management information system (PMIS) records, and inter-agency communications.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotOnBoard rdf:type rdf:Property ;
    rdfs:label 'Pilot On Board' ;
    rdfs:comment 'Indicates whether a marine pilot was on board the vessel during this mooring operation. Relevant for coordination between pilotage and mooring services and for incident liability determination.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quickReleaseHooksUsed rdf:type rdf:Property ;
    rdfs:label 'Quick Release Hooks Used' ;
    rdfs:comment 'Indicates whether quick-release mooring hooks were deployed during this operation. Quick-release hooks are critical safety equipment for emergency vessel release and are tracked for compliance and maintenance purposes.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:springLinesCount rdf:type rdf:Property ;
    rdfs:label 'Spring Lines Count' ;
    rdfs:comment 'Number of spring lines (mooring lines running at an angle fore and aft to prevent surging) deployed during the mooring operation. Part of the full line configuration record.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sternLinesCount rdf:type rdf:Property ;
    rdfs:label 'Stern Lines Count' ;
    rdfs:comment 'Number of stern lines (aft mooring lines running astern of the vessel) deployed during the mooring operation. Part of the line configuration record for SWL compliance and operational audit.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:swlCompliant rdf:type rdf:Property ;
    rdfs:label 'Swl Compliant' ;
    rdfs:comment 'Indicates whether all mooring lines and equipment used in this operation were verified to be within their Safe Working Load (SWL) limits at the time of the operation. Mandatory compliance check per OCIMF and port safety regulations.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tideHeightM rdf:type rdf:Property ;
    rdfs:label 'Tide Height M' ;
    rdfs:comment 'Recorded tide height in metres above chart datum at the time of the mooring operation commencement. Critical for under-keel clearance assessment and mooring line angle calculations.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLinesCount rdf:type rdf:Property ;
    rdfs:label 'Total Lines Count' ;
    rdfs:comment 'Total number of mooring lines deployed across all configurations (head, stern, breast, spring) for this operation. Used for equipment inventory reconciliation and billing.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:towageAssistUsed rdf:type rdf:Property ;
    rdfs:label 'Towage Assist Used' ;
    rdfs:comment 'Indicates whether tug assistance was used in conjunction with this mooring operation to manoeuvre the vessel to or from the berth. Used for service coordination and billing linkage to towage operations.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vesselMovementType rdf:type rdf:Property ;
    rdfs:label 'Vessel Movement Type' ;
    rdfs:comment 'Indicates the vessel movement context for which the mooring service is being performed: arrival at berth, departure from berth, or an intra-port shift between berths or positions.' ;
    rdfs:domain ind:MooringOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityCategory rdf:type rdf:Property ;
    rdfs:label 'Visibility Category' ;
    rdfs:comment 'Categorical assessment of meteorological visibility conditions at the time of the mooring operation: good (>5nm), moderate (2-5nm), poor (0.5-2nm), very poor (<0.5nm). Used for safety risk assessment.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windDirection rdf:type rdf:Property ;
    rdfs:label 'Wind Direction' ;
    rdfs:comment 'Compass direction from which the wind was blowing at the berth location during the mooring operation, expressed as a 16-point compass bearing. Used for safety assessment and incident investigation.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labourAgreementId rdf:type rdf:Property ;
    rdfs:label 'Labour Agreement Id' ;
    rdfs:comment 'Foreign key linking to workforce.labour_agreement. Business justification: Pilots are covered by specific labour agreements governing pay, conditions, and entitlements - real industrial relations requirement enabling payroll calculation and entitlement management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabourAgreement .

ind:nationalityCountryId rdf:type rdf:Property ;
    rdfs:label 'Nationality Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Pilot licensing authority verification, STCW certification validation, and port access credential issuance require country master data (IMO member status, STCW ratification) for regulatory compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Pilots hold specific positions in port authority organizational structure - real organizational relationship enabling workforce planning, succession management, and HR administration for pilotage staf' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:competencyClass rdf:type rdf:Property ;
    rdfs:label 'Competency Class' ;
    rdfs:comment 'IMO-recognised competency class of the pilot licence, defining the category of vessels and waterways the pilot is authorised to handle (e.g., Class 1, Class 2, Class 3). Determines assignment eligibility in VTMS scheduling. [ENUM-REF-CANDIDATE: Class 1|Class 2|Class 3|Class 4|Class 5 — promote to reference product]' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the pilot. Used for age verification, mandatory retirement age compliance, and medical fitness scheduling under national maritime authority regulations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deepSeaPilotEndorsement rdf:type rdf:Property ;
    rdfs:label 'Deep Sea Pilot Endorsement' ;
    rdfs:comment 'Indicates whether the pilot holds a deep sea pilotage endorsement, authorising operations beyond the standard port approach limits. Relevant for ports with extended pilotage districts.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyStatus rdf:type rdf:Property ;
    rdfs:label 'Duty Status' ;
    rdfs:comment 'Current operational duty status of the pilot indicating availability for pilotage assignments. Drives real-time scheduling logic in the Vessel Traffic Management System (VTMS). Values: on_duty (actively available), off_duty (not available), standby (on-call), leave (approved absence), suspended (regulatory action), retired (no longer active).' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact person to the pilot (e.g., spouse, parent, sibling). Provides context for emergency communications.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the pilot\'s employment arrangement with the port authority. Determines applicable HR policies, entitlements, and billing arrangements. Values: permanent, contract, casual, seconded.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:englishProficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'English Proficiency Level' ;
    rdfs:comment 'Assessed level of English language proficiency for maritime communications, as English is the IMO-mandated working language for international pilotage. Values: basic, operational, proficient, expert.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homePortCode rdf:type rdf:Property ;
    rdfs:label 'Home Port Code' ;
    rdfs:comment 'UN/LOCODE of the pilot\'s designated home port or primary operating port. Used for scheduling, deployment planning, and inter-port transfer management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCountYtd rdf:type rdf:Property ;
    rdfs:label 'Incident Count Ytd' ;
    rdfs:comment 'Number of marine incidents or near-misses recorded against this pilot in the current calendar year. Used for safety performance monitoring, P&I club notifications, and SOLAS/MARPOL compliance reporting. Not a calculated KPI — sourced directly from the incident management system.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ispsClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Isps Clearance Level' ;
    rdfs:comment 'ISPS security clearance level granted to the pilot, determining access permissions to restricted port areas and vessels. Aligned with the ISPS Code security framework. Values: level_1 (normal), level_2 (heightened), level_3 (exceptional).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageProficiencies rdf:type rdf:Property ;
    rdfs:label 'Language Proficiencies' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes representing languages in which the pilot is proficient for maritime communications. IMO requires English as the working language; additional languages support multi-national vessel operations. Example: \'EN,ZH,AR\'.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastIncidentDate rdf:type rdf:Property ;
    rdfs:label 'Last Incident Date' ;
    rdfs:comment 'Date of the most recent marine incident or near-miss recorded against this pilot. Used for safety trend analysis and to trigger mandatory review processes under SOLAS and port safety procedures.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenceIssueDate rdf:type rdf:Property ;
    rdfs:label 'Licence Issue Date' ;
    rdfs:comment 'Date on which the current pilot licence was issued by the national maritime authority. Used for licence tenure tracking and regulatory audit trails.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenceNumber rdf:type rdf:Property ;
    rdfs:label 'Licence Number' ;
    rdfs:comment 'Officially issued pilot licence number assigned by the national maritime authority. Serves as the primary external business identifier for the pilot across regulatory and operational systems including VTMS and PCS.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceStatus rdf:type rdf:Property ;
    rdfs:label 'Licence Status' ;
    rdfs:comment 'Current regulatory status of the pilot\'s licence as maintained by the national maritime authority. Determines whether the pilot is legally authorised to conduct pilotage operations. Values: active, expired, suspended, revoked, pending_renewal.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDwtMt rdf:type rdf:Property ;
    rdfs:label 'Max Dwt Mt' ;
    rdfs:comment 'Maximum vessel Deadweight Tonnage (DWT) in metric tonnes that this pilot is authorised to handle. Used alongside LOA and GRT limits to determine vessel assignment eligibility in VTMS scheduling.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxGrt rdf:type rdf:Property ;
    rdfs:label 'Max Grt' ;
    rdfs:comment 'Maximum vessel Gross Registered Tonnage (GRT) that this pilot is authorised to handle. Complements LOA and DWT limits for comprehensive vessel size authorisation management.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLoaM rdf:type rdf:Property ;
    rdfs:label 'Max Loa M' ;
    rdfs:comment 'Maximum vessel Length Overall (LOA) in metres that this pilot is authorised to handle, as specified on the pilot licence. Used by VTMS to validate pilot-vessel assignment eligibility.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Cert Expiry Date' ;
    rdfs:comment 'Date on which the pilot\'s current medical fitness certificate expires. Triggers renewal workflow and prevents scheduling of pilots with expired medical certificates.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalCertNumber rdf:type rdf:Property ;
    rdfs:label 'Medical Cert Number' ;
    rdfs:comment 'Reference number of the pilot\'s current medical fitness certificate issued by an approved medical examiner. Used for regulatory verification and audit purposes.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Cert Status' ;
    rdfs:comment 'Current status of the pilot\'s medical fitness certificate as required under maritime health standards. A valid certificate is a prerequisite for active pilotage duty. Values: valid, expired, suspended, pending_review.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nightPilotageAuthorised rdf:type rdf:Property ;
    rdfs:label 'Night Pilotage Authorised' ;
    rdfs:comment 'Indicates whether the pilot is authorised to conduct pilotage operations during night-time hours. Some pilots may have restrictions based on experience level or port-specific regulations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pilotageCommencementDate rdf:type rdf:Property ;
    rdfs:label 'Pilotage Commencement Date' ;
    rdfs:comment 'Date on which the pilot first commenced licensed pilotage operations at this port. Used to calculate seniority, experience tenure, and for workforce planning analytics.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pniClubNotified rdf:type rdf:Property ;
    rdfs:label 'Pni Club Notified' ;
    rdfs:comment 'Indicates whether the port\'s Protection and Indemnity (P&I) club has been notified of any incident involving this pilot. Required for liability management and insurance claim processing.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portAuthorityEmployeeNumber rdf:type rdf:Property ;
    rdfs:label 'Port Authority Employee Number' ;
    rdfs:comment 'Internal employee or contractor reference number assigned by the port authority\'s HR system (Oracle HCM Cloud). Links the pilot master record to the workforce management system for payroll, scheduling, and HR administration.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:radarArpaEndorsement rdf:type rdf:Property ;
    rdfs:label 'Radar Arpa Endorsement' ;
    rdfs:comment 'Indicates whether the pilot holds a valid Radar/ARPA endorsement, confirming competency in radar navigation and collision avoidance systems. Required for pilotage in restricted visibility conditions.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refresherTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Refresher Training Due Date' ;
    rdfs:comment 'Date by which the pilot must complete the next mandatory refresher or recurrent training programme. Triggers training scheduling workflows and compliance alerts.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:simulatorTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Simulator Training Date' ;
    rdfs:comment 'Date on which the pilot last completed mandatory bridge simulator training. Used to track recurrent training compliance and schedule upcoming simulator sessions per IMO and national authority requirements.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stcwCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Stcw Cert Expiry Date' ;
    rdfs:comment 'Expiry date of the pilot\'s STCW certificate. Drives compliance monitoring and renewal scheduling to ensure continuous regulatory validity.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stcwCertNumber rdf:type rdf:Property ;
    rdfs:label 'Stcw Cert Number' ;
    rdfs:comment 'Certificate number issued under the STCW Convention confirming the pilot meets international standards for training, certification, and watchkeeping. Required for IMO compliance and PSC inspections.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vhfRadioOperatorCert rdf:type rdf:Property ;
    rdfs:label 'Vhf Radio Operator Cert' ;
    rdfs:comment 'Indicates whether the pilot holds a valid VHF (Very High Frequency) radio operator certificate, required for maritime communications during pilotage operations. True = certificate held and valid.' ;
    rdfs:domain ind:Pilot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total number of years of active pilotage experience accumulated by the pilot. Used for competency assessment, assignment prioritisation for complex manoeuvres, and workforce analytics.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pilotDutyRosterId rdf:type rdf:Property ;
    rdfs:label 'Pilot Duty Roster Id' ;
    rdfs:comment 'Unique identifier for the pilot duty roster record. Primary key for the pilot duty roster entity.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPilotId rdf:type rdf:Property ;
    rdfs:label 'Primary Pilot Id' ;
    rdfs:comment 'Reference to the pilot assigned to this duty roster. Links to the pilot master record.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pilot .

ind:tertiaryReliefPilotId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Relief Pilot Id' ;
    rdfs:comment 'Reference to the relief pilot assigned to cover this duty roster in case of absence, emergency, or workload overflow.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pilot .

ind:actualAssignmentsCompleted rdf:type rdf:Property ;
    rdfs:label 'Actual Assignments Completed' ;
    rdfs:comment 'Number of pilotage assignments actually completed by the pilot during this roster period. Tracked for workload monitoring and billing.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedBoardingStation rdf:type rdf:Property ;
    rdfs:label 'Assigned Boarding Station' ;
    rdfs:comment 'Name or code of the pilot boarding station where the pilot is assigned to operate during this roster period. Critical for geographic coverage planning.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Real-time availability status of the pilot during the roster period. Updated dynamically as assignments are made or pilot status changes.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingStationLocation rdf:type rdf:Property ;
    rdfs:label 'Boarding Station Location' ;
    rdfs:comment 'Geographic location description or coordinates of the assigned boarding station for operational reference and dispatch planning.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Primary phone number for reaching the pilot during this duty roster period for assignment dispatch and operational coordination.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeDutyHoursMonth rdf:type rdf:Property ;
    rdfs:label 'Cumulative Duty Hours Month' ;
    rdfs:comment 'Total accumulated duty hours for the pilot in the current calendar month. Tracked for fatigue management and regulatory compliance.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeDutyHoursWeek rdf:type rdf:Property ;
    rdfs:label 'Cumulative Duty Hours Week' ;
    rdfs:comment 'Total accumulated duty hours for the pilot in the current rolling 7-day period. Monitored for compliance with maximum work hour regulations.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Duty Priority Level' ;
    rdfs:comment 'Priority ranking of the pilot within the duty roster for assignment dispatch. Determines call-out sequence for pilotage requests.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Fatigue Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the pilot is in compliance with mandatory rest hour requirements and fatigue management regulations for this roster period.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatigueRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Score' ;
    rdfs:comment 'Calculated fatigue risk assessment score based on cumulative duty hours, rest periods, and shift patterns. Used for proactive safety management.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursOfRestPrior rdf:type rdf:Property ;
    rdfs:label 'Hours Of Rest Prior' ;
    rdfs:comment 'Number of hours of rest the pilot has completed prior to commencing this duty roster period. Critical for fatigue management compliance.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxAssignmentsAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Assignments Allowed' ;
    rdfs:comment 'Maximum number of pilotage assignments the pilot is permitted to undertake during this roster period, based on fatigue management and safety regulations.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reliefReason rdf:type rdf:Property ;
    rdfs:label 'Relief Reason' ;
    rdfs:comment 'Explanation or justification for assigning a relief pilot to this duty roster, such as illness, emergency, or fatigue management.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliefTimestamp rdf:type rdf:Property ;
    rdfs:label 'Relief Timestamp' ;
    rdfs:comment 'Date and time when the relief pilot assumed duty for this roster assignment.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rosterNotes rdf:type rdf:Property ;
    rdfs:label 'Roster Notes' ;
    rdfs:comment 'Free-text operational notes, special instructions, or remarks related to this duty roster assignment for coordination and reference purposes.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterPeriodEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Roster Period End Timestamp' ;
    rdfs:comment 'Date and time when the pilot duty roster period concludes. Marks the end of the pilot\'s scheduled availability window.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rosterPeriodStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Roster Period Start Timestamp' ;
    rdfs:comment 'Date and time when the pilot duty roster period commences. Marks the beginning of the pilot\'s scheduled availability window.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rosterPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Roster Publication Date' ;
    rdfs:comment 'Date when the duty roster was officially published and communicated to the pilot and operational teams. Establishes the baseline schedule.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rosterPublishedBy rdf:type rdf:Property ;
    rdfs:label 'Roster Published By' ;
    rdfs:comment 'Name or identifier of the duty scheduler or operations manager who published this roster assignment.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Roster Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this duty roster assignment, used for operational communication and scheduling coordination.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterStatus rdf:type rdf:Property ;
    rdfs:label 'Roster Status' ;
    rdfs:comment 'Current lifecycle status of the duty roster assignment. Tracks progression from draft through publication to completion or cancellation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialQualifications rdf:type rdf:Property ;
    rdfs:label 'Special Qualifications' ;
    rdfs:comment 'Additional certifications, endorsements, or special qualifications held by the pilot that are relevant to this duty roster assignment, such as LNG carrier endorsement or deep-sea pilot authorization.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyLocation rdf:type rdf:Property ;
    rdfs:label 'Standby Location' ;
    rdfs:comment 'Physical location where the pilot is required to remain on standby during this roster period, such as pilot station, office, or designated facility.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swapApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Swap Approval Timestamp' ;
    rdfs:comment 'Date and time when the duty swap request was approved by the authorized scheduler or manager.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:swapApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Swap Approved Flag' ;
    rdfs:comment 'Boolean indicator of whether a requested duty swap has been approved by the duty scheduler or operations manager.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swapRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Swap Request Flag' ;
    rdfs:comment 'Boolean indicator of whether a duty swap or exchange request has been submitted for this roster assignment.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vhfRadioChannel rdf:type rdf:Property ;
    rdfs:label 'Vhf Radio Channel' ;
    rdfs:comment 'VHF radio channel assigned to the pilot for communication during this duty roster period. Critical for vessel traffic coordination.' ;
    rdfs:domain ind:PilotDutyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingAnchorageAreaId rdf:type rdf:Property ;
    rdfs:label 'Boarding Anchorage Area Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.anchorage_area. Business justification: Pilots board vessels at designated anchorages; boarding_station_name currently denormalized. Essential for pilot dispatch coordination, launch boat routing, and service billing accuracy.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnchorageArea .

ind:callId rdf:type rdf:Property ;
    rdfs:label 'Call Id' ;
    rdfs:comment 'FK to vessel.call.call_id — Pilotage assignments are scheduled per vessel call. This FK enables pilot resource planning and marine service billing reconciliation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Call .

ind:pilotageRouteId rdf:type rdf:Property ;
    rdfs:label 'Pilotage Route Id' ;
    rdfs:comment 'Reference to the approved pilotage route assigned for this service, defining waypoints, distance, Under-Keel Clearance (UKC) requirements, speed restrictions, and tidal windows.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PilotageRoute .

ind:recordedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Recorded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pilotage assignments require audit trail of which port operations employee recorded/verified the pilot boarding for compliance and liability purposes - standard maritime operational logging requiremen' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualBoardingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Boarding Timestamp' ;
    rdfs:comment 'Actual date and time at which the pilot boarded the vessel. Used for service performance measurement, billing, and SOLAS compliance logging.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingMethod rdf:type rdf:Property ;
    rdfs:label 'Boarding Method' ;
    rdfs:comment 'Method used for pilot transfer to the vessel. Determines safety compliance requirements under SOLAS and informs launch boat dispatch scheduling.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFromPassagePlan rdf:type rdf:Property ;
    rdfs:label 'Deviation From Passage Plan' ;
    rdfs:comment 'Indicates whether the pilot deviated from the approved passage plan during the pilotage. Triggers mandatory deviation narrative entry and may require post-incident review under SOLAS Chapter V.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationReason rdf:type rdf:Property ;
    rdfs:label 'Deviation Reason' ;
    rdfs:comment 'Narrative description of the reason for any deviation from the approved passage plan. Mandatory when deviation_from_passage_plan is True. Supports SOLAS Chapter V compliance and post-incident analysis.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Isps Compliance Verified' ;
    rdfs:comment 'Indicates whether ISPS Code security compliance was verified for the vessel prior to commencement of pilotage. Mandatory check under ISPS Code Part A for port facility security.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minUkcRecordedM rdf:type rdf:Property ;
    rdfs:label 'Min Ukc Recorded M' ;
    rdfs:comment 'Minimum Under-Keel Clearance (UKC) recorded during the pilotage passage in metres. Critical safety metric for SOLAS compliance and post-passage audit. Must meet or exceed route UKC requirements.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passageDistanceNm rdf:type rdf:Property ;
    rdfs:label 'Passage Distance Nm' ;
    rdfs:comment 'Total distance of the pilotage passage in nautical miles as recorded upon completion. Used for billing, performance benchmarking, and route validation.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passageNarrative rdf:type rdf:Property ;
    rdfs:label 'Passage Narrative' ;
    rdfs:comment 'Structured narrative of the pilotage passage including key helm orders, manoeuvres, waypoints transited, and significant events. Forms part of the official pilotage completion log for SOLAS compliance and post-incident analysis.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotLicenceClass rdf:type rdf:Property ;
    rdfs:label 'Pilot Licence Class' ;
    rdfs:comment 'Classification of the pilot\'s licence indicating the scope of authorisation (e.g., vessel size limits, route restrictions). Ensures the assigned pilot holds the appropriate licence class for the vessel and route.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotOffVesselTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pilot Off Vessel Timestamp' ;
    rdfs:comment 'Timestamp when the pilot disembarked the vessel, marking the official end of the pilotage service. Used for billing duration calculation and service completion logging.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pilotOnBoardTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pilot On Board Timestamp' ;
    rdfs:comment 'Timestamp when the pilot assumed navigational advisory responsibility on the bridge, marking the official commencement of the pilotage service. Distinct from boarding time if transfer involved a pilot ladder or boat.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledBoardingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Boarding Timestamp' ;
    rdfs:comment 'Planned date and time at which the pilot is scheduled to board the vessel at the boarding station. Used for pilot dispatch planning and Vessel Traffic Service (VTS) coordination.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDisembarkationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Disembarkation Timestamp' ;
    rdfs:comment 'Planned date and time at which the pilot is scheduled to disembark the vessel at the disembarkation point. Used for pilot rotation planning and launch boat scheduling.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:speedOverGroundAvgKnots rdf:type rdf:Property ;
    rdfs:label 'Speed Over Ground Avg Knots' ;
    rdfs:comment 'Average speed over ground in knots recorded during the pilotage passage. Used for passage time analysis, route compliance, and post-incident review.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tidalWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Tidal Window End' ;
    rdfs:comment 'End of the approved tidal window within which the pilotage must be completed to ensure adequate Under-Keel Clearance (UKC) along the assigned route.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tidalWindowStart rdf:type rdf:Property ;
    rdfs:label 'Tidal Window Start' ;
    rdfs:comment 'Start of the approved tidal window within which the pilotage must commence to ensure adequate Under-Keel Clearance (UKC) along the assigned route.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tugCount rdf:type rdf:Property ;
    rdfs:label 'Tug Count' ;
    rdfs:comment 'Number of tugs deployed to assist the vessel during the pilotage. Determined by pilot based on vessel size, weather conditions, and berth configuration. Used for towage billing and resource planning.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tugRequired rdf:type rdf:Property ;
    rdfs:label 'Tug Required' ;
    rdfs:comment 'Indicates whether tug assistance was required for this pilotage assignment based on vessel characteristics, weather conditions, or port authority requirements.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vhfChannelPrimary rdf:type rdf:Property ;
    rdfs:label 'Vhf Channel Primary' ;
    rdfs:comment 'Primary VHF radio channel used for communication between the pilot and Vessel Traffic Service (VTS) during the pilotage passage. Recorded for communications audit and incident investigation.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vtsReportingPointCount rdf:type rdf:Property ;
    rdfs:label 'Vts Reporting Point Count' ;
    rdfs:comment 'Number of mandatory Vessel Traffic Service (VTS) reporting points transited during the pilotage passage. Used for VTS compliance verification and passage plan adherence assessment.' ;
    rdfs:domain ind:PilotageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windDirectionDegrees rdf:type rdf:Property ;
    rdfs:label 'Wind Direction Degrees' ;
    rdfs:comment 'Observed wind direction in degrees true (0-360) at the time of pilotage commencement. Used alongside wind speed for manoeuvring assessment and tug deployment decisions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotageExemptionId rdf:type rdf:Property ;
    rdfs:label 'Pilotage Exemption Id' ;
    rdfs:comment 'Unique identifier for the Pilotage Exemption Certificate record. Primary key.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedBerths rdf:type rdf:Property ;
    rdfs:label 'Authorized Berths' ;
    rdfs:comment 'Comma-separated list of specific berth numbers or terminal areas the master is authorized to approach and berth at under this exemption.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedFairwaySections rdf:type rdf:Property ;
    rdfs:label 'Authorized Fairway Sections' ;
    rdfs:comment 'Comma-separated list or description of specific fairway sections, channels, or routes within the port that the master is authorized to navigate without a compulsory pilot.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedVesselTypes rdf:type rdf:Property ;
    rdfs:label 'Authorized Vessel Types' ;
    rdfs:comment 'Comma-separated list or description of vessel types the master is authorized to navigate under this exemption (e.g., container vessels, bulk carriers, tankers, RoRo vessels).' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsAndRestrictions rdf:type rdf:Property ;
    rdfs:label 'Conditions And Restrictions' ;
    rdfs:comment 'Any special conditions, limitations, or restrictions attached to this pilotage exemption certificate (e.g., daylight only, specific weather conditions, tug assistance required).' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationDate rdf:type rdf:Property ;
    rdfs:label 'Examination Date' ;
    rdfs:comment 'The date on which the master completed the pilotage exemption examination or assessment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationResult rdf:type rdf:Property ;
    rdfs:label 'Examination Result' ;
    rdfs:comment 'The outcome of the pilotage exemption examination: pass (met all requirements), fail (did not meet requirements), conditional_pass (passed with conditions), or exempt (waived based on experience).' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationScore rdf:type rdf:Property ;
    rdfs:label 'Examination Score' ;
    rdfs:comment 'The numerical score or percentage achieved by the master in the pilotage exemption examination.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinerName rdf:type rdf:Property ;
    rdfs:label 'Examiner Name' ;
    rdfs:comment 'Name of the authorized examiner or pilot who conducted the pilotage exemption assessment.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionType rdf:type rdf:Property ;
    rdfs:label 'Exemption Type' ;
    rdfs:comment 'Classification of the pilotage exemption: full (all fairways), partial (specific routes only), conditional (subject to conditions), or temporary (limited duration trial).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'The certificate number of the Protection and Indemnity (P&I) insurance or professional indemnity insurance covering the master for pilotage exemption operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPassageDate rdf:type rdf:Property ;
    rdfs:label 'Last Passage Date' ;
    rdfs:comment 'The date of the most recent passage made by the master using this pilotage exemption certificate.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'The most recent date on which this pilotage exemption certificate was renewed or revalidated.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:masterLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Master License Number' ;
    rdfs:comment 'The official license or certificate of competency number held by the vessel master, issued by the national maritime authority.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterName rdf:type rdf:Property ;
    rdfs:label 'Master Name' ;
    rdfs:comment 'Full legal name of the vessel master authorized under this pilotage exemption certificate.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxGrtTonnes rdf:type rdf:Property ;
    rdfs:label 'Max Grt Tonnes' ;
    rdfs:comment 'The maximum vessel Gross Registered Tonnage (GRT) in tonnes that the master is authorized to navigate under this pilotage exemption.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLoaMeters rdf:type rdf:Property ;
    rdfs:label 'Max Loa Meters' ;
    rdfs:comment 'The maximum vessel Length Overall (LOA) in meters that the master is authorized to navigate under this pilotage exemption.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Expiry Date' ;
    rdfs:comment 'The expiry date of the master\'s medical fitness certificate, which may be a prerequisite for maintaining pilotage exemption validity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'The date by which the certificate holder must apply for renewal to maintain continuous validity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pilotageExemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Pilotage Exemption Status' ;
    rdfs:comment 'Current lifecycle status of the pilotage exemption certificate: active (valid and in use), expired (past expiry date), suspended (temporarily invalid), revoked (permanently cancelled), pending (awaiting approval), or under_review (renewal or modification in progress).' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingPassagesCompleted rdf:type rdf:Property ;
    rdfs:label 'Qualifying Passages Completed' ;
    rdfs:comment 'The actual number of supervised qualifying passages the master completed before being issued this exemption certificate.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingPassagesRequired rdf:type rdf:Property ;
    rdfs:label 'Qualifying Passages Required' ;
    rdfs:comment 'The number of supervised passages through the authorized fairways that the master was required to complete before being granted the exemption certificate.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequirements rdf:type rdf:Property ;
    rdfs:label 'Renewal Requirements' ;
    rdfs:comment 'Description of the requirements the master must fulfill for certificate renewal, such as minimum number of passages, re-examination, medical fitness, or continuing education.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPassagesUnderExemption rdf:type rdf:Property ;
    rdfs:label 'Total Passages Under Exemption' ;
    rdfs:comment 'The cumulative number of passages the master has completed using this pilotage exemption certificate since it was issued.' ;
    rdfs:domain ind:PilotageExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pniClubNotificationId rdf:type rdf:Property ;
    rdfs:label 'Pni Club Notification Id' ;
    rdfs:comment 'Primary key for pni_club_notification' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notifyingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Notifying Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: P&I club notifications are filed by specific port staff - real compliance and legal workflow requiring employee accountability for insurance claim initiation and liability management.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:towageOrderId rdf:type rdf:Property ;
    rdfs:label 'Towage Order Id' ;
    rdfs:comment 'Reference to the towage operation record active at the time of the incident, where the incident occurred during a towage operation. Relevant for determining tug operator liability and contractual terms under BIMCO Towcon/Towhire agreements.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TowageOrder .

ind:acknowledgementDatetime rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Datetime' ;
    rdfs:comment 'Timestamp at which the P&I club formally acknowledged receipt of this notification. Used to measure notification response time and to confirm the club\'s acceptance of the notification within required timeframes.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the nature of the claim or liability event triggering this P&I notification. Determines the applicable P&I club rules, coverage provisions, and claims handling pathway. [ENUM-REF-CANDIDATE: cargo_damage|personal_injury|pollution|collision|property_damage|wreck_removal|third_party_liability — promote to reference product]' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Reason for the closure of the P&I notification. Indicates the outcome of the claims process, including settlement, determination of no liability, withdrawal by the claimant, time-bar under applicable limitation convention, or subrogation to another insurer.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clubCorrespondentContact rdf:type rdf:Property ;
    rdfs:label 'Club Correspondent Contact' ;
    rdfs:comment 'Contact details (phone, email, or address) for the P&I club correspondent assigned to this notification. Used for direct communication during claims handling and survey coordination.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clubCorrespondentName rdf:type rdf:Property ;
    rdfs:label 'Club Correspondent Name' ;
    rdfs:comment 'Name of the local P&I club correspondent or appointed representative at the port who is handling this notification on behalf of the P&I club. Correspondents act as the club\'s local agents for surveys, evidence gathering, and initial claims management.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clubHandlerName rdf:type rdf:Property ;
    rdfs:label 'Club Handler Name' ;
    rdfs:comment 'Name of the claims handler or case manager assigned by the P&I club to manage this notification and any resulting claim. Primary point of contact at the club for all correspondence related to this matter.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clubReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Club Reference Number' ;
    rdfs:comment 'The unique reference number assigned by the P&I club upon receipt and registration of this notification. Used in all subsequent correspondence, claims handling, and legal proceedings with the club.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Liability Amount' ;
    rdfs:comment 'Port\'s or insured party\'s initial estimate of the total financial liability exposure arising from this incident, expressed in the notification currency. Used for reserve setting, financial provisioning, and EBITDA impact assessment. This is an estimate, not a settled claim value.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Calendar date on which the marine incident or casualty event occurred. Used for statute of limitations tracking, regulatory reporting timelines, and claims aging analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Narrative description of the marine incident, casualty, or event giving rise to this P&I notification. Includes circumstances, sequence of events, parties involved, and initial assessment of cause. Sourced from the marine incident report.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocation rdf:type rdf:Property ;
    rdfs:label 'Incident Location' ;
    rdfs:comment 'Description of the geographic location where the incident occurred, such as berth number, terminal name, anchorage area, port approach channel, or specific coordinates within port waters. Supports jurisdictional determination and liability assessment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether a legal hold has been placed on all records, evidence, and documentation related to this P&I notification. When True, all associated records must be preserved and must not be altered, deleted, or archived pending legal proceedings or investigation.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityCurrency rdf:type rdf:Property ;
    rdfs:label 'Liability Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the estimated liability exposure amount is denominated. Typically USD for international maritime claims, but may vary by jurisdiction.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marpolReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Marpol Reportable Flag' ;
    rdfs:comment 'Indicates whether the incident involves a pollution event that triggers mandatory reporting obligations under MARPOL 73/78 (Marine Pollution Convention). When True, notification to the coastal state and flag state authority is required.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The communication channel or method used to transmit the P&I notification to the club. EDI (Electronic Data Interchange) is increasingly used for structured notifications via Port Community Systems.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDatetime rdf:type rdf:Property ;
    rdfs:label 'Notification Datetime' ;
    rdfs:comment 'The principal real-world timestamp at which the P&I club was formally notified of the incident or claim. This is the legally significant notification moment, distinct from record creation time.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationReference rdf:type rdf:Property ;
    rdfs:label 'Notification Reference' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to this P&I club notification at the time of creation. Used in all correspondence with the P&I club and legal parties. Format: PNI-YYYY-NNNNNN.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the P&I club notification. Tracks progression from initial drafting through submission, acknowledgement by the club, active review, and final closure or withdrawal.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifyingPartyRole rdf:type rdf:Property ;
    rdfs:label 'Notifying Party Role' ;
    rdfs:comment 'Role or capacity in which the notifying party is acting when submitting the P&I notification. Determines the standing of the notifying party under the P&I club rules and applicable maritime law.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piClubName rdf:type rdf:Property ;
    rdfs:label 'Pi Club Name' ;
    rdfs:comment 'Full legal name of the P&I (Protection and Indemnity) mutual insurance club to which the notification has been submitted. Examples include UK P&I Club, Gard, Skuld, West of England, North of England, Steamship Mutual.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portLegalCounsel rdf:type rdf:Property ;
    rdfs:label 'Port Legal Counsel' ;
    rdfs:comment 'Name of the legal counsel or law firm appointed by the port authority to represent its interests in connection with this P&I notification and any resulting legal proceedings.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pscNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Psc Notified Flag' ;
    rdfs:comment 'Indicates whether the Port State Control (PSC) authority has been formally notified of the incident in accordance with applicable port state regulations and international conventions.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reserveAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Amount' ;
    rdfs:comment 'Financial reserve amount set aside by the P&I club or port authority against this notification to cover anticipated claim payments. Distinct from the estimated liability exposure; represents the formal accounting provision. Used for CAPEX/OPEX financial planning and EBITDA impact reporting.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveCurrency rdf:type rdf:Property ;
    rdfs:label 'Reserve Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the P&I reserve amount is denominated.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solasReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Solas Reportable Flag' ;
    rdfs:comment 'Indicates whether the underlying incident meets the threshold for mandatory reporting under SOLAS (Safety of Life at Sea) Convention requirements. When True, formal casualty reporting to the flag state and IMO is required.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyorAppointedFlag rdf:type rdf:Property ;
    rdfs:label 'Surveyor Appointed Flag' ;
    rdfs:comment 'Indicates whether a marine surveyor has been formally appointed by the P&I club or port authority to conduct a survey of the damage, loss, or incident. Surveyor appointment is a standard step in the P&I claims process.' ;
    rdfs:domain ind:PniClubNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Survey Appointment Id' ;
    rdfs:comment 'Unique system-generated identifier for each marine survey appointment record. Primary key for the survey_appointment data product.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestingPartyPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Survey appointments are requested by shipping agents, cargo owners, or P&I clubs - all port community participants. Link enables survey authorization validation, billing to correct party, service requ' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:surveyorId rdf:type rdf:Property ;
    rdfs:label 'Surveyor Id' ;
    rdfs:comment 'Reference to the appointed marine surveyor responsible for conducting the survey, linking to the surveyor or workforce master record.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Surveyor .

ind:actualCommencement rdf:type rdf:Property ;
    rdfs:label 'Actual Commencement' ;
    rdfs:comment 'The actual date and time at which the survey commenced on board or at the survey location. Used for SLA performance measurement and billing.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCompletion rdf:type rdf:Property ;
    rdfs:label 'Actual Completion' ;
    rdfs:comment 'The actual date and time at which the survey was concluded and the surveyor departed the vessel or survey location. Used for duration calculation and billing.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cargoQuantityMt rdf:type rdf:Property ;
    rdfs:label 'Cargo Quantity Mt' ;
    rdfs:comment 'Quantity of cargo in metric tonnes within the scope of the survey, particularly relevant for draught surveys and pre-loading surveys where cargo weight determination is the primary objective.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoScope rdf:type rdf:Property ;
    rdfs:label 'Cargo Scope' ;
    rdfs:comment 'Description of the cargo or equipment included within the scope of the survey, including commodity type, quantity, and relevant cargo identifiers (e.g., Bill of Lading numbers, container numbers, bulk cargo description).' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Reference' ;
    rdfs:comment 'Reference number of the survey certificate or formal survey report issued upon completion of the survey, used for regulatory compliance tracking and document management.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Number of deficiencies or non-conformances identified during the survey. Used for PSC inspection risk profiling and vessel performance tracking.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Narrative description of deficiencies, non-conformances, or observations identified during the survey. Provides qualitative context beyond the deficiency count.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draughtAftM rdf:type rdf:Property ;
    rdfs:label 'Draught Aft M' ;
    rdfs:comment 'Aft draught reading of the vessel in metres at the time of the survey, recorded for draught surveys to determine cargo weight by displacement calculation.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:draughtForwardM rdf:type rdf:Property ;
    rdfs:label 'Draught Forward M' ;
    rdfs:comment 'Forward draught reading of the vessel in metres at the time of the survey, recorded for draught surveys to determine cargo weight by displacement calculation.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:draughtMidshipM rdf:type rdf:Property ;
    rdfs:label 'Draught Midship M' ;
    rdfs:comment 'Midship draught reading of the vessel in metres at the time of the survey, used in conjunction with forward and aft draughts for accurate displacement and cargo weight calculation.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marpolComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Marpol Compliance Flag' ;
    rdfs:comment 'Indicates whether MARPOL-related environmental compliance aspects were assessed during the survey, particularly relevant for condition surveys and damage surveys involving potential pollution risk.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pi Notification Timestamp' ;
    rdfs:comment 'Date and time at which the P&I club was formally notified of the survey or marine incident, used for insurance claim timeline management.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pscInspectionTriggered rdf:type rdf:Property ;
    rdfs:label 'Psc Inspection Triggered' ;
    rdfs:comment 'Indicates whether the survey outcome or deficiencies identified triggered a formal Port State Control inspection by the relevant PSC authority.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rectificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Rectification Deadline' ;
    rdfs:comment 'The date by which identified deficiencies must be rectified and evidence of rectification submitted to the surveying authority. Applicable when survey outcome is \'failed\' or \'conditional_pass\'.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportReference rdf:type rdf:Property ;
    rdfs:label 'Report Reference' ;
    rdfs:comment 'Reference number of the detailed survey report document produced by the surveyor, distinct from the certificate number. Used for document retrieval and audit trail.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCommencement rdf:type rdf:Property ;
    rdfs:label 'Scheduled Commencement' ;
    rdfs:comment 'The planned date and time at which the survey is scheduled to commence, used for surveyor dispatch planning and vessel scheduling coordination.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:solasComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Solas Compliance Flag' ;
    rdfs:comment 'Indicates whether the survey was conducted in compliance with SOLAS requirements, confirming that mandatory SOLAS survey protocols were followed.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Survey Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from actual survey commencement to actual completion. Used for operational performance analysis and billing verification.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyLocationType rdf:type rdf:Property ;
    rdfs:label 'Survey Location Type' ;
    rdfs:comment 'Classification of the physical location where the survey is conducted, distinguishing between berth-side, anchorage, dry dock, buoy mooring, or offshore positions.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyNotes rdf:type rdf:Property ;
    rdfs:label 'Survey Notes' ;
    rdfs:comment 'Free-text operational notes and observations recorded by the surveyor or port marine services team regarding the survey appointment, including special conditions, access arrangements, or supplementary findings.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyOutcome rdf:type rdf:Property ;
    rdfs:label 'Survey Outcome' ;
    rdfs:comment 'The formal result or finding of the survey engagement. \'passed\' indicates satisfactory condition, \'failed\' indicates deficiencies requiring rectification, \'conditional_pass\' indicates minor deficiencies with conditions attached, \'inconclusive\' indicates insufficient evidence for determination, \'deferred\' indicates survey could not be completed and must be rescheduled.' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the marine survey engagement indicating the nature and scope of the inspection. Values include: condition survey (general vessel condition assessment), draught survey (cargo weight determination by displacement), damage survey (assessment of vessel or cargo damage), pre-loading survey (cargo readiness inspection before loading), hatch inspection (hatch cover integrity and weathertightness check).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyingOrganisation rdf:type rdf:Property ;
    rdfs:label 'Surveying Organisation' ;
    rdfs:comment 'Name of the classification society, P&I club surveying firm, or independent marine surveying organisation that appointed the surveyor (e.g., Lloyd\'s Register, Bureau Veritas, DNV, ABS).' ;
    rdfs:domain ind:SurveyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the classification society or professional body that has accredited and authorised the surveyor to conduct marine surveys. Determines the scope of surveys the individual may certify. [ENUM-REF-CANDIDATE: Lloyds|DNV|Bureau Veritas|ClassNK|ABS|RINA|CCS|BKI|other — promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorisationGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Authorisation Granted Date' ;
    rdfs:comment 'Date on which the port authority formally granted the surveyor authorisation to operate within port jurisdiction. Marks the start of the surveyor\'s active engagement lifecycle at the port.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorisationRevocationDate rdf:type rdf:Property ;
    rdfs:label 'Authorisation Revocation Date' ;
    rdfs:comment 'Date on which the surveyor\'s port authorisation was revoked or permanently withdrawn. Null if the surveyor has never been revoked. Used for compliance audit trails and ISPS security records.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorisationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorisation Status' ;
    rdfs:comment 'Current lifecycle status of the surveyor\'s authorisation to operate within port jurisdiction. Controls gate access, survey report acceptance, and P&I notification eligibility. Active = fully authorised; Suspended = temporarily restricted; Expired = credentials lapsed; Revoked = permanently withdrawn; Pending = application under review.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Name of the surveying firm, classification society branch, or P&I correspondent organisation to which the surveyor is affiliated. Used for billing, correspondence, and stakeholder management in the Port Community System (PCS).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgCertified rdf:type rdf:Property ;
    rdfs:label 'Imdg Certified' ;
    rdfs:comment 'Indicates whether the surveyor is certified to survey and certify the handling, stowage, and transport of dangerous goods in accordance with the International Maritime Dangerous Goods (IMDG) Code.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Insurance Provider' ;
    rdfs:comment 'Name of the insurance company or P&I Club providing professional indemnity coverage for the surveyor. Required as part of port authorisation to ensure liability coverage for survey activities within port waters.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagesSpoken rdf:type rdf:Property ;
    rdfs:label 'Languages Spoken' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes for languages the surveyor is proficient in. Relevant for vessel boarding communications, survey report preparation, and coordination with international vessel crews.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent compliance audit or vetting review conducted by the port authority or accreditation body on the surveyor\'s credentials, insurance, and operational performance. Supports Port State Control (PSC) readiness.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marpolCertified rdf:type rdf:Property ;
    rdfs:label 'Marpol Certified' ;
    rdfs:comment 'Indicates whether the surveyor holds a valid certification to conduct surveys and inspections under the International Convention for the Prevention of Pollution from Ships (MARPOL). Required for pollution prevention and environmental compliance surveys.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile/cell phone number for the surveyor in E.164 international format. Used for on-call survey dispatch, real-time vessel boarding coordination, and emergency contact during port operations.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiPortAuthorised rdf:type rdf:Property ;
    rdfs:label 'Multi Port Authorised' ;
    rdfs:comment 'Indicates whether the surveyor holds authorisation to operate across multiple port facilities within the port authority\'s jurisdiction, beyond their primary home port. Relevant for port groups managing multiple terminals.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onCallFlag rdf:type rdf:Property ;
    rdfs:label 'On Call Flag' ;
    rdfs:comment 'Indicates whether the surveyor is currently designated as on-call for emergency or after-hours survey dispatch, including marine incident response, P&I notifications, and urgent cargo condition surveys.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'Passport number of the surveyor as recorded for ISPS port security screening and identity verification. Required for international surveyors accessing restricted port areas.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piClubAffiliation rdf:type rdf:Property ;
    rdfs:label 'Pi Club Affiliation' ;
    rdfs:comment 'Name of the Protection and Indemnity (P&I) Club for which the surveyor acts as a correspondent or appointed representative. Relevant for P&I surveyors handling cargo claims, collision liability, and pollution incidents within port waters.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portAccessCredentialNumber rdf:type rdf:Property ;
    rdfs:label 'Port Access Credential Number' ;
    rdfs:comment 'Unique credential or pass number issued by the port authority granting the surveyor physical access to port facilities, berths, and vessels. Linked to ISPS-compliant access control systems and gate operations in NAVIS N4.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portAccessExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Port Access Expiry Date' ;
    rdfs:comment 'Date on which the surveyor\'s port access credential expires. Expiry triggers automatic access revocation in the port\'s ISPS-compliant gate control system and requires re-application.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portAccessIssueDate rdf:type rdf:Property ;
    rdfs:label 'Port Access Issue Date' ;
    rdfs:comment 'Date on which the port access credential was issued to the surveyor. Used for access lifecycle management and ISPS compliance auditing.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'The surveyor\'s preferred channel for receiving survey dispatch notifications and port communications. Options include email, phone, mobile, pcs_message (Port Community System message), or edi (Electronic Data Interchange).' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfAuthorisation rdf:type rdf:Property ;
    rdfs:label 'Scope Of Authorisation' ;
    rdfs:comment 'Detailed description of the specific survey activities, vessel types, cargo categories, or operational areas the surveyor is authorised to cover within port jurisdiction. May reference SOLAS, MARPOL, IMDG, or classification society-specific survey categories.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seamanBookNumber rdf:type rdf:Property ;
    rdfs:label 'Seaman Book Number' ;
    rdfs:comment 'Seafarer\'s identity document or continuous discharge book number, where applicable. Some classification society and P&I surveyors hold seafarer credentials that facilitate vessel boarding under ILO Maritime Labour Convention requirements.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solasCertified rdf:type rdf:Property ;
    rdfs:label 'Solas Certified' ;
    rdfs:comment 'Indicates whether the surveyor holds a valid certification to conduct surveys under the International Convention for the Safety of Life at Sea (SOLAS). Required for structural, safety equipment, and load line surveys.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialisationCodes rdf:type rdf:Property ;
    rdfs:label 'Specialisation Codes' ;
    rdfs:comment 'Comma-separated list of specialisation codes indicating the surveyor\'s certified areas of expertise, such as IMDG dangerous goods, MARPOL pollution prevention, SOLAS structural surveys, draught surveys, or reefer cargo. Drives survey assignment matching in the Port Management Information System (PMIS).' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorCode rdf:type rdf:Property ;
    rdfs:label 'Surveyor Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the surveyor by the port authority or accreditation body. Used as the business-facing identifier on survey certificates, gate access systems, and Port Community System (PCS) messaging.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselTypeAuthorisations rdf:type rdf:Property ;
    rdfs:label 'Vessel Type Authorisations' ;
    rdfs:comment 'Comma-separated list of vessel types the surveyor is authorised to survey, such as container vessels, bulk carriers, tankers, RoRo vessels, LNG carriers, or passenger ships. Ensures correct surveyor-to-vessel matching for survey assignments.' ;
    rdfs:domain ind:Surveyor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingAgentPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Requesting Agent Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: Towage orders are raised by shipping agents who are port community participants. Direct link supports agent authorization checks, credit limit validation, billing account lookup, and service request t' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:towageCallId rdf:type rdf:Property ;
    rdfs:label 'Towage Call Id' ;
    rdfs:comment 'FK to vessel.call.call_id — Marine service billing and operational coordination require linking towage orders to the vessel call being serviced. Without this, towage cannot be reconciled to vessel visits.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Call .

ind:towagePortCallId rdf:type rdf:Property ;
    rdfs:label 'Towage Port Call Id' ;
    rdfs:comment 'Reference to the port call or vessel visit record associated with this towage order. Links towage service to the broader vessel arrival/departure event for integrated port operations reporting.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Call .

ind:abortReason rdf:type rdf:Property ;
    rdfs:label 'Abort Reason' ;
    rdfs:comment 'Free-text description of the reason for aborting or cancelling the towage operation. Mandatory when service_outcome is \'aborted\' or \'cancelled\'. Used for root cause analysis and operational improvement.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgHazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Imdg Hazmat Flag' ;
    rdfs:comment 'Indicates whether the vessel is carrying International Maritime Dangerous Goods (IMDG) classified hazardous cargo at the time of towage. True = hazardous cargo on board. Influences tug safety protocols and emergency response readiness.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minBollardPullTonnes rdf:type rdf:Property ;
    rdfs:label 'Min Bollard Pull Tonnes' ;
    rdfs:comment 'Minimum total bollard pull force in metric tonnes required for the towage operation, calculated based on vessel DWT, environmental conditions, and port-specific towage assessment criteria.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderReference rdf:type rdf:Property ;
    rdfs:label 'Order Reference' ;
    rdfs:comment 'Externally-known human-readable reference number assigned to the towage order, used in communications with shipping agents, tug operators, and port authority. Format: TOW-YYYY-NNNNNN.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'Date and time when the towage service was formally requested by the shipping agent or vessel operator. Principal business event timestamp marking the start of the towage order lifecycle.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:safetyObservationFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Observation Flag' ;
    rdfs:comment 'Indicates whether a safety observation, near-miss, or safety concern was recorded during the towage operation. True = safety observation exists. Triggers mandatory safety review process per SOLAS and ISPS requirements.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyObservationNotes rdf:type rdf:Property ;
    rdfs:label 'Safety Observation Notes' ;
    rdfs:comment 'Free-text description of any safety observations, near-misses, or hazards identified during the towage operation. Populated when safety_observation_flag is True. Used for safety management system reporting.' ;
    rdfs:domain ind:Marine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOutcome rdf:type rdf:Property ;
    rdfs:label 'Service Outcome' ;
    rdfs:comment 'Final outcome of the towage service delivery. \'completed\' = full service delivered successfully; \'aborted\' = commenced but terminated before completion; \'cancelled\' = cancelled before commencement; \'partial\' = service partially delivered due to operational constraints.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:towageChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Towage Charge Amount' ;
    rdfs:comment 'Gross towage service charge amount in the port\'s base currency, calculated per the applicable port tariff schedule based on vessel GRT, towage type, duration, and number of tugs. Used for billing and revenue reporting.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:towageType rdf:type rdf:Property ;
    rdfs:label 'Towage Type' ;
    rdfs:comment 'Classification of the towage operation by purpose. \'arrival\' = vessel inbound to berth; \'departure\' = vessel outbound from berth; \'shifting\' = vessel moving between berths within port; \'emergency\' = unplanned emergency towage; \'dry_dock\' = towage to/from dry dock facility.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tugAttachmentBow rdf:type rdf:Property ;
    rdfs:label 'Tug Attachment Bow' ;
    rdfs:comment 'Indicates whether a tug is required to be attached at the bow (forward) of the vessel as part of the towage configuration. True = bow tug required.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tugAttachmentBreast rdf:type rdf:Property ;
    rdfs:label 'Tug Attachment Breast' ;
    rdfs:comment 'Indicates whether a tug is required to be attached breast (alongside) the vessel as part of the towage configuration. True = breast tug required.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tugAttachmentStern rdf:type rdf:Property ;
    rdfs:label 'Tug Attachment Stern' ;
    rdfs:comment 'Indicates whether a tug is required to be attached at the stern (aft) of the vessel as part of the towage configuration. True = stern tug required.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tugsAssigned rdf:type rdf:Property ;
    rdfs:label 'Tugs Assigned' ;
    rdfs:comment 'Actual number of tug vessels assigned and dispatched for the towage operation. May differ from tugs_required if operational adjustments are made.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tugsRequired rdf:type rdf:Property ;
    rdfs:label 'Tugs Required' ;
    rdfs:comment 'Total number of tug vessels required to safely execute the towage operation as determined by the port\'s towage assessment based on vessel LOA, DWT, wind, and current conditions.' ;
    rdfs:domain ind:TowageOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ahtsCapable rdf:type rdf:Property ;
    rdfs:label 'Ahts Capable' ;
    rdfs:comment 'Indicates whether the tug vessel is equipped and certified for anchor handling and towing supply (AHTS) operations, including offshore anchor deployment and retrieval. True = AHTS capable; False = harbour towage only. Relevant for ports serving offshore oil and gas support operations.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aisTransponderClass rdf:type rdf:Property ;
    rdfs:label 'Ais Transponder Class' ;
    rdfs:comment 'Class of the Automatic Identification System (AIS) transponder fitted on the tug vessel. Class A transponders are mandatory for SOLAS vessels and provide full dynamic data; Class B transponders are used on smaller non-SOLAS vessels with reduced transmission frequency. Determines the vessel\'s real-time tracking capability within the port\'s VTS system.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beamM rdf:type rdf:Property ;
    rdfs:label 'Beam M' ;
    rdfs:comment 'Maximum breadth (beam) of the tug vessel in metres measured at the widest point of the hull. Used in navigation clearance calculations, dry dock planning, and assessing compatibility with port infrastructure such as lock chambers and fendering systems.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bollardPullTonnes rdf:type rdf:Property ;
    rdfs:label 'Bollard Pull Tonnes' ;
    rdfs:comment 'Certified static bollard pull force of the tug in metric tonnes, as measured and certified under controlled test conditions. The principal performance metric used to match tug capability to vessel assistance requirements based on the assisted vessel\'s DWT, LOA, and environmental conditions. Critical for berth allocation planning and safe towage operations.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildShipyard rdf:type rdf:Property ;
    rdfs:label 'Build Shipyard' ;
    rdfs:comment 'Name of the shipyard where the tug vessel was constructed. Retained for asset provenance records, warranty claims, technical documentation retrieval, and historical maintenance reference in Maximo Asset Management.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callSign rdf:type rdf:Property ;
    rdfs:label 'Call Sign' ;
    rdfs:comment 'International radio call sign assigned to the tug vessel by the flag state telecommunications authority. Used for VHF radio communications with Vessel Traffic Service (VTS) and port control during towage and escort operations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classNotation rdf:type rdf:Property ;
    rdfs:label 'Class Notation' ;
    rdfs:comment 'Full classification notation string assigned by the classification society, describing the vessel\'s structural class, machinery class, and any additional notations (e.g., fire-fighting, escort, ice class). Provides a concise technical summary of the vessel\'s certified capabilities and construction standards.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classSurveyDueDate rdf:type rdf:Property ;
    rdfs:label 'Class Survey Due Date' ;
    rdfs:comment 'Date by which the next mandatory classification society survey (annual, intermediate, or special/renewal) must be completed to maintain the vessel\'s class certificate in good standing. Used in maintenance planning and operational availability forecasting in Maximo Asset Management.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationSociety rdf:type rdf:Property ;
    rdfs:label 'Classification Society' ;
    rdfs:comment 'Name of the international classification society (e.g., Lloyd\'s Register, DNV, Bureau Veritas, ABS, ClassNK) that has classed the tug vessel and issues its class certificates. Determines the survey regime, structural standards, and equipment certification applicable to the vessel.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date on which the tug vessel was formally commissioned into service at the port, either as a new build delivery or upon commencement of a charter/contract arrangement. Marks the start of the vessel\'s operational lifecycle record in Maximo Asset Management and the port\'s marine services SSOT.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crewComplement rdf:type rdf:Property ;
    rdfs:label 'Crew Complement' ;
    rdfs:comment 'Minimum number of crew members required to safely operate the tug vessel as specified in the vessel\'s Safe Manning Certificate issued by the flag state. Used in workforce planning, shift rostering, and compliance with ILO Maritime Labour Convention (MLC 2006) crewing requirements.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date on which the tug vessel was formally withdrawn from service at the port, either permanently or for an extended lay-up period. Nullable for vessels currently in service. Used to close the asset lifecycle record and trigger final compliance and financial close-out processes.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:draughtM rdf:type rdf:Property ;
    rdfs:label 'Draught M' ;
    rdfs:comment 'Maximum operational draught of the tug vessel in metres. Used to assess navigability in shallow harbour areas, tidal windows for operations, and compliance with port water depth restrictions. Critical for safe operations in ports with tidal or dredging constraints.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enginePowerKw rdf:type rdf:Property ;
    rdfs:label 'Engine Power Kw' ;
    rdfs:comment 'Total installed main engine power output of the tug vessel measured in kilowatts (kW). Used alongside bollard pull rating to assess tug capability, fuel consumption planning, and compliance with port emission standards. Sourced from the vessel\'s engine certificate and classification society records.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escortBollardPullTonnes rdf:type rdf:Property ;
    rdfs:label 'Escort Bollard Pull Tonnes' ;
    rdfs:comment 'Certified escort bollard pull force in metric tonnes, measured under dynamic escort conditions as distinct from static bollard pull. Applicable only to escort-certified tugs. Used to determine the maximum DWT of tankers and gas carriers the tug can safely escort through the port approach channel.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escortCertified rdf:type rdf:Property ;
    rdfs:label 'Escort Certified' ;
    rdfs:comment 'Indicates whether the tug vessel holds a valid escort tug certification from its classification society, confirming it meets the structural, stability, and equipment standards required for escort towage of large tankers and gas carriers in restricted waterways. True = certified for escort operations; False = not certified.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifiClass rdf:type rdf:Property ;
    rdfs:label 'Fifi Class' ;
    rdfs:comment 'IMO/classification society fire-fighting system class notation of the tug vessel. FiFi1 denotes basic fire-fighting capability; FiFi1+WS includes water spray; FiFi2 and FiFi3 denote progressively higher capacity systems. \'none\' indicates no certified fire-fighting equipment. Determines eligibility for fire-fighting standby duties and emergency response assignments in the port.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Primary fuel type used by the tug vessel\'s main engines. HFO = Heavy Fuel Oil; MGO = Marine Gas Oil; MDO = Marine Diesel Oil; LNG = Liquefied Natural Gas; methanol = methanol fuel; hybrid = dual-fuel or battery-hybrid arrangement. Used in emissions reporting under MARPOL Annex VI, GHG tracking, and port environmental management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossTonnage rdf:type rdf:Property ;
    rdfs:label 'Gross Tonnage' ;
    rdfs:comment 'Gross Registered Tonnage (GRT) of the tug vessel as certified under the International Convention on Tonnage Measurement of Ships. Used for port dues calculation, PSC inspection scheduling, and regulatory reporting to maritime authorities.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homePort rdf:type rdf:Property ;
    rdfs:label 'Home Port' ;
    rdfs:comment 'Name of the port or terminal at which the tug vessel is normally based and from which it is dispatched for towage and marine service operations. Used in operational planning, crew logistics, and maintenance scheduling within the port\'s marine services management system.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iceClass rdf:type rdf:Property ;
    rdfs:label 'Ice Class' ;
    rdfs:comment 'Ice class notation assigned by the classification society indicating the tug vessel\'s structural capability to operate in ice-covered waters. Ranges from \'IA Super\' (highest) to \'ID\' (lowest ice class) or \'none\' for no ice capability. Relevant for ports in seasonal ice regions and for compliance with IACS Polar Class requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsCertExpiry rdf:type rdf:Property ;
    rdfs:label 'Isps Cert Expiry' ;
    rdfs:comment 'Expiry date of the International Ship Security Certificate (ISSC) issued under the ISPS Code. Confirms the vessel has an approved Ship Security Plan and complies with SOLAS Chapter XI-2 security requirements. Required for port access and monitored by port facility security officers.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDryDockDate rdf:type rdf:Property ;
    rdfs:label 'Last Dry Dock Date' ;
    rdfs:comment 'Date on which the tug vessel most recently completed a dry docking for hull inspection, underwater maintenance, and classification society survey. Used in maintenance planning to calculate the next scheduled dry dock and assess hull condition for operational readiness.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loaM rdf:type rdf:Property ;
    rdfs:label 'Loa M' ;
    rdfs:comment 'Length Overall (LOA) of the tug vessel in metres, measured from the foremost point to the aftermost point of the hull. Used in berth planning, harbour navigation clearance assessments, and determining operational constraints within the port basin.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marpolCertExpiry rdf:type rdf:Property ;
    rdfs:label 'Marpol Cert Expiry' ;
    rdfs:comment 'Expiry date of the vessel\'s MARPOL compliance certificate (International Oil Pollution Prevention Certificate or equivalent), confirming the tug meets IMO Marine Pollution Convention requirements for prevention of pollution from ships. Monitored for environmental compliance and PSC inspection readiness.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Max Speed Knots' ;
    rdfs:comment 'Maximum service speed of the tug vessel in knots under normal operating conditions. Used in marine service scheduling to calculate transit times to vessel rendezvous positions, optimise tug dispatch timing, and assess response capability for emergency towage.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netTonnage rdf:type rdf:Property ;
    rdfs:label 'Net Tonnage' ;
    rdfs:comment 'Net Registered Tonnage (NRT) of the tug vessel as certified under the International Convention on Tonnage Measurement of Ships. Represents the vessel\'s earning capacity and is used in certain port tariff calculations and regulatory filings.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDryDockDate rdf:type rdf:Property ;
    rdfs:label 'Next Dry Dock Date' ;
    rdfs:comment 'Planned date for the tug vessel\'s next dry docking. Used in long-term maintenance scheduling, operational availability planning, and budget forecasting for CAPEX dry dock expenditure in SAP S/4HANA.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officialNumber rdf:type rdf:Property ;
    rdfs:label 'Official Number' ;
    rdfs:comment 'National official registration number assigned by the flag state maritime authority at the port of registry. Complements the IMO number as a domestic regulatory identifier used in national maritime administration and port authority records.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCompany rdf:type rdf:Property ;
    rdfs:label 'Operating Company' ;
    rdfs:comment 'Legal name of the company responsible for the day-to-day commercial and technical management and operation of the tug vessel. May be the same as the owning company or a contracted towage operator. Used in service agreements, billing, and ISM Code compliance documentation.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningCompany rdf:type rdf:Property ;
    rdfs:label 'Owning Company' ;
    rdfs:comment 'Legal name of the company that holds registered ownership of the tug vessel. May differ from the operating company in cases of bareboat charter or leasing arrangements. Used in commercial contracts, insurance documentation, P&I Club notifications, and port authority vessel registration records.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piClub rdf:type rdf:Property ;
    rdfs:label 'Pi Club' ;
    rdfs:comment 'Name of the Protection and Indemnity (P&I) Club providing third-party liability insurance coverage for the tug vessel. P&I insurance covers liabilities arising from towage operations including collision, pollution, and crew injury. Required for port entry and towage service authorisation under ISPS and port authority regulations.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pi Expiry Date' ;
    rdfs:comment 'Date on which the current P&I Club insurance certificate expires. Used to trigger renewal alerts and ensure continuous insurance coverage. Tugs with expired P&I cover must not be dispatched for towage operations under port authority rules.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Pi Policy Number' ;
    rdfs:comment 'Policy or certificate number of the current P&I Club insurance cover for the tug vessel. Used in incident reporting, claims management, and port authority compliance verification. Required to be presented during PSC inspections and port entry clearance.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfRegistry rdf:type rdf:Property ;
    rdfs:label 'Port Of Registry' ;
    rdfs:comment 'Name of the port where the tug vessel is officially registered as recorded on the vessel\'s certificate of registry. Displayed on the vessel\'s stern and used in official maritime documentation and PSC inspections.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyManagementCertExpiry rdf:type rdf:Property ;
    rdfs:label 'Safety Management Cert Expiry' ;
    rdfs:comment 'Expiry date of the Safety Management Certificate (SMC) issued under the ISM Code, confirming the vessel\'s safety management system complies with IMO requirements. Tugs operating under the ISM Code must maintain a valid SMC. Used in compliance monitoring and PSC inspection preparation.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tugName rdf:type rdf:Property ;
    rdfs:label 'Tug Name' ;
    rdfs:comment 'Official registered name of the tug vessel as recorded on the vessel\'s certificate of registry. Used as the primary human-readable identity label in port operations, VTS communications, and marine service scheduling.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tugType rdf:type rdf:Property ;
    rdfs:label 'Tug Type' ;
    rdfs:comment 'Classification of the tug vessel by propulsion and manoeuvring system design. ASD (Azimuth Stern Drive) tugs offer 360-degree thrust; conventional tugs use fixed propellers; voith tugs use Voith-Schneider cycloidal propellers; tractor tugs use forward-mounted azimuth drives; rotor tugs use a hybrid arrangement. Determines operational capability and assignment suitability for specific towage tasks.' ;
    rdfs:domain ind:Tug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tugAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Tug Assignment Id' ;
    rdfs:comment 'Unique identifier for the tug assignment record. Primary key for the tug assignment entity.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDemobilisationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Demobilisation Timestamp' ;
    rdfs:comment 'Actual date and time when the tug returned to its berth or anchorage after completing the towage assignment. Used for utilisation tracking and billing.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualMobilisationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Mobilisation Timestamp' ;
    rdfs:comment 'Actual date and time when the tug departed from its berth or anchorage to commence the towage assignment. Used for performance tracking and billing.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedPosition rdf:type rdf:Property ;
    rdfs:label 'Assigned Position' ;
    rdfs:comment 'The designated attachment position or role of the tug relative to the vessel being assisted. Critical for operational coordination and safety planning. [ENUM-REF-CANDIDATE: bow|stern|port_bow|starboard_bow|port_quarter|starboard_quarter|standby|escort — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Assignment Duration Minutes' ;
    rdfs:comment 'Total duration of the tug assignment from mobilisation to demobilisation, measured in minutes. Used for billing and performance analysis.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assignment Outcome' ;
    rdfs:comment 'Final outcome of the tug assignment. Indicates whether the towage operation was completed successfully or encountered issues.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bollardPullAppliedTonnes rdf:type rdf:Property ;
    rdfs:label 'Bollard Pull Applied Tonnes' ;
    rdfs:comment 'Actual bollard pull force applied by the tug during the towage operation, measured in tonnes. Critical for safety assessment and performance verification.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentDirectionDegrees rdf:type rdf:Property ;
    rdfs:label 'Current Direction Degrees' ;
    rdfs:comment 'Water current direction during the towage operation, measured in degrees (0-360, where 0/360 is North). Affects vessel handling and tug positioning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disengagementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disengagement Timestamp' ;
    rdfs:comment 'Date and time when the tug disengaged from the vessel (lines cast off or push ceased). Marks the end of active towage.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Engagement Duration Minutes' ;
    rdfs:comment 'Duration of active towage engagement (from engagement to disengagement), measured in minutes. Distinguishes active towing time from standby time.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Engagement Timestamp' ;
    rdfs:comment 'Date and time when the tug physically engaged with the vessel (lines made fast or push commenced). Marks the start of active towage.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxBollardPullAppliedTonnes rdf:type rdf:Property ;
    rdfs:label 'Max Bollard Pull Applied Tonnes' ;
    rdfs:comment 'Peak bollard pull force applied by the tug during the towage operation, measured in tonnes. Used for safety analysis and equipment stress assessment.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onStationTimestamp rdf:type rdf:Property ;
    rdfs:label 'On Station Timestamp' ;
    rdfs:comment 'Date and time when the tug arrived at the designated position and was ready to commence towage operations. Marks the start of active service.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationalNarrative rdf:type rdf:Property ;
    rdfs:label 'Operational Narrative' ;
    rdfs:comment 'Detailed narrative description of the towage operation, including key events, decisions, and outcomes. Provides comprehensive operational record.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledMobilisationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Mobilisation Timestamp' ;
    rdfs:comment 'Planned date and time when the tug is scheduled to depart from its berth or anchorage to commence the towage assignment.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:towLineLengthM rdf:type rdf:Property ;
    rdfs:label 'Tow Line Length M' ;
    rdfs:comment 'Length of the tow line deployed during the towage operation, measured in meters. Affects the mechanical advantage and safety margin.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:towLineType rdf:type rdf:Property ;
    rdfs:label 'Tow Line Type' ;
    rdfs:comment 'Type of tow line used for the towage operation. Different line types have different strength, elasticity, and handling characteristics.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tugMasterLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tug Master Licence Number' ;
    rdfs:comment 'The professional licence or certificate number of the tug master, verifying their competency and authorization to command the tug.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tugMasterName rdf:type rdf:Property ;
    rdfs:label 'Tug Master Name' ;
    rdfs:comment 'Full name of the tug master on duty for this assignment. Captured for operational records and incident investigation purposes.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tugMasterRemarks rdf:type rdf:Property ;
    rdfs:label 'Tug Master Remarks' ;
    rdfs:comment 'Free-text remarks and observations recorded by the tug master regarding the towage operation. Captures operational insights and lessons learned.' ;
    rdfs:domain ind:TugAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherTideWindowId rdf:type rdf:Property ;
    rdfs:label 'Weather Tide Window Id' ;
    rdfs:comment 'Unique identifier for the weather and tidal condition observation record. Primary key for the weather_tide_window product.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedSecurityZoneId rdf:type rdf:Property ;
    rdfs:label 'Affected Security Zone Id' ;
    rdfs:comment 'Foreign key linking to security.security_zone. Business justification: Tidal and weather restrictions affect security patrol accessibility to zones: low tide blocks patrol boat access to outer anchorage security zones, high winds prevent CCTV-equipped drone patrols of pe' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:observerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Observer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Weather and tide observations are recorded by specific port staff for operational safety decisions - real logging requirement enabling accountability for critical navigational safety data.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:airTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Air Temperature C' ;
    rdfs:comment 'The ambient air temperature in degrees Celsius at the observation location and timestamp.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barometricPressureHpa rdf:type rdf:Property ;
    rdfs:label 'Barometric Pressure Hpa' ;
    rdfs:comment 'The atmospheric pressure in hectopascals (hPa) at the observation location. Rapid pressure changes can indicate approaching weather systems and affect tidal predictions.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastSource rdf:type rdf:Property ;
    rdfs:label 'Forecast Source' ;
    rdfs:comment 'The meteorological or hydrographic agency or system that provided the forecast data used for predicted values (e.g., National Weather Service, Bureau of Meteorology, port tide prediction model).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marpolEnvironmentalFlag rdf:type rdf:Property ;
    rdfs:label 'Marpol Environmental Flag' ;
    rdfs:comment 'Boolean flag indicating whether environmental conditions (e.g., high winds, heavy seas) pose a risk for MARPOL compliance during cargo or bunkering operations (True = environmental risk present, False = no risk).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxVesselDraftPermittedM rdf:type rdf:Property ;
    rdfs:label 'Max Vessel Draft Permitted M' ;
    rdfs:comment 'The maximum vessel draft in meters permitted to transit or berth under the observed tidal conditions, ensuring adequate under keel clearance (UKC).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVesselLoaPermittedM rdf:type rdf:Property ;
    rdfs:label 'Max Vessel Loa Permitted M' ;
    rdfs:comment 'The maximum vessel LOA (Length Overall) in meters permitted to conduct marine operations under the observed conditions. Larger vessels may be restricted due to wind, current, or UKC constraints.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mooringRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Mooring Restriction Flag' ;
    rdfs:comment 'Boolean flag indicating whether mooring operations are restricted or suspended due to the observed weather and tidal conditions (True = restricted, False = unrestricted).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observationLocation rdf:type rdf:Property ;
    rdfs:label 'Observation Location' ;
    rdfs:comment 'The specific location within port waters where the observation was taken (e.g., fairway entrance, pilot boarding ground, berth approach channel, anchorage block).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationReference rdf:type rdf:Property ;
    rdfs:label 'Observation Reference' ;
    rdfs:comment 'Human-readable unique reference number for the weather and tide observation window, formatted as WTW-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationRemarks rdf:type rdf:Property ;
    rdfs:label 'Observation Remarks' ;
    rdfs:comment 'Free-text field for additional notes, observations, or context provided by the observer or VTS operator regarding the weather and tidal conditions.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationSource rdf:type rdf:Property ;
    rdfs:label 'Observation Source' ;
    rdfs:comment 'The source or method by which the observation was captured: automated sensor, manual reading by marine personnel, VTS (Vessel Traffic Service) report, weather station, tide gauge, or forecast model.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationStatus rdf:type rdf:Property ;
    rdfs:label 'Observation Status' ;
    rdfs:comment 'Current lifecycle status of the observation record: preliminary (initial reading), validated (quality-checked), revised (corrected after review), final (confirmed and locked), or superseded (replaced by newer reading).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observation Timestamp' ;
    rdfs:comment 'The precise date and time when the weather and tidal conditions were observed or recorded, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). This is the principal real-world event time for this observation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pilotageRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Pilotage Restriction Flag' ;
    rdfs:comment 'Boolean flag indicating whether pilotage operations are restricted or suspended due to the observed weather and tidal conditions (True = restricted, False = unrestricted).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precipitationMm rdf:type rdf:Property ;
    rdfs:label 'Precipitation Mm' ;
    rdfs:comment 'The amount of precipitation (rain, snow, sleet) in millimeters recorded during the observation period. Heavy precipitation can affect visibility and deck operations.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictionReason rdf:type rdf:Property ;
    rdfs:label 'Restriction Reason' ;
    rdfs:comment 'Detailed explanation of why marine service restrictions were imposed, referencing specific threshold breaches (e.g., wind speed exceeds 25 knots, visibility below 1 NM, tide height insufficient for UKC).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceWindowStatus rdf:type rdf:Property ;
    rdfs:label 'Service Window Status' ;
    rdfs:comment 'The derived operational decision for marine service delivery based on observed conditions: go (safe to proceed), no-go (unsafe, operations suspended), conditional (proceed with restrictions), or restricted (limited operations only).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swellHeightM rdf:type rdf:Property ;
    rdfs:label 'Swell Height M' ;
    rdfs:comment 'The height of ocean swell in meters at the observation location. Swell is long-period wave motion distinct from locally generated wind waves.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tidalPhase rdf:type rdf:Property ;
    rdfs:label 'Tidal Phase' ;
    rdfs:comment 'The current phase of the tidal cycle at observation time: high water (peak tide), low water (minimum tide), flood (rising tide), ebb (falling tide), or slack water (minimal current between flood and ebb).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tidalStreamDirectionDegrees rdf:type rdf:Property ;
    rdfs:label 'Tidal Stream Direction Degrees' ;
    rdfs:comment 'The direction of the tidal current flow in degrees true (0-360), where 0/360 is north, 90 is east, 180 is south, and 270 is west.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tidalStreamRateKnots rdf:type rdf:Property ;
    rdfs:label 'Tidal Stream Rate Knots' ;
    rdfs:comment 'The speed of the tidal current or stream in knots at the observation location and timestamp. Critical for pilotage and towage planning.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tidalWindowEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tidal Window End Timestamp' ;
    rdfs:comment 'The timestamp when the favorable tidal window closes for vessel movements requiring specific tide heights or UKC, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tidalWindowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tidal Window Start Timestamp' ;
    rdfs:comment 'The timestamp when the favorable tidal window opens for vessel movements requiring specific tide heights or UKC, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tideHeightActualM rdf:type rdf:Property ;
    rdfs:label 'Tide Height Actual M' ;
    rdfs:comment 'The actual observed tidal height in meters above chart datum at the observation timestamp, measured by tide gauge or sensor. May differ from predicted due to meteorological effects (storm surge, barometric pressure).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tideHeightPredictedM rdf:type rdf:Property ;
    rdfs:label 'Tide Height Predicted M' ;
    rdfs:comment 'The predicted tidal height in meters above chart datum at the observation timestamp, based on published tide tables and astronomical predictions.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tideHeightVarianceM rdf:type rdf:Property ;
    rdfs:label 'Tide Height Variance M' ;
    rdfs:comment 'The difference between actual and predicted tide height in meters (actual minus predicted). Positive values indicate higher than predicted tide; negative values indicate lower than predicted.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:towageRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Towage Restriction Flag' ;
    rdfs:comment 'Boolean flag indicating whether towage operations are restricted or suspended due to the observed weather and tidal conditions (True = restricted, False = unrestricted).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ukcAvailableM rdf:type rdf:Property ;
    rdfs:label 'Ukc Available M' ;
    rdfs:comment 'The calculated under keel clearance in meters available at the observation location based on current tide height and charted depth. Critical for deep-draft vessel movements.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vtsNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Vts Notification Sent Flag' ;
    rdfs:comment 'Boolean flag indicating whether a notification of the weather and tidal conditions was sent to the Vessel Traffic Service (VTS) for broadcast to vessels (True = notification sent, False = not sent).' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Water Temperature C' ;
    rdfs:comment 'The sea water temperature in degrees Celsius at the observation location. Relevant for vessel draft calculations and environmental monitoring.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveHeightM rdf:type rdf:Property ;
    rdfs:label 'Wave Height M' ;
    rdfs:comment 'The significant wave height in meters at the observation location, representing locally generated wind waves. Used to assess vessel motion and mooring safety.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windGustSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Wind Gust Speed Knots' ;
    rdfs:comment 'The maximum wind gust speed in knots recorded during the observation period. Used to assess peak wind loading on vessels and equipment.' ;
    rdfs:domain ind:WeatherTideWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoCategoryId rdf:type rdf:Property ;
    rdfs:label 'Cargo Category Id' ;
    rdfs:comment 'Unique identifier for the cargo category. Primary key.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CargoCategory .

ind:applicableEquipmentTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Equipment Types' ;
    rdfs:comment 'Comma-separated list of equipment types suitable for handling this cargo category (e.g., STS crane, RTG, mobile harbour crane, reach stacker, forklift, AGV, bulk loader). References equipment master data.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Standardized short code identifying the cargo category (e.g., FCL, LCL, BULK-DRY, BULK-LIQ, RORO, REEFER, DG, OOG, EMPTY, BREAKBULK). Used across operational systems and EDI messaging.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full descriptive name of the cargo category (e.g., Full Container Load, Less than Container Load, Bulk Dry Cargo, Roll-on Roll-off, Refrigerated Cargo, Dangerous Goods).' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'High-level classification grouping cargo categories by handling paradigm: containerized (FCL/LCL), bulk (dry/liquid), breakbulk (general cargo), roro (wheeled), or specialized (project/OOG/reefer/DG).' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Inspection Required' ;
    rdfs:comment 'Indicates whether cargo in this category typically requires mandatory customs inspection or clearance procedures before release.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demurrageApplicable rdf:type rdf:Property ;
    rdfs:label 'Demurrage Applicable' ;
    rdfs:comment 'Indicates whether demurrage charges apply to cargo in this category when dwell time exceeds free time allowances.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detentionApplicable rdf:type rdf:Property ;
    rdfs:label 'Detention Applicable' ;
    rdfs:comment 'Indicates whether detention charges apply to equipment (containers, chassis) used for cargo in this category when held beyond free time.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dwellTimeStandardDays rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Standard Days' ;
    rdfs:comment 'Standard or average dwell time in days for cargo in this category from gate-in to gate-out. Used for yard capacity planning and demurrage calculation baselines.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Environmental Risk Level' ;
    rdfs:comment 'Environmental risk classification for this cargo category based on potential for pollution, spillage, emissions, or ecological impact (low, medium, high, critical).' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingMethod rdf:type rdf:Property ;
    rdfs:label 'Handling Method' ;
    rdfs:comment 'Primary method used to load and discharge this cargo category: LoLo (Lift-on Lift-off via crane), RoRo (Roll-on Roll-off), bulk loader, conveyor, pipeline, or manual handling. [ENUM-REF-CANDIDATE: lolo|roro|bulk_loader|crane|conveyor|pipeline|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgApplicable rdf:type rdf:Property ;
    rdfs:label 'Imdg Applicable' ;
    rdfs:comment 'Indicates whether this cargo category is subject to IMDG Code regulations for dangerous goods transport and handling.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermodalCompatible rdf:type rdf:Property ;
    rdfs:label 'Intermodal Compatible' ;
    rdfs:comment 'Indicates whether cargo in this category can be transferred to intermodal transport modes (rail, barge, truck) without repackaging or special handling.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oogCapable rdf:type rdf:Property ;
    rdfs:label 'Oog Capable' ;
    rdfs:comment 'Indicates whether this cargo category accommodates out-of-gauge (oversized) cargo that exceeds standard container or cargo dimensions.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quarantine Inspection Required' ;
    rdfs:comment 'Indicates whether cargo in this category requires quarantine or biosecurity inspection (e.g., agricultural products, live animals, timber).' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialHandlingRequired rdf:type rdf:Property ;
    rdfs:label 'Special Handling Required' ;
    rdfs:comment 'Indicates whether this cargo category requires special handling procedures, certifications, or equipment beyond standard operations (e.g., dangerous goods, reefer monitoring, oversized cargo).' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Handling Requirements' ;
    rdfs:comment 'Detailed description of special handling requirements for this cargo category, including certifications, temperature control, segregation rules, security protocols, or dimensional constraints.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageAreaType rdf:type rdf:Property ;
    rdfs:label 'Storage Area Type' ;
    rdfs:comment 'Type of storage or staging area required for this cargo category: CY (Container Yard), CFS (Container Freight Station), bulk shed, liquid berth, open yard, covered warehouse, reefer yard, or dangerous goods depot. [ENUM-REF-CANDIDATE: container_yard|container_freight_station|bulk_shed|liquid_berth|open_yard|covered_warehouse|reefer_yard|dangerous_goods_depot — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stowagePriority rdf:type rdf:Property ;
    rdfs:label 'Stowage Priority' ;
    rdfs:comment 'Numeric priority ranking for stowage planning and yard allocation (1=highest priority). Influences container stacking order and berth planning decisions.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tariffGroupCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Group Code' ;
    rdfs:comment 'Code linking this cargo category to applicable tariff schedules and billing rate tables. Used by billing systems to determine terminal handling charges (THC) and wharfage rates.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teuConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Teu Conversion Factor' ;
    rdfs:comment 'Conversion factor to express cargo volume or capacity in TEU (Twenty-foot Equivalent Units). Standard containers: 20ft=1.0 TEU, 40ft=2.0 TEU. Used for capacity planning and billing.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unLocodeApplicable rdf:type rdf:Property ;
    rdfs:label 'Un Locode Applicable' ;
    rdfs:comment 'Indicates whether UN/LOCODE location references are required for cargo in this category for international trade documentation and EDI messaging.' ;
    rdfs:domain ind:CargoCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Commodity Code Status' ;
    rdfs:comment 'Current lifecycle status of the commodity code record: ACTIVE (in use), INACTIVE (not in use), DEPRECATED (superseded by newer code), PENDING_APPROVAL (awaiting data steward approval).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSteward rdf:type rdf:Property ;
    rdfs:label 'Data Steward' ;
    rdfs:comment 'Name or identifier of the data steward responsible for maintaining this commodity code record. Typically Trade Compliance team.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emsNumber rdf:type rdf:Property ;
    rdfs:label 'Ems Number' ;
    rdfs:comment 'IMDG Emergency Schedule number providing fire-fighting and spillage procedures for dangerous goods (format: F-X,S-Y). Null if not dangerous goods.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Excepted Quantity' ;
    rdfs:comment 'Indicates whether this commodity qualifies for excepted quantity exemptions under IMDG Code (True/False).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Export License Required' ;
    rdfs:comment 'Indicates whether an export license or permit is required for this commodity when leaving the port jurisdiction (True/False).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fumigationRequired rdf:type rdf:Property ;
    rdfs:label 'Fumigation Required' ;
    rdfs:comment 'Indicates whether this commodity requires fumigation treatment before or after discharge (True/False).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsChapter rdf:type rdf:Property ;
    rdfs:label 'Hs Chapter' ;
    rdfs:comment 'Two-digit chapter code representing the highest level of HS classification hierarchy (e.g., Chapter 01 = Live Animals).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsHeading rdf:type rdf:Property ;
    rdfs:label 'Hs Heading' ;
    rdfs:comment 'Four-digit heading code representing the second level of HS classification hierarchy within a chapter.' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsRevisionYear rdf:type rdf:Property ;
    rdfs:label 'Hs Revision Year' ;
    rdfs:comment 'Year of the HS nomenclature revision that this code belongs to (e.g., 2017, 2022). WCO updates HS codes approximately every 5 years.' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hsSubheading rdf:type rdf:Property ;
    rdfs:label 'Hs Subheading' ;
    rdfs:comment 'Six-digit subheading code representing the third level of HS classification hierarchy, providing detailed commodity classification.' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Import License Required' ;
    rdfs:comment 'Indicates whether an import license or permit is required for this commodity when entering the port jurisdiction (True/False).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitedQuantity rdf:type rdf:Property ;
    rdfs:label 'Limited Quantity' ;
    rdfs:comment 'Indicates whether this commodity qualifies for limited quantity exemptions under IMDG Code (True/False).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marinePollutant rdf:type rdf:Property ;
    rdfs:label 'Marine Pollutant' ;
    rdfs:comment 'Indicates whether this commodity is classified as a marine pollutant under MARPOL and IMDG Code (True/False).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marpolCategory rdf:type rdf:Property ;
    rdfs:label 'Marpol Category' ;
    rdfs:comment 'MARPOL annex category applicable to this commodity if it is a pollutant or hazardous substance: ANNEX_I (oil), ANNEX_II (noxious liquid substances), ANNEX_III (harmful substances in packaged form), ANNEX_IV (sewage), ANNEX_V (garbage), ANNEX_VI (air pollution), NOT_APPLICABLE (not a MARPOL-regulated substance). [ENUM-REF-CANDIDATE: ANNEX_I|ANNEX_II|ANNEX_III|ANNEX_IV|ANNEX_V|ANNEX_VI|NOT_APPLICABLE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Prohibited Goods Flag' ;
    rdfs:comment 'Indicates whether this commodity is prohibited from import or export through the port under current regulations (True/False).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineRequired rdf:type rdf:Property ;
    rdfs:label 'Quarantine Required' ;
    rdfs:comment 'Indicates whether this commodity requires quarantine inspection or clearance by biosecurity or agricultural authorities (True/False).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffRatePercent rdf:type rdf:Property ;
    rdfs:label 'Tariff Rate Percent' ;
    rdfs:comment 'Standard customs tariff rate (duty percentage) applicable to this commodity code for import into the port jurisdiction. Null if duty-free or variable.' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether this commodity requires temperature-controlled storage or transport (reefer cargo) (True/False).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum temperature in Celsius required for temperature-controlled commodities. Null if not temperature-controlled.' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum temperature in Celsius required for temperature-controlled commodities. Null if not temperature-controlled.' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wcoControlFlag rdf:type rdf:Property ;
    rdfs:label 'Wco Control Flag' ;
    rdfs:comment 'Indicates whether this commodity is subject to special WCO customs controls, trade restrictions, or enhanced inspection requirements (True/False).' ;
    rdfs:domain ind:CommodityCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerCategory rdf:type rdf:Property ;
    rdfs:label 'Container Category' ;
    rdfs:comment 'Primary functional category of the container: \'general-purpose\' (dry cargo), \'reefer\' (refrigerated), \'open-top\', \'flat-rack\', \'tank\', \'platform\', or \'special\' (non-standard). Determines handling requirements and yard allocation. [ENUM-REF-CANDIDATE: general-purpose|reefer|open-top|flat-rack|tank|platform|special — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeName rdf:type rdf:Property ;
    rdfs:label 'Container Type Name' ;
    rdfs:comment 'Human-readable descriptive name of the container type (e.g., \'20ft General Purpose\', \'40ft High Cube Reefer\', \'20ft Open Top\', \'40ft Flat Rack Collapsible\').' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doorConfiguration rdf:type rdf:Property ;
    rdfs:label 'Door Configuration' ;
    rdfs:comment 'Door access configuration: \'end-door\' (standard rear doors), \'side-door\' (side access), \'open-top\' (top loading), or \'no-door\' (platform/flat-rack). Determines loading/unloading procedures.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCategory rdf:type rdf:Property ;
    rdfs:label 'Height Category' ;
    rdfs:comment 'Height classification of the container: \'standard\' (8ft 6in), \'high-cube\' (9ft 6in), or \'super-high-cube\' (10ft or greater). Determines stacking and stowage constraints.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'External height of the container in millimeters. Standard containers are typically 2591mm, high-cube containers are 2896mm.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Internal Capacity Cbm' ;
    rdfs:comment 'Internal volume capacity of the container in cubic meters. Used for cargo volume planning and Less than Container Load (LCL) consolidation.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCollapsible rdf:type rdf:Property ;
    rdfs:label 'Is Collapsible' ;
    rdfs:comment 'Boolean flag indicating whether the container can be collapsed or folded for empty repositioning to save space. Common for flat-rack collapsible types.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Approved' ;
    rdfs:comment 'Boolean flag indicating whether this container type is approved for carrying hazardous materials under IMDG Code. True if IMDG-certified, False otherwise.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOogCapable rdf:type rdf:Property ;
    rdfs:label 'Is Oog Capable' ;
    rdfs:comment 'Boolean flag indicating whether this container type can accommodate out-of-gauge (oversized) cargo. True for open-top, flat-rack, and platform types; False for standard enclosed containers.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Iso Standard Version' ;
    rdfs:comment 'Version or revision year of the ISO 6346 standard under which this container type is classified (e.g., \'ISO 6346:1995\', \'ISO 6346:2022\'). Tracks standard evolution and compliance.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoTypeCode rdf:type rdf:Property ;
    rdfs:label 'Iso Type Code' ;
    rdfs:comment 'Four-character ISO 6346 container type code identifying the container category and characteristics (e.g., 22G1 for 20ft general purpose, 45R1 for 40ft high-cube reefer). This is the globally recognized standard identifier for container types.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthMm rdf:type rdf:Property ;
    rdfs:label 'Length Mm' ;
    rdfs:comment 'External length of the container in millimeters. 20ft containers are 6058mm, 40ft containers are 12192mm, 45ft containers are 13716mm.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reeferTempMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Reefer Temp Max Celsius' ;
    rdfs:comment 'Maximum operating temperature in Celsius for refrigerated containers. Typically ranges from +25°C to +30°C for chilled cargo. Null for non-reefer types.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reeferTempMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Reefer Temp Min Celsius' ;
    rdfs:comment 'Minimum operating temperature in Celsius for refrigerated containers. Typically ranges from -35°C to -25°C for frozen cargo. Null for non-reefer types.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeCode rdf:type rdf:Property ;
    rdfs:label 'Size Code' ;
    rdfs:comment 'Nominal length of the container in feet. Standard values are 20, 40, and 45 feet.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackingStrengthTier rdf:type rdf:Property ;
    rdfs:label 'Stacking Strength Tier' ;
    rdfs:comment 'Structural stacking tier rating indicating how many containers can be safely stacked on top of this type. Typically 1-9 for standard containers, lower for specialized types. Used for yard planning and vessel stowage.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tariffClassCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Class Code' ;
    rdfs:comment 'Tariff classification code used for billing and Terminal Handling Charge (THC) calculation. Links this container type to the port\'s tariff schedule for pricing.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationSetting rdf:type rdf:Property ;
    rdfs:label 'Ventilation Setting' ;
    rdfs:comment 'Ventilation capability of the container: \'none\' (sealed), \'passive\' (natural vents), \'active\' (forced air), or \'controlled-atmosphere\' (CA for perishables). Relevant for reefers and ventilated containers.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'External width of the container in millimeters. Standard ISO containers are 2438mm wide.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardBlockPreference rdf:type rdf:Property ;
    rdfs:label 'Yard Block Preference' ;
    rdfs:comment 'Preferred yard block or zone designation for storing this container type (e.g., \'REEFER-01\' for reefers near power outlets, \'HAZMAT-A\' for dangerous goods, \'GENERAL-B\' for standard dry containers). Guides automated yard planning.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callingCode rdf:type rdf:Property ;
    rdfs:label 'Calling Code' ;
    rdfs:comment 'International dialing prefix for the country (e.g., +1, +44, +86). Used for contact information validation and telecommunications routing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatfStatus rdf:type rdf:Property ;
    rdfs:label 'Fatf Status' ;
    rdfs:comment 'Status of the country with respect to Financial Action Task Force (FATF) anti-money laundering and counter-terrorism financing standards. Values: compliant (meets FATF standards), monitored (under increased monitoring), high_risk (identified as high-risk jurisdiction), not_assessed (not yet assessed). Impacts customer due diligence and financial transaction screening.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagStateAuthorityContact rdf:type rdf:Property ;
    rdfs:label 'Flag State Authority Contact' ;
    rdfs:comment 'Primary contact information (email, phone, or address) for the flag state maritime authority. Used for regulatory inquiries, vessel certification verification, and compliance coordination.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagStateAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Flag State Authority Name' ;
    rdfs:comment 'Name of the national maritime authority or flag state administration responsible for vessel registration, certification, and flag state oversight. Used for regulatory correspondence and compliance verification.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagStateIndicator rdf:type rdf:Property ;
    rdfs:label 'Flag State Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this country is recognized as a vessel flag state. True if the country registers vessels under its flag; false otherwise. Critical for vessel registration validation and Port State Control (PSC) inspections.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flagStatePerformanceList rdf:type rdf:Property ;
    rdfs:label 'Flag State Performance List' ;
    rdfs:comment 'Classification of the flag state based on Port State Control (PSC) performance metrics. Values: white (high-performing, low deficiency rate), grey (medium-performing, moderate deficiency rate), black (low-performing, high deficiency rate). Directly impacts vessel inspection frequency and detention risk.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoMemberStatus rdf:type rdf:Property ;
    rdfs:label 'Imo Member Status' ;
    rdfs:comment 'Membership status of the country in the International Maritime Organization (IMO). Values: member (full member state), associate_member (associate member), non_member (not a member). Affects applicability of IMO conventions and compliance requirements.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indianOceanMouMember rdf:type rdf:Property ;
    rdfs:label 'Indian Ocean Mou Member' ;
    rdfs:comment 'Boolean flag indicating whether the country is a member of the Indian Ocean Memorandum of Understanding on Port State Control (Indian Ocean MOU). True if member; false otherwise. Determines PSC inspection regime applicability for vessels calling at ports in this country.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoAlpha2Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 2 Code' ;
    rdfs:comment 'Two-letter country code as defined by ISO 3166-1 alpha-2 standard. Used in customs declarations, cargo manifests, and vessel registration documentation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha3Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 3 Code' ;
    rdfs:comment 'Three-letter country code as defined by ISO 3166-1 alpha-3 standard. Commonly used in Bill of Lading (BOL), Electronic Data Interchange (EDI) messages, and Port Community System (PCS) integrations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoNumericCode rdf:type rdf:Property ;
    rdfs:label 'Iso Numeric Code' ;
    rdfs:comment 'Three-digit numeric country code as defined by ISO 3166-1 numeric standard. Used in international trade statistics and customs systems.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsCodeCompliant rdf:type rdf:Property ;
    rdfs:label 'Isps Code Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the country has implemented the International Ship and Port Facility Security (ISPS) Code. True if compliant; false otherwise. Critical for port security assessments and vessel clearance procedures.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marpolRatified rdf:type rdf:Property ;
    rdfs:label 'Marpol Ratified' ;
    rdfs:comment 'Boolean flag indicating whether the country has ratified the International Convention for the Prevention of Pollution from Ships (MARPOL). True if ratified; false otherwise. Determines applicability of environmental protection and emissions standards.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mlcRatified rdf:type rdf:Property ;
    rdfs:label 'Mlc Ratified' ;
    rdfs:comment 'Boolean flag indicating whether the country has ratified the Maritime Labour Convention (MLC) 2006. True if ratified; false otherwise. Determines applicability of seafarer labor rights and working conditions standards.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officialName rdf:type rdf:Property ;
    rdfs:label 'Official Name' ;
    rdfs:comment 'Full official name of the country or territory as recognized by the United Nations and International Maritime Organization (IMO). Used in formal legal documentation, customs declarations, and compliance reporting.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parisMouMember rdf:type rdf:Property ;
    rdfs:label 'Paris Mou Member' ;
    rdfs:comment 'Boolean flag indicating whether the country is a member of the Paris Memorandum of Understanding on Port State Control (Paris MOU). True if member; false otherwise. Determines PSC inspection regime applicability for vessels calling at ports in this country.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pscTargetingFactor rdf:type rdf:Property ;
    rdfs:label 'Psc Targeting Factor' ;
    rdfs:comment 'Numeric targeting factor used by Port State Control (PSC) authorities to prioritize vessel inspections based on flag state performance. Higher values indicate higher risk and increased inspection likelihood. Range typically 0.00 to 10.00.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the country record. Values: active (currently in use), inactive (temporarily disabled), deprecated (no longer valid, retained for historical reference). Used to control operational visibility and data quality.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broad geographic region classification (e.g., Africa, Americas, Asia, Europe, Oceania) as defined by the United Nations geoscheme. Used for regional trade analysis and cargo routing strategies.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Effective Date' ;
    rdfs:comment 'Date when current sanctions status became effective. Null if no sanctions are in place. Used for historical compliance tracking and audit trails.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Expiry Date' ;
    rdfs:comment 'Date when current sanctions are scheduled to expire or be reviewed. Null if sanctions are indefinite or no sanctions are in place. Used for forward-looking compliance planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsListFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions List Flag' ;
    rdfs:comment 'Boolean flag indicating whether the country is currently subject to international trade sanctions or embargoes (e.g., United Nations, United States OFAC, European Union). True if sanctioned; false otherwise. Critical for trade compliance screening and cargo booking restrictions.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solasRatified rdf:type rdf:Property ;
    rdfs:label 'Solas Ratified' ;
    rdfs:comment 'Boolean flag indicating whether the country has ratified the International Convention for the Safety of Life at Sea (SOLAS). True if ratified; false otherwise. Determines applicability of SOLAS safety requirements for vessels flagged or calling at ports in this country.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subRegion rdf:type rdf:Property ;
    rdfs:label 'Sub Region' ;
    rdfs:comment 'Sub-regional classification within the broader region (e.g., Eastern Asia, Western Europe, Southern Africa) as defined by the United Nations geoscheme. Supports granular trade flow analysis and vessel routing optimization.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokyoMouMember rdf:type rdf:Property ;
    rdfs:label 'Tokyo Mou Member' ;
    rdfs:comment 'Boolean flag indicating whether the country is a member of the Tokyo Memorandum of Understanding on Port State Control (Tokyo MOU). True if member; false otherwise. Determines PSC inspection regime applicability for vessels calling at ports in this country.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeAgreementCodes rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Codes' ;
    rdfs:comment 'Comma-separated list of trade agreement codes applicable to this country (e.g., USMCA, EU, ASEAN, CPTPP, RCEP). Used to determine preferential tariff rates, customs duty exemptions, and Terminal Handling Charge (THC) adjustments.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unLocodePrefix rdf:type rdf:Property ;
    rdfs:label 'Un Locode Prefix' ;
    rdfs:comment 'Two-letter country prefix used in UN/LOCODE location codes. Matches ISO 3166-1 alpha-2 code. Used to construct full UN/LOCODE identifiers for ports and inland terminals within this country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wcoMember rdf:type rdf:Property ;
    rdfs:label 'Wco Member' ;
    rdfs:comment 'Boolean flag indicating whether the country is a member of the World Customs Organization (WCO). True if member; false otherwise. Affects customs clearance procedures, Harmonized System (HS) Code usage, and trade facilitation standards.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgmentRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required' ;
    rdfs:comment 'Indicates whether functional acknowledgment messages (e.g., CONTRL, 997) are required for messages exchanged with this partner.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'The authentication mechanism used to secure EDI message exchange with this partner.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessContactEmail rdf:type rdf:Property ;
    rdfs:label 'Business Contact Email' ;
    rdfs:comment 'Email address of the business contact for commercial and operational coordination.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessContactName rdf:type rdf:Property ;
    rdfs:label 'Business Contact Name' ;
    rdfs:comment 'Name of the business relationship owner at the partner organization for commercial and operational matters.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionEndpoint rdf:type rdf:Property ;
    rdfs:label 'Connection Endpoint' ;
    rdfs:comment 'The technical endpoint URL or address for EDI message transmission. May be AS2 URL, SFTP host, or API gateway endpoint.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Status' ;
    rdfs:comment 'Current operational status of the EDI connection with this partner. Determines whether messages can be exchanged.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether message encryption is enabled for EDI transmissions with this partner.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInboundMessageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Inbound Message Timestamp' ;
    rdfs:comment 'Timestamp of the most recent EDI message received from this partner.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastOutboundMessageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Outbound Message Timestamp' ;
    rdfs:comment 'Timestamp of the most recent EDI message sent to this partner.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSuccessfulTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Successful Transmission Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful EDI message transmission (inbound or outbound) with this partner. Used for connection health monitoring.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageFormatVersion rdf:type rdf:Property ;
    rdfs:label 'Message Format Version' ;
    rdfs:comment 'The specific version of the EDI standard or message format used by this partner (e.g., EDIFACT D95B, X12 4010).' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Business identifier code assigned to the EDI trading partner. Used in message routing and partner identification across Port Community System (PCS) and Terminal Operating System (TOS).' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerShortName rdf:type rdf:Property ;
    rdfs:label 'Partner Short Name' ;
    rdfs:comment 'Abbreviated name or alias for the EDI partner used in operational displays and reports.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the EDI partner based on their role in the maritime logistics supply chain.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverIdentification rdf:type rdf:Property ;
    rdfs:label 'Receiver Identification' ;
    rdfs:comment 'The unique receiver identification code used in EDI message interchange headers for this partner.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverQualifier rdf:type rdf:Property ;
    rdfs:label 'Receiver Qualifier' ;
    rdfs:comment 'The qualifier code identifying the receiver ID type in EDI message headers.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaAvailabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Availability Percentage' ;
    rdfs:comment 'The contractual uptime availability percentage guaranteed for EDI connectivity with this partner (e.g., 99.50 for 99.5% uptime).' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedMessageTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Message Types' ;
    rdfs:comment 'Comma-separated list of EDI message types supported by this partner (e.g., COPARN, BAPLIE, IFTMIN, COARRI, CUSCAR, CUSRES, CODECO, IFTMBC). Defines the scope of electronic transactions enabled.' ;
    rdfs:domain ind:EdiPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Certification Interval Months' ;
    rdfs:comment 'Frequency of mandatory certification or statutory inspection for the equipment type expressed in months. Typical values: 12 months for lifting equipment SWL certificates, 24 months for pressure vessel inspections. Null if certification_required_flag is False.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether the equipment type requires periodic certification or inspection by a competent authority or third-party surveyor. True for lifting equipment requiring SWL certificates, pressure vessels, cranes subject to statutory inspection. False for equipment without regulatory certification requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collisionAvoidanceSystemFlag rdf:type rdf:Property ;
    rdfs:label 'Collision Avoidance System Flag' ;
    rdfs:comment 'Indicates whether the equipment type is equipped with collision avoidance or anti-collision systems. True for equipment with radar, lidar, proximity sensors, or automated braking systems to prevent collisions with other equipment, containers, or personnel. False for equipment without collision avoidance capability.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emissionStandard rdf:type rdf:Property ;
    rdfs:label 'Emission Standard' ;
    rdfs:comment 'Applicable emissions standard or tier classification for the equipment type. Examples: EPA Tier 3, EPA Tier 4 Final, Euro Stage V, IMO Tier II, IMO Tier III. Relevant for diesel-powered equipment and harbour tugs. Null for electric or manual equipment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentSubcategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Subcategory' ;
    rdfs:comment 'Detailed classification within the equipment category. Examples: STS (Ship-to-Shore crane), RTG (Rubber Tyred Gantry crane), ASC (Automated Stacking Crane), MHC (Mobile Harbour Crane), QC (Quay Crane), AGV (Automated Guided Vehicle), reach stacker, forklift, terminal tractor, straddle carrier, harbour tug.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeName rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Name' ;
    rdfs:comment 'Full descriptive name of the equipment type. Human-readable label used in operational displays, reports, and user interfaces.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Status' ;
    rdfs:comment 'Current lifecycle status of the equipment type master record. Values: active (currently in use and available for asset registration), inactive (temporarily suspended from use), obsolete (retired and no longer valid for new assets), pending_approval (awaiting data steward approval before activation).' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumptionLitresPerHour rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Litres Per Hour' ;
    rdfs:comment 'Average fuel consumption rate for diesel-powered equipment types expressed in litres per hour under normal operating conditions. Used for operational cost estimation, fuel budgeting, and Greenhouse Gas (GHG) emissions calculations. Null for electric, battery, or manual equipment.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsTrackingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled Flag' ;
    rdfs:comment 'Indicates whether the equipment type is equipped with GPS (Global Positioning System) tracking capability for real-time location monitoring. True for mobile equipment with GPS transponders used in yard management, dispatch optimization, and asset visibility. False for stationary equipment or equipment without GPS.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iotSensorEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Iot Sensor Enabled Flag' ;
    rdfs:comment 'Indicates whether the equipment type is equipped with IoT (Internet of Things) sensors for condition monitoring and predictive maintenance. True for equipment with sensors monitoring temperature, vibration, oil quality, load stress, or other operational parameters. False for equipment without IoT sensor integration.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liftHeightMetres rdf:type rdf:Property ;
    rdfs:label 'Lift Height Metres' ;
    rdfs:comment 'Maximum vertical lift height capability of the equipment type in metres. Relevant for cranes, reach stackers, and stacking equipment. Determines container stacking height and vessel reach capability. Null for equipment without lift capability.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Hours' ;
    rdfs:comment 'Standard preventive maintenance interval for the equipment type expressed in operating hours. Defines the frequency of scheduled maintenance activities based on OEM recommendations. Used by Maximo Asset Management for work order scheduling and maintenance planning.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceStandard rdf:type rdf:Property ;
    rdfs:label 'Maintenance Standard' ;
    rdfs:comment 'Applicable maintenance standard or framework governing the equipment type. Examples: OEM-specific maintenance program, ISO 55000 Asset Management, SOLAS inspection requirements, Port State Control (PSC) standards, manufacturer service bulletins. References the authoritative source for maintenance procedures and intervals.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelReference rdf:type rdf:Property ;
    rdfs:label 'Model Reference' ;
    rdfs:comment 'Manufacturer model number or designation for this equipment type. Links to OEM technical specifications, parts catalogs, and maintenance manuals.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movesPerHour rdf:type rdf:Property ;
    rdfs:label 'Moves Per Hour' ;
    rdfs:comment 'Standard productivity rate for the equipment type expressed as container moves per hour under normal operating conditions. Key Performance Indicator (KPI) for equipment performance benchmarking, berth planning, and Service Level Agreement (SLA) commitments. Relevant for cranes and container handling equipment. Null for non-handling equipment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalSpeedKmh rdf:type rdf:Property ;
    rdfs:label 'Operational Speed Kmh' ;
    rdfs:comment 'Maximum operational travel speed of mobile equipment in kilometres per hour. Used for cycle time calculations, yard planning, and safety zone definitions. Relevant for terminal tractors, straddle carriers, reach stackers, AGVs, and harbour tugs. Null for stationary equipment.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outreachMetres rdf:type rdf:Property ;
    rdfs:label 'Outreach Metres' ;
    rdfs:comment 'Maximum horizontal reach or outreach distance of the equipment type in metres. Critical specification for Ship-to-Shore (STS) cranes and Quay Cranes (QC) to determine vessel size compatibility and berth planning. Null for equipment without reach capability.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerConsumptionKw rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Kw' ;
    rdfs:comment 'Average electrical power consumption for electric-powered equipment types expressed in kilowatts (kW) under normal operating conditions. Used for energy cost estimation, electrical infrastructure planning, and carbon footprint calculations. Null for diesel or manual equipment.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerType rdf:type rdf:Property ;
    rdfs:label 'Power Type' ;
    rdfs:comment 'Primary power source or propulsion type for the equipment. Values: electric (grid-powered or e-RTG), diesel (internal combustion engine), hybrid (diesel-electric or dual-mode), battery (battery-electric or AGV), manual (non-powered equipment). Critical for environmental reporting (GHG emissions), energy management, and infrastructure planning (charging stations, fuel depots).' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spanMetres rdf:type rdf:Property ;
    rdfs:label 'Span Metres' ;
    rdfs:comment 'Rail span or track gauge distance for rail-mounted equipment types (RTG, ASC, rail-mounted gantry cranes) in metres. Defines the width of the equipment footprint and yard lane compatibility. Null for non-rail-mounted equipment.' ;
    rdfs:domain ind:EquipmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current operational status of the flag state in the port\'s master data system. Active indicates the flag state is recognized and vessels under this flag are accepted; inactive indicates the flag state is no longer recognized; suspended indicates temporary restrictions.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityContactEmail rdf:type rdf:Property ;
    rdfs:label 'Authority Contact Email' ;
    rdfs:comment 'Primary email address for contacting the flag state maritime authority for official correspondence and inquiries.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityContactPhone rdf:type rdf:Property ;
    rdfs:label 'Authority Contact Phone' ;
    rdfs:comment 'Primary telephone number for contacting the flag state maritime authority.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityName rdf:type rdf:Property ;
    rdfs:label 'Authority Name' ;
    rdfs:comment 'Name of the official maritime authority or administration responsible for vessel registration and flag state control in this country.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Authority Website Url' ;
    rdfs:comment 'Official website URL of the flag state maritime authority for accessing regulations, forms, and public information.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagOfConvenience rdf:type rdf:Property ;
    rdfs:label 'Flag Of Convenience' ;
    rdfs:comment 'Indicates whether the flag state is commonly recognized as a flag of convenience, where vessel registration requirements are less stringent and often used for tax or regulatory advantages.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flagStateCode rdf:type rdf:Property ;
    rdfs:label 'Flag State Code' ;
    rdfs:comment 'Two-letter ISO 3166-1 alpha-2 country code representing the flag state under which vessels are registered. This is the primary business identifier for the flag state.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagStateName rdf:type rdf:Property ;
    rdfs:label 'Flag State Name' ;
    rdfs:comment 'Full official name of the flag state country as recognized under international maritime law.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoMemberSinceDate rdf:type rdf:Property ;
    rdfs:label 'Imo Member Since Date' ;
    rdfs:comment 'Date when the flag state became a member of the International Maritime Organization (IMO). Null if not a member.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marpolRatificationDate rdf:type rdf:Property ;
    rdfs:label 'Marpol Ratification Date' ;
    rdfs:comment 'Date when the flag state ratified the MARPOL Convention. Null if not ratified.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mlcRatificationDate rdf:type rdf:Property ;
    rdfs:label 'Mlc Ratification Date' ;
    rdfs:comment 'Date when the flag state ratified the Maritime Labour Convention. Null if not ratified.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pscListClassification rdf:type rdf:Property ;
    rdfs:label 'Psc List Classification' ;
    rdfs:comment 'Classification of the flag state on Port State Control (PSC) performance lists. White list indicates high performance, grey list medium performance, black list poor performance, and not classified indicates no formal classification.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedOrganizationAuthorized rdf:type rdf:Property ;
    rdfs:label 'Recognized Organization Authorized' ;
    rdfs:comment 'Indicates whether the flag state authorizes Recognized Organizations (classification societies) to carry out statutory surveys and certification on its behalf.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registryType rdf:type rdf:Property ;
    rdfs:label 'Registry Type' ;
    rdfs:comment 'Classification of the flag state registry. National registries require vessel ownership by nationals; open registries (flags of convenience) allow foreign ownership; international registries are hybrid models.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solasRatificationDate rdf:type rdf:Property ;
    rdfs:label 'Solas Ratification Date' ;
    rdfs:comment 'Date when the flag state ratified the SOLAS Convention. Null if not ratified.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stcwRatificationDate rdf:type rdf:Property ;
    rdfs:label 'Stcw Ratification Date' ;
    rdfs:comment 'Date when the flag state ratified the STCW Convention. Null if not ratified.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stcwRatified rdf:type rdf:Property ;
    rdfs:label 'Stcw Ratified' ;
    rdfs:comment 'Indicates whether the flag state has ratified the International Convention on Standards of Training, Certification and Watchkeeping for Seafarers (STCW).' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRegisteredDwt rdf:type rdf:Property ;
    rdfs:label 'Total Registered Dwt' ;
    rdfs:comment 'Total Deadweight Tonnage (DWT) of all vessels registered under this flag state. Represents the total cargo-carrying capacity of the fleet.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRegisteredGrt rdf:type rdf:Property ;
    rdfs:label 'Total Registered Grt' ;
    rdfs:comment 'Total Gross Registered Tonnage (GRT) of all vessels registered under this flag state. Used for assessing the overall size and capacity of the flag state\'s fleet.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRegisteredVessels rdf:type rdf:Property ;
    rdfs:label 'Total Registered Vessels' ;
    rdfs:comment 'Total number of vessels currently registered under this flag state. This is a snapshot metric used for fleet size analysis and port planning.' ;
    rdfs:domain ind:FlagState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classNumber rdf:type rdf:Property ;
    rdfs:label 'Class Number' ;
    rdfs:comment 'Primary IMDG hazard class number (1 through 9), with optional decimal subdivision (e.g., 2.1, 2.2, 2.3 for gases; 6.1, 6.2 for toxic substances). Defines the principal hazard category per IMO IMDG Code.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'Subdivision or division within the IMDG class (e.g., 2.1 for flammable gases, 3 for flammable liquids, 6.1 for toxic substances). Provides finer hazard categorization within the primary class.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emsFireCode rdf:type rdf:Property ;
    rdfs:label 'Ems Fire Code' ;
    rdfs:comment 'EmS fire schedule code (e.g., F-A, F-B, F-C) specifying emergency response procedures for fire incidents involving this IMDG class. Referenced from the Emergency Response Procedures for Ships Carrying Dangerous Goods (EmS Guide).' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emsSpillageCode rdf:type rdf:Property ;
    rdfs:label 'Ems Spillage Code' ;
    rdfs:comment 'EmS spillage schedule code (e.g., S-A, S-B, S-C) specifying emergency response procedures for spillage or leakage incidents involving this IMDG class. Referenced from the Emergency Response Procedures for Ships Carrying Dangerous Goods (EmS Guide).' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptedQuantityCode rdf:type rdf:Property ;
    rdfs:label 'Excepted Quantity Code' ;
    rdfs:comment 'Excepted quantity code (E0, E1, E2, E3, E4, E5) defining the maximum quantity per inner packaging and per package for excepted quantity shipments. Excepted quantities are subject to minimal regulatory requirements.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardLabelType rdf:type rdf:Property ;
    rdfs:label 'Hazard Label Type' ;
    rdfs:comment 'Type or code of the hazard label required for containers and packages carrying goods of this IMDG class (e.g., \'Explosive 1.1\', \'Flammable Gas\', \'Toxic\'). Used for visual identification and compliance with labeling regulations.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgCodeAmendmentCycle rdf:type rdf:Property ;
    rdfs:label 'Imdg Code Amendment Cycle' ;
    rdfs:comment 'Amendment cycle or version of the IMDG Code under which this classification is defined (e.g., \'Amendment 40-20\', \'Amendment 41-22\'). The IMDG Code is updated biennially; this field tracks which amendment cycle applies to this record.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitedQuantityThreshold rdf:type rdf:Property ;
    rdfs:label 'Limited Quantity Threshold' ;
    rdfs:comment 'Maximum quantity per package or inner packaging that qualifies for limited quantity (LQ) exemptions under the IMDG Code. Expressed as a volume or mass (e.g., \'1L\', \'5kg\'). Limited quantities are subject to reduced regulatory requirements.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marpolAnnexReference rdf:type rdf:Property ;
    rdfs:label 'Marpol Annex Reference' ;
    rdfs:comment 'Reference to the applicable MARPOL annex for pollution prevention related to this IMDG class (e.g., \'Annex I - Oil\', \'Annex II - Noxious Liquid Substances\', \'Annex III - Harmful Substances in Packaged Form\'). Used for environmental compliance and spill response planning.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Segregation Group Code' ;
    rdfs:comment 'Segregation group code assigned to this IMDG class for stowage and segregation purposes (e.g., acids, alkalis, ammonium compounds). Used to determine compatibility and separation requirements in vessel stowage planning and yard block allocation.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationTableReference rdf:type rdf:Property ;
    rdfs:label 'Segregation Table Reference' ;
    rdfs:comment 'Reference to the segregation table in the IMDG Code specifying separation requirements (e.g., \'away from\', \'separated from\', \'separated by a complete compartment or hold from\'). Defines minimum physical separation distances for safe stowage.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solasRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Solas Regulation Reference' ;
    rdfs:comment 'Reference to the applicable SOLAS Chapter VII regulation governing the carriage of this dangerous goods class by sea (e.g., \'SOLAS Ch.VII Part A\', \'SOLAS Ch.VII Part B\'). SOLAS Chapter VII addresses the carriage of dangerous goods in packaged form or in solid form in bulk.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Un Number Range End' ;
    rdfs:comment 'Ending UN number in the range typically associated with this IMDG class. Defines the upper bound of UN numbers commonly classified under this hazard class.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unNumberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Un Number Range Start' ;
    rdfs:comment 'Starting UN number in the range typically associated with this IMDG class. UN numbers are four-digit identifiers assigned to hazardous substances and articles by the United Nations Committee of Experts on the Transport of Dangerous Goods.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Effective start date for this IMDG classification record. Used to manage amendment transitions and ensure the correct classification rules are applied based on the cargo acceptance or vessel departure date.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'Effective end date for this IMDG classification record. Nullable for current/active classifications. Used to manage historical records when IMDG Code amendments supersede or modify classifications.' ;
    rdfs:domain ind:ImdgClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicableTransportModes rdf:type rdf:Property ;
    rdfs:label 'Applicable Transport Modes' ;
    rdfs:comment 'Transport modes for which this packaging type is approved (e.g., sea, road, rail, air, intermodal). Multiple modes may be comma-separated. Used for intermodal logistics coordination.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Required' ;
    rdfs:comment 'Indicates whether cargo in this packaging type requires specific customs declaration or documentation beyond standard manifest entries.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fumigationCompatible rdf:type rdf:Property ;
    rdfs:label 'Fumigation Compatible' ;
    rdfs:comment 'Indicates whether this packaging type can withstand fumigation treatment for quarantine and phytosanitary compliance without damage or contamination.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imdgPackingGroup rdf:type rdf:Property ;
    rdfs:label 'Imdg Packing Group' ;
    rdfs:comment 'IMDG packing group compatibility indicating the degree of danger: I (high danger), II (medium danger), III (low danger), or not applicable for non-dangerous goods packaging.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marpolCompliant rdf:type rdf:Property ;
    rdfs:label 'Marpol Compliant' ;
    rdfs:comment 'Indicates whether this packaging type meets MARPOL requirements for prevention of marine pollution, particularly relevant for hazardous substance packaging.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Primary material composition of the packaging (e.g., steel, aluminium, wood, fibreboard, plastic, textile, composite). Critical for IMDG compliance and handling requirements. [ENUM-REF-CANDIDATE: steel|aluminium|wood|plywood|fibreboard|plastic|textile|paper|composite|glass|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCapacityLiters rdf:type rdf:Property ;
    rdfs:label 'Maximum Capacity Liters' ;
    rdfs:comment 'Maximum volumetric capacity of the packaging in liters. Used for liquid and bulk cargo capacity planning and compliance verification.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Gross Weight Kg' ;
    rdfs:comment 'Maximum allowable gross weight (packaging plus contents) in kilograms. Critical for Safe Working Load (SWL) compliance and handling equipment selection.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingCategory rdf:type rdf:Property ;
    rdfs:label 'Packaging Category' ;
    rdfs:comment 'High-level classification of the packaging type for operational grouping and handling instructions. [ENUM-REF-CANDIDATE: drum|box|bag|crate|ibc|cylinder|jerrycan|pallet|composite|bulk|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingName rdf:type rdf:Property ;
    rdfs:label 'Packaging Name' ;
    rdfs:comment 'Full descriptive name of the packaging type (e.g., Steel Drum, Fibreboard Box, Intermediate Bulk Container, Wooden Crate, Plastic Jerrycan, Gas Cylinder, Pallet).' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferCompatible rdf:type rdf:Property ;
    rdfs:label 'Reefer Compatible' ;
    rdfs:comment 'Indicates whether this packaging type is suitable for use in refrigerated containers for temperature-controlled cargo.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryUpdateCycle rdf:type rdf:Property ;
    rdfs:label 'Regulatory Update Cycle' ;
    rdfs:comment 'Frequency and schedule of regulatory updates for this packaging type (e.g., biennial UN update, annual IMDG amendment). Used for compliance calendar management.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solasVgmApplicable rdf:type rdf:Property ;
    rdfs:label 'Solas Vgm Applicable' ;
    rdfs:comment 'Indicates whether SOLAS VGM verification requirements apply to cargo shipped in this packaging type. Mandatory for containerized cargo under SOLAS Convention.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackable rdf:type rdf:Property ;
    rdfs:label 'Stackable' ;
    rdfs:comment 'Indicates whether this packaging type can be safely stacked during storage and transport. Critical for yard management and Container Freight Station (CFS) operations.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Classification Code' ;
    rdfs:comment 'Internal tariff code used for billing and Terminal Handling Charge (THC) calculation. Links packaging type to applicable port tariff schedules.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unPackagingCode rdf:type rdf:Property ;
    rdfs:label 'Un Packaging Code' ;
    rdfs:comment 'Standard UN packaging code as defined by UN Recommendation 21 for dangerous goods transport. Two to four character alphanumeric code identifying the packaging type (e.g., 1A for steel drum, 4G for fibreboard box).' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unRecommendationVersion rdf:type rdf:Property ;
    rdfs:label 'Un Recommendation Version' ;
    rdfs:comment 'Version of UN Recommendation 21 or UN Model Regulations this packaging type is classified under. Updated biennially to reflect regulatory changes.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unTestCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Un Test Certificate Required' ;
    rdfs:comment 'Indicates whether this packaging type requires UN performance testing and certification for dangerous goods transport under IMDG regulations.' ;
    rdfs:domain ind:PackagingType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unLocodeId rdf:type rdf:Property ;
    rdfs:label 'Un Locode Id' ;
    rdfs:comment 'Foreign key linking to masterdata.un_locode. Business justification: Port locations reference UN/LOCODE global location codes for international trade and EDI messaging. Currently stores un_locode as STRING; normalizing to FK allows joining to un_locode for full locatio' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnLocode .

ind:bollardSpacingMeters rdf:type rdf:Property ;
    rdfs:label 'Bollard Spacing Meters' ;
    rdfs:comment 'Distance in meters between mooring bollards along the berth or quay. Critical for vessel mooring planning and safe berthing operations. Applicable to berth and quay locations.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerYardCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Container Yard Capacity Teu' ;
    rdfs:comment 'Total container storage capacity of the yard location measured in Twenty-foot Equivalent Units (TEU). Applicable to Container Yard (CY) and container stacking locations.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:craneType rdf:type rdf:Property ;
    rdfs:label 'Crane Type' ;
    rdfs:comment 'Type of cargo handling crane equipment serving this location. STS = Ship-to-Shore, QC = Quay Crane, MHC = Mobile Harbour Crane, RTG = Rubber Tyred Gantry, ASC = Automated Stacking Crane. \'none\' if no crane coverage.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsZoneCode rdf:type rdf:Property ;
    rdfs:label 'Customs Zone Code' ;
    rdfs:comment 'Customs authority zone code applicable to this location. Defines the customs jurisdiction and regulatory requirements for cargo handling. Used for customs clearance and trade compliance.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fenderType rdf:type rdf:Property ;
    rdfs:label 'Fender Type' ;
    rdfs:comment 'Type of fender system installed at the berth or quay for vessel impact absorption. Applicable to berth and quay locations. \'none\' if no fender system present. [ENUM-REF-CANDIDATE: pneumatic|foam_filled|cylindrical|cone|cell|arch|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateLaneType rdf:type rdf:Property ;
    rdfs:label 'Gate Lane Type' ;
    rdfs:comment 'Operational direction and function of the gate lane. Defines whether the lane handles inbound traffic, outbound traffic, bidirectional flow, or inspection/customs processing. Applicable to gate lane locations.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdLinkageCode rdf:type rdf:Property ;
    rdfs:label 'Icd Linkage Code' ;
    rdfs:comment 'Reference code linking this port location to an associated Inland Container Depot (ICD) for intermodal container transfer. Applicable to ICD linkage point locations. Nullable for locations without ICD connectivity.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationArea rdf:type rdf:Property ;
    rdfs:label 'Location Area' ;
    rdfs:comment 'Mid-level area classification within a zone (e.g., \'Berth Complex A\', \'Yard Section 3\', \'Anchorage Inner\'). Second level of the zone > area > point hierarchy.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationPoint rdf:type rdf:Property ;
    rdfs:label 'Location Point' ;
    rdfs:comment 'Specific point identifier within an area (e.g., \'Bollard 12A\', \'Stack Row 5\', \'Gate Lane 3\'). Lowest level of the zone > area > point hierarchy.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the location type within the port infrastructure hierarchy. Defines the operational function and handling capabilities of the location. [ENUM-REF-CANDIDATE: berth|quay|anchorage|pilot_boarding_ground|container_yard|cfs_shed|gate_lane|rail_siding|bunkering_point|icd_linkage|warehouse|maintenance_area — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationZone rdf:type rdf:Property ;
    rdfs:label 'Location Zone' ;
    rdfs:comment 'High-level zone classification within the port (e.g., \'North Terminal\', \'South Basin\', \'Container Terminal 1\'). Top level of the zone > area > point hierarchy.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumVesselDwtTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Vessel Dwt Tonnes' ;
    rdfs:comment 'Maximum permissible vessel Deadweight Tonnage (DWT) in metric tonnes that can be accommodated at this location. Constraint based on water depth, berth structural capacity, and mooring equipment Safe Working Load (SWL).' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:railSidingCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Rail Siding Capacity Teu' ;
    rdfs:comment 'Container handling capacity of the rail siding measured in Twenty-foot Equivalent Units (TEU). Defines the maximum number of containers that can be loaded/unloaded per rail operation. Applicable to rail siding locations.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this location is equipped with Radio Frequency Identification (RFID) technology for automated container and vehicle tracking. True if RFID-enabled, False otherwise.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shoreCraneCoverage rdf:type rdf:Property ;
    rdfs:label 'Shore Crane Coverage' ;
    rdfs:comment 'Boolean flag indicating whether this location is covered by shore-based cargo handling cranes (Ship-to-Shore (STS), Quay Crane (QC), or Mobile Harbour Crane (MHC)). True if crane coverage exists, False otherwise.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterDepthMeters rdf:type rdf:Property ;
    rdfs:label 'Water Depth Meters' ;
    rdfs:comment 'Water depth at the location measured in meters below Chart Datum (CD). Critical for determining vessel draft limitations and safe navigation. Applicable to berths, anchorages, and waterside locations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardBlockBays rdf:type rdf:Property ;
    rdfs:label 'Yard Block Bays' ;
    rdfs:comment 'Number of container stacking bays in the yard block. Defines the longitudinal layout dimension of the container yard. Applicable to Container Yard (CY) locations.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardBlockRows rdf:type rdf:Property ;
    rdfs:label 'Yard Block Rows' ;
    rdfs:comment 'Number of container stacking rows in the yard block. Defines the horizontal layout dimension of the container yard. Applicable to Container Yard (CY) locations.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardBlockTiers rdf:type rdf:Property ;
    rdfs:label 'Yard Block Tiers' ;
    rdfs:comment 'Maximum number of container stacking tiers (vertical height) in the yard block. Defines the vertical stacking capacity. Applicable to Container Yard (CY) locations.' ;
    rdfs:domain ind:PortLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentServiceCodeId rdf:type rdf:Property ;
    rdfs:label 'Parent Service Code Id' ;
    rdfs:comment 'Foreign key reference to a parent service code if this service is a component of a bundled service. Null for standalone services.' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCode .

ind:costGlAccount rdf:type rdf:Property ;
    rdfs:label 'Cost Gl Account' ;
    rdfs:comment 'General Ledger account code in SAP Controlling (CO) to which costs associated with delivering this service are posted.' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Discount Eligible Flag' ;
    rdfs:comment 'Indicates whether this service is eligible for volume discounts, customer-specific discounts, or promotional pricing.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediServiceCode rdf:type rdf:Property ;
    rdfs:label 'Edi Service Code' ;
    rdfs:comment 'Service code used in Electronic Data Interchange (EDI) messages (e.g., IFTMIN, COPARN) exchanged with shipping lines, freight forwarders, and Port Community System (PCS) partners.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBundledService rdf:type rdf:Property ;
    rdfs:label 'Is Bundled Service' ;
    rdfs:comment 'Indicates whether this service code represents a bundle of multiple underlying services sold as a package (e.g., full terminal handling package including discharge, storage, and gate-out).' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting any regulatory compliance requirements, International Maritime Organization (IMO) regulations, International Ship and Port Facility Security (ISPS) requirements, or environmental regulations applicable to this service.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueGlAccount rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account' ;
    rdfs:comment 'General Ledger account code in SAP FI to which revenue from this service is posted. Maps service billing to financial accounting.' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Sap Material Code' ;
    rdfs:comment 'SAP Materials Management (MM) material master code corresponding to this service, if the service is treated as a sellable material in SAP. Null if service is billed directly without material master.' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Flag' ;
    rdfs:comment 'Indicates whether this service is governed by a Service Level Agreement with defined performance targets and penalties.' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Service Owner Department' ;
    rdfs:comment 'Business department or division responsible for delivering this service and maintaining the service code definition.' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardRate rdf:type rdf:Property ;
    rdfs:label 'Standard Rate' ;
    rdfs:comment 'Standard published rate for this service in the base currency. Actual billing may vary based on customer agreements, volume discounts, or surcharges.' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surchargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Surcharge Applicable Flag' ;
    rdfs:comment 'Indicates whether surcharges (e.g., Bunker Adjustment Factor (BAF), Currency Adjustment Factor (CAF), peak season surcharge) may be applied to this service.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Tariff Schedule Reference' ;
    rdfs:comment 'Reference to the owning tariff schedule document or version under which this service code is published. Used for tariff revision cycle tracking.' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tosBillingTrigger rdf:type rdf:Property ;
    rdfs:label 'Tos Billing Trigger' ;
    rdfs:comment 'Event or transaction type in NAVIS N4 or TOPS that triggers automatic generation of a billing line item for this service (e.g., container gate-in, vessel berthing, crane move completion).' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'Unit of measure applicable to this service. TEU = Twenty-foot Equivalent Unit, FEU = Forty-foot Equivalent Unit, GT = Gross Tonnage, CBM = Cubic Meter. [ENUM-REF-CANDIDATE: TEU|FEU|move|hour|day|GT|vessel_call|CBM|ton|lift|container — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Api Integration Enabled Flag' ;
    rdfs:comment 'Indicates whether the carrier has active REST/SOAP API integration with the port\'s Terminal Operating System (TOS) for real-time data exchange beyond traditional EDI.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageTeuPerCall rdf:type rdf:Property ;
    rdfs:label 'Average Teu Per Call' ;
    rdfs:comment 'Rolling 12-month average container volume in TEU handled per vessel call for this carrier. Used for yard planning and equipment allocation.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageVesselCallsPerMonth rdf:type rdf:Property ;
    rdfs:label 'Average Vessel Calls Per Month' ;
    rdfs:comment 'Rolling 12-month average number of vessel calls made by this carrier at the port per month. Used for berth capacity planning and commercial forecasting.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bicOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Bic Operator Code' ;
    rdfs:comment 'Three-letter carrier prefix followed by \'U\' (for container owner) as defined in ISO 6346. Used to identify container ownership and operator in global container tracking systems.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierShortName rdf:type rdf:Property ;
    rdfs:label 'Carrier Short Name' ;
    rdfs:comment 'Abbreviated or trade name of the shipping line commonly used in operational communications, vessel schedules, and port documentation.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialAccountReference rdf:type rdf:Property ;
    rdfs:label 'Commercial Account Reference' ;
    rdfs:comment 'Internal account identifier linking this shipping line to the commercial billing and tariff management system. Used for invoice generation, credit management, and revenue tracking.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerReference rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Reference' ;
    rdfs:comment 'Identifier of the preferred customs broker or clearance agent used by the carrier for import/export documentation and customs clearance at this port.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Enabled Flag' ;
    rdfs:comment 'Indicates whether the carrier has active EDI integration with the port for automated message exchange. True: EDI active. False: manual/email-based communication.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fleetSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Fleet Size Category' ;
    rdfs:comment 'Classification of the carrier based on global fleet capacity measured in TEU. Mega Carrier: >1M TEU. Major Carrier: 500K-1M TEU. Regional Carrier: 100K-500K TEU. Niche Carrier: 10K-100K TEU. Feeder Operator: <10K TEU. Used for berth allocation priority and commercial negotiation.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the shipping line\'s global or regional headquarters is located.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Status' ;
    rdfs:comment 'Highest level of ISO certification held by the carrier. ISO 9001: Quality Management. ISO 14001: Environmental Management. ISO 28000: Supply Chain Security. Multiple: holds more than one certification. Used for vendor assessment and partnership evaluation.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredBerthWindowHours rdf:type rdf:Property ;
    rdfs:label 'Preferred Berth Window Hours' ;
    rdfs:comment 'Preferred advance notice window in hours between ETB (Estimated Time of Berthing) and vessel arrival that the carrier requests for berth allocation planning. Used by berth planning system to optimize scheduling.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reeferCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Reefer Capable Flag' ;
    rdfs:comment 'Indicates whether the carrier operates reefer-capable vessels and handles refrigerated cargo at this port. Impacts berth allocation to reefer-equipped berths.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Four-letter unique identifier assigned by the National Motor Freight Traffic Association (NMFTA) to identify ocean carriers in EDI transactions and shipping documentation. Required for all US-bound cargo per CBP regulations.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCommencementDate rdf:type rdf:Property ;
    rdfs:label 'Service Commencement Date' ;
    rdfs:comment 'Date when the shipping line first commenced vessel operations at this port facility.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Service Termination Date' ;
    rdfs:comment 'Date when the shipping line ceased or suspended vessel operations at this port. Null for active carriers.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFleetTeuCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Fleet Teu Capacity' ;
    rdfs:comment 'Total container capacity of the carrier\'s global fleet measured in TEU. Used for commercial assessment and berth planning.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vesselCount rdf:type rdf:Property ;
    rdfs:label 'Vessel Count' ;
    rdfs:comment 'Total number of vessels (owned and chartered) in the carrier\'s operating fleet. Includes container ships, RoRo vessels, and specialized cargo vessels.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vgmComplianceMethod rdf:type rdf:Property ;
    rdfs:label 'Vgm Compliance Method' ;
    rdfs:comment 'Preferred method for VGM verification per SOLAS Chapter VI Regulation 2. Method 1: weighing the packed container. Method 2: weighing all contents and adding tare weight. Both: carrier accepts either method. Required for all export containers since July 2016.' ;
    rdfs:domain ind:ShippingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinatePrecision rdf:type rdf:Property ;
    rdfs:label 'Coordinate Precision' ;
    rdfs:comment 'Indicator of the precision level of the latitude and longitude coordinates. Exact=surveyed or GPS-verified coordinates; Approximate=estimated from regional data; Unknown=coordinates not verified.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateAdded rdf:type rdf:Property ;
    rdfs:label 'Date Added' ;
    rdfs:comment 'Date when the location code was first added to the UN/LOCODE directory. Used for data lineage and historical tracking.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dateLastModified rdf:type rdf:Property ;
    rdfs:label 'Date Last Modified' ;
    rdfs:comment 'Date when the location code record was last updated in the UN/LOCODE directory. Reflects changes to location name, function codes, coordinates, or status.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:functionCode rdf:type rdf:Property ;
    rdfs:label 'Function Code' ;
    rdfs:comment 'Eight-character function classifier indicating the transport modes and facilities available at the location. Position 1: Port (1=yes); Position 2: Rail terminal (2=yes); Position 3: Road terminal (3=yes); Position 4: Airport (4=yes); Position 5: Postal exchange office (5=yes); Position 6: Inland Container Depot (ICD) or Container Freight Station (CFS) (6=yes); Position 7: Fixed transport functions (7=yes); Position 8: Border crossing (B=yes). Hyphen (-) indicates function not available.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment 'Three-letter IATA airport or city code if the location is an airport or has an associated IATA code. Used for air cargo routing and Air Waybill (AWB) documentation.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAirport rdf:type rdf:Property ;
    rdfs:label 'Is Airport' ;
    rdfs:comment 'Boolean flag indicating whether the location functions as an airport with cargo handling facilities. Derived from function_code position 4. Used for Air Waybill (AWB) routing and multimodal logistics.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBorderCrossing rdf:type rdf:Property ;
    rdfs:label 'Is Border Crossing' ;
    rdfs:comment 'Boolean flag indicating whether the location serves as an international border crossing point. Derived from function_code position 8. Used for customs declarations, trade compliance, and cross-border cargo tracking.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFixedTransportFunction rdf:type rdf:Property ;
    rdfs:label 'Is Fixed Transport Function' ;
    rdfs:comment 'Boolean flag indicating whether the location has fixed transport infrastructure functions (e.g., pipelines, cable transport). Derived from function_code position 7.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIaphMember rdf:type rdf:Property ;
    rdfs:label 'Is Iaph Member' ;
    rdfs:comment 'Boolean flag indicating whether the port is a member of the International Association of Ports and Harbors (IAPH). IAPH membership signals adherence to international port standards, best practices, and participation in global maritime policy development.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInlandContainerDepot rdf:type rdf:Property ;
    rdfs:label 'Is Inland Container Depot' ;
    rdfs:comment 'Boolean flag indicating whether the location operates as an Inland Container Depot (ICD) or Container Freight Station (CFS). Derived from function_code position 6. Critical for Full Container Load (FCL) and Less than Container Load (LCL) cargo routing and customs clearance.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPort rdf:type rdf:Property ;
    rdfs:label 'Is Port' ;
    rdfs:comment 'Boolean flag indicating whether the location functions as a seaport or maritime terminal. Derived from function_code position 1. Used for vessel traffic management, berth allocation, and marine services routing.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPostalExchange rdf:type rdf:Property ;
    rdfs:label 'Is Postal Exchange' ;
    rdfs:comment 'Boolean flag indicating whether the location serves as a postal exchange office. Derived from function_code position 5.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRailTerminal rdf:type rdf:Property ;
    rdfs:label 'Is Rail Terminal' ;
    rdfs:comment 'Boolean flag indicating whether the location has rail freight terminal facilities. Derived from function_code position 2. Used for intermodal transport coordination and rail operations planning.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRoadTerminal rdf:type rdf:Property ;
    rdfs:label 'Is Road Terminal' ;
    rdfs:comment 'Boolean flag indicating whether the location has road freight terminal facilities. Derived from function_code position 3. Used for truck gate operations and yard management.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationNameWithoutDiacritics rdf:type rdf:Property ;
    rdfs:label 'Location Name Without Diacritics' ;
    rdfs:comment 'ASCII-normalized version of the location name with diacritical marks removed for system compatibility and EDI messaging where special characters are not supported.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locode rdf:type rdf:Property ;
    rdfs:label 'Locode' ;
    rdfs:comment 'Five-character UN/LOCODE identifier consisting of two-letter ISO 3166-1 alpha-2 country code followed by three-character location code. This is the globally recognized standard identifier for ports, inland freight terminals, airports, and border crossings used in Bill of Lading (BOL), cargo manifests, customs declarations, and Electronic Data Interchange (EDI) messaging.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusCode rdf:type rdf:Property ;
    rdfs:label 'Status Code' ;
    rdfs:comment 'UN/LOCODE status indicator. AA=Approved by competent national government agency; AC=Approved by Customs Authority; AF=Approved by national facilitation body; AI=Code adopted by international organization (IATA or ECLAC); AM=Approved by the UN/LOCODE Maintenance Agency; AQ=Entry approved, functions not verified; AS=Approved by national standardization body; RL=Recognized location (not officially approved); RN=Request from credible national sources; RQ=Request under consideration; RR=Request rejected; UR=Entry included on user request; XX=Entry that will be removed in the next issue. [ENUM-REF-CANDIDATE: AA|AC|AF|AI|AM|AQ|AS|RL|RN|RQ|RR|UR|XX — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subdivisionCode rdf:type rdf:Property ;
    rdfs:label 'Subdivision Code' ;
    rdfs:comment 'ISO 3166-2 subdivision code identifying the state, province, or administrative region within the country. Used for regional trade statistics and domestic routing.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uneceUpdateCycle rdf:type rdf:Property ;
    rdfs:label 'Unece Update Cycle' ;
    rdfs:comment 'Identifier of the UNECE publication cycle in which this location code was added or last modified, formatted as YYYY-N where YYYY is the year and N is the half-year cycle (1 or 2). Used for version control and data stewardship.' ;
    rdfs:domain ind:UnLocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:builderName rdf:type rdf:Property ;
    rdfs:label 'Builder Name' ;
    rdfs:comment 'Name of the shipyard or shipbuilding company that constructed the vessel. Relevant for technical specifications and spare parts sourcing.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationSocietyCode rdf:type rdf:Property ;
    rdfs:label 'Classification Society Code' ;
    rdfs:comment 'Code identifying the classification society that certifies the vessel meets structural and mechanical standards (e.g., Lloyd\'s Register, DNV, ABS). Impacts insurance and port acceptance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineType rdf:type rdf:Property ;
    rdfs:label 'Engine Type' ;
    rdfs:comment 'Type and model of the vessel\'s main propulsion engine. Used for emissions tracking, fuel consumption estimation, and environmental compliance under MARPOL.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feuCapacity rdf:type rdf:Property ;
    rdfs:label 'Feu Capacity' ;
    rdfs:comment 'Maximum number of forty-foot equivalent containers the vessel can carry. Supplementary capacity metric for container vessel planning.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hullNumber rdf:type rdf:Property ;
    rdfs:label 'Hull Number' ;
    rdfs:comment 'Shipyard construction number assigned during vessel building. Used for tracking vessel lineage and construction specifications.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isscExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Issc Expiry Date' ;
    rdfs:comment 'Expiration date of the vessel\'s International Ship Security Certificate. Vessels with expired certificates may be denied port entry or subjected to enhanced Port State Control inspection.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lloydsListIntelligenceReference rdf:type rdf:Property ;
    rdfs:label 'Lloyds List Intelligence Reference' ;
    rdfs:comment 'Unique identifier assigned by Lloyd\'s List Intelligence maritime data service. Used for cross-referencing vessel data with external maritime intelligence feeds.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDraftMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Draft Meters' ;
    rdfs:comment 'Maximum vertical distance between the waterline and the bottom of the hull (keel). Determines minimum water depth requirements for safe berthing and navigation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmsi rdf:type rdf:Property ;
    rdfs:label 'Mmsi' ;
    rdfs:comment 'Nine-digit unique identifier used in the Automatic Identification System (AIS) and Digital Selective Calling (DSC) for vessel tracking and communication.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piClubCode rdf:type rdf:Property ;
    rdfs:label 'Pi Club Code' ;
    rdfs:comment 'Code identifying the Protection and Indemnity insurance club providing third-party liability coverage for the vessel. Required for port entry and cargo operations.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propulsionPowerKw rdf:type rdf:Property ;
    rdfs:label 'Propulsion Power Kw' ;
    rdfs:comment 'Maximum continuous rated power output of the main propulsion engine in kilowatts. Used for environmental reporting and vessel performance assessment.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registeredOwner rdf:type rdf:Property ;
    rdfs:label 'Registered Owner' ;
    rdfs:comment 'Legal entity name of the registered owner as recorded in the ship registry. May differ from commercial operator. Subject to change through ownership transfers tracked via effectivity dating.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solasCompliant rdf:type rdf:Property ;
    rdfs:label 'Solas Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the vessel meets SOLAS convention requirements for construction, equipment, and operation. Fundamental requirement for international maritime operations.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:summerDwt rdf:type rdf:Property ;
    rdfs:label 'Summer Dwt' ;
    rdfs:comment 'Maximum weight in metric tons that the vessel can safely carry (cargo, fuel, water, stores, crew) when loaded to the summer load line. Key metric for cargo capacity and port tariff calculation.' ;
    rdfs:domain ind:VesselMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:berthCompatibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Berth Compatibility Flag' ;
    rdfs:comment 'Indicates whether this vessel type has specific berth compatibility requirements that must be validated during berth allocation.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cargoHandlingMethod rdf:type rdf:Property ;
    rdfs:label 'Cargo Handling Method' ;
    rdfs:comment 'Primary cargo handling method associated with this vessel type: Lift-on Lift-off (LoLo), Roll-on Roll-off (RoRo), bulk discharge, liquid pumping, or mixed methods.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsCapable rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Capable' ;
    rdfs:comment 'Indicates whether vessels of this type are certified and equipped to carry dangerous goods as defined by IMDG Code.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalCategory rdf:type rdf:Property ;
    rdfs:label 'Environmental Category' ;
    rdfs:comment 'Environmental classification of vessel type based on typical emissions profile and environmental impact. Used for GHG reporting and environmental compliance.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoVesselTypeCode rdf:type rdf:Property ;
    rdfs:label 'Imo Vessel Type Code' ;
    rdfs:comment 'Two-digit IMO standard vessel type code as defined by the International Maritime Organization for global vessel classification.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileCraneCompatible rdf:type rdf:Property ;
    rdfs:label 'Mobile Crane Compatible' ;
    rdfs:comment 'Indicates whether vessels of this type are compatible with mobile harbour cranes (MHC) for cargo handling operations.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:navisVesselCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Navis Vessel Category Code' ;
    rdfs:comment 'NAVIS N4 Terminal Operating System vessel category code used for vessel planning, berth allocation, and operational scheduling.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresPilotage rdf:type rdf:Property ;
    rdfs:label 'Requires Pilotage' ;
    rdfs:comment 'Indicates whether vessels of this type typically require marine pilotage services for port entry and berthing operations.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresTowage rdf:type rdf:Property ;
    rdfs:label 'Requires Towage' ;
    rdfs:comment 'Indicates whether vessels of this type typically require towage (tug) services for berthing and unberthing operations.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solasChapterReference rdf:type rdf:Property ;
    rdfs:label 'Solas Chapter Reference' ;
    rdfs:comment 'Comma-separated list of applicable SOLAS chapter references for this vessel type (e.g., Chapter II-1, Chapter II-2, Chapter V).' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stsCraneCompatible rdf:type rdf:Property ;
    rdfs:label 'Sts Crane Compatible' ;
    rdfs:comment 'Indicates whether vessels of this type are compatible with ship-to-shore (STS) quay cranes for container handling operations.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Category Code' ;
    rdfs:comment 'Tariff category code used to determine applicable port charges, wharfage, and terminal handling charges (THC) for this vessel type.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalBeamMaxM rdf:type rdf:Property ;
    rdfs:label 'Typical Beam Max M' ;
    rdfs:comment 'Maximum typical beam (width) in meters for vessels of this type. Used for berth width compatibility assessment.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalBeamMinM rdf:type rdf:Property ;
    rdfs:label 'Typical Beam Min M' ;
    rdfs:comment 'Minimum typical beam (width) in meters for vessels of this type. Used for berth width compatibility assessment.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalDraftMaxM rdf:type rdf:Property ;
    rdfs:label 'Typical Draft Max M' ;
    rdfs:comment 'Maximum typical draft (depth below waterline) in meters for vessels of this type. Critical for channel and berth depth compatibility.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalDraftMinM rdf:type rdf:Property ;
    rdfs:label 'Typical Draft Min M' ;
    rdfs:comment 'Minimum typical draft (depth below waterline) in meters for vessels of this type. Critical for channel and berth depth compatibility.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalDwtMax rdf:type rdf:Property ;
    rdfs:label 'Typical Dwt Max' ;
    rdfs:comment 'Maximum typical deadweight tonnage (DWT) in metric tons for vessels of this type. Used for berth compatibility and tariff calculation.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalDwtMin rdf:type rdf:Property ;
    rdfs:label 'Typical Dwt Min' ;
    rdfs:comment 'Minimum typical deadweight tonnage (DWT) in metric tons for vessels of this type. Used for berth compatibility and tariff calculation.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalGrtMax rdf:type rdf:Property ;
    rdfs:label 'Typical Grt Max' ;
    rdfs:comment 'Maximum typical gross registered tonnage (GRT) for vessels of this type. Used for regulatory reporting and tariff calculations.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalGrtMin rdf:type rdf:Property ;
    rdfs:label 'Typical Grt Min' ;
    rdfs:comment 'Minimum typical gross registered tonnage (GRT) for vessels of this type. Used for regulatory reporting and tariff calculations.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalLoaMaxM rdf:type rdf:Property ;
    rdfs:label 'Typical Loa Max M' ;
    rdfs:comment 'Maximum typical length overall (LOA) in meters for vessels of this type. Critical for berth allocation and planning.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalLoaMinM rdf:type rdf:Property ;
    rdfs:label 'Typical Loa Min M' ;
    rdfs:comment 'Minimum typical length overall (LOA) in meters for vessels of this type. Critical for berth allocation and planning.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalTeuCapacityMax rdf:type rdf:Property ;
    rdfs:label 'Typical Teu Capacity Max' ;
    rdfs:comment 'Maximum typical container capacity in TEU for container vessel types. Null for non-container vessel types.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalTeuCapacityMin rdf:type rdf:Property ;
    rdfs:label 'Typical Teu Capacity Min' ;
    rdfs:comment 'Minimum typical container capacity in TEU for container vessel types. Null for non-container vessel types.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vesselCategory rdf:type rdf:Property ;
    rdfs:label 'Vessel Category' ;
    rdfs:comment 'High-level categorical grouping of vessel types for operational and analytical purposes. [ENUM-REF-CANDIDATE: container|bulk|tanker|roro|lolo|general_cargo|passenger|tug|barge|specialized — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselTypeCode rdf:type rdf:Property ;
    rdfs:label 'Vessel Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the vessel type classification. Used as business key across operational systems.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Vessel Type Description' ;
    rdfs:comment 'Detailed textual description of the vessel type classification, including operational characteristics, typical cargo types, and special handling requirements.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselTypeName rdf:type rdf:Property ;
    rdfs:label 'Vessel Type Name' ;
    rdfs:comment 'Full descriptive name of the vessel type classification (e.g., Container Ship, Bulk Carrier, Tanker, RoRo, LoLo, General Cargo, Passenger/Cruise, Tug, Barge).' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Vessel Type Status' ;
    rdfs:comment 'Current lifecycle status of the vessel type classification record. Active types are available for operational use; deprecated types are retained for historical reference only.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vtsTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Vts Tracking Required' ;
    rdfs:comment 'Indicates whether vessels of this type are required to be tracked by the Vessel Traffic Service (VTS) system during port operations.' ;
    rdfs:domain ind:VesselType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedVendorListId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Id' ;
    rdfs:comment 'Unique identifier for the approved vendor list entry. Primary key.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Unique business identifier for the vendor approval record, used for tracking and audit purposes.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'Classification of the approval indicating the scope and conditions under which the vendor is authorized to supply.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedServiceCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Service Categories' ;
    rdfs:comment 'Comma-separated list of service categories that the vendor is approved to provide (e.g., maintenance, engineering, consulting, logistics).' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date of the most recent on-site or documentation audit conducted to verify vendor capabilities and compliance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditOutcome rdf:type rdf:Property ;
    rdfs:label 'Audit Outcome' ;
    rdfs:comment 'Result of the most recent vendor audit indicating compliance with qualification requirements.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStabilityCheckDate rdf:type rdf:Property ;
    rdfs:label 'Financial Stability Check Date' ;
    rdfs:comment 'Date of the most recent financial stability assessment or credit check performed on the vendor.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hsseApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Hsse Approval Date' ;
    rdfs:comment 'Date on which the HSSE team granted approval for the vendor to operate within port facilities.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hsseApproved rdf:type rdf:Property ;
    rdfs:label 'Hsse Approved' ;
    rdfs:comment 'Indicates whether the vendor has been approved by the Health, Safety, Security, and Environment team for compliance with port safety and environmental standards.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imoCompliant rdf:type rdf:Property ;
    rdfs:label 'Imo Compliant' ;
    rdfs:comment 'Indicates whether the vendor complies with IMO regulations and standards for maritime operations.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceVerified rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified' ;
    rdfs:comment 'Indicates whether the vendor\'s insurance coverage (liability, workers compensation, professional indemnity) has been verified and meets port requirements.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoCertifications rdf:type rdf:Property ;
    rdfs:label 'Iso Certifications' ;
    rdfs:comment 'Comma-separated list of ISO certifications held by the vendor (e.g., ISO 9001, ISO 14001, ISO 45001, ISO 28000).' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Value' ;
    rdfs:comment 'Maximum monetary value allowed for a single purchase order to this vendor under the current approval.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Quantitative performance score or rating assigned to the vendor based on delivery, quality, compliance, and service metrics (typically 0-100 scale).' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendor rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor' ;
    rdfs:comment 'Indicates whether this vendor has preferred status for sourcing decisions based on performance, pricing, or strategic relationship.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationBasis rdf:type rdf:Property ;
    rdfs:label 'Qualification Basis' ;
    rdfs:comment 'The method or process by which the vendor was qualified and approved for the approved vendor list.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'Date on which a previously suspended vendor approval was reinstated after corrective actions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Number of months between periodic reviews of the vendor approval status and performance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyRestrictions rdf:type rdf:Property ;
    rdfs:label 'Supply Restrictions' ;
    rdfs:comment 'Description of any limitations or restrictions on the vendor\'s ability to supply (e.g., geographic restrictions, volume caps, specific terminals only).' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryAccessPointId rdf:type rdf:Property ;
    rdfs:label 'Entry Access Point Id' ;
    rdfs:comment 'Foreign key linking to security.access_point. Business justification: Goods receipts must record the specific port gate or access point where materials entered the facility for security screening verification, customs clearance documentation, and chain-of-custody compli' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessPoint .

ind:purchaseOrderItemId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Item Id' ;
    rdfs:comment 'Reference to the specific line item on the purchase order for which goods are being received.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrderItem .

ind:receiverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiver Employee Id' ;
    rdfs:comment 'Identifier of the employee who performed the goods receipt. Links to workforce management for accountability and audit trail.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Identifier of the specific storage location or warehouse within the plant where the received goods are stored.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'The batch or lot number assigned to the received materials for traceability and quality control purposes. Critical for spare parts and consumables management.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Number' ;
    rdfs:comment 'The certificate of origin document number, if applicable for the received goods. Required for certain international trade transactions.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The actual date on which the goods were physically delivered to the port facility by the vendor.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'The delivery note or packing slip number provided by the vendor with the shipment. Used for cross-referencing vendor documentation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt transaction. Tracks the document through its workflow from creation to completion or reversal.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'The quality inspection lot number created for the received goods, if quality inspection is required.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'Fiscal year in which the goods receipt material document was posted. Part of the compound key in SAP MM for document identification.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP MM movement type code indicating the nature of the goods receipt transaction. 101=GR for PO, 102=GR reversal, 103=GR into blocked stock, 105=GR from release order, 161=GR for returnable transport packaging, 501=GR without PO, 511=GR from delivery without PO. [ENUM-REF-CANDIDATE: 101|102|103|105|161|501|511 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity originally ordered on the purchase order line item. Used for variance analysis and three-way matching.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'Identifier of the port facility or plant where the goods were received. Represents the receiving location within the port infrastructure.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of quality inspection for the received goods. Determines whether materials can be released for operational use.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The quantity of materials or spare parts physically received and accepted. Principal quantitative fact for the goods receipt transaction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiverName rdf:type rdf:Property ;
    rdfs:label 'Receiver Name' ;
    rdfs:comment 'Name of the port employee or warehouse personnel who physically received and verified the goods.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'The type of stock into which the goods were received. Unrestricted=available for use, quality_inspection=pending QC approval, blocked=not available for use, restricted=limited use authorization.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way matching process comparing purchase order, goods receipt, and vendor invoice. Critical for invoice verification and payment authorization.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'The specific dock, gate, or unloading area within the port facility where the goods were received. Relevant for terminal operations and logistics tracking.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between ordered quantity and received quantity. Positive values indicate over-delivery, negative values indicate under-delivery.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Code indicating the reason for any quantity or quality variance between ordered and received goods. Used for supplier performance evaluation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentMaterialGroupId rdf:type rdf:Property ;
    rdfs:label 'Parent Material Group Id' ;
    rdfs:comment 'Reference to the parent material group in the hierarchical taxonomy. Supports multi-level classification (category group → category → sub-category). Null for top-level groups.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialGroup .

ind:annualSpendEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Estimate' ;
    rdfs:comment 'Estimated annual procurement spend for this material group in base currency. Used for budget planning, sourcing strategy prioritization, and spend analysis. Updated annually during budget cycles.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalWorkflow rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow' ;
    rdfs:comment 'Default approval workflow for Purchase Requisitions (PR) and Purchase Orders (PO) in this material group. Options include standard multi-level approval, expedited approval for critical spares, executive approval for high-value items, or technical review for specialized equipment.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Code' ;
    rdfs:comment 'Financial budget code or cost center allocation rule for spend in this material group. Links procurement spend to financial planning, budget tracking, and variance analysis in SAP Controlling (CO).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityType rdf:type rdf:Property ;
    rdfs:label 'Commodity Type' ;
    rdfs:comment 'High-level commodity classification for the material group. Port-specific categories include mechanical spare parts, electrical components, lubricants, marine chemicals, Personal Protective Equipment (PPE), Information Technology (IT) equipment, civil materials, fuel, professional services, and port security. Used for sourcing strategy definition and category management. [ENUM-REF-CANDIDATE: mechanical_spare_parts|electrical_components|lubricants|marine_chemicals|ppe|it_equipment|civil_materials|fuel|professional_services|port_security|consumables|office_supplies — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractManagementRequired rdf:type rdf:Property ;
    rdfs:label 'Contract Management Required' ;
    rdfs:comment 'Flag indicating whether materials in this group must be procured under formal contracts with suppliers. Triggers contract compliance checks, Service Level Agreement (SLA) monitoring, and supplier performance evaluation.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalSpareIndicator rdf:type rdf:Property ;
    rdfs:label 'Critical Spare Indicator' ;
    rdfs:comment 'Flag indicating whether materials in this group are classified as critical spare parts essential for port operations continuity. Drives safety stock levels, supplier performance requirements, and expedited procurement processes.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsCodePrefix rdf:type rdf:Property ;
    rdfs:label 'Hs Code Prefix' ;
    rdfs:comment 'Harmonized System (HS) Code prefix applicable to materials in this group for customs classification and international trade compliance. Used for import/export documentation, duty calculation, and trade statistics reporting.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localContentRequirement rdf:type rdf:Property ;
    rdfs:label 'Local Content Requirement' ;
    rdfs:comment 'Percentage of local content required for materials in this group to comply with government regulations, port authority mandates, or corporate social responsibility commitments. Used in supplier selection and bid evaluation.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialGroupCode rdf:type rdf:Property ;
    rdfs:label 'Material Group Code' ;
    rdfs:comment 'Alphanumeric code uniquely identifying the material group in SAP MM and procurement systems. Used as the business key for procurement classification and spend reporting.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupDescription rdf:type rdf:Property ;
    rdfs:label 'Material Group Description' ;
    rdfs:comment 'Detailed description of the material group scope, including examples of materials, spare parts, or services covered. Used for category management guidance and sourcing strategy documentation.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupName rdf:type rdf:Property ;
    rdfs:label 'Material Group Name' ;
    rdfs:comment 'Full descriptive name of the material group. Human-readable label used in procurement documents, purchase orders, and spend reports.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupStatus rdf:type rdf:Property ;
    rdfs:label 'Material Group Status' ;
    rdfs:comment 'Current lifecycle status of the material group. Active groups are used in procurement; inactive groups are retained for historical reporting; deprecated groups are being phased out; under-review groups are subject to category management evaluation.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Default minimum order quantity for materials in this group, typically driven by supplier terms or economic order quantity calculations. Used in procurement planning and Purchase Requisition (PR) consolidation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsolescenceRisk rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Risk' ;
    rdfs:comment 'Assessment of obsolescence risk for materials in this group due to technology changes, supplier discontinuation, or regulatory phase-outs. High-risk groups require proactive lifecycle management and alternative sourcing strategies.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierCount rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Count' ;
    rdfs:comment 'Target number of preferred suppliers for this material group to balance supply risk, negotiation leverage, and administrative efficiency. Used in supplier rationalization and category management strategies.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'Procurement classification indicating whether the material group represents direct materials (used in operations), indirect materials (supporting operations), services, or capital expenditure items. Drives procurement process routing and approval workflows.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'SAP MM purchasing group code identifying the buyer or procurement team responsible for this material group. Used for workload distribution, supplier negotiation, and Purchase Order (PO) approval routing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Default purchasing organization responsible for sourcing materials in this group. May represent a centralized procurement team or a port-specific purchasing unit. Used for buyer assignment and sourcing strategy execution.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Flag indicating whether materials in this group require mandatory quality inspection upon receipt. Triggers Quality Management (QM) workflows in SAP MM and ensures compliance with Safety of Life at Sea (SOLAS) and port safety standards.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendCategory rdf:type rdf:Property ;
    rdfs:label 'Spend Category' ;
    rdfs:comment 'Financial classification indicating whether spend in this material group is Operational Expenditure (OPEX), Capital Expenditure (CAPEX), or mixed. Used for budget allocation, financial planning, and spend reporting alignment.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendVisibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Spend Visibility Level' ;
    rdfs:comment 'Classification of spend visibility and data quality for this material group. High visibility indicates well-structured spend data suitable for advanced analytics; low visibility indicates fragmented or incomplete data requiring data cleansing.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicSourcingIndicator rdf:type rdf:Property ;
    rdfs:label 'Strategic Sourcing Indicator' ;
    rdfs:comment 'Flag indicating whether this material group is subject to strategic sourcing initiatives, including long-term contracts, preferred supplier programs, or category management strategies. Influences procurement planning and supplier relationship management.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierConsolidationTarget rdf:type rdf:Property ;
    rdfs:label 'Supplier Consolidation Target' ;
    rdfs:comment 'Flag indicating whether this material group is targeted for supplier base consolidation to reduce complexity, improve negotiation leverage, and achieve economies of scale. Used in category management and sourcing strategy planning.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Sustainability Criteria' ;
    rdfs:comment 'Environmental, social, and governance (ESG) sustainability criteria applicable to this material group, such as carbon footprint limits, ethical sourcing requirements, or circular economy principles. Used for supplier qualification and sustainable procurement initiatives.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'Default tax classification code for materials in this group, determining Value Added Tax (VAT), Goods and Services Tax (GST), or customs duty treatment. Used for automatic tax calculation in Purchase Orders (PO) and invoice verification.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'SAP MM valuation class code linking the material group to General Ledger (GL) account determination for inventory valuation and cost posting. Drives automatic account assignment in Materials Management (MM) and Financial Accounting (FI) integration.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'ABC classification for inventory management. A = high-value/critical items, B = moderate-value, C = low-value/high-volume items. Used for stock control prioritization.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Standard unit in which the material quantity is managed and stored (e.g., EA for each, KG for kilogram, L for liter, M for meter). ISO unit codes preferred.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Management Flag' ;
    rdfs:comment 'Indicates whether the material is managed in batches. Batch management tracks production lots, expiry dates, and quality characteristics.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the material master record was first created in the system.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether the material is marked for deletion. Marked materials cannot be used in new transactions but historical data is retained.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the material including packaging, measured in the weight unit specified.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the material master record was last updated or changed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeProcedure rdf:type rdf:Property ;
    rdfs:label 'Lot Size Procedure' ;
    rdfs:comment 'Rule for calculating procurement or production lot sizes (e.g., fixed lot size, lot-for-lot, economic order quantity).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Original part number assigned by the manufacturer. Used for cross-referencing, warranty claims, and supplier communication.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Short textual description of the material, spare part, or consumable. Used for identification and search purposes.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Grouping code used to categorize materials for procurement, reporting, and analytics. Aligns with port operational categories such as crane parts, electrical components, marine supplies.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialLongDescription rdf:type rdf:Property ;
    rdfs:label 'Material Long Description' ;
    rdfs:comment 'Extended textual description providing detailed specifications, usage instructions, or technical characteristics of the material.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material master record. Controls whether the material can be procured, issued, or used in operations.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Maximum inventory quantity that should be held to avoid overstocking and excess capital tied up in inventory.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Shelf Life Days' ;
    rdfs:comment 'Minimum remaining shelf life required at the time of goods receipt. Materials with shorter remaining shelf life are rejected.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Weighted average price recalculated with each goods receipt. Used for material valuation in moving average price costing.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'Code defining the MRP procedure used for the material (e.g., reorder point planning, forecast-based planning, no planning).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Weight of the material excluding packaging, measured in the weight unit specified.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'Quantity unit for which the price is specified (e.g., price per 1, per 10, per 100 units). Used to normalize pricing across different order quantities.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Indicates whether the material is procured externally from suppliers, produced/serviced internally, or both.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Flag' ;
    rdfs:comment 'Indicates whether incoming goods of this material must undergo quality inspection before being released for use.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyStockLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Level' ;
    rdfs:comment 'Minimum inventory quantity maintained as buffer stock to protect against demand variability and supply delays.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberProfile rdf:type rdf:Property ;
    rdfs:label 'Serial Number Profile' ;
    rdfs:comment 'Configuration code indicating whether and how serial numbers are managed for this material (e.g., mandatory at goods receipt, optional, not used).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Fixed price used for material valuation in standard costing. Remains constant until manually updated. Used for cost accounting and budgeting.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Special storage requirements for the material such as temperature control, humidity control, ventilation, or segregation from other materials.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Physical volume or cubic capacity of the material, measured in the volume unit specified. Used for storage space planning.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for volume (e.g., L for liter, M3 for cubic meter, CBM for cubic meter).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for weight (e.g., KG for kilogram, LB for pound, TON for metric ton).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalThresholdTier rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Tier' ;
    rdfs:comment 'Approval authority tier required for this procurement plan based on total value thresholds defined in governance policy.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Code' ;
    rdfs:comment 'Identifier of the approval workflow process assigned to this procurement plan based on value and risk classification.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Financial budget code or cost center against which this procurement plan is allocated and tracked.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Commitment Amount' ;
    rdfs:comment 'Amount of budget formally committed or reserved for execution of this procurement plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Capex Allocation Amount' ;
    rdfs:comment 'Portion of total planned spend allocated to capital expenditure projects (infrastructure, equipment, long-term assets).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveTenderRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Tender Required Flag' ;
    rdfs:comment 'Indicates whether competitive tendering process is mandated for procurements under this plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractManagementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Management Required Flag' ;
    rdfs:comment 'Indicates whether formal contract management and administration processes are required for procurements executed under this plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatProcurementFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Procurement Flag' ;
    rdfs:comment 'Indicates whether this procurement plan includes hazardous materials requiring special handling, storage, and compliance with IMDG and MARPOL regulations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justificationNotes rdf:type rdf:Property ;
    rdfs:label 'Justification Notes' ;
    rdfs:comment 'Business justification and rationale for the procurement plan, including alignment to strategic objectives, operational needs, and budget priorities.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localContentRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Local Content Requirement Percentage' ;
    rdfs:comment 'Minimum percentage of local content or local supplier participation required under this procurement plan, if applicable.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opexAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Opex Allocation Amount' ;
    rdfs:comment 'Portion of total planned spend allocated to operational expenditure (maintenance, consumables, services).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the period covered by this procurement plan.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this procurement plan.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed narrative description of the procurement plans scope, objectives, and strategic alignment with port operational and capital investment priorities.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or user ID of the procurement professional who prepared this procurement plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether quality inspection and acceptance testing are mandatory for goods and services procured under this plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Overall risk level assigned to this procurement plan based on value, complexity, supply market conditions, and strategic importance.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'Unique identifier or primary key of this procurement plan record in the source system.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy' ;
    rdfs:comment 'Primary sourcing approach defined for procurement activities under this plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierConsolidationTargetCount rdf:type rdf:Property ;
    rdfs:label 'Supplier Consolidation Target Count' ;
    rdfs:comment 'Target number of preferred suppliers to be engaged under this procurement plan as part of supplier base rationalization strategy.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityCriteriaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Criteria Required Flag' ;
    rdfs:comment 'Indicates whether environmental and sustainability criteria must be evaluated in vendor selection and procurement decisions under this plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tenderScheduleEndDate rdf:type rdf:Property ;
    rdfs:label 'Tender Schedule End Date' ;
    rdfs:comment 'Planned completion date for tender evaluation and award if competitive tendering is required.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tenderScheduleStartDate rdf:type rdf:Property ;
    rdfs:label 'Tender Schedule Start Date' ;
    rdfs:comment 'Planned start date for tender activities if competitive tendering is required.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalPlannedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Planned Spend Amount' ;
    rdfs:comment 'Total budgeted procurement spend amount for the plan period across all categories and line items.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPortLocationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Port Location Id' ;
    rdfs:comment 'Foreign key linking to masterdata.port_location. Business justification: Port-specific purchases (terminal services, stevedoring, pilotage) require delivery location reference to actual port infrastructure (berths, yards, gates) for service delivery coordination and access' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortLocation .

ind:deliverySecurityZoneId rdf:type rdf:Property ;
    rdfs:label 'Delivery Security Zone Id' ;
    rdfs:comment 'Foreign key linking to security.security_zone. Business justification: Purchase orders for security equipment or restricted materials delivered to specific security zones require zone tracking for access authorization, MARSEC-level compliance verification, installation p' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the procurement buyer or purchasing agent responsible for creating and managing this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledDate rdf:type rdf:Property ;
    rdfs:label 'Cancelled Date' ;
    rdfs:comment 'Date when the purchase order was cancelled. Applicable when PO is terminated before fulfillment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the purchase order was closed after full receipt and invoice processing. Marks the end of the PO lifecycle.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectiveNumber rdf:type rdf:Property ;
    rdfs:label 'Collective Number' ;
    rdfs:comment 'Collective or batch number grouping multiple purchase orders for consolidated processing or reporting. Used for bulk procurement activities.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number of the master contract or blanket purchase agreement under which this PO is issued. Links PO to long-term procurement agreements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Full delivery address where the materials or services are to be delivered. May include terminal, warehouse, or facility address.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO 3166 country code of the delivery destination (e.g., USA, SGP, GBR).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the delivery location. Used for logistics planning and freight calculation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether goods receipt is required for this purchase order. True if GR is mandatory for invoice processing (three-way match).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port specified in the Incoterms agreement where the transfer of risk and costs occurs (e.g., Port of Los Angeles, Singapore Port).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether invoice receipt is expected for this purchase order. True if invoice verification is required.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Net total value of the purchase order after applying all discounts, surcharges, and taxes. Final committed amount.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known unique purchase order number assigned by the procurement system. Business identifier for tracking and reference.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order indicating its workflow state (draft, pending approval, approved, issued, partially received, fully received, closed, cancelled). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|partially_received|fully_received|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type indicating the procurement arrangement (standard, blanket, contract, subcontracting, consignment, framework).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStrategy rdf:type rdf:Property ;
    rdfs:label 'Release Strategy' ;
    rdfs:comment 'Code identifying the approval release strategy applied to this purchase order. Defines the approval workflow and authorization levels required.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Reference number of the purchase requisition that originated this purchase order. Provides traceability to the procurement request.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the employee or department who requested the purchase. Originator of the procurement requirement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEntryRequired rdf:type rdf:Property ;
    rdfs:label 'Service Entry Required' ;
    rdfs:comment 'Flag indicating whether service entry sheet is required for this purchase order. Applicable for service procurement.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Method of transportation for delivering the ordered materials (sea freight, air freight, road transport, rail transport, courier, multimodal).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Total monetary value of the purchase order including all line items, before taxes and adjustments. Represents committed procurement spend.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the vendor contact person. Used for PO transmission and order-related communication.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the vendor organization for this purchase order. Facilitates communication and order management.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Phone number of the vendor contact person. Used for urgent order inquiries and coordination.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedSecurityEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Installed Security Equipment Id' ;
    rdfs:comment 'Foreign key linking to security.security_equipment. Business justification: Individual PO line items for security equipment procurement must link to the deployed equipment asset for warranty tracking, commissioning verification, spare parts management, and maintenance contrac' ;
    rdfs:domain ind:PurchaseOrderItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityEquipment .

ind:supplierContractItemId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Item Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_contract_item. Business justification: Line-level linkage between PO items and contract line items enables precise contract release tracking, utilization monitoring, and verification that PO pricing/terms match the contracted rates. This i' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContractItem .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'Type of financial account assignment for this procurement. Determines how costs are allocated in financial accounting and controlling.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationControlKey rdf:type rdf:Property ;
    rdfs:label 'Confirmation Control Key' ;
    rdfs:comment 'Code defining the type of supplier confirmation required. Controls whether order acknowledgment, shipping notification, or other confirmations are expected.' ;
    rdfs:domain ind:PurchaseOrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating this line item has been marked for deletion. When true, the item is cancelled and excluded from further processing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'General ledger account number for expense posting. Defines the financial account in the chart of accounts where this procurement cost is recorded.' ;
    rdfs:domain ind:PurchaseOrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'Cumulative quantity of goods received against this purchase order item. Tracks actual receipt progress for three-way matching.' ;
    rdfs:domain ind:PurchaseOrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Cumulative quantity invoiced by the supplier for this line item. Used for three-way matching and invoice verification.' ;
    rdfs:domain ind:PurchaseOrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Classification of the procurement item type. Determines procurement processing rules, inventory treatment, and account assignment behavior.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemNumber rdf:type rdf:Property ;
    rdfs:label 'Item Number' ;
    rdfs:comment 'Sequential line item number within the purchase order. Determines the ordering and position of this item in the PO document.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current delivery and receipt status of the line item. Tracks the fulfillment lifecycle from order placement through final receipt.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Price per unit of measure agreed with the supplier, excluding taxes and additional charges. Base price used for line item value calculation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'Remaining quantity yet to be delivered. Calculated as ordered_quantity minus goods_receipt_quantity.' ;
    rdfs:domain ind:PurchaseOrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'Acceptable percentage by which supplier may exceed ordered quantity. Defines upper limit for goods receipt without requiring PO amendment.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseRequisitionItem rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Item' ;
    rdfs:comment 'Line item number within the purchase requisition. Combined with purchase_requisition_number, provides full traceability to the original request.' ;
    rdfs:domain ind:PurchaseOrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseRequisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Number' ;
    rdfs:comment 'Reference to the originating purchase requisition document. Links the PO item back to the internal request that triggered procurement.' ;
    rdfs:domain ind:PurchaseOrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Brief description of the material or service being procured. Provides human-readable identification of the line item for procurement staff and approvers.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'Acceptable percentage by which supplier may deliver less than ordered quantity. Defines lower limit before item is considered short-shipped.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Material Number' ;
    rdfs:comment 'Supplier\'s own part number or catalog code for this material. Used for cross-referencing and supplier communication.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Identifier of the preferred or recommended supplier for sourcing this requisition. May be based on contract, past performance, or technical specification.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:primaryPurchaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Employee Id' ;
    rdfs:comment 'Identifier of the employee or user who created the purchase requisition. Used for audit trail and requisitioner contact.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Reference to an existing purchasing contract or outline agreement against which this requisition should be fulfilled.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the requisition line (quantity × estimated unit price). Used for budget control and approval thresholds.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated or budgeted unit price for the requisitioned item. Used for budget checking and cost estimation. Currency specified in currency_code.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedVendorIndicator rdf:type rdf:Property ;
    rdfs:label 'Fixed Vendor Indicator' ;
    rdfs:comment 'Flag indicating whether the preferred vendor is mandatory (true) or just a recommendation (false). When true, procurement must use the specified vendor.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account number to which the expenditure will be posted. Defines the expense or asset category in financial accounting.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'Controlling internal order number for tracking costs against specific operational activities or maintenance campaigns.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderItem rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Item' ;
    rdfs:comment 'Line item number within the purchase order that fulfills this requisition. Null until PO is created.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseIndicator rdf:type rdf:Property ;
    rdfs:label 'Release Indicator' ;
    rdfs:comment 'Flag indicating whether the requisition has been released for procurement processing after approval workflow completion.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the requisition in the procurement workflow. Tracks progression from draft through approval to purchase order creation. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|partially_ordered|fully_ordered|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition based on procurement purpose: standard purchase, stock replenishment, subcontracting, consignment, service procurement, or asset procurement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionerEmail rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Email' ;
    rdfs:comment 'Email address of the requisitioner for procurement communication and delivery coordination.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDeterminationIndicator rdf:type rdf:Property ;
    rdfs:label 'Source Determination Indicator' ;
    rdfs:comment 'Method by which the vendor source will be determined: automatic sourcing, manual buyer selection, contract release order, or purchasing info record.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Optional tracking or reference number for requisition monitoring and reporting. Used for grouping related requisitions or campaign tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseRequisitionItemId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Item Id' ;
    rdfs:comment 'Unique identifier for the purchase requisition item line. Primary key.' ;
    rdfs:domain ind:PurchaseRequisitionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractItem rdf:type rdf:Property ;
    rdfs:label 'Contract Item' ;
    rdfs:comment 'Line item number in the referenced contract. Links the requisition to specific contract terms.' ;
    rdfs:domain ind:PurchaseRequisitionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the valuation price. Supports multi-currency procurement for international suppliers.' ;
    rdfs:domain ind:PurchaseRequisitionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longText rdf:type rdf:Property ;
    rdfs:label 'Long Text' ;
    rdfs:comment 'Detailed description or specification of the material or service. May include technical specifications, quality requirements, or special instructions for procurement.' ;
    rdfs:domain ind:PurchaseRequisitionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plant rdf:type rdf:Property ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Port facility or terminal location where the material will be delivered. Represents the physical location within the port infrastructure.' ;
    rdfs:domain ind:PurchaseRequisitionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitioner rdf:type rdf:Property ;
    rdfs:label 'Requisitioner' ;
    rdfs:comment 'Employee or user ID of the person who created the requisition item. Used for approval routing and accountability.' ;
    rdfs:domain ind:PurchaseRequisitionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfSupply rdf:type rdf:Property ;
    rdfs:label 'Source Of Supply' ;
    rdfs:comment 'Identifier for the source of supply, which may be a vendor, contract, or scheduling agreement. Used for automated purchase order creation.' ;
    rdfs:domain ind:PurchaseRequisitionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total estimated value of the line item (quantity × valuation price). Used for requisition approval workflows and budget checking.' ;
    rdfs:domain ind:PurchaseRequisitionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationPrice rdf:type rdf:Property ;
    rdfs:label 'Valuation Price' ;
    rdfs:comment 'Estimated unit price for the material or service. Used for budget estimation and purchase order creation. May be based on historical pricing or catalog rates.' ;
    rdfs:domain ind:PurchaseRequisitionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Number' ;
    rdfs:comment 'Preferred or assigned supplier for this requisition item. May be pre-populated based on material master or sourcing agreements.' ;
    rdfs:domain ind:PurchaseRequisitionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingInfoId rdf:type rdf:Property ;
    rdfs:label 'Purchasing Info Id' ;
    rdfs:comment 'Unique identifier for the purchasing information record. Primary key for the purchasing_info product.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodsReceiptProcessingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Processing Time Days' ;
    rdfs:comment 'The number of days required to process goods receipt, including unloading, inspection, and put-away. Added to planned delivery time for total lead time calculation.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:infoRecordCategory rdf:type rdf:Property ;
    rdfs:label 'Info Record Category' ;
    rdfs:comment 'The category or type of purchasing information record indicating the procurement arrangement type.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Info Record Number' ;
    rdfs:comment 'The unique business identifier for the purchasing information record in the source system. Used for external reference and integration.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infoRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Info Record Status' ;
    rdfs:comment 'The current lifecycle status of the purchasing information record indicating whether it can be used for procurement activities.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Date' ;
    rdfs:comment 'The date when the last purchase order was created using this purchasing information record.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Number' ;
    rdfs:comment 'The most recent purchase order number created using this purchasing information record. Provides traceability to actual procurement transactions.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchasePrice rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Price' ;
    rdfs:comment 'The actual price paid in the most recent purchase order for this vendor-material combination. May differ from the info record net price due to negotiated discounts or surcharges.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'The maximum quantity that can be ordered in a single purchase order from this vendor for this material.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderQuantityMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Quantity Multiple' ;
    rdfs:comment 'The quantity increment in which the material must be ordered. For example, if set to 10, orders must be in multiples of 10 units.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Days' ;
    rdfs:comment 'The number of calendar days from purchase order placement to expected delivery at the plant. Used for material requirements planning and order scheduling.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Change Indicator' ;
    rdfs:comment 'Flag indicating whether the price has changed since the last update. Used to trigger price variance analysis and approval workflows.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceDate rdf:type rdf:Property ;
    rdfs:label 'Price Date' ;
    rdfs:comment 'The date on which the current net price was established or last updated. Used for price history tracking and analysis.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reminderDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Days' ;
    rdfs:comment 'The number of days before the expected delivery date when a reminder should be sent to the vendor to confirm shipment status.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Standard Order Quantity' ;
    rdfs:comment 'The standard or recommended order quantity for this material from this vendor. Used as a default in purchase requisition and order creation.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unlimitedOverDeliveryAllowed rdf:type rdf:Property ;
    rdfs:label 'Unlimited Over Delivery Allowed' ;
    rdfs:comment 'Flag indicating whether the vendor is allowed to deliver any quantity above the ordered amount without restriction.' ;
    rdfs:domain ind:PurchasingInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Unique identifier for the request for quotation record. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Identifier of the vendor selected through the RFQ evaluation process. Links to the vendor master record.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the RFQ was formally awarded to the selected vendor. Marks the transition from evaluation to contracting.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardJustification rdf:type rdf:Property ;
    rdfs:label 'Award Justification' ;
    rdfs:comment 'Business rationale and evaluation summary explaining why the selected vendor was chosen. Required for procurement audit trail and compliance.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedQuotationNumber rdf:type rdf:Property ;
    rdfs:label 'Awarded Quotation Number' ;
    rdfs:comment 'Reference number of the winning vendor quotation that was selected for award. Provides audit trail to the selected bid.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level for the RFQ document and vendor responses. Determines access controls and information sharing restrictions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Type of purchasing agreement that will result from this RFQ (one-time purchase order, framework agreement, blanket order). Influences vendor commitment and pricing structure.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Port terminal, warehouse, or facility where goods must be delivered or services performed. Critical for logistics planning and freight cost evaluation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalRequirements rdf:type rdf:Property ;
    rdfs:label 'Environmental Requirements' ;
    rdfs:comment 'Environmental compliance and sustainability criteria vendors must satisfy (e.g., ISO 14001, MARPOL compliance, carbon footprint limits).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Documented criteria and weightings used to evaluate and score vendor quotations (e.g., price 50%, quality 30%, delivery 20%). Ensures transparent and auditable vendor selection.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Minimum insurance coverage vendors must maintain (e.g., liability limits, P&I coverage, cargo insurance). Critical for risk management in maritime operations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowestQuotedPrice rdf:type rdf:Property ;
    rdfs:label 'Lowest Quoted Price' ;
    rdfs:comment 'Lowest total quoted price received from all vendors. Used for quick price benchmarking and savings calculation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRequirements rdf:type rdf:Property ;
    rdfs:label 'Quality Requirements' ;
    rdfs:comment 'Specific quality standards, certifications, and inspection requirements vendors must meet (e.g., ISO 9001, SOLAS compliance, material certificates).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Total quantity of goods or volume of services requested in the RFQ. Used for vendor capacity assessment and pricing evaluation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotationCount rdf:type rdf:Property ;
    rdfs:label 'Quotation Count' ;
    rdfs:comment 'Total number of vendor quotations received in response to this RFQ. Indicates level of competitive interest and market response.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Business identifier for the RFQ document, externally visible and used in vendor communications. Sourced from SAP MM RFQ document number (EKKO-EBELN where BSART=AN).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ in the competitive sourcing workflow. Tracks progression from draft through vendor selection to closure. [ENUM-REF-CANDIDATE: draft|issued|open|under_evaluation|awarded|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqType rdf:type rdf:Property ;
    rdfs:label 'Rfq Type' ;
    rdfs:comment 'Classification of the RFQ based on procurement strategy and urgency. Determines evaluation criteria and approval workflows.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRequirements rdf:type rdf:Property ;
    rdfs:label 'Safety Requirements' ;
    rdfs:comment 'Occupational health and safety standards vendors must comply with (e.g., ISO 45001, ISPS Code, port safety regulations).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecifications rdf:type rdf:Property ;
    rdfs:label 'Technical Specifications' ;
    rdfs:comment 'Detailed technical requirements, standards, certifications, and performance criteria that vendors must meet. May reference industry standards (IMO, SOLAS, ISO).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEstimatedValue rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Value' ;
    rdfs:comment 'Estimated total value of the procurement at RFQ issuance. Used for budget validation and approval routing.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorPrequalificationRequired rdf:type rdf:Property ;
    rdfs:label 'Vendor Prequalification Required' ;
    rdfs:comment 'Indicates whether vendors must be pre-approved and registered in the vendor master before submitting quotations. Ensures only qualified suppliers participate.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryServiceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Employee Id' ;
    rdfs:comment 'Reference to the employee or user who accepted the services and approved the service entry sheet.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryServiceCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Service Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created the service entry sheet record.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the services were formally accepted by the receiving organization.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptedByName rdf:type rdf:Property ;
    rdfs:label 'Accepted By Name' ;
    rdfs:comment 'Full name of the person who accepted the services.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Status' ;
    rdfs:comment 'Status of invoice verification process against this service entry sheet, required for payment release.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Release Status' ;
    rdfs:comment 'Status indicating whether payment has been released for the accepted services.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEntrySheetNumber rdf:type rdf:Property ;
    rdfs:label 'Service Entry Sheet Number' ;
    rdfs:comment 'Externally-known business identifier for the service entry sheet, typically a 10-character alphanumeric code assigned by SAP MM upon creation.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEntrySheetStatus rdf:type rdf:Property ;
    rdfs:label 'Service Entry Sheet Status' ;
    rdfs:comment 'Current lifecycle status of the service entry sheet in the approval and posting workflow.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Service Type Code' ;
    rdfs:comment 'Classification code identifying the type of service rendered (e.g., maintenance, pilotage, towage, dredging, consulting).' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAcceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Accepted Quantity' ;
    rdfs:comment 'Total quantity of services accepted across all line items in this service entry sheet, measured in the unit of measure specified per line.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAcceptedValue rdf:type rdf:Property ;
    rdfs:label 'Total Accepted Value' ;
    rdfs:comment 'Total monetary value of all accepted services in this service entry sheet, calculated as sum of line item values.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Classification code identifying the primary commodity or material group covered by this contract (e.g., spare parts, fuel, services).' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Regulatory, safety, environmental, or quality compliance standards that the vendor must adhere to under this contract (e.g., ISO certifications, ISPS, MARPOL).' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClause rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause' ;
    rdfs:comment 'Non-disclosure and confidentiality obligations binding the vendor regarding proprietary information, trade secrets, and business data.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDescription rdf:type rdf:Property ;
    rdfs:label 'Contract Description' ;
    rdfs:comment 'Detailed textual description of the contract scope, materials, services, and special terms covered by this agreement.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the signed contract document stored in the document management system.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'Name or identifier of the procurement manager or contract administrator responsible for this agreement.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the supplier contract indicating its operational state and validity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Contractual penalties and liquidated damages applicable for non-performance, late delivery, or quality failures by the vendor.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'Cumulative quantity of materials or services released through purchase orders against this contract to date.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releasedValue rdf:type rdf:Property ;
    rdfs:label 'Released Value' ;
    rdfs:comment 'Cumulative monetary value of all release orders or call-offs issued against this contract to date.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Defined service level commitments, performance metrics, and quality standards that the vendor must meet under this contract.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Planned or target quantity of materials or services to be procured over the contract period. Applicable for quantity contracts.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Legal provisions and conditions under which either party may terminate the contract, including notice periods and penalties.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of contract value or quantity that has been utilized through release orders, calculated as (released / target) * 100.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Rating' ;
    rdfs:comment 'Overall performance rating of the vendor under this contract based on delivery, quality, and service metrics.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingIndicator rdf:type rdf:Property ;
    rdfs:label 'Blocking Indicator' ;
    rdfs:comment 'Flag indicating whether this contract line is temporarily blocked from use in release orders. Used for quality holds or contractual disputes.' ;
    rdfs:domain ind:SupplierContractItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractItemNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Item Number' ;
    rdfs:comment 'Sequential line item number within the contract document. Used for ordering and referencing specific contract lines.' ;
    rdfs:domain ind:SupplierContractItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Standard number of calendar days from release order placement to expected delivery at the destination. Used for planning and scheduling.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodsReceiptRequired rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Required' ;
    rdfs:comment 'Flag indicating whether a goods receipt must be posted for materials ordered against this contract line. Controls inventory management integration.' ;
    rdfs:domain ind:SupplierContractItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptRequired rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Required' ;
    rdfs:comment 'Flag indicating whether invoice verification is required for orders against this contract line. Controls accounts payable integration.' ;
    rdfs:domain ind:SupplierContractItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date when the most recent goods receipt was posted for materials ordered against this contract line. Tracks fulfillment activity.' ;
    rdfs:domain ind:SupplierContractItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReleaseOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Release Order Date' ;
    rdfs:comment 'Date when the most recent release order was created against this contract line. Used for contract activity monitoring.' ;
    rdfs:domain ind:SupplierContractItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'Remaining quantity available for release under this contract line. Calculated as target_quantity minus released_quantity.' ;
    rdfs:domain ind:SupplierContractItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingValue rdf:type rdf:Property ;
    rdfs:label 'Remaining Value' ;
    rdfs:comment 'Remaining monetary value available for release under this contract line. Calculated as target_value minus released_value.' ;
    rdfs:domain ind:SupplierContractItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalSpecificationReference rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Reference' ;
    rdfs:comment 'Reference to technical specification document or standard that the contracted material or service must meet. Examples: ISO standard, IMO regulation, port technical specification.' ;
    rdfs:domain ind:SupplierContractItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderId rdf:type rdf:Property ;
    rdfs:label 'Tender Id' ;
    rdfs:comment 'Unique identifier for the tender record. Primary key.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tenderCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tender Created By User Employee Id' ;
    rdfs:comment 'User ID of the person who created this tender record.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tenderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tender Employee Id' ;
    rdfs:comment 'User ID of the approving authority who authorized the tender issuance or award.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tenderManagerUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tender Manager User Employee Id' ;
    rdfs:comment 'User ID of the procurement professional responsible for managing this tender process.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tenderModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tender Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified this tender record.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:awardedValue rdf:type rdf:Property ;
    rdfs:label 'Awarded Value' ;
    rdfs:comment 'Final contracted value awarded to the winning vendor, in the specified currency.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidBondAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Amount' ;
    rdfs:comment 'Required bid bond amount in the specified currency, if applicable.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidBondRequired rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Required' ;
    rdfs:comment 'Indicates whether bidders must submit a bid bond or bid security as part of their submission.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'Deadline date by which all bids must be submitted. No bids are accepted after this date.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closingTime rdf:type rdf:Property ;
    rdfs:label 'Closing Time' ;
    rdfs:comment 'Precise timestamp (date and time) when the tender submission window closes.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:commodityScope rdf:type rdf:Property ;
    rdfs:label 'Commodity Scope' ;
    rdfs:comment 'High-level categorization of the commodity or service category being procured (e.g., marine equipment, IT services, construction works, spare parts).' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Months' ;
    rdfs:comment 'Expected duration of the resulting contract in months.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Estimated total value of the tender in the specified currency, used for budget planning and approval thresholds.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationMethod rdf:type rdf:Property ;
    rdfs:label 'Evaluation Method' ;
    rdfs:comment 'Method used to evaluate and compare bids: lowest price, best value (price and quality), technical merit, two-envelope system (technical then commercial), or quality-cost based scoring.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the tender manager responsible for this procurement.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfBidsEvaluated rdf:type rdf:Property ;
    rdfs:label 'Number Of Bids Evaluated' ;
    rdfs:comment 'Count of bids that met eligibility criteria and were formally evaluated.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfBidsReceived rdf:type rdf:Property ;
    rdfs:label 'Number Of Bids Received' ;
    rdfs:comment 'Total count of valid bids received by the closing date.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Final outcome of the tender process: awarded (contract given), no award (no suitable bids), cancelled (process terminated), withdrawn (by issuer), or under review (pending decision).' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required' ;
    rdfs:comment 'Indicates whether the awarded vendor must provide a performance bond or guarantee upon contract execution.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preQualificationRequired rdf:type rdf:Property ;
    rdfs:label 'Pre Qualification Required' ;
    rdfs:comment 'Indicates whether vendors must be pre-qualified or pre-registered to participate in this tender.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationChannel rdf:type rdf:Property ;
    rdfs:label 'Publication Channel' ;
    rdfs:comment 'Channels through which the tender was published (e.g., port authority website, government procurement portal, industry publications).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderDescription rdf:type rdf:Property ;
    rdfs:label 'Tender Description' ;
    rdfs:comment 'Detailed description of the goods, services, or works being procured through this tender, including scope, specifications, and requirements.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderNumber rdf:type rdf:Property ;
    rdfs:label 'Tender Number' ;
    rdfs:comment 'Externally-known unique business identifier for the tender, typically following organizational numbering convention.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderStatus rdf:type rdf:Property ;
    rdfs:label 'Tender Status' ;
    rdfs:comment 'Current lifecycle status of the tender process: draft (being prepared), published (announced), open (accepting bids), closed (submission deadline passed), evaluation (under review), awarded (vendor selected), cancelled, or withdrawn. [ENUM-REF-CANDIDATE: draft|published|open|closed|evaluation|awarded|cancelled|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderType rdf:type rdf:Property ;
    rdfs:label 'Tender Type' ;
    rdfs:comment 'Classification of the tender process: open tender (public), restricted tender (pre-qualified vendors), negotiated tender, expression of interest (EOI), framework agreement, or single source procurement.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedCommodityCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Commodity Categories' ;
    rdfs:comment 'Comma-separated list of UNSPSC commodity categories or internal procurement categories that the vendor is approved to supply. Restricts purchase order creation to approved categories only.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountCurrency rdf:type rdf:Property ;
    rdfs:label 'Bank Account Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the vendor\'s bank account. May differ from transaction currency if currency conversion is required for payment.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountValidFrom rdf:type rdf:Property ;
    rdfs:label 'Bank Account Valid From' ;
    rdfs:comment 'Date from which the vendor\'s bank account details are valid and can be used for payment processing. Used to manage bank account changes over time.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankAccountValidTo rdf:type rdf:Property ;
    rdfs:label 'Bank Account Valid To' ;
    rdfs:comment 'Date until which the vendor\'s bank account details remain valid. Null indicates the account is currently active with no planned end date.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankBranch rdf:type rdf:Property ;
    rdfs:label 'Bank Branch' ;
    rdfs:comment 'Specific branch or location of the bank where the vendor account is held. May include branch code or address.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution where the vendor holds their primary payment account. Used for electronic funds transfer and payment processing. Sourced from SAP MM Vendor Master (LFBK-BANKS).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number used for cross-border payments in SEPA and international wire transfers. Standardized format for global payment processing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certificate Number' ;
    rdfs:comment 'Unique certificate number issued by the certification body for ISO 14001 environmental compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 14001 Environmental Management System certification. Important for chemical suppliers and contractors.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Expiry Date' ;
    rdfs:comment 'Date when the vendor\'s ISO 14001 environmental certification expires and requires renewal.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso45001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certificate Number' ;
    rdfs:comment 'Unique certificate number issued by the certification body for ISO 45001 occupational health and safety compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso45001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 45001 Occupational Health and Safety Management System certification. Required for service contractors working on port premises.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Expiry Date' ;
    rdfs:comment 'Date when the vendor\'s ISO 45001 occupational health and safety certification expires and requires renewal.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso9001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certificate Number' ;
    rdfs:comment 'Unique certificate number issued by the certification body for ISO 9001 compliance. Used for verification and audit purposes.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 9001 Quality Management System certification. Critical for equipment and spare parts suppliers.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Expiry Date' ;
    rdfs:comment 'Date when the vendor\'s ISO 9001 certification expires and requires renewal. Monitored to ensure continued compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ispsClearanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Isps Clearance Expiry Date' ;
    rdfs:comment 'Date when the vendor\'s ISPS security clearance expires. Vendors with expired clearance cannot access restricted port areas.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ispsClearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Isps Clearance Number' ;
    rdfs:comment 'Unique clearance number issued by port security authority under ISPS Code requirements. Used for access control and security audits.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Isps Clearance Status' ;
    rdfs:comment 'Security clearance status under ISPS Code for vendors requiring access to restricted port areas. Mandatory for marine services and contractors working in secure zones.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent vendor performance evaluation. Used to track periodic supplier assessments and qualification reviews.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum monetary value required for a purchase order to be accepted by the vendor. Orders below this threshold may incur additional fees or be rejected.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Performance Review Date' ;
    rdfs:comment 'Scheduled date for the next vendor performance evaluation. Ensures regular assessment of supplier quality, delivery, and service levels.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Typical number of days from purchase order issuance to delivery of goods or completion of services. Used for procurement planning and inventory management.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:swiftBicCode rdf:type rdf:Property ;
    rdfs:label 'Swift Bic Code' ;
    rdfs:comment 'SWIFT/BIC code identifying the vendor\'s bank for international wire transfers. 8 or 11 character code following ISO 9362 standard.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax registration number or VAT number for the vendor. Format varies by jurisdiction (e.g., EIN in USA, VAT in EU, GST in India). Used for tax reporting and compliance. Sourced from SAP MM Vendor Master (LFA1-STCEG).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLicenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Trade License Expiry Date' ;
    rdfs:comment 'Date when the vendor\'s trade license expires. Vendors with expired licenses may be blocked from new transactions pending renewal.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeLicenseIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Trade License Issuing Authority' ;
    rdfs:comment 'Name of the government body or regulatory authority that issued the vendor\'s trade license (e.g., Ministry of Commerce, Chamber of Commerce).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Trade License Number' ;
    rdfs:comment 'Government-issued trade license or business permit number authorizing the vendor to conduct commercial operations in the jurisdiction.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Category' ;
    rdfs:comment 'Primary business classification of the vendor based on the type of goods or services they provide to the port authority. Determines procurement workflows and approval hierarchies. [ENUM-REF-CANDIDATE: spare_parts_supplier|equipment_vendor|service_contractor|fuel_supplier|chemical_supplier|consumables_provider|marine_services|logistics_provider|construction_contractor|professional_services — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Externally-known unique business identifier for the vendor. Alphanumeric code used in procurement documents, purchase orders, and supplier communications. Sourced from SAP MM Vendor Master (LFA1-LIFNR).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Full legal registered name of the vendor organization as it appears on contracts, invoices, and official documents. Sourced from SAP MM Vendor Master (LFA1-NAME1).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current operational status of the vendor in the procurement system. Active vendors can receive purchase orders. Blocked vendors cannot transact. Sourced from SAP MM Vendor Master (LFA1-SPERR).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Strategic classification of vendor based on spend volume, criticality of supplies, performance history, and relationship strength. Tier 1 vendors receive preferential treatment and longer-term contracts.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account Id' ;
    rdfs:comment 'Unique identifier for the vendor bank account record. Primary key for this entity.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the account holder as registered with the bank. Must match vendor legal name for payment processing.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountPurpose rdf:type rdf:Property ;
    rdfs:label 'Bank Account Purpose' ;
    rdfs:comment 'Business purpose or use case for this specific bank account, such as general payments, advance payments, or specific contract payments.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line1' ;
    rdfs:comment 'First line of the bank branch physical address including street number and name.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line2' ;
    rdfs:comment 'Second line of the bank branch physical address for additional location details such as building or suite number.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCity rdf:type rdf:Property ;
    rdfs:label 'Bank City' ;
    rdfs:comment 'City or municipality where the bank branch is located.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankControlKey rdf:type rdf:Property ;
    rdfs:label 'Bank Control Key' ;
    rdfs:comment 'Additional bank-specific control identifier used in certain countries for payment validation and routing purposes.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bank Country Code' ;
    rdfs:comment 'Three-letter ISO country code indicating the country where the bank is located.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'Bank identification key or routing number that uniquely identifies the financial institution. May be a sort code, routing number, or bank code depending on country.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankPostalCode rdf:type rdf:Property ;
    rdfs:label 'Bank Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the bank branch address used for correspondence and verification.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStateProvince rdf:type rdf:Property ;
    rdfs:label 'Bank State Province' ;
    rdfs:comment 'State, province, or region where the bank branch is located.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockReason rdf:type rdf:Property ;
    rdfs:label 'Block Reason' ;
    rdfs:comment 'Explanation or reason code for why the bank account has been blocked for payment processing.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankName rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Name' ;
    rdfs:comment 'Name of the intermediary or correspondent bank used for routing international payments when direct transfer is not available.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediarySwiftCode rdf:type rdf:Property ;
    rdfs:label 'Intermediary Swift Code' ;
    rdfs:comment 'SWIFT/BIC code of the intermediary bank used for multi-hop international wire transfers.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlockedForPayment rdf:type rdf:Property ;
    rdfs:label 'Is Blocked For Payment' ;
    rdfs:comment 'Boolean flag indicating whether this bank account is temporarily blocked from receiving payments due to compliance, audit, or vendor issues.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAccount rdf:type rdf:Property ;
    rdfs:label 'Is Primary Account' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary or default bank account for the vendor. Used for automatic payment selection.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceDetails rdf:type rdf:Property ;
    rdfs:label 'Reference Details' ;
    rdfs:comment 'Additional reference information or payment instructions specific to this bank account, such as beneficiary reference or special handling notes.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'SWIFT/BIC code identifying the bank for international payments. 8 or 11 character code used for cross-border wire transfers.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the user or system that performed the bank account verification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCertificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Certification Id' ;
    rdfs:comment 'Unique identifier for the vendor certification record. Primary key.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Frequency in months at which surveillance audits or compliance reviews are required by the certifying body to maintain the certification.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Level, grade, or tier of the certification if the certification scheme includes multiple levels of achievement or compliance. Examples include basic, advanced, gold, platinum, or numerical levels.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full descriptive name of the certification or accreditation as stated on the certificate.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique certificate number or registration number issued by the certifying body. This is the externally-known identifier for the certification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Detailed description of the scope of the certification, including the specific products, services, processes, or activities covered by the certification. Defines the boundaries and applicability of the certification.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification. Indicates whether the certification is active and valid, expired, suspended by the issuing body, pending renewal, revoked, or under review.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type or category of certification held by the vendor. Includes quality management (ISO 9001), environmental management (ISO 14001), occupational health and safety (ISO 45001), supply chain security (ISO 28000), International Ship and Port Facility Security (ISPS) clearances, trade licenses, and other industry-specific certifications. [ENUM-REF-CANDIDATE: ISO 9001|ISO 14001|ISO 45001|ISO 28000|ISPS|Trade License|Industry Specific|Other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Full name and version of the standard, regulation, or framework against which the vendor is certified. Examples include ISO 9001:2015, ISO 14001:2015, ISO 45001:2018, ISPS Code Amendment, or specific trade regulations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the organization, authority, or accreditation body that issued the certification. Examples include certification bodies, government agencies, industry associations, or regulatory authorities.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country where the issuing body is registered or headquartered.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next surveillance audit or recertification audit required to maintain the certification. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Initiated Date' ;
    rdfs:comment 'Date when the certification renewal process was initiated by the vendor or the port\'s procurement team. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorQualificationImpact rdf:type rdf:Property ;
    rdfs:label 'Vendor Qualification Impact' ;
    rdfs:comment 'Impact of this certification on the vendor\'s overall qualification status for procurement activities. Indicates whether the vendor is fully qualified, conditionally qualified, disqualified, or under review based on certification status.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Evaluation Id' ;
    rdfs:comment 'Unique identifier for the vendor evaluation record. Primary key for the vendor evaluation entity.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Description of the corrective actions required from the vendor. Details specific performance improvements, process changes, or compliance measures that must be implemented.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which the vendor must complete required corrective actions. Used to track vendor response and follow-up evaluation scheduling.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentVendorTier rdf:type rdf:Property ;
    rdfs:label 'Current Vendor Tier' ;
    rdfs:comment 'Current classification tier of the vendor prior to this evaluation. Preferred vendors receive priority in sourcing, approved vendors meet minimum standards, conditional vendors have restrictions, probation vendors are under performance improvement plans, and blocked vendors are suspended from new business.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Documentation Compliance Score' ;
    rdfs:comment 'Performance score for vendor adherence to documentation requirements including certificates, test reports, material safety data sheets, customs documentation, and trade compliance paperwork during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationComplianceWeight rdf:type rdf:Property ;
    rdfs:label 'Documentation Compliance Weight' ;
    rdfs:comment 'Weighting factor applied to the documentation compliance score in the overall score calculation. Expressed as a percentage or decimal fraction.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationComments rdf:type rdf:Property ;
    rdfs:label 'Evaluation Comments' ;
    rdfs:comment 'Free-text comments and observations from the evaluator. Captures qualitative feedback, notable incidents, improvement areas, and strengths observed during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date when the vendor evaluation was conducted and finalized. Represents the business event timestamp for the evaluation activity.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationNumber rdf:type rdf:Property ;
    rdfs:label 'Evaluation Number' ;
    rdfs:comment 'Business identifier for the vendor evaluation. Human-readable reference number used in procurement documentation and vendor communications.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the period covered by this vendor evaluation. Defines the conclusion of the performance measurement window.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this vendor evaluation. Defines the beginning of the performance measurement window.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle status of the vendor evaluation. Tracks the evaluation through its workflow from initial draft to final completion.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Type' ;
    rdfs:comment 'Classification of the evaluation based on its trigger and purpose. Periodic evaluations occur on a regular schedule, ad-hoc evaluations are triggered by specific events, contract renewal evaluations support sourcing decisions, incident-driven evaluations follow quality or delivery issues, and qualification/requalification evaluations determine vendor eligibility.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Full name of the employee who conducted the vendor evaluation. Captured for audit trail and accountability purposes.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsseComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Hsse Compliance Score' ;
    rdfs:comment 'Performance score for vendor adherence to health, safety, security, and environmental standards. Evaluates compliance with ISPS Code, SOLAS, MARPOL, ISO 45001 (Occupational Health and Safety), ISO 14001 (Environmental Management), and port-specific HSSE requirements during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsseComplianceWeight rdf:type rdf:Property ;
    rdfs:label 'Hsse Compliance Weight' ;
    rdfs:comment 'Weighting factor applied to the HSSE compliance score in the overall score calculation. Expressed as a percentage or decimal fraction.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateDeliveries rdf:type rdf:Property ;
    rdfs:label 'Late Deliveries' ;
    rdfs:comment 'Number of purchase orders delivered after the requested delivery date during the evaluation period. Used to calculate the on-time delivery score.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextEvaluationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Evaluation Due Date' ;
    rdfs:comment 'Scheduled date for the next vendor evaluation. May be accelerated for vendors on probation or extended for preferred vendors based on evaluation results.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeDeliveries rdf:type rdf:Property ;
    rdfs:label 'On Time Deliveries' ;
    rdfs:comment 'Number of purchase orders delivered on or before the requested delivery date during the evaluation period. Used to calculate the on-time delivery score.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliveryScore rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Score' ;
    rdfs:comment 'Performance score for vendor adherence to delivery schedules. Measures the percentage of purchase orders delivered on or before the requested delivery date during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryWeight rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Weight' ;
    rdfs:comment 'Weighting factor applied to the on-time delivery score in the overall score calculation. Expressed as a percentage or decimal fraction.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Qualitative rating band derived from the overall score. Provides a business-friendly classification of vendor performance for reporting and decision-making.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Composite vendor performance score calculated from weighted sub-criteria scores. Typically expressed as a percentage or on a 0-100 scale. Used for vendor ranking and qualification decisions.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCompetitivenessScore rdf:type rdf:Property ;
    rdfs:label 'Price Competitiveness Score' ;
    rdfs:comment 'Performance score for vendor pricing relative to market benchmarks and competing suppliers. Evaluates cost-effectiveness and value for money during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCompetitivenessWeight rdf:type rdf:Property ;
    rdfs:label 'Price Competitiveness Weight' ;
    rdfs:comment 'Weighting factor applied to the price competitiveness score in the overall score calculation. Expressed as a percentage or decimal fraction.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate' ;
    rdfs:comment 'Percentage of goods receipts accepted without quality issues during the evaluation period. Calculated as (total receipts - rejections) / total receipts * 100.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Quality Compliance Score' ;
    rdfs:comment 'Performance score for vendor adherence to quality specifications and standards. Measures defect rates, rejection rates, and compliance with quality requirements during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityComplianceWeight rdf:type rdf:Property ;
    rdfs:label 'Quality Compliance Weight' ;
    rdfs:comment 'Weighting factor applied to the quality compliance score in the overall score calculation. Expressed as a percentage or decimal fraction.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRejections rdf:type rdf:Property ;
    rdfs:label 'Quality Rejections' ;
    rdfs:comment 'Number of goods receipts rejected due to quality defects during the evaluation period. Used to calculate the quality compliance score.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendedVendorTier rdf:type rdf:Property ;
    rdfs:label 'Recommended Vendor Tier' ;
    rdfs:comment 'Recommended classification tier for the vendor based on this evaluation. May differ from current tier if performance warrants upgrade or downgrade.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Performance score for vendor communication, inquiry response time, and flexibility in addressing urgent requirements or changes during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessWeight rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Weight' ;
    rdfs:comment 'Weighting factor applied to the responsiveness score in the overall score calculation. Expressed as a percentage or decimal fraction.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierChangeReason rdf:type rdf:Property ;
    rdfs:label 'Tier Change Reason' ;
    rdfs:comment 'Business justification for recommending a change in vendor tier classification. Captures the rationale for upgrade or downgrade decisions.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPurchaseOrders rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Orders' ;
    rdfs:comment 'Total number of purchase orders issued to the vendor during the evaluation period. Provides context for the evaluation sample size.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseValue rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Value' ;
    rdfs:comment 'Total monetary value of purchases from the vendor during the evaluation period. Expressed in the base currency of the port authority.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Unique identifier for the vendor invoice record. Primary key for the vendor invoice entity.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Percentage' ;
    rdfs:comment 'The percentage discount rate applicable for early payment within the discount period.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Gross Amount' ;
    rdfs:comment 'Total gross amount invoiced by the vendor before any deductions. Includes base amount plus tax and other charges.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNetAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Net Amount' ;
    rdfs:comment 'Net amount invoiced excluding tax. Base amount for goods or services before tax calculation.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Date' ;
    rdfs:comment 'The date the invoice document was received by the port organization. Used for tracking invoice processing cycle time.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceVariance rdf:type rdf:Property ;
    rdfs:label 'Price Variance' ;
    rdfs:comment 'The difference between invoiced price and purchase order price. Used to identify pricing discrepancies requiring approval or vendor correction.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The difference between invoiced quantity and goods receipt quantity. Positive values indicate over-invoicing; negative values indicate under-invoicing.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference Number' ;
    rdfs:comment 'Additional reference number provided by the vendor for their internal tracking or delivery note reference. May include packing slip number or vendor order number.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxCode rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Code' ;
    rdfs:comment 'Code identifying the type and rate of withholding tax applied to the invoice.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorQuotationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Quotation Id' ;
    rdfs:comment 'Unique identifier for the vendor quotation record. Primary key for the vendor quotation entity.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commercialTermsNotes rdf:type rdf:Property ;
    rdfs:label 'Commercial Terms Notes' ;
    rdfs:comment 'Additional commercial terms and conditions proposed by the vendor, including special discounts, volume pricing, or contractual clauses.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'The composite score assigned to this quotation during the bid evaluation process. Calculated based on price, delivery time, technical compliance, and vendor performance criteria.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCompetitivenessRank rdf:type rdf:Property ;
    rdfs:label 'Price Competitiveness Rank' ;
    rdfs:comment 'The ranking of this quotation relative to other vendor quotations for the same RFQ based on total quoted value. Rank 1 indicates the lowest price.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotationNumber rdf:type rdf:Property ;
    rdfs:label 'Quotation Number' ;
    rdfs:comment 'The vendor-assigned quotation reference number. External business identifier used by the vendor to track their quotation submission.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationStatus rdf:type rdf:Property ;
    rdfs:label 'Quotation Status' ;
    rdfs:comment 'Current lifecycle status of the vendor quotation in the procurement evaluation workflow. Tracks progression from submission through evaluation to final disposition. [ENUM-REF-CANDIDATE: draft|submitted|under_evaluation|accepted|rejected|withdrawn|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationType rdf:type rdf:Property ;
    rdfs:label 'Quotation Type' ;
    rdfs:comment 'The category of quotation based on procurement context. Distinguishes between standard competitive bids, framework agreements, emergency purchases, and contract renewals.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedForAwardFlag rdf:type rdf:Property ;
    rdfs:label 'Recommended For Award Flag' ;
    rdfs:comment 'Indicates whether the procurement team recommends this quotation for purchase order award. True if recommended, false otherwise.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Flag' ;
    rdfs:comment 'Indicates whether the quoted items meet all technical specifications and requirements defined in the RFQ. True if compliant, false if deviations exist.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalDeviationNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Deviation Notes' ;
    rdfs:comment 'Detailed description of any deviations from the technical specifications requested in the RFQ. Documents alternative materials, dimensions, or performance characteristics offered by the vendor.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuotedValue rdf:type rdf:Property ;
    rdfs:label 'Total Quoted Value' ;
    rdfs:comment 'The total monetary value of all line items in this quotation before taxes and adjustments. Used for comparative bid evaluation and budget verification.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValueIncludingTax rdf:type rdf:Property ;
    rdfs:label 'Total Value Including Tax' ;
    rdfs:comment 'The final total value of the quotation including all taxes and charges. Represents the complete financial commitment if this quotation is accepted.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryContractorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Contractor Employee Id' ;
    rdfs:comment 'Reference to the port safety officer responsible for managing this contractor\'s safety performance and compliance. Links to employee master data.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:competencyVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Competency Verification Date' ;
    rdfs:comment 'Date when contractor personnel competencies were last verified against work scope requirements.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competencyVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Competency Verification Status' ;
    rdfs:comment 'Status of verification that contractor personnel hold required competencies, licenses, and certifications for the authorized work scope.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSafetyPlanApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Contract Safety Plan Approval Date' ;
    rdfs:comment 'Date when the contractor\'s safety plan was approved by the port safety authority. Work cannot commence until plan is approved.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractSafetyPlanReference rdf:type rdf:Property ;
    rdfs:label 'Contract Safety Plan Reference' ;
    rdfs:comment 'Document reference or identifier for the contractor\'s site-specific safety plan submitted and approved for the current contract or work scope.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorCompanyName rdf:type rdf:Property ;
    rdfs:label 'Contractor Company Name' ;
    rdfs:comment 'Legal name of the contractor organization. Denormalized for reporting and quick reference.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contractor Reference Number' ;
    rdfs:comment 'External business identifier for the contractor safety record. Used for tracking and reporting purposes across systems.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emrCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Emr Calculation Date' ;
    rdfs:comment 'Date when the EMR was calculated or last updated. EMR is typically recalculated annually.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emrRate rdf:type rdf:Property ;
    rdfs:label 'Emr Rate' ;
    rdfs:comment 'Experience Modification Rate reflecting the contractor\'s workers compensation claims history. Values below 1.0 indicate better-than-average safety performance; above 1.0 indicates worse-than-average.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentCount12Months rdf:type rdf:Property ;
    rdfs:label 'Incident Count 12 Months' ;
    rdfs:comment 'Total number of OHS incidents involving this contractor in the last 12 months. Used for trend analysis and performance monitoring.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inductionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Induction Certificate Number' ;
    rdfs:comment 'Unique certificate number issued upon successful completion of port safety induction. Used for verification and access control.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inductionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Induction Completion Date' ;
    rdfs:comment 'Date when the contractor\'s authorized personnel completed the required port safety induction. Null if induction not yet completed or not required.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inductionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Induction Expiry Date' ;
    rdfs:comment 'Date when the contractor\'s safety induction expires and must be renewed. Typically 12-36 months from completion date.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inductionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Induction Required Flag' ;
    rdfs:comment 'Indicates whether site-specific safety induction is required for this contractor before commencing work. True for most contractors; false only for pre-approved low-risk administrative contractors.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltifr rdf:type rdf:Property ;
    rdfs:label 'Ltifr' ;
    rdfs:comment 'Lost Time Injury Frequency Rate per million work hours. Measures the frequency of injuries resulting in time away from work.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ltifrReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Ltifr Reporting Period' ;
    rdfs:comment 'Time period covered by the LTIFR calculation. Provides context for the LTIFR value.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceCount12Months rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Count 12 Months' ;
    rdfs:comment 'Total number of safety non-conformances identified for this contractor in the last 12 months through inspections, audits, or observations.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Effective Date' ;
    rdfs:comment 'Date when the contractor qualification became active and the contractor was authorized to commence work at the port.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date when the contractor qualification expires and must be renewed. Null for indefinite qualifications subject to ongoing performance monitoring.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current pre-qualification status of the contractor for port operations. Determines whether the contractor is authorized to perform work at the port facility. [ENUM-REF-CANDIDATE: pre_qualified|qualified|conditional|suspended|disqualified|expired|under_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Category of contractor qualification based on the nature and risk level of work authorized. Determines applicable safety requirements and monitoring intensity.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementConditions rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Conditions' ;
    rdfs:comment 'Specific conditions and corrective actions that must be met for contractor reinstatement following suspension. May include training, audits, or enhanced monitoring requirements.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAccreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Safety Accreditation Expiry Date' ;
    rdfs:comment 'Expiry date of the contractor\'s safety management system accreditation. Monitored to ensure continuous compliance.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Safety Accreditation Number' ;
    rdfs:comment 'Certificate or registration number for the contractor\'s safety accreditation. Used for verification with accreditation bodies.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAccreditationType rdf:type rdf:Property ;
    rdfs:label 'Safety Accreditation Type' ;
    rdfs:comment 'Type of safety management system accreditation held by the contractor (e.g., ISO 45001, SafeContractor, Achilles, CHAS). Multiple accreditations may be concatenated.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Safety Performance Rating' ;
    rdfs:comment 'Categorical safety performance rating derived from the safety performance score. Used for contractor tiering and access decisions.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Safety Performance Score' ;
    rdfs:comment 'Composite safety performance score calculated from incident history, audit results, compliance metrics, and behavioral observations. Scale typically 0-100, with higher scores indicating better performance.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suspensionFlag rdf:type rdf:Property ;
    rdfs:label 'Suspension Flag' ;
    rdfs:comment 'Indicates whether the contractor is currently suspended from performing work at the port due to safety performance issues. True if suspended, false if active.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trir rdf:type rdf:Property ;
    rdfs:label 'Trir' ;
    rdfs:comment 'Total Recordable Incident Rate per 200,000 work hours. Key safety performance indicator used in contractor pre-qualification and ongoing monitoring.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trirReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Trir Reporting Period' ;
    rdfs:comment 'Time period covered by the TRIR calculation (e.g., 2023, Q1-2024, Last 12 months). Provides context for the TRIR value.' ;
    rdfs:domain ind:ContractorSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Safety Corrective Action Id' ;
    rdfs:comment 'Unique identifier for the corrective action record. Primary key.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyCorrectiveAction .

ind:primarySafetyAssignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Assigned To Employee Id' ;
    rdfs:comment 'Foreign key to the employee responsible for implementing this corrective action. Action owner accountable for completion.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternarySafetyCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Safety Created By Employee Id' ;
    rdfs:comment 'Foreign key to the employee who created the corrective action record, typically a safety officer or incident investigator.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinarySafetyLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Safety Last Modified By Employee Id' ;
    rdfs:comment 'Foreign key to the employee who last modified the corrective action record. Audit trail for accountability.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySafetyClosedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Safety Closed By Employee Id' ;
    rdfs:comment 'Foreign key to the employee who formally closed the corrective action, typically a safety manager or supervisor.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business-facing unique identifier for the corrective action, typically formatted as CA-NNNNNN. Used for tracking and reference in reports and communications.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the action: corrective (addresses existing nonconformity), preventive (eliminates potential causes), or improvement (enhances performance beyond compliance).' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Department' ;
    rdfs:comment 'Department or functional area responsible for implementing the action (e.g., Terminal Operations, Marine Services, Maintenance).' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Final notes and summary recorded at closure, including lessons learned and recommendations for continual improvement.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Regulatory or contractual deadline by which the action must be completed to maintain compliance. May differ from internal target completion date.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated cost to implement the corrective action, including labor, materials, equipment, and external services. Used for budgeting and CAPEX/OPEX planning.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectivenessNotes rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Notes' ;
    rdfs:comment 'Detailed notes from the effectiveness review, including evidence, observations, and any follow-up actions required.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Outcome' ;
    rdfs:comment 'Result of the effectiveness review: whether the action successfully eliminated the root cause and prevented recurrence.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOverdue rdf:type rdf:Property ;
    rdfs:label 'Is Overdue' ;
    rdfs:comment 'Boolean flag indicating whether the action has passed its target completion date without being completed. Used for KPI reporting and escalation.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrencePreventionMeasures rdf:type rdf:Property ;
    rdfs:label 'Recurrence Prevention Measures' ;
    rdfs:comment 'Specific measures implemented to prevent recurrence of the incident or nonconformity, such as procedure updates, training, or engineering controls.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedSopDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Related Sop Document Reference' ;
    rdfs:comment 'Foreign key to the SOP or procedure document that was updated or created as part of this corrective action.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyCorrectiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Safety Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective or preventive action to be taken, including specific steps, resources, and expected outcomes.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCorrectiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Corrective Action Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action from assignment through verification to closure. [ENUM-REF-CANDIDATE: open|in_progress|completed|verified|closed|overdue|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Business identifier of the originating record (e.g., incident number, inspection number) for traceability and reporting.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Type of originating event or activity that triggered this corrective action. Polymorphic discriminator for source reference.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective action must be completed. Used for tracking and escalation of overdue actions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when required training associated with this corrective action was completed. Null if training not required or not yet completed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Boolean flag indicating whether employee training is required as part of this corrective action implementation.' ;
    rdfs:domain ind:SafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersedesPlanEmergencyResponsePlanId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Plan Emergency Response Plan Id' ;
    rdfs:comment 'Reference to the previous emergency response plan that this version supersedes. Nullable for initial versions.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyResponsePlan .

ind:activationTriggerDescription rdf:type rdf:Property ;
    rdfs:label 'Activation Trigger Description' ;
    rdfs:comment 'Detailed description of the conditions, thresholds, or events that trigger activation of this emergency response plan. Includes detection criteria and escalation decision points.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Full name of the authority who approved this emergency response plan, typically the Port Safety Manager, Operations Director, or Chief Executive Officer.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByTitle rdf:type rdf:Property ;
    rdfs:label 'Approved By Title' ;
    rdfs:comment 'Job title or role of the approving authority for this emergency response plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentMitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Containment Mitigation Strategy' ;
    rdfs:comment 'Strategy for containing and mitigating the emergency scenario including immediate actions, containment equipment deployment, and environmental protection measures.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'Physical or digital location where the full emergency response plan document is stored, including file path, document management system reference, or physical archive location.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Drill Completion Status' ;
    rdfs:comment 'Status of the drill execution record indicating whether the drill was completed as planned, cancelled, or postponed.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillExecutionCount rdf:type rdf:Property ;
    rdfs:label 'Drill Execution Count' ;
    rdfs:comment 'Total number of drills and exercises executed under this emergency response plan. Used to track compliance with mandatory drill frequency requirements.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Drill Execution Date' ;
    rdfs:comment 'Date on which the drill or exercise was conducted. Part of the drill line record pattern.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drillFollowUpActions rdf:type rdf:Property ;
    rdfs:label 'Drill Follow Up Actions' ;
    rdfs:comment 'List of corrective actions, training requirements, or plan updates required as a result of the drill exercise. Includes responsible parties and target completion dates.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillIdentifiedGaps rdf:type rdf:Property ;
    rdfs:label 'Drill Identified Gaps' ;
    rdfs:comment 'Documented gaps, deficiencies, or areas for improvement identified during the drill exercise including procedural weaknesses, resource shortfalls, and communication breakdowns.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillLessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Drill Lessons Learned' ;
    rdfs:comment 'Key lessons learned from the drill exercise including best practices observed, successful tactics, and insights for future improvement.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillObserverNames rdf:type rdf:Property ;
    rdfs:label 'Drill Observer Names' ;
    rdfs:comment 'Names of observers and evaluators who monitored and assessed the drill execution.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillParticipatingTeams rdf:type rdf:Property ;
    rdfs:label 'Drill Participating Teams' ;
    rdfs:comment 'List of teams, departments, or external agencies that participated in the drill exercise.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Drill Performance Score' ;
    rdfs:comment 'Overall performance evaluation score for the drill exercise, typically on a scale of 0-100, assessing response time, coordination, communication, and adherence to procedures.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillScenarioDescription rdf:type rdf:Property ;
    rdfs:label 'Drill Scenario Description' ;
    rdfs:comment 'Detailed description of the specific scenario simulated during the drill exercise, including scope, assumptions, and injects provided to participants.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillType rdf:type rdf:Property ;
    rdfs:label 'Drill Type' ;
    rdfs:comment 'Type of drill or exercise conducted under this plan. Drill line records capture exercise type, scenario, execution date, participating teams, observer names, performance evaluation scores, identified gaps, lessons learned, and follow-up actions required. One plan has zero-to-many drill records.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactMitigation rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Mitigation' ;
    rdfs:comment 'Procedures for minimizing environmental impact during emergency response including spill containment, air quality monitoring, water quality protection, and waste management protocols.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContactList rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact List' ;
    rdfs:comment 'Structured list of escalation contacts including names, roles, phone numbers, and email addresses for internal and external stakeholders to be notified during emergency activation.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evacuationProcedure rdf:type rdf:Property ;
    rdfs:label 'Evacuation Procedure' ;
    rdfs:comment 'Step-by-step evacuation procedures including assembly points, evacuation routes, headcount protocols, and special considerations for personnel with disabilities or medical conditions.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgencyCoordination rdf:type rdf:Property ;
    rdfs:label 'External Agency Coordination' ;
    rdfs:comment 'Description of coordination protocols with external agencies including coast guard, fire brigade, port authority, environmental agency, police, and medical services. Includes contact protocols and information-sharing agreements.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivationDate rdf:type rdf:Property ;
    rdfs:label 'Last Activation Date' ;
    rdfs:comment 'Date of the most recent actual emergency activation of this plan. Nullable if the plan has never been activated in a real emergency.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDrillDate rdf:type rdf:Property ;
    rdfs:label 'Last Drill Date' ;
    rdfs:comment 'Date of the most recent drill or exercise conducted under this emergency response plan. Used to monitor compliance with mandatory drill schedules.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalResponseProtocol rdf:type rdf:Property ;
    rdfs:label 'Medical Response Protocol' ;
    rdfs:comment 'Medical response protocols including first aid procedures, triage protocols, medical facility coordination, and casualty transportation arrangements.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known unique business identifier for the emergency response plan, used for reference in drills, audits, and regulatory submissions.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTitle rdf:type rdf:Property ;
    rdfs:label 'Plan Title' ;
    rdfs:comment 'Descriptive title of the emergency response plan, summarizing the primary scenario or scope covered.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceAllocationSummary rdf:type rdf:Property ;
    rdfs:label 'Resource Allocation Summary' ;
    rdfs:comment 'Summary of critical resources allocated to this plan including equipment, personnel, facilities, and materials required for effective emergency response.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTeamRoles rdf:type rdf:Property ;
    rdfs:label 'Response Team Roles' ;
    rdfs:comment 'Comma-separated list or structured description of key response team roles and their responsibilities (e.g., Incident Commander, Safety Officer, Operations Coordinator, Communications Lead, Medical Response Lead).' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioType rdf:type rdf:Property ;
    rdfs:label 'Scenario Type' ;
    rdfs:comment 'Primary emergency scenario type that this plan addresses. Determines response protocols, resource allocation, and external agency coordination requirements. [ENUM-REF-CANDIDATE: vessel_fire|oil_spill|dangerous_goods_release|tsunami|man_overboard|mass_casualty|security_threat|structural_collapse|hazmat_leak|medical_emergency|natural_disaster|cyber_incident — promote to reference product]' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:envMonitoringReadingId rdf:type rdf:Property ;
    rdfs:label 'Env Monitoring Reading Id' ;
    rdfs:comment 'Unique identifier for the environmental monitoring reading record. Primary key for the environmental monitoring reading entity.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atmosphericPressureHpa rdf:type rdf:Property ;
    rdfs:label 'Atmospheric Pressure Hpa' ;
    rdfs:comment 'Atmospheric pressure in hectopascals (hPa) at the time of reading. Affects gas concentration measurements and dispersion patterns.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorityNotified rdf:type rdf:Property ;
    rdfs:label 'Authority Notified' ;
    rdfs:comment 'Name of the environmental regulatory authority or port authority that was notified of the exceedance (e.g., EPA Regional Office, State Environmental Protection Agency, Port Environmental Officer).' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averagingPeriodMinutes rdf:type rdf:Property ;
    rdfs:label 'Averaging Period Minutes' ;
    rdfs:comment 'The time period in minutes over which the measured value was averaged (e.g., 1-minute, 15-minute, 1-hour, 24-hour averages). Regulatory thresholds often specify required averaging periods.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'The date when the monitoring sensor was last calibrated prior to this reading. Used to assess data quality and compliance with calibration schedules.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'The date when the next sensor calibration is scheduled or required. Readings taken after this date may be flagged for quality review.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicator of the reliability and validity of the reading. Valid indicates normal operation; suspect indicates potential sensor drift; invalid indicates known error; calibration/maintenance indicate sensor was being serviced; missing indicates data gap.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceClosureDate rdf:type rdf:Property ;
    rdfs:label 'Exceedance Closure Date' ;
    rdfs:comment 'The date when the exceedance event was formally closed after completion of all required corrective actions and regulatory acceptance. Null if still open.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceedanceClosureStatus rdf:type rdf:Property ;
    rdfs:label 'Exceedance Closure Status' ;
    rdfs:comment 'Lifecycle status of the exceedance event management. Tracks from initial detection through investigation, corrective action, and regulatory acceptance of closure.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Exceedance Duration Minutes' ;
    rdfs:comment 'The cumulative duration in minutes that the parameter remained above threshold during this exceedance event. Calculated from continuous monitoring data. Null if no exceedance occurred.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Exceedance Flag' ;
    rdfs:comment 'Boolean indicator whether this reading exceeded the regulatory or operational threshold for the parameter. True indicates a threshold breach event requiring response and notification.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceedanceSeverity rdf:type rdf:Property ;
    rdfs:label 'Exceedance Severity' ;
    rdfs:comment 'Classification of the severity of the threshold breach based on magnitude and duration. Minor: slight exceedance; Moderate: sustained exceedance; Major: significant breach; Critical: severe breach requiring immediate action.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgCo2EquivalentKg rdf:type rdf:Property ;
    rdfs:label 'Ghg Co2 Equivalent Kg' ;
    rdfs:comment 'The calculated CO2-equivalent mass in kilograms for this reading, derived by applying the GHG emission factor to the measured value. Used for carbon footprint reporting. Null for non-GHG parameters.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgEmissionFactor rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Factor' ;
    rdfs:comment 'The emission factor used to convert measured pollutant concentrations to GHG equivalent emissions (kg CO2e per unit). Used for carbon accounting and sustainability reporting. Null for non-GHG parameters.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The numeric value of the environmental parameter reading as captured by the sensor. Precision supports scientific measurement requirements.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Reference Number' ;
    rdfs:comment 'The unique reference number assigned by the regulatory authority upon receipt of the exceedance notification. Used for tracking correspondence and follow-up.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalActivityType rdf:type rdf:Property ;
    rdfs:label 'Operational Activity Type' ;
    rdfs:comment 'Description of the primary port operational activity occurring at the time of reading (e.g., vessel berthing, container handling, bulk cargo loading, dredging, bunkering). Used for source attribution and impact analysis.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterType rdf:type rdf:Property ;
    rdfs:label 'Parameter Type' ;
    rdfs:comment 'The type of environmental parameter being measured. Categories include air quality (PM2.5, PM10, NOx, SOx, CO, VOC), water quality (pH, turbidity, dissolved oxygen, hydrocarbon, heavy metals), noise level, and emissions. [ENUM-REF-CANDIDATE: air_quality_pm25|air_quality_pm10|air_quality_nox|air_quality_sox|air_quality_co|air_quality_voc|air_quality_ozone|water_quality_ph|water_quality_turbidity|water_quality_dissolved_oxygen|water_quality_hydrocarbon|water_quality_heavy_metals|water_quality_bod|water_quality_cod|noise_level_boundary|noise_level_source|emissions_co2|emissions_nox|emissions_sox|emissions_pm|emissions_voc — promote to reference product]' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'The exact date and time when the environmental parameter was measured by the sensor. This is the business event timestamp representing when the observation occurred in the real world.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Current status of the regulatory notification workflow for this exceedance event. Tracks progression from identification through authority acknowledgment.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relativeHumidityPercent rdf:type rdf:Property ;
    rdfs:label 'Relative Humidity Percent' ;
    rdfs:comment 'Relative humidity as a percentage at the time of reading. Influences particulate matter behavior and water quality parameters.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseActionTaken rdf:type rdf:Property ;
    rdfs:label 'Response Action Taken' ;
    rdfs:comment 'Description of the immediate corrective or mitigation actions taken in response to the threshold exceedance (e.g., equipment shutdown, dust suppression activated, vessel speed reduction, investigation initiated).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'The method by which the environmental sample was collected: continuous (real-time monitoring), periodic (scheduled intervals), grab sample (single point-in-time), or composite (averaged over period).' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Sensor Serial Number' ;
    rdfs:comment 'The manufacturer serial number of the specific sensor instrument that captured this reading. Used for traceability and maintenance history.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windSpeedMps rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Mps' ;
    rdfs:comment 'Wind speed in meters per second at the time of reading. Critical for interpreting air quality and emissions dispersion patterns.' ;
    rdfs:domain ind:EnvMonitoringReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmThresholdConfigured rdf:type rdf:Property ;
    rdfs:label 'Alarm Threshold Configured' ;
    rdfs:comment 'Flag indicating whether automated alarm thresholds have been configured for this monitoring station to trigger alerts when environmental parameters exceed acceptable limits. True if real-time alerting is enabled.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Annual Maintenance Cost' ;
    rdfs:comment 'Estimated or actual annual operational expenditure (OPEX) for maintaining the monitoring station, including calibration, repairs, consumables, and service contracts. Used for lifecycle cost analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Number' ;
    rdfs:comment 'Reference number of the most recent calibration certificate issued by the calibration laboratory or service provider. Used for audit trail and regulatory compliance verification.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Required interval in days between calibration events for the sensor equipment as specified by manufacturer guidelines, regulatory requirements, or ISO 14001 monitoring program. Used to schedule preventive maintenance.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current compliance status of the sensor calibration relative to the required calibration schedule. Indicates whether the station is operating within calibration validity period.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionIntervalMinutes rdf:type rdf:Property ;
    rdfs:label 'Data Collection Interval Minutes' ;
    rdfs:comment 'Frequency in minutes at which the monitoring station collects and records environmental measurements. Defines the temporal resolution of the monitoring data.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataTransmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Transmission Method' ;
    rdfs:comment 'Technical method by which the monitoring station transmits collected data to the central EMS (Environmental Monitoring System). Determines data availability latency and connectivity requirements.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationMeters rdf:type rdf:Property ;
    rdfs:label 'Elevation Meters' ;
    rdfs:comment 'Height above mean sea level in meters at which the monitoring station is installed. Critical for air quality and meteorological measurements where elevation affects readings.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Ghg Monitoring Flag' ;
    rdfs:comment 'Flag indicating whether this monitoring station measures greenhouse gas emissions (CO2, CH4, N2O) as part of the port\'s carbon footprint tracking and sustainability initiatives. True if station contributes to GHG inventory.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Compliance Flag' ;
    rdfs:comment 'Flag indicating whether this monitoring station is part of the port\'s ISO 14001 Environmental Management System certification scope and monitoring program. True if station data is used for ISO 14001 compliance demonstration.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date when the most recent calibration was performed on the sensor equipment. Used to determine calibration compliance status and schedule next calibration.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceContractReference rdf:type rdf:Property ;
    rdfs:label 'Maintenance Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the service contract or maintenance agreement covering this monitoring station. Used to track warranty coverage, service level agreements, and contractor obligations.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoredParameters rdf:type rdf:Property ;
    rdfs:label 'Monitored Parameters' ;
    rdfs:comment 'Comma-separated list of environmental parameters measured by this station (e.g., \'PM2.5, PM10, NO2, SO2, CO, O3\' for air quality; \'pH, DO, BOD, COD, TSS\' for water quality; \'LAeq, LAmax, LAmin\' for noise). Defines the station\'s measurement scope.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Calculated or scheduled date when the next calibration is due based on last calibration date and calibration frequency. Used for maintenance planning and compliance tracking.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisplayEnabled rdf:type rdf:Property ;
    rdfs:label 'Public Display Enabled' ;
    rdfs:comment 'Flag indicating whether data from this monitoring station is made available for public viewing through port community systems, websites, or public information displays. True if station data is part of environmental transparency initiatives.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Flag indicating whether data from this monitoring station must be included in mandatory regulatory reports to environmental authorities or port state control. True if station is part of compliance monitoring program.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'Name or identifier of the maintenance team, department, or contractor responsible for the upkeep, calibration, and operational management of this monitoring station. Used for work order assignment and accountability.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorManufacturer rdf:type rdf:Property ;
    rdfs:label 'Sensor Manufacturer' ;
    rdfs:comment 'Name of the manufacturer or vendor of the sensor equipment installed at the station. Used for warranty tracking, spare parts procurement, and technical support.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorModel rdf:type rdf:Property ;
    rdfs:label 'Sensor Model' ;
    rdfs:comment 'Specific model number or designation of the sensor equipment. Used for technical specifications lookup, calibration procedures, and replacement parts identification.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorType rdf:type rdf:Property ;
    rdfs:label 'Sensor Type' ;
    rdfs:comment 'Technical classification or model designation of the primary sensor equipment installed at the station (e.g., \'Continuous Ambient Air Quality Monitor\', \'Multi-parameter Water Quality Probe\', \'Class 1 Sound Level Meter\'). Used for maintenance planning and calibration scheduling.' ;
    rdfs:domain ind:EnvMonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationCode rdf:type rdf:Property ;
    rdfs:label 'Station Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the monitoring station for identification and reference in EMS (Environmental Monitoring System) and regulatory reporting. Format: PORT-TYPE-SEQUENCE (e.g., SYD-AQ-001 for Sydney Air Quality station 001).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationName rdf:type rdf:Property ;
    rdfs:label 'Station Name' ;
    rdfs:comment 'Human-readable descriptive name of the monitoring station indicating its location or purpose within the port precinct (e.g., \'Container Terminal 3 Air Quality Monitor\', \'Berth 12 Water Quality Sensor\').' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationType rdf:type rdf:Property ;
    rdfs:label 'Station Type' ;
    rdfs:comment 'Classification of the monitoring station based on the primary environmental parameter it measures. Determines the sensor suite and data collection protocols. [ENUM-REF-CANDIDATE: air_quality|water_quality|noise|emissions|weather|soil|radiation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeRuleId rdf:type rdf:Property ;
    rdfs:label 'Surcharge Rule Id' ;
    rdfs:comment 'Foreign key linking to tariff.surcharge_rule. Business justification: Carbon pricing and environmental levy programs require linking emission records to applicable surcharge rules for calculating environmental charges. Ports implementing carbon pricing schemes must trac' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurchargeRule .

ind:activityDataUnit rdf:type rdf:Property ;
    rdfs:label 'Activity Data Unit' ;
    rdfs:comment 'Unit of measure for the activity data value (e.g., liters, kWh, tonnes, hours). [ENUM-REF-CANDIDATE: liters|gallons|kwh|mwh|kg|tonnes|hours|km|nautical_miles — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityDataValue rdf:type rdf:Property ;
    rdfs:label 'Activity Data Value' ;
    rdfs:comment 'Quantitative measure of the activity that generated emissions (e.g., fuel consumed, energy used, distance traveled, operating hours).' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineComparisonFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Comparison Flag' ;
    rdfs:comment 'Indicates whether this emission record is part of a baseline year used for tracking emission reduction targets.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Date and time when the emission calculation was performed.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ch4Tonnes rdf:type rdf:Property ;
    rdfs:label 'Ch4 Tonnes' ;
    rdfs:comment 'Mass of methane emissions in metric tonnes.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2EquivalentTonnes rdf:type rdf:Property ;
    rdfs:label 'Co2 Equivalent Tonnes' ;
    rdfs:comment 'Calculated greenhouse gas emissions expressed in metric tonnes of CO2 equivalent, representing the global warming potential of all GHGs emitted.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2Tonnes rdf:type rdf:Property ;
    rdfs:label 'Co2 Tonnes' ;
    rdfs:comment 'Mass of carbon dioxide emissions in metric tonnes.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceYear rdf:type rdf:Property ;
    rdfs:label 'Compliance Year' ;
    rdfs:comment 'Calendar year for which this emission record contributes to regulatory compliance reporting.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserCode rdf:type rdf:Property ;
    rdfs:label 'Created By User Code' ;
    rdfs:comment 'Reference to the user who created this emission record.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Method by which the activity data was collected (e.g., automated sensor, manual reading, invoice-based, estimated).' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityRating rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rating' ;
    rdfs:comment 'Assessment of the quality and reliability of the underlying activity data and emission factors used in the calculation.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorSource rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Source' ;
    rdfs:comment 'Source or reference for the emission factor used in the calculation (e.g., IPCC, DEFRA, EPA, local grid factor).' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorUnit rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Unit' ;
    rdfs:comment 'Unit of measure for the emission factor (e.g., kg CO2e per liter, kg CO2e per kWh).' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorValue rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Value' ;
    rdfs:comment 'Emission factor applied to convert activity data to CO2-equivalent emissions, expressed as mass of CO2e per unit of activity.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Emission Record Number' ;
    rdfs:comment 'Business-facing unique reference number for the emission record, used for tracking and reporting purposes.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionScope rdf:type rdf:Property ;
    rdfs:label 'Emission Scope' ;
    rdfs:comment 'GHG Protocol scope classification: Scope 1 (direct emissions from owned/controlled sources), Scope 2 (indirect emissions from purchased energy), or Scope 3 (other indirect emissions in value chain).' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceCategory rdf:type rdf:Property ;
    rdfs:label 'Emission Source Category' ;
    rdfs:comment 'Category of the emission source within the port operations. [ENUM-REF-CANDIDATE: vessel_at_berth|cargo_handling_equipment|port_vehicles|utilities|shore_power|lighting|hvac|refrigeration|rail_operations|truck_operations|employee_commute|waste_disposal — promote to reference product]' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Emission Source Description' ;
    rdfs:comment 'Detailed description of the specific emission source, including equipment type, location, or operational context.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Code' ;
    rdfs:comment 'Reference to the user who last modified this emission record.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:n2oTonnes rdf:type rdf:Property ;
    rdfs:label 'N2o Tonnes' ;
    rdfs:comment 'Mass of nitrous oxide emissions in metric tonnes.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Offset Applied Flag' ;
    rdfs:comment 'Indicates whether carbon offsets or credits have been applied to neutralize the emissions recorded in this entry.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsetCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Offset Certificate Reference' ;
    rdfs:comment 'Reference number or identifier of the carbon offset certificate applied to this emission record, if applicable.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the reporting period for which this emission record applies.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the reporting period for which this emission record applies.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uncertaintyPercentage rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Percentage' ;
    rdfs:comment 'Estimated uncertainty or margin of error in the emission calculation, expressed as a percentage.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Certificate Number' ;
    rdfs:comment 'Reference number of the verification certificate issued for this emission record, if applicable.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Name of the organization or individual who verified the emission record.' ;
    rdfs:domain ind:GhgEmissionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Linked Risk Assessment Id' ;
    rdfs:comment 'Identifier of the formal risk assessment document or record in which this hazard was identified and evaluated. Supports traceability between hazard register and risk assessment processes.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:primaryHazardOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Hazard Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedWorkerGroups rdf:type rdf:Property ;
    rdfs:label 'Affected Worker Groups' ;
    rdfs:comment 'Categories of workers, contractors, or visitors who may be exposed to this hazard (e.g., stevedores, crane operators, truck drivers, marine pilots, maintenance technicians, office staff, contractors, visitors).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedActivity rdf:type rdf:Property ;
    rdfs:label 'Associated Activity' ;
    rdfs:comment 'Primary work activity or operation during which the hazard is present or most likely to cause harm (e.g., container lifting operations, vessel mooring, cargo lashing, equipment maintenance, truck loading).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consequenceSeverity rdf:type rdf:Property ;
    rdfs:label 'Consequence Severity' ;
    rdfs:comment 'Rated severity of the potential consequence using a five-point scale: catastrophic (fatality or permanent total disability), major (serious injury requiring hospitalization), moderate (medical treatment injury), minor (first aid injury), negligible (no injury).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Control Hierarchy Level' ;
    rdfs:comment 'Highest level of control in the hierarchy of controls currently applied to this hazard. Indicates the effectiveness tier of the primary control strategy per ISO 45001 and ILO guidance.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasureSummary rdf:type rdf:Property ;
    rdfs:label 'Control Measure Summary' ;
    rdfs:comment 'Summary of existing control measures currently in place to eliminate or reduce the hazard, following the hierarchy of controls: elimination, substitution, engineering controls, administrative controls, and personal protective equipment (PPE).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseProcedure rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Procedure' ;
    rdfs:comment 'Reference to the emergency response procedure or contingency plan applicable if this hazard results in an incident (e.g., spill response plan, fire evacuation procedure, medical emergency protocol, man overboard procedure).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAspect rdf:type rdf:Property ;
    rdfs:label 'Environmental Aspect' ;
    rdfs:comment 'Description of any environmental aspect associated with this hazard (e.g., potential for air emissions, water pollution, soil contamination, noise pollution, waste generation). Links safety and environmental management per ISO 14001.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Category' ;
    rdfs:comment 'Secondary classification providing more granular categorization within the hazard type (e.g., for physical: struck-by, caught-in, fall from height, electrical; for chemical: toxic, corrosive, flammable).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCode rdf:type rdf:Property ;
    rdfs:label 'Hazard Code' ;
    rdfs:comment 'Unique business identifier for the hazard following the format HAZ-[AREA]-[SEQUENCE]. Used for cross-referencing in risk assessments, safety inspections, and permit-to-work documentation.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Detailed description of the hazard including the nature of the danger, how it manifests, and under what conditions it presents a risk to workers, contractors, or visitors.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardName rdf:type rdf:Property ;
    rdfs:label 'Hazard Name' ;
    rdfs:comment 'Short descriptive name of the hazard for quick identification and reporting purposes.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Hazard Register Status' ;
    rdfs:comment 'Current lifecycle status of the hazard record: active (hazard present and managed), under review (assessment in progress), controls pending (awaiting implementation of additional controls), mitigated (hazard eliminated or reduced to acceptable level), archived (no longer applicable).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'Primary classification of the hazard according to occupational health and safety taxonomy: physical (noise, vibration, moving machinery, falling objects), chemical (fumes, dust, hazardous substances), biological (bacteria, viruses, mold), ergonomic (repetitive strain, manual handling, awkward postures), or psychosocial (work stress, fatigue, violence).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'Date when the hazard was first identified and recorded in the register. Establishes the baseline for hazard lifecycle tracking and review scheduling.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identification Method' ;
    rdfs:comment 'Method or process through which the hazard was identified (e.g., routine safety inspection, incident investigation, formal risk assessment, worker consultation, internal audit, job safety analysis, change management review). [ENUM-REF-CANDIDATE: safety_inspection|incident_investigation|risk_assessment|worker_consultation|audit|job_safety_analysis|change_management|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentHistoryCount rdf:type rdf:Property ;
    rdfs:label 'Incident History Count' ;
    rdfs:comment 'Number of recorded incidents, near-misses, or injuries associated with this hazard over the past 12 months. Used to identify high-frequency hazards requiring enhanced controls.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'Initial risk level calculated from consequence severity and likelihood before any control measures are applied. Represents the raw risk exposure and drives control measure prioritization.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Probability that the hazard will result in harm under current conditions and controls, using a five-point scale: almost certain (expected to occur in most circumstances), likely (will probably occur), possible (might occur), unlikely (could occur but not expected), rare (may occur only in exceptional circumstances).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Required' ;
    rdfs:comment 'Indicates whether work activities involving this hazard require a formal permit-to-work authorization under the ports PTW system. True for high-risk activities such as hot work, confined space entry, work at height, or energized electrical work.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:potentialConsequence rdf:type rdf:Property ;
    rdfs:label 'Potential Consequence' ;
    rdfs:comment 'Description of the potential harm or adverse health effect that could result from exposure to or interaction with the hazard, including severity of injury, illness, or environmental impact.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Specification of personal protective equipment required when working in the presence of this hazard (e.g., hard hat, safety boots, high-visibility vest, hearing protection, respiratory protection, fall arrest harness).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Risk level remaining after all current control measures have been applied. Determines whether additional controls are required and whether the risk is acceptable under the organizations risk tolerance criteria.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAcceptabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptability Status' ;
    rdfs:comment 'Determination of whether the residual risk level is acceptable under the organizations Occupational Health and Safety (OHS) risk criteria and ALARP (As Low As Reasonably Practicable) principles.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signageRequired rdf:type rdf:Property ;
    rdfs:label 'Signage Required' ;
    rdfs:comment 'Indicates whether safety signage or warning notices are required at the hazard location to alert workers and visitors. True for hazards requiring visual warnings per ISO 7010 safety signs standard.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificLocation rdf:type rdf:Property ;
    rdfs:label 'Specific Location' ;
    rdfs:comment 'Detailed location description within the operational area (e.g., Berth 3 Apron, Container Stack Row 12, Gate Lane 5, Rail Siding 2). Provides precise geographic context for hazard identification and control implementation.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequirement rdf:type rdf:Property ;
    rdfs:label 'Training Requirement' ;
    rdfs:comment 'Mandatory training or competency requirements for workers exposed to this hazard (e.g., confined space entry training, dangerous goods handling certification, crane operator license, first aid certification).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoComplianceRegisterId rdf:type rdf:Property ;
    rdfs:label 'Iso Compliance Register Id' ;
    rdfs:comment 'Unique identifier for the ISO compliance register entry. Primary key for tracking individual compliance obligations against ISO 14001 (Environmental Management) and ISO 45001 (Occupational Health and Safety) standards.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsoComplianceRegister .

ind:applicableLocations rdf:type rdf:Property ;
    rdfs:label 'Applicable Locations' ;
    rdfs:comment 'Comma-separated list of port locations, terminals, or facilities to which this compliance obligation applies. Enables location-specific compliance tracking for multi-site port operations.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProcesses rdf:type rdf:Property ;
    rdfs:label 'Applicable Processes' ;
    rdfs:comment 'Comma-separated list of business processes or operational activities to which this compliance obligation applies (e.g., \'Container Handling\', \'Vessel Berthing\', \'Fuel Storage\', \'Waste Management\'). Enables process-specific compliance tracking.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the accredited certification body that audits and certifies the ports ISO 14001 or ISO 45001 management system (e.g., \'Bureau Veritas\', \'Lloyd\'s Register\', \'DNV GL\'). Relevant for external audit tracking.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuousImprovementInitiative rdf:type rdf:Property ;
    rdfs:label 'Continuous Improvement Initiative' ;
    rdfs:comment 'Description of any continuous improvement initiative or project linked to enhancing conformance or performance related to this ISO obligation. Aligns with the ISO requirement for continual improvement.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Summary of the corrective action plan in place to address any non-conformance or gap related to this obligation. Captures planned actions, timelines, and responsible parties.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentedInformationReference rdf:type rdf:Property ;
    rdfs:label 'Documented Information Reference' ;
    rdfs:comment 'Reference to the documented information (procedures, work instructions, forms, records) that supports this compliance obligation. ISO standards require documented information to be maintained and controlled.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Reference identifier or location of the evidence supporting compliance (e.g., document control number, file path, database record ID, inspection report number). Enables auditors to trace and verify conformance claims.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceType rdf:type rdf:Property ;
    rdfs:label 'Evidence Type' ;
    rdfs:comment 'The type of evidence used to demonstrate conformance with the ISO obligation. Documented procedures, records, direct observations, staff interviews, environmental/safety measurements, inspection reports, and audit findings are common evidence types. [ENUM-REF-CANDIDATE: documented_procedure|record|observation|interview|measurement|inspection_report|audit_finding — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditReference rdf:type rdf:Property ;
    rdfs:label 'External Audit Reference' ;
    rdfs:comment 'Reference number or identifier of the most recent external certification audit or surveillance audit that assessed this compliance obligation. Used for traceability to certification body findings.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoClauseReference rdf:type rdf:Property ;
    rdfs:label 'Iso Clause Reference' ;
    rdfs:comment 'The specific clause or section reference within the ISO standard that defines this compliance obligation (e.g., \'4.3.2\', \'6.1.2.1\', \'9.1.1\'). Used to trace requirements back to the authoritative standard text.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoStandardCode rdf:type rdf:Property ;
    rdfs:label 'Iso Standard Code' ;
    rdfs:comment 'The ISO standard to which this compliance obligation applies. ISO 14001 covers Environmental Management Systems; ISO 45001 covers Occupational Health and Safety Management Systems.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiLinked rdf:type rdf:Property ;
    rdfs:label 'Kpi Linked' ;
    rdfs:comment 'Name or identifier of the Key Performance Indicator (KPI) used to monitor performance related to this compliance obligation (e.g., \'Environmental Incident Rate\', \'Lost Time Injury Frequency Rate (LTIFR)\', \'Waste Diversion Rate\').' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Audit Outcome' ;
    rdfs:comment 'Outcome of the most recent audit or assessment of this obligation. Conformance indicates no issues found; minor/major non-conformance indicates gaps requiring corrective action; observation indicates improvement opportunity; not audited indicates no recent assessment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Last Updated By User Code' ;
    rdfs:comment 'Identifier of the user who last updated this compliance register entry. Links to workforce or user management data for accountability and audit trail.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Requirement Flag' ;
    rdfs:comment 'Indicates whether this ISO obligation is also a legal or regulatory requirement in the ports jurisdiction (True) or is purely a voluntary management system standard (False). Legal obligations carry additional compliance risk.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementReviewDate rdf:type rdf:Property ;
    rdfs:label 'Management Review Date' ;
    rdfs:comment 'Date when this compliance obligation was last reviewed by top management as part of the ISO management system review process. ISO standards require periodic management review of system performance.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Management Review Outcome' ;
    rdfs:comment 'Summary of management review decisions or actions related to this compliance obligation. Captures strategic direction, resource allocation decisions, or system improvement initiatives.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationCategory rdf:type rdf:Property ;
    rdfs:label 'Obligation Category' ;
    rdfs:comment 'High-level category grouping of the ISO obligation based on the standard structure. Aligns with the major sections of ISO 14001 and ISO 45001 (Context, Leadership, Planning, Support, Operation, Performance Evaluation, Improvement). [ENUM-REF-CANDIDATE: context_of_organization|leadership|planning|support|operation|performance_evaluation|improvement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationTitle rdf:type rdf:Property ;
    rdfs:label 'Obligation Title' ;
    rdfs:comment 'Short descriptive title of the compliance obligation for quick identification and reporting (e.g., \'Environmental Aspects Identification\', \'Hazard Identification and Risk Assessment\', \'Management Review\').' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Target date for closing any open non-conformance or gap related to this compliance obligation. Used to track progress on corrective actions and ensure timely resolution.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingReference rdf:type rdf:Property ;
    rdfs:label 'Training Reference' ;
    rdfs:comment 'Reference to the training program, course code, or learning module that addresses competency requirements for this compliance obligation. Enables linkage to workforce training records.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether specific training is required for personnel to ensure conformance with this ISO obligation (True) or not (False). Used to trigger competency and awareness programs.' ;
    rdfs:domain ind:IsoComplianceRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receptionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Reception Facility Id' ;
    rdfs:comment 'Reference to the specific port reception facility that accepted the waste.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteReceptionFacility .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Method used to collect waste from the vessel: truck, barge, pipeline, container, or manual handling.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationFlag rdf:type rdf:Property ;
    rdfs:label 'Contamination Flag' ;
    rdfs:comment 'Indicates whether the waste was found to be contaminated with substances not declared in the waste declaration.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contaminationNotes rdf:type rdf:Property ;
    rdfs:label 'Contamination Notes' ;
    rdfs:comment 'Details of any contamination discovered, including substances identified and corrective actions taken.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Certificate Number' ;
    rdfs:comment 'Certificate or consignment note number issued by the disposal facility confirming proper waste handling and disposal.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalLocation rdf:type rdf:Property ;
    rdfs:label 'Disposal Location' ;
    rdfs:comment 'Name or address of the final disposal or treatment facility where the waste was processed.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousWasteFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Flag' ;
    rdfs:comment 'Indicates whether the waste is classified as hazardous under IMDG Code or national hazardous waste regulations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionConducted rdf:type rdf:Property ;
    rdfs:label 'Inspection Conducted' ;
    rdfs:comment 'Indicates whether a physical inspection of the waste was conducted by port environmental officers or PSC inspectors.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the waste inspection was conducted.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nonComplianceDetails rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Details' ;
    rdfs:comment 'Description of any MARPOL non-compliance issues identified, including regulation breached and corrective actions required.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prfReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Prf Receipt Number' ;
    rdfs:comment 'Unique receipt number issued by the Port Reception Facility upon waste acceptance. Required for MARPOL Annex compliance documentation.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'The quantity of waste received from the vessel, measured in the unit specified in quantity_unit.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reception Timestamp' ;
    rdfs:comment 'Date and time when the waste was received at the port reception facility. This is the principal business event timestamp for MARPOL compliance tracking.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Reference number assigned by the regulatory authority upon submission of the waste record.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date when the waste record was submitted to the regulatory authority for compliance reporting.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required' ;
    rdfs:comment 'Indicates whether this waste record must be reported to maritime or environmental regulatory authorities.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Waste Category Code' ;
    rdfs:comment 'Detailed waste category code as per MARPOL waste classification system (e.g., A01 for oily bilge water, E01 for plastics).' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDeclarationReceived rdf:type rdf:Property ;
    rdfs:label 'Waste Declaration Received' ;
    rdfs:comment 'Indicates whether the vessel provided a formal waste declaration (as required under MARPOL) prior to or upon arrival.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteDeclarationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waste Declaration Timestamp' ;
    rdfs:comment 'Date and time when the vessel submitted the waste declaration to the port authority.' ;
    rdfs:domain ind:MarpolWasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryOhsInjuredPartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ohs Injured Party Employee Id' ;
    rdfs:comment 'Employee identifier of the injured party if they are a port employee. Null for contractor, visitor, or third-party personnel. Links to Oracle HCM Cloud workforce records for HR and workers compensation processing.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'Anatomical body part(s) injured in the incident (e.g., hand, back, head, leg, multiple). Null for non-injury incidents. Used for injury pattern analysis and PPE effectiveness assessment. Follows ILO classification of body parts.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysLost rdf:type rdf:Property ;
    rdfs:label 'Days Lost' ;
    rdfs:comment 'Number of scheduled workdays lost due to the injury, excluding the day of injury. Zero for non-injury incidents or injuries with no time loss. Used to calculate Lost Time Injury Frequency Rate (LTIFR) and Total Recordable Injury Frequency Rate (TRIFR) KPIs.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysRestricted rdf:type rdf:Property ;
    rdfs:label 'Days Restricted' ;
    rdfs:comment 'Number of scheduled workdays the injured party was on restricted or light duty following the injury. Zero if no work restrictions were imposed. Used for OSHA DART (Days Away, Restricted, or Transferred) rate calculation.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalConditions rdf:type rdf:Property ;
    rdfs:label 'Environmental Conditions' ;
    rdfs:comment 'Description of environmental conditions at the time of the incident, such as weather (rain, fog, wind), lighting (daylight, night, poor visibility), temperature, or noise levels. Relevant for outdoor port operations and vessel-related incidents.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentInvolved rdf:type rdf:Property ;
    rdfs:label 'Equipment Involved' ;
    rdfs:comment 'Description or identifier of equipment, machinery, or assets involved in the incident (e.g., RTG crane, forklift, conveyor, vessel, container). Links to Maximo Asset Management for equipment history and maintenance correlation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDatetime rdf:type rdf:Property ;
    rdfs:label 'Incident Datetime' ;
    rdfs:comment 'The precise date and time when the OHS incident or observation occurred. This is the real-world event timestamp, distinct from reporting or recording timestamps. Critical for shift analysis, operational correlation, and regulatory reporting.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-visible unique incident reference number used for tracking, reporting, and communication with regulatory authorities and stakeholders. Format: INC-YYYYMMDD sequence.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentSeverity rdf:type rdf:Property ;
    rdfs:label 'Incident Severity' ;
    rdfs:comment 'Severity classification of the incident: fatal (death), major (permanent disability or hospitalization >24h), serious (medical treatment required), minor (restricted work), first_aid (first aid treatment only), observation (no harm occurred). Aligns with ISPS and national maritime safety authority severity scales.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current workflow state of the incident record: reported (initial notification), under_investigation (active investigation in progress), pending_review (investigation complete awaiting approval), closed (finalized and archived), reopened (closed incident requiring further investigation).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyName rdf:type rdf:Property ;
    rdfs:label 'Injured Party Name' ;
    rdfs:comment 'Full legal name of the person injured or affected by the incident. Null for near-miss, unsafe condition, or positive observation events where no person was harmed. Required for injury incidents per ISO 45001 and national OHS regulations.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyRole rdf:type rdf:Property ;
    rdfs:label 'Injured Party Role' ;
    rdfs:comment 'Employment or role classification of the injured party: port_employee (direct hire), contractor (third-party service provider), stevedore (cargo handling worker), truck_driver (road transport operator), vessel_crew (ship personnel), visitor (guest or vendor), pilot (marine pilot), other. Used for workforce safety segmentation and liability determination. [ENUM-REF-CANDIDATE: port_employee|contractor|stevedore|truck_driver|vessel_crew|visitor|pilot|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryNature rdf:type rdf:Property ;
    rdfs:label 'Injury Nature' ;
    rdfs:comment 'Type of physical injury sustained (e.g., laceration, fracture, sprain, burn, contusion, amputation, multiple injuries). Null for non-injury incidents. Follows ILO injury classification for international comparability.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'Reference number of the insurance claim filed for this incident, if applicable. Links to Protection and Indemnity (P&I) club or workers compensation insurer records. Null if no claim was filed.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsSecurityRelevant rdf:type rdf:Property ;
    rdfs:label 'Isps Security Relevant' ;
    rdfs:comment 'Indicates whether the incident has security implications under the ISPS Code (e.g., unauthorized access, sabotage, security breach, terrorism-related). True if the incident must be reported to port security and national maritime security authority. False for routine OHS incidents.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Summary of key lessons learned from the incident investigation, intended for sharing across the organization and industry to improve safety culture and prevent similar incidents. May be published in safety bulletins or toolbox talks.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalTreatmentRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Treatment Required' ;
    rdfs:comment 'Indicates whether the injured party required medical treatment beyond first aid. True if medical professional intervention was needed (clinic, hospital, paramedic). False for first aid only or no treatment. Used for OSHA recordability and lost time injury (LTI) determination.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActions rdf:type rdf:Property ;
    rdfs:label 'Preventive Actions' ;
    rdfs:comment 'Description of preventive actions planned to address similar hazards across the port and prevent similar incidents in other areas. Broader in scope than corrective actions, targeting systemic improvements.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which the incident was formally notified to the relevant regulatory authority. Null if no notification was required. Used to verify compliance with mandatory reporting timeframes (typically 24-48 hours for major incidents).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reporterContactPhone rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact Phone' ;
    rdfs:comment 'Contact phone number of the incident reporter for follow-up investigation and clarification. Required for external reporters (contractors, visitors) who may not have employee records.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterName rdf:type rdf:Property ;
    rdfs:label 'Reporter Name' ;
    rdfs:comment 'Full name of the person who reported the incident. May be the injured party, a witness, a supervisor, or a safety officer. Required for all incident types to establish accountability and enable follow-up.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'The structured root cause analysis methodology applied during investigation: five_whys (iterative questioning), fishbone (Ishikawa diagram), fault_tree (logical fault tree analysis), bow_tie (barrier analysis), tripod_beta (incident causation model), other (alternative method), none (no formal RCA conducted). [ENUM-REF-CANDIDATE: five_whys|fishbone|fault_tree|bow_tie|tripod_beta|other|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseFindings rdf:type rdf:Property ;
    rdfs:label 'Root Cause Findings' ;
    rdfs:comment 'Summary of the root cause(s) identified through formal investigation, including systemic, organizational, and human factors. Null if investigation is incomplete or not required. Used to drive corrective and preventive actions (CAPA).' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'The work shift during which the incident occurred: day (morning/afternoon), night (overnight), swing (evening), other. Used for shift-based risk analysis and fatigue correlation studies.' ;
    rdfs:domain ind:OhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessNames rdf:type rdf:Property ;
    rdfs:label 'Witness Names' ;
    rdfs:comment 'Comma-separated list of names of witnesses to the incident. Used for investigation interviews and evidence corroboration. May be redacted in public reports per privacy regulations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ohsInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Ohs Investigation Id' ;
    rdfs:comment 'Unique identifier for the OHS investigation record. Primary key.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOhsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ohs Employee Id' ;
    rdfs:comment 'Employee ID of the lead investigator responsible for coordinating the investigation and ensuring completion. Must be a qualified safety professional.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaTrackingReference rdf:type rdf:Property ;
    rdfs:label 'Capa Tracking Reference' ;
    rdfs:comment 'Reference number or identifier linking this investigation to the CAPA tracking system where corrective and preventive actions are monitored through to closure.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactorsEnvironmental rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors Environmental' ;
    rdfs:comment 'Environmental conditions that contributed to the incident, such as adverse weather, poor lighting, noise levels, temperature extremes, or hazardous atmosphere.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactorsEquipment rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors Equipment' ;
    rdfs:comment 'Equipment or asset-related factors that contributed to the incident, including equipment failure, design deficiency, inadequate maintenance, or missing safety devices.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactorsHuman rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors Human' ;
    rdfs:comment 'Human factors that contributed to the incident, such as inadequate training, fatigue, communication breakdown, procedural non-compliance, or human error. Analyzed without assigning blame.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactorsProcedural rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors Procedural' ;
    rdfs:comment 'Procedural or organizational factors that contributed to the incident, including inadequate procedures, lack of risk assessment, insufficient supervision, or systemic management failures.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsAssigned rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Assigned' ;
    rdfs:comment 'Corrective actions assigned to address the root cause and prevent recurrence. Each action should specify the action description, responsible party, and target completion date.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'Estimated total cost impact of the incident, including direct costs (medical, equipment damage, cleanup) and indirect costs (lost productivity, regulatory penalties, reputation). Expressed in the port\'s operating currency.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalConsultantEngaged rdf:type rdf:Property ;
    rdfs:label 'External Consultant Engaged' ;
    rdfs:comment 'Indicates whether external safety consultants or subject matter experts were engaged to support the investigation. Common for complex incidents or specialized technical investigations.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalConsultantName rdf:type rdf:Property ;
    rdfs:label 'External Consultant Name' ;
    rdfs:comment 'Name of the external consulting firm or independent expert engaged to support the investigation.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Actions Taken' ;
    rdfs:comment 'Immediate corrective actions taken at the time of or shortly after the incident to prevent recurrence and secure the scene. Includes emergency response, area isolation, and interim controls.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentSummary rdf:type rdf:Property ;
    rdfs:label 'Incident Summary' ;
    rdfs:comment 'Brief narrative summary of the incident under investigation, including what happened, where, when, and who was involved. Provides context for the investigation.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the formal investigation was initiated. Regulatory requirements often mandate investigation commencement within specific timeframes after incident occurrence.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationDurationDays rdf:type rdf:Property ;
    rdfs:label 'Investigation Duration Days' ;
    rdfs:comment 'Total number of calendar days from investigation initiation to completion. Used to track investigation efficiency and identify process improvement opportunities.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationFindings rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings' ;
    rdfs:comment 'Detailed findings from the investigation, including evidence collected, witness statements analyzed, and observations made during site inspections and document reviews.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Externally-visible unique investigation reference number assigned by the safety management system. Format: INV-YYYY-NNNNNN.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationPriority rdf:type rdf:Property ;
    rdfs:label 'Investigation Priority' ;
    rdfs:comment 'Priority level assigned based on incident severity, potential consequences, and regulatory requirements. Determines resource allocation and completion timeline.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationReportLocation rdf:type rdf:Property ;
    rdfs:label 'Investigation Report Location' ;
    rdfs:comment 'File path or document management system reference where the complete investigation report is stored. Ensures traceability and supports audit requirements.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Investigation Team Members' ;
    rdfs:comment 'Comma-separated list of employee IDs representing the investigation team. May include safety officers, supervisors, technical experts, worker representatives, and external consultants.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of investigation depth and methodology. Determines the level of analysis required based on incident severity and regulatory requirements.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearnedDisseminationDate rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned Dissemination Date' ;
    rdfs:comment 'Date when lessons learned were disseminated to relevant stakeholders through safety bulletins, toolbox talks, training sessions, or organizational communications.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lessonsLearnedDocumented rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned Documented' ;
    rdfs:comment 'Indicates whether lessons learned from the investigation have been formally documented for organizational learning and knowledge sharing.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lessonsLearnedSummary rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned Summary' ;
    rdfs:comment 'Summary of key lessons learned from the investigation, including insights into systemic weaknesses, effective controls, and recommendations for organizational improvement.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionsAssigned rdf:type rdf:Property ;
    rdfs:label 'Preventive Actions Assigned' ;
    rdfs:comment 'Preventive actions assigned to address contributing factors and reduce the likelihood of similar incidents across the organization. May include systemic improvements, training programs, or policy changes.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcaMethodology rdf:type rdf:Property ;
    rdfs:label 'Rca Methodology' ;
    rdfs:comment 'Structured methodology applied for root cause analysis. Common methods include Five Whys, Fishbone (Ishikawa), Fault Tree Analysis, Bow-Tie, Tripod Beta, ICAM, and TapRoot. [ENUM-REF-CANDIDATE: five_whys|fishbone_ishikawa|fault_tree_analysis|bow_tie|tripod_beta|icam|taproot — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Status' ;
    rdfs:comment 'Status of regulatory submission for incidents requiring external reporting. Tracks the submission lifecycle from preparation through regulatory acceptance. [ENUM-REF-CANDIDATE: not_required|pending|submitted|acknowledged|under_review|accepted|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenedDate rdf:type rdf:Property ;
    rdfs:label 'Reopened Date' ;
    rdfs:comment 'Date when the investigation was reopened. Null if the investigation has never been reopened.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reopenedFlag rdf:type rdf:Property ;
    rdfs:label 'Reopened Flag' ;
    rdfs:comment 'Indicates whether the investigation was reopened after initial closure due to new evidence, recurring incidents, or regulatory directive.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reopenedReason rdf:type rdf:Property ;
    rdfs:label 'Reopened Reason' ;
    rdfs:comment 'Explanation of why the investigation was reopened, including new evidence discovered, similar incident recurrence, or regulatory request for additional analysis.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseIdentified rdf:type rdf:Property ;
    rdfs:label 'Root Cause Identified' ;
    rdfs:comment 'Primary root cause identified through the RCA methodology. Describes the fundamental reason the incident occurred, addressing underlying systemic issues rather than immediate symptoms.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerRepresentativeInvolved rdf:type rdf:Property ;
    rdfs:label 'Worker Representative Involved' ;
    rdfs:comment 'Indicates whether worker representatives or union safety delegates participated in the investigation, as required by ISO 45001 and ILO Maritime Labour Convention for worker consultation.' ;
    rdfs:domain ind:OhsInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryPermitEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Permit Employee Id' ;
    rdfs:comment 'Identifier of the authorized person (typically safety officer, supervisor, or port authority representative) who issued and approved this permit.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPermitClosureVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Permit Closure Verified By Employee Id' ;
    rdfs:comment 'Identifier of the authorized person (typically safety officer or supervisor) who inspected the work site and verified that work is complete, area is safe, and all equipment/materials have been removed before closing the permit.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizedWorkerNames rdf:type rdf:Property ;
    rdfs:label 'Authorized Worker Names' ;
    rdfs:comment 'Comma-separated list of names of all workers authorized to perform work under this permit. Only listed individuals may participate in the permitted activity.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureConfirmationNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Confirmation Notes' ;
    rdfs:comment 'Notes recorded during permit closure inspection confirming work completion, site restoration, removal of hazards, and any observations or follow-up actions required.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerifiedByName rdf:type rdf:Property ;
    rdfs:label 'Closure Verified By Name' ;
    rdfs:comment 'Full name of the authorized person who verified permit closure.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Competency Verification Flag' ;
    rdfs:comment 'Indicates whether the competency and training certifications of all authorized workers have been verified and confirmed as current and appropriate for the permitted work type.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireWatchDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Fire Watch Duration Minutes' ;
    rdfs:comment 'Required duration in minutes that fire watch must be maintained after completion of hot work (typically 30-60 minutes depending on risk assessment).' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireWatchRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fire Watch Required Flag' ;
    rdfs:comment 'Indicates whether a dedicated fire watch person must be present during and after hot work activities to monitor for ignition sources and respond to fire emergencies.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gasTestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gas Test Required Flag' ;
    rdfs:comment 'Indicates whether atmospheric gas testing is mandatory before and during the work (typically required for confined space entry, hot work in enclosed areas, or areas with potential toxic/flammable gas exposure).' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gasTestResults rdf:type rdf:Property ;
    rdfs:label 'Gas Test Results' ;
    rdfs:comment 'Recorded results of atmospheric gas testing including oxygen level (%), lower explosive limit (LEL %), carbon monoxide (CO ppm), hydrogen sulfide (H2S ppm), and other relevant gas concentrations. Includes timestamp of each test.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentOccurredFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Occurred Flag' ;
    rdfs:comment 'Indicates whether any safety incident, near-miss, or environmental event occurred during the execution of this permitted work.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Reference Number' ;
    rdfs:comment 'Reference number of the associated incident report if an incident occurred during the permitted work. Links to the incident management system.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Isolation Certificate Reference' ;
    rdfs:comment 'Reference number or identifier of the associated isolation certificate or lockout/tagout (LOTO) certificate confirming that energy sources have been properly isolated and secured.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Isolation Required Flag' ;
    rdfs:comment 'Indicates whether energy isolation (electrical, mechanical, hydraulic, pneumatic) or lockout/tagout (LOTO) procedures are required before work can commence.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitExtensionCount rdf:type rdf:Property ;
    rdfs:label 'Permit Extension Count' ;
    rdfs:comment 'Number of times this permit has been extended beyond its original validity period. Multiple extensions may indicate scope creep or inadequate planning.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppeRequired rdf:type rdf:Property ;
    rdfs:label 'Ppe Required' ;
    rdfs:comment 'Specification of all personal protective equipment that workers must wear during the permitted activity (e.g., hard hat, safety glasses, gloves, respirator, harness, steel-toed boots, high-visibility vest).' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether this permit requires notification to external regulatory authorities (e.g., port state control, maritime safety authority, environmental agency) due to the nature or location of the work.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestingSupervisorName rdf:type rdf:Property ;
    rdfs:label 'Requesting Supervisor Name' ;
    rdfs:comment 'Full name of the supervisor responsible for the work crew.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPrecautionsSpecified rdf:type rdf:Property ;
    rdfs:label 'Safety Precautions Specified' ;
    rdfs:comment 'Comprehensive list of mandatory safety precautions, controls, and protective measures that must be in place before and during the permitted work (e.g., fire extinguisher on site, ventilation equipment, fall protection, lockout/tagout procedures, gas monitoring).' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolboxTalkConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Toolbox Talk Conducted Flag' ;
    rdfs:comment 'Indicates whether a pre-work safety briefing (toolbox talk) was conducted with the work crew covering hazards, controls, emergency procedures, and permit conditions.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toolboxTalkTimestamp rdf:type rdf:Property ;
    rdfs:label 'Toolbox Talk Timestamp' ;
    rdfs:comment 'Date and time when the pre-work safety briefing (toolbox talk) was conducted. Aligns with yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valid From Timestamp' ;
    rdfs:comment 'Date and time when this permit becomes effective and work is authorized to commence. Aligns with yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validUntilTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valid Until Timestamp' ;
    rdfs:comment 'Date and time when this permit expires and work must cease unless permit is renewed or extended. Aligns with yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workAreaCode rdf:type rdf:Property ;
    rdfs:label 'Work Area Code' ;
    rdfs:comment 'Standardized code identifying the operational area or zone where work will occur, aligned with port facility layout and safety zone classifications.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCrewSize rdf:type rdf:Property ;
    rdfs:label 'Work Crew Size' ;
    rdfs:comment 'Number of workers authorized to perform the permitted work activity under this permit.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workLocation rdf:type rdf:Property ;
    rdfs:label 'Work Location' ;
    rdfs:comment 'Specific location within the port facility where the permitted work will be conducted (e.g., berth number, terminal area, warehouse zone, crane number, vessel name).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed description of the port operation, task, or hazardous activity being assessed. Includes context such as equipment used, personnel involved, environmental conditions, and operational procedures.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:additionalControlsRequired rdf:type rdf:Property ;
    rdfs:label 'Additional Controls Required' ;
    rdfs:comment 'Recommended additional risk control measures, improvements, or actions required to further reduce the residual risk to an acceptable level. May include new engineering controls, enhanced procedures, additional training, or operational restrictions. Prioritized based on the hierarchy of controls (elimination, substitution, engineering, administrative, PPE).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTitle rdf:type rdf:Property ;
    rdfs:label 'Assessment Title' ;
    rdfs:comment 'Descriptive title of the risk assessment identifying the operation, task, or activity being assessed (e.g., \'Container Handling - Quay Crane Operations\', \'IMDG Cargo Handling - Berth 5\').' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'Job title or role of the person who conducted the assessment (e.g., Safety Manager, OHS Officer, Terminal Operations Manager, Marine Safety Advisor).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confinedSpaceFlag rdf:type rdf:Property ;
    rdfs:label 'Confined Space Flag' ;
    rdfs:comment 'Indicates whether the assessed activity involves entry into a confined space (e.g., vessel holds, tanks, voids, enclosed equipment). Confined space work requires specific permits, atmospheric testing, rescue procedures, and enhanced controls per SOLAS and national OHS regulations.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consequenceRating rdf:type rdf:Property ;
    rdfs:label 'Consequence Rating' ;
    rdfs:comment 'Qualitative assessment of the severity of potential harm or loss if the hazard materializes. Ratings typically follow a five-level scale: insignificant (no injury, minimal financial loss), minor (first aid treatment, low financial loss), moderate (medical treatment required, medium financial loss), major (extensive injuries, major financial loss, significant environmental impact), catastrophic (death, huge financial loss, severe environmental damage).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationParties rdf:type rdf:Property ;
    rdfs:label 'Consultation Parties' ;
    rdfs:comment 'List of stakeholders, workers, or subject matter experts consulted during the risk assessment process. ISO 45001 requires worker participation and consultation in hazard identification and risk assessment. May include operational staff, union representatives, safety committee members, or external experts.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness' ;
    rdfs:comment 'Assessment of how well the existing controls reduce the risk. Ineffective controls provide minimal risk reduction, partially effective controls provide some reduction but gaps remain, effective controls adequately reduce risk to acceptable levels, highly effective controls substantially eliminate or minimize the risk.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponsePlan rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Plan' ;
    rdfs:comment 'Reference to or description of the emergency response procedures applicable to this risk. Includes evacuation procedures, emergency contacts, first aid arrangements, spill response, fire response, rescue procedures, and coordination with port emergency services. Critical for high-risk activities and IMDG cargo handling.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpact rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact' ;
    rdfs:comment 'Assessment of potential environmental consequences if the hazard materializes. Considers impacts on air quality, water quality, noise levels, greenhouse gas (GHG) emissions, waste generation, and compliance with MARPOL and ISO 14001 requirements. Severe impacts may include oil spills, hazardous material releases, or significant ecosystem damage.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:existingControls rdf:type rdf:Property ;
    rdfs:label 'Existing Controls' ;
    rdfs:comment 'Description of current risk control measures, safeguards, and mitigation strategies already in place. May include engineering controls (e.g., safety barriers, interlocks), administrative controls (e.g., permits, procedures, training), and personal protective equipment (PPE). References relevant Safe Working Load (SWL) certifications, ISPS security measures, or SOLAS safety equipment where applicable.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardIdentification rdf:type rdf:Property ;
    rdfs:label 'Hazard Identification' ;
    rdfs:comment 'Comprehensive identification of potential hazards associated with the activity, including physical hazards (e.g., moving equipment, falling objects), chemical hazards (e.g., dangerous goods per IMDG Code), ergonomic hazards, environmental hazards, and operational hazards. May reference specific IMO, SOLAS, or MARPOL hazard classifications.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hotWorkFlag rdf:type rdf:Property ;
    rdfs:label 'Hot Work Flag' ;
    rdfs:comment 'Indicates whether the assessed activity involves hot work operations (welding, cutting, grinding, or other spark-producing activities). Hot work requires permits, fire watch, and enhanced fire prevention controls, especially in areas with flammable materials or near vessels.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentHistory rdf:type rdf:Property ;
    rdfs:label 'Incident History' ;
    rdfs:comment 'Summary of past incidents, near-misses, or accidents related to this activity or hazard. Provides context for the risk assessment and informs likelihood ratings. May reference specific incident report numbers or dates.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Level' ;
    rdfs:comment 'Categorical risk level derived from the inherent risk score, representing the unmitigated risk severity. Low risk may require monitoring only, medium risk requires management attention and controls, high risk requires senior management attention and immediate controls, extreme risk requires immediate action and may halt operations until mitigated.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Numerical risk score calculated from the risk matrix by combining likelihood and consequence ratings before any controls are applied. Typically ranges from 1 (lowest risk) to 25 (highest risk) in a 5x5 matrix. Represents the raw, unmitigated risk level.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Required Flag' ;
    rdfs:comment 'Indicates whether the assessed activity requires a formal work permit (e.g., hot work permit, confined space entry permit, height work permit, electrical isolation permit). Permit systems ensure proper authorization, risk controls, and emergency preparedness before high-risk work commences.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Categorical risk level derived from the residual risk score, representing the mitigated risk severity after controls are applied. Determines whether the risk is acceptable (low), requires monitoring (medium), requires additional controls (high), or is unacceptable and requires immediate action (extreme).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Numerical risk score calculated after considering the effectiveness of existing controls. Represents the remaining risk level after mitigation measures are applied. Used to determine if additional controls are required or if the risk is acceptable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskOwner rdf:type rdf:Property ;
    rdfs:label 'Risk Owner' ;
    rdfs:comment 'Name or role of the person or department accountable for managing and monitoring this risk. Typically a manager, supervisor, or department head responsible for the operational area where the activity occurs.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Target Risk Level' ;
    rdfs:comment 'The desired risk level to be achieved after implementing additional controls. Represents the organizations risk appetite and tolerance for this specific activity. Typically aims to reduce risk to low or medium levels.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequirements rdf:type rdf:Property ;
    rdfs:label 'Training Requirements' ;
    rdfs:comment 'Specification of competency and training requirements for personnel involved in the assessed activity. May include IMDG training, crane operator certification, confined space entry training, first aid certification, ISPS security awareness, or equipment-specific training. Ensures personnel have the necessary skills and knowledge to work safely.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionClosureVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Closure Verified By Employee Id' ;
    rdfs:comment 'Identifier of the person who verified and approved the closure of the inspection, confirming all corrective actions were satisfactorily completed.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inspectionCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Created By Employee Id' ;
    rdfs:comment 'Identifier of the user who created the inspection record in the system, supporting accountability and audit requirements.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inspectionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Employee Id' ;
    rdfs:comment 'Identifier of the primary inspector who conducted the safety inspection. References the workforce or employee master data.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inspectionLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the inspection record, supporting change accountability and audit requirements.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inspectionResponsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Responsible Manager Employee Id' ;
    rdfs:comment 'Identifier of the manager or supervisor responsible for the inspected area or asset, accountable for addressing inspection findings.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:checklistReference rdf:type rdf:Property ;
    rdfs:label 'Checklist Reference' ;
    rdfs:comment 'Reference code or identifier of the standardized inspection checklist or procedure used during the inspection, ensuring consistency and compliance with inspection protocols.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistVersion rdf:type rdf:Property ;
    rdfs:label 'Checklist Version' ;
    rdfs:comment 'Version number of the inspection checklist used, enabling tracking of checklist evolution and ensuring inspections are conducted against current standards.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Numerical compliance score calculated from the inspection checklist, typically expressed as a percentage (0.00 to 100.00) representing the proportion of checklist items passed.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical severity findings identified, representing immediate safety risks requiring urgent corrective action.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Timestamp when the inspection activity concluded, used to calculate inspection duration and resource utilization.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalPermitReference rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Reference' ;
    rdfs:comment 'Reference number of the environmental permit or license being audited during environmental inspections, linking the inspection to specific regulatory authorizations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which the follow-up inspection must be completed to verify closure of findings and corrective actions.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Boolean indicator whether a follow-up inspection is required to verify corrective actions. True = follow-up required; False = no follow-up needed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the primary inspector who conducted the inspection, captured for audit trail and accountability purposes.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pscDetentionFlag rdf:type rdf:Property ;
    rdfs:label 'Psc Detention Flag' ;
    rdfs:comment 'Boolean indicator whether the PSC inspection resulted in vessel detention due to critical deficiencies. True = vessel detained; False = no detention. Applicable only to PSC inspections.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'URL or file path to the detailed inspection report document, providing access to the full inspection documentation and evidence.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The originally planned date for the inspection, used to track adherence to inspection schedules and identify delays or rescheduling.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Timestamp when the inspection activity commenced, capturing precise start time for duration tracking and operational scheduling.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Executive summary of the inspection findings, key observations, and overall assessment, providing high-level context for management review.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of additional team members who participated in the inspection, capturing full team composition for complex inspections.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of findings (deficiencies, observations, non-conformances) identified during the inspection, providing a quick metric of inspection outcome severity.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kpiEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Kpi Employee Id' ;
    rdfs:comment 'Employee identifier of the manager or executive accountable for this KPI performance. This person owns the improvement actions and reports on progress to senior leadership.' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:kpiResponsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Kpi Responsible Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:kpiVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Kpi Verified By Employee Id' ;
    rdfs:comment 'Employee identifier of the person who verified and approved the KPI data. Provides accountability and audit trail for data quality assurance.' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'Baseline or reference value for this KPI, typically from a prior period or initial measurement. Used to calculate improvement trends and demonstrate continual improvement over time.' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkComparisonStatus rdf:type rdf:Property ;
    rdfs:label 'Benchmark Comparison Status' ;
    rdfs:comment 'Performance status relative to industry benchmark: above_benchmark (better than industry), at_benchmark (equal to industry), below_benchmark (worse than industry), or no_benchmark_available (no comparison data exists).' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source' ;
    rdfs:comment 'Source of the benchmark or industry standard used for comparison (e.g., IAPH WPSP, National Port Authority Average, ISO Industry Benchmark, Internal Historical Best). Provides context for performance evaluation.' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkValue rdf:type rdf:Property ;
    rdfs:label 'Benchmark Value' ;
    rdfs:comment 'Industry benchmark or peer comparison value for this KPI. Used to assess organizational performance relative to industry standards or best practices.' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso45001ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Compliance Flag' ;
    rdfs:comment 'Indicates whether this KPI is tracked as part of ISO 45001 Occupational Health and Safety Management System compliance (True) or not (False). Used for certification audit preparation and continual improvement evidence.' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiCategory rdf:type rdf:Property ;
    rdfs:label 'Kpi Category' ;
    rdfs:comment 'Classification of the KPI type: safety_leading (proactive indicators like inspections, training), safety_lagging (reactive indicators like injury rates), environmental (emissions, waste, quality), compliance (regulatory adherence), or operational (process efficiency).' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiCode rdf:type rdf:Property ;
    rdfs:label 'Kpi Code' ;
    rdfs:comment 'Standardized code identifying the specific safety or environmental KPI being measured (e.g., LTIFR, TRIFR, GHG_INTENSITY). Used for consistent reporting and benchmarking across the organization.' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiName rdf:type rdf:Property ;
    rdfs:label 'Kpi Name' ;
    rdfs:comment 'Full descriptive name of the safety or environmental KPI (e.g., Lost Time Injury Frequency Rate, Total Recordable Injury Frequency Rate, Near-Miss Reporting Rate, Greenhouse Gas Intensity).' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiType rdf:type rdf:Property ;
    rdfs:label 'Kpi Type' ;
    rdfs:comment 'Measurement type of the KPI: frequency_rate (incidents per hours worked), percentage (completion rates), count (absolute numbers), ratio (comparative metrics), intensity (per unit of activity), or index (composite scores).' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'Direction of the KPI trend over time compared to previous periods: improving (getting better), stable (no significant change), declining (getting worse), or insufficient_data (not enough history to determine trend).' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendPercentageChange rdf:type rdf:Property ;
    rdfs:label 'Trend Percentage Change' ;
    rdfs:comment 'Percentage change in KPI value compared to the previous reporting period. Positive or negative value indicates the magnitude and direction of change period-over-period.' ;
    rdfs:domain ind:Kpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wpspGoalAlignment rdf:type rdf:Property ;
    rdfs:label 'Wpsp Goal Alignment' ;
    rdfs:comment 'Alignment of this KPI to specific IAPH World Ports Sustainability Program goals or United Nations Sustainable Development Goals (SDGs). Demonstrates commitment to global sustainability frameworks and industry best practices.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountSchemeId rdf:type rdf:Property ;
    rdfs:label 'Discount Scheme Id' ;
    rdfs:comment 'Foreign key linking to tariff.discount_scheme. Business justification: Ports implement sustainability initiatives (green vessel programs, shore power incentives, emission reduction targets) through discount schemes offering tariff reductions. Linking initiatives to disco' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiscountScheme .

ind:primarySustainabilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sustainability Employee Id' ;
    rdfs:comment 'Identifier of the employee or organizational unit accountable for the successful delivery and ongoing management of the sustainability initiative, typically a senior manager or department head.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetVesselTypeId rdf:type rdf:Property ;
    rdfs:label 'Target Vessel Type Id' ;
    rdfs:comment 'Foreign key linking to masterdata.vessel_type. Business justification: Shore power, cold ironing, and emission reduction initiatives are often vessel-type-specific (e.g., reefer vessels for cold ironing, cruise ships for shore power infrastructure).' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VesselType .

ind:baselineMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Baseline Metric Unit' ;
    rdfs:comment 'Unit of measure for the baseline metric value (e.g., tonnes_co2e for greenhouse gas emissions, mwh for energy, decibels for noise, cubic_meters for water, percentage for efficiency ratios).' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineMetricValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Metric Value' ;
    rdfs:comment 'Quantitative baseline measurement captured at initiative start, representing the pre-initiative state against which progress and improvement will be measured (e.g., annual GHG emissions in tonnes CO2e, noise levels in decibels, energy consumption in MWh).' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total capital expenditure (CAPEX) and operational expenditure (OPEX) budget allocated to the initiative for planning, implementation, and initial operational period, expressed in the port\'s functional currency.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Spent Amount' ;
    rdfs:comment 'Cumulative actual expenditure incurred to date on the initiative, including capital investments, operational costs, consulting fees, and implementation expenses, tracked against allocated budget.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationTarget rdf:type rdf:Property ;
    rdfs:label 'Certification Target' ;
    rdfs:comment 'Name of the environmental or sustainability certification that the initiative aims to achieve or maintain (e.g., EcoPorts PERS, Green Marine, ISO 14001, IAPH WPSP certification levels).' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentMetricValue rdf:type rdf:Property ;
    rdfs:label 'Current Metric Value' ;
    rdfs:comment 'Most recent measured value of the initiative performance metric, updated periodically to track progress from baseline toward target, expressed in the same unit as baseline and target metrics.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energySavingsMwh rdf:type rdf:Property ;
    rdfs:label 'Energy Savings Mwh' ;
    rdfs:comment 'Estimated or actual annual energy consumption reduction achieved through the initiative, measured in megawatt hours (MWh), relevant for electrification and efficiency programs.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalFundingAmount rdf:type rdf:Property ;
    rdfs:label 'External Funding Amount' ;
    rdfs:comment 'Total amount of external funding secured for the initiative, expressed in the same currency as budget amounts, reducing net port investment required.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalFundingSource rdf:type rdf:Property ;
    rdfs:label 'External Funding Source' ;
    rdfs:comment 'Name of external funding body, grant program, or partnership providing financial support for the initiative (e.g., government environmental grants, international development funds, industry consortium co-funding), if applicable.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgReductionTonnesCo2e rdf:type rdf:Property ;
    rdfs:label 'Ghg Reduction Tonnes Co2e' ;
    rdfs:comment 'Estimated or actual annual reduction in greenhouse gas emissions attributable to this initiative, expressed in tonnes of carbon dioxide equivalent (CO2e) using GHG Protocol calculation methodologies, supporting MARPOL and IMO GHG Strategy compliance.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiativeCategory rdf:type rdf:Property ;
    rdfs:label 'Initiative Category' ;
    rdfs:comment 'Primary classification of the sustainability initiative type: shore power (cold ironing for vessels at berth), equipment electrification (conversion of Rubber Tyred Gantry cranes and Mobile Harbour Cranes to electric), carbon offset programs, green port certification pursuits, biodiversity management programs, or community noise reduction programs.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeCode rdf:type rdf:Property ;
    rdfs:label 'Initiative Code' ;
    rdfs:comment 'Externally-known unique business identifier for the sustainability initiative, formatted as three-letter category prefix followed by four-digit sequence number (e.g., SHP-0001 for shore power, EMR-0023 for emissions reduction).' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeName rdf:type rdf:Property ;
    rdfs:label 'Initiative Name' ;
    rdfs:comment 'Full descriptive name of the sustainability initiative as recognized by stakeholders and in official port documentation.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativePriority rdf:type rdf:Property ;
    rdfs:label 'Initiative Priority' ;
    rdfs:comment 'Strategic priority level assigned to the initiative based on regulatory urgency, environmental impact, stakeholder expectations, and alignment with port sustainability strategy: critical (regulatory mandate or major reputational risk), high (strategic priority), medium (important but flexible timing), low (opportunistic or long-term).' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeStatus rdf:type rdf:Property ;
    rdfs:label 'Initiative Status' ;
    rdfs:comment 'Current lifecycle status of the sustainability initiative: planning (under development), approved (funded and authorized), in_progress (actively being implemented), on_hold (temporarily suspended), completed (fully implemented and operational), or cancelled (discontinued).' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Metric Last Updated Date' ;
    rdfs:comment 'Date when the current metric value was last measured and recorded, indicating the freshness of progress tracking data.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneSummary rdf:type rdf:Property ;
    rdfs:label 'Milestone Summary' ;
    rdfs:comment 'Narrative summary of key implementation milestones achieved and upcoming, including major deliverables, phase completions, regulatory approvals obtained, and critical path activities.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressPercentage rdf:type rdf:Property ;
    rdfs:label 'Progress Percentage' ;
    rdfs:comment 'Calculated percentage of initiative completion based on current metric value relative to baseline and target, expressed as a value between 0.00 and 100.00, used for executive dashboards and KPI reporting.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFrameworkReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework Reference' ;
    rdfs:comment 'Citation of specific regulatory requirements, standards, or compliance frameworks that this initiative addresses (e.g., MARPOL Annex VI, ISO 14001:2015, local environmental protection ordinances, IAPH WPSP certification criteria).' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Frequency at which initiative progress and performance metrics are formally reported to executive leadership, board, and external stakeholders (monthly for active high-priority initiatives, quarterly for standard programs, annual for long-term strategic initiatives).' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Summary of key risks identified for initiative delivery (technical, financial, regulatory, operational) and mitigation strategies in place, supporting ISO 45001 and ISO 14001 risk management requirements.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderEngagementSummary rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Engagement Summary' ;
    rdfs:comment 'Summary of stakeholder consultation, community engagement, and communication activities conducted as part of the initiative, including feedback received and how it influenced implementation.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricValue rdf:type rdf:Property ;
    rdfs:label 'Target Metric Value' ;
    rdfs:comment 'Quantitative target value that the initiative aims to achieve by completion, expressed in the same unit as the baseline metric, representing the desired end-state performance level.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetOutcomeDescription rdf:type rdf:Property ;
    rdfs:label 'Target Outcome Description' ;
    rdfs:comment 'Detailed narrative of the intended environmental, social, or operational outcome that the initiative aims to achieve, including specific measurable goals and expected benefits to port operations and community.' ;
    rdfs:domain ind:SustainabilityInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Access Attempt Count' ;
    rdfs:comment 'Total number of access attempts (successful and failed) recorded for this credential. Used for usage analytics and anomaly detection.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessTimeRestrictions rdf:type rdf:Property ;
    rdfs:label 'Access Time Restrictions' ;
    rdfs:comment 'Description of temporal access restrictions for this credential, such as specific days of the week, time windows, or shift-based access. Free-text or structured time range specification.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricEnrolled rdf:type rdf:Property ;
    rdfs:label 'Biometric Enrolled' ;
    rdfs:comment 'Indicates whether the credential holder has completed biometric enrollment (fingerprint, facial recognition, iris scan) for enhanced access control verification.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biometricModality rdf:type rdf:Property ;
    rdfs:label 'Biometric Modality' ;
    rdfs:comment 'Type of biometric authentication method enrolled for this credential. None indicates no biometric enrollment.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialNumber rdf:type rdf:Property ;
    rdfs:label 'Credential Number' ;
    rdfs:comment 'Unique externally-visible credential number or badge number printed on the physical credential. This is the business identifier used for access control system lookups and audit trails.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialStatus rdf:type rdf:Property ;
    rdfs:label 'Credential Status' ;
    rdfs:comment 'Current lifecycle status of the credential. Controls whether the credential is valid for access control system authorization. [ENUM-REF-CANDIDATE: active|suspended|revoked|expired|pending_activation|lost|stolen — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialType rdf:type rdf:Property ;
    rdfs:label 'Credential Type' ;
    rdfs:comment 'Classification of the credential based on its purpose and holder category. Determines access privileges and validation requirements.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedAccessCount rdf:type rdf:Property ;
    rdfs:label 'Failed Access Count' ;
    rdfs:comment 'Total number of failed or denied access attempts for this credential. High counts may indicate lost credentials, unauthorized use, or system issues.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holderEmail rdf:type rdf:Property ;
    rdfs:label 'Holder Email' ;
    rdfs:comment 'Primary email address of the credential holder for notifications regarding credential expiry, renewal, or security alerts.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderNationalIdentifier rdf:type rdf:Property ;
    rdfs:label 'Holder National Identifier' ;
    rdfs:comment 'Government-issued national identification number of the credential holder. Required for background checks and compliance with maritime security regulations.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderOrganization rdf:type rdf:Property ;
    rdfs:label 'Holder Organization' ;
    rdfs:comment 'Name of the company, agency, or organization that the credential holder represents. Applicable for contractors, vendors, and external parties.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderPhone rdf:type rdf:Property ;
    rdfs:label 'Holder Phone' ;
    rdfs:comment 'Primary contact phone number of the credential holder for emergency contact and verification purposes.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderType rdf:type rdf:Property ;
    rdfs:label 'Holder Type' ;
    rdfs:comment 'Category of the individual or entity to whom this credential is issued. Used for access policy enforcement and reporting segmentation.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Access Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful use of this credential at any port access control point. Used for activity monitoring and dormant credential identification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marsecLevelAccess rdf:type rdf:Property ;
    rdfs:label 'Marsec Level Access' ;
    rdfs:comment 'Maximum MARSEC security level at which this credential remains valid. MARSEC 1 is normal, MARSEC 2 is heightened, MARSEC 3 is exceptional threat. Credentials may be restricted at higher threat levels.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoReference rdf:type rdf:Property ;
    rdfs:label 'Photo Reference' ;
    rdfs:comment 'File path, URL, or document management system reference to the credential holder photograph. Used for visual identity verification at access points.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Sent' ;
    rdfs:comment 'Indicates whether an automated renewal reminder notification has been sent to the credential holder prior to expiry.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revokedBy rdf:type rdf:Property ;
    rdfs:label 'Revoked By' ;
    rdfs:comment 'Name or identifier of the security officer or authorized personnel who revoked the credential. Used for accountability and audit purposes.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContact rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact' ;
    rdfs:comment 'Contact phone number or email of the sponsor for verification and emergency contact purposes.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Name' ;
    rdfs:comment 'Name of the internal port employee or department who sponsors or vouches for the credential holder. Applicable for visitor and contractor credentials.' ;
    rdfs:domain ind:AccessCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessPointId rdf:type rdf:Property ;
    rdfs:label 'Access Point Id' ;
    rdfs:comment 'Identifier of the physical access control point where the event occurred (gate, turnstile, door, vehicle barrier).' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessPoint .

ind:accessControlSystemCode rdf:type rdf:Property ;
    rdfs:label 'Access Control System Code' ;
    rdfs:comment 'Identifier of the physical access control system (hardware/software platform) that recorded this event.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessDecision rdf:type rdf:Property ;
    rdfs:label 'Access Decision' ;
    rdfs:comment 'The access control system decision outcome for this event indicating whether access was granted, denied, or triggered an alarm.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Access Duration Minutes' ;
    rdfs:comment 'Duration in minutes that the person remained in the zone, calculated from entry to exit events. Null if exit event not yet recorded or for single-point events.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessPointType rdf:type rdf:Property ;
    rdfs:label 'Access Point Type' ;
    rdfs:comment 'Classification of the physical access control point type (vehicle gate, pedestrian gate, turnstile, door, barrier, bollard).' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessPurpose rdf:type rdf:Property ;
    rdfs:label 'Access Purpose' ;
    rdfs:comment 'Stated business purpose or reason for the access (e.g., cargo operations, maintenance, delivery, inspection, meeting).' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Triggered Flag' ;
    rdfs:comment 'Indicates whether this access event triggered a security alarm condition. True if alarm was triggered, False otherwise.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alarmType rdf:type rdf:Property ;
    rdfs:label 'Alarm Type' ;
    rdfs:comment 'Classification of the security alarm that was triggered, if applicable. Null if no alarm was triggered.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antiPassbackViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Anti Passback Violation Flag' ;
    rdfs:comment 'Indicates whether this event violated anti-passback rules (attempting to enter without a prior exit, or vice versa). True if violation detected, False otherwise.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailHash rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Hash' ;
    rdfs:comment 'Cryptographic hash of the event record to ensure data integrity and prevent tampering for compliance and forensic purposes.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricMatchScore rdf:type rdf:Property ;
    rdfs:label 'Biometric Match Score' ;
    rdfs:comment 'Confidence score (0.00 to 100.00) of the biometric authentication match, if biometric credential was used. Null for non-biometric credentials.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cctvClipReference rdf:type rdf:Property ;
    rdfs:label 'Cctv Clip Reference' ;
    rdfs:comment 'Reference identifier or file path to the CCTV video clip capturing this access event for forensic review and audit purposes.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason why access was denied, if applicable. Null for granted access events. [ENUM-REF-CANDIDATE: invalid_credential|expired_credential|unauthorized_zone|time_restriction|revoked_access|blacklisted|system_error|unknown — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Device Serial Number' ;
    rdfs:comment 'Serial number of the physical access control device (card reader, biometric scanner, barrier controller) that captured the event.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escortRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escort Required Flag' ;
    rdfs:comment 'Indicates whether the person was required to be escorted while in the accessed zone per security policy. True if escort required, False otherwise.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventSourceIpAddress rdf:type rdf:Property ;
    rdfs:label 'Event Source Ip Address' ;
    rdfs:comment 'IP address of the access control device or system that generated this event record.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marsecLevel rdf:type rdf:Property ;
    rdfs:label 'Marsec Level' ;
    rdfs:comment 'The MARSEC security level in effect at the port facility at the time of the access event (1=normal, 2=heightened, 3=exceptional). MARSEC levels are defined by ISPS Code to indicate threat conditions.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Name of the company or organization that the person represents (e.g., port operator, shipping line, customs, contractor).' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Override Authorized By' ;
    rdfs:comment 'Name or identifier of the security supervisor who authorized a manual override of the access control decision. Null for standard automated decisions.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text explanation for why a manual override was authorized, if applicable. Null for standard automated decisions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personName rdf:type rdf:Property ;
    rdfs:label 'Person Name' ;
    rdfs:comment 'Full name of the individual associated with the credential at the time of the access event.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureReadingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading Celsius' ;
    rdfs:comment 'Body temperature reading in Celsius captured at the access point for health screening purposes. Null if temperature screening not performed.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeZoneRestrictionViolatedFlag rdf:type rdf:Property ;
    rdfs:label 'Time Zone Restriction Violated Flag' ;
    rdfs:comment 'Indicates whether the access attempt violated time-based access restrictions for the credential or zone. True if violation, False otherwise.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleRegistration rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration' ;
    rdfs:comment 'License plate or registration number of the vehicle involved in the access event, if applicable. Null for pedestrian access.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitorFlag rdf:type rdf:Property ;
    rdfs:label 'Visitor Flag' ;
    rdfs:comment 'Indicates whether the person was a visitor (temporary access) rather than a regular employee or contractor. True if visitor, False if regular personnel.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneClassification rdf:type rdf:Property ;
    rdfs:label 'Zone Classification' ;
    rdfs:comment 'Security classification level of the zone: public (open access), restricted (controlled access), high security (limited personnel), or critical infrastructure (essential operations).' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityBuildingId rdf:type rdf:Property ;
    rdfs:label 'Facility Building Id' ;
    rdfs:comment 'Reference to the port facility building or structure where this access point is physically installed.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FacilityBuilding .

ind:responsibleSecurityPostId rdf:type rdf:Property ;
    rdfs:label 'Responsible Security Post Id' ;
    rdfs:comment 'Reference to the security post or guard station responsible for monitoring and responding to events at this access point.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Post .

ind:accessLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Access Level Required' ;
    rdfs:comment 'Minimum security clearance or authorization level required to pass through this access control point.' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessPointCode rdf:type rdf:Property ;
    rdfs:label 'Access Point Code' ;
    rdfs:comment 'Business identifier code assigned to the access control point for operational reference and security system integration.' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessPointName rdf:type rdf:Property ;
    rdfs:label 'Access Point Name' ;
    rdfs:comment 'Descriptive name of the access control point for human-readable identification (e.g., Main Gate North, Terminal 3 Pedestrian Entry).' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Integration Flag' ;
    rdfs:comment 'Indicates whether the access point is integrated with the port facility alarm and intrusion detection system.' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:antiTailgatingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Anti Tailgating Enabled Flag' ;
    rdfs:comment 'Indicates whether anti-tailgating or anti-passback technology is enabled to prevent unauthorized persons from following authorized users through the access point.' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:barrierType rdf:type rdf:Property ;
    rdfs:label 'Barrier Type' ;
    rdfs:comment 'Type of physical barrier mechanism installed at the access point to control passage. [ENUM-REF-CANDIDATE: swing_gate|sliding_gate|boom_barrier|bollard|turnstile|door|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cctvCameraIds rdf:type rdf:Property ;
    rdfs:label 'Cctv Camera Ids' ;
    rdfs:comment 'Comma-separated list of CCTV camera identifiers that provide surveillance coverage of this access point.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Number' ;
    rdfs:comment 'Certification or approval number indicating that the access control point meets ISPS Code and national security standards.' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlTechnologyType rdf:type rdf:Property ;
    rdfs:label 'Control Technology Type' ;
    rdfs:comment 'Primary access control technology deployed at this point for identity verification and authorization (ANPR = Automatic Number Plate Recognition, RFID = Radio Frequency Identification). [ENUM-REF-CANDIDATE: card_reader|biometric_fingerprint|biometric_facial|anpr|manual_guard|rfid|pin_keypad|multi_factor — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directionControl rdf:type rdf:Property ;
    rdfs:label 'Direction Control' ;
    rdfs:comment 'Indicates whether the access point controls entry, exit, or both directions of movement through the control point.' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyExitFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Exit Flag' ;
    rdfs:comment 'Indicates whether this access point is designated as an emergency exit route for evacuation purposes.' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:integrationSystemCode rdf:type rdf:Property ;
    rdfs:label 'Integration System Code' ;
    rdfs:comment 'Identifier of the access control system or security management platform that this access point is integrated with for centralized monitoring.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercomAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Intercom Available Flag' ;
    rdfs:comment 'Indicates whether an intercom or two-way communication system is available at this access point for visitor communication with security personnel.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance inspection or service of the access control equipment.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondaryControlTechnology rdf:type rdf:Property ;
    rdfs:label 'Secondary Control Technology' ;
    rdfs:comment 'Secondary or backup access control technology deployed for redundancy or multi-factor authentication requirements. [ENUM-REF-CANDIDATE: card_reader|biometric_fingerprint|biometric_facial|anpr|manual_guard|rfid|pin_keypad|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputCapacityPerHour rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Per Hour' ;
    rdfs:comment 'Maximum number of persons or vehicles that can be processed through this access point per hour under normal operating conditions.' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitorManagementIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Visitor Management Integration Flag' ;
    rdfs:comment 'Indicates whether the access point is integrated with the port visitor management system for pre-registration and visitor tracking.' ;
    rdfs:domain ind:AccessPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cctvCameraId rdf:type rdf:Property ;
    rdfs:label 'Cctv Camera Id' ;
    rdfs:comment 'Unique identifier for the CCTV camera asset within the port facility security infrastructure. Primary key for the camera registry.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CctvCamera .

ind:vmsChannelId rdf:type rdf:Property ;
    rdfs:label 'Vms Channel Id' ;
    rdfs:comment 'Unique channel identifier or stream ID assigned to this camera within the Video Management System. Used for video retrieval, live monitoring, and incident playback.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:analyticsFeatures rdf:type rdf:Property ;
    rdfs:label 'Analytics Features' ;
    rdfs:comment 'Comma-separated list of advanced video analytics features enabled for this camera (e.g., \'facial_recognition\', \'license_plate_recognition\', \'intrusion_detection\', \'object_tracking\', \'crowd_detection\', \'abandoned_object_alert\'). Used for intelligent surveillance and automated threat detection.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cameraCode rdf:type rdf:Property ;
    rdfs:label 'Camera Code' ;
    rdfs:comment 'Externally-known unique asset code for the camera following port facility naming convention (e.g., STS-CAM-00123 for ship-to-shore crane camera). Used for maintenance work orders and security incident reporting.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cameraType rdf:type rdf:Property ;
    rdfs:label 'Camera Type' ;
    rdfs:comment 'Classification of camera technology and operational capability. Fixed cameras provide static coverage, PTZ (pan-tilt-zoom) cameras offer remote directional control, thermal cameras enable night/low-visibility monitoring, vessel-monitoring cameras track ship movements, LPR cameras capture vehicle plates at gates, and underwater cameras monitor submerged infrastructure.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Coverage Area Description' ;
    rdfs:comment 'Textual description of the surveillance coverage area and field of view for this camera (e.g., \'Monitors container stacking operations in Yard Block A, rows 1-8\', \'Covers vessel gangway and berth access point\', \'Overlooks main gate vehicle inspection zone\'). Used for security coverage planning and incident response.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cybersecurityZone rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Zone' ;
    rdfs:comment 'Network security zone classification for the camera. OT (Operational Technology) network for industrial control systems, IT network for corporate systems, DMZ (demilitarized zone) for internet-facing systems, isolated for segmented networks, air-gapped for physically disconnected systems. Used for cybersecurity risk assessment and network access control.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalRating rdf:type rdf:Property ;
    rdfs:label 'Environmental Rating' ;
    rdfs:comment 'IP (Ingress Protection) rating indicating the camera enclosure resistance to dust and water (e.g., IP66 for dust-tight and water-jet resistant, IP67 for submersion protection). Critical for outdoor and marine environment installations.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Current firmware version installed on the camera device. Critical for cybersecurity vulnerability management, feature compatibility, and coordinated firmware update campaigns.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameRateFps rdf:type rdf:Property ;
    rdfs:label 'Frame Rate Fps' ;
    rdfs:comment 'Video recording frame rate in frames per second (fps). Typical values range from 15 fps (basic surveillance) to 30 fps (smooth motion capture). Higher frame rates improve incident analysis but increase storage requirements.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationLocation rdf:type rdf:Property ;
    rdfs:label 'Installation Location' ;
    rdfs:comment 'Detailed physical location description of the camera installation within the port facility (e.g., \'Berth 5 North Corner\', \'Container Yard Block C Row 12\', \'Main Gate Entry Lane 3\', \'Administration Building Roof East\'). Supports incident investigation and coverage gap analysis.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IPv4 network address assigned to the camera on the port facility security network. Used for Video Management System (VMS) integration, remote access, and network troubleshooting. Classified as confidential to prevent unauthorized access attempts.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFirmwareUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Firmware Update Date' ;
    rdfs:comment 'Date when the camera firmware was last updated. Used for cybersecurity patch management tracking and vulnerability assessment.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastOnlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Online Timestamp' ;
    rdfs:comment 'Timestamp when the camera last successfully communicated with the Video Management System. Used for connectivity monitoring, fault detection, and service level agreement (SLA) compliance tracking.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Hardware MAC address of the camera network interface. Used for network access control, device authentication, and cybersecurity incident investigation.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:motionDetectionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Motion Detection Enabled Flag' ;
    rdfs:comment 'Boolean indicator of whether motion detection analytics are enabled for this camera. When true, the camera or VMS triggers alerts on detected movement in defined zones, reducing manual monitoring workload.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mountingType rdf:type rdf:Property ;
    rdfs:label 'Mounting Type' ;
    rdfs:comment 'Physical mounting configuration of the camera installation. Pole mount for outdoor surveillance towers, wall mount for building facades, ceiling mount for indoor areas, gantry mount for crane-mounted cameras, mobile mount for temporary or relocatable surveillance.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nightVisionCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Night Vision Capability Flag' ;
    rdfs:comment 'Boolean indicator of whether the camera has infrared or low-light night vision capability for 24/7 surveillance. True indicates night vision support, false indicates daylight-only operation.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procurementCost rdf:type rdf:Property ;
    rdfs:label 'Procurement Cost' ;
    rdfs:comment 'Original purchase cost of the camera equipment in the port facility base currency. Used for capital expenditure (CAPEX) tracking, depreciation calculation, and return on investment analysis. Classified as confidential business financial data.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptzCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Ptz Capability Flag' ;
    rdfs:comment 'Boolean indicator of whether the camera has pan-tilt-zoom remote control capability. True indicates PTZ functionality for operator-directed surveillance, false indicates fixed-position camera.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordingResolution rdf:type rdf:Property ;
    rdfs:label 'Recording Resolution' ;
    rdfs:comment 'Maximum video recording resolution capability of the camera (e.g., 1080p Full HD, 4K Ultra HD, 5 megapixel). Higher resolution enables better forensic analysis and facial/license plate recognition but requires more storage capacity.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days that recorded video footage from this camera is retained in the Video Management System before automatic deletion. ISPS Code requires minimum 90 days retention for port facility security footage. Longer retention may be required for critical areas or regulatory compliance.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vmsIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Vms Integration Status' ;
    rdfs:comment 'Status of camera integration with the central Video Management System platform. Integrated indicates active streaming and recording, pending indicates configuration in progress, failed indicates connectivity or authentication issues, not_configured indicates new camera awaiting setup.' ;
    rdfs:domain ind:CctvCamera ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cctvIncidentClipId rdf:type rdf:Property ;
    rdfs:label 'Cctv Incident Clip Id' ;
    rdfs:comment 'Unique identifier for the CCTV incident clip record. Primary key for the table.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCctvEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cctv Employee Id' ;
    rdfs:comment 'Reference to the security officer who authorized and performed the extraction of this CCTV incident clip.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cameraLocation rdf:type rdf:Property ;
    rdfs:label 'Camera Location' ;
    rdfs:comment 'Physical location description of the CCTV camera that captured this footage (e.g., Gate 3, Berth 5, Container Yard A).' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cameraZone rdf:type rdf:Property ;
    rdfs:label 'Camera Zone' ;
    rdfs:comment 'Security zone classification where the camera is positioned within the port facility. [ENUM-REF-CANDIDATE: restricted_area|public_area|cargo_handling|gate_entry|berth|yard|perimeter|office|warehouse — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyLog rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Log' ;
    rdfs:comment 'Detailed log of all personnel who have accessed, reviewed, or handled this CCTV incident clip to maintain evidential integrity.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clipReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Clip Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for the CCTV incident clip, used for chain of custody and legal proceedings.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clipStatus rdf:type rdf:Property ;
    rdfs:label 'Clip Status' ;
    rdfs:comment 'Current lifecycle status of the CCTV incident clip in the evidence management workflow.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceTag rdf:type rdf:Property ;
    rdfs:label 'Evidence Tag' ;
    rdfs:comment 'Formal evidence tag or identifier assigned to this CCTV incident clip for legal proceedings or investigations.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extractionReason rdf:type rdf:Property ;
    rdfs:label 'Extraction Reason' ;
    rdfs:comment 'Detailed explanation of why this CCTV footage clip was extracted and preserved.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extractionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Extraction Timestamp' ;
    rdfs:comment 'Date and time when the CCTV footage clip was extracted from the surveillance system.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Size of the CCTV incident clip file measured in megabytes.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:footageEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Footage End Timestamp' ;
    rdfs:comment 'Date and time marking the end of the captured footage in this clip.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:footageStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Footage Start Timestamp' ;
    rdfs:comment 'Date and time marking the beginning of the captured footage in this clip.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:frameRate rdf:type rdf:Property ;
    rdfs:label 'Frame Rate' ;
    rdfs:comment 'Number of frames per second in the CCTV incident clip video.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hashChecksum rdf:type rdf:Property ;
    rdfs:label 'Hash Checksum' ;
    rdfs:comment 'Cryptographic hash (SHA-256) of the CCTV incident clip file to ensure integrity and detect tampering.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementAgency rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Agency' ;
    rdfs:comment 'Name of the law enforcement or legal authority that requested this CCTV incident clip.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementReference rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Reference' ;
    rdfs:comment 'Reference number or case identifier provided by the law enforcement agency for this CCTV incident clip request.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Request Flag' ;
    rdfs:comment 'Indicates whether this CCTV incident clip was extracted in response to a law enforcement or legal authority request.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseAuthorizationDocument rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Document' ;
    rdfs:comment 'Reference to the formal authorization document (court order, warrant, or official request) that permitted the release of this CCTV incident clip.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when this CCTV incident clip was officially released to law enforcement, legal counsel, or other authorized parties.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releasedTo rdf:type rdf:Property ;
    rdfs:label 'Released To' ;
    rdfs:comment 'Name of the individual, organization, or authority to whom this CCTV incident clip was released.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Video resolution of the CCTV incident clip (e.g., 1920x1080, 1280x720).' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Retention Override Reason' ;
    rdfs:comment 'Explanation for any extension or modification to the standard retention period for this CCTV incident clip.' ;
    rdfs:domain ind:CctvIncidentClip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyberRiskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Cyber Risk Register Id' ;
    rdfs:comment 'Foreign key linking to security.cyber_risk_register. Business justification: Cyber incidents often materialize identified risks from the cyber risk register. Linking incidents to the risk register entry enables risk tracking (likelihood validation, impact validation) and suppo' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CyberRiskRegister .

ind:affectedSystemPrimary rdf:type rdf:Property ;
    rdfs:label 'Affected System Primary' ;
    rdfs:comment 'Primary IT or OT (Operational Technology) system affected by the incident. Includes TOS (NAVIS N4), VTS (Vessel Traffic Service), SCADA, PCS (Port Community System), gate automation, and crane control systems. [ENUM-REF-CANDIDATE: navis_n4_tos|vtms|scada|pcs|gate_automation|crane_control_system|sap_erp|maximo|network_infrastructure|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystemsAdditional rdf:type rdf:Property ;
    rdfs:label 'Affected Systems Additional' ;
    rdfs:comment 'Comma-separated list of additional IT/OT systems impacted by the incident beyond the primary affected system.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attackVector rdf:type rdf:Property ;
    rdfs:label 'Attack Vector' ;
    rdfs:comment 'Method or pathway through which the cyber attack was initiated or delivered into port systems. [ENUM-REF-CANDIDATE: email_phishing|malicious_attachment|compromised_credentials|network_vulnerability|usb_device|supply_chain|insider_threat|brute_force|zero_day_exploit|social_engineering|unknown — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Business Impact Assessment' ;
    rdfs:comment 'Detailed assessment of the business impact including operational disruption, financial loss, reputational damage, and safety implications for port operations.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Cert Notification Flag' ;
    rdfs:comment 'Flag indicating whether the incident was reported to the national Computer Emergency Response Team (CERT) or cybersecurity authority.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cert Notification Timestamp' ;
    rdfs:comment 'Date and time when the incident was reported to the national CERT or cybersecurity authority.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:certReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Cert Reference Number' ;
    rdfs:comment 'Reference number assigned by the national CERT or cybersecurity authority for tracking the reported incident.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentActions rdf:type rdf:Property ;
    rdfs:label 'Containment Actions' ;
    rdfs:comment 'Description of immediate containment actions taken to limit the spread and impact of the incident, such as network isolation, system shutdown, or access revocation.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Timestamp' ;
    rdfs:comment 'Date and time when the incident was successfully contained and prevented from further spread.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveActionsIdentified rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Identified' ;
    rdfs:comment 'Description of corrective actions and security improvements identified during post-incident review to prevent recurrence.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Data Breach Flag' ;
    rdfs:comment 'Flag indicating whether the incident resulted in unauthorized access to, disclosure of, or loss of sensitive or personal data.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataBreachRecordCount rdf:type rdf:Property ;
    rdfs:label 'Data Breach Record Count' ;
    rdfs:comment 'Estimated number of data records compromised or exposed in the incident, if applicable.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectedBy rdf:type rdf:Property ;
    rdfs:label 'Detected By' ;
    rdfs:comment 'Source or method by which the incident was initially detected. [ENUM-REF-CANDIDATE: automated_monitoring|security_operations_center|end_user_report|external_notification|routine_audit|penetration_test|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that affected systems were unavailable or non-operational due to the incident.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact' ;
    rdfs:comment 'Estimated total financial impact of the incident including direct costs, recovery costs, lost revenue, and potential fines or penalties.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalSupportEngagedFlag rdf:type rdf:Property ;
    rdfs:label 'External Support Engaged Flag' ;
    rdfs:comment 'Flag indicating whether external cybersecurity consultants, forensic investigators, or incident response vendors were engaged to support incident response.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalSupportVendorName rdf:type rdf:Property ;
    rdfs:label 'External Support Vendor Name' ;
    rdfs:comment 'Name of the external cybersecurity vendor or consultant engaged to support incident response, if applicable.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated financial impact amount.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Incident Coordinator Name' ;
    rdfs:comment 'Name of the security personnel or incident response team member coordinating the incident response.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorsOfCompromise rdf:type rdf:Property ;
    rdfs:label 'Indicators Of Compromise' ;
    rdfs:comment 'Technical indicators of compromise such as IP addresses, file hashes, domain names, or registry keys associated with the incident.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notification Flag' ;
    rdfs:comment 'Flag indicating whether the incident was reported to law enforcement authorities for criminal investigation.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:malwareIdentified rdf:type rdf:Property ;
    rdfs:label 'Malware Identified' ;
    rdfs:comment 'Name or family of malware identified during the incident investigation, if applicable.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maritimeAuthorityNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Maritime Authority Notification Flag' ;
    rdfs:comment 'Flag indicating whether the incident was reported to the national maritime authority or port state control as required under IMO guidelines.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maritimeAuthorityNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Maritime Authority Notification Timestamp' ;
    rdfs:comment 'Date and time when the incident was reported to the maritime authority or port state control.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:occurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Occurrence Timestamp' ;
    rdfs:comment 'Estimated or confirmed date and time when the cybersecurity incident actually occurred or began, which may differ from detection time.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationalDisruptionFlag rdf:type rdf:Property ;
    rdfs:label 'Operational Disruption Flag' ;
    rdfs:comment 'Flag indicating whether the incident caused disruption to port operations such as vessel movements, cargo handling, or gate operations.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pfsoNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pfso Notification Timestamp' ;
    rdfs:comment 'Date and time when the Port Facility Security Officer was notified of the incident.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pfsoNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Pfso Notified Flag' ;
    rdfs:comment 'Flag indicating whether the Port Facility Security Officer was notified of the cybersecurity incident as required under ISPS Code.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piiExposedFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Exposed Flag' ;
    rdfs:comment 'Flag indicating whether personally identifiable information was exposed or compromised during the incident.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postIncidentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Date' ;
    rdfs:comment 'Date when the post-incident review was completed and documented.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postIncidentReviewReference rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Reference' ;
    rdfs:comment 'Reference identifier or document location for the post-incident review report containing lessons learned and improvement recommendations.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryActions rdf:type rdf:Property ;
    rdfs:label 'Recovery Actions' ;
    rdfs:comment 'Description of recovery actions taken to restore affected systems and services to normal operation, including system restoration, data recovery, and security hardening.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recovery Timestamp' ;
    rdfs:comment 'Date and time when affected systems were fully recovered and restored to normal operational status.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Summary of the root cause analysis identifying the underlying vulnerabilities, weaknesses, or failures that allowed the incident to occur.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatActorType rdf:type rdf:Property ;
    rdfs:label 'Threat Actor Type' ;
    rdfs:comment 'Classification of the suspected threat actor type based on tactics, techniques, and procedures observed during the incident.' ;
    rdfs:domain ind:CyberIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyberEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cyber Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCyberEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cyber Employee Id' ;
    rdfs:comment 'Identifier of the individual or role accountable for managing and monitoring this cyber risk.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetAtRisk rdf:type rdf:Property ;
    rdfs:label 'Asset At Risk' ;
    rdfs:comment 'Specific asset, data repository, or operational technology component that could be compromised by this risk.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentControls rdf:type rdf:Property ;
    rdfs:label 'Current Controls' ;
    rdfs:comment 'Description of existing security controls, safeguards, and countermeasures currently in place to mitigate this cyber risk.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyberRiskRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Cyber Risk Register Status' ;
    rdfs:comment 'Current lifecycle status of the cyber risk register entry: active (ongoing monitoring), closed (risk eliminated or no longer relevant), archived (historical record), or under review (assessment in progress).' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate' ;
    rdfs:comment 'Estimated financial loss in the event this cyber risk materializes, including direct costs, business interruption, and recovery expenses.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imoMsc428ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Imo Msc 428 Compliance Flag' ;
    rdfs:comment 'Indicates whether this cyber risk assessment and treatment aligns with IMO Resolution MSC.428(98) maritime cyber risk management obligations.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactRating rdf:type rdf:Property ;
    rdfs:label 'Impact Rating' ;
    rdfs:comment 'Assessment of the potential business impact if this cyber risk is realized, considering operational disruption, financial loss, safety implications, and reputational damage.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScore rdf:type rdf:Property ;
    rdfs:label 'Impact Score' ;
    rdfs:comment 'Numeric score representing the severity of impact if the risk materializes, typically on a scale of 1-5, used for quantitative risk calculations.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iso27001AlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 27001 Alignment Flag' ;
    rdfs:comment 'Indicates whether this cyber risk entry and its controls align with ISO/IEC 27001 information security management requirements.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsCodeRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Isps Code Relevance Flag' ;
    rdfs:comment 'Indicates whether this cyber risk has implications for ISPS Code compliance and port facility security operations.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date when this cyber risk was most recently assessed or reviewed for changes in likelihood, impact, or control effectiveness.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:likelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Likelihood Score' ;
    rdfs:comment 'Numeric score representing the likelihood of risk occurrence, typically on a scale of 1-5, used for quantitative risk calculations.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicates whether realization of this cyber risk could result in regulatory non-compliance, fines, or sanctions from maritime or cybersecurity authorities.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAcceptanceAuthority rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptance Authority' ;
    rdfs:comment 'Name and title of the senior executive or committee that formally accepted this residual risk.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptance Date' ;
    rdfs:comment 'Date when the residual risk was formally accepted by authorized management, if applicable.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAcceptanceFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptance Flag' ;
    rdfs:comment 'Indicates whether this residual risk has been formally accepted by senior management or the risk committee.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed description of the cybersecurity risk, including threat vectors, vulnerabilities, and potential attack scenarios.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Risk Reference Number' ;
    rdfs:comment 'Business identifier for the cyber risk entry, formatted as CR-YYYY-#### for external communication and audit trails.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'More granular classification within the primary risk category, providing additional context for risk treatment planning.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Concise title summarizing the cybersecurity risk for quick identification and reporting.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Flag' ;
    rdfs:comment 'Indicates whether this cyber risk could result in physical harm to personnel, environmental damage, or compromise of safety-critical systems.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemAtRisk rdf:type rdf:Property ;
    rdfs:label 'System At Risk' ;
    rdfs:comment 'Name or identifier of the IT or OT system, application, or infrastructure component exposed to this cyber risk.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatSource rdf:type rdf:Property ;
    rdfs:label 'Threat Source' ;
    rdfs:comment 'Origin or actor behind the potential threat, such as nation-state actors, cybercriminal groups, hacktivists, malicious insiders, or accidental user error.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Completion Date' ;
    rdfs:comment 'Actual date when the risk treatment plan was completed and controls were fully implemented.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Due Date' ;
    rdfs:comment 'Target date by which the risk treatment plan should be completed, used for tracking and accountability.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentPlan rdf:type rdf:Property ;
    rdfs:label 'Treatment Plan' ;
    rdfs:comment 'Detailed description of planned actions, controls, or initiatives to address this cyber risk according to the chosen treatment strategy.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentPriority rdf:type rdf:Property ;
    rdfs:label 'Treatment Priority' ;
    rdfs:comment 'Priority level assigned to the risk treatment activities, guiding resource allocation and scheduling.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Treatment Status' ;
    rdfs:comment 'Current status of the risk treatment plan implementation, tracking progress from planning through completion.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Treatment Strategy' ;
    rdfs:comment 'Selected risk treatment approach: mitigate (reduce likelihood/impact), accept (acknowledge and monitor), transfer (insurance or third-party), or avoid (eliminate the activity).' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityDescription rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Description' ;
    rdfs:comment 'Description of the technical or procedural weakness that could be exploited to realize this cyber risk.' ;
    rdfs:domain ind:CyberRiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marsecLevelChangeId rdf:type rdf:Property ;
    rdfs:label 'Marsec Level Change Id' ;
    rdfs:comment 'Foreign key linking to security.marsec_level_change. Business justification: DoS records capture the MARSEC level at time of execution (port_marsec_level, vessel_marsec_level fields). Linking to the specific marsec_level_change event that was in effect enables audit trail of w' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarsecLevelChange .

ind:activitiesCovered rdf:type rdf:Property ;
    rdfs:label 'Activities Covered' ;
    rdfs:comment 'Comma-separated list of activities covered by this Declaration of Security, such as cargo operations, passenger embarkation/disembarkation, crew change, bunkering, stores delivery, waste removal, ship-to-ship transfer.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bunkeringFlag rdf:type rdf:Property ;
    rdfs:label 'Bunkering Flag' ;
    rdfs:comment 'Indicates whether bunkering (fuel supply) operations are covered under this Declaration of Security.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cargoOperationsFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Operations Flag' ;
    rdfs:comment 'Indicates whether cargo loading/discharge operations are covered under this Declaration of Security.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crewChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Crew Change Flag' ;
    rdfs:comment 'Indicates whether crew change operations are covered under this Declaration of Security.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dosNumber rdf:type rdf:Property ;
    rdfs:label 'Dos Number' ;
    rdfs:comment 'Unique business identifier for the Declaration of Security document. Externally-known reference number used for regulatory filing and audit trail.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosStatus rdf:type rdf:Property ;
    rdfs:label 'Dos Status' ;
    rdfs:comment 'Current lifecycle status of the Declaration of Security record: draft (being prepared), active (in force), completed (interface concluded), cancelled (voided before completion), expired (validity period ended).' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReference rdf:type rdf:Property ;
    rdfs:label 'Filing Reference' ;
    rdfs:comment 'Document management system reference or filing location where the signed Declaration of Security document is stored for regulatory compliance and audit purposes.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interfaceLocation rdf:type rdf:Property ;
    rdfs:label 'Interface Location' ;
    rdfs:comment 'Specific location within the port facility where the ship-to-port or ship-to-ship interface takes place (e.g., berth number, anchorage area, terminal name).' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerOperationsFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Operations Flag' ;
    rdfs:comment 'Indicates whether passenger embarkation or disembarkation operations are covered under this Declaration of Security.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pfsoName rdf:type rdf:Property ;
    rdfs:label 'Pfso Name' ;
    rdfs:comment 'Full name of the Port Facility Security Officer who signed this Declaration of Security on behalf of the port facility.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pfso Signature Timestamp' ;
    rdfs:comment 'Date and time when the Port Facility Security Officer signed the Declaration of Security.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portMarsecLevel rdf:type rdf:Property ;
    rdfs:label 'Port Marsec Level' ;
    rdfs:comment 'MARSEC level declared by the port facility at the time of interface: 1 (normal), 2 (heightened), or 3 (exceptional).' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Port Security Measures' ;
    rdfs:comment 'Detailed description of the security measures the port facility agrees to implement during the interface, including access control, surveillance, patrols, screening procedures, and communication protocols.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified Flag' ;
    rdfs:comment 'Indicates whether the relevant national maritime security authority or Port State Control was notified of this Declaration of Security as required by local regulations.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Security Incident Flag' ;
    rdfs:comment 'Indicates whether any security incident occurred during the validity period of this Declaration of Security.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipToShipTransferFlag rdf:type rdf:Property ;
    rdfs:label 'Ship To Ship Transfer Flag' ;
    rdfs:comment 'Indicates whether ship-to-ship transfer operations are covered under this Declaration of Security.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storesDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Stores Delivery Flag' ;
    rdfs:comment 'Indicates whether ship stores delivery operations are covered under this Declaration of Security.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threatAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Threat Assessment Reference' ;
    rdfs:comment 'Reference number or identifier of the threat assessment conducted prior to the interface, which informed the security measures agreed in this Declaration of Security.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselMarsecLevel rdf:type rdf:Property ;
    rdfs:label 'Vessel Marsec Level' ;
    rdfs:comment 'MARSEC level declared by the vessel at the time of interface: 1 (normal), 2 (heightened), or 3 (exceptional).' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vesselMasterName rdf:type rdf:Property ;
    rdfs:label 'Vessel Master Name' ;
    rdfs:comment 'Full name of the vessel master (captain) who signed this Declaration of Security on behalf of the vessel.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Vessel Security Measures' ;
    rdfs:comment 'Detailed description of the security measures the vessel agrees to implement during the interface, including access control, surveillance, restricted areas, and communication protocols.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Vessel Signature Timestamp' ;
    rdfs:comment 'Date and time when the vessel master or Ship Security Officer signed the Declaration of Security.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vesselSsoName rdf:type rdf:Property ;
    rdfs:label 'Vessel Sso Name' ;
    rdfs:comment 'Full name of the Ship Security Officer who co-signed or endorsed this Declaration of Security on behalf of the vessel.' ;
    rdfs:domain ind:DosRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlSystemType rdf:type rdf:Property ;
    rdfs:label 'Access Control System Type' ;
    rdfs:comment 'Type or model of the access control system specified in the Port Facility Security Plan (e.g., RFID, biometric, card-based).' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Certificate Number' ;
    rdfs:comment 'Certificate reference number issued by the approval authority upon PFSP approval.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cctvCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Cctv Coverage Percentage' ;
    rdfs:comment 'Percentage of the port facility area covered by CCTV surveillance systems as specified in the security plan.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCertificateExpiry rdf:type rdf:Property ;
    rdfs:label 'Compliance Certificate Expiry' ;
    rdfs:comment 'Expiry date of the ISPS Code compliance certificate associated with this Port Facility Security Plan.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cybersecurityMeasuresIncluded rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Measures Included' ;
    rdfs:comment 'Indicates whether the Port Facility Security Plan includes specific cybersecurity measures for IT/OT systems protection.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentClassification rdf:type rdf:Property ;
    rdfs:label 'Document Classification' ;
    rdfs:comment 'Security classification level assigned to the Port Facility Security Plan document itself.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Document Storage Location' ;
    rdfs:comment 'Physical or digital location where the official Port Facility Security Plan document is securely stored.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Drill Frequency Months' ;
    rdfs:comment 'Frequency in months at which security drills and exercises must be conducted as specified in the plan.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastAmendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Description' ;
    rdfs:comment 'Brief description of the changes made in the most recent amendment to the Port Facility Security Plan.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marsecLevel1Measures rdf:type rdf:Property ;
    rdfs:label 'Marsec Level 1 Measures' ;
    rdfs:comment 'Summary of security measures and procedures defined in the plan for Maritime Security (MARSEC) Level 1 (normal operations).' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marsecLevel2Measures rdf:type rdf:Property ;
    rdfs:label 'Marsec Level 2 Measures' ;
    rdfs:comment 'Summary of heightened security measures and procedures defined in the plan for Maritime Security (MARSEC) Level 2 (heightened risk).' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marsecLevel3Measures rdf:type rdf:Property ;
    rdfs:label 'Marsec Level 3 Measures' ;
    rdfs:comment 'Summary of exceptional security measures and procedures defined in the plan for Maritime Security (MARSEC) Level 3 (probable or imminent security incident).' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDrillDate rdf:type rdf:Property ;
    rdfs:label 'Next Drill Date' ;
    rdfs:comment 'Scheduled date for the next mandatory security drill or exercise.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patrolFrequencyHours rdf:type rdf:Property ;
    rdfs:label 'Patrol Frequency Hours' ;
    rdfs:comment 'Frequency in hours at which security patrols must be conducted as specified in the Port Facility Security Plan.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pfsoContactNumber rdf:type rdf:Property ;
    rdfs:label 'Pfso Contact Number' ;
    rdfs:comment 'Primary contact telephone number for the designated Port Facility Security Officer.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Pfso Email Address' ;
    rdfs:comment 'Official email address for the designated Port Facility Security Officer.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Reference Number' ;
    rdfs:comment 'Official reference number assigned to the Port Facility Security Plan by the approval authority. Externally-known unique identifier for the plan.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Scope Description' ;
    rdfs:comment 'Detailed description of the scope and coverage of the Port Facility Security Plan, including physical boundaries, operations covered, and exclusions.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Frequency in months at which the Port Facility Security Plan must be reviewed and updated (e.g., 12, 24, 36 months).' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Security Assessment Reference' ;
    rdfs:comment 'Reference number or identifier of the Port Facility Security Assessment (PFSA) upon which this plan is based.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Threat Assessment Date' ;
    rdfs:comment 'Date of the most recent threat assessment conducted for the port facility as part of the security plan maintenance.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingProgramReference rdf:type rdf:Property ;
    rdfs:label 'Training Program Reference' ;
    rdfs:comment 'Reference to the security training and drill program defined in the Port Facility Security Plan.' ;
    rdfs:domain ind:FacilitySecurityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByChangeMarsecLevelChangeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Change Marsec Level Change Id' ;
    rdfs:comment 'Reference to the subsequent MARSEC level change that superseded this one. Null if this is the current active change.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarsecLevelChange .

ind:accessControlMeasures rdf:type rdf:Property ;
    rdfs:label 'Access Control Measures' ;
    rdfs:comment 'Description of the access control measures to be implemented at this MARSEC level (e.g., enhanced ID checks, escort requirements, restricted access zones).' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoScreeningRequirement rdf:type rdf:Property ;
    rdfs:label 'Cargo Screening Requirement' ;
    rdfs:comment 'The level of cargo screening required at this MARSEC level.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'Business identifier for the MARSEC level change event, formatted as MARSEC-YYYY-NNNNNN.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Coded reason category for the MARSEC level change. [ENUM-REF-CANDIDATE: threat_intelligence|security_incident|regional_conflict|terrorist_activity|piracy_alert|cyber_threat|drill_exercise — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the reason for the MARSEC level change, including threat assessment details and intelligence briefing summary.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cybersecurityPosture rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Posture' ;
    rdfs:comment 'The cybersecurity posture level for port IT/OT systems corresponding to this MARSEC level.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Declaration Timestamp' ;
    rdfs:comment 'The date and time when the MARSEC level change was officially declared by the issuing authority.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drillExerciseFlag rdf:type rdf:Property ;
    rdfs:label 'Drill Exercise Flag' ;
    rdfs:comment 'Indicates whether this MARSEC level change is part of a planned security drill or exercise rather than a real threat response.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationType rdf:type rdf:Property ;
    rdfs:label 'Duration Type' ;
    rdfs:comment 'Indicates whether the MARSEC level change is indefinite, temporary, or time-limited.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'The date and time when the new MARSEC level becomes effective and operational security posture changes must be implemented.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:issuingAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Type' ;
    rdfs:comment 'The type or classification of the authority that issued the MARSEC level change.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marsecLevelChangeStatus rdf:type rdf:Property ;
    rdfs:label 'Marsec Level Change Status' ;
    rdfs:comment 'Current lifecycle status of the MARSEC level change record.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newMarsecLevel rdf:type rdf:Property ;
    rdfs:label 'New Marsec Level' ;
    rdfs:comment 'The MARSEC level declared by this change. 1=Normal (minimum security measures), 2=Heightened (additional protective measures), 3=Exceptional (further specific protective measures).' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The primary method or channel used to notify stakeholders of the MARSEC level change. [ENUM-REF-CANDIDATE: port_community_system|email|vts_broadcast|edi_message|secure_portal|phone|fax — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patrolFrequencyChange rdf:type rdf:Property ;
    rdfs:label 'Patrol Frequency Change' ;
    rdfs:comment 'Description of changes to security patrol frequency and coverage required by this MARSEC level change.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoAcknowledgedFlag rdf:type rdf:Property ;
    rdfs:label 'Pfso Acknowledged Flag' ;
    rdfs:comment 'Indicates whether the Port Facility Security Officer has acknowledged receipt and understanding of the MARSEC level change.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pfsoAcknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pfso Acknowledged Timestamp' ;
    rdfs:comment 'The date and time when the PFSO acknowledged the MARSEC level change.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousMarsecLevel rdf:type rdf:Property ;
    rdfs:label 'Previous Marsec Level' ;
    rdfs:comment 'The MARSEC level in effect before this change. 1=Normal (minimum security measures), 2=Heightened (additional protective measures), 3=Exceptional (further specific protective measures).' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveillanceEnhancement rdf:type rdf:Property ;
    rdfs:label 'Surveillance Enhancement' ;
    rdfs:comment 'Description of enhancements to CCTV surveillance and monitoring required by this MARSEC level change.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselScreeningRequirement rdf:type rdf:Property ;
    rdfs:label 'Vessel Screening Requirement' ;
    rdfs:comment 'The level of vessel security screening required at this MARSEC level.' ;
    rdfs:domain ind:MarsecLevelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdaObservationId rdf:type rdf:Property ;
    rdfs:label 'Mda Observation Id' ;
    rdfs:comment 'Unique identifier for the maritime domain awareness observation record.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patrolId rdf:type rdf:Property ;
    rdfs:label 'Patrol Id' ;
    rdfs:comment 'Unique identifier of the security patrol dispatched in response to this observation if applicable.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patrol .

ind:primaryMdaPersonnelId rdf:type rdf:Property ;
    rdfs:label 'Primary Mda Personnel Id' ;
    rdfs:comment 'Unique identifier of the security officer or VTS operator who reported the observation.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Personnel .

ind:aisDataReference rdf:type rdf:Property ;
    rdfs:label 'Ais Data Reference' ;
    rdfs:comment 'Reference identifier linking to the AIS data record or VTS system log associated with this observation.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisStatus rdf:type rdf:Property ;
    rdfs:label 'Ais Status' ;
    rdfs:comment 'Status of the vessel AIS transmission at the time of observation indicating whether the vessel was broadcasting, dark, or exhibiting anomalous AIS behaviour.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cctvFootageAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Cctv Footage Available Flag' ;
    rdfs:comment 'Indicates whether CCTV footage of the observation location and time is available for review or evidence purposes.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:courseDegrees rdf:type rdf:Property ;
    rdfs:label 'Course Degrees' ;
    rdfs:comment 'Vessel course over ground in degrees (0-360) at the time of observation if available from AIS or radar tracking.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceFromPortNm rdf:type rdf:Property ;
    rdfs:label 'Distance From Port Nm' ;
    rdfs:comment 'Distance of the observation location from the port facility boundary measured in nautical miles.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flagState rdf:type rdf:Property ;
    rdfs:label 'Flag State' ;
    rdfs:comment 'Three-letter ISO country code representing the flag state of the vessel involved in the observation.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maritimeAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Maritime Authority Name' ;
    rdfs:comment 'Name of the maritime security authority or coast guard agency to which the observation was reported.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maritimeAuthorityNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Maritime Authority Notified Flag' ;
    rdfs:comment 'Indicates whether the observation was reported to the national maritime security authority, coast guard, or port state control.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observationNotes rdf:type rdf:Property ;
    rdfs:label 'Observation Notes' ;
    rdfs:comment 'Detailed narrative description of the observation including circumstances, behaviour patterns, environmental conditions, and any other relevant contextual information.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationNumber rdf:type rdf:Property ;
    rdfs:label 'Observation Number' ;
    rdfs:comment 'Human-readable reference number assigned to the observation for tracking and reporting purposes.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationType rdf:type rdf:Property ;
    rdfs:label 'Observation Type' ;
    rdfs:comment 'Classification of the maritime domain awareness observation indicating the nature of the security concern or anomaly detected.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoComments rdf:type rdf:Property ;
    rdfs:label 'Pfso Comments' ;
    rdfs:comment 'Comments or assessment notes provided by the Port Facility Security Officer during review of the observation.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pfso Review Timestamp' ;
    rdfs:comment 'Date and time when the Port Facility Security Officer reviewed the observation.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pfsoReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Pfso Reviewed Flag' ;
    rdfs:comment 'Indicates whether the observation has been reviewed by the Port Facility Security Officer.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Reporting Officer Name' ;
    rdfs:comment 'Name of the security officer or VTS operator who reported the observation for accountability and follow-up purposes.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSource rdf:type rdf:Property ;
    rdfs:label 'Reporting Source' ;
    rdfs:comment 'Source entity or system that generated or reported the maritime domain awareness observation. [ENUM-REF-CANDIDATE: vts|coast_guard|port_security_patrol|cctv|radar|pilot|harbour_master|third_party — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityIncidentCreatedFlag rdf:type rdf:Property ;
    rdfs:label 'Security Incident Created Flag' ;
    rdfs:comment 'Indicates whether a formal security incident record was created as a result of this observation.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityPatrolDispatchedFlag rdf:type rdf:Property ;
    rdfs:label 'Security Patrol Dispatched Flag' ;
    rdfs:comment 'Indicates whether a security patrol was dispatched to investigate or respond to the observation.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:speedKnots rdf:type rdf:Property ;
    rdfs:label 'Speed Knots' ;
    rdfs:comment 'Vessel speed over ground in knots at the time of observation if available from AIS or radar tracking.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:threatLevel rdf:type rdf:Property ;
    rdfs:label 'Threat Level' ;
    rdfs:comment 'Assessed threat level of the observation based on the nature of the activity, proximity to critical infrastructure, and intelligence context.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselChallengedFlag rdf:type rdf:Property ;
    rdfs:label 'Vessel Challenged Flag' ;
    rdfs:comment 'Indicates whether the vessel was challenged via VHF radio or other communication means to identify itself or explain its behaviour.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vesselResponse rdf:type rdf:Property ;
    rdfs:label 'Vessel Response' ;
    rdfs:comment 'Summary of the vessel response to any challenge or communication attempt made by port security or VTS.' ;
    rdfs:domain ind:MdaObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselType rdf:type rdf:Property ;
    rdfs:label 'Vessel Type' ;
    rdfs:comment 'Classification of the vessel type involved in the observation such as cargo, tanker, fishing, pleasure craft, or unknown.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Triggered Flag' ;
    rdfs:comment 'Indicates whether the screening triggered an automated or manual security alert requiring further action.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biometricVerificationType rdf:type rdf:Property ;
    rdfs:label 'Biometric Verification Type' ;
    rdfs:comment 'Type of biometric verification performed during screening, if any. None indicates no biometric check was conducted.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Notification Flag' ;
    rdfs:comment 'Indicates whether customs authorities were notified as a result of this screening (e.g., for prohibited goods, watchlist match, or trade compliance issue).' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Date' ;
    rdfs:comment 'Expiration date of the document checked, if applicable. Used to verify document validity at time of screening.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Document Issuing Authority' ;
    rdfs:comment 'Name of the authority or country that issued the document being verified (e.g., government agency, port authority, classification society).' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypeChecked rdf:type rdf:Property ;
    rdfs:label 'Document Type Checked' ;
    rdfs:comment 'Type of document verified during screening (e.g., passport, national ID, seafarer ID, driver license, port pass, vessel certificate, cargo manifest, dangerous goods declaration, BOL).' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAction rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action' ;
    rdfs:comment 'Action taken as a result of the screening outcome. Documents the operational response to the screening result. [ENUM-REF-CANDIDATE: none|secondary_screening|supervisor_review|law_enforcement_notified|customs_referral|access_denied|item_confiscated|incident_report_filed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReportReference rdf:type rdf:Property ;
    rdfs:label 'Incident Report Reference' ;
    rdfs:comment 'Reference number of any security incident report filed as a result of this screening, if applicable. Links to incident management system.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedItemDescription rdf:type rdf:Property ;
    rdfs:label 'Prohibited Item Description' ;
    rdfs:comment 'Detailed description of any prohibited or restricted items detected, including quantity, type, and classification (e.g., IMDG class for dangerous goods).' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedItemDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Prohibited Item Detected Flag' ;
    rdfs:comment 'Indicates whether prohibited or restricted items (weapons, explosives, contraband, dangerous goods) were detected during screening.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:radiationReading rdf:type rdf:Property ;
    rdfs:label 'Radiation Reading' ;
    rdfs:comment 'Radiation level detected during screening, measured in microsieverts per hour (μSv/h). Applicable when radiation detection equipment is used.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:radiationThresholdExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Radiation Threshold Exceeded Flag' ;
    rdfs:comment 'Indicates whether the detected radiation level exceeded the port facility\'s safety threshold, triggering an alert.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Screening Duration Seconds' ;
    rdfs:comment 'Total time taken to complete the screening process, measured in seconds. Used for throughput analysis and SLA monitoring.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screeningLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Screening Location Description' ;
    rdfs:comment 'Textual description of the specific location within the port facility where the screening took place (e.g., Main Gate 1, Container Yard Entrance, Vessel Gangway, CFS Building).' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningMethod rdf:type rdf:Property ;
    rdfs:label 'Screening Method' ;
    rdfs:comment 'Primary method or technology used to conduct the screening. ANPR = Automatic Number Plate Recognition for vehicles. Biometric verification includes fingerprint, facial recognition, iris scan. [ENUM-REF-CANDIDATE: document_check|x_ray_scan|physical_search|anpr|biometric_verification|radiation_detection|explosive_trace_detection|canine_inspection|metal_detector|cctv_review — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Number' ;
    rdfs:comment 'Human-readable unique reference number assigned to this screening event for tracking and audit purposes.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningOfficerName rdf:type rdf:Property ;
    rdfs:label 'Screening Officer Name' ;
    rdfs:comment 'Full name of the security officer who performed the screening for audit trail and accountability.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningOutcome rdf:type rdf:Property ;
    rdfs:label 'Screening Outcome' ;
    rdfs:comment 'Result of the screening check. Cleared: passed all checks. Flagged: alert triggered, requires review. Denied: access refused. Referred: escalated to supervisor. Pending review: awaiting additional verification. Escalated: sent to law enforcement or customs.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryScreeningMethod rdf:type rdf:Property ;
    rdfs:label 'Secondary Screening Method' ;
    rdfs:comment 'Additional screening method applied if primary screening triggered an alert or as part of enhanced security protocol. Same value set as screening_method.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectIdentifier rdf:type rdf:Property ;
    rdfs:label 'Subject Identifier' ;
    rdfs:comment 'Unique identifier of the subject being screened. For persons: employee ID, visitor badge number, passport number. For vehicles: license plate (ANPR). For cargo: BOL number. For vessels: IMO number. For containers: container number.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectName rdf:type rdf:Property ;
    rdfs:label 'Subject Name' ;
    rdfs:comment 'Name or description of the subject being screened. For persons: full name. For vehicles: make/model. For cargo: cargo description. For vessels: vessel name. For containers: container owner/operator.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Category of entity being screened: person (crew, visitor, worker), vehicle (truck, car), cargo (shipment, package), vessel (ship, barge), container (TEU/FEU), or equipment (mobile harbor crane, forklift).' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisor Override Flag' ;
    rdfs:comment 'Indicates whether a supervisor manually overrode the screening outcome or system recommendation.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisorOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Supervisor Override Reason' ;
    rdfs:comment 'Explanation provided by the supervisor for overriding the screening outcome, if applicable. Confidential for security audit purposes.' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Watchlist Match Flag' ;
    rdfs:comment 'Indicates whether the subject matched an entry on a security watchlist (customs, border control, law enforcement, or internal port security watchlist).' ;
    rdfs:domain ind:ScreeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityAuditId rdf:type rdf:Property ;
    rdfs:label 'Security Audit Id' ;
    rdfs:comment 'Unique identifier for the security audit record. Primary key for the security audit entity.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityAudit .

ind:areasAudited rdf:type rdf:Property ;
    rdfs:label 'Areas Audited' ;
    rdfs:comment 'Comma-separated list of specific security functional areas covered in the audit, such as access control, CCTV surveillance, perimeter security, cargo security, vessel interface security, cybersecurity, personnel security, security training, incident response, and security equipment maintenance.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique business identifier for the security audit, typically formatted as SA-YYYY-NNNNNN for tracking and reference purposes.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditing Organization' ;
    rdfs:comment 'Name of the organization or authority conducting the security audit. For internal audits, this is the port authority; for external audits, this is the third-party auditing firm or regulatory body.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationImpact rdf:type rdf:Property ;
    rdfs:label 'Certification Impact' ;
    rdfs:comment 'Impact of audit findings on port facility ISPS Code certification status. None indicates no impact on certification, warning indicates formal notice issued, suspension indicates temporary suspension of certification pending corrective action, and revocation indicates permanent withdrawal of certification.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Closure Verification Date' ;
    rdfs:comment 'Date when the auditing authority formally verified that all corrective actions have been effectively implemented and the audit can be closed.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conformancesCount rdf:type rdf:Property ;
    rdfs:label 'Conformances Count' ;
    rdfs:comment 'Total number of audit findings where port facility security operations were found to be in full conformance with ISPS Code requirements, national maritime security regulations, and internal security standards.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionPlanApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Approved Date' ;
    rdfs:comment 'Date when the corrective action plan was formally approved by the auditing authority, authorizing implementation of corrective measures.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Due Date' ;
    rdfs:comment 'Target date by which the corrective action plan must be submitted to address all identified non-conformances. Typically set by the auditing authority based on severity of findings.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Required' ;
    rdfs:comment 'Boolean flag indicating whether a formal corrective action plan is required to address audit non-conformances. True when non-conformances were identified, false when audit resulted in full conformance.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionPlanSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Submitted Date' ;
    rdfs:comment 'Actual date when the corrective action plan was formally submitted to the auditing authority for review and approval.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionsCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Completion Date' ;
    rdfs:comment 'Date when all corrective actions identified in the corrective action plan were completed and verified. This date marks the closure of all non-conformances.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost amount, such as USD, EUR, or GBP.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitiesAudited rdf:type rdf:Property ;
    rdfs:label 'Facilities Audited' ;
    rdfs:comment 'Comma-separated list of specific port facilities, terminals, berths, or zones included in the audit scope. May include container terminals, bulk cargo terminals, passenger terminals, restricted areas, and security control rooms.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'Scheduled date for the follow-up audit to verify corrective action effectiveness. Typically scheduled 3-6 months after corrective actions completion.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required' ;
    rdfs:comment 'Boolean flag indicating whether a follow-up audit is required to verify implementation and effectiveness of corrective actions. True when major non-conformances were identified or when regulatory authority mandates verification audit.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsCodeComplianceLevel rdf:type rdf:Property ;
    rdfs:label 'Isps Code Compliance Level' ;
    rdfs:comment 'Overall ISPS Code compliance level determined by the audit. Level 1 indicates normal security measures, Level 2 indicates heightened security measures, Level 3 indicates exceptional security measures, and non-compliant indicates failure to meet minimum ISPS Code requirements.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for conducting and overseeing the security audit. The lead auditor is accountable for audit planning, execution, and reporting.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNonConformancesCount rdf:type rdf:Property ;
    rdfs:label 'Major Non Conformances Count' ;
    rdfs:comment 'Number of critical non-conformances that pose significant security risks or represent systemic failures in security management. Major non-conformances may result in suspension of ISPS Code certification or port facility security plan approval.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Description of the audit methodology employed, including document review, physical inspection, personnel interviews, security system testing, and compliance verification techniques used during the audit.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorNonConformancesCount rdf:type rdf:Property ;
    rdfs:label 'Minor Non Conformances Count' ;
    rdfs:comment 'Number of non-critical non-conformances that represent isolated lapses or documentation deficiencies but do not pose immediate security threats. Minor non-conformances require corrective action but do not jeopardize certification.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonConformancesCount rdf:type rdf:Property ;
    rdfs:label 'Non Conformances Count' ;
    rdfs:comment 'Total number of audit findings where port facility security operations failed to meet ISPS Code requirements, national maritime security regulations, or internal security standards. Non-conformances require mandatory corrective action.' ;
    rdfs:domain ind:SecurityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Security Corrective Action Id' ;
    rdfs:comment 'Unique identifier for the security corrective action record. Primary key.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillId rdf:type rdf:Property ;
    rdfs:label 'Drill Id' ;
    rdfs:comment 'Foreign key linking to security.drill. Business justification: Corrective actions arise from drill deficiencies. The source_type field indicates \'drill\' as a source, and drill.deficiencies_identified and drill.corrective_actions_raised fields confirm this relatio' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Drill .

ind:primarySecurityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Security Employee Id' ;
    rdfs:comment 'Identifier of the security officer or personnel assigned primary responsibility for implementing this corrective action. Links to workforce or security personnel master data.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionCategory rdf:type rdf:Property ;
    rdfs:label 'Action Category' ;
    rdfs:comment 'Classification of the corrective action by type: procedural (process changes), physical (infrastructure/equipment), technical (IT/OT systems), training (personnel development), policy (documentation updates), or organizational (structural changes).' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative description of the corrective or preventive action to be taken, including specific steps, controls to be implemented, and expected outcomes.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionPriority rdf:type rdf:Property ;
    rdfs:label 'Action Priority' ;
    rdfs:comment 'Priority level assigned to the corrective action based on risk severity and urgency. Critical actions require immediate implementation; low priority actions may be scheduled for routine maintenance windows.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action. Tracks progression from identification through implementation, verification, and closure. [ENUM-REF-CANDIDATE: open|in_progress|pending_verification|verified|closed|cancelled|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Closure Approved By' ;
    rdfs:comment 'Name or identifier of the authority (typically PFSO or senior security manager) who approved the closure of the corrective action.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToComplete rdf:type rdf:Property ;
    rdfs:label 'Days To Complete' ;
    rdfs:comment 'The number of calendar days between identification and actual completion. Used for performance measurement and SLA compliance tracking.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'The date on which the need for this corrective action was identified, typically the date of the source incident, audit finding, or drill deficiency.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ispsComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Isps Compliance Impact' ;
    rdfs:comment 'Assessment of the impact of the underlying deficiency on ISPS Code compliance. Critical impact indicates a material breach requiring immediate remediation and potential regulatory notification.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdueFlag rdf:type rdf:Property ;
    rdfs:label 'Overdue Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the corrective action is past its target completion date without being closed. True indicates overdue status requiring escalation.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActionFlag rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this action is preventive (addressing potential future issues) rather than corrective (addressing existing deficiencies). True indicates preventive action.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedActionIds rdf:type rdf:Property ;
    rdfs:label 'Related Action Ids' ;
    rdfs:comment 'Comma-separated list of related corrective action IDs that address the same root cause or are part of a coordinated remediation effort. Enables tracking of action clusters.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Name' ;
    rdfs:comment 'Full name of the security officer or personnel responsible for implementing the corrective action. Denormalized for reporting convenience.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether a formal root cause analysis was conducted for the underlying issue. True indicates RCA was performed.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Summary' ;
    rdfs:comment 'Summary of the root cause identified through analysis. Describes the underlying systemic or procedural failure that necessitated the corrective action.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityPlanAmendmentReference rdf:type rdf:Property ;
    rdfs:label 'Security Plan Amendment Reference' ;
    rdfs:comment 'Reference number or identifier of the Facility Security Plan amendment that incorporates this corrective action. Null if no amendment was required.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityPlanAmendmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Security Plan Amendment Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the corrective action necessitates an amendment to the Facility Security Plan (FSP). True indicates FSP update is required.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Detailed notes from the verification officer documenting findings, evidence reviewed, and rationale for the verification outcome.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationOfficerName rdf:type rdf:Property ;
    rdfs:label 'Verification Officer Name' ;
    rdfs:comment 'Full name of the officer or auditor who verified the corrective action. Denormalized for audit trail purposes.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'The result of the verification process. Effective indicates the action resolved the issue; partially effective or ineffective may trigger additional corrective actions.' ;
    rdfs:domain ind:SecurityCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Drill Coordinator Employee Id' ;
    rdfs:comment 'Identifier of the personnel assigned to coordinate and facilitate the security drill execution.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:drillEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Drill Employee Id' ;
    rdfs:comment 'Identifier of the Port Facility Security Officer responsible for planning, conducting, and signing off on the security drill as required by ISPS Code.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Additional audit trail notes and administrative comments related to the drill record, including any amendments or follow-up actions.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRaised rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Raised' ;
    rdfs:comment 'List of corrective actions and improvement measures raised as a result of the drill findings, to be tracked through completion.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficienciesIdentified rdf:type rdf:Property ;
    rdfs:label 'Deficiencies Identified' ;
    rdfs:comment 'Detailed description of any deficiencies, gaps, or weaknesses identified during the security drill that require corrective action.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillNumber rdf:type rdf:Property ;
    rdfs:label 'Drill Number' ;
    rdfs:comment 'Business identifier for the security drill, typically a sequential or formatted reference number used for external communication and audit trails.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillStatus rdf:type rdf:Property ;
    rdfs:label 'Drill Status' ;
    rdfs:comment 'Current status of the security drill in its lifecycle from planning through completion and sign-off.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTested rdf:type rdf:Property ;
    rdfs:label 'Equipment Tested' ;
    rdfs:comment 'List of security equipment and systems tested during the drill (e.g., CCTV, access control systems, communication devices, alarms, barriers).' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgenciesInvolved rdf:type rdf:Property ;
    rdfs:label 'External Agencies Involved' ;
    rdfs:comment 'List of external agencies, authorities, or organizations that participated in or observed the security drill (e.g., coast guard, police, customs, port state control).' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDrillDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Drill Due Date' ;
    rdfs:comment 'Calculated or scheduled date for the next required security drill of this type, based on ISPS Code frequency requirements (minimum intervals).' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objectives rdf:type rdf:Property ;
    rdfs:label 'Objectives' ;
    rdfs:comment 'Stated objectives and goals for the security drill, defining what capabilities, procedures, or responses are being tested and validated.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomesSummary rdf:type rdf:Property ;
    rdfs:label 'Outcomes Summary' ;
    rdfs:comment 'Summary of the outcomes and results of the security drill, including performance observations, response effectiveness, and overall assessment.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of personnel who participated in the security drill, used for compliance reporting and resource planning.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participatingDepartments rdf:type rdf:Property ;
    rdfs:label 'Participating Departments' ;
    rdfs:comment 'List of port facility departments and units that participated in the security drill, comma-separated or structured format.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoSignOffComments rdf:type rdf:Property ;
    rdfs:label 'Pfso Sign Off Comments' ;
    rdfs:comment 'Comments and observations provided by the PFSO during sign-off, including approval notes or additional recommendations.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoSignOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pfso Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the PFSO formally signed off on the drill report and outcomes, confirming review and acceptance.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proceduresTested rdf:type rdf:Property ;
    rdfs:label 'Procedures Tested' ;
    rdfs:comment 'List of security procedures and protocols tested during the drill, referencing sections of the Port Facility Security Plan (PFSP).' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioDescription rdf:type rdf:Property ;
    rdfs:label 'Scenario Description' ;
    rdfs:comment 'Detailed description of the security scenario simulated during the drill, including threat type, location, and simulated conditions. Confidential to prevent security vulnerability disclosure.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevelDuringDrill rdf:type rdf:Property ;
    rdfs:label 'Security Level During Drill' ;
    rdfs:comment 'ISPS Code security level in effect at the port facility during the drill (Level 1: normal, Level 2: heightened, Level 3: exceptional). Impacts drill scope and procedures.' ;
    rdfs:domain ind:Drill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupPowerAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Power Available Flag' ;
    rdfs:comment 'Indicates whether the security equipment has backup power supply (UPS or generator) to maintain operation during power outages, as required by ISPS Code for critical security systems.' ;
    rdfs:domain ind:SecurityEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calibrationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Months' ;
    rdfs:comment 'Required interval in months between calibrations for this security equipment type as specified by manufacturer or regulatory authority.' ;
    rdfs:domain ind:SecurityEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationAuthority rdf:type rdf:Property ;
    rdfs:label 'Certification Authority' ;
    rdfs:comment 'Name of the regulatory body or certification authority that issued the equipment certification (e.g., national maritime authority, TSA, customs authority).' ;
    rdfs:domain ind:SecurityEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentLocation rdf:type rdf:Property ;
    rdfs:label 'Deployment Location' ;
    rdfs:comment 'Physical location within the port facility where the security equipment is deployed. Examples include main gate, cargo screening area, passenger terminal entrance, perimeter fence zone 3, etc.' ;
    rdfs:domain ind:SecurityEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Expected Useful Life Years' ;
    rdfs:comment 'Expected useful operational life of the security equipment in years, used for asset replacement planning and depreciation calculations.' ;
    rdfs:domain ind:SecurityEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage in the asset lifecycle indicating whether the equipment is new, in operational service, aging and requiring increased maintenance, approaching end of life, or obsolete.' ;
    rdfs:domain ind:SecurityEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule Reference' ;
    rdfs:comment 'Reference number or identifier linking this equipment to its maintenance plan in the asset management system (e.g., Maximo work plan number).' ;
    rdfs:domain ind:SecurityEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTemperatureRange rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Range' ;
    rdfs:comment 'Manufacturer-specified temperature range within which the security equipment can operate reliably (e.g., -20°C to +60°C). Important for equipment deployed in outdoor or extreme environments.' ;
    rdfs:domain ind:SecurityEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagNumber rdf:type rdf:Property ;
    rdfs:label 'Tag Number' ;
    rdfs:comment 'Unique asset tag number assigned to the security equipment for physical identification and tracking. Typically affixed to the equipment as a barcode or RFID tag.' ;
    rdfs:domain ind:SecurityEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlLogsReference rdf:type rdf:Property ;
    rdfs:label 'Access Control Logs Reference' ;
    rdfs:comment 'Reference identifier for access control system logs relevant to the incident (badge swipes, gate entries, biometric records).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Involved Flag' ;
    rdfs:comment 'Boolean flag indicating whether cargo was involved in or affected by the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cctvFootageReference rdf:type rdf:Property ;
    rdfs:label 'Cctv Footage Reference' ;
    rdfs:comment 'Reference identifier or storage location for CCTV footage related to the incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDatetime rdf:type rdf:Property ;
    rdfs:label 'Closed Datetime' ;
    rdfs:comment 'Date and time when the security incident was officially closed after resolution and completion of all follow-up actions.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:immediateResponseActions rdf:type rdf:Property ;
    rdfs:label 'Immediate Response Actions' ;
    rdfs:comment 'Detailed description of immediate response actions taken by security personnel, PFSO, or emergency responders to contain and address the incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Case Number' ;
    rdfs:comment 'Case or reference number assigned by law enforcement agency if the incident was reported to police or other authorities.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified Flag' ;
    rdfs:comment 'Boolean flag indicating whether local or national law enforcement agencies were notified of the incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationBerth rdf:type rdf:Property ;
    rdfs:label 'Location Berth' ;
    rdfs:comment 'Specific berth identifier where the incident occurred, if applicable. Null if incident did not occur at a berth.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCoordinates rdf:type rdf:Property ;
    rdfs:label 'Location Coordinates' ;
    rdfs:comment 'Geographic coordinates (latitude, longitude) of the incident location for precise mapping and spatial analysis.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationGate rdf:type rdf:Property ;
    rdfs:label 'Location Gate' ;
    rdfs:comment 'Specific gate identifier where the incident occurred, if applicable. Null if incident did not occur at a gate.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalAuthorityEscalatedDatetime rdf:type rdf:Property ;
    rdfs:label 'National Authority Escalated Datetime' ;
    rdfs:comment 'Date and time when the incident was escalated to the national maritime security authority.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nationalAuthorityEscalatedFlag rdf:type rdf:Property ;
    rdfs:label 'National Authority Escalated Flag' ;
    rdfs:comment 'Boolean flag indicating whether the incident was escalated to the national maritime security authority or designated security agency.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personsInvolvedCount rdf:type rdf:Property ;
    rdfs:label 'Persons Involved Count' ;
    rdfs:comment 'Number of persons directly involved in or associated with the security incident (perpetrators, suspects, witnesses).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personsInvolvedDescription rdf:type rdf:Property ;
    rdfs:label 'Persons Involved Description' ;
    rdfs:comment 'Detailed description of persons involved in the incident including physical descriptions, identification details, and roles. Confidential for security purposes.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoNotifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Pfso Notified Datetime' ;
    rdfs:comment 'Date and time when the PFSO was notified of the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portAuthorityNotifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Port Authority Notified Datetime' ;
    rdfs:comment 'Date and time when the port authority was notified of the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portAuthorityNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Port Authority Notified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the port authority was notified of the incident.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Detailed sub-classification of the incident type providing additional granularity for analysis and reporting (e.g., vehicle intrusion, gate breach, cargo tampering).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Unique identifier for the security investigation record. Primary key.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessLogReferences rdf:type rdf:Property ;
    rdfs:label 'Access Log References' ;
    rdfs:comment 'References to access control system logs examined during the investigation. Includes badge swipes, gate entries, biometric scans, and system access records.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cctvFootageReferences rdf:type rdf:Property ;
    rdfs:label 'Cctv Footage References' ;
    rdfs:comment 'References to CCTV video clips and camera identifiers relevant to the investigation. Includes camera locations, timestamps, and storage system references.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'Name or identifier of the person or role who authorized closure of the investigation. Typically Port Facility Security Officer (PFSO) or senior security management.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'Data classification level for the investigation record. Determines access controls and information sharing restrictions. Most investigations are confidential or restricted.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionTaken rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Taken' ;
    rdfs:comment 'Indicates whether disciplinary action was taken against personnel as a result of the investigation findings. Details stored separately with HR records.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceCollected rdf:type rdf:Property ;
    rdfs:label 'Evidence Collected' ;
    rdfs:comment 'Comprehensive list of evidence collected during the investigation including CCTV footage references, access log extracts, witness statement identifiers, physical evidence, and digital forensics artifacts.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident End Timestamp' ;
    rdfs:comment 'Reconstructed date and time when the security incident concluded or was contained, based on investigation findings and evidence analysis.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Start Timestamp' ;
    rdfs:comment 'Reconstructed date and time when the security incident is believed to have started, based on investigation findings and evidence analysis.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Name or identifier of the person or role who authorized the initiation of the investigation. Typically Port Facility Security Officer (PFSO) or senior security management.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementNotified rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified' ;
    rdfs:comment 'Indicates whether law enforcement authorities were notified of the incident and investigation. Required for certain incident types under ISPS Code and local regulations.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalImpactHours rdf:type rdf:Property ;
    rdfs:label 'Operational Impact Hours' ;
    rdfs:comment 'Total hours of operational disruption caused by the security incident. Includes facility closures, berth unavailability, gate delays, or system downtime.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personnelInvolvedCount rdf:type rdf:Property ;
    rdfs:label 'Personnel Involved Count' ;
    rdfs:comment 'Number of personnel identified as involved in or affected by the security incident. May include suspects, victims, witnesses, or responders.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendations rdf:type rdf:Property ;
    rdfs:label 'Recommendations' ;
    rdfs:comment 'Formal recommendations for corrective actions, security enhancements, procedural changes, training requirements, or system improvements to prevent recurrence.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDetermination rdf:type rdf:Property ;
    rdfs:label 'Root Cause Determination' ;
    rdfs:comment 'Identified root cause of the security incident based on investigation analysis. May include human error, system failure, procedural gap, external threat, or combination of factors.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityControlFailures rdf:type rdf:Property ;
    rdfs:label 'Security Control Failures' ;
    rdfs:comment 'Specific security controls, systems, or procedures that failed or were found inadequate during the incident. Identifies gaps in the port facility security plan.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityPlanAmendmentRequired rdf:type rdf:Property ;
    rdfs:label 'Security Plan Amendment Required' ;
    rdfs:comment 'Indicates whether the Port Facility Security Plan (PFSP) must be amended based on investigation findings and identified security gaps.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:team rdf:type rdf:Property ;
    rdfs:label 'Team' ;
    rdfs:comment 'Comma-separated list of team member names or identifiers involved in the investigation. May include internal security staff, external consultants, and law enforcement liaisons.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineOfEvents rdf:type rdf:Property ;
    rdfs:label 'Timeline Of Events' ;
    rdfs:comment 'Chronological reconstruction of events during the incident based on evidence collected. Includes key actions, observations, and system events in sequence.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessStatementSummary rdf:type rdf:Property ;
    rdfs:label 'Witness Statement Summary' ;
    rdfs:comment 'Aggregated summary of key information from witness statements. Individual witness identities are protected; detailed statements stored separately with restricted access.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessStatementsCount rdf:type rdf:Property ;
    rdfs:label 'Witness Statements Count' ;
    rdfs:comment 'Number of formal witness statements collected during the investigation from personnel, contractors, visitors, or other parties with relevant information.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityZoneId rdf:type rdf:Property ;
    rdfs:label 'Facility Zone Id' ;
    rdfs:comment 'Port facility zone or area where the patrol is conducted, such as restricted area, cargo terminal, berth area, or perimeter zone.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:patrolBackupOfficerSecurityPersonnelId rdf:type rdf:Property ;
    rdfs:label 'Patrol Backup Officer Security Personnel Id' ;
    rdfs:comment 'Secondary security officer assigned to accompany or provide backup support during the patrol. Nullable for single-officer patrols.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Personnel .

ind:patrolPersonnelId rdf:type rdf:Property ;
    rdfs:label 'Patrol Personnel Id' ;
    rdfs:comment 'Primary security officer assigned to lead and execute this patrol. References the workforce or security personnel master data.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Personnel .

ind:patrolSupervisorSecurityPersonnelId rdf:type rdf:Property ;
    rdfs:label 'Patrol Supervisor Security Personnel Id' ;
    rdfs:comment 'Security supervisor who reviewed and approved the patrol log. Nullable if review is pending or not required.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Personnel .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Predefined route or path that the patrol is scheduled to follow, referencing the patrol route master data with checkpoint sequences.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatrolRoute .

ind:accessControlChecks rdf:type rdf:Property ;
    rdfs:label 'Access Control Checks' ;
    rdfs:comment 'Number of access control points, gates, or entry barriers inspected during the patrol to verify proper functioning and compliance with security protocols.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual date and time when the patrol was completed, recorded by the security officer at patrol conclusion for duration tracking and shift reconciliation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual date and time when the patrol commenced, recorded by the security officer at patrol initiation for compliance tracking and variance analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:anomaliesDetected rdf:type rdf:Property ;
    rdfs:label 'Anomalies Detected' ;
    rdfs:comment 'Count of security anomalies, irregularities, or suspicious activities observed during the patrol that require documentation or follow-up action.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anomalyDescription rdf:type rdf:Property ;
    rdfs:label 'Anomaly Description' ;
    rdfs:comment 'Detailed narrative description of any security anomalies, irregularities, suspicious activities, or non-compliance observations identified during the patrol, including location, time, and nature of the finding.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cctvVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Cctv Verification Flag' ;
    rdfs:comment 'Boolean indicator whether CCTV surveillance systems were verified as operational during the patrol. True indicates verification performed, False indicates not checked.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkpointsCompleted rdf:type rdf:Property ;
    rdfs:label 'Checkpoints Completed' ;
    rdfs:comment 'Actual number of security checkpoints successfully visited and verified during the patrol execution, used for patrol compliance measurement.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkpointsPlanned rdf:type rdf:Property ;
    rdfs:label 'Checkpoints Planned' ;
    rdfs:comment 'Total number of security checkpoints or inspection points planned to be visited during this patrol route, used for patrol completion verification.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distanceCoveredKm rdf:type rdf:Property ;
    rdfs:label 'Distance Covered Km' ;
    rdfs:comment 'Total distance covered during the patrol in kilometers, tracked via GPS or vehicle odometer for vehicle and waterside patrols, used for patrol coverage analysis.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Reported Flag' ;
    rdfs:comment 'Boolean indicator whether a formal security incident was reported as a result of this patrol. True indicates an incident report was filed, False indicates no incident escalation required.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lightingVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Lighting Verification Flag' ;
    rdfs:comment 'Boolean indicator whether security lighting systems were verified as operational during the patrol. True indicates verification performed, False indicates not checked.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patrolNumber rdf:type rdf:Property ;
    rdfs:label 'Patrol Number' ;
    rdfs:comment 'Business identifier for the patrol assignment, formatted as PAT-YYYYMMDD-NNNN for external reference and reporting.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patrolStatus rdf:type rdf:Property ;
    rdfs:label 'Patrol Status' ;
    rdfs:comment 'Current lifecycle status of the patrol: scheduled for planned but not started, in_progress for active patrol, completed for finished patrol, cancelled for pre-start cancellation, suspended for temporary halt, or aborted for early termination due to incident or emergency.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patrolType rdf:type rdf:Property ;
    rdfs:label 'Patrol Type' ;
    rdfs:comment 'Classification of the patrol method used: foot patrol for walking inspections, vehicle patrol for mobile inspections, waterside patrol for marine-side security, perimeter patrol for fence line checks, combined for multi-method patrols, or roving for random pattern patrols.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perimeterIntegrityFlag rdf:type rdf:Property ;
    rdfs:label 'Perimeter Integrity Flag' ;
    rdfs:comment 'Boolean indicator whether the facility perimeter (fencing, barriers, gates) was verified as intact and secure during the patrol. True indicates integrity confirmed, False indicates breach or damage detected.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the patrol log was reviewed and approved by the supervisor. Nullable if review is pending.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Planned date and time when the patrol is scheduled to be completed, used for patrol duration planning and shift management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Planned date and time when the patrol is scheduled to commence, as defined in the patrol roster or security operations plan.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisorReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Flag' ;
    rdfs:comment 'Boolean indicator whether the patrol log has been reviewed and approved by a security supervisor. True indicates reviewed, False indicates pending review.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Code' ;
    rdfs:comment 'Reference to the security vehicle or patrol vessel used for vehicle or waterside patrols. Nullable for foot patrols.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Visibility Level' ;
    rdfs:comment 'Assessment of visibility conditions during the patrol, affecting the officers ability to detect security threats or anomalies. Factors include lighting, weather, and time of day.' ;
    rdfs:domain ind:Patrol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySecurityPostId rdf:type rdf:Property ;
    rdfs:label 'Primary Security Post Id' ;
    rdfs:comment 'Reference to the primary security post or station where this personnel is normally assigned for duty.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Post .

ind:clearanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Expiry Date' ;
    rdfs:comment 'Date on which the security clearance expires and re-vetting is required.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceIssueDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Issue Date' ;
    rdfs:comment 'Date on which the current security clearance was granted following background checks and vetting.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'Official email address for security communications, incident notifications, and operational coordination.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deputyPfsoFlag rdf:type rdf:Property ;
    rdfs:label 'Deputy Pfso Flag' ;
    rdfs:comment 'Indicates whether this personnel is designated as a deputy PFSO authorized to act in the absence of the primary PFSO.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firearmsAuthorisationFlag rdf:type rdf:Property ;
    rdfs:label 'Firearms Authorisation Flag' ;
    rdfs:comment 'Indicates whether the security personnel is authorized to carry and use firearms while on duty at the port facility.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firearmsLicenceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Firearms Licence Expiry Date' ;
    rdfs:comment 'Expiry date of the firearms licence. Null if no firearms authorisation.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firearmsLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Firearms Licence Number' ;
    rdfs:comment 'Official firearms licence number if the personnel is authorized to carry weapons. Null if firearms_authorisation_flag is false.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date on which the security personnel was hired or contracted to begin security duties at the port facility.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ispsTrainingCertification rdf:type rdf:Property ;
    rdfs:label 'Isps Training Certification' ;
    rdfs:comment 'Certification number for ISPS Code training completion, demonstrating the personnel has received required security awareness and operational training.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsTrainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Isps Training Completion Date' ;
    rdfs:comment 'Date on which the personnel successfully completed ISPS Code security training.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ispsTrainingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Isps Training Expiry Date' ;
    rdfs:comment 'Date on which the ISPS training certification expires and refresher training is required.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'Date of the most recent security training or refresher course completed by the personnel.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenceIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Licence Issuing Authority' ;
    rdfs:comment 'Name of the government agency, regulatory body, or certification authority that issued the security licence.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalFitnessCertificateExpiry rdf:type rdf:Property ;
    rdfs:label 'Medical Fitness Certificate Expiry' ;
    rdfs:comment 'Expiry date of the medical fitness certificate confirming the personnel is physically and mentally fit to perform security duties.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number used for background checks and security vetting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Training Due Date' ;
    rdfs:comment 'Date by which the next mandatory security training or refresher course must be completed to maintain certification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:personnelNumber rdf:type rdf:Property ;
    rdfs:label 'Personnel Number' ;
    rdfs:comment 'Business identifier for the security personnel, typically assigned by HR or security management system. Used for external reference and integration with workforce systems.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personnelStatus rdf:type rdf:Property ;
    rdfs:label 'Personnel Status' ;
    rdfs:comment 'Current operational status of the security personnel indicating availability for duty.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Pfso Designation Flag' ;
    rdfs:comment 'Indicates whether this personnel holds the official PFSO designation as required by ISPS Code. Only one active PFSO per facility is permitted.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:positionTitle rdf:type rdf:Property ;
    rdfs:label 'Position Title' ;
    rdfs:comment 'Official job title or role designation for the security personnel within the port facility security organization (e.g., Port Facility Security Officer, Security Supervisor, Security Guard, CCTV Operator).' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Standardized classification of the security role for reporting and resource planning purposes. [ENUM-REF-CANDIDATE: pfso|deputy_pfso|security_supervisor|security_guard|cctv_operator|access_control_officer|patrol_officer|cybersecurity_officer — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'Level of background security clearance granted to the personnel, determining access to sensitive areas and information.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Security Licence Number' ;
    rdfs:comment 'Official security licence or certification number issued by the relevant national or regional authority authorizing the individual to perform security duties at the port facility.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniformSize rdf:type rdf:Property ;
    rdfs:label 'Uniform Size' ;
    rdfs:comment 'Uniform size for the security personnel for procurement and inventory management purposes.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'Expiry date of the work permit. Null for nationals who do not require work permits.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Work Permit Number' ;
    rdfs:comment 'Work permit or visa number for non-national personnel, required for legal employment verification.' ;
    rdfs:domain ind:Personnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postId rdf:type rdf:Property ;
    rdfs:label 'Post Id' ;
    rdfs:comment 'Unique identifier for the security post or guard position within the port facility security infrastructure.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessControlFunctionFlag rdf:type rdf:Property ;
    rdfs:label 'Access Control Function Flag' ;
    rdfs:comment 'Indicates whether this security post has responsibility for controlling and verifying access of personnel, vehicles, or cargo into restricted areas.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alarmResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Response Flag' ;
    rdfs:comment 'Indicates whether this security post is designated as a first responder to security alarms in its assigned zone or area.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:barrierControlFlag rdf:type rdf:Property ;
    rdfs:label 'Barrier Control Flag' ;
    rdfs:comment 'Indicates whether this security post has operational control over physical barriers such as gates, bollards, or vehicle barriers.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cctvCameraCoverage rdf:type rdf:Property ;
    rdfs:label 'Cctv Camera Coverage' ;
    rdfs:comment 'List or description of CCTV cameras that are monitored or within the surveillance responsibility of this security post.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cctvMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Cctv Monitoring Flag' ;
    rdfs:comment 'Indicates whether this security post has access to and responsibility for monitoring CCTV camera feeds.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentAssignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Current Assignment Status' ;
    rdfs:comment 'Real-time status indicating whether the security post is currently staffed with the required number of officers.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStaffingLevel rdf:type rdf:Property ;
    rdfs:label 'Current Staffing Level' ;
    rdfs:comment 'Actual number of security officers currently assigned and deployed to this post at the present time.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyResponseRole rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Role' ;
    rdfs:comment 'Specific role and responsibilities assigned to this security post during emergency situations, security incidents, or MARSEC level escalations.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'Date when this security post was first established and became operational within the port facility security infrastructure.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marsecLevel1Staffing rdf:type rdf:Property ;
    rdfs:label 'Marsec Level 1 Staffing' ;
    rdfs:comment 'Required number of security officers to be assigned to this post when the port facility is operating at MARSEC Level 1 (normal security conditions).' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marsecLevel2Staffing rdf:type rdf:Property ;
    rdfs:label 'Marsec Level 2 Staffing' ;
    rdfs:comment 'Required number of security officers to be assigned to this post when the port facility is operating at MARSEC Level 2 (heightened security threat).' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marsecLevel3Staffing rdf:type rdf:Property ;
    rdfs:label 'Marsec Level 3 Staffing' ;
    rdfs:comment 'Required number of security officers to be assigned to this post when the port facility is operating at MARSEC Level 3 (imminent or actual security incident).' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of this security post configuration and effectiveness as part of the Port Facility Security Plan (PFSP) review cycle.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursDescription rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Description' ;
    rdfs:comment 'Detailed description of the operating hours and staffing schedule for this security post (e.g., 0600-1800 weekdays, 24/7 during vessel operations).' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursType rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Type' ;
    rdfs:comment 'Classification of the operating schedule for this security post indicating when it is required to be staffed.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patrolFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Patrol Frequency Minutes' ;
    rdfs:comment 'Required frequency in minutes for completing patrol rounds or checkpoint visits for roving security posts.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patrolFunctionFlag rdf:type rdf:Property ;
    rdfs:label 'Patrol Function Flag' ;
    rdfs:comment 'Indicates whether this security post involves mobile patrol duties covering multiple locations within the port facility.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patrolRouteDescription rdf:type rdf:Property ;
    rdfs:label 'Patrol Route Description' ;
    rdfs:comment 'Detailed description of the patrol route, checkpoints, and coverage area for roving security posts.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postCode rdf:type rdf:Property ;
    rdfs:label 'Post Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the security post for operational reference and radio communication (e.g., GATE-01, QUAY-A3, PATROL-05).' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postName rdf:type rdf:Property ;
    rdfs:label 'Post Name' ;
    rdfs:comment 'Descriptive name of the security post indicating its location or function (e.g., Main Gate North, Berth 7 Waterside, Container Yard Patrol).' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postType rdf:type rdf:Property ;
    rdfs:label 'Post Type' ;
    rdfs:comment 'Classification of the security post based on its operational mode and location type within the port facility. [ENUM-REF-CANDIDATE: fixed|roving|waterside|control_room|gate|perimeter|quay|vehicle_patrol|foot_patrol — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryResponsibility rdf:type rdf:Property ;
    rdfs:label 'Primary Responsibility' ;
    rdfs:comment 'Main security function and responsibility assigned to this post (e.g., vehicle inspection, personnel access control, CCTV monitoring, perimeter patrol, vessel interface security).' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:radioChannel rdf:type rdf:Property ;
    rdfs:label 'Radio Channel' ;
    rdfs:comment 'Designated radio frequency or channel used by security officers at this post for operational communications.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:radioEquipmentAssigned rdf:type rdf:Property ;
    rdfs:label 'Radio Equipment Assigned' ;
    rdfs:comment 'Type and identifier of radio communication equipment assigned to this security post for coordination with security control room and other posts.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scannerEquipmentAssigned rdf:type rdf:Property ;
    rdfs:label 'Scanner Equipment Assigned' ;
    rdfs:comment 'Type and identifier of scanning equipment assigned to this post (e.g., RFID reader, barcode scanner, biometric scanner, document scanner).' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard shift rotation pattern applied to this security post (e.g., 3x8-hour shifts, 2x12-hour shifts, rotating 4-on-4-off).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveillanceFunctionFlag rdf:type rdf:Property ;
    rdfs:label 'Surveillance Function Flag' ;
    rdfs:comment 'Indicates whether this security post has responsibility for monitoring CCTV systems, conducting visual surveillance, or observing restricted areas.' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleAssigned rdf:type rdf:Property ;
    rdfs:label 'Vehicle Assigned' ;
    rdfs:comment 'Identifier of the security patrol vehicle assigned to this post for mobile patrol duties (e.g., patrol car, motorcycle, bicycle, golf cart).' ;
    rdfs:domain ind:Post ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryZoneEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Zone Employee Id' ;
    rdfs:comment 'Identifier of the security officer or manager responsible for this zone. Links to workforce or security personnel registry.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:zoneEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Zone Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessControlRequirementMarsec1 rdf:type rdf:Property ;
    rdfs:label 'Access Control Requirement Marsec1' ;
    rdfs:comment 'Detailed description of access control measures required for this zone when operating at MARSEC Level 1 (normal security). Includes badge requirements, escort policies, vehicle inspection protocols, and entry authorization procedures.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlRequirementMarsec2 rdf:type rdf:Property ;
    rdfs:label 'Access Control Requirement Marsec2' ;
    rdfs:comment 'Enhanced access control measures required for this zone when operating at MARSEC Level 2 (heightened security threat). Typically includes additional screening, reduced access lists, mandatory escorts, and enhanced vehicle searches.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlRequirementMarsec3 rdf:type rdf:Property ;
    rdfs:label 'Access Control Requirement Marsec3' ;
    rdfs:comment 'Maximum security access control measures required for this zone when operating at MARSEC Level 3 (imminent security threat). May include zone closure, armed security, biometric verification, and complete lockdown procedures.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessPointCount rdf:type rdf:Property ;
    rdfs:label 'Access Point Count' ;
    rdfs:comment 'Number of controlled access points (gates, doors, turnstiles) into the security zone. Used for access control planning and security resource allocation.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaSquareMeters rdf:type rdf:Property ;
    rdfs:label 'Area Square Meters' ;
    rdfs:comment 'Total area of the security zone measured in square meters. Used for resource allocation, patrol planning, and CCTV coverage calculations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Boundary Description' ;
    rdfs:comment 'Textual description of the physical boundaries of the security zone. Includes landmarks, fence lines, berth numbers, building identifiers, and geographic references for operational clarity.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryGisPolygon rdf:type rdf:Property ;
    rdfs:label 'Boundary Gis Polygon' ;
    rdfs:comment 'GIS polygon coordinates defining the precise geographic boundaries of the security zone in WKT (Well-Known Text) format. Used for spatial analysis, mapping, and automated geofencing in access control systems.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cctvCameraCount rdf:type rdf:Property ;
    rdfs:label 'Cctv Camera Count' ;
    rdfs:comment 'Number of CCTV cameras actively monitoring this security zone. Used for surveillance coverage assessment and maintenance planning.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalInfrastructureFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Infrastructure Flag' ;
    rdfs:comment 'Indicates whether this security zone contains critical infrastructure as defined by national security regulations. True for zones containing fuel storage, power generation, control centers, or other critical assets.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cybersecurityZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Zone Flag' ;
    rdfs:comment 'Indicates whether this zone includes IT/OT (Information Technology/Operational Technology) systems requiring cybersecurity controls. True for zones with control rooms, server facilities, or networked operational systems.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyAssemblyPoint rdf:type rdf:Property ;
    rdfs:label 'Emergency Assembly Point' ;
    rdfs:comment 'Designated emergency assembly point location for personnel evacuating from this security zone. Used for emergency response planning and safety drills.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRiskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Risk Assessment Date' ;
    rdfs:comment 'Date when the most recent security risk assessment was conducted for this zone. ISPS Code requires periodic reassessment of security zones.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lightingAdequacyFlag rdf:type rdf:Property ;
    rdfs:label 'Lighting Adequacy Flag' ;
    rdfs:comment 'Indicates whether the security zone has adequate lighting for security purposes as per ISPS Code requirements. True if lighting meets standards, false if lighting is insufficient or requires upgrade.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marsecLevelApplicability rdf:type rdf:Property ;
    rdfs:label 'Marsec Level Applicability' ;
    rdfs:comment 'Indicates which MARSEC security levels this zone designation applies to. MARSEC 1 is normal operations, MARSEC 2 is heightened threat, MARSEC 3 is imminent threat. Some zones may only be activated at higher MARSEC levels.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRiskAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Risk Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory security risk assessment of this zone. Used for compliance tracking and audit preparation.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalHours rdf:type rdf:Property ;
    rdfs:label 'Operational Hours' ;
    rdfs:comment 'Standard operational hours for this security zone. Format examples: 24/7, 0600-2200, Business Hours Only. Affects access control and patrol scheduling.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perimeterFencingType rdf:type rdf:Property ;
    rdfs:label 'Perimeter Fencing Type' ;
    rdfs:comment 'Type of physical barrier securing the perimeter of the security zone. Chain link for standard fencing, concrete wall for high-security areas, steel barrier for vehicle protection, water barrier for waterside zones, none for open zones.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfspReferenceSection rdf:type rdf:Property ;
    rdfs:label 'Pfsp Reference Section' ;
    rdfs:comment 'Reference to the specific section or annex in the Port Facility Security Plan that details this security zone. Used for audit compliance and security plan maintenance.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedCargoTypes rdf:type rdf:Property ;
    rdfs:label 'Restricted Cargo Types' ;
    rdfs:comment 'Types of cargo that are restricted or prohibited within this security zone. Examples: IMDG Class 1 explosives, radioactive materials, high-value cargo. Pipe-separated list for multiple restrictions.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the security zone for operational reference and access control system integration. Used in gate systems and patrol logs.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current operational status of the security zone. Active zones are enforced, inactive zones are not currently monitored, suspended zones are temporarily disabled, under review zones are being reassessed.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosureReason rdf:type rdf:Property ;
    rdfs:label 'Case Closure Reason' ;
    rdfs:comment 'Explanation or reason for closing the stowaway case, including final disposition of the individuals involved.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Business identifier for the stowaway case, formatted as STC-YYYY-NNNNNN for external reference and reporting to authorities.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether corrective actions to port facility security measures are required as a result of this stowaway incident.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Detecting Officer Name' ;
    rdfs:comment 'Name of the security officer or personnel who first detected the stowaway(s).' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLocationCode rdf:type rdf:Property ;
    rdfs:label 'Detection Location Code' ;
    rdfs:comment 'Specific location identifier within the port facility where detection occurred (berth number, gate ID, terminal zone, etc.).' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLocationType rdf:type rdf:Property ;
    rdfs:label 'Detection Location Type' ;
    rdfs:comment 'Type of port facility location where the stowaway(s) were discovered. [ENUM-REF-CANDIDATE: vessel|terminal|gate|container_yard|warehouse|berth|anchorage — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionFacilityName rdf:type rdf:Property ;
    rdfs:label 'Detention Facility Name' ;
    rdfs:comment 'Name of the facility where the stowaway(s) are being detained pending repatriation or other resolution.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detention Start Timestamp' ;
    rdfs:comment 'Date and time when detention of the stowaway(s) commenced.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detentionStatus rdf:type rdf:Property ;
    rdfs:label 'Detention Status' ;
    rdfs:comment 'Current detention status and location of the stowaway(s) following detection.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immigrationAuthorityNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Immigration Authority Notification Timestamp' ;
    rdfs:comment 'Date and time when immigration authorities were notified of the stowaway case.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:immigrationAuthorityNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Immigration Authority Notified Flag' ;
    rdfs:comment 'Indicates whether national immigration authorities have been formally notified of the stowaway incident.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfStowaways rdf:type rdf:Property ;
    rdfs:label 'Number Of Stowaways' ;
    rdfs:comment 'Total count of individuals detected as stowaways in this case incident.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portAuthorityNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Port Authority Notification Timestamp' ;
    rdfs:comment 'Date and time when the port authority was notified of the stowaway case.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:repatriationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Repatriation Cost Amount' ;
    rdfs:comment 'Total cost incurred for repatriation arrangements including travel, documentation, and administrative expenses.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repatriationCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Repatriation Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for repatriation cost amount.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repatriationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Repatriation Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country for stowaway repatriation.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repatriationDate rdf:type rdf:Property ;
    rdfs:label 'Repatriation Date' ;
    rdfs:comment 'Scheduled or actual date of stowaway repatriation to their country of origin.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repatriationStatus rdf:type rdf:Property ;
    rdfs:label 'Repatriation Status' ;
    rdfs:comment 'Current status of repatriation arrangements for the stowaway(s) to their country of origin or nationality.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Security Breach Flag' ;
    rdfs:comment 'Indicates whether the stowaway incident represents a security breach requiring additional investigation or corrective action under ISPS Code.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippingLineNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipping Line Notification Timestamp' ;
    rdfs:comment 'Date and time when the shipping line was notified of the stowaway case.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingLineNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Shipping Line Notified Flag' ;
    rdfs:comment 'Indicates whether the shipping line operating the vessel has been notified of the stowaway incident.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stowawayIdentityDocuments rdf:type rdf:Property ;
    rdfs:label 'Stowaway Identity Documents' ;
    rdfs:comment 'Description of identity documents presented or found on stowaways (passport numbers, national ID cards, etc.), if available. Highly sensitive personal information.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stowawayNationalities rdf:type rdf:Property ;
    rdfs:label 'Stowaway Nationalities' ;
    rdfs:comment 'Comma-separated list of nationalities of the stowaways involved, using ISO 3166-1 alpha-3 country codes where known.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stowawayPersonalDetails rdf:type rdf:Property ;
    rdfs:label 'Stowaway Personal Details' ;
    rdfs:comment 'Names, ages, gender, and other identifying personal information of stowaways, captured for immigration and repatriation purposes.' ;
    rdfs:domain ind:StowawayCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterdataFlagStateId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Flag State Id' ;
    rdfs:comment 'Foreign key linking to masterdata.flag_state. Business justification: Threat assessments evaluate flag state risk profiles using Paris/Tokyo MOU targeting factors, PSC deficiency rates, and flag of convenience status. ISPS Code requires facility to assess vessel flag st' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlagState .

ind:supersededByAssessmentThreatAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Assessment Threat Assessment Id' ;
    rdfs:comment 'Reference to the newer threat assessment that supersedes this record. Used to maintain assessment lineage and ensure only the current assessment is operationally active. Null if this is the current active assessment.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThreatAssessment .

ind:assessmentReportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the full threat assessment report document. The report contains detailed findings, evidence, analysis, and recommendations that support the summary data captured in this record.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Date' ;
    rdfs:comment 'Date when the threat assessment process was initiated. Used to track assessment duration and compliance with mandated assessment timelines.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationLevel rdf:type rdf:Property ;
    rdfs:label 'Classification Level' ;
    rdfs:comment 'Security classification level assigned to the threat assessment document and data. Determines access controls and handling procedures. Most threat assessments are classified as confidential or restricted due to sensitive security information.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conductingAuthority rdf:type rdf:Property ;
    rdfs:label 'Conducting Authority' ;
    rdfs:comment 'Entity or role responsible for conducting the threat assessment. Recognized Security Organization (RSO) is an accredited third-party assessor; Port Facility Security Officer (PFSO) is the internal security lead; internal security team represents in-house capability; external consultant is a contracted specialist; government agency is a regulatory or intelligence body; joint assessment team is a multi-party collaboration.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conductingOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Conducting Organization Name' ;
    rdfs:comment 'Name of the organization or entity that performed the threat assessment. For RSO assessments, this is the accredited security organization; for internal assessments, this is the port authority or terminal operator name.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceSourcesConsulted rdf:type rdf:Property ;
    rdfs:label 'Intelligence Sources Consulted' ;
    rdfs:comment 'Description of threat intelligence sources consulted during the assessment, such as national maritime security bulletins, port state control advisories, regional security information sharing networks, law enforcement intelligence, or commercial threat intelligence services.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAssessorCredentials rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Credentials' ;
    rdfs:comment 'Professional qualifications and certifications held by the lead assessor, such as Certified Protection Professional (CPP), Physical Security Professional (PSP), ISPS auditor certification, or equivalent credentials demonstrating competence in maritime security assessment.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAssessorName rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Name' ;
    rdfs:comment 'Name of the individual who led the threat assessment. This person is accountable for the assessment methodology, findings, and recommendations.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRiskRating rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Rating' ;
    rdfs:comment 'Composite risk rating representing the aggregate security posture of the facility or vessel based on all evaluated threat categories and identified vulnerabilities. This rating informs the security level and countermeasure requirements in the Port Facility Security Plan (PFSP).' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedCountermeasures rdf:type rdf:Property ;
    rdfs:label 'Recommended Countermeasures' ;
    rdfs:comment 'Detailed recommendations for security countermeasures to mitigate identified threats and vulnerabilities. May include physical security enhancements, procedural changes, technology deployments, training requirements, and policy updates. These recommendations form the basis for PFSP development or revision.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderConsultationConducted rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Consultation Conducted' ;
    rdfs:comment 'Indicates whether consultation with relevant stakeholders (terminal operators, shipping lines, customs, law enforcement, emergency services) was conducted as part of the assessment process. Stakeholder input enhances assessment comprehensiveness and operational feasibility of recommendations.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threatCyberEvaluated rdf:type rdf:Property ;
    rdfs:label 'Threat Cyber Evaluated' ;
    rdfs:comment 'Indicates whether cyber threats to port IT and OT systems were evaluated in this assessment. Cyber threats include ransomware, data breaches, operational technology disruption, and denial-of-service attacks.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threatCyberRating rdf:type rdf:Property ;
    rdfs:label 'Threat Cyber Rating' ;
    rdfs:comment 'Risk rating assigned to cyber threats based on IT/OT security posture, network segmentation, patch management, incident response capability, and threat intelligence on cyber attacks targeting maritime infrastructure.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatPiracyEvaluated rdf:type rdf:Property ;
    rdfs:label 'Threat Piracy Evaluated' ;
    rdfs:comment 'Indicates whether piracy and armed robbery threats were evaluated in this assessment. Relevant for ports in regions with maritime piracy activity.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threatPiracyRating rdf:type rdf:Property ;
    rdfs:label 'Threat Piracy Rating' ;
    rdfs:comment 'Risk rating assigned to piracy and armed robbery threats based on regional threat intelligence, historical incidents, and current security conditions.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatSabotageEvaluated rdf:type rdf:Property ;
    rdfs:label 'Threat Sabotage Evaluated' ;
    rdfs:comment 'Indicates whether sabotage threats (intentional damage to infrastructure, equipment, or cargo) were evaluated in this assessment.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threatSabotageRating rdf:type rdf:Property ;
    rdfs:label 'Threat Sabotage Rating' ;
    rdfs:comment 'Risk rating assigned to sabotage threats based on insider threat controls, access restrictions to critical infrastructure, and background screening effectiveness.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatSmugglingEvaluated rdf:type rdf:Property ;
    rdfs:label 'Threat Smuggling Evaluated' ;
    rdfs:comment 'Indicates whether smuggling threats (contraband, narcotics, weapons, illegal goods) were evaluated in this assessment. Smuggling undermines customs compliance and can facilitate other security threats.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threatSmugglingRating rdf:type rdf:Property ;
    rdfs:label 'Threat Smuggling Rating' ;
    rdfs:comment 'Risk rating assigned to smuggling threats based on cargo inspection procedures, customs integration, and intelligence on smuggling activity in the region.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatStowawaysEvaluated rdf:type rdf:Property ;
    rdfs:label 'Threat Stowaways Evaluated' ;
    rdfs:comment 'Indicates whether stowaway infiltration threats were evaluated in this assessment. Stowaways pose security, safety, and legal risks to port and vessel operations.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threatStowawaysRating rdf:type rdf:Property ;
    rdfs:label 'Threat Stowaways Rating' ;
    rdfs:comment 'Risk rating assigned to stowaway infiltration threats based on access control effectiveness, perimeter security, and historical stowaway incidents.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatTerrorismEvaluated rdf:type rdf:Property ;
    rdfs:label 'Threat Terrorism Evaluated' ;
    rdfs:comment 'Indicates whether terrorism threats were evaluated in this assessment. ISPS Code mandates evaluation of terrorism as a primary threat category.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threatTerrorismRating rdf:type rdf:Property ;
    rdfs:label 'Threat Terrorism Rating' ;
    rdfs:comment 'Risk rating assigned to terrorism threats based on likelihood and potential impact. Critical indicates imminent or highly probable threat with catastrophic consequences; high indicates probable threat with severe consequences; medium indicates possible threat with moderate consequences; low indicates unlikely threat with limited consequences; negligible indicates minimal or no credible threat; not evaluated indicates this category was not assessed.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Findings Summary' ;
    rdfs:comment 'Executive summary of key vulnerabilities identified during the assessment. Describes weaknesses in physical security, access control, surveillance, cybersecurity, or operational procedures that could be exploited by threat actors.' ;
    rdfs:domain ind:ThreatAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryVisitorEntryAccessPointId rdf:type rdf:Property ;
    rdfs:label 'Primary Visitor Entry Access Point Id' ;
    rdfs:comment 'Identifier of the physical access control point where the visitor entered the port facility.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessPoint .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'Maximum security zone access level granted to the visitor based on visit purpose and security clearance.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badgeReturnedFlag rdf:type rdf:Property ;
    rdfs:label 'Badge Returned Flag' ;
    rdfs:comment 'Indicates whether the visitor returned their temporary badge upon exit from the port facility.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biometricCaptureFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Capture Flag' ;
    rdfs:comment 'Indicates whether biometric data (fingerprint, facial recognition, iris scan) was captured from the visitor for enhanced security verification.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escortOfficerName rdf:type rdf:Property ;
    rdfs:label 'Escort Officer Name' ;
    rdfs:comment 'Full name of the security officer or authorized employee assigned as escort for audit trail purposes.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exit Timestamp' ;
    rdfs:comment 'Date and time when the visitor exited the port facility. Null if visitor is still on-site or exit was not recorded.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hostContactName rdf:type rdf:Property ;
    rdfs:label 'Host Contact Name' ;
    rdfs:comment 'Full name of the port facility employee or authorized person who is hosting or sponsoring the visitor.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostContactPhone rdf:type rdf:Property ;
    rdfs:label 'Host Contact Phone' ;
    rdfs:comment 'Contact telephone number of the host employee for visitor coordination and emergency contact purposes.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostDepartment rdf:type rdf:Property ;
    rdfs:label 'Host Department' ;
    rdfs:comment 'Name of the port facility department or division that the host contact belongs to.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityDocumentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Identity Document Expiry Date' ;
    rdfs:comment 'Expiration date of the visitor\'s identity document. Used to validate document validity at time of visit.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identityDocumentIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'Identity Document Issuing Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the authority that issued the identity document.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Identity Document Number' ;
    rdfs:comment 'Unique identification number from the visitor\'s official identity document. Critical for security verification and audit trail compliance.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityDocumentType rdf:type rdf:Property ;
    rdfs:label 'Identity Document Type' ;
    rdfs:comment 'Type of official identity document presented by the visitor for verification and registration purposes.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationType rdf:type rdf:Property ;
    rdfs:label 'Organization Type' ;
    rdfs:comment 'Classification of the organization that the visitor represents, used for access control and reporting purposes. [ENUM-REF-CANDIDATE: shipping_line|freight_forwarder|customs_broker|government_agency|contractor|vendor|surveyor|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfsoApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pfso Approval Required Flag' ;
    rdfs:comment 'Indicates whether this visit required explicit approval from the Port Facility Security Officer due to high-risk classification or restricted area access.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pfsoApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pfso Approval Timestamp' ;
    rdfs:comment 'Date and time when the PFSO approved this visitor access request.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:photoCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Captured Flag' ;
    rdfs:comment 'Indicates whether a photograph of the visitor was captured during registration for badge printing and security records.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedAreaAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Area Access Flag' ;
    rdfs:comment 'Indicates whether the visitor accessed any restricted security zones during their visit, requiring enhanced audit trail documentation.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityScreeningCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Security Screening Completed Flag' ;
    rdfs:comment 'Indicates whether the visitor completed mandatory security screening procedures including metal detection, bag inspection, or other MARSEC-level requirements.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleEntryFlag rdf:type rdf:Property ;
    rdfs:label 'Vehicle Entry Flag' ;
    rdfs:comment 'Indicates whether the visitor entered the port facility with a vehicle requiring separate vehicle registration and inspection.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleMakeModel rdf:type rdf:Property ;
    rdfs:label 'Vehicle Make Model' ;
    rdfs:comment 'Manufacturer and model description of the visitor\'s vehicle for identification and security verification.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Visit Duration Minutes' ;
    rdfs:comment 'Calculated duration of the visit in minutes from entry to exit. Used for access pattern analysis and security monitoring.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitPurpose rdf:type rdf:Property ;
    rdfs:label 'Visit Purpose' ;
    rdfs:comment 'Detailed description of the business purpose or reason for the visitor\'s entry into the port facility. Required for ISPS Code access justification.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitPurposeCategory rdf:type rdf:Property ;
    rdfs:label 'Visit Purpose Category' ;
    rdfs:comment 'Standardized category classification of the visit purpose for reporting and analytics. [ENUM-REF-CANDIDATE: cargo_operations|vessel_operations|maintenance|inspection|delivery|meeting|training|audit|emergency — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitorBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Visitor Badge Number' ;
    rdfs:comment 'Unique identification number of the temporary visitor badge issued to the visitor for the duration of their visit. Format: VB-NNNNNN.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitorFullName rdf:type rdf:Property ;
    rdfs:label 'Visitor Full Name' ;
    rdfs:comment 'Complete legal name of the visitor as shown on identity document. Required for ISPS Code visitor identification and access audit trail.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Watchlist Check Status' ;
    rdfs:comment 'Result of security watchlist verification check performed against visitor identity information during registration.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zonesAccessed rdf:type rdf:Property ;
    rdfs:label 'Zones Accessed' ;
    rdfs:comment 'Comma-separated list of security zone identifiers or names that the visitor accessed during their visit. Critical for ISPS Code access audit trail.' ;
    rdfs:domain ind:VisitorLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Access Control Integration Flag' ;
    rdfs:comment 'Indicates whether this watchlist entry is integrated with automated access control systems (gates, turnstiles, biometric readers) for real-time screening. True if integrated, False if manual screening only.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertActionRequired rdf:type rdf:Property ;
    rdfs:label 'Alert Action Required' ;
    rdfs:comment 'Mandatory action to be taken when the subject is detected: deny access to port facility, detain subject and notify law enforcement, notify relevant authority (customs/immigration/security), apply enhanced screening procedures, monitor movements, or log encounter only.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertCategory rdf:type rdf:Property ;
    rdfs:label 'Alert Category' ;
    rdfs:comment 'Classification of the watchlist alert: security threat, terrorism, international sanctions, smuggling, piracy, stolen property (vehicle/container), banned person (previous incident), immigration violation, or customs violation. [ENUM-REF-CANDIDATE: security_threat|terrorism|sanctions|smuggling|piracy|stolen_property|banned_person|immigration_violation|customs_violation — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableFacilities rdf:type rdf:Property ;
    rdfs:label 'Applicable Facilities' ;
    rdfs:comment 'List of port facility codes or terminal identifiers where this watchlist entry applies. Null if scope is global or national. Semi-colon separated list for multiple facilities.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricDataAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Data Available Flag' ;
    rdfs:comment 'Indicates whether biometric data (fingerprints, facial recognition, iris scan) is available for this watchlist subject to support automated identity verification. True if biometric data is attached, False otherwise.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionCount rdf:type rdf:Property ;
    rdfs:label 'Detection Count' ;
    rdfs:comment 'Total number of times the watchlist subject has been detected or encountered at port facilities since the entry became effective. Incremented by screening systems.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionRestriction rdf:type rdf:Property ;
    rdfs:label 'Distribution Restriction' ;
    rdfs:comment 'Specific restrictions on who may access or be informed about this watchlist entry (e.g., PFSO and designated security personnel only, law enforcement only, need-to-know basis).' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Business-facing unique reference number for the watchlist entry, used for external communication and audit trails.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDetectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Detection Timestamp' ;
    rdfs:comment 'Date and time when the watchlist subject was most recently detected or encountered at any port facility. Null if never detected since listing. Updated by access control or screening systems.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'User identifier or name of the Port Facility Security Officer (PFSO) or security personnel who last modified the watchlist entry record.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managingAuthority rdf:type rdf:Property ;
    rdfs:label 'Managing Authority' ;
    rdfs:comment 'Name of the port authority, government agency, or security organization responsible for maintaining and reviewing this watchlist entry.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationAuthority rdf:type rdf:Property ;
    rdfs:label 'Notification Authority' ;
    rdfs:comment 'Name of the authority or agency that must be notified when the subject is detected (e.g., national police, customs, immigration, coast guard, port state control, PFSO).' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationContact rdf:type rdf:Property ;
    rdfs:label 'Notification Contact' ;
    rdfs:comment 'Contact phone number, email, or radio channel for notifying the designated authority when the watchlist subject is detected.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalDate rdf:type rdf:Property ;
    rdfs:label 'Removal Date' ;
    rdfs:comment 'Date on which the watchlist entry was removed or deactivated. Null for active entries. Populated when status changes to removed.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Explanation for why the watchlist entry was removed: threat resolved, incorrect identification, legal challenge, expiry without renewal, or administrative error.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedBy rdf:type rdf:Property ;
    rdfs:label 'Removed By' ;
    rdfs:comment 'Name or identifier of the Port Facility Security Officer (PFSO) or authorized security personnel who removed or deactivated the watchlist entry.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Date by which the watchlist entry must be reviewed by the Port Facility Security Officer (PFSO) or managing authority to confirm continued validity and relevance.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectAdditionalIdentifiers rdf:type rdf:Property ;
    rdfs:label 'Subject Additional Identifiers' ;
    rdfs:comment 'Supplementary identifiers for the subject such as aliases, previous names, call signs, former vessel names, or alternative registration numbers. Stored as semi-colon separated list.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Subject Date Of Birth' ;
    rdfs:comment 'Date of birth for person subjects. Null for non-person entities. Used for identity verification and age-based screening.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectIdentifierType rdf:type rdf:Property ;
    rdfs:label 'Subject Identifier Type' ;
    rdfs:comment 'Type of primary identifier used for the subject: passport, national ID, seafarer identification document, IMO number (vessels), MMSI (Maritime Mobile Service Identity), vehicle registration, tax identification number, or container number. [ENUM-REF-CANDIDATE: passport|national_id|seafarer_id|imo_number|mmsi|vehicle_registration|tax_id|container_number — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectIdentifierValue rdf:type rdf:Property ;
    rdfs:label 'Subject Identifier Value' ;
    rdfs:comment 'The actual identifier value corresponding to the subject identifier type. For vessels: IMO number or MMSI. For persons: passport or national ID number. For vehicles: registration plate number.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselScreeningIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Vessel Screening Integration Flag' ;
    rdfs:comment 'Indicates whether this watchlist entry is integrated with Vessel Traffic Management System (VTMS) or Port Community System (PCS) for automated vessel pre-arrival screening. True if integrated, False if manual check required.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:watchlistEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Watchlist Entry Status' ;
    rdfs:comment 'Current lifecycle status of the watchlist entry: active (enforced), suspended (temporarily inactive), expired (past expiry date), removed (permanently deleted), or under review (pending PFSO decision).' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistSource rdf:type rdf:Property ;
    rdfs:label 'Watchlist Source' ;
    rdfs:comment 'Origin or issuing authority of the watchlist entry: Interpol notices, national security agencies, international sanctions lists (OFAC, UN, EU), port authority internal list, customs, immigration, Port Facility Security Officer (PFSO) internal ban, or industry shared intelligence. [ENUM-REF-CANDIDATE: interpol|national_security|sanctions_list|port_authority|customs|immigration|pfso_internal|industry_shared — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistSourceReference rdf:type rdf:Property ;
    rdfs:label 'Watchlist Source Reference' ;
    rdfs:comment 'External reference number or case identifier from the originating watchlist source authority. For Interpol: notice number. For sanctions: list entry ID. For internal: case reference.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bunkerAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Bunker Adjustment Id' ;
    rdfs:comment 'Unique identifier for the bunker adjustment factor record. Primary key.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BunkerAdjustment .

ind:primaryBunkerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Bunker Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that created this BAF record.' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByBafBunkerAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Baf Bunker Adjustment Id' ;
    rdfs:comment 'Reference to the bunker_adjustment_id of the BAF record that supersedes this one, enabling time-series tracking. Nullable if current.' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BunkerAdjustment .

ind:applicableServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Types' ;
    rdfs:comment 'Comma-separated list of port service types to which this BAF applies (e.g., THC, wharfage, pilotage, towage, all services).' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Official reference number or document identifier associated with the approval of this BAF rate.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bafCode rdf:type rdf:Property ;
    rdfs:label 'Baf Code' ;
    rdfs:comment 'Unique business identifier code for the BAF rate record, used for external reference and publication.' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bafName rdf:type rdf:Property ;
    rdfs:label 'Baf Name' ;
    rdfs:comment 'Descriptive name of the bunker adjustment factor rate, typically including the applicable period and scope.' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bafRateAmount rdf:type rdf:Property ;
    rdfs:label 'Baf Rate Amount' ;
    rdfs:comment 'The monetary value of the BAF surcharge. Interpretation depends on calculation_method (e.g., USD per TEU for flat rates, percentage value for percentage-based).' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bafType rdf:type rdf:Property ;
    rdfs:label 'Baf Type' ;
    rdfs:comment 'Classification of the BAF rate based on its purpose and application scope (standard, emergency, seasonal, trade lane specific, vessel specific, temporary).' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bunkerAdjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Bunker Adjustment Status' ;
    rdfs:comment 'Current lifecycle status of the BAF rate record (draft, pending approval, approved, active, suspended, expired, superseded). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|expired|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Cargo Type Applicability' ;
    rdfs:comment 'Comma-separated list of cargo types to which this BAF applies (e.g., FCL, LCL, breakbulk, bulk, liquid, all types).' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Container Type Applicability' ;
    rdfs:comment 'Comma-separated list of container types to which this BAF applies (e.g., standard, reefer, dangerous goods, oversized, all types).' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTierEligibility rdf:type rdf:Property ;
    rdfs:label 'Customer Tier Eligibility' ;
    rdfs:comment 'Comma-separated list of customer tiers or segments to which this BAF applies (e.g., tier_1, tier_2, tier_3, all_customers).' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwtBandMax rdf:type rdf:Property ;
    rdfs:label 'Dwt Band Max' ;
    rdfs:comment 'Maximum Deadweight Tonnage (DWT) for which this BAF rate applies. Nullable if no maximum.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dwtBandMin rdf:type rdf:Property ;
    rdfs:label 'Dwt Band Min' ;
    rdfs:comment 'Minimum Deadweight Tonnage (DWT) for which this BAF rate applies. Nullable if no minimum.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionConditions rdf:type rdf:Property ;
    rdfs:label 'Exemption Conditions' ;
    rdfs:comment 'Description of conditions under which customers or transactions may be exempt from this BAF surcharge.' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelIndexReference rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Reference' ;
    rdfs:comment 'The fuel price index or benchmark used as the basis for calculating the BAF rate (e.g., Platts Singapore, MOPS, IFO380, VLSFO, MGO, Brent, WTI, or custom index). [ENUM-REF-CANDIDATE: platts|mops|ifo380|vlsfo|mgo|brent|wti|custom — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelIndexValue rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Value' ;
    rdfs:comment 'The actual fuel price index value (in USD per metric ton or other unit) at the time of BAF calculation or publication.' ;
    rdfs:domain ind:BunkerAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grtBandMax rdf:type rdf:Property ;
    rdfs:label 'Grt Band Max' ;
    rdfs:comment 'Maximum Gross Registered Tonnage (GRT) for which this BAF rate applies. Nullable if no maximum.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grtBandMin rdf:type rdf:Property ;
    rdfs:label 'Grt Band Min' ;
    rdfs:comment 'Minimum Gross Registered Tonnage (GRT) for which this BAF rate applies. Nullable if no minimum.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loaBandMaxMeters rdf:type rdf:Property ;
    rdfs:label 'Loa Band Max Meters' ;
    rdfs:comment 'Maximum vessel length overall (LOA) in meters for which this BAF rate applies. Nullable if no maximum.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loaBandMinMeters rdf:type rdf:Property ;
    rdfs:label 'Loa Band Min Meters' ;
    rdfs:comment 'Minimum vessel length overall (LOA) in meters for which this BAF rate applies. Nullable if no minimum.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge Amount' ;
    rdfs:comment 'Maximum charge amount cap for the BAF surcharge. Nullable if no cap applies.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Amount' ;
    rdfs:comment 'Minimum charge amount that will be applied regardless of calculated BAF value. Nullable if no minimum.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationAuthority rdf:type rdf:Property ;
    rdfs:label 'Publication Authority' ;
    rdfs:comment 'Name of the authority or organization that published or mandated this BAF rate (e.g., port authority, shipping line consortium, regulatory body).' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Rate Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the BAF rate (per TEU, per FEU, per container, per ton, per CBM, percentage, per vessel call). [ENUM-REF-CANDIDATE: per_teu|per_feu|per_container|per_ton|per_cbm|percentage|per_vessel_call — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required Flag' ;
    rdfs:comment 'Indicates whether this BAF rate requires filing with a regulatory authority (True) or not (False).' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeLaneScope rdf:type rdf:Property ;
    rdfs:label 'Trade Lane Scope' ;
    rdfs:comment 'Comma-separated list or description of trade lanes to which this BAF applies (e.g., Asia-Europe, Transpacific, Intra-Asia, All Lanes).' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Vessel Size Category' ;
    rdfs:comment 'Vessel size category to which this BAF applies (feeder, Panamax, Post-Panamax, New Panamax, Suezmax, Ultra Large, all sizes). [ENUM-REF-CANDIDATE: feeder|panamax|post_panamax|new_panamax|suezmax|ultra_large|all_sizes — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Vessel Type Applicability' ;
    rdfs:comment 'Comma-separated list of vessel types to which this BAF applies (e.g., container, bulk, tanker, RoRo, general cargo, all types).' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Currency Adjustment Id' ;
    rdfs:comment 'Unique identifier for the currency adjustment factor record. Primary key for the currency adjustment entity.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyAdjustment .

ind:primaryCurrencyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Currency Employee Id' ;
    rdfs:comment 'Identifier of the user or authority who approved this CAF rate for publication and application. Critical for audit trail and accountability.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByCafCurrencyAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Caf Currency Adjustment Id' ;
    rdfs:comment 'Reference to the newer CAF record that replaces this one. Enables time-series tracking of CAF rate evolution and historical rate reconstruction.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyAdjustment .

ind:tertiaryCurrencyModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Currency Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this CAF rate record. Supports change tracking and accountability.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the currency for which the adjustment factor is being applied to compensate for exchange rate fluctuations.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether this CAF should be automatically applied by the billing system to eligible charges, or requires manual application. True for automatic application.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the base currency in which tariff rates are published (e.g., USD, EUR, SGD).' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Billing System Code' ;
    rdfs:comment 'The charge code or identifier used in the billing system (e.g., NAVIS N4, SAP) to apply this CAF to invoices. Enables system integration and automated billing.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cafCode rdf:type rdf:Property ;
    rdfs:label 'Caf Code' ;
    rdfs:comment 'Externally-known unique business identifier for the CAF rate record, used in tariff publications and billing system references.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cafName rdf:type rdf:Property ;
    rdfs:label 'Caf Name' ;
    rdfs:comment 'Human-readable descriptive name for the CAF rate schedule, typically including currency pair and period reference.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cafPercentage rdf:type rdf:Property ;
    rdfs:label 'Caf Percentage' ;
    rdfs:comment 'The percentage surcharge or discount applied to base tariff rates to compensate for currency exchange rate fluctuations. Positive values represent surcharges, negative values represent discounts.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoTypeScope rdf:type rdf:Property ;
    rdfs:label 'Cargo Type Scope' ;
    rdfs:comment 'Defines the cargo categories to which this CAF applies. Allows differentiated currency adjustments for different cargo handling operations. [ENUM-REF-CANDIDATE: all|containerized|breakbulk|liquid_bulk|dry_bulk|roro|general_cargo — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyAdjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Currency Adjustment Status' ;
    rdfs:comment 'Current lifecycle status of the CAF rate record indicating whether it is in draft, awaiting approval, actively applied to billing, temporarily suspended, expired, or superseded by a newer rate.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentExchangeRate rdf:type rdf:Property ;
    rdfs:label 'Current Exchange Rate' ;
    rdfs:comment 'The current market exchange rate at the time of CAF calculation or publication. Used in conjunction with reference rate to determine adjustment percentage.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerTierScope rdf:type rdf:Property ;
    rdfs:label 'Customer Tier Scope' ;
    rdfs:comment 'Defines the customer segments or tiers to which this CAF applies. Allows differentiated currency adjustments based on customer relationship and volume commitments. [ENUM-REF-CANDIDATE: all|tier_1|tier_2|tier_3|premium|standard|spot — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionTerms rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Terms' ;
    rdfs:comment 'Contractual terms and procedures for resolving disputes related to CAF application, including arbitration clauses and escalation processes.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateReference rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Reference' ;
    rdfs:comment 'The source or benchmark exchange rate used to calculate the CAF percentage (e.g., Central Bank rate, OANDA average, Bloomberg fixing). Provides transparency for rate justification.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCafAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Caf Amount' ;
    rdfs:comment 'The maximum absolute currency adjustment amount that can be charged, capping exposure for large transactions. Provides cost predictability for customers.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCafAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Caf Amount' ;
    rdfs:comment 'The minimum absolute currency adjustment amount that will be charged, regardless of calculated percentage. Ensures administrative costs are covered for small transactions.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'The number of days advance notice provided to customers before this CAF becomes effective. Ensures compliance with contractual and regulatory notice requirements.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationReference rdf:type rdf:Property ;
    rdfs:label 'Publication Reference' ;
    rdfs:comment 'Reference to the official tariff publication, circular, or notice in which this CAF was announced. Critical for regulatory compliance and customer communication.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceExchangeRate rdf:type rdf:Property ;
    rdfs:label 'Reference Exchange Rate' ;
    rdfs:comment 'The baseline exchange rate used as the reference point for calculating currency adjustment. Deviations from this rate trigger CAF adjustments.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'The date on which regulatory authorities approved this CAF rate for implementation. Required for jurisdictions with mandatory tariff approval processes.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceTypeScope rdf:type rdf:Property ;
    rdfs:label 'Service Type Scope' ;
    rdfs:comment 'Specifies the port services to which this CAF applies, such as container handling, wharfage, pilotage, or all services. Enables selective application of currency adjustments.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Vessel Category Scope' ;
    rdfs:comment 'Specifies the vessel types or size categories to which this CAF applies (e.g., container vessels, bulk carriers, tankers, all vessels). Enables vessel-specific currency adjustments.' ;
    rdfs:domain ind:CurrencyAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demurrageScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Demurrage Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the demurrage schedule. Active schedules are applied to billing; draft schedules are under review; suspended schedules are temporarily inactive; expired schedules are past their validity period; archived schedules are retained for historical reference only.' ;
    rdfs:domain ind:DemurrageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Exclusion Flag' ;
    rdfs:comment 'Indicates whether public holidays are excluded from demurrage day calculations. True = holidays excluded, False = holidays included.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumDemurrageCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Demurrage Cap' ;
    rdfs:comment 'Maximum total demurrage amount that can be charged per unit under this schedule, regardless of overstay duration. Nullable if no cap applies.' ;
    rdfs:domain ind:DemurrageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proratedCalculationFlag rdf:type rdf:Property ;
    rdfs:label 'Prorated Calculation Flag' ;
    rdfs:comment 'Indicates whether partial days are prorated in demurrage calculations. True = partial days are prorated hourly, False = partial days are rounded up to full days.' ;
    rdfs:domain ind:DemurrageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateTier1Amount rdf:type rdf:Property ;
    rdfs:label 'Rate Tier 1 Amount' ;
    rdfs:comment 'Daily demurrage charge amount for the first rate tier, applied per unit (container, vessel, or cargo unit) per day.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateTier1Days rdf:type rdf:Property ;
    rdfs:label 'Rate Tier 1 Days' ;
    rdfs:comment 'Number of days in the first demurrage rate tier after free time expires. Demurrage escalates through tiers to incentivize prompt cargo movement.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateTier2Amount rdf:type rdf:Property ;
    rdfs:label 'Rate Tier 2 Amount' ;
    rdfs:comment 'Daily demurrage charge amount for the second rate tier, typically higher than tier 1 to escalate pressure for cargo removal. Nullable if only one tier is defined.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateTier2Days rdf:type rdf:Property ;
    rdfs:label 'Rate Tier 2 Days' ;
    rdfs:comment 'Number of days in the second demurrage rate tier. Nullable if only one tier is defined.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateTier3Amount rdf:type rdf:Property ;
    rdfs:label 'Rate Tier 3 Amount' ;
    rdfs:comment 'Daily demurrage charge amount for the third rate tier, typically the highest escalation level. Nullable if fewer than three tiers are defined.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateTier3Days rdf:type rdf:Property ;
    rdfs:label 'Rate Tier 3 Days' ;
    rdfs:comment 'Number of days in the third demurrage rate tier. Nullable if fewer than three tiers are defined.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Business identifier for the demurrage schedule, used in billing and tariff documentation. Externally visible code.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name of the demurrage schedule for business reference and reporting.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of demurrage schedule by asset type: container demurrage for TEU/FEU overstay, vessel demurrage for berth overstay, cargo demurrage for cargo dwell time, or equipment demurrage for terminal equipment.' ;
    rdfs:domain ind:DemurrageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Sla Reference Code' ;
    rdfs:comment 'Reference code linking this demurrage schedule to a specific Service Level Agreement (SLA) with a customer or customer segment. Nullable if not SLA-linked.' ;
    rdfs:domain ind:DemurrageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffPublicationReference rdf:type rdf:Property ;
    rdfs:label 'Tariff Publication Reference' ;
    rdfs:comment 'Reference to the official tariff publication document or section where this demurrage schedule is published for regulatory and customer transparency.' ;
    rdfs:domain ind:DemurrageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLane rdf:type rdf:Property ;
    rdfs:label 'Trade Lane' ;
    rdfs:comment 'Specific trade route or geographic lane to which this demurrage schedule applies (e.g., Asia-Europe, Transpacific). Nullable if schedule applies globally.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Waiver Authority Level' ;
    rdfs:comment 'Organizational authority level required to approve waivers or reductions of demurrage charges under this schedule.' ;
    rdfs:domain ind:DemurrageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weekendExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Weekend Exclusion Flag' ;
    rdfs:comment 'Indicates whether weekends are excluded from demurrage day calculations. True = weekends excluded, False = weekends included.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByScheduleDetentionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Detention Schedule Id' ;
    rdfs:comment 'Reference to the detention schedule that replaces this one when status is superseded. Maintains lineage of schedule evolution.' ;
    rdfs:domain ind:DetentionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DetentionSchedule .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which detention charges are invoiced to customers. Daily accrual but may be billed in batches.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Detention Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the detention schedule. Only active schedules are used in billing calculations.' ;
    rdfs:domain ind:DetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Holiday Charge Applicable' ;
    rdfs:comment 'Indicates whether detention charges apply on public holidays. Some schedules waive charges on recognized port holidays.' ;
    rdfs:domain ind:DetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumDetentionCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Detention Cap' ;
    rdfs:comment 'Maximum total detention charge that can be assessed per container regardless of duration. Protects customers from unlimited liability in exceptional circumstances.' ;
    rdfs:domain ind:DetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorationRule rdf:type rdf:Property ;
    rdfs:label 'Proration Rule' ;
    rdfs:comment 'Rule for prorating detention charges for partial days. Determines whether partial days are charged at full rate, prorated hourly, or rounded.' ;
    rdfs:domain ind:DetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date when this detention schedule was officially published and communicated to customers and stakeholders.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeDirection rdf:type rdf:Property ;
    rdfs:label 'Trade Direction' ;
    rdfs:comment 'Direction of cargo movement to which this detention schedule applies. Rates may differ between import and export operations.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverEligible rdf:type rdf:Property ;
    rdfs:label 'Waiver Eligible' ;
    rdfs:comment 'Indicates whether detention charges under this schedule are eligible for waiver or dispute resolution processes.' ;
    rdfs:domain ind:DetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weekendChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Weekend Charge Applicable' ;
    rdfs:comment 'Indicates whether detention charges apply on weekends. Some schedules waive charges on Saturdays and Sundays.' ;
    rdfs:domain ind:DetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Scheme Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Discount schemes require designated owners with approval authority to evaluate customer requests, verify eligibility criteria, authorize exceptions, monitor scheme utilization, and conduct periodic re' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableChargeCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Charge Codes' ;
    rdfs:comment 'Comma-separated list of tariff charge codes to which this discount applies (e.g., THC, WHR, DMG, DET, PIL, BAF, CAF). Empty means applies to all charges.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalReference rdf:type rdf:Property ;
    rdfs:label 'Approval Reference' ;
    rdfs:comment 'Reference number or document identifier for the approval decision (e.g., board resolution number, approval memo reference).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoTypeRestriction rdf:type rdf:Property ;
    rdfs:label 'Cargo Type Restriction' ;
    rdfs:comment 'Comma-separated list of cargo types to which this discount applies (e.g., containerized, breakbulk, roro, liquid_bulk, dry_bulk). Empty means no cargo type restriction.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinableWithOtherDiscounts rdf:type rdf:Property ;
    rdfs:label 'Combinable With Other Discounts' ;
    rdfs:comment 'Indicates whether this discount can be combined with other discount schemes on the same transaction. True allows stacking, False requires exclusive application.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Customer Type Eligibility' ;
    rdfs:comment 'Comma-separated list of customer types eligible for this discount (e.g., shipping_line, freight_forwarder, cargo_owner, nvocc). Empty means all customer types are eligible.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountCategory rdf:type rdf:Property ;
    rdfs:label 'Discount Category' ;
    rdfs:comment 'Business classification of the discount scheme: promotional campaign, contractual agreement, volume incentive, loyalty reward, seasonal offer, or strategic partnership discount.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Discount Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for flat rate discounts. Null for percentage or free days discount types.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Classification of the discount mechanism: percentage reduction, flat rate deduction, free storage days, tiered pricing, volume-based rebate, or loyalty-based incentive.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'Numeric value of the discount. Interpretation depends on discount_type: percentage (e.g., 15.00 for 15%), flat rate (monetary amount), or number of free days.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumDiscountCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Cap' ;
    rdfs:comment 'Maximum monetary value of discount that can be applied per transaction or period, regardless of calculated discount amount. Null means no cap applies.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Threshold' ;
    rdfs:comment 'Minimum charge amount below which the discount cannot be applied. Ensures discounts are only given on transactions above a certain value.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking for discount application when multiple schemes are eligible. Lower numbers indicate higher priority (1 = highest priority).' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Campaign Code' ;
    rdfs:comment 'Reference code linking this discount to a specific marketing or promotional campaign. Used for tracking campaign effectiveness and ROI.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCustomerRequest rdf:type rdf:Property ;
    rdfs:label 'Requires Customer Request' ;
    rdfs:comment 'Indicates whether the customer must explicitly request this discount (True) or if it can be applied proactively by the port (False).' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retroactiveApplicationAllowed rdf:type rdf:Property ;
    rdfs:label 'Retroactive Application Allowed' ;
    rdfs:comment 'Indicates whether this discount can be applied retroactively to past transactions within the effective period (True) or only to future transactions (False).' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Code' ;
    rdfs:comment 'Unique business identifier code for the discount scheme, used for external reference and integration with billing systems.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeDescription rdf:type rdf:Property ;
    rdfs:label 'Scheme Description' ;
    rdfs:comment 'Detailed description of the discount scheme including its purpose, eligibility criteria, and business rationale.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeName rdf:type rdf:Property ;
    rdfs:label 'Scheme Name' ;
    rdfs:comment 'Full descriptive name of the discount scheme for business user identification and reporting purposes.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Status' ;
    rdfs:comment 'Current lifecycle status of the discount scheme: draft (being designed), pending approval (awaiting authorization), active (in use), suspended (temporarily inactive), expired (past effective date), or cancelled (terminated before expiration).' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Linked Flag' ;
    rdfs:comment 'Indicates whether this discount is tied to Service Level Agreement (SLA) performance metrics. True means discount is conditional on meeting service standards.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaPerformanceMetric rdf:type rdf:Property ;
    rdfs:label 'Sla Performance Metric' ;
    rdfs:comment 'Description of the SLA performance metric that must be met for this discount to apply (e.g., vessel turnaround time < 24 hours, container dwell time < 5 days).' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalRestriction rdf:type rdf:Property ;
    rdfs:label 'Terminal Restriction' ;
    rdfs:comment 'Comma-separated list of terminal codes where this discount is valid. Empty means discount applies across all port terminals.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdPeriod rdf:type rdf:Property ;
    rdfs:label 'Threshold Period' ;
    rdfs:comment 'Time period over which the threshold is measured and evaluated: per vessel call, monthly, quarterly, annually, or over the entire contract term.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdType rdf:type rdf:Property ;
    rdfs:label 'Threshold Type' ;
    rdfs:comment 'Type of qualifying threshold that must be met to earn the discount: TEU (Twenty-foot Equivalent Unit) volume, vessel call frequency, cargo tonnage, revenue value, container count, or none for unconditional discounts.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for the threshold value: TEU (Twenty-foot Equivalent Unit), FEU (Forty-foot Equivalent Unit), vessel calls, metric tonnes (MT), cubic meters (CBM), container count, or currency. [ENUM-REF-CANDIDATE: TEU|FEU|calls|tonnes|MT|CBM|containers|USD|EUR — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselTypeRestriction rdf:type rdf:Property ;
    rdfs:label 'Vessel Type Restriction' ;
    rdfs:comment 'Comma-separated list of vessel types eligible for this discount (e.g., container_ship, bulk_carrier, tanker, roro_vessel). Empty means no vessel type restriction.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeTimeAllowanceId rdf:type rdf:Property ;
    rdfs:label 'Free Time Allowance Id' ;
    rdfs:comment 'Primary key for free_time_allowance' ;
    rdfs:domain ind:FreeTimeAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByAllowanceFreeTimeAllowanceId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Allowance Free Time Allowance Id' ;
    rdfs:comment 'Reference to the newer free time allowance rule that replaces this one, if applicable. Null if not superseded.' ;
    rdfs:domain ind:FreeTimeAllowance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreeTimeAllowance .

ind:allowanceCode rdf:type rdf:Property ;
    rdfs:label 'Allowance Code' ;
    rdfs:comment 'Unique business identifier code for this free time allowance rule, used in billing and operational systems.' ;
    rdfs:domain ind:FreeTimeAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceName rdf:type rdf:Property ;
    rdfs:label 'Allowance Name' ;
    rdfs:comment 'Descriptive name of the free time allowance rule for business users and reporting.' ;
    rdfs:domain ind:FreeTimeAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableChargeType rdf:type rdf:Property ;
    rdfs:label 'Applicable Charge Type' ;
    rdfs:comment 'The type of charge that commences after the free time expires: storage, demurrage (DMG), detention (DET), wharfage (WHR), or THC (Terminal Handling Charge).' ;
    rdfs:domain ind:FreeTimeAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Type of container to which this free time allowance applies: standard TEU (Twenty-foot Equivalent Unit), standard FEU (Forty-foot Equivalent Unit), high cube 40ft, high cube 45ft, reefer 20ft, reefer 40ft, open top, flat rack, tank, or all types. [ENUM-REF-CANDIDATE: standard_20|standard_40|high_cube_40|high_cube_45|reefer_20|reefer_40|open_top|flat_rack|tank|all_types — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'End Trigger Event' ;
    rdfs:comment 'The operational event that ends the free time period: gate-out, vessel loading, container pickup, or expiry of the allocated free days.' ;
    rdfs:domain ind:FreeTimeAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeDays rdf:type rdf:Property ;
    rdfs:label 'Free Days' ;
    rdfs:comment 'Number of free days granted before storage, demurrage (DMG), or detention (DET) charges commence.' ;
    rdfs:domain ind:FreeTimeAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freeTimeAllowanceStatus rdf:type rdf:Property ;
    rdfs:label 'Free Time Allowance Status' ;
    rdfs:comment 'Current lifecycle status of the free time allowance rule: draft (under review), active (in use), suspended (temporarily inactive), expired (past expiry date), or superseded (replaced by newer rule).' ;
    rdfs:domain ind:FreeTimeAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeTimeType rdf:type rdf:Property ;
    rdfs:label 'Free Time Type' ;
    rdfs:comment 'Category of free time allowance: import free days (container dwell before storage charges), export free days (pre-shipment dwell), transshipment free days (in-transit dwell), equipment free days (chassis/equipment rental grace period), storage free days (yard storage grace), or demurrage free days (vessel delay grace).' ;
    rdfs:domain ind:FreeTimeAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumVolumeTeu rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume Teu' ;
    rdfs:comment 'Maximum volume in TEU (Twenty-foot Equivalent Unit) to which this free time allowance applies. Null if no maximum cap exists.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeTeu rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Teu' ;
    rdfs:comment 'Minimum committed volume in TEU (Twenty-foot Equivalent Unit) required to qualify for this free time allowance. Null if no minimum applies.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityOrder rdf:type rdf:Property ;
    rdfs:label 'Priority Order' ;
    rdfs:comment 'Numeric priority for rule evaluation when multiple free time allowances could apply to the same transaction. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Start Trigger Event' ;
    rdfs:comment 'The operational event that triggers the start of the free time period: vessel discharge, gate-in, customs release, delivery order (D/O) issue, container available for pickup, or berth departure.' ;
    rdfs:domain ind:FreeTimeAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMooringEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Mooring Employee Id' ;
    rdfs:comment 'Identifier of the user or authority who approved this mooring tariff for operational use.' ;
    rdfs:domain ind:MooringTariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByTariffMooringTariffId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tariff Mooring Tariff Id' ;
    rdfs:comment 'Reference to the newer mooring tariff record that replaces this one, maintaining tariff version history and lineage.' ;
    rdfs:domain ind:MooringTariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MooringTariff .

ind:tertiaryMooringModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Mooring Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this mooring tariff record.' ;
    rdfs:domain ind:MooringTariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseMooringFee rdf:type rdf:Property ;
    rdfs:label 'Base Mooring Fee' ;
    rdfs:comment 'Standard charge amount for the mooring or unmooring service under normal conditions, excluding surcharges and additional fees.' ;
    rdfs:domain ind:MooringTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationFee rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee' ;
    rdfs:comment 'Charge applied when a scheduled mooring service is cancelled within the notice period, compensating for crew mobilization costs.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationNoticeHours rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notice Hours' ;
    rdfs:comment 'Minimum number of hours advance notice required to cancel a mooring service without incurring the cancellation fee.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freeWaitingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Free Waiting Time Minutes' ;
    rdfs:comment 'Grace period in minutes during which no waiting time surcharge is applied before the mooring gang begins work.' ;
    rdfs:domain ind:MooringTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumChargeCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge Cap' ;
    rdfs:comment 'Maximum billable amount ceiling for the mooring service to protect customers from excessive charges in extended operations. Null indicates no cap.' ;
    rdfs:domain ind:MooringTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mooringGangCount rdf:type rdf:Property ;
    rdfs:label 'Mooring Gang Count' ;
    rdfs:comment 'Number of mooring gangs (line-handling crews) deployed for the service covered by this tariff rate.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicTariffFlag rdf:type rdf:Property ;
    rdfs:label 'Public Tariff Flag' ;
    rdfs:comment 'Indicates whether this tariff is publicly published and available to all customers, or is a private negotiated rate.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffName rdf:type rdf:Property ;
    rdfs:label 'Tariff Name' ;
    rdfs:comment 'Descriptive name of the mooring tariff schedule for business user identification and reporting purposes.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffStatus rdf:type rdf:Property ;
    rdfs:label 'Tariff Status' ;
    rdfs:comment 'Current lifecycle status of the mooring tariff: draft (under development), active (in use), suspended (temporarily inactive), expired (past validity), or superseded (replaced by newer version).' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffVersion rdf:type rdf:Property ;
    rdfs:label 'Tariff Version' ;
    rdfs:comment 'Version number of this tariff schedule in major.minor format, enabling tracking of tariff evolution and changes over time.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOfDayCategory rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Category' ;
    rdfs:comment 'Time period classification for differential pricing: day (standard business hours), night (after-hours), weekend, or holiday operations.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitingTimeSurchargePerHour rdf:type rdf:Property ;
    rdfs:label 'Waiting Time Surcharge Per Hour' ;
    rdfs:comment 'Additional charge per hour when mooring gang is on standby waiting for vessel readiness or berth availability beyond the free waiting period.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByTariffPilotageTariffId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tariff Pilotage Tariff Id' ;
    rdfs:comment 'Reference to the pilotage_tariff_id that replaces this tariff when status is \'superseded\'. Creates a chain of tariff versions for historical tracking. Nullable if tariff is current or not superseded.' ;
    rdfs:domain ind:PilotageTariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PilotageTariff .

ind:basePilotageFee rdf:type rdf:Property ;
    rdfs:label 'Base Pilotage Fee' ;
    rdfs:comment 'Base charge amount for the pilotage service before any surcharges or adjustments. Represents the standard fee for the defined vessel size band, zone, and time category. Currency is defined at port level (typically USD or local currency).' ;
    rdfs:domain ind:PilotageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dangerousGoodsSurcharge rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Surcharge' ;
    rdfs:comment 'Additional charge applied when piloting vessels carrying dangerous goods or hazardous materials as classified under IMDG Code. Reflects additional risk and certification requirements. Nullable if no dangerous goods surcharges apply.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceBasedFlag rdf:type rdf:Property ;
    rdfs:label 'Distance Based Flag' ;
    rdfs:comment 'Indicates whether this tariff includes distance-based pricing components. True if charges vary by nautical miles traveled, false if charges are fixed per service regardless of distance.' ;
    rdfs:domain ind:PilotageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dwtBandMaxTons rdf:type rdf:Property ;
    rdfs:label 'Dwt Band Max Tons' ;
    rdfs:comment 'Maximum Deadweight Tonnage (DWT) in tons for which this tariff applies. Nullable for open-ended upper bands. Defines the upper boundary of the deadweight segment.' ;
    rdfs:domain ind:PilotageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dwtBandMinTons rdf:type rdf:Property ;
    rdfs:label 'Dwt Band Min Tons' ;
    rdfs:comment 'Minimum Deadweight Tonnage (DWT) in tons for which this tariff applies. DWT is the measure of how much weight a vessel can safely carry (cargo, fuel, crew, provisions). Used for cargo vessel tariff segmentation.' ;
    rdfs:domain ind:PilotageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extraordinaryConditionsSurcharge rdf:type rdf:Property ;
    rdfs:label 'Extraordinary Conditions Surcharge' ;
    rdfs:comment 'Additional charge applied for pilotage under extraordinary conditions such as severe weather, restricted visibility, emergency situations, or vessels with special handling requirements. Nullable if no extraordinary surcharges apply.' ;
    rdfs:domain ind:PilotageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grtBandMaxTons rdf:type rdf:Property ;
    rdfs:label 'Grt Band Max Tons' ;
    rdfs:comment 'Maximum Gross Registered Tonnage (GRT) in tons for which this tariff applies. Nullable for open-ended upper bands. Defines the upper boundary of the tonnage segment.' ;
    rdfs:domain ind:PilotageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grtBandMinTons rdf:type rdf:Property ;
    rdfs:label 'Grt Band Min Tons' ;
    rdfs:comment 'Minimum Gross Registered Tonnage (GRT) in tons for which this tariff applies. GRT is a measure of the overall internal volume of a vessel. Used as an alternative or complementary vessel size metric for tariff segmentation.' ;
    rdfs:domain ind:PilotageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pilotageTariffStatus rdf:type rdf:Property ;
    rdfs:label 'Pilotage Tariff Status' ;
    rdfs:comment 'Current lifecycle status of the pilotage tariff. Active tariffs are in use, inactive are retired, suspended are temporarily not applicable, pending_approval awaits regulatory approval, superseded have been replaced by newer versions.' ;
    rdfs:domain ind:PilotageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerNauticalMile rdf:type rdf:Property ;
    rdfs:label 'Rate Per Nautical Mile' ;
    rdfs:comment 'Charge per nautical mile for distance-based pilotage tariffs. Applied in addition to or instead of base_pilotage_fee depending on tariff structure. Nullable if distance_based_flag is false.' ;
    rdfs:domain ind:PilotageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the regulatory approval or port authority authorization for this tariff. Links to official tariff approval documentation. Nullable if no formal approval reference exists.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPortEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Port Employee Id' ;
    rdfs:comment 'Identifier of the user who created this port dues schedule record in the system. Required for audit trail and accountability.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededBySchedulePortDuesScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Port Dues Schedule Id' ;
    rdfs:comment 'Reference to the port dues schedule that replaces this schedule. Nullable for current active schedules. Maintains version history and audit trail for regulatory compliance.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortDuesSchedule .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'Base monetary amount for the port dues charge before any discounts, surcharges, or adjustments. Represents the standard statutory rate for the defined vessel classification and dues type.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callFrequencyDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Call Frequency Discount Percentage' ;
    rdfs:comment 'Percentage discount applied to port dues for vessels meeting the call frequency tier criteria. Incentivizes regular service commitments and port loyalty.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callFrequencyTier rdf:type rdf:Property ;
    rdfs:label 'Call Frequency Tier' ;
    rdfs:comment 'Classification tier based on vessel call frequency at the port. First call applies to vessels making their inaugural visit, regular applies to standard service schedules, frequent applies to high-frequency callers, and premium applies to vessels with committed service agreements. Higher frequency tiers may attract discounted dues rates.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsSurchargePercentage rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Surcharge Percentage' ;
    rdfs:comment 'Additional percentage surcharge applied to port dues for vessels carrying International Maritime Dangerous Goods (IMDG) classified cargo. Reflects additional risk management and safety oversight costs.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duesType rdf:type rdf:Property ;
    rdfs:label 'Dues Type' ;
    rdfs:comment 'Classification of the statutory port dues charge type levied on vessels. Light dues cover navigational aids, conservancy dues cover channel maintenance, port entry fee is the basic vessel call charge, anchorage dues apply to vessels at anchor, navigation dues cover vessel traffic services, and pilotage dues cover mandatory pilotage services.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalLevyPercentage rdf:type rdf:Property ;
    rdfs:label 'Environmental Levy Percentage' ;
    rdfs:comment 'Percentage levy added to port dues to fund environmental protection initiatives, emissions monitoring, and compliance with MARPOL (Marine Pollution Convention) requirements.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exemption Criteria' ;
    rdfs:comment 'Detailed description of the criteria under which vessels may be exempt from port dues under this schedule. Typically includes naval vessels, government vessels on official duty, vessels in distress, and humanitarian mission vessels.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentPenaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Percentage' ;
    rdfs:comment 'Percentage penalty applied to overdue port dues payments. Calculated as a percentage of the outstanding amount per period (typically per month or per day).' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Days' ;
    rdfs:comment 'Number of days over which call frequency is measured for discount eligibility. Typically 30, 90, or 365 days depending on service agreement terms.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCallsPerPeriod rdf:type rdf:Property ;
    rdfs:label 'Minimum Calls Per Period' ;
    rdfs:comment 'Minimum number of vessel calls required within the measurement period to qualify for the call frequency discount. Used to enforce service commitment thresholds.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nrtBandMax rdf:type rdf:Property ;
    rdfs:label 'Nrt Band Max' ;
    rdfs:comment 'Maximum Net Registered Tonnage for the vessel size band. Nullable for open-ended upper bands.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nrtBandMin rdf:type rdf:Property ;
    rdfs:label 'Nrt Band Min' ;
    rdfs:comment 'Minimum Net Registered Tonnage for the vessel size band. NRT represents the earning capacity of the vessel and may be used as an alternative or supplementary metric for dues calculation in some jurisdictions.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portDuesScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Port Dues Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the port dues schedule. Draft schedules are under development, active schedules are in force, suspended schedules are temporarily inactive, expired schedules have passed their validity period, superseded schedules have been replaced by newer versions, and withdrawn schedules have been permanently removed.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevyPercentage rdf:type rdf:Property ;
    rdfs:label 'Security Levy Percentage' ;
    rdfs:comment 'Percentage levy added to port dues to fund International Ship and Port Facility Security (ISPS) Code compliance measures and port security infrastructure.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeType rdf:type rdf:Property ;
    rdfs:label 'Trade Type' ;
    rdfs:comment 'Classification of trade type for which this dues schedule applies. International trade involves cross-border cargo, coastal trade is between domestic ports, domestic trade is within national waters, cabotage is domestic cargo carriage reserved for national flag vessels, and transshipment involves cargo transfer without customs clearance.' ;
    rdfs:domain ind:PortDuesSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTariffPortTariffId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tariff Port Tariff Id' ;
    rdfs:comment 'Reference to the port_tariff_id of the newer tariff schedule that replaces this one. Null if this is the current active schedule.' ;
    rdfs:domain ind:PortTariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortTariff .

ind:applicableCargoTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Cargo Types' ;
    rdfs:comment 'Comma-separated list of cargo types to which this tariff applies (e.g., \'FCL\', \'LCL\', \'Breakbulk\', \'Dangerous Goods\', \'Reefer\'). Null if applicable to all cargo types.' ;
    rdfs:domain ind:PortTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableContainerTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Container Types' ;
    rdfs:comment 'Comma-separated list of container types to which this tariff applies (e.g., \'20GP\', \'40GP\', \'40HC\', \'45HC\', \'Reefer\', \'Tank\', \'Flat Rack\'). Null if not container-specific.' ;
    rdfs:domain ind:PortTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMovementTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Movement Types' ;
    rdfs:comment 'Comma-separated list of cargo movement types to which this tariff applies (e.g., \'Import\', \'Export\', \'Transshipment\', \'Empty Repositioning\', \'Restow\'). Null if applicable to all movements.' ;
    rdfs:domain ind:PortTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTerminalZones rdf:type rdf:Property ;
    rdfs:label 'Applicable Terminal Zones' ;
    rdfs:comment 'Comma-separated list of terminal zones, berths, or container yards to which this tariff applies (e.g., \'Zone A\', \'Berth 1-5\', \'CY North\'). Null if applicable port-wide.' ;
    rdfs:domain ind:PortTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTradeLanes rdf:type rdf:Property ;
    rdfs:label 'Applicable Trade Lanes' ;
    rdfs:comment 'Comma-separated list of trade lanes or routes to which this tariff applies (e.g., \'Asia-Europe\', \'Transpacific\', \'Intra-Asia\'). Null if applicable to all lanes.' ;
    rdfs:domain ind:PortTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableVesselCategories rdf:type rdf:Property ;
    rdfs:label 'Applicable Vessel Categories' ;
    rdfs:comment 'Comma-separated list of vessel types or categories to which this tariff applies (e.g., \'Container\', \'Bulk Carrier\', \'Tanker\', \'RoRo\'). Null if applicable to all vessel types.' ;
    rdfs:domain ind:PortTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationStructure rdf:type rdf:Property ;
    rdfs:label 'Escalation Structure' ;
    rdfs:comment 'Pricing escalation model for storage, demurrage, or detention charges. FLAT=Single rate throughout, TIERED=Rate increases at defined day thresholds, PROGRESSIVE=Rate increases daily or weekly.' ;
    rdfs:domain ind:PortTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffDescription rdf:type rdf:Property ;
    rdfs:label 'Tariff Description' ;
    rdfs:comment 'Detailed description of the tariff schedule including scope, applicability conditions, calculation methodology, and any special terms or exclusions.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffScheduleName rdf:type rdf:Property ;
    rdfs:label 'Tariff Schedule Name' ;
    rdfs:comment 'Human-readable name of the tariff schedule (e.g., \'Terminal Handling Charges - Container Import 2024\', \'Pilotage Fees - LOA Band 200-300m\').' ;
    rdfs:domain ind:PortTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingRuleId rdf:type rdf:Property ;
    rdfs:label 'Pricing Rule Id' ;
    rdfs:comment 'Unique identifier for the pricing rule. Primary key.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableRateCardId rdf:type rdf:Property ;
    rdfs:label 'Applicable Rate Card Id' ;
    rdfs:comment 'Specific rate card identifier that this pricing rule selects or modifies when trigger conditions are met.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:supersededByRulePricingRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Pricing Rule Id' ;
    rdfs:comment 'Identifier of the pricing rule that supersedes this rule, establishing version lineage and rule evolution history.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingRule .

ind:conflictResolutionStrategy rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Strategy' ;
    rdfs:comment 'Strategy used to resolve conflicts when multiple pricing rules with the same priority could apply to the same billable event.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Unique business identifier code for the pricing rule, used for external reference and system integration.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed textual description of the pricing rule purpose, business rationale, and application context for business user reference.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleExpression rdf:type rdf:Property ;
    rdfs:label 'Rule Expression' ;
    rdfs:comment 'Formal expression or decision logic defining the rule conditions and calculation formula, stored in a structured or semi-structured format for execution by the billing engine.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the pricing rule describing its purpose and application context.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the pricing rule indicating whether it is in use, pending approval, or retired.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the pricing rule logic type determining how charges are calculated or tariffs are selected. [ENUM-REF-CANDIDATE: tiered_pricing|conditional_surcharge|minimum_charge_enforcement|free_period_calculation|tariff_selection|applicability_matrix|conflict_resolution — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargePercentage rdf:type rdf:Property ;
    rdfs:label 'Surcharge Percentage' ;
    rdfs:comment 'Percentage surcharge applied by this pricing rule when trigger conditions are met (e.g., BAF, CAF, peak season surcharge).' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerCargoType rdf:type rdf:Property ;
    rdfs:label 'Trigger Cargo Type' ;
    rdfs:comment 'Cargo type condition that triggers the applicability of this pricing rule (e.g., containerized, bulk, RoRo, dangerous goods). Pipe-separated list for multiple values.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCargoWeightMaxKg rdf:type rdf:Property ;
    rdfs:label 'Trigger Cargo Weight Max Kg' ;
    rdfs:comment 'Maximum cargo weight threshold in kilograms that triggers the applicability of this pricing rule. Used for weight-based tiered pricing.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerCargoWeightMinKg rdf:type rdf:Property ;
    rdfs:label 'Trigger Cargo Weight Min Kg' ;
    rdfs:comment 'Minimum cargo weight threshold in kilograms that triggers the applicability of this pricing rule. Used for weight-based tiered pricing.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerContainerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Container Type' ;
    rdfs:comment 'Container type condition that triggers the applicability of this pricing rule (e.g., 20ft dry, 40ft dry, 40ft high cube, reefer, tank, flat rack). Pipe-separated list for multiple values.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Trigger Customer Segment' ;
    rdfs:comment 'Customer segment condition that triggers the applicability of this pricing rule (e.g., shipping line, freight forwarder, cargo owner, government). Pipe-separated list for multiple values.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerGrtMax rdf:type rdf:Property ;
    rdfs:label 'Trigger Grt Max' ;
    rdfs:comment 'Maximum gross registered tonnage that triggers the applicability of this pricing rule. Used for vessel tonnage-based pricing.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerGrtMin rdf:type rdf:Property ;
    rdfs:label 'Trigger Grt Min' ;
    rdfs:comment 'Minimum gross registered tonnage that triggers the applicability of this pricing rule. Used for vessel tonnage-based pricing.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerLoaMaxMeters rdf:type rdf:Property ;
    rdfs:label 'Trigger Loa Max Meters' ;
    rdfs:comment 'Maximum vessel length overall in meters that triggers the applicability of this pricing rule. Used for vessel size-based pricing.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerLoaMinMeters rdf:type rdf:Property ;
    rdfs:label 'Trigger Loa Min Meters' ;
    rdfs:comment 'Minimum vessel length overall in meters that triggers the applicability of this pricing rule. Used for vessel size-based pricing.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerServiceType rdf:type rdf:Property ;
    rdfs:label 'Trigger Service Type' ;
    rdfs:comment 'Service type condition that triggers the applicability of this pricing rule (e.g., THC, wharfage, pilotage, demurrage, detention, storage). Pipe-separated list for multiple values.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerTradeDirection rdf:type rdf:Property ;
    rdfs:label 'Trigger Trade Direction' ;
    rdfs:comment 'Trade direction condition that triggers the applicability of this pricing rule, determining whether the cargo is inbound, outbound, or in transit.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerTradeLane rdf:type rdf:Property ;
    rdfs:label 'Trigger Trade Lane' ;
    rdfs:comment 'Trade lane or route condition that triggers the applicability of this pricing rule (e.g., Asia-Europe, Transpacific, Transatlantic). Pipe-separated list for multiple values.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerVesselClass rdf:type rdf:Property ;
    rdfs:label 'Trigger Vessel Class' ;
    rdfs:comment 'Vessel class or category condition that triggers the applicability of this pricing rule (e.g., feeder, panamax, post-panamax, ULCV). Pipe-separated list for multiple values.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerVolumeMaxTeu rdf:type rdf:Property ;
    rdfs:label 'Trigger Volume Max Teu' ;
    rdfs:comment 'Maximum volume threshold in TEU that triggers the applicability of this pricing rule. Used for volume-based tiered pricing.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerVolumeMinTeu rdf:type rdf:Property ;
    rdfs:label 'Trigger Volume Min Teu' ;
    rdfs:comment 'Minimum volume threshold in TEU that triggers the applicability of this pricing rule. Used for volume-based tiered pricing or minimum commitment enforcement.' ;
    rdfs:domain ind:PricingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryRatePortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Primary Rate Port Community Participant Id' ;
    rdfs:comment 'Reference to the specific customer or shipping line to which this rate card applies. Null if rate card is segment-based rather than customer-specific.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:supersededByRateCardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Card Id' ;
    rdfs:comment 'Reference to the newer rate card that replaces this one. Null if this rate card is still current or has not been superseded.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:committedVolumeTeu rdf:type rdf:Property ;
    rdfs:label 'Committed Volume Teu' ;
    rdfs:comment 'Committed container volume in TEU that the customer agrees to handle under this rate card during the contract period. Applicable to volume-based rate cards.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:craneProductivityTargetMovesPerHour rdf:type rdf:Property ;
    rdfs:label 'Crane Productivity Target Moves Per Hour' ;
    rdfs:comment 'Target crane productivity in container moves per hour committed under SLA-linked rate cards. Null for non-SLA rate cards.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateProcessingTimeTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Gate Processing Time Target Minutes' ;
    rdfs:comment 'Target gate processing time in minutes for truck transactions committed under SLA-linked rate cards. Null for non-SLA rate cards.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'Time period over which SLA performance is measured and assessed (e.g., monthly average, per vessel call). Null for non-SLA rate cards.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Amount' ;
    rdfs:comment 'Minimum revenue or volume commitment required from the customer to qualify for this rate card pricing. Null if no minimum commitment applies.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Description' ;
    rdfs:comment 'Textual description of penalty terms applicable if SLA performance targets are not met (e.g., \'5% rate reduction for each hour beyond target turnaround time\'). Null for non-SLA rate cards.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumClauseDescription rdf:type rdf:Property ;
    rdfs:label 'Premium Clause Description' ;
    rdfs:comment 'Textual description of premium or bonus terms applicable if SLA performance targets are exceeded (e.g., \'3% rate premium for turnaround time 20% faster than target\'). Null for non-SLA rate cards.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPercentage rdf:type rdf:Property ;
    rdfs:label 'Premium Percentage' ;
    rdfs:comment 'Overall premium percentage applied to base tariff rates in this rate card for expedited or premium services (e.g., 10.00 represents a 10% premium). Null if no premium applies.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardName rdf:type rdf:Property ;
    rdfs:label 'Rate Card Name' ;
    rdfs:comment 'Human-readable name of the rate card, typically describing the customer segment, trade lane, or service tier (e.g., \'Asia-Europe Premium SLA Gold Tier\', \'Standard Container Handling - Tier 1 Customers\').' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Card Number' ;
    rdfs:comment 'Externally-known unique business identifier for the rate card, used in commercial documentation and billing references.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardType rdf:type rdf:Property ;
    rdfs:label 'Rate Card Type' ;
    rdfs:comment 'Classification of the rate card: standard (published rates), sla_linked (performance-based pricing with SLA tiers), promotional (temporary discount rates), spot (one-time negotiated rates), contract (long-term agreement rates).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselTurnaroundTimeTargetHours rdf:type rdf:Property ;
    rdfs:label 'Vessel Turnaround Time Target Hours' ;
    rdfs:comment 'Target vessel turnaround time in hours committed under SLA-linked rate cards. Null for non-SLA rate cards.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bafApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Baf Applicable Flag' ;
    rdfs:comment 'Indicates whether the Bunker Adjustment Factor (BAF) surcharge is applicable to this rate card line. BAF compensates for fuel cost fluctuations. True if BAF applies, False otherwise.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cafApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Caf Applicable Flag' ;
    rdfs:comment 'Indicates whether the Currency Adjustment Factor (CAF) surcharge is applicable to this rate card line. CAF compensates for currency exchange rate fluctuations. True if CAF applies, False otherwise.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of this rate card line. Values: draft (under negotiation), active (in effect and billable), suspended (temporarily inactive), expired (validity period ended), superseded (replaced by newer version), cancelled (terminated before expiry).' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Quantity' ;
    rdfs:comment 'The maximum quantity threshold for this rate to apply. Used for tiered pricing structures where different rates apply to different volume bands. Null if no maximum applies.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'The minimum quantity threshold for this rate to apply. Used for minimum charge enforcement or tiered pricing structures. Null if no minimum applies.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Code indicating the reason for any manual override or exception to standard pricing rules for this line. Examples include VOLUME_DISCOUNT, STRATEGIC_CUSTOMER, PROMOTIONAL, SERVICE_RECOVERY, COMPETITIVE_MATCH. Null if no override applies.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Override Reason Description' ;
    rdfs:comment 'Detailed textual explanation of the reason for any pricing override or exception applied to this rate card line. Provides audit trail and business justification.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The target service delivery time in hours associated with this rate card line, if the pricing is linked to a Service Level Agreement (SLA). Used for SLA-linked service rate cards. Null if no SLA applies.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThresholdLower rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Lower' ;
    rdfs:comment 'Lower bound of the quantity tier for tiered pricing. When quantity falls within this tier, the specified unit rate applies. Null for flat-rate pricing.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThresholdUpper rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Upper' ;
    rdfs:comment 'Upper bound of the quantity tier for tiered pricing. When quantity falls within this tier, the specified unit rate applies. Null for flat-rate pricing or open-ended top tier.' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Service Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: SLA-based rate cards with performance targets (vessel turnaround time, crane productivity, gate processing) require designated service managers to monitor KPIs, coordinate operational delivery, handle' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Segment' ;
    rdfs:comment 'Customer segment or classification to which this SLA rate card applies (e.g., \'Tier 1 Shipping Lines\', \'Freight Forwarders\', \'All Customers\'). Nullable if universally applicable.' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthAllocationResponseTimeTargetHours rdf:type rdf:Property ;
    rdfs:label 'Berth Allocation Response Time Target Hours' ;
    rdfs:comment 'Committed Key Performance Indicator (KPI) for berth allocation response time in hours from vessel pre-arrival notification.' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Discount Eligibility Flag' ;
    rdfs:comment 'Indicates whether this SLA rate card is eligible for additional volume or loyalty discounts (True/False).' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationIndexType rdf:type rdf:Property ;
    rdfs:label 'Escalation Index Type' ;
    rdfs:comment 'Type of index used for automatic rate escalation (CPI, Fuel Index, Currency Exchange, Fixed Percentage, None).' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Textual description of force majeure conditions under which SLA performance obligations are suspended (e.g., natural disasters, labor strikes, port closures).' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumVolumeCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume Cap' ;
    rdfs:comment 'Maximum volume cap for this SLA rate card, beyond which different pricing applies. Nullable if no cap applies.' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment' ;
    rdfs:comment 'Minimum volume commitment required to qualify for this SLA rate card, measured in the rate unit of measure. Nullable if no minimum applies.' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Penalty Percentage' ;
    rdfs:comment 'Percentage penalty (discount) applied to base rate when SLA performance targets are not met. Nullable if no penalty applies.' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Performance Reporting Frequency' ;
    rdfs:comment 'Frequency at which SLA performance reports are provided to customers (Real-Time, Daily, Weekly, Monthly, Quarterly).' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardCode rdf:type rdf:Property ;
    rdfs:label 'Rate Card Code' ;
    rdfs:comment 'Externally-known unique business identifier for the SLA rate card, used in contracts and billing systems.' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Card Status' ;
    rdfs:comment 'Current lifecycle status of the SLA rate card (Draft, Active, Suspended, Expired, Superseded).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rate amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceExclusions rdf:type rdf:Property ;
    rdfs:label 'Service Exclusions' ;
    rdfs:comment 'Textual description of services or scenarios explicitly excluded from this SLA rate card (e.g., \'Excludes dangerous goods handling\', \'Excludes overtime charges\').' ;
    rdfs:domain ind:SlaRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTariffStorageTariffId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tariff Storage Tariff Id' ;
    rdfs:comment 'Reference to the storage tariff ID that replaces this tariff schedule, enabling version lineage tracking. Null if current version.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageTariff .

ind:demurrageConversionDay rdf:type rdf:Property ;
    rdfs:label 'Demurrage Conversion Day' ;
    rdfs:comment 'Day number at which storage charges convert to demurrage charges, if demurrage linkage is enabled. Null if no conversion applies.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demurrageLinkageFlag rdf:type rdf:Property ;
    rdfs:label 'Demurrage Linkage Flag' ;
    rdfs:comment 'Indicates whether this storage tariff is linked to demurrage charges. True = storage charges convert to or trigger demurrage after specified period, False = standalone storage charges only.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeStorageDays rdf:type rdf:Property ;
    rdfs:label 'Free Storage Days' ;
    rdfs:comment 'Number of calendar days of free storage allowed before storage charges commence. Varies by container status, customer tier, and cargo type.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicHolidayChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Public Holiday Charge Flag' ;
    rdfs:comment 'Indicates whether storage charges apply on public holidays. True = holidays are chargeable days, False = holidays excluded from storage day count.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateBand1DailyRate rdf:type rdf:Property ;
    rdfs:label 'Rate Band 1 Daily Rate' ;
    rdfs:comment 'Daily storage charge amount for rate band 1, expressed in the tariff currency.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBand1EndDay rdf:type rdf:Property ;
    rdfs:label 'Rate Band 1 End Day' ;
    rdfs:comment 'Ending day number (inclusive) for the first storage rate band.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateBand1StartDay rdf:type rdf:Property ;
    rdfs:label 'Rate Band 1 Start Day' ;
    rdfs:comment 'Starting day number (inclusive) for the first storage rate band, typically immediately after free storage period expires.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateBand2DailyRate rdf:type rdf:Property ;
    rdfs:label 'Rate Band 2 Daily Rate' ;
    rdfs:comment 'Daily storage charge amount for rate band 2, typically higher than band 1 to incentivize cargo movement.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBand2EndDay rdf:type rdf:Property ;
    rdfs:label 'Rate Band 2 End Day' ;
    rdfs:comment 'Ending day number (inclusive) for the second storage rate band. Null indicates open-ended band.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateBand2StartDay rdf:type rdf:Property ;
    rdfs:label 'Rate Band 2 Start Day' ;
    rdfs:comment 'Starting day number (inclusive) for the second storage rate band, typically with escalated rates.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateBand3DailyRate rdf:type rdf:Property ;
    rdfs:label 'Rate Band 3 Daily Rate' ;
    rdfs:comment 'Daily storage charge amount for rate band 3, typically the highest rate for long-term storage.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBand3EndDay rdf:type rdf:Property ;
    rdfs:label 'Rate Band 3 End Day' ;
    rdfs:comment 'Ending day number (inclusive) for the third storage rate band. Null indicates open-ended band.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateBand3StartDay rdf:type rdf:Property ;
    rdfs:label 'Rate Band 3 Start Day' ;
    rdfs:comment 'Starting day number (inclusive) for the third storage rate band, for extended storage periods.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekendChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Weekend Charge Flag' ;
    rdfs:comment 'Indicates whether storage charges apply on weekends. True = weekends are chargeable days, False = weekends excluded from storage day count.' ;
    rdfs:domain ind:StorageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByRuleSurchargeRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Surcharge Rule Id' ;
    rdfs:comment 'Reference to the surcharge_rule_id that supersedes this rule. Null if this is the current active version. Enables navigation through rule version history.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurchargeRule .

ind:applicabilityConditions rdf:type rdf:Property ;
    rdfs:label 'Applicability Conditions' ;
    rdfs:comment 'Free-text description of specific conditions under which this surcharge applies (e.g., applies only during peak season months, applies when fuel price exceeds threshold, applies to vessels over 50,000 DWT). Captures business rules not covered by structured fields.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationBase rdf:type rdf:Property ;
    rdfs:label 'Calculation Base' ;
    rdfs:comment 'The base amount upon which percentage-based surcharges are calculated: FREIGHT (ocean freight charges), THC (Terminal Handling Charges), BASE_TARIFF (base port tariff), TOTAL_CHARGES (sum of all charges before surcharge), CARGO_VALUE (declared cargo value). Applicable when calculation_method is PERCENTAGE_OF_BASE.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationPriority rdf:type rdf:Property ;
    rdfs:label 'Calculation Priority' ;
    rdfs:comment 'Numeric priority order for applying this surcharge when multiple surcharges are applicable (lower numbers calculated first). Ensures consistent calculation sequence when compounding is allowed.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compoundingAllowed rdf:type rdf:Property ;
    rdfs:label 'Compounding Allowed' ;
    rdfs:comment 'Indicates whether this surcharge can be compounded with other surcharges (true) or must be calculated independently on the base amount only (false). Affects multi-surcharge calculation order and logic.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyPair rdf:type rdf:Property ;
    rdfs:label 'Currency Pair' ;
    rdfs:comment 'Currency pair for CAF (Currency Adjustment Factor) surcharges in format BASE/QUOTE (e.g., USD/EUR, EUR/SGD). Indicates the exchange rate relationship used for currency adjustment calculations. Applicable only for CAF surcharge types.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexReferenceName rdf:type rdf:Property ;
    rdfs:label 'Index Reference Name' ;
    rdfs:comment 'Name of the external index or benchmark used for index-linked surcharges (e.g., Platts Singapore Fuel Oil 380, MOPS Singapore, Bloomberg Commodity Index). Used primarily for BAF calculations. Null if not index-linked.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Index Reference Url' ;
    rdfs:comment 'URL or reference location for the external index source used in index-linked surcharge calculations. Enables audit trail and verification of index values.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method for prorating the surcharge when applicable period is partial: NONE (no proration, full charge applies), DAILY (prorated by days), MONTHLY (prorated by months), PROPORTIONAL (prorated by usage or volume). Applicable for time-based or usage-based surcharges.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'Numeric rate value for the surcharge. Interpretation depends on calculation_method: flat fee amount, percentage value (e.g., 5.5 for 5.5%), or per-unit rate. Null if index-linked calculation is used.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Percentage' ;
    rdfs:comment 'Percentage rate for surcharges calculated as percentage of base amount (e.g., 3.5000 represents 3.5%). Used when calculation_method is PERCENTAGE_OF_BASE. Null for non-percentage methods.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Service Type Applicability' ;
    rdfs:comment 'Port services to which this surcharge applies (e.g., Wharfage, Pilotage, Towage, Storage, ALL). Pipe-separated list if multiple services apply. Null indicates applicability to all services.' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeName rdf:type rdf:Property ;
    rdfs:label 'Surcharge Name' ;
    rdfs:comment 'Full descriptive name of the surcharge for display and reporting purposes (e.g., Bunker Adjustment Factor - Asia Pacific, Currency Adjustment Factor USD/EUR).' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeType rdf:type rdf:Property ;
    rdfs:label 'Surcharge Type' ;
    rdfs:comment 'Discriminator identifying the category of surcharge: BAF (Bunker Adjustment Factor), CAF (Currency Adjustment Factor), PIL (Port Infrastructure Levy), ISPS (International Ship and Port Facility Security), PEAK_SEASON, IMDG (International Maritime Dangerous Goods), OOG (Out-of-Gauge), COLD_IRONING, THC_ADJUSTMENT (Terminal Handling Charge Adjustment), CONGESTION, REEFER (Refrigerated Container), SECURITY. [ENUM-REF-CANDIDATE: BAF|CAF|PIL|ISPS|PEAK_SEASON|IMDG|OOG|COLD_IRONING|THC_ADJUSTMENT|CONGESTION|REEFER|SECURITY — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SurchargeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityId rdf:type rdf:Property ;
    rdfs:label 'Applicability Id' ;
    rdfs:comment 'Unique identifier for the tariff applicability rule. Primary key for the tariff applicability matrix.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applicability Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this applicability rule record. Required for audit trail and data governance.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicabilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applicability Employee Id' ;
    rdfs:comment 'Reference to the user who approved this applicability rule. Required for audit trail and compliance with tariff governance policies.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicabilityModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applicability Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this applicability rule record. Required for audit trail and change tracking.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originUnLocodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Un Locode Id' ;
    rdfs:comment 'Foreign key linking to masterdata.un_locode. Business justification: Applicability rules specify port_of_origin for trade lane-based tariff filtering. UN LOCODE provides standardized location references for origin/destination routing. Essential for trade lane tariff ap' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnLocode .

ind:supersededByRuleApplicabilityId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Applicability Id' ;
    rdfs:comment 'Reference to the applicability rule that supersedes this one. Used for version control and historical tariff tracking.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Applicability .

ind:applicabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Applicability Status' ;
    rdfs:comment 'Current lifecycle status of the applicability rule. Only active rules are used by the billing engine for tariff selection.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictResolutionOrder rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Order' ;
    rdfs:comment 'Secondary ordering criterion for conflict resolution when multiple rules have the same priority. Used in conjunction with rule_priority for deterministic tariff selection.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dangerousGoodsClass rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Class' ;
    rdfs:comment 'IMDG dangerous goods classification to which this tariff applies. Dangerous goods require specialized handling and attract premium charges.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Flag' ;
    rdfs:comment 'Indicates whether this rule defines an exclusion (tariff does NOT apply) rather than an inclusion. Used for negative matching in complex tariff matrices.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grtMax rdf:type rdf:Property ;
    rdfs:label 'Grt Max' ;
    rdfs:comment 'Maximum gross registered tonnage for this tariff to apply. Null indicates no upper limit. Enables GRT-based tariff banding.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grtMin rdf:type rdf:Property ;
    rdfs:label 'Grt Min' ;
    rdfs:comment 'Minimum gross registered tonnage for this tariff to apply. GRT is used for port dues and regulatory fee calculation.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loaMaxMeters rdf:type rdf:Property ;
    rdfs:label 'Loa Max Meters' ;
    rdfs:comment 'Maximum vessel length overall in meters for this tariff to apply. Null indicates no upper limit. Used for vessel size-based tariff banding.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loaMinMeters rdf:type rdf:Property ;
    rdfs:label 'Loa Min Meters' ;
    rdfs:comment 'Minimum vessel length overall in meters for this tariff to apply. LOA is a key dimension for berth allocation and wharfage calculation.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portOfDestination rdf:type rdf:Property ;
    rdfs:label 'Port Of Destination' ;
    rdfs:comment 'UN/LOCODE of the port of discharge to which this tariff applies. Null indicates applicability to all destination ports. Used for origin-destination pricing matrices.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'Priority order for conflict resolution when multiple tariff applicability rules match a billable event. Lower numbers indicate higher priority. Used by billing engine to deterministically select the correct tariff.' ;
    rdfs:domain ind:Applicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Exception Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this tariff exception record in the system.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:exceptionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Exception Employee Id' ;
    rdfs:comment 'Reference to the user who formally approved this tariff exception in the system.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:exceptionModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Exception Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this tariff exception record.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:exceptionRevokedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Exception Revoked By User Employee Id' ;
    rdfs:comment 'Reference to the user who revoked this tariff exception, if applicable.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationScope rdf:type rdf:Property ;
    rdfs:label 'Application Scope' ;
    rdfs:comment 'Defines the scope of applicability for this exception: whether it applies to a single transaction, all transactions within a vessel call, all transactions under a customer agreement, specific cargo types, trade lanes, or a defined time period.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to external audit trail or approval workflow documentation supporting this exception decision.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalClause rdf:type rdf:Property ;
    rdfs:label 'Conditional Clause' ;
    rdfs:comment 'Any conditional terms or clauses that must be satisfied for this exception to remain valid (e.g., performance targets, volume thresholds, payment terms).' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this tariff exception for tracking and audit purposes.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the tariff exception indicating its approval and validity state. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|expired|revoked|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Classification of the type of tariff exception granted. Indicates the nature of the deviation from standard published tariff. [ENUM-REF-CANDIDATE: rate_waiver|rate_discount|free_day_extension|surcharge_exemption|thc_waiver|dmg_waiver|det_waiver|storage_waiver — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeDaysGranted rdf:type rdf:Property ;
    rdfs:label 'Free Days Granted' ;
    rdfs:comment 'Extended number of free days granted under this exception before storage or demurrage charges apply.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freeDaysStandard rdf:type rdf:Property ;
    rdfs:label 'Free Days Standard' ;
    rdfs:comment 'Number of free days allowed under the standard published tariff before storage or demurrage charges apply.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Detailed business justification and rationale for granting this tariff exception, including commercial, operational, or strategic reasons.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Commitment Amount' ;
    rdfs:comment 'Minimum revenue commitment amount that the customer must meet to qualify for this exception, in the specified currency.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardRateAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Rate Amount' ;
    rdfs:comment 'The standard published tariff rate amount from which this exception deviates, in the specified currency.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Validity Period Days' ;
    rdfs:comment 'Number of days for which this exception remains valid, calculated from the effective date.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filingId rdf:type rdf:Property ;
    rdfs:label 'Filing Id' ;
    rdfs:comment 'Unique identifier for the tariff filing record. Primary key for the tariff filing entity.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filingCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Filing Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created the initial tariff filing record.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:filingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Filing Employee Id' ;
    rdfs:comment 'Identifier of the port authority user who submitted the tariff filing to the regulator.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:filingModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Filing Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the tariff filing record.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:filingWithdrawnByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Filing Withdrawn By User Employee Id' ;
    rdfs:comment 'Identifier of the port authority user who initiated the withdrawal of the tariff filing.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySupersededByFilingId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Filing Id' ;
    rdfs:comment 'Reference to the subsequent tariff filing that supersedes this filing, creating a version history chain.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Filing .

ind:approvedByAuthorityOfficer rdf:type rdf:Property ;
    rdfs:label 'Approved By Authority Officer' ;
    rdfs:comment 'Name and title of the regulatory authority officer who signed off on the tariff filing approval.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsImposed rdf:type rdf:Property ;
    rdfs:label 'Conditions Imposed' ;
    rdfs:comment 'Specific conditions, restrictions, or requirements imposed by the regulatory authority as part of the tariff approval.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDateGranted rdf:type rdf:Property ;
    rdfs:label 'Effective Date Granted' ;
    rdfs:comment 'Date granted by the regulatory authority when the approved tariff is authorized to take effect and be applied to port services.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedRevenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact Amount' ;
    rdfs:comment 'Projected annual revenue impact of the proposed tariff changes, used in regulatory impact assessment.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryDateGranted rdf:type rdf:Property ;
    rdfs:label 'Expiry Date Granted' ;
    rdfs:comment 'Date when the approved tariff expires and must be renewed or refiled, as specified by the regulatory authority.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current status of the tariff filing in the regulatory approval lifecycle, from draft preparation through final approval or rejection. [ENUM-REF-CANDIDATE: draft|submitted|under_review|public_consultation|approved|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Classification of the tariff filing indicating whether it is a new tariff, amendment to existing tariff, full revision, withdrawal, or emergency filing.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gazettePublicationDate rdf:type rdf:Property ;
    rdfs:label 'Gazette Publication Date' ;
    rdfs:comment 'Date when the approved tariff was published in the official government gazette or public registry, making it legally effective.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gazetteReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Gazette Reference Number' ;
    rdfs:comment 'Official reference number or citation of the gazette publication where the approved tariff was published.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Completed Flag' ;
    rdfs:comment 'Indicates whether a regulatory impact assessment was completed and submitted as part of the tariff filing.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Flag' ;
    rdfs:comment 'Indicates whether internal legal review was completed before submitting the tariff filing to the regulatory authority.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewerName rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Name' ;
    rdfs:comment 'Name of the legal counsel or compliance officer who reviewed the tariff filing for regulatory compliance.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicCommentCount rdf:type rdf:Property ;
    rdfs:label 'Public Comment Count' ;
    rdfs:comment 'Total number of public comments or submissions received during the consultation period from stakeholders.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicConsultationEndDate rdf:type rdf:Property ;
    rdfs:label 'Public Consultation End Date' ;
    rdfs:comment 'Date when the public consultation period closes and no further stakeholder comments will be accepted.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicConsultationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Public Consultation Required Flag' ;
    rdfs:comment 'Indicates whether the tariff filing requires a public consultation period for stakeholder feedback before approval.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicConsultationStartDate rdf:type rdf:Property ;
    rdfs:label 'Public Consultation Start Date' ;
    rdfs:comment 'Date when the public consultation period begins, allowing stakeholders to submit comments on the proposed tariff.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthorityContact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Contact' ;
    rdfs:comment 'Contact information for the regulatory authority case officer or department handling the tariff filing.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderFeedbackSummary rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Feedback Summary' ;
    rdfs:comment 'Summary of key themes, concerns, and recommendations raised by stakeholders during the public consultation period.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Reference' ;
    rdfs:comment 'Reference to supporting documents submitted with the filing, such as cost justifications, impact assessments, or stakeholder consultation records.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date when the tariff filing was withdrawn by the port authority before regulatory approval was granted.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Explanation for why the tariff filing was withdrawn, such as business decision change, stakeholder opposition, or regulatory feedback.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeBasis rdf:type rdf:Property ;
    rdfs:label 'Charge Basis' ;
    rdfs:comment 'The calculation method for the charge (e.g., per unit, per day, per move, flat rate, percentage of cargo value). [ENUM-REF-CANDIDATE: per_unit|per_day|per_move|per_gang|per_hour|per_shift|per_vessel_call|flat_rate|percentage — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCode rdf:type rdf:Property ;
    rdfs:label 'Charge Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the type of charge (e.g., THC, WHR, DMG, DET, PIL, BAF, CAF). Used as the billing system reference for this tariff item.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Description' ;
    rdfs:comment 'Detailed description of the tariff item, including applicability conditions, service scope, and any special terms or exclusions.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeName rdf:type rdf:Property ;
    rdfs:label 'Charge Name' ;
    rdfs:comment 'Human-readable name of the charge (e.g., Terminal Handling Charge, Wharfage, Pilotage Fee, Demurrage, Detention, Port Infrastructure Levy).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerSizeApplicability rdf:type rdf:Property ;
    rdfs:label 'Container Size Applicability' ;
    rdfs:comment 'Specifies which container sizes this tariff item applies to (20ft for TEU, 40ft for FEU, 45ft for high-cube, all for any size).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTier1Days rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier 1 Days' ;
    rdfs:comment 'Number of days after free time expires when the first escalation tier rate applies (used for storage, demurrage, detention with escalating daily rates).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationTier1Rate rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier 1 Rate' ;
    rdfs:comment 'Rate amount for the first escalation tier (days beyond free time up to escalation_tier_1_days).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationTier2Days rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier 2 Days' ;
    rdfs:comment 'Number of days after tier 1 expires when the second escalation tier rate applies.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationTier2Rate rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier 2 Rate' ;
    rdfs:comment 'Rate amount for the second escalation tier (days beyond tier 1 up to escalation_tier_2_days).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationTier3Days rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier 3 Days' ;
    rdfs:comment 'Number of days after tier 2 expires when the third escalation tier rate applies.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationTier3Rate rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier 3 Rate' ;
    rdfs:comment 'Rate amount for the third escalation tier (days beyond tier 2 up to escalation_tier_3_days).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fclLclApplicability rdf:type rdf:Property ;
    rdfs:label 'Fcl Lcl Applicability' ;
    rdfs:comment 'Indicates whether this tariff item applies to Full Container Load (FCL) shipments, Less than Container Load (LCL) shipments, or both.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importExportDirection rdf:type rdf:Property ;
    rdfs:label 'Import Export Direction' ;
    rdfs:comment 'Specifies whether this tariff item applies to import cargo, export cargo, transshipment cargo, or all directions.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateBandAmount1 rdf:type rdf:Property ;
    rdfs:label 'Rate Band Amount 1' ;
    rdfs:comment 'Rate amount applied to units within the first rate band (up to rate_band_threshold_1).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBandAmount2 rdf:type rdf:Property ;
    rdfs:label 'Rate Band Amount 2' ;
    rdfs:comment 'Rate amount applied to units within the second rate band (between threshold_1 and threshold_2).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBandAmount3 rdf:type rdf:Property ;
    rdfs:label 'Rate Band Amount 3' ;
    rdfs:comment 'Rate amount applied to units within the third rate band (between threshold_2 and threshold_3).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBandThreshold1 rdf:type rdf:Property ;
    rdfs:label 'Rate Band Threshold 1' ;
    rdfs:comment 'First threshold value for tiered pricing. Units below or equal to this threshold are charged at rate_band_amount_1.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBandThreshold2 rdf:type rdf:Property ;
    rdfs:label 'Rate Band Threshold 2' ;
    rdfs:comment 'Second threshold value for tiered pricing. Units above threshold_1 and below or equal to this threshold are charged at rate_band_amount_2.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBandThreshold3 rdf:type rdf:Property ;
    rdfs:label 'Rate Band Threshold 3' ;
    rdfs:comment 'Third threshold value for tiered pricing. Units above threshold_2 and below or equal to this threshold are charged at rate_band_amount_3.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roundingPrecision rdf:type rdf:Property ;
    rdfs:label 'Rounding Precision' ;
    rdfs:comment 'Number of decimal places to which the charge should be rounded (e.g., 0 for whole numbers, 2 for cents).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'Specifies how calculated charges should be rounded (e.g., round up to nearest whole unit, round down, round to nearest, no rounding).' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Sla Service Level' ;
    rdfs:comment 'Service level tier associated with this tariff item (e.g., standard, express, premium). Used for SLA-linked rate cards where pricing varies by committed service level.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tieredPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Tiered Pricing Flag' ;
    rdfs:comment 'Indicates whether this tariff item uses tiered or banded pricing (True) or a flat rate (False). When True, rate bands and thresholds apply.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeLaneApplicability rdf:type rdf:Property ;
    rdfs:label 'Trade Lane Applicability' ;
    rdfs:comment 'Comma-separated list of trade lanes or routes to which this tariff item applies (e.g., asia_europe, transatlantic, intra_asia). Empty means applies to all trade lanes.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationId rdf:type rdf:Property ;
    rdfs:label 'Negotiation Id' ;
    rdfs:comment 'Unique identifier for the tariff or rate negotiation record. Primary key.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiationApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiation Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who provided final approval for this negotiation.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:negotiationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiation Employee Id' ;
    rdfs:comment 'Reference to the port staff member who initiated this negotiation.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:negotiationModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiation Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this negotiation record.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:resultingRateCardId rdf:type rdf:Property ;
    rdfs:label 'Resulting Rate Card Id' ;
    rdfs:comment 'Reference to the rate card created as a result of this successful negotiation.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Level of authority required to approve this negotiation based on materiality and deviation from standard terms.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialJustification rdf:type rdf:Property ;
    rdfs:label 'Commercial Justification' ;
    rdfs:comment 'Detailed business rationale and justification for the proposed rates and terms, including competitive analysis and strategic considerations.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Commitment Period Months' ;
    rdfs:comment 'Duration in months for which the volume or revenue commitment applies.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorBenchmarkRate rdf:type rdf:Property ;
    rdfs:label 'Competitor Benchmark Rate' ;
    rdfs:comment 'Competitive benchmark rate from rival ports used as reference during negotiation.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterOfferRateAmount rdf:type rdf:Property ;
    rdfs:label 'Counter Offer Rate Amount' ;
    rdfs:comment 'The counter-offer rate amount proposed by the customer in response to the port\'s proposal.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalAgreedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Final Agreed Rate Amount' ;
    rdfs:comment 'The final rate amount agreed upon by both parties after negotiation completion.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the negotiation was formally initiated.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationStatus rdf:type rdf:Property ;
    rdfs:label 'Negotiation Status' ;
    rdfs:comment 'Current lifecycle status of the negotiation process. [ENUM-REF-CANDIDATE: draft|in_progress|under_review|approved|rejected|withdrawn|completed|superseded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationType rdf:type rdf:Property ;
    rdfs:label 'Negotiation Type' ;
    rdfs:comment 'Classification of the negotiation based on its purpose and scope. [ENUM-REF-CANDIDATE: new_contract|renewal|amendment|exception|volume_discount|sla_linked|ad_hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Rate Amount' ;
    rdfs:comment 'The rate amount proposed by the port in the current negotiation round.' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Assessment of commercial risk associated with the negotiated terms (e.g., revenue impact, customer credit risk, volume uncertainty).' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:round rdf:type rdf:Property ;
    rdfs:label 'Round' ;
    rdfs:comment 'Sequential counter indicating the current round of negotiation (1 for initial proposal, incremented for each counter-offer cycle).' ;
    rdfs:domain ind:Negotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionId rdf:type rdf:Property ;
    rdfs:label 'Version Id' ;
    rdfs:comment 'Unique identifier for the tariff version record. Primary key for the tariff version entity.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupersededByVersionId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Version Id' ;
    rdfs:comment 'Reference to the tariff version that replaced this version. Enables forward navigation through version history and supports audit trail reconstruction.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Primary category of change represented by this version. Enables classification and analysis of tariff evolution patterns.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationEndDate rdf:type rdf:Property ;
    rdfs:label 'Consultation End Date' ;
    rdfs:comment 'Date when the public consultation period closed for this tariff version. Null if no consultation was required.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consultationStartDate rdf:type rdf:Property ;
    rdfs:label 'Consultation Start Date' ;
    rdfs:comment 'Date when the public consultation period began for this tariff version. Null if no consultation was required.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:draftDate rdf:type rdf:Property ;
    rdfs:label 'Draft Date' ;
    rdfs:comment 'Date when this tariff version was initially drafted and entered into the version control system.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveTime rdf:type rdf:Property ;
    rdfs:label 'Effective Time' ;
    rdfs:comment 'Precise timestamp when this tariff version becomes effective. Used when tariff changes must take effect at a specific time (e.g., midnight UTC, start of business day).' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impactAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Completed' ;
    rdfs:comment 'Indicates whether a formal business impact assessment was conducted for this tariff version. True for major changes requiring financial and operational impact analysis.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed' ;
    rdfs:comment 'Indicates whether this tariff version underwent formal legal review for compliance with maritime law, competition law, and contractual obligations.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicConsultationRequired rdf:type rdf:Property ;
    rdfs:label 'Public Consultation Required' ;
    rdfs:comment 'Indicates whether this tariff version required a public consultation period before approval. True for major tariff changes affecting broad stakeholder groups.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date when this tariff version was formally filed with the regulatory authority. Required for compliance tracking when regulatory_filing_required is true.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this tariff version required formal filing with a regulatory authority. True for versions subject to government oversight, false for internal commercial adjustments.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retroactiveBillingAllowed rdf:type rdf:Property ;
    rdfs:label 'Retroactive Billing Allowed' ;
    rdfs:comment 'Indicates whether this tariff version permits retroactive billing corrections for transactions that occurred before the effective date. Critical for billing system processing rules.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retroactivePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retroactive Period Days' ;
    rdfs:comment 'Maximum number of days prior to the effective date for which retroactive billing adjustments are permitted. Null if retroactive billing is not allowed.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'Actual date when this tariff version was replaced by a subsequent version. May differ from planned expiry_date if emergency changes were implemented.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionName rdf:type rdf:Property ;
    rdfs:label 'Version Name' ;
    rdfs:comment 'Descriptive name or title for this tariff version (e.g., \'Q1 2024 Rate Adjustment\', \'Annual Tariff Update 2024\', \'Emergency Fuel Surcharge Amendment\').' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the version change type. Distinguishes between initial publication, routine amendments, major revisions, emergency adjustments, regulatory-mandated changes, and annual updates.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesScheduleThcScheduleId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Schedule Thc Schedule Id' ;
    rdfs:comment 'Reference to the previous THC schedule ID that this schedule replaces or supersedes. Null if this is the initial version.' ;
    rdfs:domain ind:ThcSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThcSchedule .

ind:cargoCategory rdf:type rdf:Property ;
    rdfs:label 'Cargo Category' ;
    rdfs:comment 'Category of cargo handled. FCL (Full Container Load), LCL (Less than Container Load), RoRo (Roll-on Roll-off), LoLo (Lift-on Lift-off), breakbulk, or bulk cargo.' ;
    rdfs:domain ind:ThcSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date when this THC schedule was filed with the regulatory authority. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ThcSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oversizeSurcharge rdf:type rdf:Property ;
    rdfs:label 'Oversize Surcharge' ;
    rdfs:comment 'Additional surcharge for handling out-of-gauge (OOG) or oversize containers that require special handling equipment or procedures. Zero if not applicable.' ;
    rdfs:domain ind:ThcSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedFlag rdf:type rdf:Property ;
    rdfs:label 'Published Flag' ;
    rdfs:comment 'Indicates whether this THC schedule has been published to customers and external systems. True if published, False if internal-only.' ;
    rdfs:domain ind:ThcSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reeferSurcharge rdf:type rdf:Property ;
    rdfs:label 'Reefer Surcharge' ;
    rdfs:comment 'Additional surcharge amount for handling refrigerated (reefer) containers requiring power and temperature monitoring. Zero if not applicable.' ;
    rdfs:domain ind:ThcSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Service level tier associated with this THC rate. Different service levels may have different handling priorities and rates.' ;
    rdfs:domain ind:ThcSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTariffTowageTariffId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tariff Towage Tariff Id' ;
    rdfs:comment 'Reference to the towage tariff record that replaces this tariff when it expires or is superseded by a new version.' ;
    rdfs:domain ind:TowageTariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TowageTariff .

ind:baseTowageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Towage Fee Amount' ;
    rdfs:comment 'Base charge amount for the towage operation before any adjustments, surcharges, or time-based premiums.' ;
    rdfs:domain ind:TowageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationNoticePeriodHours rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notice Period Hours' ;
    rdfs:comment 'Minimum number of hours advance notice required to cancel a towage booking without incurring the cancellation fee.' ;
    rdfs:domain ind:TowageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extraordinaryConditionsSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Extraordinary Conditions Surcharge Pct' ;
    rdfs:comment 'Percentage surcharge applied to the base towage fee for operations conducted under extraordinary conditions such as severe weather, restricted visibility, or emergency response.' ;
    rdfs:domain ind:TowageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeStandbyTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Free Standby Time Minutes' ;
    rdfs:comment 'Number of minutes of tug standby time included in the base towage fee before standby charges apply.' ;
    rdfs:domain ind:TowageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfTugsRequired rdf:type rdf:Property ;
    rdfs:label 'Number Of Tugs Required' ;
    rdfs:comment 'Standard number of tug vessels required for the towage operation under this tariff, based on vessel size and port conditions.' ;
    rdfs:domain ind:TowageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standbyTimeRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Standby Time Rate Per Hour' ;
    rdfs:comment 'Hourly rate charged when tugs are on standby awaiting vessel readiness or operational clearance beyond the included free standby time.' ;
    rdfs:domain ind:TowageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tugBollardPullMinTonnes rdf:type rdf:Property ;
    rdfs:label 'Tug Bollard Pull Min Tonnes' ;
    rdfs:comment 'Minimum bollard pull capacity in tonnes required for tugs performing this towage operation. Bollard pull is the pulling force a tug can exert.' ;
    rdfs:domain ind:TowageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Vessel Type Category' ;
    rdfs:comment 'Category of vessel to which this towage tariff applies (e.g., container, bulk carrier, tanker, RoRo, cruise, general cargo). Null indicates applicability to all vessel types.' ;
    rdfs:domain ind:TowageTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByScheduleWharfageScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Wharfage Schedule Id' ;
    rdfs:comment 'Reference to the wharfage_schedule_id that supersedes this tariff entry. Populated when a new version replaces this schedule.' ;
    rdfs:domain ind:WharfageSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WharfageSchedule .

ind:exemptionCondition rdf:type rdf:Property ;
    rdfs:label 'Exemption Condition' ;
    rdfs:comment 'Description of conditions under which wharfage charges are exempted (e.g., transshipment cargo not leaving port, government cargo, humanitarian aid, military cargo). Populated only when exemption_flag is True.' ;
    rdfs:domain ind:WharfageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Per Unit' ;
    rdfs:comment 'Wharfage charge rate per unit of measure. Base rate before any adjustments, surcharges, or discounts.' ;
    rdfs:domain ind:WharfageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refrigeratedCargoFlag rdf:type rdf:Property ;
    rdfs:label 'Refrigerated Cargo Flag' ;
    rdfs:comment 'Indicates whether this wharfage rate applies to refrigerated (reefer) cargo requiring temperature-controlled handling.' ;
    rdfs:domain ind:WharfageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeBreakLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Volume Break Lower Limit' ;
    rdfs:comment 'Lower volume threshold (in CBM - Cubic Meters) for tiered wharfage pricing. Cargo volume at or above this limit qualifies for this rate tier.' ;
    rdfs:domain ind:WharfageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeBreakUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Volume Break Upper Limit' ;
    rdfs:comment 'Upper volume threshold (in CBM - Cubic Meters) for tiered wharfage pricing. Cargo volume below this limit qualifies for this rate tier. Null indicates no upper limit.' ;
    rdfs:domain ind:WharfageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Weight Break Lower Limit' ;
    rdfs:comment 'Lower weight threshold (in tonnes) for tiered wharfage pricing. Cargo weight at or above this limit qualifies for this rate tier.' ;
    rdfs:domain ind:WharfageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Weight Break Upper Limit' ;
    rdfs:comment 'Upper weight threshold (in tonnes) for tiered wharfage pricing. Cargo weight below this limit qualifies for this rate tier. Null indicates no upper limit.' ;
    rdfs:domain ind:WharfageSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialAgreementId rdf:type rdf:Property ;
    rdfs:label 'Commercial Agreement Id' ;
    rdfs:comment 'Reference to the commercial agreement or contract governing the terms of this berth allocation. Links to contract domain for tariff and SLA details.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'Reference to the system user who created this berth allocation record. Links to workforce domain for audit trail.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the system user who last modified this berth allocation record. Links to workforce domain for audit trail.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedCraneCount rdf:type rdf:Property ;
    rdfs:label 'Allocated Crane Count' ;
    rdfs:comment 'Number of Ship-to-Shore (STS) cranes or Quay Cranes (QC) allocated for cargo operations during this berth allocation. Impacts vessel turnaround time and terminal productivity.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedQuayLengthM rdf:type rdf:Property ;
    rdfs:label 'Allocated Quay Length M' ;
    rdfs:comment 'Length of quay allocated for this vessel in meters. Must accommodate vessel Length Overall (LOA) plus safety margins.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes and comments related to this berth allocation. May include operational instructions, coordination details, or special circumstances.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationReason rdf:type rdf:Property ;
    rdfs:label 'Allocation Reason' ;
    rdfs:comment 'Business reason or justification for this specific berth allocation. May include service requirements, vessel preferences, operational constraints, or commercial agreements.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthDraftRestrictionM rdf:type rdf:Property ;
    rdfs:label 'Berth Draft Restriction M' ;
    rdfs:comment 'Maximum allowable draft at the allocated berth in meters. Vessel draft must not exceed this value for safe berthing operations.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:berthProductivityTargetMph rdf:type rdf:Property ;
    rdfs:label 'Berth Productivity Target Mph' ;
    rdfs:comment 'Target container handling productivity in moves per hour for this berth allocation. Used for performance monitoring and SLA compliance.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:berthWindowDurationHours rdf:type rdf:Property ;
    rdfs:label 'Berth Window Duration Hours' ;
    rdfs:comment 'Planned duration of the berth window in hours. Calculated from berth window start and end times. Used for berth utilization KPIs.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:berthWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Berth Window End' ;
    rdfs:comment 'End of the allocated berth window. Defines the latest time the berth is reserved for this vessel before it must be released.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:berthWindowStart rdf:type rdf:Property ;
    rdfs:label 'Berth Window Start' ;
    rdfs:comment 'Start of the allocated berth window. Defines the earliest time the berth is reserved for this vessel.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cargoOperationType rdf:type rdf:Property ;
    rdfs:label 'Cargo Operation Type' ;
    rdfs:comment 'Type of cargo operations planned for this berth allocation. LoLo: Lift-on Lift-off (container); RoRo: Roll-on Roll-off (vehicles); Mixed: combination; Bulk: bulk cargo; General: general cargo.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craneAllocationType rdf:type rdf:Property ;
    rdfs:label 'Crane Allocation Type' ;
    rdfs:comment 'Type of cranes allocated for this berth. STS: Ship-to-Shore crane; QC: Quay Crane; MHC: Mobile Harbour Crane; Mixed: combination of crane types.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgCargoFlag rdf:type rdf:Property ;
    rdfs:label 'Imdg Cargo Flag' ;
    rdfs:comment 'Indicates whether this berth allocation involves dangerous goods cargo requiring IMDG compliance. True if dangerous goods are present; False otherwise.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tideWindowRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tide Window Required Flag' ;
    rdfs:comment 'Indicates whether this berth allocation is constrained by tidal conditions. True if vessel can only berth during specific tide windows; False if tide-independent.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vesselDraftM rdf:type rdf:Property ;
    rdfs:label 'Vessel Draft M' ;
    rdfs:comment 'Maximum draft of the vessel in meters. Must be validated against berth depth restrictions to ensure safe berthing.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselLoaM rdf:type rdf:Property ;
    rdfs:label 'Vessel Loa M' ;
    rdfs:comment 'Length Overall of the vessel in meters. Used to validate berth allocation suitability and quay length requirements.' ;
    rdfs:domain ind:TerminalBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cfsActivityId rdf:type rdf:Property ;
    rdfs:label 'Cfs Activity Id' ;
    rdfs:comment 'Unique identifier for the CFS activity record. Primary key for the CFS activity transaction.' ;
    rdfs:domain ind:CfsActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerVisitId rdf:type rdf:Property ;
    rdfs:label 'Container Visit Id' ;
    rdfs:comment 'Foreign key linking to terminal.container_visit. Business justification: CFS (Container Freight Station) activities such as stuffing and stripping are performed on containers during their terminal visit. The cfs_activity table has container_number (STRING) but no FK to con' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerVisit .

ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: CFS stuffing/stripping operations require tracking which employee performed the work for productivity measurement (packages per hour), quality accountability (damage claims), and labor billing to cust' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCfsOperatorPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Primary Cfs Operator Port Community Participant Id' ;
    rdfs:comment 'Reference to the workforce member or team responsible for performing the CFS activity. Used for productivity tracking and accountability.' ;
    rdfs:domain ind:CfsActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:tertiaryCfsConsigneePortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Cfs Consignee Port Community Participant Id' ;
    rdfs:comment 'Reference to the consignee party receiving the cargo. Links to the customer or participant account.' ;
    rdfs:domain ind:CfsActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the CFS activity. Tracks the operational state from scheduling through completion.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cfsJobNumber rdf:type rdf:Property ;
    rdfs:label 'Cfs Job Number' ;
    rdfs:comment 'Business identifier for the CFS job. Externally-known reference number used for tracking and billing purposes.' ;
    rdfs:domain ind:CfsActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cfsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Cfs Location Code' ;
    rdfs:comment 'Code identifying the specific CFS facility or zone where the activity is performed. Used for operational planning and resource allocation.' ;
    rdfs:domain ind:CfsActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Reported Flag' ;
    rdfs:comment 'Indicates whether cargo or container damage was reported during the CFS activity. True if damage was observed and documented.' ;
    rdfs:domain ind:CfsActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handlingChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Handling Charge Amount' ;
    rdfs:comment 'Base charge amount for the CFS handling service. Excludes taxes and additional fees. Used for billing and revenue recognition.' ;
    rdfs:domain ind:CfsActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the container seal was found intact upon arrival at CFS. True if seal was unbroken, false if tampered or missing.' ;
    rdfs:domain ind:CfsActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Celsius' ;
    rdfs:comment 'Required temperature setting in degrees Celsius for temperature-controlled cargo. Used for reefer container configuration and monitoring.' ;
    rdfs:domain ind:CfsActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether the cargo requires temperature-controlled handling. True for refrigerated or temperature-sensitive cargo.' ;
    rdfs:domain ind:CfsActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerDamageId rdf:type rdf:Property ;
    rdfs:label 'Container Damage Id' ;
    rdfs:comment 'Unique identifier for the container damage record. Primary key for the container damage assessment entity.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContainerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Container Employee Id' ;
    rdfs:comment 'Reference to the system user who created the initial damage record. Supports audit trail and accountability for data quality.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryContainerOwnerPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Primary Container Owner Port Community Participant Id' ;
    rdfs:comment 'Reference to the legal owner of the container (may be shipping line, leasing company, or container pool). Critical for determining who must be notified and who will receive repair payment.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:repairVendorId rdf:type rdf:Property ;
    rdfs:label 'Repair Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Container repairs are outsourced to specialized repair vendors. Damage reports must track which vendor performed repairs for cost recovery, quality assessment, vendor performance evaluation, and liabi' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualRepairCost rdf:type rdf:Property ;
    rdfs:label 'Actual Repair Cost' ;
    rdfs:comment 'Final invoiced cost of repairs completed. Used for variance analysis against estimate, billing to liable party, and financial reporting. Amount in terminal base currency.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoDamageIndicator rdf:type rdf:Property ;
    rdfs:label 'Cargo Damage Indicator' ;
    rdfs:comment 'Flag indicating whether the container damage also resulted in damage to the cargo inside. Triggers separate cargo damage assessment and claims processes.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cargoStatusAtDiscovery rdf:type rdf:Property ;
    rdfs:label 'Cargo Status At Discovery' ;
    rdfs:comment 'Whether the container was empty or laden (loaded with cargo) when the damage was discovered. Impacts liability assessment and urgency of repair or cargo transfer.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Damage Location Code' ;
    rdfs:comment 'Standardized code identifying the specific location on the container where damage occurred. Uses IICL location coding system for precise damage mapping and repair specification.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageReportNumber rdf:type rdf:Property ;
    rdfs:label 'Damage Report Number' ;
    rdfs:comment 'Unique business identifier for the damage report used for external communication with shipping lines, P&I clubs, and surveyors. Format: DMG-YYYYMMDD sequence.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageReportStatus rdf:type rdf:Property ;
    rdfs:label 'Damage Report Status' ;
    rdfs:comment 'Current lifecycle status of the damage report. Tracks progression from initial discovery through survey, liability determination, claims processing, and final resolution. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|disputed|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageSeverity rdf:type rdf:Property ;
    rdfs:label 'Damage Severity' ;
    rdfs:comment 'Assessment of the severity level of the damage based on repair cost, structural integrity impact, and container serviceability. Used for prioritization and liability determination.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryLocation rdf:type rdf:Property ;
    rdfs:label 'Discovery Location' ;
    rdfs:comment 'The specific physical location within the terminal where the damage was discovered, such as gate lane number, yard block and row, or berth position. Supports incident investigation and operational analysis.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryPoint rdf:type rdf:Property ;
    rdfs:label 'Discovery Point' ;
    rdfs:comment 'The operational checkpoint or activity during which the damage was first discovered. Critical for establishing liability and determining whether damage occurred on-terminal or pre-existing. [ENUM-REF-CANDIDATE: gate_in|gate_out|discharge|loading|yard_inspection|vessel_inspection|delivery|receiving — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'The date and time when the container damage was first identified and recorded. Used for liability determination and claims processing timelines.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Flag' ;
    rdfs:comment 'Flag indicating whether the container damage resulted in an environmental incident such as spill, leak, or release of hazardous materials. Triggers regulatory reporting and remediation protocols.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityParty rdf:type rdf:Property ;
    rdfs:label 'Liability Party' ;
    rdfs:comment 'Determination of which party is responsible for the damage based on discovery point, handling records, and investigation findings. Critical for claims processing and cost recovery.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Repair Authorization Number' ;
    rdfs:comment 'Authorization number provided by the container owner or shipping line approving repair work. Required before terminal or depot can proceed with repairs and invoice for costs.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Repair Completion Date' ;
    rdfs:comment 'Date on which container repairs were completed and container returned to serviceable condition. Used for tracking repair turnaround time and container availability.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repairCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Repair Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated repair cost. Supports multi-currency operations and financial reporting.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairRecommendation rdf:type rdf:Property ;
    rdfs:label 'Repair Recommendation' ;
    rdfs:comment 'Surveyor recommendation on the appropriate action to take regarding the damaged container. Guides operational decisions on container disposition and repair authorization.' ;
    rdfs:domain ind:ContainerDamage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardSlotId rdf:type rdf:Property ;
    rdfs:label 'Yard Slot Id' ;
    rdfs:comment 'Foreign key linking to terminal.yard_slot. Business justification: container_visit has current_yard_location (STRING) and yard_block (STRING) which are denormalized representations of the container\'s current position. Should FK to yard_slot for authoritative location' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:YardSlot .

ind:arrivalMode rdf:type rdf:Property ;
    rdfs:label 'Arrival Mode' ;
    rdfs:comment 'Transportation mode by which the container arrived at the terminal. Determines gate processing, yard allocation, and intermodal handling requirements.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Flag' ;
    rdfs:comment 'Indicates whether the container has reported damage. Triggers inspection workflow and potential repair work orders.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demurrageStartDate rdf:type rdf:Property ;
    rdfs:label 'Demurrage Start Date' ;
    rdfs:comment 'Date when demurrage charges begin to accrue for this container visit. Calculated as arrival date plus free time days.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:departureMode rdf:type rdf:Property ;
    rdfs:label 'Departure Mode' ;
    rdfs:comment 'Planned or actual transportation mode for container departure from the terminal. Null until departure is scheduled or executed.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeHours rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Hours' ;
    rdfs:comment 'Total time in hours that the container has remained in the terminal from arrival to current moment (or to departure if departed). Key performance indicator for terminal efficiency and customer service.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fullEmptyIndicator rdf:type rdf:Property ;
    rdfs:label 'Full Empty Indicator' ;
    rdfs:comment 'Indicates whether the container is loaded with cargo (full) or empty. Critical for weight calculations, handling procedures, and billing.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferHumiditySetpointPct rdf:type rdf:Property ;
    rdfs:label 'Reefer Humidity Setpoint Pct' ;
    rdfs:comment 'Target relative humidity setting for refrigerated container as percentage. Required for certain cargo types (e.g., fresh produce) to prevent spoilage.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reeferTemperatureSetpointC rdf:type rdf:Property ;
    rdfs:label 'Reefer Temperature Setpoint C' ;
    rdfs:comment 'Target temperature setting for refrigerated container in degrees Celsius. Critical for cargo preservation; monitored continuously by terminal reefer management system.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reeferVentilationSetting rdf:type rdf:Property ;
    rdfs:label 'Reefer Ventilation Setting' ;
    rdfs:comment 'Ventilation configuration for reefer container (e.g., closed, 10 CBM/hr, 20 CBM/hr). Controls fresh air exchange rate for perishable cargo.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumber1 rdf:type rdf:Property ;
    rdfs:label 'Seal Number 1' ;
    rdfs:comment 'Primary security seal number affixed to the container door. Used for customs verification and cargo security tracking per ISPS Code requirements.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumber2 rdf:type rdf:Property ;
    rdfs:label 'Seal Number 2' ;
    rdfs:comment 'Secondary or customs seal number if multiple seals are applied. Common for high-security shipments or specific customs requirements.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teuFactor rdf:type rdf:Property ;
    rdfs:label 'Teu Factor' ;
    rdfs:comment 'TEU conversion factor for the container. Standard values: 1.0 for 20ft containers, 2.0 for 40ft containers, 2.25 for 45ft containers. Used for capacity planning and billing calculations.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tosReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Tos Reference Code' ;
    rdfs:comment 'Native identifier for this container visit in the source Terminal Operating System (NAVIS N4 or TOPS Expert). Used for system integration and audit trail.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselDischargeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Vessel Discharge Timestamp' ;
    rdfs:comment 'Date and time when the container was discharged from the vessel onto the terminal. Applicable for vessel arrival mode; marks start of terminal custody for vessel-delivered containers.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vesselLoadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Vessel Load Timestamp' ;
    rdfs:comment 'Date and time when the container was loaded onto the vessel from the terminal. Applicable for vessel departure mode; marks end of terminal custody for vessel-bound containers.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vgmWeightKg rdf:type rdf:Property ;
    rdfs:label 'Vgm Weight Kg' ;
    rdfs:comment 'Verified Gross Mass of the packed container in kilograms, as required by SOLAS regulation VI/2. Mandatory for all full export containers before vessel loading.' ;
    rdfs:domain ind:ContainerVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentDispatchId rdf:type rdf:Property ;
    rdfs:label 'Equipment Dispatch Id' ;
    rdfs:comment 'Unique identifier for the equipment dispatch work instruction record. Primary key.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEquipmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Equipment Employee Id' ;
    rdfs:comment 'Unique identifier of the equipment operator assigned to execute this work instruction. Format: OP followed by six digits. Null for automated equipment (AGV, ASC).' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cargoReference rdf:type rdf:Property ;
    rdfs:label 'Cargo Reference' ;
    rdfs:comment 'General cargo identifier for non-containerized cargo (breakbulk, RoRo units, project cargo). Used when container_number is null.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchSource rdf:type rdf:Property ;
    rdfs:label 'Dispatch Source' ;
    rdfs:comment 'Origin of the dispatch instruction: TOS_auto_dispatch (system-generated by NAVIS N4 or TOPS Expert auto-dispatch algorithm), manual_planner_override (planner manual assignment), operator_request (operator-initiated), emergency_dispatch (urgent safety or operational requirement).' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'Date and time when the work instruction was dispatched to the equipment operator or automated system. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossCraneTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Gross Crane Time Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from crane hook engagement to hook release, including all delays. Used for STS/QC productivity analysis. Null for non-crane operations.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hatchPosition rdf:type rdf:Property ;
    rdfs:label 'Hatch Position' ;
    rdfs:comment 'Vessel hatch identifier for STS/QC crane operations (e.g., H01, H12). Format: H followed by two-digit hatch number. Null for non-vessel operations.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Idle Time Seconds' ;
    rdfs:comment 'Non-productive idle time in seconds during the dispatch operation due to delays, waiting, or interruptions. Calculated as gross_crane_time_seconds minus net_crane_time_seconds for crane operations.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netCraneTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Net Crane Time Seconds' ;
    rdfs:comment 'Productive crane time in seconds excluding idle time, delays, and interruptions. Used to calculate net crane productivity. Null for non-crane operations.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productiveFlag rdf:type rdf:Property ;
    rdfs:label 'Productive Flag' ;
    rdfs:comment 'Indicates whether this dispatch represents a productive move (True) or non-productive move (False). Productive moves directly contribute to vessel or customer operations; non-productive moves are internal yard housekeeping or rehandles.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehandleFlag rdf:type rdf:Property ;
    rdfs:label 'Rehandle Flag' ;
    rdfs:comment 'Indicates whether this dispatch is a rehandle operation (True) - moving a container to access another container - or a direct move (False). Rehandles negatively impact terminal productivity metrics.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehandleReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rehandle Reason Code' ;
    rdfs:comment 'Reason code for rehandle operations: access_obstruction (blocking container), weight_segregation (stacking by weight class), hazmat_compliance (IMDG segregation), reefer_relocation (reefer plug availability), vessel_premarshal (pre-stow optimization), damage_inspection (damage assessment access), customs_hold (regulatory inspection). Null for non-rehandle moves. [ENUM-REF-CANDIDATE: access_obstruction|weight_segregation|hazmat_compliance|reefer_relocation|vessel_premarshal|damage_inspection|customs_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spreaderType rdf:type rdf:Property ;
    rdfs:label 'Spreader Type' ;
    rdfs:comment 'Type of crane spreader attachment used for this lift: standard_20ft (fixed 20-foot), standard_40ft (fixed 40-foot), telescopic (adjustable 20-40 foot), twin_20ft (dual 20-foot), tandem_40ft (dual 40-foot for heavy lifts), breakbulk_hook (non-container cargo). Applicable to crane operations.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tandemLiftFlag rdf:type rdf:Property ;
    rdfs:label 'Tandem Lift Flag' ;
    rdfs:comment 'Indicates whether this operation uses tandem-lift (True) - two cranes working together on a single heavy lift - or single crane (False). Used for oversized or heavy project cargo.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:twinLiftFlag rdf:type rdf:Property ;
    rdfs:label 'Twin Lift Flag' ;
    rdfs:comment 'Indicates whether this crane operation is a twin-lift (True) - lifting two 20-foot containers simultaneously - or single lift (False). Applicable only to STS/QC crane operations.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workInstructionNumber rdf:type rdf:Property ;
    rdfs:label 'Work Instruction Number' ;
    rdfs:comment 'Externally-known unique business identifier for the dispatch work instruction, formatted as WI- followed by 10 digits. Used for tracking and reference across TOS systems.' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workInstructionType rdf:type rdf:Property ;
    rdfs:label 'Work Instruction Type' ;
    rdfs:comment 'Type of equipment operation being dispatched: lift (vertical movement), move (horizontal transfer), load (vessel loading), discharge (vessel unloading), shift (yard repositioning), restow (vessel re-stowage), rehandle (access movement), reshuffle (yard optimization). [ENUM-REF-CANDIDATE: lift|move|load|discharge|shift|restow|rehandle|reshuffle — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Gate Appointment Id' ;
    rdfs:comment 'Primary key for gate_appointment' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateLaneId rdf:type rdf:Property ;
    rdfs:label 'Gate Lane Id' ;
    rdfs:comment 'Foreign key linking to terminal.gate_lane. Business justification: Gate appointments are scheduled for specific gate lanes. The gate_appointment table currently has gate_lane_number (STRING) but no FK relationship. Adding gate_lane_id FK enables proper referential in' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GateLane .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Externally-known unique business identifier for the gate appointment, used for tracking and reference by hauliers and terminal operators.' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Appointment Window End' ;
    rdfs:comment 'End timestamp of the scheduled appointment time slot window, defining the latest acceptable arrival time for the appointment.' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentWindowStart rdf:type rdf:Property ;
    rdfs:label 'Appointment Window Start' ;
    rdfs:comment 'Start timestamp of the scheduled appointment time slot window during which the truck is expected to arrive at the gate.' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:haulierCode rdf:type rdf:Property ;
    rdfs:label 'Haulier Code' ;
    rdfs:comment 'Unique code identifying the transport operator or haulage company responsible for the container movement.' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulierName rdf:type rdf:Property ;
    rdfs:label 'Haulier Name' ;
    rdfs:comment 'Business name of the transport operator or haulage company performing the gate transaction.' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Flag indicating whether the container has been selected for physical inspection by customs, port state control, or security authorities.' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to process the gate transaction from arrival to departure, used for KPI measurement.' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truckDriverLicense rdf:type rdf:Property ;
    rdfs:label 'Truck Driver License' ;
    rdfs:comment 'Driver license number of the truck driver, captured for security and compliance purposes.' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:truckDriverName rdf:type rdf:Property ;
    rdfs:label 'Truck Driver Name' ;
    rdfs:comment 'Full name of the truck driver presenting at the gate for the appointment.' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:truckRegistration rdf:type rdf:Property ;
    rdfs:label 'Truck Registration' ;
    rdfs:comment 'Vehicle registration plate number of the truck making the gate appointment, used for access control and tracking.' ;
    rdfs:domain ind:GateAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityScreeningRecordId rdf:type rdf:Property ;
    rdfs:label 'Security Screening Record Id' ;
    rdfs:comment 'Foreign key linking to security.screening_record. Business justification: Every gate transaction requires security screening (document verification, watchlist check, prohibited item detection) per ISPS Code. Links transaction to screening outcome for audit trail, compliance' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScreeningRecord .

ind:terminalGateAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Terminal Gate Appointment Id' ;
    rdfs:comment 'Foreign key linking to terminal.gate_appointment. Business justification: Gate transactions often fulfill pre-booked appointments. The gate_transaction has appointment_reference (STRING) which should be normalized to FK to gate_appointment. Business reality: a gate transact' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GateAppointment .

ind:anprCaptureReference rdf:type rdf:Property ;
    rdfs:label 'Anpr Capture Reference' ;
    rdfs:comment 'Reference identifier to the ANPR (Automatic Number Plate Recognition) system capture of vehicle license plates for automated gate processing.' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coparnReference rdf:type rdf:Property ;
    rdfs:label 'Coparn Reference' ;
    rdfs:comment 'Reference to the COPARN EDI message (Container Pre-Announcement) sent prior to gate arrival for pre-clearance and planning.' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateClerkOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Gate Clerk Override Flag' ;
    rdfs:comment 'Boolean indicator whether the gate clerk manually overrode automated gate processing rules or validations.' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ocrCaptureReference rdf:type rdf:Property ;
    rdfs:label 'Ocr Capture Reference' ;
    rdfs:comment 'Reference identifier to the OCR (Optical Character Recognition) system capture of container number, license plates, and other visual data at gate.' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Seconds' ;
    rdfs:comment 'Total time in seconds taken to process the gate transaction from entry to exit, used for gate performance KPI measurement.' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reeferTemperatureActualC rdf:type rdf:Property ;
    rdfs:label 'Reefer Temperature Actual C' ;
    rdfs:comment 'Actual temperature reading in Celsius from the reefer container monitoring system at gate transaction time.' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rpmScanResult rdf:type rdf:Property ;
    rdfs:label 'Rpm Scan Result' ;
    rdfs:comment 'Result of the RPM (Radiation Portal Monitor) scan performed at gate entry for security screening and detection of radioactive materials.' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerLicensePlate rdf:type rdf:Property ;
    rdfs:label 'Trailer License Plate' ;
    rdfs:comment 'Vehicle registration number of the trailer or chassis unit, if separate from the tractor unit.' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Precise date and time when the container or vehicle movement through the gate occurred, representing the primary business event time.' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weightBridgeReadingKg rdf:type rdf:Property ;
    rdfs:label 'Weight Bridge Reading Kg' ;
    rdfs:comment 'Gross weight of the container and vehicle measured at the terminal weight bridge in kilograms, used for safety compliance and billing verification.' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yardLocationAssignment rdf:type rdf:Property ;
    rdfs:label 'Yard Location Assignment' ;
    rdfs:comment 'Assigned yard location (block, row, tier) where the container will be or was stacked in the Container Yard (CY).' ;
    rdfs:domain ind:GateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Declaration Id' ;
    rdfs:comment 'Unique identifier for the hazardous material declaration record. Primary key for the hazmat_declaration product.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifyingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certifying Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: IMDG Code requires a competent person to certify dangerous goods declarations. Tracking the certifying employee is mandatory for regulatory compliance, audit trails, and competency verification (emplo' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptanceDecisionBy rdf:type rdf:Property ;
    rdfs:label 'Acceptance Decision By' ;
    rdfs:comment 'The name or user ID of the terminal hazmat officer or supervisor who made the acceptance decision. Used for audit trail and accountability.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Decision Timestamp' ;
    rdfs:comment 'The date and time when the terminal made the acceptance decision (accepted, rejected, or conditional). Null if status is still pending.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:competentAuthorityApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Competent Authority Approval Reference' ;
    rdfs:comment 'The approval reference number issued by the competent authority for dangerous goods requiring special authorization (e.g., Class 1 explosives, Class 7 radioactive materials). Null if no approval required.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competentAuthorityNotificationReference rdf:type rdf:Property ;
    rdfs:label 'Competent Authority Notification Reference' ;
    rdfs:comment 'The reference number of the notification sent to the competent authority (port state control, customs, or environmental agency) for high-risk dangerous goods. Required for certain IMDG classes per local regulations.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgdDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Dgd Document Reference' ;
    rdfs:comment 'The unique reference number of the Dangerous Goods Declaration document submitted by the shipper. Links to the electronic or paper DGD in the Port Community System (PCS).' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgdSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dgd Submission Timestamp' ;
    rdfs:comment 'The date and time when the Dangerous Goods Declaration was submitted to the terminal via EDI, PCS, or manual upload. Used for compliance verification and SLA tracking.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flashpointCelsius rdf:type rdf:Property ;
    rdfs:label 'Flashpoint Celsius' ;
    rdfs:comment 'The flashpoint temperature in degrees Celsius for flammable liquids (IMDG Class 3). Critical for fire risk assessment and segregation planning. Null for non-flammable goods.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mfagTableNumber rdf:type rdf:Property ;
    rdfs:label 'Mfag Table Number' ;
    rdfs:comment 'The IMDG Code Medical First Aid Guide table number providing first aid instructions for exposure to the dangerous goods. Used by terminal medical and safety personnel.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Net Quantity Unit' ;
    rdfs:comment 'The unit of measure for the net quantity: kilograms (kg), liters (L), or cubic meters (m3). Must align with IMDG Code reporting requirements.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placardingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Placarding Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether IMDG placards and labels must be affixed to the container. True for most dangerous goods; false for limited/excepted quantities.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segregationDistanceMeters rdf:type rdf:Property ;
    rdfs:label 'Segregation Distance Meters' ;
    rdfs:comment 'The minimum required horizontal separation distance in meters from incompatible dangerous goods, calculated per IMDG Code Chapter 7.2. Enforced by the TOS yard planning module.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialStowageInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Stowage Instructions' ;
    rdfs:comment 'Free-text field capturing any special stowage, handling, or segregation instructions from the shipper or competent authority. May include ventilation requirements, temperature controls, or away-from restrictions.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Terminal Acceptance Status' ;
    rdfs:comment 'The current status of the hazmat declaration in the terminal acceptance workflow. Pending: under review; Accepted: approved for handling; Rejected: not accepted; Conditional: accepted with restrictions; Withdrawn: declaration cancelled by shipper.' ;
    rdfs:domain ind:HazmatDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Reefer Monitoring Id' ;
    rdfs:comment 'Primary key for reefer_monitoring' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTemperature rdf:type rdf:Property ;
    rdfs:label 'Actual Temperature' ;
    rdfs:comment 'The measured actual temperature inside the reefer container at the time of monitoring in degrees Celsius. Critical for cold chain integrity verification.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Flag' ;
    rdfs:comment 'Boolean indicator whether an alarm condition was triggered during this monitoring event. True indicates an alarm was raised, False indicates normal operation.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alarmSeverity rdf:type rdf:Property ;
    rdfs:label 'Alarm Severity' ;
    rdfs:comment 'The severity level of the alarm condition. Critical requires immediate action, high requires urgent attention, medium requires scheduled intervention, low is informational.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2Level rdf:type rdf:Property ;
    rdfs:label 'Co2 Level' ;
    rdfs:comment 'The carbon dioxide concentration measured inside the reefer container in percentage. Critical for controlled atmosphere cargo such as fruits and vegetables.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliance Flag' ;
    rdfs:comment 'Boolean indicator whether this monitoring event confirms cold chain integrity compliance. True indicates temperature and conditions within acceptable range, False indicates breach of cold chain requirements.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compressorRuntimeHours rdf:type rdf:Property ;
    rdfs:label 'Compressor Runtime Hours' ;
    rdfs:comment 'The cumulative operating hours of the refrigeration compressor since last reset. Used for maintenance scheduling and equipment lifecycle management.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compressorStatus rdf:type rdf:Property ;
    rdfs:label 'Compressor Status' ;
    rdfs:comment 'The operational status of the refrigeration compressor unit. Running indicates active cooling, stopped indicates unit off, standby indicates ready but not cooling, fault indicates malfunction.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defrostCycleStatus rdf:type rdf:Property ;
    rdfs:label 'Defrost Cycle Status' ;
    rdfs:comment 'The status of the automatic defrost cycle for the refrigeration unit. Active indicates defrost in progress, inactive indicates normal cooling mode, scheduled indicates defrost pending.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doorStatus rdf:type rdf:Property ;
    rdfs:label 'Door Status' ;
    rdfs:comment 'The physical status of the reefer container door. Closed indicates door shut but not sealed, open indicates door ajar or open, sealed indicates door closed with customs or security seal intact.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityReading rdf:type rdf:Property ;
    rdfs:label 'Humidity Reading' ;
    rdfs:comment 'The relative humidity percentage measured inside the reefer container. Important for cargo types sensitive to moisture levels such as fresh produce.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringSource rdf:type rdf:Property ;
    rdfs:label 'Monitoring Source' ;
    rdfs:comment 'The method or system that captured this monitoring reading. Automated sensor indicates TOS integration, manual inspection indicates technician reading, remote telemetry indicates IoT device, RFID reader indicates tag-based monitoring.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Status' ;
    rdfs:comment 'The current lifecycle status of this monitoring event. Active indicates ongoing monitoring, resolved indicates issue closed, escalated indicates elevated to management, pending review indicates awaiting technician assessment.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringTimestamp rdf:type rdf:Property ;
    rdfs:label 'Monitoring Timestamp' ;
    rdfs:comment 'The date and time when the reefer container monitoring reading was captured. Principal business event timestamp for this monitoring transaction.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:o2Level rdf:type rdf:Property ;
    rdfs:label 'O2 Level' ;
    rdfs:comment 'The oxygen concentration measured inside the reefer container in percentage. Used for controlled atmosphere monitoring to preserve perishable cargo.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerStatus rdf:type rdf:Property ;
    rdfs:label 'Power Status' ;
    rdfs:comment 'The electrical power connection status of the reefer container. Connected indicates active power supply, disconnected indicates no power, standby indicates backup power mode.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerSupplyVoltage rdf:type rdf:Property ;
    rdfs:label 'Power Supply Voltage' ;
    rdfs:comment 'The electrical voltage being supplied to the reefer container in volts. Standard voltages are 220V, 380V, or 440V depending on terminal infrastructure.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Device Code' ;
    rdfs:comment 'The unique identifier of the monitoring sensor or telemetry device that captured this reading. Used for device calibration tracking and data quality assurance.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setTemperature rdf:type rdf:Property ;
    rdfs:label 'Set Temperature' ;
    rdfs:comment 'The target temperature setting configured for the reefer container in degrees Celsius. This is the temperature the refrigeration unit is programmed to maintain.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicianInspectionReference rdf:type rdf:Property ;
    rdfs:label 'Technician Inspection Reference' ;
    rdfs:comment 'Reference number or identifier linking this monitoring event to a technician inspection work order or maintenance record. Populated when manual intervention occurred.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureDeviation rdf:type rdf:Property ;
    rdfs:label 'Temperature Deviation' ;
    rdfs:comment 'The calculated difference between set temperature and actual temperature in degrees. Positive values indicate warmer than set point, negative values indicate cooler than set point.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureUnit rdf:type rdf:Property ;
    rdfs:label 'Temperature Unit' ;
    rdfs:comment 'The unit of measure for temperature readings. Standard is Celsius but Fahrenheit may be used in some jurisdictions.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationRate rdf:type rdf:Property ;
    rdfs:label 'Ventilation Rate' ;
    rdfs:comment 'The air exchange rate in cubic meters per hour when ventilation is active. Applicable for cargo requiring fresh air circulation.' ;
    rdfs:domain ind:ReeferMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roroActivityId rdf:type rdf:Property ;
    rdfs:label 'Roro Activity Id' ;
    rdfs:comment 'Unique identifier for the RoRo activity record. Primary key for the RoRo activity transaction.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activity End Timestamp' ;
    rdfs:comment 'Date and time when the RoRo activity was completed. Used for duration calculation and productivity analysis.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activityNumber rdf:type rdf:Property ;
    rdfs:label 'Activity Number' ;
    rdfs:comment 'Business identifier for the RoRo activity. Externally-known reference number used in operational communications and documentation.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activity Start Timestamp' ;
    rdfs:comment 'Date and time when the RoRo activity commenced. Used for operational performance measurement and billing.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:damageDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Detected Flag' ;
    rdfs:comment 'Indicates whether damage was detected during inspection. True if damage found, false if no damage or no inspection performed.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:damageInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Inspection Flag' ;
    rdfs:comment 'Indicates whether a damage inspection was performed during or after the activity. True if inspection occurred, false otherwise.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deckPosition rdf:type rdf:Property ;
    rdfs:label 'Deck Position' ;
    rdfs:comment 'Stowage position on the vessel deck where the vehicle is located or will be placed. Follows vessel stowage plan notation.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingInstruction rdf:type rdf:Property ;
    rdfs:label 'Handling Instruction' ;
    rdfs:comment 'Special handling instructions or requirements for the cargo unit. May include stowage preferences, security requirements, or operational constraints.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightMeters rdf:type rdf:Property ;
    rdfs:label 'Height Meters' ;
    rdfs:comment 'Height of the vehicle or cargo unit in meters. Critical for deck clearance and stowage planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lashingEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Lashing Equipment Type' ;
    rdfs:comment 'Type of lashing equipment used to secure the cargo. Determines securing method and safety compliance.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lashingPointCount rdf:type rdf:Property ;
    rdfs:label 'Lashing Point Count' ;
    rdfs:comment 'Number of lashing points used to secure the vehicle or cargo unit. Ensures compliance with cargo securing requirements.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lengthMeters rdf:type rdf:Property ;
    rdfs:label 'Length Meters' ;
    rdfs:comment 'Length of the vehicle or cargo unit in meters. Used for stowage planning and space allocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rampIdentifier rdf:type rdf:Property ;
    rdfs:label 'Ramp Identifier' ;
    rdfs:comment 'Identifier of the RoRo ramp used for the activity. Links the operation to specific terminal infrastructure.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleMake rdf:type rdf:Property ;
    rdfs:label 'Vehicle Make' ;
    rdfs:comment 'Manufacturer or brand of the vehicle being handled. Used for inventory tracking and customer reporting.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleModel rdf:type rdf:Property ;
    rdfs:label 'Vehicle Model' ;
    rdfs:comment 'Model designation of the vehicle being handled. Provides detailed identification for tracking and documentation.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleUnitIdentifier rdf:type rdf:Property ;
    rdfs:label 'Vehicle Unit Identifier' ;
    rdfs:comment 'Unique identifier for the vehicle or cargo unit being handled. May be VIN (Vehicle Identification Number), chassis number, or equipment identifier depending on cargo type.' ;
    rdfs:domain ind:RoroActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthMeters rdf:type rdf:Property ;
    rdfs:label 'Width Meters' ;
    rdfs:comment 'Width of the vehicle or cargo unit in meters. Used for stowage planning and clearance verification.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentYardZone rdf:type rdf:Property ;
    rdfs:label 'Current Yard Zone' ;
    rdfs:comment 'Current yard zone or operational area where the equipment is assigned or located. Used for dispatch optimization, equipment utilization tracking, and operational planning. Typically references yard block identifiers from terminal layout.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Number' ;
    rdfs:comment 'Externally-known unique business identifier for the terminal handling equipment unit. Used for operational dispatch, maintenance tracking, and cross-system reference. Typically alphanumeric code assigned by terminal operations or manufacturer.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelPowerType rdf:type rdf:Property ;
    rdfs:label 'Fuel Power Type' ;
    rdfs:comment 'Primary energy source or propulsion type for the equipment. Critical for environmental reporting (GHG emissions), operational cost tracking, refueling/recharging infrastructure planning, and compliance with port environmental regulations.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeTerminal rdf:type rdf:Property ;
    rdfs:label 'Home Terminal' ;
    rdfs:comment 'Primary terminal or facility where the equipment is permanently assigned. Used for multi-terminal port operations to track equipment allocation and inter-terminal transfers.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Reference' ;
    rdfs:comment 'Reference number for the insurance policy covering this equipment. Used for risk management, claims processing, and asset protection. Links to Protection and Indemnity (P&I) or equipment insurance policies.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMajorOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Overhaul Date' ;
    rdfs:comment 'Date of the most recent major overhaul or refurbishment of the equipment. Used for maintenance planning, remaining useful life estimation, and capital expenditure tracking.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximoAssetReference rdf:type rdf:Property ;
    rdfs:label 'Maximo Asset Reference' ;
    rdfs:comment 'Cross-reference identifier linking this terminal equipment record to the corresponding asset record in Maximo Asset Management system. Enables integration between operational equipment master (TOS) and full asset lifecycle management (EAM) for maintenance, work orders, and asset financial tracking.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLiftHeightMetres rdf:type rdf:Property ;
    rdfs:label 'Maximum Lift Height Metres' ;
    rdfs:comment 'Maximum vertical lift height of the equipment in metres. Applicable to cranes and lifting equipment, indicates the maximum container stack height or vessel reach capability. Critical for operational planning and safety.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumReachMetres rdf:type rdf:Property ;
    rdfs:label 'Maximum Reach Metres' ;
    rdfs:comment 'Maximum horizontal reach or span of the equipment in metres. Applicable to cranes (STS, QC, MHC, RTG, ASC) and indicates the operational envelope for cargo handling. Used for berth planning and yard layout optimization.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHoursSinceLastService rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Since Last Service' ;
    rdfs:comment 'Operating hours accumulated since the last scheduled maintenance service. Used to trigger interval-based preventive maintenance activities.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHoursTotal rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Total' ;
    rdfs:comment 'Cumulative total operating hours recorded for the equipment since commissioning. Used for usage-based maintenance scheduling, depreciation calculations, and equipment lifecycle analysis.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reeferMonitoringCapable rdf:type rdf:Property ;
    rdfs:label 'Reefer Monitoring Capable' ;
    rdfs:comment 'Indicates whether the equipment is equipped with systems to monitor refrigerated container (reefer) parameters during handling or storage. Applicable to yard equipment and critical for cold chain integrity.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swlTonnes rdf:type rdf:Property ;
    rdfs:label 'Swl Tonnes' ;
    rdfs:comment 'Maximum safe working load capacity of the equipment expressed in metric tonnes. Critical safety parameter for operational dispatch and cargo handling planning. Must not be exceeded during operations per SOLAS and port safety regulations.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tandemLiftCapable rdf:type rdf:Property ;
    rdfs:label 'Tandem Lift Capable' ;
    rdfs:comment 'Indicates whether the equipment is capable of lifting two Forty-foot Equivalent Unit (FEU) containers simultaneously. Applicable to high-capacity cranes and represents advanced productivity capability.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telematicsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Telematics System Code' ;
    rdfs:comment 'Identifier for the telematics system or IoT device installed on the equipment for remote monitoring of performance, diagnostics, and operational parameters. Used for predictive maintenance and real-time equipment health monitoring.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twinLiftCapable rdf:type rdf:Property ;
    rdfs:label 'Twin Lift Capable' ;
    rdfs:comment 'Indicates whether the equipment is capable of lifting two Twenty-foot Equivalent Unit (TEU) containers simultaneously. Applicable to cranes and significantly impacts productivity for vessel and yard operations.' ;
    rdfs:domain ind:TerminalEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminalServiceOrderId rdf:type rdf:Property ;
    rdfs:label 'Terminal Service Order Id' ;
    rdfs:comment 'Unique identifier for the terminal service order. Primary key for this entity.' ;
    rdfs:domain ind:TerminalServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether the service order requires management or customer approval before execution, typically for high-value or non-standard services.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancelledBy rdf:type rdf:Property ;
    rdfs:label 'Cancelled By' ;
    rdfs:comment 'Identifier of the user or system that cancelled the service order, for audit trail purposes.' ;
    rdfs:domain ind:TerminalServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Charge Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the service charge amount.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeReference rdf:type rdf:Property ;
    rdfs:label 'Charge Reference' ;
    rdfs:comment 'Reference to the billing charge or tariff code associated with this service for revenue tracking and invoicing.' ;
    rdfs:domain ind:TerminalServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRemarks rdf:type rdf:Property ;
    rdfs:label 'Completion Remarks' ;
    rdfs:comment 'Final remarks or comments recorded upon service completion, including any deviations from standard procedure or follow-up actions required.' ;
    rdfs:domain ind:TerminalServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated duration for the service execution in minutes, used for scheduling and resource planning.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCheckPerformed rdf:type rdf:Property ;
    rdfs:label 'Quality Check Performed' ;
    rdfs:comment 'Indicates whether a quality inspection or verification was performed after service completion to ensure standards were met.' ;
    rdfs:domain ind:TerminalServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckResult rdf:type rdf:Property ;
    rdfs:label 'Quality Check Result' ;
    rdfs:comment 'Result of the quality inspection performed after service completion, indicating whether the service met required standards.' ;
    rdfs:domain ind:TerminalServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'Date when the customer initially requested the terminal service, used for SLA tracking and service demand analysis.' ;
    rdfs:domain ind:TerminalServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLocationType rdf:type rdf:Property ;
    rdfs:label 'Service Location Type' ;
    rdfs:comment 'Type of terminal location where the service is performed, such as container yard, gate, berth, container freight station (CFS), workshop, or inspection area.' ;
    rdfs:domain ind:TerminalServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceNotes rdf:type rdf:Property ;
    rdfs:label 'Service Notes' ;
    rdfs:comment 'Operational notes recorded by the assigned operator during or after service execution, documenting observations or issues encountered.' ;
    rdfs:domain ind:TerminalServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderReference rdf:type rdf:Property ;
    rdfs:label 'Work Order Reference' ;
    rdfs:comment 'Reference to the maintenance or operational work order associated with this service, if applicable.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselBayPlanId rdf:type rdf:Property ;
    rdfs:label 'Vessel Bay Plan Id' ;
    rdfs:comment 'Unique identifier for the vessel bay plan record. Primary key for vessel stowage and operational planning.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baplieMessageId rdf:type rdf:Property ;
    rdfs:label 'Baplie Message Id' ;
    rdfs:comment 'Unique identifier for the UN/EDIFACT BAPLIE message received from the vessel or shipping line containing stowage plan data.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiMessage .

ind:securityClearanceOfficerSecurityPersonnelId rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Officer Security Personnel Id' ;
    rdfs:comment 'Foreign key linking to security.security_personnel. Business justification: Bay plans containing hazmat/restricted cargo require security officer review and clearance per ISPS Code. Tracks which security-cleared personnel approved stowage plans for audit trail, liability dete' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Personnel .

ind:cargoCutoffDatetime rdf:type rdf:Property ;
    rdfs:label 'Cargo Cutoff Datetime' ;
    rdfs:comment 'Deadline timestamp by which all export cargo must be delivered to the terminal for loading onto this vessel call.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dischargeSequence rdf:type rdf:Property ;
    rdfs:label 'Discharge Sequence' ;
    rdfs:comment 'Planned sequence order for discharging this container from the vessel to optimize operational efficiency.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hatchNumber rdf:type rdf:Property ;
    rdfs:label 'Hatch Number' ;
    rdfs:comment 'Vessel hatch identifier for grouping bays and planning hatch cover operations and crane work sequences.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hatchSequencePlan rdf:type rdf:Property ;
    rdfs:label 'Hatch Sequence Plan' ;
    rdfs:comment 'Planned operational sequence for working vessel hatches to optimize crane productivity and minimize vessel turnaround time.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSequence rdf:type rdf:Property ;
    rdfs:label 'Load Sequence' ;
    rdfs:comment 'Planned sequence order for loading this container onto the vessel to optimize operational efficiency and vessel stability.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oogOverhangFrontCm rdf:type rdf:Property ;
    rdfs:label 'Oog Overhang Front Cm' ;
    rdfs:comment 'Front overhang dimension in centimeters for out-of-gauge cargo. Null for standard containers.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oogOverhangLeftCm rdf:type rdf:Property ;
    rdfs:label 'Oog Overhang Left Cm' ;
    rdfs:comment 'Left side overhang dimension in centimeters for out-of-gauge cargo. Null for standard containers.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oogOverhangRearCm rdf:type rdf:Property ;
    rdfs:label 'Oog Overhang Rear Cm' ;
    rdfs:comment 'Rear overhang dimension in centimeters for out-of-gauge cargo. Null for standard containers.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oogOverhangRightCm rdf:type rdf:Property ;
    rdfs:label 'Oog Overhang Right Cm' ;
    rdfs:comment 'Right side overhang dimension in centimeters for out-of-gauge cargo. Null for standard containers.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oogOverheightCm rdf:type rdf:Property ;
    rdfs:label 'Oog Overheight Cm' ;
    rdfs:comment 'Height overhang dimension in centimeters for out-of-gauge cargo. Null for standard containers.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Approved Timestamp' ;
    rdfs:comment 'Timestamp when this vessel bay plan was formally approved and released for operational execution.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Created Timestamp' ;
    rdfs:comment 'Timestamp when this vessel bay plan record was initially created in the terminal operating system.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Updated Timestamp' ;
    rdfs:comment 'Timestamp when this vessel bay plan record was last modified or revised.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedCraneCount rdf:type rdf:Property ;
    rdfs:label 'Planned Crane Count' ;
    rdfs:comment 'Number of STS (Ship-to-Shore) or QC (Quay Crane) units allocated for this vessel operation to achieve target productivity.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedGangCount rdf:type rdf:Property ;
    rdfs:label 'Planned Gang Count' ;
    rdfs:comment 'Number of stevedore gangs or labor teams allocated for vessel loading and discharge operations.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOperationEnd rdf:type rdf:Property ;
    rdfs:label 'Planned Operation End' ;
    rdfs:comment 'Scheduled timestamp for completing all vessel cargo operations including final crane move and securing.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedOperationStart rdf:type rdf:Property ;
    rdfs:label 'Planned Operation Start' ;
    rdfs:comment 'Scheduled timestamp for commencing vessel cargo operations including first crane move.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preMarshallingRequired rdf:type rdf:Property ;
    rdfs:label 'Pre Marshalling Required' ;
    rdfs:comment 'Indicates whether containers require pre-marshalling or repositioning in the yard prior to vessel loading to optimize load sequence.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reeferTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Reefer Temperature C' ;
    rdfs:comment 'Required temperature setting in Celsius for refrigerated containers. Null for non-reefer units.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceAllocationNotes rdf:type rdf:Property ;
    rdfs:label 'Resource Allocation Notes' ;
    rdfs:comment 'Free-text notes documenting equipment allocation decisions, operational constraints, or special resource requirements for this vessel call.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restowFlag rdf:type rdf:Property ;
    rdfs:label 'Restow Flag' ;
    rdfs:comment 'Indicates whether this container requires restowing or repositioning on the vessel to access underlying cargo or optimize stowage.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stowageInstruction rdf:type rdf:Property ;
    rdfs:label 'Stowage Instruction' ;
    rdfs:comment 'Special handling or stowage instructions for the container including segregation requirements, securing notes, or operational constraints.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDischargeMoves rdf:type rdf:Property ;
    rdfs:label 'Total Discharge Moves' ;
    rdfs:comment 'Total number of container discharge moves planned for this vessel call across all bays and hatches.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLoadMoves rdf:type rdf:Property ;
    rdfs:label 'Total Load Moves' ;
    rdfs:comment 'Total number of container load moves planned for this vessel call across all bays and hatches.' ;
    rdfs:domain ind:VesselBayPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardBlockId rdf:type rdf:Property ;
    rdfs:label 'Yard Block Id' ;
    rdfs:comment 'Unique identifier for the container yard block. Primary key. MASTER_RESOURCE role entity representing physical yard infrastructure for container stacking operations.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:YardBlock .

ind:yardZoneId rdf:type rdf:Property ;
    rdfs:label 'Yard Zone Id' ;
    rdfs:comment 'Foreign key reference to the logical yard zone grouping that this block belongs to. Yard zones aggregate multiple blocks for operational planning, resource allocation, and performance reporting.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalZone .

ind:bayCount rdf:type rdf:Property ;
    rdfs:label 'Bay Count' ;
    rdfs:comment 'Number of container bays configured in the yard block layout. Bays run parallel to the equipment travel path and define the block\'s length dimension. Each bay typically accommodates one 40-foot container (FEU) or two 20-foot containers (TEU).' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockCode rdf:type rdf:Property ;
    rdfs:label 'Block Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the yard block within the terminal. Used for operational communication, TOS integration, and equipment dispatch instructions.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockName rdf:type rdf:Property ;
    rdfs:label 'Block Name' ;
    rdfs:comment 'Human-readable descriptive name of the yard block for operational reference and reporting purposes.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockType rdf:type rdf:Property ;
    rdfs:label 'Block Type' ;
    rdfs:comment 'Classification of the yard block based on primary container handling purpose. Determines container allocation rules, equipment requirements, and operational workflows.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drainageSystem rdf:type rdf:Property ;
    rdfs:label 'Drainage System' ;
    rdfs:comment 'Type of water drainage system installed in the yard block to manage rainwater runoff and prevent surface flooding that could disrupt operations or damage containers.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundSlotCapacity rdf:type rdf:Property ;
    rdfs:label 'Ground Slot Capacity' ;
    rdfs:comment 'Total number of ground-level container positions (slots) available in the yard block. Represents base capacity before vertical stacking. Measured in TEU (Twenty-foot Equivalent Unit) ground slots.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lightingAvailable rdf:type rdf:Property ;
    rdfs:label 'Lighting Available' ;
    rdfs:comment 'Indicates whether the yard block is equipped with operational lighting infrastructure to support 24/7 container handling operations during night shifts.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxStackHeight rdf:type rdf:Property ;
    rdfs:label 'Max Stack Height' ;
    rdfs:comment 'Maximum number of container tiers (vertical stacking levels) permitted in this yard block. Determined by equipment capabilities (RTG, ASC safe working load), surface load-bearing capacity, and operational safety standards.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rowCount rdf:type rdf:Property ;
    rdfs:label 'Row Count' ;
    rdfs:comment 'Number of container rows configured in the yard block layout. Rows run perpendicular to the equipment travel path and define the block\'s width dimension.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityZone rdf:type rdf:Property ;
    rdfs:label 'Security Zone' ;
    rdfs:comment 'Security classification level of the yard block per ISPS Code requirements. Determines access control requirements, surveillance coverage, and security personnel deployment.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationZone rdf:type rdf:Property ;
    rdfs:label 'Segregation Zone' ;
    rdfs:comment 'Designated segregation zone code for dangerous goods container stacking per IMDG Code segregation requirements. Defines compatibility groups and minimum separation distances.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'Number of vertical tiers (stacking levels) configured in the yard block. Tier 1 is ground level; higher tiers represent vertical stacking positions. Must not exceed max_stack_height.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'User identifier or system account that last modified this yard block record. Used for audit trails, accountability, and change management.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightScaleAvailable rdf:type rdf:Property ;
    rdfs:label 'Weight Scale Available' ;
    rdfs:comment 'Indicates whether the yard block is equipped with weighbridge or container weighing infrastructure to support SOLAS VGM (Verified Gross Mass) compliance and load planning.' ;
    rdfs:domain ind:YardBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationIcdFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Icd Facility Id' ;
    rdfs:comment 'Foreign key linking to intermodal.icd_facility. Business justification: Yard slots are pre-marshalled by destination ICD to optimize drayage routing. Linking slot to destination ICD enables yard block allocation by ICD corridor, reduces truck travel distance, and supports' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcdFacility .

ind:primaryYardCurrentContainerId rdf:type rdf:Property ;
    rdfs:label 'Primary Yard Current Container Id' ;
    rdfs:comment 'Reference to the container currently occupying this slot. Null if slot is vacant. Enables real-time container location tracking.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Container .

ind:accessibilityRating rdf:type rdf:Property ;
    rdfs:label 'Accessibility Rating' ;
    rdfs:comment 'Operational accessibility rating based on equipment reach, traffic flow, and physical constraints. Affects slot utilization priority.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsInspectionZone rdf:type rdf:Property ;
    rdfs:label 'Customs Inspection Zone' ;
    rdfs:comment 'Indicates whether the slot is located within a designated customs inspection area. True if subject to enhanced customs controls.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distanceToGateMeters rdf:type rdf:Property ;
    rdfs:label 'Distance To Gate Meters' ;
    rdfs:comment 'Distance from this slot to the nearest terminal gate in meters. Used for optimizing container placement and reducing truck turn time.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceToQuayMeters rdf:type rdf:Property ;
    rdfs:label 'Distance To Quay Meters' ;
    rdfs:comment 'Distance from this slot to the nearest quay crane position in meters. Critical for optimizing vessel loading/discharge operations.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drainageStatus rdf:type rdf:Property ;
    rdfs:label 'Drainage Status' ;
    rdfs:comment 'Condition of drainage infrastructure at the slot. Critical for reefer operations and preventing water damage to cargo.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentAccessType rdf:type rdf:Property ;
    rdfs:label 'Equipment Access Type' ;
    rdfs:comment 'Type of handling equipment that can access this slot. Determines operational flexibility and throughput capability. [ENUM-REF-CANDIDATE: rtg|sts|asc|qc|mhc|reach_stacker|forklift|multi — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Hazmat Approved' ;
    rdfs:comment 'Indicates whether the slot is certified for storing hazardous materials per IMDG Code. True if approved for dangerous goods.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClassRestrictions rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class Restrictions' ;
    rdfs:comment 'Comma-separated list of IMDG hazard classes permitted in this slot. Empty if no hazmat approved. Example: 3,4.1,9.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightClearanceMeters rdf:type rdf:Property ;
    rdfs:label 'Height Clearance Meters' ;
    rdfs:comment 'Maximum vertical clearance available at this slot position. Critical for high-cube containers and OOG cargo.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastOccupiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Occupied Timestamp' ;
    rdfs:comment 'Date and time when a container was last placed in this slot. Used for slot utilization analytics and dwell time calculations.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastVacatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Vacated Timestamp' ;
    rdfs:comment 'Date and time when the slot was last vacated. Used for slot turnover metrics and yard efficiency KPIs.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maintenanceNotes rdf:type rdf:Property ;
    rdfs:label 'Maintenance Notes' ;
    rdfs:comment 'Free-text field for recording maintenance history, known issues, or special handling instructions for the slot.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Capacity Kg' ;
    rdfs:comment 'Maximum gross weight the slot can safely support in kilograms. Derived from ground bearing capacity and structural limits.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupiedFlag rdf:type rdf:Property ;
    rdfs:label 'Occupied Flag' ;
    rdfs:comment 'Indicates whether the slot is currently occupied by a container. True if a container is present, false if vacant.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oogApproved rdf:type rdf:Property ;
    rdfs:label 'Oog Approved' ;
    rdfs:comment 'Indicates whether the slot can accommodate out-of-gauge cargo that exceeds standard container dimensions. True if OOG capable.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalZone rdf:type rdf:Property ;
    rdfs:label 'Operational Zone' ;
    rdfs:comment 'Logical operational zone or area code within the terminal. Used for yard segmentation and equipment dispatch optimization.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferPlugAvailable rdf:type rdf:Property ;
    rdfs:label 'Reefer Plug Available' ;
    rdfs:comment 'Indicates whether the slot is equipped with a reefer power plug for refrigerated containers. True if plug is installed and operational.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reeferPlugType rdf:type rdf:Property ;
    rdfs:label 'Reefer Plug Type' ;
    rdfs:comment 'Type of electrical connection available for reefer containers. Specifies voltage and phase configuration of the power supply.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferVoltage rdf:type rdf:Property ;
    rdfs:label 'Reefer Voltage' ;
    rdfs:comment 'Voltage rating of the reefer power supply at this slot in volts. Common values are 220V, 380V, or 440V.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservationExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Expiry Timestamp' ;
    rdfs:comment 'Date and time when the current slot reservation expires. After expiry, the slot becomes available for re-allocation.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotCode rdf:type rdf:Property ;
    rdfs:label 'Slot Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the slot within the terminal. Used for operational reference and TOS integration.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Status' ;
    rdfs:comment 'Current operational status of the slot. Indicates whether the slot is available for container placement or restricted.' ;
    rdfs:domain ind:YardSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Agency Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Agent appointments are formalized through agency agreements defining scope, commission rates, financial authority, and service fees. Essential for billing reconciliation, commission calculation, and d' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:appointingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Appointing Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Port authority officers approve agent appointments, verify credentials, and manage ISPS security clearances. Essential for regulatory control, security compliance, and commercial relationship manageme' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the agent appointment role. General agent handles all vessel matters; husbanding agent provides operational support; cargo agent manages cargo documentation; protective agent represents owner interests; liner agent serves scheduled services; port agent provides local representation.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Appointment Agreement Reference' ;
    rdfs:comment 'Reference to the formal agency agreement or contract document that governs the terms and conditions of the agent appointment.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Appointment End Date' ;
    rdfs:comment 'The date on which the agent appointment expires or is scheduled to terminate. Nullable for indefinite appointments.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentReason rdf:type rdf:Property ;
    rdfs:label 'Appointment Reason' ;
    rdfs:comment 'Free-text description of the business reason or circumstances that led to this agent appointment, such as regular service, emergency replacement, or special cargo handling.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentScope rdf:type rdf:Property ;
    rdfs:label 'Appointment Scope' ;
    rdfs:comment 'Defines the coverage extent of the agent appointment. Single call for one port visit; voyage series for a defined set of calls; annual contract for all calls within a year; indefinite for ongoing representation.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Start Date' ;
    rdfs:comment 'The date from which the agent appointment becomes effective and the agent is authorized to act on behalf of the vessel or owner.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingAddressRouting rdf:type rdf:Property ;
    rdfs:label 'Billing Address Routing' ;
    rdfs:comment 'Specifies to whom port invoices and charges should be addressed. Agent routes to agent company; owner to vessel owner; operator to vessel operator; charterer to the charterer.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'The percentage commission rate payable to the agent for services rendered, typically applied to port charges or cargo handling fees.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsClearanceAuthority rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Authority' ;
    rdfs:comment 'Indicates whether the agent is authorized to handle customs clearance procedures and submit customs declarations on behalf of the vessel.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disbursementAccountReference rdf:type rdf:Property ;
    rdfs:label 'Disbursement Account Reference' ;
    rdfs:comment 'Reference to the disbursement account used by the agent for settling port charges, pilotage fees, and other expenses on behalf of the vessel.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSubmissionAuthority rdf:type rdf:Property ;
    rdfs:label 'Document Submission Authority' ;
    rdfs:comment 'Indicates whether the agent is authorized to submit official port and customs documentation on behalf of the vessel or owner. True grants submission rights; false restricts to coordination only.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Authority Flag' ;
    rdfs:comment 'Indicates whether the agent has authority to commit to financial obligations and sign invoices on behalf of the vessel owner or operator.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsSecurityClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Isps Security Clearance Status' ;
    rdfs:comment 'Security clearance status of the agent company under ISPS Code requirements. Cleared allows port facility access; pending awaits approval; denied restricts access; expired requires renewal.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portFacilityAccessPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Port Facility Access Permit Number' ;
    rdfs:comment 'Unique identifier of the port facility access permit issued to the agent company, required for physical access to restricted port areas.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proformaDisbursementAccountRequired rdf:type rdf:Property ;
    rdfs:label 'Proforma Disbursement Account Required' ;
    rdfs:comment 'Indicates whether a proforma disbursement account statement must be issued before the vessel arrival for advance payment of estimated port charges.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Created By' ;
    rdfs:comment 'User identifier or system account that created this agent appointment record. Audit trail field.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Service Fee Structure' ;
    rdfs:comment 'Defines how the agent is compensated. Fixed per call charges a set amount; percentage commission applies a rate to charges; time and materials bills actual hours; hybrid combines methods.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Date' ;
    rdfs:comment 'The date on which formal notice of termination was given by either party. Used to track notice period compliance per agency agreement terms.' ;
    rdfs:domain ind:AgentAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:anchorageId rdf:type rdf:Property ;
    rdfs:label 'Anchorage Id' ;
    rdfs:comment 'Primary key for anchorage' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Anchorage .

ind:anchorageEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Anchorage Employee Id' ;
    rdfs:comment 'Reference to the VTS officer responsible for managing and monitoring this anchorage assignment. Ensures accountability and operational oversight.' ;
    rdfs:domain ind:Anchorage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:anchorageVtsOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Anchorage Vts Officer Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Anchorage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicablePortTariffId rdf:type rdf:Property ;
    rdfs:label 'Applicable Port Tariff Id' ;
    rdfs:comment 'Foreign key linking to tariff.port_tariff. Business justification: Anchorage assignments incur anchorage charges defined in port tariff schedules based on vessel size, duration, and anchorage area. While anchorage_charge_amount captures the result, the tariff referen' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortTariff .

ind:nextBerthId rdf:type rdf:Property ;
    rdfs:label 'Next Berth Id' ;
    rdfs:comment 'Reference to the berth allocated for the vessel after departing anchorage. Links anchorage assignment to subsequent berth allocation.' ;
    rdfs:domain ind:Anchorage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Berth .

ind:anchorBerthNumber rdf:type rdf:Property ;
    rdfs:label 'Anchor Berth Number' ;
    rdfs:comment 'Specific berth or position number within the anchorage area assigned to the vessel. Used for precise positioning and capacity management.' ;
    rdfs:domain ind:Anchorage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration the vessel remained at anchorage measured in hours. Calculated from actual anchor drop time to actual weigh anchor time. Used for billing and performance analysis.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedWeighAnchorTime rdf:type rdf:Property ;
    rdfs:label 'Expected Weigh Anchor Time' ;
    rdfs:comment 'Expected timestamp when the vessel will weigh anchor and depart the anchorage. Used for berth planning and vessel traffic sequencing.' ;
    rdfs:domain ind:Anchorage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:positionLatitude rdf:type rdf:Property ;
    rdfs:label 'Position Latitude' ;
    rdfs:comment 'Latitude coordinate of the vessel\'s anchorage position in decimal degrees. Used for precise vessel location tracking and VTS monitoring.' ;
    rdfs:domain ind:Anchorage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionLongitude rdf:type rdf:Property ;
    rdfs:label 'Position Longitude' ;
    rdfs:comment 'Longitude coordinate of the vessel\'s anchorage position in decimal degrees. Used for precise vessel location tracking and VTS monitoring.' ;
    rdfs:domain ind:Anchorage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledAnchorDropTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Anchor Drop Time' ;
    rdfs:comment 'Planned timestamp when the vessel is scheduled to drop anchor at the assigned anchorage position. Used for VTS coordination and sequencing.' ;
    rdfs:domain ind:Anchorage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visibilityMeters rdf:type rdf:Property ;
    rdfs:label 'Visibility Meters' ;
    rdfs:comment 'Visibility distance at the anchorage position measured in meters. Important for navigation safety and VTS monitoring.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bunkerOperationId rdf:type rdf:Property ;
    rdfs:label 'Bunker Operation Id' ;
    rdfs:comment 'Unique identifier for the bunkering operation record. Primary key.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableBunkerAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Applicable Bunker Adjustment Id' ;
    rdfs:comment 'Foreign key linking to tariff.bunker_adjustment. Business justification: Bunker operations may be subject to bunker adjustment factors (BAF) that affect port service pricing when fuel price volatility impacts operational costs. Required for calculating fuel-indexed surchar' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BunkerAdjustment .

ind:bunkerSupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Bunker Supply Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement. Business justification: Bunker operations execute under fuel supply agreements defining pricing, quality specifications, delivery terms, and payment conditions. Required for rate verification, invoice reconciliation, and dis' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:operationsSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operations Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Port operations supervisors authorize bunkering operations, verify safety checklists, and monitor MARPOL compliance. Critical for environmental protection, safety incident accountability, and VTS coor' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bdnReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bdn Reference Number' ;
    rdfs:comment 'Unique reference number from the Bunker Delivery Note issued by the supplier. Required for MARPOL Annex VI compliance and serves as the official receipt for fuel delivery.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bunkerBargeImoNumber rdf:type rdf:Property ;
    rdfs:label 'Bunker Barge Imo Number' ;
    rdfs:comment 'Seven-digit IMO number of the bunker barge, if applicable. Used for vessel tracking and security screening.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bunkerSupplierName rdf:type rdf:Property ;
    rdfs:label 'Bunker Supplier Name' ;
    rdfs:comment 'Name of the bunker fuel supplier company conducting the operation.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chiefEngineerName rdf:type rdf:Property ;
    rdfs:label 'Chief Engineer Name' ;
    rdfs:comment 'Name of the vessel\'s Chief Engineer who supervised and signed off on the bunkering operation.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationType rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Type' ;
    rdfs:comment 'Type of location where the bunkering operation is conducted. Impacts safety protocols and operational procedures.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityAt15cKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Density At 15c Kg Per M3' ;
    rdfs:comment 'Density of the bunker fuel at 15 degrees Celsius in kilograms per cubic meter. Standard measurement for fuel quality verification per ISO 8217.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelGrade rdf:type rdf:Property ;
    rdfs:label 'Fuel Grade' ;
    rdfs:comment 'Specific grade or quality designation of the bunker fuel as per ISO 8217 standards (e.g., RMG380, DMA, DMB).' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSampleSealNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Sample Seal Number' ;
    rdfs:comment 'Seal number of the fuel sample container. Ensures sample integrity for potential dispute resolution or PSC inspection.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSampleTakenFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Sample Taken Flag' ;
    rdfs:comment 'Indicates whether a representative fuel sample was taken during delivery for quality verification and MARPOL compliance.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Operation Duration Minutes' ;
    rdfs:comment 'Total duration of the bunkering operation in minutes, from start to end. Used for billing berth time and operational efficiency analysis.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portServiceCharge rdf:type rdf:Property ;
    rdfs:label 'Port Service Charge' ;
    rdfs:comment 'Port authority charges for facilitating the bunkering operation, including berth time during fueling and safety oversight.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Certificate Number' ;
    rdfs:comment 'Certificate number from the fuel quality analysis report provided by the supplier or independent laboratory.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDeliveredMt rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered Mt' ;
    rdfs:comment 'Actual quantity of bunker fuel delivered to the vessel in metric tonnes (MT). Recorded on the BDN and used for billing.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOrderedMt rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered Mt' ;
    rdfs:comment 'Quantity of bunker fuel ordered by the vessel in metric tonnes (MT). Represents the planned delivery volume.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingTankName rdf:type rdf:Property ;
    rdfs:label 'Receiving Tank Name' ;
    rdfs:comment 'Name or designation of the vessel\'s fuel tank receiving the bunker delivery (e.g., Port Bunker Tank No. 1, Starboard Service Tank).' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyChecklistCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Checklist Completed Flag' ;
    rdfs:comment 'Indicates whether the ship-shore safety checklist was completed before bunkering commenced. Required by ISGOTT (International Safety Guide for Oil Tankers and Terminals).' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyChecklistReference rdf:type rdf:Property ;
    rdfs:label 'Safety Checklist Reference' ;
    rdfs:comment 'Reference number or document identifier for the completed ship-shore safety checklist.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time for the bunkering operation to commence. Used for berth planning and VTS coordination.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sulphurContentPercent rdf:type rdf:Property ;
    rdfs:label 'Sulphur Content Percent' ;
    rdfs:comment 'Sulphur content of the delivered fuel expressed as a percentage by mass. Critical for MARPOL Annex VI compliance (0.50% global limit, 0.10% in ECAs).' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Supplier Representative Name' ;
    rdfs:comment 'Name of the bunker supplier\'s representative who conducted the delivery and signed the BDN.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankAfterSoundingMeters rdf:type rdf:Property ;
    rdfs:label 'Tank After Sounding Meters' ;
    rdfs:comment 'Tank gauging reading in meters after bunkering completed. Used to verify delivered quantity against BDN.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tankBeforeSoundingMeters rdf:type rdf:Property ;
    rdfs:label 'Tank Before Sounding Meters' ;
    rdfs:comment 'Tank gauging reading in meters before bunkering commenced. Used to calculate actual quantity received.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFuelCost rdf:type rdf:Property ;
    rdfs:label 'Total Fuel Cost' ;
    rdfs:comment 'Total cost for the bunker fuel delivered, calculated as quantity delivered multiplied by unit price.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPricePerMt rdf:type rdf:Property ;
    rdfs:label 'Unit Price Per Mt' ;
    rdfs:comment 'Price per metric tonne of bunker fuel. Commercial pricing information used for billing and cost analysis.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viscosityCst rdf:type rdf:Property ;
    rdfs:label 'Viscosity Cst' ;
    rdfs:comment 'Kinematic viscosity of the fuel in centistokes (cSt) at 50°C. Key quality parameter affecting fuel handling and combustion.' ;
    rdfs:domain ind:BunkerOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vtsClearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Vts Clearance Number' ;
    rdfs:comment 'VTS clearance reference number authorizing the bunkering operation. Required for operations in VTS-controlled waters.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allFastTimestamp rdf:type rdf:Property ;
    rdfs:label 'All Fast Timestamp' ;
    rdfs:comment 'Timestamp when all mooring lines were secured and the vessel was fully berthed. Marks completion of berthing operations.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:baplieReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Baplie Received Flag' ;
    rdfs:comment 'Indicates whether the BAPLIE EDI message containing the vessel stowage plan has been received from the shipping line.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callNumber rdf:type rdf:Property ;
    rdfs:label 'Call Number' ;
    rdfs:comment 'Sequential port-assigned identifier for this specific vessel visit. Used as the business reference number for all port operations and billing.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callStatus rdf:type rdf:Property ;
    rdfs:label 'Call Status' ;
    rdfs:comment 'Current lifecycle status of the port call. Tracks progression from pre-arrival notification through departure. [ENUM-REF-CANDIDATE: pre_arrival|expected|arrived|berthed|working|completed|departed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoOpsEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cargo Ops End Timestamp' ;
    rdfs:comment 'Timestamp when all cargo loading or discharge operations were completed. Used for calculating working time and productivity.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cargoOpsStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cargo Ops Start Timestamp' ;
    rdfs:comment 'Timestamp when cargo loading or discharge operations commenced. Used for calculating working time and productivity.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstLineTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Line Timestamp' ;
    rdfs:comment 'Timestamp when the first mooring line was secured to the berth during berthing operations.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gangwayDownTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gangway Down Timestamp' ;
    rdfs:comment 'Timestamp when the gangway was lowered and secured, allowing personnel access to the vessel.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastLineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Line Timestamp' ;
    rdfs:comment 'Timestamp when the last mooring line was released during unberthing operations. Marks start of departure sequence.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pilotBoardedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pilot Boarded Timestamp' ;
    rdfs:comment 'Timestamp when the marine pilot boarded the vessel to guide it into port. First milestone in the arrival sequence.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pilotOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pilot Off Timestamp' ;
    rdfs:comment 'Timestamp when the marine pilot disembarked after guiding the vessel out of port. Final milestone in the departure sequence.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pod rdf:type rdf:Property ;
    rdfs:label 'Pod' ;
    rdfs:comment 'UN/LOCODE of the next port where cargo will be discharged after this call. Five-character code following UN/LOCODE standard.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pol rdf:type rdf:Property ;
    rdfs:label 'Pol' ;
    rdfs:comment 'UN/LOCODE of the port where cargo was loaded prior to this call. Five-character code following UN/LOCODE standard.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Primary reason for the vessel visit. Determines operational requirements and resource allocation. [ENUM-REF-CANDIDATE: loading|discharge|loading_discharge|bunkering|transit|lay_up|crew_change|repair|provisions — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFeuDeclared rdf:type rdf:Property ;
    rdfs:label 'Total Feu Declared' ;
    rdfs:comment 'Total number of FEU declared for loading and discharge operations during this call. Used for capacity planning and billing.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTeuDeclared rdf:type rdf:Property ;
    rdfs:label 'Total Teu Declared' ;
    rdfs:comment 'Total number of TEU declared for loading and discharge operations during this call. Used for capacity planning and billing.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vtsClearanceReference rdf:type rdf:Property ;
    rdfs:label 'Vts Clearance Reference' ;
    rdfs:comment 'Reference number issued by VTS granting clearance for vessel movement within port waters. Required for compliance with ISPS and port regulations.' ;
    rdfs:domain ind:Call ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callDocumentId rdf:type rdf:Property ;
    rdfs:label 'Call Document Id' ;
    rdfs:comment 'Primary key for call_document' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousDocumentCallDocumentId rdf:type rdf:Property ;
    rdfs:label 'Previous Document Call Document Id' ;
    rdfs:comment 'Reference to the previous version of this document if this is an amendment or resubmission.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CallDocument .

ind:reviewingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewing Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Port authority officers review FAL forms, cargo manifests, and ISPS declarations for regulatory compliance. Mandatory for customs clearance workflows, port health authority coordination, and IMO FAL C' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorityAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authority Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the regulatory authority acknowledged receipt or processed the document.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cargoManifestReference rdf:type rdf:Property ;
    rdfs:label 'Cargo Manifest Reference' ;
    rdfs:comment 'Reference number of the cargo manifest document. Applicable to cargo manifest documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewChangeCount rdf:type rdf:Property ;
    rdfs:label 'Crew Change Count' ;
    rdfs:comment 'Number of crew members joining or leaving the vessel during this port call. Applicable to crew list documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'Storage path or URI to the digital copy of the submitted document in the document management system.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Unique external reference number assigned to the document by the submitting party or regulatory authority.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falFormNumber rdf:type rdf:Property ;
    rdfs:label 'Fal Form Number' ;
    rdfs:comment 'IMO Facilitation (FAL) Convention form number if applicable (e.g., FAL Form 1 for General Declaration, FAL Form 5 for Crew List).' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthIllnessDescription rdf:type rdf:Property ;
    rdfs:label 'Health Illness Description' ;
    rdfs:comment 'Description of any illness, symptoms, or health conditions reported onboard. Applicable to health declaration documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthIllnessOnboardFlag rdf:type rdf:Property ;
    rdfs:label 'Health Illness Onboard Flag' ;
    rdfs:comment 'Indicates whether there are any cases of illness or health concerns onboard requiring port health notification. Applicable to health declaration documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthSanitationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Health Sanitation Certificate Number' ;
    rdfs:comment 'Ship Sanitation Certificate or Ship Sanitation Control Exemption Certificate number. Applicable to health declaration documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsCurrentSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Isps Current Security Level' ;
    rdfs:comment 'Current ship security level (1: normal, 2: heightened, 3: exceptional) as declared under ISPS Code. Applicable to ISPS security declaration documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ispsDosRequired rdf:type rdf:Property ;
    rdfs:label 'Isps Dos Required' ;
    rdfs:comment 'Indicates whether a Declaration of Security (DoS) is required for this port call under ISPS Code. Applicable to ISPS security declaration documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsIsscNumber rdf:type rdf:Property ;
    rdfs:label 'Isps Issc Number' ;
    rdfs:comment 'International Ship Security Certificate number issued under ISPS Code. Applicable to ISPS security declaration documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsLastTenPorts rdf:type rdf:Property ;
    rdfs:label 'Isps Last Ten Ports' ;
    rdfs:comment 'Comma-separated list of the last ten ports of call with their security levels, as required by ISPS Code. Applicable to ISPS security declaration documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsSecurityIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Isps Security Incident Flag' ;
    rdfs:comment 'Indicates whether any security incidents occurred since the last port of call. Applicable to ISPS security declaration documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsSsoName rdf:type rdf:Property ;
    rdfs:label 'Isps Sso Name' ;
    rdfs:comment 'Name of the Ship Security Officer (SSO) responsible for vessel security. Applicable to ISPS security declaration documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marpolWasteType rdf:type rdf:Property ;
    rdfs:label 'Marpol Waste Type' ;
    rdfs:comment 'Type of waste being declared according to MARPOL Annexes (I: oil, II: noxious liquid substances, III: harmful packaged substances, IV: sewage, V: garbage, VI: air emissions). Applicable only to waste notification documents. [ENUM-REF-CANDIDATE: annex_i_oil|annex_ii_noxious_liquid|annex_iii_harmful_packaged|annex_iv_sewage|annex_v_garbage|annex_vi_air_emissions — promote to reference product]' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receptionFacilityName rdf:type rdf:Property ;
    rdfs:label 'Reception Facility Name' ;
    rdfs:comment 'Name of the port reception facility that received the waste. Applicable to waste notification documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittingAgentName rdf:type rdf:Property ;
    rdfs:label 'Submitting Agent Name' ;
    rdfs:comment 'Name of the organization or individual who submitted the document on behalf of the vessel.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteActualVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Waste Actual Volume M3' ;
    rdfs:comment 'Actual volume of waste discharged at port reception facility, measured in cubic meters (CBM). Applicable to waste notification documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteDeliveryConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Delivery Confirmation Number' ;
    rdfs:comment 'Confirmation receipt number issued by the port reception facility upon waste delivery. Applicable to waste notification documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteEstimatedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Waste Estimated Volume M3' ;
    rdfs:comment 'Estimated volume of waste to be discharged at port reception facility, measured in cubic meters (CBM). Applicable to waste notification documents.' ;
    rdfs:domain ind:CallDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callScheduleId rdf:type rdf:Property ;
    rdfs:label 'Call Schedule Id' ;
    rdfs:comment 'Primary key for call_schedule' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allianceDesignation rdf:type rdf:Property ;
    rdfs:label 'Alliance Designation' ;
    rdfs:comment 'Name of the shipping alliance if this service is part of a carrier alliance (e.g., 2M, Ocean Alliance, THE Alliance). Null for independent services.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageVesselCapacityTeu rdf:type rdf:Property ;
    rdfs:label 'Average Vessel Capacity Teu' ;
    rdfs:comment 'Average container capacity in TEU of vessels deployed on this service. Used for capacity planning and commercial forecasting.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:berthPreference rdf:type rdf:Property ;
    rdfs:label 'Berth Preference' ;
    rdfs:comment 'Preferred berth or berth zone requested by the shipping line or agent for this scheduled call. Used in berth allocation planning.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Commercial Agreement Reference' ;
    rdfs:comment 'Reference to the commercial service agreement or contract governing this scheduled service. Links to tariff and SLA terms.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastCargoVolumeTeu rdf:type rdf:Property ;
    rdfs:label 'Forecast Cargo Volume Teu' ;
    rdfs:comment 'Forecasted container volume in TEU expected to be loaded and discharged at this port call. Used for yard planning and equipment allocation.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastDischargeTeu rdf:type rdf:Property ;
    rdfs:label 'Forecast Discharge Teu' ;
    rdfs:comment 'Forecasted number of TEU to be discharged from the vessel at this port call.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastLoadTeu rdf:type rdf:Property ;
    rdfs:label 'Forecast Load Teu' ;
    rdfs:comment 'Forecasted number of TEU to be loaded onto the vessel at this port call.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastRestowTeu rdf:type rdf:Property ;
    rdfs:label 'Forecast Restow Teu' ;
    rdfs:comment 'Forecasted number of TEU requiring restow operations (containers moved to optimize stowage). Impacts operational planning and berth time.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextPortCode rdf:type rdf:Property ;
    rdfs:label 'Next Port Code' ;
    rdfs:comment 'UN/LOCODE of the port immediately following this call in the rotation sequence. Used for cargo routing and stowage planning.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omissionReason rdf:type rdf:Property ;
    rdfs:label 'Omission Reason' ;
    rdfs:comment 'Explanation for why a scheduled port call was omitted or skipped (e.g., weather, operational delays, insufficient cargo). Populated when schedule_status is omitted.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingShippingLine rdf:type rdf:Property ;
    rdfs:label 'Operating Shipping Line' ;
    rdfs:comment 'Name of the primary shipping line or carrier operating this service. May include multiple lines in alliance services.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBerthWindowHours rdf:type rdf:Property ;
    rdfs:label 'Planned Berth Window Hours' ;
    rdfs:comment 'Expected duration in hours that the vessel will occupy the berth, calculated from planned ETB to planned ETD. Used for berth utilization planning.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEta rdf:type rdf:Property ;
    rdfs:label 'Planned Eta' ;
    rdfs:comment 'Scheduled estimated time when the vessel is expected to arrive at the port. Forward-looking planning timestamp provided by shipping line or agent.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedEtb rdf:type rdf:Property ;
    rdfs:label 'Planned Etb' ;
    rdfs:comment 'Scheduled estimated time when the vessel is expected to berth at the assigned terminal. Used for berth planning and resource allocation.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedEtd rdf:type rdf:Property ;
    rdfs:label 'Planned Etd' ;
    rdfs:comment 'Scheduled estimated time when the vessel is expected to depart from the port. Used for berth window planning and next port coordination.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portOfCallCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Call Code' ;
    rdfs:comment 'Five-letter UN/LOCODE identifying the port for this scheduled call (e.g., USNYC, SGSIN, NLRTM).' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousPortCode rdf:type rdf:Property ;
    rdfs:label 'Previous Port Code' ;
    rdfs:comment 'UN/LOCODE of the port immediately preceding this call in the rotation sequence. Used for voyage tracking and cargo routing.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationPortCount rdf:type rdf:Property ;
    rdfs:label 'Rotation Port Count' ;
    rdfs:comment 'Total number of ports in the complete service rotation. Provides context for the rotation sequence number.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rotationSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rotation Sequence Number' ;
    rdfs:comment 'Sequential position of this port call within the service rotation. Indicates the order of port visits in the voyage loop (e.g., 1 for first port, 2 for second).' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleEffectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Effective From Date' ;
    rdfs:comment 'Date from which this schedule version becomes effective. Supports schedule versioning and historical tracking.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleEffectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Effective To Date' ;
    rdfs:comment 'Date until which this schedule version remains effective. Null for current active schedules. Used for schedule supersession management.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schedulePublishedDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Published Date' ;
    rdfs:comment 'Date when this schedule was first published or communicated to the port. Used for schedule horizon management and planning lead time analysis.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Schedule Received Timestamp' ;
    rdfs:comment 'Timestamp when this schedule record was received by the port system. Used for audit trail and schedule update tracking.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleSource rdf:type rdf:Property ;
    rdfs:label 'Schedule Source' ;
    rdfs:comment 'Origin system or channel through which this schedule information was received (e.g., EDI from shipping line, agent portal submission, VTS pre-notification).' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current status of this scheduled port call. Tracks the lifecycle from initial provisional schedule through confirmation, amendments, or cancellation.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for this schedule record (e.g., 2024-01-V01). Allows tracking of schedule amendments and revisions over time.' ;
    rdfs:domain ind:CallSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFrequency rdf:type rdf:Property ;
    rdfs:label 'Service Frequency' ;
    rdfs:comment 'Frequency at which this service calls at the port (e.g., weekly, bi-weekly, monthly). Indicates the regularity of scheduled calls.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselStringSize rdf:type rdf:Property ;
    rdfs:label 'Vessel String Size' ;
    rdfs:comment 'Number of vessels deployed in this service rotation. Indicates the fleet size required to maintain the service frequency.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateId rdf:type rdf:Property ;
    rdfs:label 'Certificate Id' ;
    rdfs:comment 'Primary key for certificate' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pscInspectionId rdf:type rdf:Property ;
    rdfs:label 'Psc Inspection Id' ;
    rdfs:comment 'Unique identifier assigned by the PSC authority for the inspection event. Applicable when record_type is psc_inspection.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PscInspection .

ind:verificationOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verification Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Port operations staff verify vessel certificates (ISSC, class certificates, MARPOL) during clearance and PSC inspections. Required for port state control workflows, detention risk assessment, and regu' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualSurveyDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Survey Due Date' ;
    rdfs:comment 'Due date for the next annual survey required to maintain certificate validity. Annual surveys are typically required within 3 months before or after the anniversary date.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of statutory or class certificate. SOLAS (Safety of Life at Sea) certificates include Safety Construction, Safety Equipment, Safety Radio. MARPOL (Marine Pollution Convention) certificates include IOPP (International Oil Pollution Prevention), NLS (Noxious Liquid Substances). ISM (International Safety Management) includes DOC (Document of Compliance) and SMC (Safety Management Certificate). ISPS (International Ship and Port Facility Security) includes ISSC (International Ship Security Certificate). MLC (Maritime Labour Convention), Tonnage, Classification, CLC (Civil Liability Convention) / Bunker Convention certificates also tracked. [ENUM-REF-CANDIDATE: solas_safety_construction|solas_safety_equipment|solas_safety_radio|load_line|marpol_iopp|marpol_nls|ism_doc|ism_smc|isps_issc|mlc|tonnage|classification|clc_bunker_convention|other — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyCodes rdf:type rdf:Property ;
    rdfs:label 'Deficiency Codes' ;
    rdfs:comment 'Comma-separated list of deficiency codes identified during the PSC inspection, per the MOU convention deficiency code list. Examples: 01106 (Certificates & Documentation - SOLAS), 07113 (Fire Safety - Fire Doors), 11101 (Life-Saving Appliances - Lifeboats).' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionEndDate rdf:type rdf:Property ;
    rdfs:label 'Detention End Date' ;
    rdfs:comment 'Date on which the vessel detention was lifted after deficiencies were rectified and re-inspection was satisfactory. Applicable only if detention_flag is true.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detentionFlag rdf:type rdf:Property ;
    rdfs:label 'Detention Flag' ;
    rdfs:comment 'Boolean indicator of whether the vessel was detained as a result of the PSC inspection. True indicates detention occurred. False indicates no detention. Detention prevents the vessel from sailing until deficiencies are rectified.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detentionStartDate rdf:type rdf:Property ;
    rdfs:label 'Detention Start Date' ;
    rdfs:comment 'Date on which the vessel detention commenced following the PSC inspection. Applicable only if detention_flag is true.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpActionDescription rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Description' ;
    rdfs:comment 'Detailed description of the follow-up actions required, including rectification steps, re-inspection requirements, or flag state notifications.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Required' ;
    rdfs:comment 'Boolean indicator of whether follow-up action is required by the vessel operator or flag state. True indicates follow-up is needed. False indicates no further action required.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Inspecting Officer Name' ;
    rdfs:comment 'Name of the PSC officer who conducted the inspection. Business-confidential operational data.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPort rdf:type rdf:Property ;
    rdfs:label 'Inspection Port' ;
    rdfs:comment 'Name of the port where the PSC inspection was conducted.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPortCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Port Code' ;
    rdfs:comment 'UN/LOCODE or other standardized code for the port where the PSC inspection was conducted.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediateSurveyDueDate rdf:type rdf:Property ;
    rdfs:label 'Intermediate Survey Due Date' ;
    rdfs:comment 'Due date for the next intermediate survey, typically required at the second or third anniversary of the certificate issue date.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSurveyType rdf:type rdf:Property ;
    rdfs:label 'Last Survey Type' ;
    rdfs:comment 'Type of the most recent survey conducted. Annual surveys verify ongoing compliance. Intermediate surveys are more comprehensive mid-term inspections. Renewal surveys are conducted for certificate renewal. Special surveys address specific issues. Damage surveys assess vessel condition after incidents.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pscAuthority rdf:type rdf:Property ;
    rdfs:label 'Psc Authority' ;
    rdfs:comment 'Name of the PSC authority or MOU region that conducted the inspection. Examples: Paris MOU (Europe), Tokyo MOU (Asia-Pacific), Indian Ocean MOU, US Coast Guard, AMSA (Australian Maritime Safety Authority).' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pscAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Psc Authority Code' ;
    rdfs:comment 'Standardized code for the PSC authority or MOU region. Examples: PMOU (Paris MOU), TMOU (Tokyo MOU), IOMOU (Indian Ocean MOU), USCG (US Coast Guard).' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pscInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Psc Inspection Date' ;
    rdfs:comment 'Date on which the PSC inspection was conducted at the port.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Discriminator indicating whether this record represents a statutory/class certificate or a Port State Control (PSC) inspection event.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalSurveyDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Survey Due Date' ;
    rdfs:comment 'Due date for the renewal survey required to issue a new certificate upon expiry of the current certificate.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipRiskProfile rdf:type rdf:Property ;
    rdfs:label 'Ship Risk Profile' ;
    rdfs:comment 'Risk classification of the vessel based on PSC inspection history, flag state performance, recognized organization performance, company performance, and vessel age. Used for PSC targeting and inspection frequency determination per the New Inspection Regime (NIR) under Paris MOU and Tokyo MOU.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeficiencies rdf:type rdf:Property ;
    rdfs:label 'Total Deficiencies' ;
    rdfs:comment 'Total number of deficiencies identified during the PSC inspection. Used for ship risk profile calculation and detention risk assessment.' ;
    rdfs:domain ind:Certificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewListId rdf:type rdf:Property ;
    rdfs:label 'Crew List Id' ;
    rdfs:comment 'Primary key for crew_list' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Address' ;
    rdfs:comment 'Shore-based contact address for the crew member. Used for emergency contact and repatriation purposes.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewChangeType rdf:type rdf:Property ;
    rdfs:label 'Crew Change Type' ;
    rdfs:comment 'Indicates whether the crew member is joining the vessel, departing (signing off), remaining aboard, or in transit through the port. Critical for immigration and crew change coordination.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewListStatus rdf:type rdf:Property ;
    rdfs:label 'Crew List Status' ;
    rdfs:comment 'Current status of the crew member on this vessel port call. Tracks lifecycle from active service through sign-off or other separation events.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewMemberFamilyName rdf:type rdf:Property ;
    rdfs:label 'Crew Member Family Name' ;
    rdfs:comment 'Family name (surname) of the crew member as it appears on their passport or seafarer identity document. Required for immigration and security screening.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewMemberGivenName rdf:type rdf:Property ;
    rdfs:label 'Crew Member Given Name' ;
    rdfs:comment 'Given name (first name) of the crew member as it appears on their passport or seafarer identity document. Required for immigration and security screening.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewMemberMiddleName rdf:type rdf:Property ;
    rdfs:label 'Crew Member Middle Name' ;
    rdfs:comment 'Middle name or patronymic of the crew member if applicable. Optional field for complete name identification.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfJoiningVessel rdf:type rdf:Property ;
    rdfs:label 'Date Of Joining Vessel' ;
    rdfs:comment 'Date on which the crew member joined the vessel. Marks the start of their current tour of duty and is used to calculate sea service time.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedDateOfSigningOff rdf:type rdf:Property ;
    rdfs:label 'Expected Date Of Signing Off' ;
    rdfs:comment 'Anticipated date on which the crew member will sign off the vessel and complete their tour of duty. Used for crew change planning and relief scheduling.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedPortOfSigningOff rdf:type rdf:Property ;
    rdfs:label 'Expected Port Of Signing Off' ;
    rdfs:comment 'Name of the port where the crew member is expected to sign off the vessel. Used for crew change coordination and travel arrangements.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsScreeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Isps Screening Timestamp' ;
    rdfs:comment 'Date and time when ISPS security screening was completed for the crew member. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ispsSecurityScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Isps Security Screening Status' ;
    rdfs:comment 'Result of ISPS security screening for the crew member. Cleared status is required for vessel operations in ISPS-compliant ports.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Number' ;
    rdfs:comment 'Medical certificate number confirming the crew member is medically fit for sea service. Required under ILO Maritime Labour Convention.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextOfKinName rdf:type rdf:Property ;
    rdfs:label 'Next Of Kin Name' ;
    rdfs:comment 'Full name of the crew member\'s next of kin or emergency contact person. Critical for emergency notifications and repatriation.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextOfKinPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Next Of Kin Phone Number' ;
    rdfs:comment 'Contact phone number for the crew member\'s next of kin. Primary channel for emergency notifications.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextOfKinRelationship rdf:type rdf:Property ;
    rdfs:label 'Next Of Kin Relationship' ;
    rdfs:comment 'Relationship of the next of kin to the crew member (e.g., spouse, parent, sibling). Used for emergency contact prioritization.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Passport Expiry Date' ;
    rdfs:comment 'Date on which the crew member\'s passport expires. Must be valid for the duration of the port call and voyage to meet immigration requirements.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportIssueDate rdf:type rdf:Property ;
    rdfs:label 'Passport Issue Date' ;
    rdfs:comment 'Date on which the crew member\'s passport was issued. Used to verify document validity and authenticity.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportIssuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Passport Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the country that issued the crew member\'s passport. May differ from nationality in some cases.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfBirth rdf:type rdf:Property ;
    rdfs:label 'Place Of Birth' ;
    rdfs:comment 'City and country where the crew member was born. May be required by certain port state authorities for immigration processing.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfJoining rdf:type rdf:Property ;
    rdfs:label 'Port Of Joining' ;
    rdfs:comment 'Name of the port where the crew member joined the vessel. Used for crew change tracking and repatriation planning.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rankPosition rdf:type rdf:Property ;
    rdfs:label 'Rank Position' ;
    rdfs:comment 'The crew member\'s rank or position aboard the vessel as per the ship\'s crew list. Determines responsibilities and STCW certification requirements. [ENUM-REF-CANDIDATE: master|chief_officer|second_officer|third_officer|chief_engineer|second_engineer|third_engineer|bosun|able_seaman|ordinary_seaman|deck_cadet|engine_cadet|radio_officer|electrician|fitter|oiler|wiper|cook|steward|messman|pumpman|other — 22 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seafarersBookExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Seafarers Book Expiry Date' ;
    rdfs:comment 'Date on which the seafarer\'s book expires. Must be valid for the crew member to serve aboard the vessel.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seafarersBookIssueDate rdf:type rdf:Property ;
    rdfs:label 'Seafarers Book Issue Date' ;
    rdfs:comment 'Date on which the seafarer\'s book was issued. Used to verify document validity and seafaring experience.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seafarersBookNumber rdf:type rdf:Property ;
    rdfs:label 'Seafarers Book Number' ;
    rdfs:comment 'Seafarer\'s discharge book or continuous discharge certificate number. Official record of sea service and qualifications issued by flag state.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shoreLeaveAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Shore Leave Authorized Flag' ;
    rdfs:comment 'Indicates whether the crew member has been authorized for shore leave by port immigration authorities. True if authorized, false if restricted to vessel.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stcwCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Stcw Certificate Expiry Date' ;
    rdfs:comment 'Date on which the STCW certificate expires. Crew member must hold valid certification to serve in their assigned rank.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stcwCertificateGrade rdf:type rdf:Property ;
    rdfs:label 'Stcw Certificate Grade' ;
    rdfs:comment 'Grade or level of the STCW certificate held by the crew member (e.g., Master Unlimited, Chief Engineer, Officer of the Watch). Determines authorized duties.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stcwCertificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Stcw Certificate Issue Date' ;
    rdfs:comment 'Date on which the STCW certificate was issued. Used to verify currency of qualifications.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stcwCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Stcw Certificate Number' ;
    rdfs:comment 'Certificate of competency number issued under the STCW Convention. Validates that the crew member holds the required qualifications for their rank.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaccinationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Vaccination Certificate Number' ;
    rdfs:comment 'International certificate of vaccination number (yellow card). May be required by port health authorities for entry into certain jurisdictions.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Visa Expiry Date' ;
    rdfs:comment 'Date on which the crew member\'s visa expires. Must be valid for the duration of the port call if shore leave is requested.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visaNumber rdf:type rdf:Property ;
    rdfs:label 'Visa Number' ;
    rdfs:comment 'Visa number if the crew member holds a visa for the port state. Required for shore leave authorization and immigration compliance.' ;
    rdfs:domain ind:CrewList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftSurveyId rdf:type rdf:Property ;
    rdfs:label 'Draft Survey Id' ;
    rdfs:comment 'Primary key for draft_survey' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableWharfageScheduleId rdf:type rdf:Property ;
    rdfs:label 'Applicable Wharfage Schedule Id' ;
    rdfs:comment 'Foreign key linking to tariff.wharfage_schedule. Business justification: Draft surveys determine cargo weight (calculated_cargo_weight_mt) which directly drives wharfage charges under weight-based tariff schedules. Essential for wharfage billing calculation, cargo tonnage-' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WharfageSchedule .

ind:primaryDraftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Draft Employee Id' ;
    rdfs:comment 'Identifier of the system user who created this draft survey record. Audit trail for accountability.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aftDraftPortMeters rdf:type rdf:Property ;
    rdfs:label 'Aft Draft Port Meters' ;
    rdfs:comment 'Draft reading at the aft perpendicular on the port side of the vessel, measured in meters from the waterline to the keel.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aftDraftStarboardMeters rdf:type rdf:Property ;
    rdfs:label 'Aft Draft Starboard Meters' ;
    rdfs:comment 'Draft reading at the aft perpendicular on the starboard side of the vessel, measured in meters from the waterline to the keel.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ballastWaterMt rdf:type rdf:Property ;
    rdfs:label 'Ballast Water Mt' ;
    rdfs:comment 'Weight of ballast water on board the vessel at the time of survey, measured in metric tons. Deducted from displacement to calculate cargo weight.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bunkerFuelMt rdf:type rdf:Property ;
    rdfs:label 'Bunker Fuel Mt' ;
    rdfs:comment 'Weight of bunker fuel oil on board the vessel at the time of survey, measured in metric tons. Deducted from displacement to calculate cargo weight.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedCargoWeightMt rdf:type rdf:Property ;
    rdfs:label 'Calculated Cargo Weight Mt' ;
    rdfs:comment 'Net weight of cargo loaded or discharged, calculated by subtracting lightship weight, constant, bunkers, water, ballast, and stores from the displacement. Measured in metric tons. This is the principal quantitative result of the draft survey.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date on which the draft survey certificate was officially issued by the surveyor.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Flag' ;
    rdfs:comment 'Indicates whether a formal draft survey certificate has been issued for this survey. True if certificate issued, False otherwise.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constantMt rdf:type rdf:Property ;
    rdfs:label 'Constant Mt' ;
    rdfs:comment 'Constant correction factor representing the difference between the actual lightship weight and the documented lightship weight, measured in metric tons. Accounts for permanent additions or removals since last lightship survey.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displacementMt rdf:type rdf:Property ;
    rdfs:label 'Displacement Mt' ;
    rdfs:comment 'Total weight of water displaced by the vessel at the surveyed draft, measured in metric tons. Derived from hydrostatic tables and draft readings.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dwaAllowanceMm rdf:type rdf:Property ;
    rdfs:label 'Dwa Allowance Mm' ;
    rdfs:comment 'Dock water allowance correction applied when the vessel is in water of intermediate density between salt and fresh water, measured in millimeters.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forwardDraftPortMeters rdf:type rdf:Property ;
    rdfs:label 'Forward Draft Port Meters' ;
    rdfs:comment 'Draft reading at the forward perpendicular on the port side of the vessel, measured in meters from the waterline to the keel.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forwardDraftStarboardMeters rdf:type rdf:Property ;
    rdfs:label 'Forward Draft Starboard Meters' ;
    rdfs:comment 'Draft reading at the forward perpendicular on the starboard side of the vessel, measured in meters from the waterline to the keel.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freshWaterMt rdf:type rdf:Property ;
    rdfs:label 'Fresh Water Mt' ;
    rdfs:comment 'Weight of fresh water on board the vessel at the time of survey, measured in metric tons. Deducted from displacement to calculate cargo weight.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fwaAllowanceMm rdf:type rdf:Property ;
    rdfs:label 'Fwa Allowance Mm' ;
    rdfs:comment 'Fresh water allowance correction applied when the vessel is in fresh water or dock water, measured in millimeters. Accounts for the difference in buoyancy between salt and fresh water.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lightshipWeightMt rdf:type rdf:Property ;
    rdfs:label 'Lightship Weight Mt' ;
    rdfs:comment 'Weight of the vessel in light condition (empty, without cargo, fuel, water, stores), measured in metric tons. Used as baseline for cargo weight calculation.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listDegrees rdf:type rdf:Property ;
    rdfs:label 'List Degrees' ;
    rdfs:comment 'Transverse inclination of the vessel measured in degrees. Positive value indicates list to starboard, negative indicates list to port.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanAftDraftMeters rdf:type rdf:Property ;
    rdfs:label 'Mean Aft Draft Meters' ;
    rdfs:comment 'Average of port and starboard aft draft readings, used in displacement calculations.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanDraftMeters rdf:type rdf:Property ;
    rdfs:label 'Mean Draft Meters' ;
    rdfs:comment 'Overall mean draft of the vessel calculated from forward, midship, and aft draft readings, used as the primary input for displacement calculation.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanForwardDraftMeters rdf:type rdf:Property ;
    rdfs:label 'Mean Forward Draft Meters' ;
    rdfs:comment 'Average of port and starboard forward draft readings, used in displacement calculations.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanMidshipDraftMeters rdf:type rdf:Property ;
    rdfs:label 'Mean Midship Draft Meters' ;
    rdfs:comment 'Average of port and starboard midship draft readings, used in displacement calculations.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:midshipDraftPortMeters rdf:type rdf:Property ;
    rdfs:label 'Midship Draft Port Meters' ;
    rdfs:comment 'Draft reading at the midship section on the port side of the vessel, measured in meters from the waterline to the keel.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:midshipDraftStarboardMeters rdf:type rdf:Property ;
    rdfs:label 'Midship Draft Starboard Meters' ;
    rdfs:comment 'Draft reading at the midship section on the starboard side of the vessel, measured in meters from the waterline to the keel.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storesProvisionsMt rdf:type rdf:Property ;
    rdfs:label 'Stores Provisions Mt' ;
    rdfs:comment 'Weight of stores, provisions, and consumables on board the vessel at the time of survey, measured in metric tons. Deducted from displacement to calculate cargo weight.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyAccuracyRating rdf:type rdf:Property ;
    rdfs:label 'Survey Accuracy Rating' ;
    rdfs:comment 'Surveyor\'s assessment of the accuracy and reliability of the draft survey results based on conditions and measurement quality: excellent, good, fair, or poor.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyDatetime rdf:type rdf:Property ;
    rdfs:label 'Survey Datetime' ;
    rdfs:comment 'Date and time when the draft survey was conducted. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyPurpose rdf:type rdf:Property ;
    rdfs:label 'Survey Purpose' ;
    rdfs:comment 'Business purpose for conducting the draft survey: cargo weight verification, load line compliance check, demurrage calculation support, charter party contractual requirement, customs declaration, or insurance claim documentation.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Current lifecycle status of the draft survey: draft (in progress), completed (survey finished), certified (certificate issued), disputed (under dispute), or cancelled.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorCompanyName rdf:type rdf:Property ;
    rdfs:label 'Surveyor Company Name' ;
    rdfs:comment 'Name of the marine surveyor company or independent surveyor who conducted the draft survey.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimMeters rdf:type rdf:Property ;
    rdfs:label 'Trim Meters' ;
    rdfs:comment 'Difference between forward and aft drafts. Positive value indicates trim by stern (aft deeper), negative indicates trim by bow (forward deeper).' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterDensityKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Water Density Kg Per M3' ;
    rdfs:comment 'Density of the water in which the vessel is floating at the time of survey, measured in kilograms per cubic meter. Used for displacement corrections.' ;
    rdfs:domain ind:DraftSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ispsRecordId rdf:type rdf:Property ;
    rdfs:label 'Isps Record Id' ;
    rdfs:comment 'Primary key for isps_record' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Security Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Port Facility Security Officers (PFSO) manage ISPS compliance, sign Declarations of Security, and coordinate security measures. Mandatory under ISPS Code for security incident reporting, DoS managemen' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:additionalSecurityMeasuresApplied rdf:type rdf:Property ;
    rdfs:label 'Additional Security Measures Applied' ;
    rdfs:comment 'Description of any additional or special security measures applied beyond standard procedures, such as enhanced screening, armed guards, restricted access zones, or increased surveillance.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerificationOfficerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Verification Officer Name' ;
    rdfs:comment 'Name of the port security officer or authority representative who conducted the ISPS compliance verification for this port call.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Verification Status' ;
    rdfs:comment 'Status of the ISPS compliance verification for this port call. Compliant = all requirements met, Non-compliant = deficiencies identified, Pending Verification = under review, Conditional Approval = approved with conditions, Rejected = entry denied.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Verification Timestamp' ;
    rdfs:comment 'Date and time when the ISPS compliance verification was completed by the Port Facility Security Officer or designated authority.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controlMeasuresImposed rdf:type rdf:Property ;
    rdfs:label 'Control Measures Imposed' ;
    rdfs:comment 'Description of any control measures imposed by the port state control authority in response to identified deficiencies, such as detention, expulsion, restrictions on operations, or requirement for rectification before departure.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationOfSecurityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Of Security Reference Number' ;
    rdfs:comment 'Unique reference number assigned to the Declaration of Security document agreed between the ship and the port facility. Null if DoS is not required.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationOfSecurityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Declaration Of Security Required Flag' ;
    rdfs:comment 'Indicates whether a Declaration of Security is required for this port call. True if security level is 2 or 3, or if ship-to-ship activity is planned, or if requested by either party.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declarationOfSecuritySignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Declaration Of Security Signed Timestamp' ;
    rdfs:comment 'Date and time when the Declaration of Security was signed by both the Ship Security Officer and the Port Facility Security Officer. Null if DoS is not required.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deficiencyIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Deficiency Identified Flag' ;
    rdfs:comment 'Indicates whether any ISPS compliance deficiencies were identified during the verification process. True if deficiencies were found.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isscCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Issc Certificate Number' ;
    rdfs:comment 'The unique certificate number of the vessel\'s valid ISSC issued by the flag state or recognized security organization. Mandatory for vessels engaged in international voyages.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isscIssueDate rdf:type rdf:Property ;
    rdfs:label 'Issc Issue Date' ;
    rdfs:comment 'Date when the ISSC certificate was issued to the vessel.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isscIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issc Issuing Authority' ;
    rdfs:comment 'Name of the flag state administration or recognized security organization that issued the ISSC certificate.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTenPortsOfCall rdf:type rdf:Property ;
    rdfs:label 'Last Ten Ports Of Call' ;
    rdfs:comment 'Comma-separated list of the last ten ports where the vessel called, including port name and country code. Required for security risk assessment and ISPS compliance verification.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTenPortsSecurityLevels rdf:type rdf:Property ;
    rdfs:label 'Last Ten Ports Security Levels' ;
    rdfs:comment 'Comma-separated list of security levels (1, 2, or 3) at which the vessel operated at each of the last ten ports of call. Corresponds to the ports listed in last_ten_ports_of_call.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portFacilitySecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Port Facility Security Level' ;
    rdfs:comment 'Security level set by the port facility at the time of the vessel\'s arrival. Level 1 = normal, Level 2 = heightened, Level 3 = exceptional.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portFacilitySecurityOfficerContact rdf:type rdf:Property ;
    rdfs:label 'Port Facility Security Officer Contact' ;
    rdfs:comment 'Contact phone number or communication channel for the Port Facility Security Officer during the vessel\'s port call.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portFacilitySecurityOfficerName rdf:type rdf:Property ;
    rdfs:label 'Port Facility Security Officer Name' ;
    rdfs:comment 'Full name of the Port Facility Security Officer responsible for the development, implementation, and maintenance of the port facility security plan.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preArrivalSecurityInformationSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Arrival Security Information Submitted Flag' ;
    rdfs:comment 'Indicates whether the vessel submitted the required pre-arrival security information to the port facility within the mandated timeframe (typically 24-96 hours before arrival).' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preArrivalSecurityInformationSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pre Arrival Security Information Submitted Timestamp' ;
    rdfs:comment 'Date and time when the vessel submitted the pre-arrival security information to the port facility.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securityIncidentDescription rdf:type rdf:Property ;
    rdfs:label 'Security Incident Description' ;
    rdfs:comment 'Detailed description of any security incident, breach, or threat that occurred during the port call. Null if no incident occurred. Confidential information for security management.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityIncidentReportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Security Incident Reported Timestamp' ;
    rdfs:comment 'Date and time when the security incident was first reported to the port facility or relevant authorities. Null if no incident occurred.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securityMeasuresInPlace rdf:type rdf:Property ;
    rdfs:label 'Security Measures In Place' ;
    rdfs:comment 'Description of specific security measures implemented for this port call, including access control, surveillance, cargo screening, and perimeter security. May reference the Ship Security Plan and Port Facility Security Plan.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Ship Security Level' ;
    rdfs:comment 'Current security level at which the ship is operating at the time of port call. Level 1 = normal, Level 2 = heightened, Level 3 = exceptional. Must align with port facility security level or higher.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipSecurityOfficerContact rdf:type rdf:Property ;
    rdfs:label 'Ship Security Officer Contact' ;
    rdfs:comment 'Contact phone number or radio call sign for the Ship Security Officer during the port call.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipSecurityOfficerName rdf:type rdf:Property ;
    rdfs:label 'Ship Security Officer Name' ;
    rdfs:comment 'Full name of the designated Ship Security Officer responsible for implementing and maintaining the ship security plan on board the vessel.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToShipActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Ship To Ship Activity Description' ;
    rdfs:comment 'Description of ship-to-ship activities conducted, including the name and IMO number of the other vessel, type of activity (cargo transfer, bunkering, etc.), and location. Null if no ship-to-ship activity occurred.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToShipActivityFlag rdf:type rdf:Property ;
    rdfs:label 'Ship To Ship Activity Flag' ;
    rdfs:comment 'Indicates whether the vessel engaged in ship-to-ship activities during this port call. Ship-to-ship activities require additional security coordination and may mandate a Declaration of Security.' ;
    rdfs:domain ind:IspsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:movementId rdf:type rdf:Property ;
    rdfs:label 'Movement Id' ;
    rdfs:comment 'Primary key for movement' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airDraftMeters rdf:type rdf:Property ;
    rdfs:label 'Air Draft Meters' ;
    rdfs:comment 'Vertical distance from the waterline to the highest point of the vessel at the time of movement, measured in meters. Critical for clearance under bridges and overhead structures.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dangerousCargoFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Cargo Flag' ;
    rdfs:comment 'Indicates whether the vessel is carrying dangerous goods (IMDG cargo) during this movement. True if dangerous cargo is on board, False otherwise. Triggers special handling and notification procedures.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delayMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Minutes' ;
    rdfs:comment 'Delay time in minutes compared to scheduled movement timestamp. Positive value indicates late movement, zero indicates on-time. Used for SLA (Service Level Agreement) performance tracking.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftAftMeters rdf:type rdf:Property ;
    rdfs:label 'Draft Aft Meters' ;
    rdfs:comment 'Vessel\'s draft at the aft perpendicular at the time of movement, measured in meters. Used with forward draft to calculate trim and ensure safe passage.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:draftForwardMeters rdf:type rdf:Property ;
    rdfs:label 'Draft Forward Meters' ;
    rdfs:comment 'Vessel\'s draft at the forward perpendicular at the time of movement, measured in meters. Critical for safe navigation and channel depth clearance verification.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headingDegrees rdf:type rdf:Property ;
    rdfs:label 'Heading Degrees' ;
    rdfs:comment 'Vessel\'s heading in degrees (0-360) at the time of movement. 0/360 represents North, 90 represents East, 180 represents South, 270 represents West.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Number' ;
    rdfs:comment 'Business identifier for the movement event, typically assigned by VTS (Vessel Traffic Service) or port operations. Externally-known reference number for this movement.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the movement event. Tracks the movement through its workflow from scheduling to completion.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'The actual date and time when the movement event occurred. Principal business event timestamp for this transaction. Recorded in UTC and converted to local port time for operational reporting.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pilotOnBoardFlag rdf:type rdf:Property ;
    rdfs:label 'Pilot On Board Flag' ;
    rdfs:comment 'Indicates whether a marine pilot was on board the vessel during this movement. True if pilot was present, False otherwise. Critical for safety and regulatory compliance tracking.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Movement Timestamp' ;
    rdfs:comment 'The planned date and time for the movement event. Used for comparison against actual movement timestamp to calculate delays and measure operational performance.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:speedOverGroundKnots rdf:type rdf:Property ;
    rdfs:label 'Speed Over Ground Knots' ;
    rdfs:comment 'Vessel\'s speed over ground at the time of movement, measured in knots. Captured from AIS (Automatic Identification System) or VTS radar tracking.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tideHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Tide Height Meters' ;
    rdfs:comment 'Tidal height above chart datum at the time of movement, measured in meters. Critical for under-keel clearance calculations.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tugAssistanceFlag rdf:type rdf:Property ;
    rdfs:label 'Tug Assistance Flag' ;
    rdfs:comment 'Indicates whether tug assistance was provided during this movement. True if tugs were used, False otherwise. Important for operational cost allocation and safety analysis.' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vtsReportingChannel rdf:type rdf:Property ;
    rdfs:label 'Vts Reporting Channel' ;
    rdfs:comment 'VHF radio channel used for VTS communication during this movement. Typically a designated port operations channel (e.g., Channel 12, Channel 14).' ;
    rdfs:domain ind:Movement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerId rdf:type rdf:Property ;
    rdfs:label 'Owner Id' ;
    rdfs:comment 'Primary key for owner' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAccountReference rdf:type rdf:Property ;
    rdfs:label 'Billing Account Reference' ;
    rdfs:comment 'Reference to the billing account used for invoicing port charges and services to this owning or managing company. Links vessel operations to commercial billing relationships.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFax rdf:type rdf:Property ;
    rdfs:label 'Contact Fax' ;
    rdfs:comment 'Fax number for formal document transmission to the owning or managing company, still used in maritime industry for official correspondence.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfDomicile rdf:type rdf:Property ;
    rdfs:label 'Country Of Domicile' ;
    rdfs:comment 'The three-letter ISO country code representing the country where the owning or managing company is legally domiciled or incorporated.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Doc Certificate Number' ;
    rdfs:comment 'The certificate number of the Document of Compliance issued to the ISM company demonstrating compliance with the International Safety Management Code. Required for ISM company role type and PSC inspections.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Doc Expiry Date' ;
    rdfs:comment 'The expiration date of the Document of Compliance certificate. Used for compliance monitoring and PSC inspection readiness.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:docIssueDate rdf:type rdf:Property ;
    rdfs:label 'Doc Issue Date' ;
    rdfs:comment 'The date on which the Document of Compliance certificate was issued to the ISM company by the flag state or recognized organization.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isBeneficialOwner rdf:type rdf:Property ;
    rdfs:label 'Is Beneficial Owner' ;
    rdfs:comment 'Boolean flag indicating whether this entity is the beneficial owner (ultimate economic owner) of the vessel, as opposed to nominee or registered owner. Critical for anti-money laundering (AML) compliance and transparency requirements.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Date' ;
    rdfs:comment 'The date when KYC verification was completed or last updated for this owning or managing company. Used for compliance monitoring and re-verification scheduling.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Status' ;
    rdfs:comment 'Status of Know Your Customer due diligence verification for this owning or managing company. Verified indicates completed and approved KYC checks, pending for in-progress verification, failed for rejected applications, expired for verifications requiring renewal.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementContractReference rdf:type rdf:Property ;
    rdfs:label 'Management Contract Reference' ;
    rdfs:comment 'Reference number of the ship management contract or agreement governing this management relationship. Applicable for technical manager, commercial operator, and ship manager role types.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipRoleType rdf:type rdf:Property ;
    rdfs:label 'Ownership Role Type' ;
    rdfs:comment 'The type of ownership or management relationship this entity has with the vessel. Registered owner holds legal title, technical manager handles maintenance and crewing, commercial operator (disponent owner) manages commercial operations, ISM company is responsible for International Safety Management Code compliance, ship manager provides comprehensive vessel management services, bareboat charterer has operational control under charter agreement.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Current lifecycle status of this ownership or management relationship. Active indicates current valid relationship, inactive for historical records, pending transfer during ownership change process, terminated for formally ended relationships.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pniCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Pni Certificate Number' ;
    rdfs:comment 'The certificate number for the P&I insurance coverage. Required for port entry clearance and commercial operations.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pniClubName rdf:type rdf:Property ;
    rdfs:label 'Pni Club Name' ;
    rdfs:comment 'The name of the Protection and Indemnity insurance club providing liability coverage for the vessel under this ownership arrangement. Critical for claims management and port entry requirements.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddress rdf:type rdf:Property ;
    rdfs:label 'Registered Address' ;
    rdfs:comment 'The full registered business address of the owning or managing company as recorded in official maritime registries.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Port authority assigns internal coordinators to liaise with PSC inspectors, manage documentation, and track rectification. Required for compliance management, detention cost recovery, and port state c' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:areasInspected rdf:type rdf:Property ;
    rdfs:label 'Areas Inspected' ;
    rdfs:comment 'Comma-separated list of vessel areas and systems inspected during the PSC inspection (e.g., bridge, engine room, accommodation, safety equipment, cargo holds, pollution prevention equipment).' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificatesChecked rdf:type rdf:Property ;
    rdfs:label 'Certificates Checked' ;
    rdfs:comment 'Comma-separated list of statutory certificates and documents verified during the inspection (e.g., Safety Construction Certificate, Load Line Certificate, IOPP Certificate, Minimum Safe Manning Document, ISPS Certificate).' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearGroundsObserved rdf:type rdf:Property ;
    rdfs:label 'Clear Grounds Observed' ;
    rdfs:comment 'Description of any clear grounds (overriding or unexpected factors) that justified a more detailed or expanded inspection beyond the initial inspection scope.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conventionsChecked rdf:type rdf:Property ;
    rdfs:label 'Conventions Checked' ;
    rdfs:comment 'Comma-separated list of international maritime conventions under which deficiencies were assessed (e.g., SOLAS, MARPOL, Load Lines, STCW, MLC, Tonnage, COLREG, ILO).' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewInterviewedCount rdf:type rdf:Property ;
    rdfs:label 'Crew Interviewed Count' ;
    rdfs:comment 'Number of crew members interviewed during the PSC inspection to verify competency, working conditions, and compliance with Maritime Labour Convention requirements.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detentionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Detention Duration Hours' ;
    rdfs:comment 'Total duration of vessel detention in hours, calculated from detention start to detention end. Null if vessel was not detained.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detentionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detention End Timestamp' ;
    rdfs:comment 'Timestamp when the vessel detention was lifted after satisfactory rectification of deficiencies. Null if vessel was not detained or detention is ongoing.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flagStateNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Flag State Notification Date' ;
    rdfs:comment 'Date on which the flag state administration was notified of the inspection results. Null if flag state was not notified.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flagStateNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Flag State Notified Flag' ;
    rdfs:comment 'Indicates whether the vessel\'s flag state administration was notified of the inspection results, particularly in cases of detention or serious deficiencies.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpPort rdf:type rdf:Property ;
    rdfs:label 'Follow Up Port' ;
    rdfs:comment 'Name of the port where follow-up inspection is scheduled or recommended to verify deficiency rectification. Null if no follow-up required.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCostUsd rdf:type rdf:Property ;
    rdfs:label 'Inspection Cost Usd' ;
    rdfs:comment 'Total cost incurred by the port authority for conducting the PSC inspection, including inspector time, administrative overhead, and any third-party expert fees. Recorded in USD for standardized reporting.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionReason rdf:type rdf:Property ;
    rdfs:label 'Inspection Reason' ;
    rdfs:comment 'Primary reason or trigger for conducting the PSC inspection: routine selection, priority vessel (high-risk profile), overriding factors (clear grounds), unexpected factors (observed deficiencies), follow-up, complaint from crew or third party, incident-related, or part of a Concentrated Inspection Campaign. [ENUM-REF-CANDIDATE: routine|priority_vessel|overriding_factors|unexpected_factors|follow_up|complaint|incident_related|cic_campaign — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRegime rdf:type rdf:Property ;
    rdfs:label 'Inspection Regime' ;
    rdfs:comment 'Regional Memorandum of Understanding (MOU) or national regime under which the inspection was conducted, determining applicable standards and procedures. [ENUM-REF-CANDIDATE: paris_mou|tokyo_mou|indian_ocean_mou|caribbean_mou|mediterranean_mou|black_sea_mou|riyadh_mou|abuja_mou|vina_del_mar_mou|uscg|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRemarks rdf:type rdf:Property ;
    rdfs:label 'Inspection Remarks' ;
    rdfs:comment 'Additional remarks, observations, or contextual notes recorded by the PSC inspectors regarding the inspection, vessel condition, or cooperation of the crew.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsSecurityLevelAtInspection rdf:type rdf:Property ;
    rdfs:label 'Isps Security Level At Inspection' ;
    rdfs:comment 'ISPS security level in effect at the port facility at the time of the PSC inspection: Level 1 (normal), Level 2 (heightened), or Level 3 (exceptional).' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadInspectorCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Lead Inspector Certificate Number' ;
    rdfs:comment 'Official certificate or license number of the lead PSC inspector, verifying their authorization to conduct inspections.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadInspectorName rdf:type rdf:Property ;
    rdfs:label 'Lead Inspector Name' ;
    rdfs:comment 'Full name of the lead PSC inspector who conducted the inspection.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterNotifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Master Notified Timestamp' ;
    rdfs:comment 'Timestamp when the vessel master was formally notified of the inspection findings and any deficiencies or detention orders.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portStateControlReportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Port State Control Report Issued Date' ;
    rdfs:comment 'Date on which the formal PSC inspection report was issued to the vessel master and relevant authorities.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pscAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Psc Authority Name' ;
    rdfs:comment 'Name of the national maritime authority or agency that conducted the inspection (e.g., Maritime and Port Authority, Coast Guard, Flag State Administration).' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedOrganizationNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Recognized Organization Notified Flag' ;
    rdfs:comment 'Indicates whether the Recognized Organization (classification society) that issued the vessel\'s statutory certificates was notified of deficiencies related to their certification scope.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rectificationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Rectification Deadline Date' ;
    rdfs:comment 'Date by which all identified deficiencies must be rectified, as specified by the PSC authority. May be immediate (before departure), within 14 days, or at next port.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalDeficienciesFound rdf:type rdf:Property ;
    rdfs:label 'Total Deficiencies Found' ;
    rdfs:comment 'Total count of deficiencies identified during the PSC inspection across all areas and conventions checked.' ;
    rdfs:domain ind:PscInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceRouteId rdf:type rdf:Property ;
    rdfs:label 'Service Route Id' ;
    rdfs:comment 'Primary key for service_route' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredBerthId rdf:type rdf:Property ;
    rdfs:label 'Preferred Berth Id' ;
    rdfs:comment 'Identifier of the preferred or contracted berth for this service. Used in berth allocation planning and service level agreement management.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Berth .

ind:allianceName rdf:type rdf:Property ;
    rdfs:label 'Alliance Name' ;
    rdfs:comment 'Name of the shipping alliance or consortium operating the service (e.g., 2M Alliance, THE Alliance, Ocean Alliance). Null if service is operated by a single carrier outside alliance framework.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allianceServiceDesignation rdf:type rdf:Property ;
    rdfs:label 'Alliance Service Designation' ;
    rdfs:comment 'Alliance-level service identifier or designation code used when multiple carriers jointly operate the service under a shared service agreement.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageVesselBeamMeters rdf:type rdf:Property ;
    rdfs:label 'Average Vessel Beam Meters' ;
    rdfs:comment 'Average beam (width) in meters of vessels deployed on this service. Used for berth compatibility assessment and safe navigation planning.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageVesselDraftMeters rdf:type rdf:Property ;
    rdfs:label 'Average Vessel Draft Meters' ;
    rdfs:comment 'Average maximum draft in meters of vessels deployed on this service. Critical for ensuring channel depth and berth depth compatibility, and for tide-dependent berthing planning.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageVesselLoaMeters rdf:type rdf:Property ;
    rdfs:label 'Average Vessel Loa Meters' ;
    rdfs:comment 'Average length overall in meters of vessels deployed on this service. LOA is critical for berth allocation planning and ensuring adequate berth length availability.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dangerousCargoPercentage rdf:type rdf:Property ;
    rdfs:label 'Dangerous Cargo Percentage' ;
    rdfs:comment 'Expected percentage of container volume classified as dangerous goods under IMDG Code. Used for safety planning, segregation requirements, and regulatory compliance.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedContainerVolumeTeu rdf:type rdf:Property ;
    rdfs:label 'Expected Container Volume Teu' ;
    rdfs:comment 'Forecasted or contracted container volume in TEU per vessel call for this service at this port. Used for yard planning, equipment allocation, and commercial performance tracking.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exportVolumePercentage rdf:type rdf:Property ;
    rdfs:label 'Export Volume Percentage' ;
    rdfs:comment 'Expected percentage of total container volume that is export (loading) cargo. Used for yard planning and gate operation forecasting.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:importVolumePercentage rdf:type rdf:Property ;
    rdfs:label 'Import Volume Percentage' ;
    rdfs:comment 'Expected percentage of total container volume that is import (discharge) cargo. Used for yard planning and gate operation forecasting. Complement is export and transshipment volume.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCallDate rdf:type rdf:Property ;
    rdfs:label 'Last Call Date' ;
    rdfs:comment 'Date of the most recent vessel call for this service at this port. Used for service activity monitoring and performance tracking.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledCallDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Call Date' ;
    rdfs:comment 'Date of the next scheduled vessel call for this service at this port. Used for near-term berth planning and operational readiness.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portCallSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Port Call Sequence Number' ;
    rdfs:comment 'Sequential position of this port within the service rotation (e.g., 1 for first port, 2 for second port). Used for berth window planning and voyage sequencing.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portRotationSequence rdf:type rdf:Property ;
    rdfs:label 'Port Rotation Sequence' ;
    rdfs:comment 'Ordered list of ports in the service rotation, typically represented as comma-separated port codes or names (e.g., Singapore-Hong Kong-Shanghai-Busan-Los Angeles-Oakland). Defines the complete loop or string that vessels follow on this service.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portStayDurationHours rdf:type rdf:Property ;
    rdfs:label 'Port Stay Duration Hours' ;
    rdfs:comment 'Average or planned duration in hours that vessels on this service spend at this port, from berthing to departure. Used for berth window planning and terminal resource allocation.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reeferPercentage rdf:type rdf:Property ;
    rdfs:label 'Reefer Percentage' ;
    rdfs:comment 'Expected percentage of container volume that requires refrigeration (reefer containers). Used for reefer plug allocation planning and power supply capacity management.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationDurationDays rdf:type rdf:Property ;
    rdfs:label 'Rotation Duration Days' ;
    rdfs:comment 'Total number of days required to complete one full service rotation from first port back to first port. Used to calculate vessel string requirements and service frequency.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceReliabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Service Reliability Percentage' ;
    rdfs:comment 'Percentage of vessel calls that arrived within the scheduled time window over a measurement period. Key performance indicator for service quality and customer satisfaction.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalOperator rdf:type rdf:Property ;
    rdfs:label 'Terminal Operator' ;
    rdfs:comment 'Name of the terminal operating company handling this service. Used for operational coordination and commercial agreement management.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transshipmentVolumePercentage rdf:type rdf:Property ;
    rdfs:label 'Transshipment Volume Percentage' ;
    rdfs:comment 'Expected percentage of total container volume that is transshipment cargo (discharged from one vessel and loaded onto another). Critical for hub port operations and inter-terminal transfer planning.' ;
    rdfs:domain ind:ServiceRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grtTonnes rdf:type rdf:Property ;
    rdfs:label 'Grt Tonnes' ;
    rdfs:comment 'Measure of the overall internal volume of the vessel. Used for regulatory compliance, port dues calculation, and manning requirements. Expressed in register tons (100 cubic feet).' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ismCompanyImoNumber rdf:type rdf:Property ;
    rdfs:label 'Ism Company Imo Number' ;
    rdfs:comment 'Unique IMO company identification number assigned to the ISM-responsible company.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ismCompanyName rdf:type rdf:Property ;
    rdfs:label 'Ism Company Name' ;
    rdfs:comment 'Name of the company holding the Document of Compliance (DOC) and responsible for ISM Code implementation on the vessel. Identified on the vessel\'s Safety Management Certificate.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPscDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Last Psc Deficiency Count' ;
    rdfs:comment 'Number of deficiencies identified during the most recent PSC inspection. High deficiency counts trigger increased inspection frequency and may result in detention.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPscDetentionFlag rdf:type rdf:Property ;
    rdfs:label 'Last Psc Detention Flag' ;
    rdfs:comment 'Boolean indicator of whether the vessel was detained during the most recent PSC inspection. Detention history is a key risk factor for future inspections.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nrtTonnes rdf:type rdf:Property ;
    rdfs:label 'Nrt Tonnes' ;
    rdfs:comment 'Measure of the cargo-carrying volume of the vessel, calculated by subtracting non-cargo spaces from GRT. Used for port charges and canal dues.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerCountryDomicileCode rdf:type rdf:Property ;
    rdfs:label 'Owner Country Domicile Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the registered owner is domiciled or incorporated. Used for sanctions screening and beneficial ownership analysis.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Ownership Current Flag' ;
    rdfs:comment 'Boolean indicator of whether this record represents the current active ownership. True for the current record, False for historical records. Part of SCD Type 2 implementation.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipEffectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Ownership Effective From Date' ;
    rdfs:comment 'Start date of the current ownership record. Part of SCD Type 2 implementation for tracking ownership change history.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipEffectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Ownership Effective To Date' ;
    rdfs:comment 'End date of the current ownership record. Null for the current active ownership record. Part of SCD Type 2 implementation for tracking ownership change history.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pniClubCode rdf:type rdf:Property ;
    rdfs:label 'Pni Club Code' ;
    rdfs:comment 'Code identifying the P&I club providing third-party liability insurance coverage for the vessel. Used for claims coordination and financial assurance verification.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOwnerImoCompanyNumber rdf:type rdf:Property ;
    rdfs:label 'Registered Owner Imo Company Number' ;
    rdfs:comment 'Unique IMO company identification number assigned to the registered owner organization. Enables corporate hierarchy tracking and sanctions screening.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOwnerName rdf:type rdf:Property ;
    rdfs:label 'Registered Owner Name' ;
    rdfs:comment 'Legal name of the entity holding title to the vessel as recorded in the ship registry. May differ from commercial operator or technical manager.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskProfileScore rdf:type rdf:Property ;
    rdfs:label 'Risk Profile Score' ;
    rdfs:comment 'Composite risk score (0-100) calculated from vessel age, flag state, classification society, PSC history, ownership transparency, and sanctions screening. Higher scores indicate higher risk. Used for prioritizing inspections and service restrictions.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipyardCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipyard Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the nation where the shipyard is located.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipyardName rdf:type rdf:Property ;
    rdfs:label 'Shipyard Name' ;
    rdfs:comment 'Name of the shipyard where the vessel was constructed. Provides provenance and build quality indicators for risk profiling.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalManagerImoCompanyNumber rdf:type rdf:Property ;
    rdfs:label 'Technical Manager Imo Company Number' ;
    rdfs:comment 'Unique IMO company identification number assigned to the technical manager organization.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalManagerName rdf:type rdf:Property ;
    rdfs:label 'Technical Manager Name' ;
    rdfs:comment 'Name of the company responsible for the technical operation, maintenance, and crewing of the vessel. May be the owner, a third-party ship manager, or the ISM company.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthProductivityTarget rdf:type rdf:Property ;
    rdfs:label 'Berth Productivity Target' ;
    rdfs:comment 'The target container handling productivity rate for this voyage measured in container moves per hour. Used for terminal resource planning and SLA performance measurement.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callSequence rdf:type rdf:Property ;
    rdfs:label 'Call Sequence' ;
    rdfs:comment 'Sequential number indicating this port\'s position in the voyage\'s port call sequence. Used to order intermediate ports of call and support cargo routing logic.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoManifestReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Manifest Received Flag' ;
    rdfs:comment 'Boolean indicator showing whether the cargo manifest for this voyage has been received from the shipping line. Critical for customs clearance, cargo planning, and terminal readiness.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coparnReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Coparn Received Flag' ;
    rdfs:comment 'Boolean indicator showing whether the COPARN (Container Pre-Announcement) EDI message has been received. COPARN provides advance notice of containers to be discharged and loaded.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationPortCode rdf:type rdf:Property ;
    rdfs:label 'Destination Port Code' ;
    rdfs:comment 'UN/LOCODE of the voyage destination port. Five-character code identifying the final port of call for this voyage leg.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emptyTeuOnboard rdf:type rdf:Property ;
    rdfs:label 'Empty Teu Onboard' ;
    rdfs:comment 'The number of empty containers onboard measured in TEU. Critical for empty container repositioning planning and depot management.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imdgCargoOnboardFlag rdf:type rdf:Property ;
    rdfs:label 'Imdg Cargo Onboard Flag' ;
    rdfs:comment 'Boolean indicator showing whether the vessel is carrying dangerous goods as classified under IMDG Code. Triggers special safety protocols, segregation requirements, and emergency response planning.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMaidenCall rdf:type rdf:Property ;
    rdfs:label 'Is Maiden Call' ;
    rdfs:comment 'Boolean flag indicating whether this is the vessel\'s first-ever call to this port. Maiden calls often receive special ceremonial recognition and may have different operational procedures.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOmitted rdf:type rdf:Property ;
    rdfs:label 'Is Omitted' ;
    rdfs:comment 'Boolean flag indicating whether this scheduled port call was omitted or skipped by the vessel. Used for schedule reliability analysis and customer service impact assessment.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ladenTeuOnboard rdf:type rdf:Property ;
    rdfs:label 'Laden Teu Onboard' ;
    rdfs:comment 'The number of laden (full) containers onboard measured in TEU. Used for cargo volume analysis and vessel utilization calculations.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oogCargoOnboardFlag rdf:type rdf:Property ;
    rdfs:label 'Oog Cargo Onboard Flag' ;
    rdfs:comment 'Boolean indicator showing whether the vessel is carrying out-of-gauge cargo that exceeds standard container dimensions. Requires special handling equipment and stowage planning considerations.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originPortCode rdf:type rdf:Property ;
    rdfs:label 'Origin Port Code' ;
    rdfs:comment 'UN/LOCODE (United Nations Code for Trade and Transport Locations) of the voyage origin port. Five-character code identifying the port where the voyage originated.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Health quarantine status of the vessel and crew. Not_required indicates no health concerns, pending indicates awaiting health authority inspection, cleared indicates health clearance granted, restricted indicates quarantine measures in effect.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reeferTeuOnboard rdf:type rdf:Property ;
    rdfs:label 'Reefer Teu Onboard' ;
    rdfs:comment 'The number of refrigerated containers onboard measured in TEU. Requires special handling, power supply monitoring, and temperature-controlled storage planning.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationNumber rdf:type rdf:Property ;
    rdfs:label 'Rotation Number' ;
    rdfs:comment 'Sequential rotation identifier within the service string. Used by shipping lines to track vessel position within a cyclical service route (e.g., rotation 1, rotation 2). Supports schedule adherence analysis.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageStatus rdf:type rdf:Property ;
    rdfs:label 'Voyage Status' ;
    rdfs:comment 'Current lifecycle status of the voyage. Planned indicates initial voyage planning stage, scheduled indicates confirmed berth and resource allocation, in_progress indicates vessel is actively executing the voyage, completed indicates voyage has concluded with vessel departure, cancelled indicates voyage was terminated before execution, delayed indicates voyage is behind schedule.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageType rdf:type rdf:Property ;
    rdfs:label 'Voyage Type' ;
    rdfs:comment 'Classification of the voyage based on direction and scope. Inbound indicates arrival to the port, outbound indicates departure, coastal indicates domestic port-to-port movement, international indicates cross-border movement, feeder indicates short-sea collection/distribution service, and transshipment indicates cargo transfer voyage.' ;
    rdfs:domain ind:Voyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vtsLogId rdf:type rdf:Property ;
    rdfs:label 'Vts Log Id' ;
    rdfs:comment 'Primary key for vts_log' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aisMessageReference rdf:type rdf:Property ;
    rdfs:label 'Ais Message Reference' ;
    rdfs:comment 'Identifier of the AIS message associated with this VTS log entry, if the communication was triggered by or included AIS data. Links to AIS message logs.' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'The communication medium or channel used for the VTS interaction (e.g., VHF radio channel, telephone, AIS, email). [ENUM-REF-CANDIDATE: VHF Channel 12|VHF Channel 14|VHF Channel 16|Telephone|AIS|Email|Radio — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Flag' ;
    rdfs:comment 'Boolean flag indicating whether this VTS log entry is associated with a safety incident, near-miss, or emergency event requiring investigation or follow-up.' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instructionComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Instruction Compliance Status' ;
    rdfs:comment 'Status indicating whether the vessel complied with VTS instructions. Complied (vessel followed directive), Non-Compliant (vessel did not follow directive), Partial (vessel partially followed), Not Applicable (no instruction given).' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logTimestamp rdf:type rdf:Property ;
    rdfs:label 'Log Timestamp' ;
    rdfs:comment 'Date and time when the VTS communication or traffic event occurred. This is the operational event time, not the record creation time.' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageContent rdf:type rdf:Property ;
    rdfs:label 'Message Content' ;
    rdfs:comment 'Summary or full text of the VTS communication message content. Captures the substance of the instruction, advisory, warning, or information exchanged.' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Response Time Seconds' ;
    rdfs:comment 'Time elapsed in seconds between the VTS communication being sent and the vessel acknowledgement being received. Used for VTS performance monitoring and SLA compliance.' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficDensity rdf:type rdf:Property ;
    rdfs:label 'Traffic Density' ;
    rdfs:comment 'Assessment of vessel traffic density in the VTS area at the time of the communication. Light (few vessels), Moderate (normal traffic), Heavy (high volume), Congested (capacity constraints).' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselCourseDegrees rdf:type rdf:Property ;
    rdfs:label 'Vessel Course Degrees' ;
    rdfs:comment 'Course or heading of the vessel at the time of the VTS communication, measured in degrees (0-360) from true north.' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselPositionLatitude rdf:type rdf:Property ;
    rdfs:label 'Vessel Position Latitude' ;
    rdfs:comment 'Latitude coordinate of the vessel at the time of the VTS communication, in decimal degrees. Positive for North, negative for South.' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselPositionLongitude rdf:type rdf:Property ;
    rdfs:label 'Vessel Position Longitude' ;
    rdfs:comment 'Longitude coordinate of the vessel at the time of the VTS communication, in decimal degrees. Positive for East, negative for West.' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Vessel Speed Knots' ;
    rdfs:comment 'Speed of the vessel at the time of the VTS communication, measured in knots (nautical miles per hour).' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vtsAreaZone rdf:type rdf:Property ;
    rdfs:label 'Vts Area Zone' ;
    rdfs:comment 'The specific VTS area or zone within the port VTS coverage where the vessel was located during this communication (e.g., Approach Zone, Inner Harbor, Anchorage Area).' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vtsCentreCode rdf:type rdf:Property ;
    rdfs:label 'Vts Centre Code' ;
    rdfs:comment 'Identifier of the VTS centre that recorded this log entry. Links to the VTS centre master data.' ;
    rdfs:domain ind:VtsLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wasteDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Waste Declaration Id' ;
    rdfs:comment 'Primary key for waste_declaration' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receptionFacilityPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Reception Facility Port Community Participant Id' ;
    rdfs:comment 'Foreign key linking to customer.port_community_participant. Business justification: MARPOL Annex V compliance requires tracking which licensed waste reception facility (a port community participant) received ship-generated waste. Port state control inspections verify waste delivery t' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:actualVolumeDeliveredM3 rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Delivered M3' ;
    rdfs:comment 'Actual volume of waste delivered to the port reception facility, measured in cubic meters (m³) upon discharge completion.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'Unique business identifier for the waste declaration, used for tracking and regulatory reporting.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Declaration Submission Timestamp' ;
    rdfs:comment 'Date and time when the waste declaration was officially submitted to the port authority, typically required at least 24 hours before arrival per MARPOL.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Completion Timestamp' ;
    rdfs:comment 'Date and time when waste discharge operations were completed and the vessel was cleared.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disposalFacilityLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility License Number' ;
    rdfs:comment 'Environmental license or permit number of the disposal facility, verifying its authorization to handle the declared waste type.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility Name' ;
    rdfs:comment 'Name of the licensed waste disposal or treatment facility where the waste will be ultimately processed.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emsIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Ems Integration Status' ;
    rdfs:comment 'Status of data transmission to the Environmental Monitoring System for emissions tracking and environmental compliance reporting.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emsTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ems Transmission Timestamp' ;
    rdfs:comment 'Date and time when waste declaration data was transmitted to the Environmental Monitoring System.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume M3' ;
    rdfs:comment 'Estimated volume of waste to be discharged, declared in cubic meters (m³) in the pre-arrival notification.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference' ;
    rdfs:comment 'Reference to the billing invoice generated for waste discharge services, linking to the port billing system.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'Planned date and time for waste delivery to the port reception facility, coordinated with berth operations.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:violationDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Violation Detected Flag' ;
    rdfs:comment 'Indicates whether a MARPOL or environmental regulation violation was detected during inspection or verification (e.g., undeclared waste, illegal discharge).' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'Date until which the granted waiver remains valid, after which the vessel must discharge waste at a port reception facility.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether the vessel was granted a waiver exempting it from mandatory waste discharge requirements (e.g., due to sufficient onboard storage or next port arrangements).' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteContractorReference rdf:type rdf:Property ;
    rdfs:label 'Waste Contractor Reference' ;
    rdfs:comment 'External reference number or job ticket issued by the waste contractor for this waste collection service.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDescription rdf:type rdf:Property ;
    rdfs:label 'Waste Description' ;
    rdfs:comment 'Detailed textual description of the waste material, including composition, source, and any hazardous characteristics.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Receipt Number' ;
    rdfs:comment 'Official receipt number issued by the port reception facility confirming waste delivery, required under MARPOL for vessel records.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteTypeCode rdf:type rdf:Property ;
    rdfs:label 'Waste Type Code' ;
    rdfs:comment 'Standardized code identifying the specific waste category (e.g., OW01 for bilge water, GC03 for plastic waste) per MARPOL classification.' ;
    rdfs:domain ind:WasteDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyId rdf:type rdf:Property ;
    rdfs:label 'Competency Id' ;
    rdfs:comment 'Unique surrogate identifier for each competency record in the master catalogue. Primary key for the competency data product.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Competency .

ind:applicableJobFamily rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Family' ;
    rdfs:comment 'Port workforce job family or occupational group for which this competency is relevant (e.g., \'Marine Pilot\', \'Stevedore\', \'Equipment Operator\', \'Port Security Officer\', \'Harbour Master\'). Supports role-based competency gap analysis and workforce planning. [ENUM-REF-CANDIDATE: marine_pilot|stevedore|equipment_operator|port_security_officer|harbour_master|customs_officer|maintenance_technician|administrative — promote to reference product]' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTrainingProvider rdf:type rdf:Property ;
    rdfs:label 'Approved Training Provider' ;
    rdfs:comment 'Name of the approved training institution or provider authorised by the issuing authority to deliver training for this competency (e.g., \'Australian Maritime College\', \'Port Authority Training Centre\'). Ensures workforce training is conducted through recognised providers.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Primary method used to assess and award this competency. Determines the training and assessment pathway required for workforce members to obtain the qualification. [ENUM-REF-CANDIDATE: written_exam|practical_assessment|simulator|on_the_job|portfolio|medical_examination|observation|combined — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyCategory rdf:type rdf:Property ;
    rdfs:label 'Competency Category' ;
    rdfs:comment 'Functional grouping of the competency for workforce planning and reporting purposes (e.g., \'Marine Operations\', \'Container Handling Equipment\', \'Security\', \'Health and Safety\', \'Trade Compliance\', \'Leadership\'). [ENUM-REF-CANDIDATE: marine_operations|container_handling|security|health_safety|trade_compliance|leadership|environmental|administrative — promote to reference product]' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyCode rdf:type rdf:Property ;
    rdfs:label 'Competency Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the competency within the port authority and Oracle HCM Cloud competency catalogue. Used for cross-system referencing and EDI exchanges.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyDescription rdf:type rdf:Property ;
    rdfs:label 'Competency Description' ;
    rdfs:comment 'Detailed narrative description of the competency, including the knowledge, skills, and abilities it certifies, the scope of work it authorises, and any specific conditions or limitations on its application in port operations.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyName rdf:type rdf:Property ;
    rdfs:label 'Competency Name' ;
    rdfs:comment 'Full human-readable name of the competency, qualification, or certification as recognised by the issuing authority (e.g., \'Basic Safety Training\', \'ISPS Port Facility Security Officer\', \'Quay Crane Operator Licence\').' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyStatus rdf:type rdf:Property ;
    rdfs:label 'Competency Status' ;
    rdfs:comment 'Current lifecycle status of the competency record in the master catalogue. \'active\' indicates the competency is currently in use; \'superseded\' indicates it has been replaced by a newer version; \'draft\' indicates it is pending approval for inclusion.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyType rdf:type rdf:Property ;
    rdfs:label 'Competency Type' ;
    rdfs:comment 'Classification of the competency into its primary category: operational_licence (equipment or vessel operating licence), safety_certification (safety-related training certificate), regulatory_certificate (mandatory regulatory compliance certificate), trade_qualification (vocational or trade qualification), medical_certificate (seafarer or port worker medical fitness certificate).' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costToObtain rdf:type rdf:Property ;
    rdfs:label 'Cost To Obtain' ;
    rdfs:comment 'Standard cost (in local currency) for a workforce member to obtain this competency through the approved training and assessment pathway. Used for workforce training budget planning and OPEX forecasting in SAP CO.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalCertificateSupported rdf:type rdf:Property ;
    rdfs:label 'Digital Certificate Supported' ;
    rdfs:comment 'Indicates whether the issuing authority supports digital or electronic certificates for this competency, enabling integration with port access control systems and ISPS security checks via RFID or digital verification.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'Official reference number or code assigned by the issuing authority (e.g., IMO Model Course number, STCW regulation reference such as \'STCW Reg VI/1\', national certificate code). Enables direct cross-referencing with regulatory documentation.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoModelCourseNumber rdf:type rdf:Property ;
    rdfs:label 'Imo Model Course Number' ;
    rdfs:comment 'IMO Model Course number associated with the training programme for this competency (e.g., \'1.21\' for Personal Safety and Social Responsibilities, \'3.12\' for Ship Security Officer). Used to align port training programmes with IMO-approved curricula.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatoryIsps rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Isps' ;
    rdfs:comment 'Indicates whether this competency is mandatory under the ISPS Code for port facility security personnel, Port Facility Security Officers (PFSOs), and security-designated roles.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryMlc rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Mlc' ;
    rdfs:comment 'Indicates whether this competency is mandatory under the ILO Maritime Labour Convention (MLC 2006) for seafarers and port workers covered by the convention\'s scope.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryStcw rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Stcw' ;
    rdfs:comment 'Indicates whether this competency is mandatory under the IMO Standards of Training, Certification and Watchkeeping (STCW) Convention. True for all STCW-mandated certificates required for seafarers and port workers with shipboard duties.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRenewable rdf:type rdf:Property ;
    rdfs:label 'Is Renewable' ;
    rdfs:comment 'Indicates whether the competency requires periodic renewal upon expiry. True for time-limited certificates (e.g., STCW refresher, medical fitness); False for lifetime qualifications (e.g., trade certificates).' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelDescriptor rdf:type rdf:Property ;
    rdfs:label 'Level Descriptor' ;
    rdfs:comment 'STCW-aligned functional level descriptor indicating the operational tier at which this competency applies: \'management_level\' (officer in charge), \'operational_level\' (watchkeeping officer), \'support_level\' (rating), \'awareness_level\' (general port worker). Aligns with STCW Table A-II/1 through A-VI/6.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalStandardRef rdf:type rdf:Property ;
    rdfs:label 'Medical Standard Ref' ;
    rdfs:comment 'Reference to the applicable medical fitness standard required for this competency (e.g., \'ILO/IMO Guidelines on Medical Examinations\', \'ENG1 Medical Standard\', \'ML5 Medical Standard\'). Applicable to competencies with a medical fitness prerequisite under MLC 2006.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumProficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Proficiency Level' ;
    rdfs:comment 'The minimum proficiency level required for a workforce member to be considered competent for role assignment. Expressed in terms of the competency\'s proficiency scale (e.g., \'3\' for a 1-5 scale, \'working\' for a maturity scale, \'pass\' for pass/fail).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mutualRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Mutual Recognition Flag' ;
    rdfs:comment 'Indicates whether this competency is subject to international mutual recognition agreements between maritime administrations, allowing certificates issued in one jurisdiction to be accepted in another without re-examination.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prerequisiteCompetencyCodes rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Competency Codes' ;
    rdfs:comment 'Comma-separated list of competency codes that must be held by a workforce member before they can undertake training or assessment for this competency. Supports competency pathway sequencing in Oracle HCM Cloud learning plans.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyScale rdf:type rdf:Property ;
    rdfs:label 'Proficiency Scale' ;
    rdfs:comment 'Proficiency measurement scale applied to this competency. \'pass_fail\' for binary certification outcomes; \'level_1_5\' for graded proficiency levels; \'awareness\', \'working\', \'practitioner\', \'expert\' for capability maturity levels used in Oracle HCM Cloud competency profiles.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pscRecognised rdf:type rdf:Property ;
    rdfs:label 'Psc Recognised' ;
    rdfs:comment 'Indicates whether this competency certificate is recognised and accepted by Port State Control (PSC) authorities during vessel and port facility inspections. Critical for compliance with PSC detention avoidance.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revalidationSeaServiceDays rdf:type rdf:Property ;
    rdfs:label 'Revalidation Sea Service Days' ;
    rdfs:comment 'Minimum number of days of approved sea service or port operational service required as evidence for revalidation of this competency under STCW or national maritime authority requirements.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stcwRegulationRef rdf:type rdf:Property ;
    rdfs:label 'Stcw Regulation Ref' ;
    rdfs:comment 'Specific STCW Convention regulation reference applicable to this competency (e.g., \'Regulation II/1\', \'Regulation VI/1\'). Populated only for STCW-mandated competencies to support PSC inspection compliance documentation.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Minimum number of training hours required to attain this competency, as specified by the issuing authority or port training standards. Used for workforce training planning, scheduling, and cost estimation.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disciplinaryCaseId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Case Id' ;
    rdfs:comment 'Unique identifier for the disciplinary or grievance case record. Primary key.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Updated By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last updated the case record.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryDisciplinaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Disciplinary Employee Id' ;
    rdfs:comment 'Identifier of the employee who is the subject of the disciplinary action or the initiator of the grievance.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDisciplinaryHearingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disciplinary Hearing Officer Employee Id' ;
    rdfs:comment 'Identifier of the management or HR representative who presided over the hearing.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allegationCategory rdf:type rdf:Property ;
    rdfs:label 'Allegation Category' ;
    rdfs:comment 'Primary category of the allegation or complaint being addressed in the case. [ENUM-REF-CANDIDATE: misconduct|safety_violation|isps_security_breach|mlc_non_compliance|pay_dispute|roster_fairness|workplace_bullying|working_conditions|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allegationDetails rdf:type rdf:Property ;
    rdfs:label 'Allegation Details' ;
    rdfs:comment 'Detailed description of the misconduct allegation or grievance complaint including circumstances, witnesses, and evidence summary.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision Date' ;
    rdfs:comment 'Date when the appeal decision was formally communicated.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date when the employee formally filed an appeal.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the employee has filed an appeal against the disciplinary decision.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Result of the appeal process indicating whether the original decision was upheld, overturned, or modified.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosureDate rdf:type rdf:Property ;
    rdfs:label 'Case Closure Date' ;
    rdfs:comment 'Date when the case was officially closed and all administrative actions completed.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Case Opened Date' ;
    rdfs:comment 'Date when the formal case was officially opened and recorded in the system.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Case Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the case for tracking and reporting purposes.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the case as either employer-initiated disciplinary action or employee-initiated grievance.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeRepresentationType rdf:type rdf:Property ;
    rdfs:label 'Employee Representation Type' ;
    rdfs:comment 'Type of representation the employee had during the hearing process.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToTribunalFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated To Tribunal Flag' ;
    rdfs:comment 'Indicates whether the case has been escalated to an external labour tribunal or arbitration body.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hearingConductedDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Conducted Date' ;
    rdfs:comment 'Actual date when the hearing was conducted.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hearingScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Scheduled Date' ;
    rdfs:comment 'Date when the formal disciplinary or grievance hearing is scheduled to take place.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatorType rdf:type rdf:Property ;
    rdfs:label 'Initiator Type' ;
    rdfs:comment 'Indicates whether the case was initiated by the employer (disciplinary) or the employee (grievance).' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the investigation was formally concluded and findings documented.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ispsSecurityRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Isps Security Related Flag' ;
    rdfs:comment 'Indicates whether the case involves a breach of ISPS Code security requirements.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mlcComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Mlc Compliance Flag' ;
    rdfs:comment 'Indicates whether the case handling and outcome comply with MLC 2006 Title 5 requirements for fair treatment and dispute resolution.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeDecision rdf:type rdf:Property ;
    rdfs:label 'Outcome Decision' ;
    rdfs:comment 'Final decision or action taken as a result of the disciplinary case or grievance resolution. [ENUM-REF-CANDIDATE: verbal_warning|written_warning|final_warning|suspension|dismissal|no_action|mediation|resolution|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDetails rdf:type rdf:Property ;
    rdfs:label 'Outcome Details' ;
    rdfs:comment 'Detailed explanation of the outcome decision including rationale, conditions, and any corrective actions required.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representativeName rdf:type rdf:Property ;
    rdfs:label 'Representative Name' ;
    rdfs:comment 'Name of the union representative, legal counsel, or colleague who represented the employee.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Related Flag' ;
    rdfs:comment 'Indicates whether the case is related to a workplace safety violation or occupational health and safety incident.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'End date of the suspension period when the employee is eligible to return to work.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionPaidFlag rdf:type rdf:Property ;
    rdfs:label 'Suspension Paid Flag' ;
    rdfs:comment 'Indicates whether the suspension period is paid or unpaid.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Start date of any suspension period imposed as part of the disciplinary outcome.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tribunalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tribunal Reference Number' ;
    rdfs:comment 'External reference number assigned by the labour tribunal or arbitration body.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warning Expiry Date' ;
    rdfs:comment 'Date when a verbal, written, or final warning expires and is removed from the employee record.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:careerAspirations rdf:type rdf:Property ;
    rdfs:label 'Career Aspirations' ;
    rdfs:comment 'Free-text description of the employee\'s career goals, desired roles, and professional development interests. Used for talent development planning and internal mobility programs.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyCertifications rdf:type rdf:Property ;
    rdfs:label 'Competency Certifications' ;
    rdfs:comment 'Comma-separated list of competency certifications held by the employee. Examples include STCW (Standards of Training, Certification and Watchkeeping), crane operator license, dangerous goods handling, first aid, forklift license. Used for workforce capability planning and compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentGoals rdf:type rdf:Property ;
    rdfs:label 'Development Goals' ;
    rdfs:comment 'Structured list of individual development goals and objectives for the employee. Includes skill development targets, certification goals, performance improvement areas, and leadership competencies. Used for performance management and talent development.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the employee within the port workforce. Active indicates currently employed and working; inactive indicates on leave or temporarily not working; suspended indicates disciplinary suspension; terminated indicates employment ended; retired indicates retirement; deceased indicates employee has passed away.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highPotentialFlag rdf:type rdf:Property ;
    rdfs:label 'High Potential Flag' ;
    rdfs:comment 'Boolean flag indicating whether the employee is identified as high-potential talent for accelerated development and leadership roles. True indicates high-potential; False indicates standard talent management track.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the employee. Nullable for employees without middle names.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlcCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Mlc Compliant Flag' ;
    rdfs:comment 'Boolean flag indicating whether the employee meets all Maritime Labour Convention 2006 compliance requirements including minimum age, medical fitness, training certification, and working conditions. True indicates compliant; False indicates non-compliant or compliance review required.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number for the employee. Used for shift notifications, emergency alerts, and field operations coordination.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilityPreference rdf:type rdf:Property ;
    rdfs:label 'Mobility Preference' ;
    rdfs:comment 'Employee\'s willingness and preference for geographic relocation or transfer. Local_only indicates no relocation; regional indicates willing to relocate within region; national indicates willing to relocate within country; international indicates willing to relocate globally. Used for succession planning and talent deployment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oracleHcmEmployeeNumber rdf:type rdf:Property ;
    rdfs:label 'Oracle Hcm Employee Number' ;
    rdfs:comment 'Employee number assigned by Oracle HCM Cloud system. System of record identifier for workforce management, payroll, talent management, and time and attendance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Preferred or commonly used name for the employee in workplace communications and systems.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readinessLevelForNextRole rdf:type rdf:Property ;
    rdfs:label 'Readiness Level For Next Role' ;
    rdfs:comment 'Assessment of the employee\'s readiness for promotion or lateral move to next target role. Not_ready indicates significant development needed; developing indicates progressing toward readiness; ready_with_support indicates ready with mentoring; fully_ready indicates ready for immediate transition; exceeds_requirements indicates overqualified for next role.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapHrPersonnelNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Hr Personnel Number' ;
    rdfs:comment 'Personnel number assigned by SAP S/4HANA HR module. Legacy system identifier for human resources management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sidNumber rdf:type rdf:Property ;
    rdfs:label 'Sid Number' ;
    rdfs:comment 'Seafarer Identity Document number issued under ILO Convention 185. Required for marine pilots, seafarers, and maritime personnel working in ISPS-regulated port areas.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillsInventory rdf:type rdf:Property ;
    rdfs:label 'Skills Inventory' ;
    rdfs:comment 'Structured list of skills, competencies, and capabilities possessed by the employee. Includes technical skills (equipment operation, software proficiency), soft skills (leadership, communication), and specialized knowledge (customs procedures, hazardous cargo handling). Used for talent management, succession planning, and workforce optimization.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanningDesignation rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Designation' ;
    rdfs:comment 'Employee\'s status in succession planning for critical roles. Not_identified indicates not in succession pool; identified indicates potential successor; ready_now indicates ready for immediate promotion; ready_1_year indicates ready within one year; ready_2_years indicates ready within two years.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Code identifying the specific labor union or collective bargaining unit to which the employee belongs. Nullable for non-union employees. Used for labor relations and payroll processing.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMembershipFlag rdf:type rdf:Property ;
    rdfs:label 'Union Membership Flag' ;
    rdfs:comment 'Boolean flag indicating whether the employee is a member of a labor union or collective bargaining unit. True indicates union member; False indicates non-union. Used for payroll deductions, labor relations, and collective agreement compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeCertificationId rdf:type rdf:Property ;
    rdfs:label 'Employee Certification Id' ;
    rdfs:comment 'Unique identifier for the employee certification record. Primary key.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Qualitative outcome of the certification assessment: pass, fail, distinction, credit, competent, or not yet competent.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numerical score or grade achieved in the certification assessment or examination (e.g., percentage, grade point). Null if not applicable.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorisedVesselTypes rdf:type rdf:Property ;
    rdfs:label 'Authorised Vessel Types' ;
    rdfs:comment 'Comma-separated list of vessel types the pilot is authorised to handle (e.g., container, tanker, bulk carrier, RoRo, cruise). Null for non-pilot certifications.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for additional notes, special conditions, or contextual information about this certification record.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Deployment Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is currently eligible for deployment to roles requiring this certification, based on certification status and validity. True if eligible.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:examiningPhysicianName rdf:type rdf:Property ;
    rdfs:label 'Examining Physician Name' ;
    rdfs:comment 'Name of the medical practitioner who conducted the fitness examination. Confidential. Null for non-medical certifications.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitnessOutcome rdf:type rdf:Property ;
    rdfs:label 'Fitness Outcome' ;
    rdfs:comment 'Result of the medical fitness assessment: fit for duty (no restrictions), fit with restrictions (conditional fitness), temporarily unfit (short-term limitation), or permanently unfit (cannot perform role). Confidential. Null for non-medical certifications.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitnessRestrictions rdf:type rdf:Property ;
    rdfs:label 'Fitness Restrictions' ;
    rdfs:comment 'Description of any work restrictions or limitations imposed by the medical assessment (e.g., no night shifts, no heavy lifting, hearing protection required). Confidential. Null if no restrictions or non-medical certification.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether this certification is mandatory for the employees current role and deployment eligibility. True if required, False if optional or supplementary.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumDwtTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Dwt Tonnes' ;
    rdfs:comment 'Maximum vessel deadweight tonnage (DWT) in tonnes that the pilot is authorised to handle. Null for non-pilot certifications.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumLoaMetres rdf:type rdf:Property ;
    rdfs:label 'Maximum Loa Metres' ;
    rdfs:comment 'Maximum vessel length overall (LOA) in metres that the pilot is authorised to handle. Null for non-pilot certifications.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalExaminationDate rdf:type rdf:Property ;
    rdfs:label 'Medical Examination Date' ;
    rdfs:comment 'Date of the most recent medical fitness examination. Null for non-medical certifications.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalFitnessStandard rdf:type rdf:Property ;
    rdfs:label 'Medical Fitness Standard' ;
    rdfs:comment 'The medical fitness standard or protocol applied for this medical certification (e.g., MLC ENG1 for seafarers, ISO 45001 OHS, national occupational health standard). Null for non-medical certifications.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMedicalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Medical Due Date' ;
    rdfs:comment 'Date by which the next medical fitness examination is required. Null for non-medical certifications.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pilotageAreaCode rdf:type rdf:Property ;
    rdfs:label 'Pilotage Area Code' ;
    rdfs:comment 'Code identifying the specific port area or waterway the pilot is authorised to operate in. Null for non-pilot certifications.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Date' ;
    rdfs:comment 'Date on which the renewal reminder notification was sent to the employee. Null if not yet sent.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Sent Flag' ;
    rdfs:comment 'Indicates whether a renewal reminder notification has been sent to the employee for this certification. True if notification sent.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stcwCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Stcw Compliant Flag' ;
    rdfs:comment 'Indicates whether this certification meets IMO STCW Convention requirements for seafarers and marine personnel. True if STCW-compliant.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the accredited training organization or institution that delivered the training leading to this certification.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeTerminalZoneId rdf:type rdf:Property ;
    rdfs:label 'Home Terminal Zone Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.terminal_zone. Business justification: Gangs are based in specific zones for deployment optimization, equipment access, and shift planning. Critical for labor allocation algorithms and travel time calculations. Removes denormalized home_be' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalZone .

ind:averageExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Average Experience Years' ;
    rdfs:comment 'Average number of years of stevedoring experience across all current members of the gang. Used for gang capability assessment, productivity benchmarking, and workforce planning analytics.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoTypeSpecialisation rdf:type rdf:Property ;
    rdfs:label 'Cargo Type Specialisation' ;
    rdfs:comment 'The primary cargo type this gang is trained and certified to handle. Determines eligibility for assignment to specific vessel calls and berth operations. [ENUM-REF-CANDIDATE: container|bulk|breakbulk|roro|liquid_bulk|project_cargo|general — promote to reference product]' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Competency Review Date' ;
    rdfs:comment 'The date of the next scheduled competency review for this gang, covering skills assessment, certification renewals, and operational performance evaluation as required by port training standards.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbandmentDate rdf:type rdf:Property ;
    rdfs:label 'Disbandment Date' ;
    rdfs:comment 'The date on which this stevedore gang was officially disbanded or decommissioned. Null for active gangs. Used for workforce planning, historical reporting, and MLC compliance audits.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'The date on which this stevedore gang was officially formed and registered in the workforce management system. Marks the start of the gang\'s operational lifecycle.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gangCode rdf:type rdf:Property ;
    rdfs:label 'Gang Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the stevedore gang across operational systems including NAVIS N4 and SAP HR. Used for gang assignment to vessel operations and labour deployment scheduling.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gangDescription rdf:type rdf:Property ;
    rdfs:label 'Gang Description' ;
    rdfs:comment 'Free-text description of the stevedore gang\'s operational scope, specialisations, and any specific deployment conditions or restrictions not captured by structured fields.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gangName rdf:type rdf:Property ;
    rdfs:label 'Gang Name' ;
    rdfs:comment 'Human-readable descriptive name of the stevedore gang used for display in operational reports, shift schedules, and terminal operating system interfaces.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gangStatus rdf:type rdf:Property ;
    rdfs:label 'Gang Status' ;
    rdfs:comment 'Current lifecycle status of the stevedore gang. Active gangs are available for vessel call deployment; standby gangs are formed but not currently assigned; suspended gangs are temporarily unavailable; disbanded gangs are permanently decommissioned.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gangType rdf:type rdf:Property ;
    rdfs:label 'Gang Type' ;
    rdfs:comment 'Classification of the stevedore gang by operational function. Hatch gangs work in vessel holds; crane gangs operate ship-to-shore (STS) or mobile harbour cranes (MHC); lashing gangs secure containers; RoRo gangs handle roll-on roll-off cargo; mooring gangs handle vessel mooring lines. [ENUM-REF-CANDIDATE: hatch_gang|crane_gang|lashing_gang|roro_gang|general_gang|mooring_gang — promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiSkilled rdf:type rdf:Property ;
    rdfs:label 'Is Multi Skilled' ;
    rdfs:comment 'Indicates whether this gang is certified and qualified to perform multiple operation types (e.g., both crane operations and lashing), enabling flexible deployment across different vessel operation requirements.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPermanent rdf:type rdf:Property ;
    rdfs:label 'Is Permanent' ;
    rdfs:comment 'Indicates whether this is a permanent standing gang with a fixed composition (True) or a casual/ad-hoc gang assembled for specific vessel calls (False). Permanent gangs have fixed supervisor and core member assignments.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ispsCleared rdf:type rdf:Property ;
    rdfs:label 'Isps Cleared' ;
    rdfs:comment 'Indicates whether all members of this gang have current ISPS Code security clearance, permitting access to restricted port security zones and vessel operations areas.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxComplement rdf:type rdf:Property ;
    rdfs:label 'Max Complement' ;
    rdfs:comment 'Maximum number of workers permitted in the stevedore gang for a single deployment, as defined by operational capacity, equipment constraints, and port labour agreements.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxContinuousWorkHours rdf:type rdf:Property ;
    rdfs:label 'Max Continuous Work Hours' ;
    rdfs:comment 'Maximum number of continuous hours this gang may work without a mandatory rest break, as prescribed by the applicable labour agreement and MLC 2006 rest hour requirements.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minComplement rdf:type rdf:Property ;
    rdfs:label 'Min Complement' ;
    rdfs:comment 'Minimum number of workers required to constitute a legally and operationally compliant stevedore gang for deployment. Defined by port labour agreements, union contracts, and safety regulations under MLC 2006 and OHS standards.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mlcComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Mlc Compliance Status' ;
    rdfs:comment 'Current MLC 2006 compliance status of this gang, reflecting whether rest hour requirements, minimum complement, pay conditions, and certification requirements are fully met under the Maritime Labour Convention.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navisGangCode rdf:type rdf:Property ;
    rdfs:label 'Navis Gang Code' ;
    rdfs:comment 'The native gang identifier as recorded in the NAVIS N4 Terminal Operating System. Used for cross-system reconciliation between the workforce data product and NAVIS N4 gang assignment records.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGradeCode rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Code' ;
    rdfs:comment 'The pay grade classification code applicable to this gang type, used in SAP HR payroll processing to determine base wage rates, allowances, and overtime multipliers under the applicable labour agreement.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Rest Period Hours' ;
    rdfs:comment 'Minimum mandatory rest period in hours required between consecutive deployments for this gang, as mandated by MLC 2006 and the applicable port labour agreement.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyInductionCurrent rdf:type rdf:Property ;
    rdfs:label 'Safety Induction Current' ;
    rdfs:comment 'Indicates whether all current members of this gang have completed and hold valid safety induction certification as required by OHS regulations and port safety management systems.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapHrGangCode rdf:type rdf:Property ;
    rdfs:label 'Sap Hr Gang Code' ;
    rdfs:comment 'The gang or work group identifier as recorded in SAP S/4HANA HR module. Used for payroll processing, labour cost allocation, and time and attendance integration.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardComplement rdf:type rdf:Property ;
    rdfs:label 'Standard Complement' ;
    rdfs:comment 'The standard or nominal number of workers typically deployed in this gang for routine vessel operations. Used as the default headcount for shift planning and labour cost estimation in SAP HR.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionAffiliationCode rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation Code' ;
    rdfs:comment 'Code identifying the maritime trade union or labour organisation to which this gang\'s members are affiliated. Determines applicable enterprise bargaining agreement, dispute resolution procedures, and industrial relations obligations.' ;
    rdfs:domain ind:Gang ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gangAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Gang Assignment Id' ;
    rdfs:comment 'Primary key for gang_assignment' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryGangForemanEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Gang Foreman Employee Id' ;
    rdfs:comment 'Employee identifier of the gang foreman (leading hand) responsible for supervising this deployment. The foreman is accountable for safety, productivity, and sign-off of the gang\'s work record.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryGangApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Gang Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the operations supervisor or terminal manager who approved this gang deployment. Required for audit trail, payroll authorisation, and MLC compliance documentation.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFinishTime rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Time' ;
    rdfs:comment 'Actual timestamp when the gang completed work and was signed off the vessel operation. Used for hours-worked calculation, overtime determination, and productivity reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Calendar date of the gang deployment. Used as the primary date dimension for daily productivity reporting, payroll date alignment, and operational KPI dashboards.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentNumber rdf:type rdf:Property ;
    rdfs:label 'Deployment Number' ;
    rdfs:comment 'Externally-known business identifier for this gang deployment, used in operational communications, payroll references, and TOS dispatch records. Format: GD-YYYY-NNNNNN.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current lifecycle state of the gang deployment. \'assigned\' = gang allocated but not yet started; \'active\' = gang currently working; \'completed\' = work finished and signed off; \'cancelled\' = deployment cancelled before commencement; \'suspended\' = work temporarily halted (e.g., weather, safety hold).' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deployment Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp when the gang was formally deployed and dispatched to the vessel operation. Distinct from the scheduled start time and the actual work commencement time.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gangSizeActual rdf:type rdf:Property ;
    rdfs:label 'Gang Size Actual' ;
    rdfs:comment 'Actual number of workers who reported and worked during this deployment. May differ from planned due to absenteeism, late arrivals, or safety stand-downs. Used for productivity normalisation and payroll.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gangSizePlanned rdf:type rdf:Property ;
    rdfs:label 'Gang Size Planned' ;
    rdfs:comment 'Number of workers planned/allocated to the gang for this deployment as per the gang complement schedule. Used for labour cost estimation and MLC compliance planning.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Gross Hours Worked' ;
    rdfs:comment 'Total elapsed hours from actual start to actual finish for this gang deployment, including meal breaks and stoppages. Used as the denominator for gross productivity rate calculations.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOvertimeApproved rdf:type rdf:Property ;
    rdfs:label 'Is Overtime Approved' ;
    rdfs:comment 'Indicates whether overtime worked during this deployment has been formally approved by the operations supervisor. Required for payroll processing and MLC 2006 working hours compliance audit.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyIncident rdf:type rdf:Property ;
    rdfs:label 'Is Safety Incident' ;
    rdfs:comment 'Indicates whether a safety incident (injury, near-miss, or dangerous occurrence) was recorded during this gang deployment. Triggers mandatory incident reporting under ISO 45001 and OHS regulations.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:movesCompleted rdf:type rdf:Property ;
    rdfs:label 'Moves Completed' ;
    rdfs:comment 'Total number of cargo moves (container lifts, unit moves, or equivalent) completed by the gang during this deployment. Primary raw productivity metric used to calculate moves per hour (MPH) KPI.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Net Hours Worked' ;
    rdfs:comment 'Productive working hours excluding meal breaks, safety stoppages, and non-productive time. Used as the denominator for net productivity rate (moves per net gang hour) calculations and MLC compliance reporting.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of overtime hours worked by the gang beyond the standard shift duration. Drives overtime pay calculations in SAP Payroll and is monitored for MLC 2006 maximum working hours compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollPeriodRef rdf:type rdf:Property ;
    rdfs:label 'Payroll Period Ref' ;
    rdfs:comment 'Payroll period identifier (YYYY-MM) to which this gang deployment\'s hours and earnings are allocated. Used for payroll batch processing in SAP S/4HANA HR and Oracle HCM Cloud payroll runs.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentRef rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Ref' ;
    rdfs:comment 'Reference number of the safety incident report raised during this deployment, if applicable. Links to the safety incident management system for investigation and regulatory reporting. Populated only when is_safety_incident = TRUE.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledFinishTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Time' ;
    rdfs:comment 'Planned finish timestamp for the gang deployment based on the vessel operation schedule. Used for variance analysis and shift planning.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift period during which the gang is deployed. Determines applicable shift penalty rates, allowances, and MLC rest period compliance checks. Day/afternoon/night/swing shifts attract different award rates.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoppageHours rdf:type rdf:Property ;
    rdfs:label 'Stoppage Hours' ;
    rdfs:comment 'Total hours of non-productive stoppage during the deployment (e.g., weather delays, equipment breakdown, safety holds, industrial action). Used for demurrage claims, productivity analysis, and vessel delay reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stoppageReasonCode rdf:type rdf:Property ;
    rdfs:label 'Stoppage Reason Code' ;
    rdfs:comment 'Standardised code identifying the primary reason for any work stoppage during this deployment (e.g., WEATHER, EQUIP_BREAKDOWN, SAFETY_HOLD, INDUSTRIAL). Used for delay analysis and demurrage dispute resolution.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teuHandled rdf:type rdf:Property ;
    rdfs:label 'Teu Handled' ;
    rdfs:comment 'Total TEU (Twenty-foot Equivalent Units) handled by the gang during this deployment. FEU containers count as 2 TEU. Core metric for container terminal productivity benchmarking and billing. TEU = Twenty-foot Equivalent Unit.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teuPerGangHour rdf:type rdf:Property ;
    rdfs:label 'Teu Per Gang Hour' ;
    rdfs:comment 'Container productivity rate expressed as TEU handled per net gang hour. Captured from TOS dispatch records as the operational productivity figure for this deployment. TEU = Twenty-foot Equivalent Unit.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tosDispatchRef rdf:type rdf:Property ;
    rdfs:label 'Tos Dispatch Ref' ;
    rdfs:comment 'Source system dispatch reference number from NAVIS N4 or TOPS Expert TOS. Used for data lineage, reconciliation with the TOS, and audit trail back to the operational system of record. TOS = Terminal Operating System.' ;
    rdfs:domain ind:GangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceCaseId rdf:type rdf:Property ;
    rdfs:label 'Grievance Case Id' ;
    rdfs:comment 'Unique identifier for the grievance case record. Primary key.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryGrievanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Grievance Employee Id' ;
    rdfs:comment 'Identifier of the employee who lodged the grievance. Links to the employee master record in Oracle HCM Cloud.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryGrievanceAssignedInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Grievance Assigned Investigator Employee Id' ;
    rdfs:comment 'Identifier of the HR or management employee assigned to investigate the grievance.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryGrievanceCorrectiveActionOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Grievance Corrective Action Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee or manager responsible for implementing corrective actions.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryGrievanceUnionRepresentativeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Grievance Union Representative Employee Id' ;
    rdfs:comment 'Identifier of the union representative assisting the employee with the grievance, if applicable. Null if no union representation.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Assigned Investigator Name' ;
    rdfs:comment 'Full name of the investigator assigned to the case. Denormalized for reporting purposes.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Employee Satisfaction Rating' ;
    rdfs:comment 'Optional satisfaction rating provided by the employee after resolution, on a scale of 1 to 5, where 5 is highly satisfied.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalatedFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated Flag' ;
    rdfs:comment 'Boolean flag indicating whether the grievance was escalated to a labour tribunal, external arbitrator, or higher authority.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationBody rdf:type rdf:Property ;
    rdfs:label 'Escalation Body' ;
    rdfs:comment 'Name of the external body or authority to which the grievance was escalated (e.g., Labour Tribunal, Fair Work Commission, Arbitrator).' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Escalation Reference Number' ;
    rdfs:comment 'External reference number or case number assigned by the escalation body.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingOutcome rdf:type rdf:Property ;
    rdfs:label 'Finding Outcome' ;
    rdfs:comment 'Categorical outcome of the investigation findings.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceCategory rdf:type rdf:Property ;
    rdfs:label 'Grievance Category' ;
    rdfs:comment 'Categorization of the grievance by scope and formality level. Individual grievances affect one employee; collective grievances affect multiple employees or a gang.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceDescription rdf:type rdf:Property ;
    rdfs:label 'Grievance Description' ;
    rdfs:comment 'Detailed narrative description of the grievance as provided by the employee. Captures the nature of the complaint, circumstances, and requested remedy.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceType rdf:type rdf:Property ;
    rdfs:label 'Grievance Type' ;
    rdfs:comment 'Classification of the grievance by subject matter. Categorizes the nature of the complaint raised by the employee. [ENUM-REF-CANDIDATE: pay_dispute|working_conditions|roster_fairness|mlc_entitlement|workplace_conduct|discrimination|harassment|safety_concern|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlcStandardReference rdf:type rdf:Property ;
    rdfs:label 'Mlc Standard Reference' ;
    rdfs:comment 'Specific MLC 2006 standard or regulation reference that the grievance relates to, if applicable.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentName rdf:type rdf:Property ;
    rdfs:label 'Respondent Name' ;
    rdfs:comment 'Full name of the individual who is the subject of the grievance, if applicable. Null if grievance is not against an individual.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Union Representative Name' ;
    rdfs:comment 'Full name of the union representative assisting the employee, if applicable.' ;
    rdfs:domain ind:GrievanceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Id' ;
    rdfs:comment 'Primary key for headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHeadcountApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Headcount Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the manager or executive who approved this headcount plan. Establishes accountability for workforce planning decisions.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Headcount' ;
    rdfs:comment 'Actual headcount at the snapshot date. Represents the realized workforce level. May include fractional FTE values for part-time and casual workers.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualLabourCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labour Cost' ;
    rdfs:comment 'Actual labor cost incurred during the planning period. Enables variance analysis against budget for financial control.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attritionCount rdf:type rdf:Property ;
    rdfs:label 'Attrition Count' ;
    rdfs:comment 'Number of employees who left the organization during the planning period. Used for turnover analysis and retention strategy.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Headcount' ;
    rdfs:comment 'Authorized headcount for the planning period as approved in the workforce budget. Represents the planned workforce capacity. May include fractional FTE (Full-Time Equivalent) values.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedLabourCost rdf:type rdf:Property ;
    rdfs:label 'Budgeted Labour Cost' ;
    rdfs:comment 'Total budgeted labor cost for the planning period including base pay, allowances, and employer contributions. Used for OPEX and CAPEX labor budgeting.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employmentCategory rdf:type rdf:Property ;
    rdfs:label 'Employment Category' ;
    rdfs:comment 'Category of employment relationship. Distinguishes between permanent staff, casual labor, contractors, and temporary workers for workforce flexibility planning.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broader job family grouping for the position. Used for talent management and career path planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlcCompliant rdf:type rdf:Property ;
    rdfs:label 'Mlc Compliant' ;
    rdfs:comment 'Indicates whether the headcount plan meets Maritime Labour Convention 2006 requirements for crew welfare, working hours, and rest periods.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newHireCount rdf:type rdf:Property ;
    rdfs:label 'New Hire Count' ;
    rdfs:comment 'Number of new employees hired during the planning period. Tracks recruitment effectiveness and workforce growth.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text notes and comments about the headcount plan. Captures business context, assumptions, and special considerations.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedThroughputTeu rdf:type rdf:Property ;
    rdfs:label 'Planned Throughput Teu' ;
    rdfs:comment 'Planned container throughput in TEU for the planning period. Links workforce capacity planning to operational volume targets.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period covered by this headcount plan. Defines the temporal scope of workforce planning.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period covered by this headcount plan. Typically aligns with fiscal year or quarter boundaries.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productivityTargetTeuPerGangHour rdf:type rdf:Property ;
    rdfs:label 'Productivity Target Teu Per Gang Hour' ;
    rdfs:comment 'Target productivity rate in TEU per gang hour. Used to calculate required stevedore gang capacity based on throughput forecasts.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Explanation for why the plan was revised. Documents the business drivers for headcount plan changes.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'Point-in-time date when the actual headcount was captured. Used for comparing planned versus actual workforce levels at specific moments.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vacancyCount rdf:type rdf:Property ;
    rdfs:label 'Vacancy Count' ;
    rdfs:comment 'Number of open positions (approved but unfilled) at the snapshot date. Critical for recruitment planning and operational risk assessment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Variance Headcount' ;
    rdfs:comment 'Difference between budgeted and actual headcount (actual minus budgeted). Positive values indicate overstaffing, negative values indicate understaffing.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededAgreementLabourAgreementId rdf:type rdf:Property ;
    rdfs:label 'Superseded Agreement Labour Agreement Id' ;
    rdfs:comment 'Reference to the previous labour agreement that this agreement replaces or supersedes, enabling historical tracking of agreement evolution.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabourAgreement .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Full legal or business name of the labour agreement, typically including the parties involved and the scope of coverage.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualLeaveEntitlementDays rdf:type rdf:Property ;
    rdfs:label 'Annual Leave Entitlement Days' ;
    rdfs:comment 'Number of paid annual leave days per year that employees are entitled to under the agreement.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableJobFamilies rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Families' ;
    rdfs:comment 'Comma-separated list or description of job families, roles, or classifications covered by this agreement (e.g., stevedores, crane operators, marine pilots, security personnel).' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Document Reference Url' ;
    rdfs:comment 'URL or file path reference to the full legal document or PDF of the labour agreement for detailed review and audit purposes.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerPartyName rdf:type rdf:Property ;
    rdfs:label 'Employer Party Name' ;
    rdfs:comment 'Legal name of the employer or port authority entity that is a party to the labour agreement.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairWorkCommissionApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Fair Work Commission Approval Number' ;
    rdfs:comment 'Official approval or registration number issued by the Fair Work Commission (or equivalent regulatory body) for the labour agreement.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueManagementRules rdf:type rdf:Property ;
    rdfs:label 'Fatigue Management Rules' ;
    rdfs:comment 'Summary of fatigue management provisions including maximum consecutive work hours, mandatory rest periods, and shift rotation constraints to ensure MLC (Maritime Labour Convention) compliance.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gangComplementMinimum rdf:type rdf:Property ;
    rdfs:label 'Gang Complement Minimum' ;
    rdfs:comment 'Minimum number of workers required to constitute a stevedore gang or work crew under the terms of the agreement, ensuring safe and efficient operations.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyTermsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Terms Summary' ;
    rdfs:comment 'High-level summary of the key employment terms and conditions covered by the agreement, including wage rates, overtime provisions, penalty rates, gang complement requirements, and fatigue management rules.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longServiceLeaveThresholdYears rdf:type rdf:Property ;
    rdfs:label 'Long Service Leave Threshold Years' ;
    rdfs:comment 'Number of years of continuous service required before an employee becomes eligible for long service leave under the agreement.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumWageRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Wage Rate' ;
    rdfs:comment 'Minimum hourly or daily wage rate stipulated in the agreement for covered employees, serving as the baseline for payroll calculations.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlcRestHoursMinimum rdf:type rdf:Property ;
    rdfs:label 'Mlc Rest Hours Minimum' ;
    rdfs:comment 'Minimum number of rest hours required between shifts as mandated by the Maritime Labour Convention to prevent fatigue and ensure worker safety.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'Multiplier applied to the base wage rate for overtime hours worked (e.g., 1.5 for time-and-a-half, 2.0 for double-time).' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Integration Flag' ;
    rdfs:comment 'Indicates whether the terms of this agreement have been integrated into the payroll system calculation rules and roster constraints. True if integrated, False otherwise.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to the base wage rate for work performed during penalty periods such as weekends, public holidays, or night shifts.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratificationDate rdf:type rdf:Property ;
    rdfs:label 'Ratification Date' ;
    rdfs:comment 'Date on which the labour agreement was formally ratified or approved by the relevant parties, including union members and employer representatives.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratificationMethod rdf:type rdf:Property ;
    rdfs:label 'Ratification Method' ;
    rdfs:comment 'Method by which the agreement was ratified, such as member ballot, delegate vote, Fair Work Commission approval, or management approval.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyPaymentFormula rdf:type rdf:Property ;
    rdfs:label 'Redundancy Payment Formula' ;
    rdfs:comment 'Formula or calculation method for determining redundancy payments based on years of service, as stipulated in the agreement.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renegotiationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renegotiation Notice Days' ;
    rdfs:comment 'Number of days advance notice required before commencing renegotiation of the agreement, as stipulated in the agreement terms.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renegotiationTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Renegotiation Trigger Date' ;
    rdfs:comment 'Date on which renegotiation of the agreement is scheduled to commence, typically set in advance of the expiry date to allow sufficient time for bargaining.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sickLeaveEntitlementDays rdf:type rdf:Property ;
    rdfs:label 'Sick Leave Entitlement Days' ;
    rdfs:comment 'Number of paid sick leave days per year that employees are entitled to under the agreement.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionDuesPercentage rdf:type rdf:Property ;
    rdfs:label 'Union Dues Percentage' ;
    rdfs:comment 'Percentage of gross wages to be deducted as union dues or membership fees, as agreed between the parties.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionPartyName rdf:type rdf:Property ;
    rdfs:label 'Union Party Name' ;
    rdfs:comment 'Name of the union, labour body, or employee representative organization that is a party to the agreement (e.g., MUA - Maritime Union of Australia, ITF affiliate).' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wageRateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Wage Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the wage rates and monetary terms specified in the agreement.' ;
    rdfs:domain ind:LabourAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique system-generated identifier for each employee leave request record in the workforce management system. Primary key for the leave_request data product.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaveRequest .

ind:primaryLeaveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Employee Id' ;
    rdfs:comment 'Reference to the employee submitting the leave request. Links to the employee master record in Oracle HCM Cloud and SAP HR.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'The date the employee actually returned to work from leave. May differ from approved_end_date in cases of early return, extended sick leave, or compassionate leave extensions. Used for attendance reconciliation and payroll.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedDays rdf:type rdf:Property ;
    rdfs:label 'Approved Days' ;
    rdfs:comment 'Total number of working days approved, which may differ from requested_days if the approver modified the leave period. Used for payroll deduction and leave balance updates in SAP HR.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedEndDate rdf:type rdf:Property ;
    rdfs:label 'Approved End Date' ;
    rdfs:comment 'The actual approved end date of the leave, which may differ from the requested end date if the approver modified the dates to accommodate operational requirements.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedStartDate rdf:type rdf:Property ;
    rdfs:label 'Approved Start Date' ;
    rdfs:comment 'The actual approved start date of the leave, which may differ from the requested start date if the approver modified the dates to accommodate operational requirements such as minimum gang complement.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approverComments rdf:type rdf:Property ;
    rdfs:label 'Approver Comments' ;
    rdfs:comment 'Free-text comments entered by the approving manager when approving, rejecting, or modifying the leave request. Provides audit trail for approval decisions and communicates conditions or deferrals to the employee.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeComments rdf:type rdf:Property ;
    rdfs:label 'Employee Comments' ;
    rdfs:comment 'Free-text comments provided by the employee when submitting the leave request, providing additional context such as travel plans, medical circumstances, or operational handover notes.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gangComplementAffected rdf:type rdf:Property ;
    rdfs:label 'Gang Complement Affected' ;
    rdfs:comment 'Specific flag indicating whether approving this leave would reduce the stevedore gang complement below the minimum safe working level required for cargo operations. Critical for vessel scheduling and STS/RTG crane operations.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:halfDayFlag rdf:type rdf:Property ;
    rdfs:label 'Half Day Flag' ;
    rdfs:comment 'Indicates whether the leave request is for a half-day (morning or afternoon session) rather than a full working day. Supports flexible leave management for port workers on rotating shift patterns.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:halfDaySession rdf:type rdf:Property ;
    rdfs:label 'Half Day Session' ;
    rdfs:comment 'Specifies whether the half-day leave applies to the morning or afternoon session. Only populated when half_day_flag is true. Relevant for shift scheduling and gang complement planning.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Handover Completed Flag' ;
    rdfs:comment 'Indicates whether the employee has completed the required operational handover to their substitute or team before commencing leave. Particularly important for marine pilots, crane operators, and security personnel.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveBalanceAtRequest rdf:type rdf:Property ;
    rdfs:label 'Leave Balance At Request' ;
    rdfs:comment 'The employee\'s available leave balance (in days) for the requested leave type at the time the request was submitted. Captured as a snapshot to support audit and dispute resolution.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveCategory rdf:type rdf:Property ;
    rdfs:label 'Leave Category' ;
    rdfs:comment 'Indicates whether the leave is fully paid, unpaid, or partially paid, which drives payroll processing in SAP S/4HANA HR and determines the financial impact on the employee\'s earnings.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveLoadingApplicable rdf:type rdf:Property ;
    rdfs:label 'Leave Loading Applicable' ;
    rdfs:comment 'Indicates whether the employee is entitled to leave loading (an additional payment percentage on top of base pay during annual leave) as per the applicable enterprise agreement or MLC provisions.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Classification of the leave being requested. Shore leave is a Maritime Labour Convention (MLC) 2006-mandated entitlement for seafarers and port workers. [ENUM-REF-CANDIDATE: annual|sick|maternity|paternity|compassionate|shore_leave|unpaid|study — promote to reference product]' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveYear rdf:type rdf:Property ;
    rdfs:label 'Leave Year' ;
    rdfs:comment 'The leave entitlement year (e.g., 2024) against which this leave request is charged. Used for annual leave balance management, MLC compliance reporting, and year-end leave liability calculations in SAP HR.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalCertificateReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Received' ;
    rdfs:comment 'Indicates whether the required medical certificate has been received and verified by HR. Relevant for sick leave compliance and MLC health-related absence management. Null when medical_certificate_required is false.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Required' ;
    rdfs:comment 'Indicates whether a medical certificate is required to support this leave request (typically for sick leave exceeding the threshold number of days defined in the enterprise leave policy or MLC requirements).' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mlcShoreLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Mlc Shore Leave Flag' ;
    rdfs:comment 'Indicates whether this leave request is an MLC 2006 Regulation 2.4-mandated shore leave entitlement for seafarers or port workers. MLC shore leave requests carry special compliance obligations and cannot be unreasonably denied.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Operational Impact Flag' ;
    rdfs:comment 'Indicates whether this leave request has been flagged as having an operational impact on port operations, such as reducing a stevedore gang below the minimum complement required for vessel operations or crane operations.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollPeriod rdf:type rdf:Property ;
    rdfs:label 'Payroll Period' ;
    rdfs:comment 'The payroll processing period (YYYY-MM) in which this leave is processed for pay deduction or leave loading payment in SAP S/4HANA HR. Ensures correct financial period allocation for leave costs.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally visible, human-readable reference number for the leave request, used in correspondence, approval workflows, and payroll integration. Format: LR-YYYY-NNNNNN.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDays rdf:type rdf:Property ;
    rdfs:label 'Requested Days' ;
    rdfs:comment 'Total number of working days requested by the employee, calculated from requested_start_date to requested_end_date excluding weekends and public holidays. Supports half-day precision.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested End Date' ;
    rdfs:comment 'The last calendar date of the leave period as requested by the employee. Combined with requested_start_date to determine the total requested leave duration.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'The first calendar date of the leave period as requested by the employee. Used for scheduling, gang complement planning, and operational impact assessment.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'The native record identifier from the source system (Oracle HCM Cloud Absence Management transaction ID or SAP HR absence record key). Enables traceability and reconciliation back to the system of record.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalFitnessId rdf:type rdf:Property ;
    rdfs:label 'Medical Fitness Id' ;
    rdfs:comment 'Unique identifier for the medical fitness examination record. Primary key.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByOhsManager rdf:type rdf:Property ;
    rdfs:label 'Approved By Ohs Manager' ;
    rdfs:comment 'Indicates whether the medical fitness outcome has been reviewed and approved by the port OHS manager for workforce deployment decisions. True if approved, False otherwise.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardiovascularAssessment rdf:type rdf:Property ;
    rdfs:label 'Cardiovascular Assessment' ;
    rdfs:comment 'Assessment of cardiovascular health including blood pressure, heart rate, and cardiac function. Critical for high-stress roles such as crane operators and marine pilots.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssued rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued' ;
    rdfs:comment 'Indicates whether a formal medical fitness certificate was issued to the employee following the examination. True if certificate issued, False otherwise.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugScreeningConducted rdf:type rdf:Property ;
    rdfs:label 'Drug Screening Conducted' ;
    rdfs:comment 'Indicates whether drug and alcohol screening was conducted as part of the medical examination. True if screening performed, False otherwise.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Drug Screening Result' ;
    rdfs:comment 'Outcome of drug and alcohol screening test. Negative indicates no substances detected, positive indicates presence of prohibited substances, inconclusive requires retest.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationCost rdf:type rdf:Property ;
    rdfs:label 'Examination Cost' ;
    rdfs:comment 'Total cost of the medical fitness examination charged by the occupational health provider. Used for workforce health budget tracking and cost allocation.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinationDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Examination Duration Minutes' ;
    rdfs:comment 'Total duration of the medical examination in minutes, used for occupational health service capacity planning and billing.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:examinationNumber rdf:type rdf:Property ;
    rdfs:label 'Examination Number' ;
    rdfs:comment 'Externally-known unique reference number for the medical fitness examination, typically generated by the occupational health provider or port medical services department.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationStatus rdf:type rdf:Property ;
    rdfs:label 'Examination Status' ;
    rdfs:comment 'Current lifecycle status of the medical fitness examination record.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationType rdf:type rdf:Property ;
    rdfs:label 'Examination Type' ;
    rdfs:comment 'Category of medical examination conducted: pre-employment screening, periodic health surveillance, return-to-work assessment, fitness-for-duty evaluation, post-incident medical review, or random health check.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examiningPhysicianLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Examining Physician License Number' ;
    rdfs:comment 'Professional registration or license number of the examining physician, issued by the relevant medical council or maritime health authority.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDetails rdf:type rdf:Property ;
    rdfs:label 'Follow Up Details' ;
    rdfs:comment 'Description of required follow-up actions, specialist referrals, or additional medical assessments needed.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether follow-up medical consultation, specialist referral, or additional testing is required. True if follow-up needed, False otherwise.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hearingTestResult rdf:type rdf:Property ;
    rdfs:label 'Hearing Test Result' ;
    rdfs:comment 'Outcome of audiometric hearing assessment. Critical for roles requiring radio communication, alarm response, and hazardous area work.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispsClearanceGranted rdf:type rdf:Property ;
    rdfs:label 'Isps Clearance Granted' ;
    rdfs:comment 'Indicates whether the medical fitness examination supports ISPS security clearance for port security personnel. True if clearance granted, False otherwise.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Medical Facility Name' ;
    rdfs:comment 'Name of the clinic, hospital, or occupational health center where the examination was conducted.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalStandardApplied rdf:type rdf:Property ;
    rdfs:label 'Medical Standard Applied' ;
    rdfs:comment 'The medical fitness standard or certification framework applied during the examination. MLC ENG1/ENG2/ENG3 for seafarers and marine pilots, national OHS standards for stevedores and crane operators, ISPS security standards for port security personnel. [ENUM-REF-CANDIDATE: MLC-ENG1|MLC-ENG2|MLC-ENG3|national-OHS|ISPS-security|crane-operator|pilot-medical|stevedore-fitness — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musculoskeletalAssessment rdf:type rdf:Property ;
    rdfs:label 'Musculoskeletal Assessment' ;
    rdfs:comment 'Assessment of musculoskeletal health, joint mobility, and physical capability. Critical for stevedores and manual handling roles.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextExaminationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Examination Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic medical fitness examination. Typically 12-24 months from current examination depending on role and age of employee.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalFitnessAssessment rdf:type rdf:Property ;
    rdfs:label 'Physical Fitness Assessment' ;
    rdfs:comment 'Overall assessment of physical fitness and capability to perform the physical demands of the safety-critical role (e.g., climbing, lifting, endurance).' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianComments rdf:type rdf:Property ;
    rdfs:label 'Physician Comments' ;
    rdfs:comment 'Additional clinical notes, observations, or recommendations provided by the examining physician. Classified as restricted due to medical confidentiality.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psychologicalAssessmentConducted rdf:type rdf:Property ;
    rdfs:label 'Psychological Assessment Conducted' ;
    rdfs:comment 'Indicates whether psychological or mental health assessment was conducted. Typically required for high-stress safety-critical roles such as marine pilots and crane operators.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:psychologicalAssessmentResult rdf:type rdf:Property ;
    rdfs:label 'Psychological Assessment Result' ;
    rdfs:comment 'Outcome of psychological fitness assessment. Fit indicates mental health suitable for role, fit-with-support indicates fitness with counseling or support services, unfit indicates psychological concerns preclude role performance.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Record Retention Years' ;
    rdfs:comment 'Number of years this medical fitness record must be retained per regulatory requirements. Typically 5-7 years for MLC compliance and occupational health regulations.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:respiratoryAssessment rdf:type rdf:Property ;
    rdfs:label 'Respiratory Assessment' ;
    rdfs:comment 'Assessment of respiratory function and lung capacity. Critical for roles involving dust exposure, confined spaces, or respiratory protection equipment use.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionDetails rdf:type rdf:Property ;
    rdfs:label 'Restriction Details' ;
    rdfs:comment 'Detailed description of any work restrictions or accommodations required (e.g., no night shifts, no heavy lifting over 20kg, hearing protection mandatory, restricted to ground-level operations). Classified as restricted due to health information sensitivity.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionEndDate rdf:type rdf:Property ;
    rdfs:label 'Restriction End Date' ;
    rdfs:comment 'Date when the medical restrictions expire or are scheduled for review. Null for permanent restrictions.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionStartDate rdf:type rdf:Property ;
    rdfs:label 'Restriction Start Date' ;
    rdfs:comment 'Date from which the medical restrictions become effective. Applicable only when fitness outcome is fit-with-restrictions or temporarily-unfit.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visionTestResult rdf:type rdf:Property ;
    rdfs:label 'Vision Test Result' ;
    rdfs:comment 'Outcome of visual acuity testing. Critical for crane operators, marine pilots, and equipment operators. Pass indicates uncorrected vision meets standard, corrected-pass indicates vision meets standard with corrective lenses.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlcComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Mlc Compliance Record Id' ;
    rdfs:comment 'Unique identifier for the MLC compliance record. Primary key.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accommodationStandardMet rdf:type rdf:Property ;
    rdfs:label 'Accommodation Standard Met' ;
    rdfs:comment 'Boolean flag indicating whether accommodation provided to the seafarer meets MLC 2006 Title 3 standards for size, ventilation, heating, lighting, and sanitary facilities. Applicable to seafarers with onboard accommodation.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintLodged rdf:type rdf:Property ;
    rdfs:label 'Complaint Lodged' ;
    rdfs:comment 'Boolean flag indicating whether this compliance record originated from or is related to a seafarer complaint lodged through the onboard complaint procedure as required by MLC 2006 Standard A5.1.5.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintReference rdf:type rdf:Property ;
    rdfs:label 'Complaint Reference' ;
    rdfs:comment 'Reference number of the related seafarer complaint if this compliance record was triggered by a complaint. Links to the complaint management system. Nullable when no complaint is associated.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceArea rdf:type rdf:Property ;
    rdfs:label 'Compliance Area' ;
    rdfs:comment 'Specific compliance area or regulation within the MLC title being tracked (e.g., Minimum Age, Medical Certification, Seafarers Employment Agreement, Hours of Work and Rest, Repatriation, Accommodation Standards, Food and Catering, Medical Care, Social Security).' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Record Number' ;
    rdfs:comment 'Business identifier for the MLC compliance record, formatted as MLC-YYYYMMDD-NNNN for external reference and audit trail.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Date' ;
    rdfs:comment 'Actual date the corrective action was completed and verified. Used to track remediation effectiveness and close out non-conformances. Nullable until corrective action is completed.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Verified By' ;
    rdfs:comment 'Name or identifier of the person or authority who verified completion of the corrective action and restoration of MLC compliance (e.g., Port Safety Officer, MLC Compliance Manager, External Auditor).' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationOfMlcComplianceRef rdf:type rdf:Property ;
    rdfs:label 'Declaration Of Mlc Compliance Ref' ;
    rdfs:comment 'Reference number of the Declaration of Maritime Labour Compliance (DMLC) Part I and Part II under which this compliance record is tracked. The DMLC is the primary MLC certification document.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorOrganization rdf:type rdf:Property ;
    rdfs:label 'Inspector Organization' ;
    rdfs:comment 'Organization or authority the inspector represents (e.g., Port State Control Authority, Flag State Administration, Classification Society, Internal Audit Team).' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCareAccessConfirmed rdf:type rdf:Property ;
    rdfs:label 'Medical Care Access Confirmed' ;
    rdfs:comment 'Boolean flag indicating whether the seafarer has confirmed access to medical care as required by MLC 2006 Title 4, including medical facilities, qualified medical personnel, and medical supplies.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mlcTitle rdf:type rdf:Property ;
    rdfs:label 'Mlc Title' ;
    rdfs:comment 'The specific MLC 2006 title under which this compliance record is categorized. MLC 2006 is structured into five titles covering minimum requirements, employment conditions, accommodation, health protection, and compliance enforcement.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceDescription rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Description' ;
    rdfs:comment 'Detailed description of the MLC non-conformance or deficiency identified during inspection or assessment. Includes nature of violation, specific regulation breached, and circumstances. Nullable when compliance status is compliant.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceSeverity rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Severity' ;
    rdfs:comment 'Severity classification of the MLC non-conformance. Critical indicates immediate risk to seafarer safety or rights requiring urgent action, major indicates significant breach requiring corrective action before next PSC inspection, minor indicates administrative or documentation issue requiring correction within defined timeframe.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repatriationSecurityHeld rdf:type rdf:Property ;
    rdfs:label 'Repatriation Security Held' ;
    rdfs:comment 'Boolean flag indicating whether financial security for repatriation is in place for this seafarer as required by MLC 2006 Standard A2.5. Typically satisfied through P&I (Protection and Indemnity) club coverage or bank guarantee.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Email' ;
    rdfs:comment 'Email address of the responsible officer for MLC compliance follow-up and communication. Business-confidential contact information.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restHoursCompliant rdf:type rdf:Property ;
    rdfs:label 'Rest Hours Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the employee is compliant with MLC 2006 Standard A2.3 rest hours requirements (minimum 10 hours rest in any 24-hour period and 77 hours in any 7-day period). Critical for seafarer welfare and PSC inspection.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seafarerEmploymentAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Seafarer Employment Agreement Ref' ;
    rdfs:comment 'Reference number of the Seafarers Employment Agreement under which this employee is engaged. Required for MLC Title 2 compliance tracking. Nullable for shore-based port employees not classified as seafarers.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialSecurityCoverage rdf:type rdf:Property ;
    rdfs:label 'Social Security Coverage' ;
    rdfs:comment 'Level of social security coverage provided to the seafarer in accordance with MLC 2006 Standard A4.5, covering medical care, sickness benefit, employment injury benefit, and other social security branches.' ;
    rdfs:domain ind:MlcComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentUnitOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Unit Org Unit Id' ;
    rdfs:comment 'Reference to the parent organisational unit in the hierarchy. Enables traversal of the organisational tree structure from terminals down to gangs and sections. Null for top-level units.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:capexLabourBudget rdf:type rdf:Property ;
    rdfs:label 'Capex Labour Budget' ;
    rdfs:comment 'Capital expenditure budget allocated for labour costs in this organisational unit for the current fiscal period. Includes project-based labour for infrastructure development and major initiatives.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Casual Headcount' ;
    rdfs:comment 'Number of casual or temporary employees in this organisational unit. Common in port operations for stevedore gangs and peak-period labour.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competencyFramework rdf:type rdf:Property ;
    rdfs:label 'Competency Framework' ;
    rdfs:comment 'Name or code of the competency framework applicable to this organisational unit (e.g., Marine Pilot Competency Framework, Crane Operator Certification Framework). Links to training and certification requirements.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractHeadcount rdf:type rdf:Property ;
    rdfs:label 'Contract Headcount' ;
    rdfs:comment 'Number of contract or third-party employees assigned to this organisational unit. Used for contingent workforce management.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountVariance rdf:type rdf:Property ;
    rdfs:label 'Headcount Variance' ;
    rdfs:comment 'Difference between budgeted and actual headcount (budgeted minus actual). Positive variance indicates understaffing; negative indicates overstaffing. Key KPI for workforce planning.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mlcComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Mlc Compliance Required' ;
    rdfs:comment 'Indicates whether this organisational unit must comply with ILO Maritime Labour Convention 2006 standards. True for marine-facing units (pilots, towage, vessel services); False for landside operations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opexLabourBudget rdf:type rdf:Property ;
    rdfs:label 'Opex Labour Budget' ;
    rdfs:comment 'Operational expenditure budget allocated for labour costs in this organisational unit for the current fiscal period. Includes salaries, wages, and benefits for ongoing operations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organisational units purpose, responsibilities, and scope of operations. Provides business context for workforce planning and reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organisational unit. Active = operational; Inactive = temporarily non-operational; Suspended = on hold; Planned = future unit not yet operational; Closed = permanently decommissioned.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permanentHeadcount rdf:type rdf:Property ;
    rdfs:label 'Permanent Headcount' ;
    rdfs:comment 'Number of permanent (full-time equivalent) employees in this organisational unit. Part of employment category breakdown for workforce composition analysis.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningPeriod rdf:type rdf:Property ;
    rdfs:label 'Planning Period' ;
    rdfs:comment 'Time period for workforce planning data (e.g., 2024-Q1, 2024-M03, 2024-FY). Enables time-series workforce capacity analysis and trend reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalUnit rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Unit' ;
    rdfs:comment 'Indicates whether this organisational unit performs safety-critical operations requiring enhanced OHS (Occupational Health and Safety) protocols, competency certification, and incident reporting. True for crane operations, marine pilotage, hazardous cargo handling.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionRepresentation rdf:type rdf:Property ;
    rdfs:label 'Union Representation' ;
    rdfs:comment 'Indicates whether employees in this organisational unit are represented by a labour union or collective bargaining agreement. Impacts workforce relations and MLC compliance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Business identifier code for the organisational unit used across SAP HR and Oracle HCM systems. Unique alphanumeric code for external reference.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full name of the organisational unit (e.g., Container Terminal 1, Marine Operations Department, Stevedore Gang Alpha).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organisational unit indicating its role in the port hierarchy. Terminal = marine terminal facility; Department = functional business unit; Division = strategic business division; Section = operational sub-unit; Gang = stevedore work crew; Cost Centre = financial accounting unit; Operational Area = geographic or functional zone. [ENUM-REF-CANDIDATE: terminal|department|division|section|gang|cost_centre|operational_area — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Unique surrogate identifier for each payroll run record in the Databricks Silver layer. Primary key for the payroll_run data product.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:primaryPayrollApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payroll Approved By Employee Id' ;
    rdfs:comment 'SAP employee ID of the payroll manager or HR director who formally approved this payroll run for posting. Supports audit trail and segregation of duties compliance.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reversedRunPayrollRunId rdf:type rdf:Property ;
    rdfs:label 'Reversed Run Payroll Run Id' ;
    rdfs:comment 'Reference to the original payroll_run_id that this run reverses or corrects. Populated only for correction or reversal run types, enabling audit chain traceability.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:bankFileReference rdf:type rdf:Property ;
    rdfs:label 'Bank File Reference' ;
    rdfs:comment 'Reference number of the bank payment file (e.g., ABA, BACS, SEPA file) generated for this payroll run and submitted to the port\'s banking institution for net pay disbursement.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Bank Submission Timestamp' ;
    rdfs:comment 'The date and time when the bank payment file was submitted to the financial institution for processing. Used for payment traceability and treasury reconciliation.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossPayTotal rdf:type rdf:Property ;
    rdfs:label 'Gross Pay Total' ;
    rdfs:comment 'Total gross earnings for all employees processed in this payroll run before any deductions. Includes base pay, allowances, overtime, and all other earnings components. Used for financial reconciliation and SAP FI/CO posting.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountErrors rdf:type rdf:Property ;
    rdfs:label 'Headcount Errors' ;
    rdfs:comment 'Number of employee records that encountered processing errors during the payroll run and were excluded from the final payroll results. Used for quality control and exception management.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountProcessed rdf:type rdf:Property ;
    rdfs:label 'Headcount Processed' ;
    rdfs:comment 'Total number of employee records included and processed in this payroll run. Used for payroll reconciliation, workforce reporting, and KPI tracking.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netPayTotal rdf:type rdf:Property ;
    rdfs:label 'Net Pay Total' ;
    rdfs:comment 'Total net pay disbursed to all employees in this payroll run after all deductions. This is the total bank transfer amount and is used for treasury cash management and bank file reconciliation.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oracleHcmBatchCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Hcm Batch Code' ;
    rdfs:comment 'Reference identifier from Oracle HCM Cloud for the corresponding workforce management batch that feeds time and attendance data into this SAP payroll run. Supports cross-system reconciliation between Oracle HCM and SAP HR.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'The frequency at which this payroll run is executed, determining the pay cycle length. Maritime port workforces may have weekly cycles for casual stevedores and monthly cycles for salaried staff.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGroupCode rdf:type rdf:Property ;
    rdfs:label 'Pay Group Code' ;
    rdfs:comment 'Code identifying the employee pay group processed in this run, used to segment workforce populations such as permanent, casual, maritime, or shore-based employees.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGroupDescription rdf:type rdf:Property ;
    rdfs:label 'Pay Group Description' ;
    rdfs:comment 'Descriptive label for the pay group, e.g., \'Permanent Waterfront\', \'Casual Stevedore\', \'Marine Pilot\', \'Port Security Officer\'.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollAreaCode rdf:type rdf:Property ;
    rdfs:label 'Payroll Area Code' ;
    rdfs:comment 'SAP HR payroll area code that defines the grouping of employees processed together in this payroll run (e.g., stevedores, marine pilots, administrative staff). Corresponds to the SAP Payroll Area (Abrechnungskreis) configuration object.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Payroll Area Description' ;
    rdfs:comment 'Human-readable description of the SAP payroll area, such as \'Stevedore Gang - Waterfront\', \'Marine Pilots\', \'Port Security\', or \'Administrative Staff\'.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollPeriodCode rdf:type rdf:Property ;
    rdfs:label 'Payroll Period Code' ;
    rdfs:comment 'SAP payroll period identifier combining the period number and fiscal year (e.g., \'01/2024\', \'26/2024\' for fortnightly). Uniquely identifies the pay cycle within the payroll area.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipsGenerated rdf:type rdf:Property ;
    rdfs:label 'Payslips Generated' ;
    rdfs:comment 'Indicates whether individual employee payslips (wage statements) have been generated and made available for this payroll run. MLC 2006 Regulation 2.2 requires seafarers and maritime workers to receive a written wage statement.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'The date and time when payroll results were posted to the SAP FI/CO general ledger and cost centres, completing the financial integration of the payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Execution Timestamp' ;
    rdfs:comment 'The date and time when the payroll calculation was initiated and executed in SAP HR Payroll. This is the principal business event timestamp for the payroll run lifecycle.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-text notes entered by the payroll administrator documenting any exceptions, special processing instructions, or explanations for this payroll run (e.g., vessel arrival delays affecting overtime, industrial action adjustments).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAllowances rdf:type rdf:Property ;
    rdfs:label 'Total Allowances' ;
    rdfs:comment 'Aggregate of all allowance payments across the payroll run, including shift allowances, danger allowances, meal allowances, and maritime-specific allowances such as port operations and hazardous cargo allowances.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBasePay rdf:type rdf:Property ;
    rdfs:label 'Total Base Pay' ;
    rdfs:comment 'Aggregate base salary or wage component across all employees in this payroll run, excluding allowances and overtime. Used for compensation benchmarking and cost analysis.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Deductions' ;
    rdfs:comment 'Total of all employee deductions across the payroll run, including income tax (PAYG/PAYE), pension/superannuation contributions, union dues, and other statutory or voluntary deductions.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmployerContributions rdf:type rdf:Property ;
    rdfs:label 'Total Employer Contributions' ;
    rdfs:comment 'Total employer-side payroll contributions for this run, including employer pension/superannuation contributions, workers compensation levies, and other statutory employer obligations. Represents the full employment cost beyond gross pay.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOvertimePay rdf:type rdf:Property ;
    rdfs:label 'Total Overtime Pay' ;
    rdfs:comment 'Aggregate overtime earnings across all employees in this payroll run. Overtime is common in port operations due to vessel scheduling, tidal windows, and 24/7 terminal operations.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPensionDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Pension Deductions' ;
    rdfs:comment 'Aggregate employee pension or superannuation contributions deducted across all employees in this payroll run. Supports pension fund remittance and MLC 2006 social security compliance.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Total Tax Withheld' ;
    rdfs:comment 'Aggregate income tax withheld from all employee pay in this payroll run. Used for statutory tax remittance reporting to national tax authorities.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnionDues rdf:type rdf:Property ;
    rdfs:label 'Total Union Dues' ;
    rdfs:comment 'Aggregate union membership dues deducted from employee pay in this payroll run. Waterfront and maritime workers are typically represented by maritime unions; dues are remitted to the relevant union body.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payslipId rdf:type rdf:Property ;
    rdfs:label 'Payslip Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual payslip record in the Databricks Silver Layer. Primary key for the payslip data product. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountReference rdf:type rdf:Property ;
    rdfs:label 'Bank Account Reference' ;
    rdfs:comment 'Masked or tokenised reference to the employee\'s nominated bank account for net pay disbursement. Full account details are stored in the secure payroll system (SAP HR Infotype 0009). Only the last 4 digits or a token is stored here for audit trail purposes.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePay rdf:type rdf:Property ;
    rdfs:label 'Base Pay' ;
    rdfs:comment 'Gross base salary or wage earned by the employee for the pay period before any allowances, overtime, or deductions. Calculated from the employee\'s pay grade and contracted hours. MONETARY_TRIPLET gross-base component per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dangerAllowance rdf:type rdf:Property ;
    rdfs:label 'Danger Allowance' ;
    rdfs:comment 'Hazard or danger allowance paid to employees working in high-risk port environments such as IMDG cargo handling, confined space operations, or heavy lift operations. Mandated under OHS regulations and enterprise agreements.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeFullName rdf:type rdf:Property ;
    rdfs:label 'Employee Full Name' ;
    rdfs:comment 'Full legal name of the employee as printed on the payslip. Required for MLC wage statement compliance and employee identification. Sourced from SAP HR Infotype 0002 / Oracle HCM Cloud Person record.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerPensionContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Pension Contribution' ;
    rdfs:comment 'Employer\'s superannuation or pension contribution for the employee for the pay period, calculated as a percentage of ordinary time earnings. Shown on payslip for MLC social security transparency. Not deducted from employee pay.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPay rdf:type rdf:Property ;
    rdfs:label 'Gross Pay' ;
    rdfs:comment 'Total gross earnings for the pay period before any deductions, comprising base pay plus all allowances and overtime pay. MONETARY_TRIPLET gross-base amount per TRANSACTION_HEADER role. Printed on MLC wage statement.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeTaxDeduction rdf:type rdf:Property ;
    rdfs:label 'Income Tax Deduction' ;
    rdfs:comment 'Amount of income tax withheld from the employee\'s gross pay for the pay period in accordance with applicable national tax legislation. Calculated based on the employee\'s tax code, residency status, and gross earnings.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMlcCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Mlc Compliant' ;
    rdfs:comment 'Indicates whether this payslip meets all Maritime Labour Convention 2006 wage statement requirements, including minimum wage, deduction limits, and payment method compliance. Set by the payroll compliance validation process. Critical for Port State Control (PSC) inspections.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Date and time when the payslip was formally issued and made available to the employee (via employee self-service portal, email, or physical distribution). BUSINESS_EVENT_TIMESTAMP (precise issuance time) per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leaveHoursTaken rdf:type rdf:Property ;
    rdfs:label 'Leave Hours Taken' ;
    rdfs:comment 'Total hours of approved leave (annual leave, sick leave, personal leave) taken by the employee during the pay period. Used to reconcile leave balances and verify leave pay calculations.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveLoadingPay rdf:type rdf:Property ;
    rdfs:label 'Leave Loading Pay' ;
    rdfs:comment 'Additional leave loading payment (typically 17.5% of base pay) paid when the employee takes annual leave, as mandated by enterprise agreements common in Australian and Asia-Pacific port operations. Zero if no leave was taken in the period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealAllowance rdf:type rdf:Property ;
    rdfs:label 'Meal Allowance' ;
    rdfs:comment 'Meal or subsistence allowance paid to employees for extended shifts, overtime, or remote port assignments. Typically defined in enterprise agreements for stevedore gangs and marine service personnel.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPay rdf:type rdf:Property ;
    rdfs:label 'Net Pay' ;
    rdfs:comment 'Final amount payable to the employee after all deductions have been applied (gross_pay minus total_deductions). MONETARY_TRIPLET net total per TRANSACTION_HEADER role. The amount actually disbursed to the employee\'s bank account.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ordinaryHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Ordinary Hours Worked' ;
    rdfs:comment 'Total ordinary (non-overtime) hours worked by the employee during the pay period. Used to verify base pay calculations, monitor MLC rest hour compliance, and support workforce productivity analytics. Sourced from Oracle HCM Cloud Time and Attendance.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductions rdf:type rdf:Property ;
    rdfs:label 'Other Deductions' ;
    rdfs:comment 'Aggregate of all other authorised deductions not separately itemised (e.g., salary advance repayments, equipment damage levies, voluntary savings). MLC 2006 restricts deductions to those authorised by law or collective agreement.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePay rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay' ;
    rdfs:comment 'Total overtime earnings for the pay period, calculated from overtime hours worked multiplied by the applicable overtime rate. Critical for port operations where vessel turnaround requirements drive significant overtime for stevedore and crane operator workforces.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Salary grade or pay band assigned to the employee\'s position, determining the base pay range. Sourced from SAP HR Infotype 0008 (Basic Pay). Confidential as it reveals compensation structure.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'Last calendar date of the pay period covered by this payslip. Defines the end boundary of the earnings and deductions calculation window. Together with pay_period_start_date, fully identifies the pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'First calendar date of the pay period covered by this payslip. Defines the start boundary of the earnings and deductions calculation window. BUSINESS_EVENT_TIMESTAMP category (date precision) per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollArea rdf:type rdf:Property ;
    rdfs:label 'Payroll Area' ;
    rdfs:comment 'SAP HR Payroll area code grouping employees processed together in the same payroll run cycle (e.g., stevedores, marine pilots, administrative staff, security). Determines pay frequency and payroll calendar. [ENUM-REF-CANDIDATE: promote to reference product as payroll areas vary by port organisation]' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipNumber rdf:type rdf:Property ;
    rdfs:label 'Payslip Number' ;
    rdfs:comment 'Externally-known unique business identifier for the payslip, formatted as PS-YYYY-MM-EMPREF. Used for employee reference, MLC wage statement compliance, and audit trail. BUSINESS_IDENTIFIER category per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipStatus rdf:type rdf:Property ;
    rdfs:label 'Payslip Status' ;
    rdfs:comment 'Current lifecycle state of the payslip document. \'draft\' indicates payroll is being processed; \'generated\' means the payslip has been computed; \'issued\' means it has been delivered to the employee; \'cancelled\' means it was voided; \'reissued\' means a corrected version was produced. LIFECYCLE_STATUS category per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionDeduction rdf:type rdf:Property ;
    rdfs:label 'Pension Deduction' ;
    rdfs:comment 'Employee contribution to pension, superannuation, or provident fund deducted from gross pay for the pay period. Mandatory under national pension legislation and MLC 2006 social security provisions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftAllowance rdf:type rdf:Property ;
    rdfs:label 'Shift Allowance' ;
    rdfs:comment 'Additional allowance paid to employees working non-standard shifts (night shifts, weekend shifts, rotating shifts) in port terminal operations. Common for stevedore gangs, crane operators, and vessel traffic service staff operating 24/7.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionDuesDeduction rdf:type rdf:Property ;
    rdfs:label 'Union Dues Deduction' ;
    rdfs:comment 'Trade union membership dues deducted from the employee\'s pay per authorisation. Relevant for port workforces with high union membership rates (e.g., International Longshoremen\'s Association, maritime unions). Requires employee written authorisation.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdGrossPay rdf:type rdf:Property ;
    rdfs:label 'Ytd Gross Pay' ;
    rdfs:comment 'Cumulative gross pay earned by the employee from the start of the financial/tax year to the end of the current pay period. Required for annual tax reporting, payment summaries, and MLC wage record compliance.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdNetPay rdf:type rdf:Property ;
    rdfs:label 'Ytd Net Pay' ;
    rdfs:comment 'Cumulative net pay disbursed to the employee from the start of the financial/tax year to the end of the current pay period. Supports annual earnings verification, MLC wage record compliance, and employee financial planning.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdTaxDeduction rdf:type rdf:Property ;
    rdfs:label 'Ytd Tax Deduction' ;
    rdfs:comment 'Cumulative income tax withheld from the employee from the start of the financial/tax year to the end of the current pay period. Required for annual tax reconciliation and payment summary generation.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Primary key for performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationSessionId rdf:type rdf:Property ;
    rdfs:label 'Calibration Session Id' ;
    rdfs:comment 'Identifier of the calibration session where this performance review was discussed and validated with peer managers to ensure rating consistency and fairness across the organization.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationSession .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Unique identifier of the employee being reviewed. Links to the employee master record in Oracle HCM Cloud.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Unique identifier of the employee conducting the performance review, typically the direct supervisor or manager.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bonusEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligibility Flag' ;
    rdfs:comment 'Indicator of whether the employee is eligible for performance-based bonus or incentive payment based on review outcome. True indicates eligibility for variable compensation. Classified as confidential business information.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensationAdjustmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Compensation Adjustment Percentage' ;
    rdfs:comment 'Recommended percentage increase in base compensation based on performance review outcome. Used for merit increase planning and budget allocation. Classified as confidential business information.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationAdjustmentRecommended rdf:type rdf:Property ;
    rdfs:label 'Compensation Adjustment Recommended' ;
    rdfs:comment 'Indicator of whether a salary increase, bonus, or other compensation adjustment is recommended based on performance. True indicates a compensation change is recommended. Classified as confidential business information.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyRating rdf:type rdf:Property ;
    rdfs:label 'Competency Rating' ;
    rdfs:comment 'Assessment of the employee\'s demonstration of core competencies required for their role, including technical skills, behavioral competencies, and role-specific capabilities. Evaluates how well the employee applies required knowledge and skills in their work.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlanSummary rdf:type rdf:Property ;
    rdfs:label 'Development Plan Summary' ;
    rdfs:comment 'Summary of the agreed-upon development plan for the employee, including training needs, skill development objectives, career progression goals, and specific actions to address performance gaps or enhance capabilities.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment' ;
    rdfs:comment 'The employee\'s own evaluation of their performance during the review period, including accomplishments, challenges, and self-identified development needs. Provides employee perspective and promotes self-reflection.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievementRating rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Rating' ;
    rdfs:comment 'Assessment of the employee\'s success in achieving individual goals and objectives set at the beginning of the review period. Measures performance against specific, measurable targets aligned with business objectives.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadershipRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Rating' ;
    rdfs:comment 'Assessment of the employee\'s leadership capabilities, including team management, decision-making, mentoring, and influence. Not applicable for non-supervisory roles. Evaluates ability to guide, motivate, and develop others.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlcComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Mlc Compliance Rating' ;
    rdfs:comment 'Assessment of the employee\'s adherence to Maritime Labour Convention standards, including rest hours, working conditions, and seafarer rights. Applicable primarily to marine pilots, stevedore gangs, and vessel operations personnel. Ensures compliance with international maritime labor standards.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalEfficiencyRating rdf:type rdf:Property ;
    rdfs:label 'Operational Efficiency Rating' ;
    rdfs:comment 'Assessment of the employee\'s contribution to operational efficiency, including productivity, quality of work, resource utilization, and process improvement. Measures effectiveness in executing core job responsibilities and contributing to terminal operations performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oracleHcmReviewCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Hcm Review Code' ;
    rdfs:comment 'The unique identifier for this performance review record in the source Oracle HCM Cloud Performance Management system. Enables traceability and reconciliation with the system of record.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Rating' ;
    rdfs:comment 'The comprehensive performance rating assigned to the employee for the review period. Outstanding indicates exceptional performance beyond all expectations, exceeds expectations indicates performance above standard requirements, meets expectations indicates satisfactory performance meeting all requirements, needs improvement indicates performance below standards requiring development, and unsatisfactory indicates performance significantly below acceptable levels.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numerical score representing the overall performance rating, typically on a scale such as 1.0 to 5.0. Enables quantitative analysis and comparison of performance across employees and time periods.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceImprovementPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Improvement Plan Flag' ;
    rdfs:comment 'Indicator of whether the employee has been placed on a formal Performance Improvement Plan due to unsatisfactory performance. True indicates active PIP status requiring structured improvement actions and monitoring.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Readiness Flag' ;
    rdfs:comment 'Indicator of whether the employee is considered ready for promotion to a higher role or responsibility level based on current performance and demonstrated capabilities. True indicates readiness for advancement, false indicates not yet ready.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'The date when the performance review was finalized and completed by the reviewer. Represents the official completion of the assessment process.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Business identifier for the performance review, typically generated by Oracle HCM Cloud Performance Management module. Used for tracking and reference purposes.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The ending date of the performance period being evaluated. Defines the conclusion of the timeframe for which employee performance is assessed.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'The beginning date of the performance period being evaluated. Defines the start of the timeframe for which employee performance is assessed.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle state of the performance review. Draft indicates the review is being prepared, submitted means it has been sent to the employee, under review indicates active discussion, completed means finalized by reviewer, acknowledged means employee has accepted, disputed indicates employee disagreement, and archived means the review is closed and stored for historical reference. [ENUM-REF-CANDIDATE: draft|submitted|under_review|completed|acknowledged|disputed|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the performance review based on its purpose and timing. Annual reviews are comprehensive yearly assessments, mid-year reviews are interim checkpoints, probationary reviews assess new hires, post-incident reviews follow safety or operational incidents, project completion reviews assess performance on specific assignments, and promotion reviews support advancement decisions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Detailed narrative feedback provided by the reviewer summarizing the employee\'s performance, strengths, areas for improvement, and specific examples supporting the ratings. Provides qualitative context for quantitative ratings.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Safety Compliance Rating' ;
    rdfs:comment 'Assessment of the employee\'s adherence to port safety protocols, ISPS (International Ship and Port Facility Security) requirements, OHS (Occupational Health and Safety) standards, and incident prevention practices. Critical for maritime operations where safety is paramount.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionCandidateFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Candidate Flag' ;
    rdfs:comment 'Indicator of whether the employee is identified as a candidate for succession planning for critical roles within the organization. True indicates inclusion in succession planning initiatives.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teamworkCollaborationRating rdf:type rdf:Property ;
    rdfs:label 'Teamwork Collaboration Rating' ;
    rdfs:comment 'Assessment of the employee\'s ability to work effectively with colleagues, cross-functional teams, and external stakeholders. Evaluates communication, cooperation, and contribution to team success in the port environment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRecommendations rdf:type rdf:Property ;
    rdfs:label 'Training Recommendations' ;
    rdfs:comment 'Specific training courses, certifications, or development programs recommended for the employee based on performance gaps, career aspirations, or business needs. May include technical training, safety certifications, leadership development, or competency enhancement programs.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotLicenceId rdf:type rdf:Property ;
    rdfs:label 'Pilot Licence Id' ;
    rdfs:comment 'Unique identifier for the marine pilot licence record. Primary key for the pilot licence entity.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cruiseShipEndorsement rdf:type rdf:Property ;
    rdfs:label 'Cruise Ship Endorsement' ;
    rdfs:comment 'Indicates whether the pilot is authorised to pilot cruise ships. Cruise vessels may require additional certification due to passenger safety considerations and vessel size.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsEndorsement rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Endorsement' ;
    rdfs:comment 'Indicates whether the pilot is certified to pilot vessels carrying dangerous goods under the IMDG Code. Required for piloting tankers, chemical carriers, and vessels with hazardous cargo.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endorsementNotes rdf:type rdf:Property ;
    rdfs:label 'Endorsement Notes' ;
    rdfs:comment 'Free-text field for additional endorsements, restrictions, or special conditions attached to the licence. May include specific berth restrictions, tug assistance requirements, or weather limitations.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgClassesAuthorised rdf:type rdf:Property ;
    rdfs:label 'Imdg Classes Authorised' ;
    rdfs:comment 'Comma-separated list of IMDG hazard classes the pilot is authorised to handle (e.g., Class 1 Explosives, Class 2 Gases, Class 3 Flammable Liquids, Class 7 Radioactive Materials). Blank if no dangerous goods endorsement.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceClass rdf:type rdf:Property ;
    rdfs:label 'Licence Class' ;
    rdfs:comment 'Classification of the pilotage licence indicating the level of authority and vessel size restrictions. Class 1 typically represents the highest authority for largest vessels, while restricted classes have specific limitations.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lngCarrierEndorsement rdf:type rdf:Property ;
    rdfs:label 'Lng Carrier Endorsement' ;
    rdfs:comment 'Indicates whether the pilot holds specific endorsement to pilot LNG carriers. LNG vessels require specialized training due to cargo hazards and vessel handling characteristics.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumGrtTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Grt Tonnes' ;
    rdfs:comment 'Maximum vessel Gross Registered Tonnage that the pilot is authorised to pilot. GRT is a measure of the overall internal volume of a vessel. Used in some jurisdictions as an alternative to DWT for licence restrictions.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Reference' ;
    rdfs:comment 'Reference number of the current valid medical fitness certificate required for pilotage operations. Pilots must maintain medical fitness standards equivalent to or exceeding merchant marine officer requirements.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotageAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Pilotage Area Description' ;
    rdfs:comment 'Detailed description of the geographic pilotage area covered by this licence, including specific berths, anchorages, channels, and navigational limits. May include multiple terminals or port zones.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedVisibilityAuthorised rdf:type rdf:Property ;
    rdfs:label 'Restricted Visibility Authorised' ;
    rdfs:comment 'Indicates whether the pilot is authorised to conduct pilotage operations in restricted visibility conditions (fog, heavy rain, snow). Requires additional experience and may require radar endorsement.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stcwEndorsementFlag rdf:type rdf:Property ;
    rdfs:label 'Stcw Endorsement Flag' ;
    rdfs:comment 'Indicates whether the pilot holds valid STCW certification endorsement. STCW is the International Maritime Organization convention setting qualification standards for seafarers. Required for pilots operating on international voyages.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPilotageActs rdf:type rdf:Property ;
    rdfs:label 'Total Pilotage Acts' ;
    rdfs:comment 'Cumulative count of pilotage acts (vessel movements) completed by this pilot under this licence. Used to track experience and for performance analysis. Incremented with each completed pilotage assignment.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vtmsIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Vtms Integration Enabled' ;
    rdfs:comment 'Indicates whether this licence record is integrated with the Vessel Traffic Management System for automated pilotage scheduling and dispatch. Required for VTS and pilotage scheduling integration.' ;
    rdfs:domain ind:PilotLicence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Identifier of the supervisory position to which this position reports in the organisational hierarchy. Null for top-level executive positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:fullTimeEquivalent rdf:type rdf:Property ;
    rdfs:label 'Full Time Equivalent' ;
    rdfs:comment 'Proportion of full-time hours allocated to this position, expressed as a decimal (e.g., 1.00 for full-time, 0.50 for half-time). Used for headcount budgeting and workforce capacity planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeBand rdf:type rdf:Property ;
    rdfs:label 'Grade Band' ;
    rdfs:comment 'Compensation and seniority level assigned to the position within the port\'s grading structure (e.g., G1, G2, M1, E1).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountBudget rdf:type rdf:Property ;
    rdfs:label 'Headcount Budget' ;
    rdfs:comment 'Number of authorised incumbents for this position. Typically 1 for individual positions; may be greater than 1 for pooled positions (e.g., casual stevedore gang members).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isIspsDesignated rdf:type rdf:Property ;
    rdfs:label 'Is Isps Designated' ;
    rdfs:comment 'Indicates whether the position requires ISPS security clearance and background checks due to access to restricted port areas or sensitive maritime security functions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManagementPosition rdf:type rdf:Property ;
    rdfs:label 'Is Management Position' ;
    rdfs:comment 'Indicates whether the position has direct supervisory or managerial responsibilities over other employees.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOperationalPosition rdf:type rdf:Property ;
    rdfs:label 'Is Operational Position' ;
    rdfs:comment 'Indicates whether the position is directly involved in core port operations (vessel handling, cargo operations, equipment operation) as opposed to administrative or support functions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyCritical rdf:type rdf:Property ;
    rdfs:label 'Is Safety Critical' ;
    rdfs:comment 'Indicates whether the position is designated as safety-critical under International Ship and Port Facility Security (ISPS) Code or Safety of Life at Sea (SOLAS) regulations, requiring enhanced screening, certification, and oversight.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCategory rdf:type rdf:Property ;
    rdfs:label 'Job Category' ;
    rdfs:comment 'Detailed classification within the job family, specifying the functional area (e.g., Container Handling, Vessel Operations, Port Security, Terminal Planning).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyPerformanceIndicators rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicators' ;
    rdfs:comment 'Comma-separated list of measurable performance metrics used to evaluate success in the position (e.g., Crane Moves per Hour, Vessel Turnaround Time, Safety Incident Rate).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum formal education qualification required for the position (e.g., secondary school, diploma, bachelor\'s degree).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant industry or functional experience required to qualify for the position.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Business identifier for the position, used across HR systems and organisational charts. Typically alphanumeric code assigned by HR.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed narrative description of the position\'s purpose, key responsibilities, accountabilities, and scope within the port organisation.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresMedicalClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Medical Clearance' ;
    rdfs:comment 'Indicates whether the position requires periodic medical fitness assessments due to safety-critical duties or physical demands (e.g., crane operators, marine pilots).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSecurityClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Security Clearance' ;
    rdfs:comment 'Indicates whether the position requires background security vetting and clearance due to access to restricted areas or sensitive information.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for salary and compensation amounts (e.g., USD, EUR, AUD).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Maximum' ;
    rdfs:comment 'Maximum annual salary or wage rate for the position in the port\'s base currency, as defined by the compensation structure.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Minimum' ;
    rdfs:comment 'Minimum annual salary or wage rate for the position in the port\'s base currency, as defined by the compensation structure.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionClassification rdf:type rdf:Property ;
    rdfs:label 'Union Classification' ;
    rdfs:comment 'Union or collective bargaining agreement classification applicable to the position, if covered by maritime labour agreements.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterId rdf:type rdf:Property ;
    rdfs:label 'Roster Id' ;
    rdfs:comment 'Unique system-generated identifier for each roster record in the workforce scheduling system. Primary key for the roster data product.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Roster .

ind:advanceNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Days' ;
    rdfs:comment 'The number of calendar days in advance that this roster assignment was published to the employee prior to the assignment date. Used to measure compliance with enterprise agreement advance notice obligations.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The specific calendar date on which the employee is assigned to work the designated shift. The principal business event date for this roster entry.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breakEntitlementMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Entitlement Minutes' ;
    rdfs:comment 'Total scheduled break time in minutes to which the employee is entitled during this shift, as defined by the applicable enterprise agreement or MLC rest provisions.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeNotes rdf:type rdf:Property ;
    rdfs:label 'Change Notes' ;
    rdfs:comment 'Free-text notes providing additional context for roster changes, amendments, or special instructions related to this assignment. Supports operational communication between planners and supervisors.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyVerified rdf:type rdf:Property ;
    rdfs:label 'Competency Verified' ;
    rdfs:comment 'Indicates whether the employee\'s required competency certifications and qualifications have been verified as current and valid for the assigned position and shift type at the time of roster creation.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentTypeAssigned rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Assigned' ;
    rdfs:comment 'The type of port equipment the employee is assigned to operate during this shift, such as Ship-to-Shore (STS) crane, Rubber Tyred Gantry (RTG), Automated Stacking Crane (ASC), Automated Guided Vehicle (AGV), or Mobile Harbour Crane (MHC). Sourced from NAVIS N4 equipment dispatch.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlcMinRestHours rdf:type rdf:Property ;
    rdfs:label 'Mlc Min Rest Hours' ;
    rdfs:comment 'The minimum number of rest hours required between consecutive shifts for this employee as mandated by MLC 2006 Regulation 2.3. Standard minimum is 10 hours in any 24-hour period and 77 hours in any 7-day period.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlcRestHoursCompliant rdf:type rdf:Property ;
    rdfs:label 'Mlc Rest Hours Compliant' ;
    rdfs:comment 'Indicates whether this roster assignment satisfies the minimum rest hour requirements prescribed by the Maritime Labour Convention (MLC) 2006 Regulation 2.3. True if compliant; False if a potential violation is detected requiring review.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:navisWorkQueueCode rdf:type rdf:Property ;
    rdfs:label 'Navis Work Queue Code' ;
    rdfs:comment 'The NAVIS N4 Terminal Operating System work queue identifier associated with this roster assignment, linking the labour plan to specific container handling or vessel operations tasks in the TOS.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Rate Multiplier' ;
    rdfs:comment 'The pay rate multiplier applied to overtime shift assignments (e.g., 1.5 for time-and-a-half, 2.0 for double time). Used in payroll calculation for overtime and call-out shifts. Classified as confidential.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Hours' ;
    rdfs:comment 'The total planned working duration of the shift in decimal hours, excluding break entitlements. Used for payroll calculation, MLC maximum hours of work compliance, and labour cost forecasting.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'The planned date and time at which the employee\'s shift is scheduled to conclude. Used together with planned_start_time for MLC rest hour compliance and shift duration calculations.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'The planned date and time at which the employee\'s shift is scheduled to commence. Used for MLC rest hour compliance calculations and labour deployment planning.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:precedingRestHours rdf:type rdf:Property ;
    rdfs:label 'Preceding Rest Hours' ;
    rdfs:comment 'The actual number of rest hours recorded between the previous shift end and this shift\'s planned start time. Used to validate MLC minimum rest hour compliance before publishing the roster.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'The date and time at which the roster was published and made available to employees. Supports advance notice compliance requirements under enterprise agreements and MLC provisions.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rosterNumber rdf:type rdf:Property ;
    rdfs:label 'Roster Number' ;
    rdfs:comment 'Externally-known business identifier for the roster record, used in workforce planning communications, MLC compliance reporting, and integration with Oracle HCM Cloud and SAP HR. Format: RST-YYYY-NNNNNN.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaLabourReadinessMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Labour Readiness Minutes' ;
    rdfs:comment 'The contracted or target number of minutes within which the assigned employee or gang must be ready and deployed at the designated work location after shift commencement. Supports Key Performance Indicator (KPI) measurement for vessel turnaround SLA compliance.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native record identifier from the originating operational system (Oracle HCM Cloud, NAVIS N4, or SAP HR) for this roster entry. Enables reconciliation and traceability back to the system of record.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableDepartment rdf:type rdf:Property ;
    rdfs:label 'Applicable Department' ;
    rdfs:comment 'Name or code of the port department or operational division to which this shift pattern applies (e.g., \'Terminal Operations\', \'Marine Services\', \'Security\', \'Yard Operations\', \'Gate Operations\', \'Administration\'). Supports department-level workforce planning and reporting.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakCount rdf:type rdf:Property ;
    rdfs:label 'Break Count' ;
    rdfs:comment 'Number of discrete break periods scheduled within the shift pattern. Supports detailed roster planning and MLC rest hour compliance verification where minimum break frequency is mandated.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total scheduled break entitlement in minutes for the shift pattern. Includes all meal and rest breaks. Distinguishing paid vs unpaid breaks is captured in is_break_paid flag. Used for MLC rest hour compliance and payroll deduction calculations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Days Of Week' ;
    rdfs:comment 'Comma-separated list of days on which this shift pattern is scheduled (e.g., \'MON,TUE,WED,THU,FRI\' for weekdays; \'SAT,SUN\' for weekends; \'MON,TUE,WED,THU,FRI,SAT,SUN\' for 7-day operations). Supports roster generation and weekend/public holiday penalty rate identification.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enterpriseAwardCode rdf:type rdf:Property ;
    rdfs:label 'Enterprise Award Code' ;
    rdfs:comment 'Code referencing the enterprise bargaining agreement or industrial award under which this shift pattern is defined (e.g., \'MUA-EBA-2023\', \'AMOU-AWARD-2022\'). Ensures payroll and rostering compliance with applicable industrial instruments for maritime and port workers.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueRiskIndex rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Index' ;
    rdfs:comment 'Numeric fatigue risk score assigned to this shift pattern based on shift timing, duration, and rotation frequency. Higher values indicate greater fatigue risk. Used in MLC compliance monitoring, OHS risk management, and roster optimisation to minimise fatigue-related incidents in safety-critical port operations.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hcmWorkScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Hcm Work Schedule Code' ;
    rdfs:comment 'Source system identifier for the corresponding Work Schedule record in Oracle HCM Cloud. Enables bi-directional traceability between the Silver Layer data product and the operational system of record for reconciliation and change management.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBreakPaid rdf:type rdf:Property ;
    rdfs:label 'Is Break Paid' ;
    rdfs:comment 'Indicates whether the scheduled break entitlement for this shift pattern is paid (True) or unpaid (False). Determines whether break_duration_minutes is deducted from paid_hours in payroll processing.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvernight rdf:type rdf:Property ;
    rdfs:label 'Is Overnight' ;
    rdfs:comment 'Indicates whether the shift pattern spans midnight (True) or is contained within a single calendar day (False). Used in roster date calculations, night shift penalty rate application, and MLC rest hour tracking across calendar day boundaries.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicHolidayApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Public Holiday Applicable' ;
    rdfs:comment 'Indicates whether this shift pattern is scheduled to operate on public holidays (True) or is suspended on public holidays (False). Drives public holiday penalty rate application in payroll and supports port operational continuity planning for 24/7 terminal operations.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxCrewSize rdf:type rdf:Property ;
    rdfs:label 'Max Crew Size' ;
    rdfs:comment 'Maximum number of personnel that can be rostered under this shift pattern, constrained by equipment capacity, berth space, or operational safety limits. Used in workforce scheduling to prevent over-allocation and manage OPEX.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minCrewSize rdf:type rdf:Property ;
    rdfs:label 'Min Crew Size' ;
    rdfs:comment 'Minimum number of personnel required to be rostered under this shift pattern to meet safe operational standards and SLA commitments. Used in workforce capacity planning, gang allocation for stevedore operations, and OHS compliance validation.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mlcMaxHoursWorkPerDay rdf:type rdf:Property ;
    rdfs:label 'Mlc Max Hours Work Per Day' ;
    rdfs:comment 'Maximum hours of work permitted per 24-hour period under the Maritime Labour Convention (MLC) 2006 for this shift pattern. Standard MLC limit is 14 hours. Used in compliance validation to ensure shift assignments do not breach MLC rest hour requirements.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlcMaxHoursWorkPerWeek rdf:type rdf:Property ;
    rdfs:label 'Mlc Max Hours Work Per Week' ;
    rdfs:comment 'Maximum hours of work permitted per 7-day period under the Maritime Labour Convention (MLC) 2006 for this shift pattern. Standard MLC limit is 72 hours. Used in weekly compliance reporting and roster validation.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlcMinRestHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Mlc Min Rest Hours Per Day' ;
    rdfs:comment 'Minimum hours of rest required per 24-hour period under the Maritime Labour Convention (MLC) 2006 for this shift pattern. Standard MLC minimum is 10 hours. Used in compliance validation to ensure adequate rest between consecutive shift assignments.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlcMinRestHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Mlc Min Rest Hours Per Week' ;
    rdfs:comment 'Minimum hours of rest required per 7-day period under the Maritime Labour Convention (MLC) 2006 for this shift pattern. Standard MLC minimum is 77 hours. Used in weekly MLC compliance reporting submitted to Port State Control (PSC) authorities.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ohsRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Ohs Risk Level' ;
    rdfs:comment 'Occupational Health and Safety (OHS) risk classification assigned to this shift pattern based on time-of-day, operational environment, and task type. Drives mandatory safety briefing requirements, PPE specifications, and incident reporting thresholds. Aligns with ISO 45001 risk assessment framework.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Threshold Hours' ;
    rdfs:comment 'Number of hours worked within this shift pattern beyond which overtime rates apply. Used in payroll processing to automatically trigger overtime rate calculations in Oracle HCM Cloud and SAP S/4HANA HR.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidHours rdf:type rdf:Property ;
    rdfs:label 'Paid Hours' ;
    rdfs:comment 'Number of hours for which the employee is remunerated under this shift pattern, after deducting unpaid break entitlements from total duration. Used as the basis for payroll processing in SAP S/4HANA HR and Oracle HCM Cloud Payroll.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyRateCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Code' ;
    rdfs:comment 'Payroll penalty rate code applicable to this shift pattern, referencing the enterprise pay rate schedule in SAP S/4HANA HR (e.g., \'NIGHT-1.5X\', \'WKND-2X\', \'PH-2.5X\', \'STD-1X\'). Drives automated payroll calculation for shift-based penalty loadings.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertificationCodes rdf:type rdf:Property ;
    rdfs:label 'Required Certification Codes' ;
    rdfs:comment 'Comma-separated list of competency certification codes required for personnel assigned to this shift pattern (e.g., \'STCW,ISPS,RTG-OPS,STS-CRANE\'). Used in competency-based scheduling to ensure only qualified personnel are rostered. References the workforce competency certification register.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationCycleDays rdf:type rdf:Property ;
    rdfs:label 'Rotation Cycle Days' ;
    rdfs:comment 'Number of calendar days in the full rotation cycle for rotating shift patterns (e.g., 7 for weekly rotation, 14 for fortnightly, 28 for 4-week cycle). Null for non-rotating shift types. Used in roster generation and long-term workforce planning.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rotationSequence rdf:type rdf:Property ;
    rdfs:label 'Rotation Sequence' ;
    rdfs:comment 'Ordinal position of this shift pattern within a rotation cycle (e.g., 1 = first leg, 2 = second leg). Used to sequence multiple shift_pattern records that together form a complete rotating roster cycle. Null for non-rotating shift types.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapWorkScheduleVariant rdf:type rdf:Property ;
    rdfs:label 'Sap Work Schedule Variant' ;
    rdfs:comment 'SAP S/4HANA HR work schedule variant code corresponding to this shift pattern, used for payroll time evaluation and absence/attendance management. Enables cross-system alignment between Oracle HCM Cloud roster data and SAP payroll processing.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCategory rdf:type rdf:Property ;
    rdfs:label 'Shift Category' ;
    rdfs:comment 'Broad time-of-day category of the shift pattern used for workforce planning, penalty rate determination, and MLC rest hour compliance reporting. \'day\' typically covers 06:00–18:00; \'afternoon\' covers 14:00–22:00; \'night\' covers 22:00–06:00; \'early_morning\' covers 04:00–12:00; \'rotating\' covers patterns that cycle across categories.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the shift pattern (e.g., DAY-01, NIGHT-03, STBY-AM). Used as the business key across Oracle HCM Cloud, SAP HR, and NAVIS N4 for cross-system referencing.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDescription rdf:type rdf:Property ;
    rdfs:label 'Shift Description' ;
    rdfs:comment 'Free-text description providing additional context about the shift pattern, including operational purpose, special conditions, applicable vessel operations, or notes on MLC compliance exceptions. Supports business user understanding and documentation.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Human-readable name of the shift pattern (e.g., \'Day Shift\', \'Night Shift\', \'Afternoon Rotating\', \'Marine Pilot Standby\'). Used in rosters, payroll reports, and workforce scheduling displays.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle status of the shift pattern record. \'active\' indicates available for roster assignment; \'inactive\' indicates temporarily suspended; \'draft\' indicates pending approval; \'under_review\' indicates subject to MLC or award compliance review; \'retired\' indicates permanently decommissioned.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyActivationNoticeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standby Activation Notice Minutes' ;
    rdfs:comment 'Minimum notice period in minutes required to activate an employee from standby to active duty under this shift pattern. Applicable only to standby and call-out shift types. Used in operational planning for vessel arrival response and emergency port operations.' ;
    rdfs:domain ind:ShiftPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:talentProfileId rdf:type rdf:Property ;
    rdfs:label 'Talent Profile Id' ;
    rdfs:comment 'Unique identifier for the employee talent profile record. Primary key for the talent profile entity.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Reference to the HR business partner or talent manager responsible for maintaining and updating this talent profile.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryTalentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Talent Employee Id' ;
    rdfs:comment 'Reference to the employee master record in the workforce domain. Links this talent profile to the core employee entity.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:careerAspiration rdf:type rdf:Property ;
    rdfs:label 'Career Aspiration' ;
    rdfs:comment 'Employee\'s stated career goals and desired future roles within the organization. Captured during talent review conversations and career development discussions.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalExperienceGaps rdf:type rdf:Property ;
    rdfs:label 'Critical Experience Gaps' ;
    rdfs:comment 'Identified gaps in experience or exposure that must be addressed before the employee is ready for the target succession role (e.g., vessel operations experience, P&L management, multi-terminal oversight).' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPriority rdf:type rdf:Property ;
    rdfs:label 'Development Priority' ;
    rdfs:comment 'Priority level assigned for investing in this employee\'s development based on talent segment, performance, potential, and business needs.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationLevel rdf:type rdf:Property ;
    rdfs:label 'Education Level' ;
    rdfs:comment 'Highest level of formal education attained by the employee (e.g., Bachelor\'s Degree in Maritime Studies, Master\'s in Logistics, Maritime Academy Diploma).' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOfLoss rdf:type rdf:Property ;
    rdfs:label 'Impact Of Loss' ;
    rdfs:comment 'Assessment of the business impact if this employee were to leave, considering role criticality, specialized skills, and knowledge concentration.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keySkills rdf:type rdf:Property ;
    rdfs:label 'Key Skills' ;
    rdfs:comment 'Comma-separated list of the employee\'s core competencies and technical skills relevant to maritime logistics operations (e.g., NAVIS N4, crane operations, vessel planning, ISPS compliance).' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTalentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Talent Review Date' ;
    rdfs:comment 'Date of the most recent formal talent review or calibration session where this employee\'s profile was assessed and updated.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadershipCompetencies rdf:type rdf:Property ;
    rdfs:label 'Leadership Competencies' ;
    rdfs:comment 'Assessment of leadership capabilities including people management, strategic thinking, decision-making, and change management. Critical for succession into management roles.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mentoringStatus rdf:type rdf:Property ;
    rdfs:label 'Mentoring Status' ;
    rdfs:comment 'Current status of the formal mentoring relationship indicating whether the employee is actively being mentored.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTalentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Talent Review Date' ;
    rdfs:comment 'Scheduled date for the next formal talent review or calibration session for this employee.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:potentialRating rdf:type rdf:Property ;
    rdfs:label 'Potential Rating' ;
    rdfs:comment 'Assessment of the employee\'s future growth potential and ability to take on roles of greater scope and complexity. Key input to the 9-box talent matrix.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLocation rdf:type rdf:Property ;
    rdfs:label 'Preferred Location' ;
    rdfs:comment 'Specific geographic location or terminal where the employee prefers to work if relocation is required. Supports internal mobility and succession planning.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredNextRole rdf:type rdf:Property ;
    rdfs:label 'Preferred Next Role' ;
    rdfs:comment 'Specific job role or position that the employee aspires to move into as their next career step. Used for succession planning and internal mobility.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileNotes rdf:type rdf:Property ;
    rdfs:label 'Profile Notes' ;
    rdfs:comment 'Confidential notes and observations from talent review discussions, calibration sessions, and development conversations. Restricted to HR and senior leadership.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Number' ;
    rdfs:comment 'Human-readable business identifier for the talent profile, typically generated by Oracle HCM Cloud Talent Management module.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskOfLoss rdf:type rdf:Property ;
    rdfs:label 'Risk Of Loss' ;
    rdfs:comment 'Assessment of the likelihood that the employee may leave the organization voluntarily. Used for retention planning and intervention strategies.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stcwCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Stcw Certification Level' ;
    rdfs:comment 'Highest STCW certification level held by the employee if applicable to marine operations roles (e.g., Officer of the Watch, Master Mariner, Marine Pilot).' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanRole rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Role' ;
    rdfs:comment 'Target role or position for which this employee is identified as a potential successor. Links to the organization\'s formal succession planning process.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionRank rdf:type rdf:Property ;
    rdfs:label 'Succession Rank' ;
    rdfs:comment 'Ranking of this employee among multiple successors for the same target role (1 = primary successor, 2 = backup, etc.). Used for succession depth analysis.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successionReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Succession Readiness Level' ;
    rdfs:comment 'Assessment of the employee\'s readiness to assume the next role or target position in the succession plan. Critical for workforce continuity planning.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentSegment rdf:type rdf:Property ;
    rdfs:label 'Talent Segment' ;
    rdfs:comment 'Strategic talent classification indicating the employee\'s designation in the organization\'s talent matrix (9-box grid). Used for succession planning and development prioritization.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompetencies rdf:type rdf:Property ;
    rdfs:label 'Technical Competencies' ;
    rdfs:comment 'Specialized technical skills and certifications relevant to port operations (e.g., STCW certifications, TOS expertise, equipment operation, marine pilotage, IMDG handling).' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingPlan rdf:type rdf:Property ;
    rdfs:label 'Training Plan' ;
    rdfs:comment 'Structured training and development activities planned for the employee including courses, certifications, on-the-job training, and stretch assignments.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsInIndustry rdf:type rdf:Property ;
    rdfs:label 'Years In Industry' ;
    rdfs:comment 'Total years of experience in the maritime logistics industry. Used for assessing depth of industry knowledge and readiness for senior roles.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearsInOrganization rdf:type rdf:Property ;
    rdfs:label 'Years In Organization' ;
    rdfs:comment 'Total years of service with Shipping Ports. Indicates organizational knowledge and cultural fit for leadership succession.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeAttendanceId rdf:type rdf:Property ;
    rdfs:label 'Time Attendance Id' ;
    rdfs:comment 'Unique surrogate identifier for each time and attendance record in the port workforce management system. Primary key for this entity.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Reference to the employee whose time and attendance is being recorded. Links to the workforce employee master record in Oracle HCM Cloud.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceType rdf:type rdf:Property ;
    rdfs:label 'Absence Type' ;
    rdfs:comment 'Classification of the reason for employee absence when attendance_status is \'absent\'. Drives leave balance deduction and payroll treatment in Oracle HCM Cloud and SAP HR. [ENUM-REF-CANDIDATE: annual_leave|sick_leave|unpaid_leave|public_holiday|maternity_paternity|training|compassionate|jury_duty|medical_appointment|suspension — promote to reference product]' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendanceDate rdf:type rdf:Property ;
    rdfs:label 'Attendance Date' ;
    rdfs:comment 'The calendar date for which this time and attendance record applies. Used for daily payroll calculation, MLC rest hour compliance monitoring, and workforce reporting.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attendanceStatus rdf:type rdf:Property ;
    rdfs:label 'Attendance Status' ;
    rdfs:comment 'Current attendance status of the employee for the shift. Indicates whether the employee was present, absent, arrived late, departed early, or partially attended. Critical for payroll deduction and MLC compliance reporting.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricVerified rdf:type rdf:Property ;
    rdfs:label 'Biometric Verified' ;
    rdfs:comment 'Indicates whether the employee\'s identity was verified via biometric authentication (fingerprint, facial recognition) at clock-in or gate entry. True = biometric verification completed; False = RFID-only or manual entry. Supports ISPS security compliance and payroll fraud prevention.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Break End Timestamp' ;
    rdfs:comment 'The timestamp when the employee returned from their scheduled break period. Used together with break_start_timestamp to calculate total break duration and net productive hours.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breakStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Break Start Timestamp' ;
    rdfs:comment 'The timestamp when the employee commenced their scheduled break period during the shift. Used to calculate net working hours and verify MLC minimum rest period compliance.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'The exact date and time the employee clocked in at the start of their shift, captured via RFID badge scan or biometric verification at the terminal gate or facility entry point. Principal business event timestamp for this record.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock Out Timestamp' ;
    rdfs:comment 'The exact date and time the employee clocked out at the end of their shift, captured via RFID badge scan or biometric verification. Used to calculate total hours worked and overtime.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:earlyDepartureMinutes rdf:type rdf:Property ;
    rdfs:label 'Early Departure Minutes' ;
    rdfs:comment 'Number of minutes the employee departed before the scheduled shift end time. Zero if departed on time or later. Used for attendance discipline tracking and payroll deduction calculation.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryMethod rdf:type rdf:Property ;
    rdfs:label 'Entry Method' ;
    rdfs:comment 'The method by which the clock-in/clock-out time was captured. RFID scan = automated badge reader; Biometric = fingerprint/facial recognition; Manual = supervisor or HR manual entry; Mobile app = employee self-service; Supervisor entry = entered by line manager.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gate Entry Timestamp' ;
    rdfs:comment 'The timestamp when the employee physically entered the port terminal through the security gate, captured from NAVIS N4 Gate Operations or ISPS-compliant access control system. May differ from clock_in_timestamp if the employee entered the terminal before clocking in.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gateExitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gate Exit Timestamp' ;
    rdfs:comment 'The timestamp when the employee physically exited the port terminal through the security gate. Used for ISPS security compliance, access duration tracking, and cross-referencing with clock-out data.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total net hours worked by the employee during the shift, calculated as (clock_out - clock_in) minus break_duration_minutes. Expressed in decimal hours. Feeds SAP HR payroll calculation and MLC rest hour compliance monitoring.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPublicHoliday rdf:type rdf:Property ;
    rdfs:label 'Is Public Holiday' ;
    rdfs:comment 'Indicates whether the attendance date falls on a public holiday. True = public holiday; False = regular working day. Drives public holiday pay rate multiplier application in SAP HR payroll.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateArrivalMinutes rdf:type rdf:Property ;
    rdfs:label 'Late Arrival Minutes' ;
    rdfs:comment 'Number of minutes the employee arrived late relative to the scheduled shift start time. Zero if on time or early. Used for attendance discipline tracking, payroll deduction calculation, and KPI reporting on workforce punctuality.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payPeriodCode rdf:type rdf:Property ;
    rdfs:label 'Pay Period Code' ;
    rdfs:comment 'Identifier for the payroll period (e.g., 2024-W23, 2024-M06) to which this attendance record belongs. Used to group attendance records for payroll run processing in SAP HR.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollProcessed rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed' ;
    rdfs:comment 'Indicates whether this attendance record has been included in a payroll run and processed in SAP HR. True = included in payroll; False = pending payroll processing. Prevents double-counting in payroll runs.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restHoursBeforeShift rdf:type rdf:Property ;
    rdfs:label 'Rest Hours Before Shift' ;
    rdfs:comment 'Number of hours of rest the employee had between the end of their previous shift and the start of this shift. Critical for MLC 2006 Regulation 2.3 compliance monitoring — minimum 10 hours rest required in any 24-hour period.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Rfid Badge Number' ;
    rdfs:comment 'The unique RFID badge identifier used by the employee to clock in/out and access the terminal. Captured from RFID reader scan events. Used to verify identity and link physical access events to attendance records.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The native record identifier from the originating source system (Oracle HCM Cloud, SAP HR, or NAVIS N4). Used for data lineage tracing, reconciliation, and deduplication in the Databricks Silver Layer.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Unique identifier for the training course record. Primary key for the training course entity.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:courseOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Course Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for the design, maintenance, and quality assurance of the training course content. Typically a training manager or subject matter expert.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingFacilityWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Training Facility Warehouse Id' ;
    rdfs:comment 'Foreign key linking to infrastructure.warehouse. Business justification: Training venues often use port warehouses for practical cargo handling and IMDG training. Tracks facility utilization, scheduling conflicts, and logistics. Removes denormalized default_venue_name.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:certificateValidityMonths rdf:type rdf:Property ;
    rdfs:label 'Certificate Validity Months' ;
    rdfs:comment 'Number of months that the certificate issued upon course completion remains valid before renewal or recertification is required. Null if the certificate does not expire or if no certificate is issued.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether successful completion of this course results in the issuance of a formal certificate or credential. True if a certificate is issued; false if only a completion record is maintained.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique business identifier for the training course in the learning management system catalogue. Used for course registration and scheduling.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCostAmount rdf:type rdf:Property ;
    rdfs:label 'Course Cost Amount' ;
    rdfs:comment 'Total cost per participant for delivering the training course, including instructor fees, materials, venue rental, and equipment usage. Used for training budget planning and cost allocation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseLanguage rdf:type rdf:Property ;
    rdfs:label 'Course Language' ;
    rdfs:comment 'Primary language in which the training course is delivered, using ISO 639-2 three-letter language codes (e.g., ENG for English, SPA for Spanish, FRA for French).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseMaterialsProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Course Materials Provided Flag' ;
    rdfs:comment 'Indicates whether training materials (manuals, handouts, digital resources) are provided to participants as part of the course. True if materials are provided; false if participants must source their own materials.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:courseObjectives rdf:type rdf:Property ;
    rdfs:label 'Course Objectives' ;
    rdfs:comment 'Detailed description of the learning objectives and outcomes that participants will achieve upon successful completion of the training course.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseStatus rdf:type rdf:Property ;
    rdfs:label 'Course Status' ;
    rdfs:comment 'Current lifecycle status of the training course in the catalogue. Active courses are available for enrolment; inactive courses are temporarily unavailable; under review courses are being updated; retired courses are no longer offered; draft courses are in development.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseTitle rdf:type rdf:Property ;
    rdfs:label 'Course Title' ;
    rdfs:comment 'Full descriptive title of the training course as displayed in the learning catalogue and on certificates.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'Classification of the training course by its primary purpose: induction (new hire orientation), safety (OHS and emergency response), technical (equipment and operational skills), leadership (management development), regulatory (MLC, ISPS, SOLAS), or compliance (mandatory certifications).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'Method by which the training course is delivered: classroom (instructor-led in-person), e-learning (online self-paced), on-the-job (practical workplace training), simulator (equipment or vessel simulator), or blended (combination of methods).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Compliance Flag' ;
    rdfs:comment 'Indicates whether the training course is mandatory for regulatory compliance (MLC, ISPS, SOLAS, OHS) or operational certification. True if the course is required by law or port policy; false if the course is optional or developmental.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumEnrolment rdf:type rdf:Property ;
    rdfs:label 'Maximum Enrolment' ;
    rdfs:comment 'Maximum number of participants that can be enrolled in a single delivery session of the course, constrained by venue capacity, instructor ratio, or equipment availability.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percentage' ;
    rdfs:comment 'Minimum score percentage required to pass the course assessment and achieve completion status. Null if no formal assessment or passing threshold is defined.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the organization or department providing the training course. For internal courses, this is the port department; for external courses, this is the vendor or training institution name.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the training provider: internal (delivered by port staff), external (third-party training organization), vendor (equipment manufacturer training), or industry_body (IAPH, IMO, or maritime association).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refresherCourseFlag rdf:type rdf:Property ;
    rdfs:label 'Refresher Course Flag' ;
    rdfs:comment 'Indicates whether this course is a refresher or recertification course designed to renew an existing competency or certification. True if this is a refresher course; false if this is initial training.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended audience for the training course, such as job roles, departments, or employee categories (e.g., stevedore gangs, equipment operators, marine pilots, security personnel, administrative staff).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueType rdf:type rdf:Property ;
    rdfs:label 'Venue Type' ;
    rdfs:comment 'Type of location where the training course is delivered: on-site (port training facility), off-site (external training center), online (virtual platform), field (operational work area), or simulator facility (equipment or vessel simulator).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingEnrolmentId rdf:type rdf:Property ;
    rdfs:label 'Training Enrolment Id' ;
    rdfs:comment 'Unique identifier for the training enrolment record. Primary key.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTrainingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Employee Id' ;
    rdfs:comment 'Unique identifier of the employee enrolled in the training course. Links to the employee master record.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attendancePercentage rdf:type rdf:Property ;
    rdfs:label 'Attendance Percentage' ;
    rdfs:comment 'Percentage of scheduled training sessions or hours that the employee attended. Used to determine eligibility for assessment and completion.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrolmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrolment Date' ;
    rdfs:comment 'Date on which the employee was officially enrolled in the training course. Represents the business event timestamp for enrolment initiation.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrolmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrolment Number' ;
    rdfs:comment 'Business-facing unique enrolment reference number generated by the Learning Management System for tracking and reporting purposes.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrolmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrolment Source' ;
    rdfs:comment 'Origin or trigger that initiated this training enrolment, such as employee self-service request, manager nomination, mandatory compliance requirement, or talent development program.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrolmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrolment Status' ;
    rdfs:comment 'Current lifecycle status of the training enrolment indicating whether the employee is enrolled, actively participating, has completed, withdrawn, or failed the course. [ENUM-REF-CANDIDATE: enrolled|in_progress|completed|withdrawn|failed|deferred|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to achieve a pass result for this training course enrolment. Used to determine pass/fail outcome.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether this training course requires periodic recertification or refresher training to maintain competency and compliance.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date on which the training course is scheduled to conclude for this enrolment.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date on which the training course is scheduled to commence for this enrolment.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainerFeedback rdf:type rdf:Property ;
    rdfs:label 'Trainer Feedback' ;
    rdfs:comment 'Free-text feedback provided by the trainer or facilitator regarding the employees performance, participation, and areas for improvement during the training.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Training Cost Amount' ;
    rdfs:comment 'Total cost incurred for this training enrolment, including course fees, materials, trainer costs, and venue expenses.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Method' ;
    rdfs:comment 'Method by which the training course was delivered to the employee, such as classroom-based, online e-learning, blended learning, or on-the-job training.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHours rdf:type rdf:Property ;
    rdfs:label 'Training Hours' ;
    rdfs:comment 'Total number of hours the employee spent in training activities for this enrolment, including classroom time, online modules, and assessments.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingPlatform rdf:type rdf:Property ;
    rdfs:label 'Training Platform' ;
    rdfs:comment 'Name of the digital learning platform or system used to deliver online or blended training content (e.g., Oracle Learn, Moodle, Cornerstone).' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingVenue rdf:type rdf:Property ;
    rdfs:label 'Training Venue' ;
    rdfs:comment 'Physical location or facility where the training was conducted. For online training, may indicate the platform or virtual environment used.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentId rdf:type rdf:Property ;
    rdfs:label 'Deployment Id' ;
    rdfs:comment 'Unique identifier for this gang deployment record. Primary key.' ;
    rdfs:domain ind:Deployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:infrastructureBerthReservationId rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Berth Reservation Id' ;
    rdfs:comment 'Primary key for infrastructure_berth_reservation' ;
    rdfs:domain ind:InfrastructureBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:berthReservationId rdf:type rdf:Property ;
    rdfs:label 'Berth Reservation Id' ;
    rdfs:comment 'Unique identifier for this berth reservation record. Primary key.' ;
    rdfs:domain ind:InfrastructureBerthReservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BookingBerthReservation .

ind:actualAtb rdf:type rdf:Property ;
    rdfs:label 'Actual Atb' ;
    rdfs:comment 'Actual timestamp when the vessel berthed at this specific berth. Populated after berthing operation completes.' ;
    rdfs:domain ind:InfrastructureBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualAtd rdf:type rdf:Property ;
    rdfs:label 'Actual Atd' ;
    rdfs:comment 'Actual timestamp when the vessel departed from this specific berth. Populated after unberthing operation completes.' ;
    rdfs:domain ind:InfrastructureBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedBerthCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Berth Code' ;
    rdfs:comment 'Code identifying the actual berth location assigned by port operations for the vessel call. [Moved from call_booking: This attribute represents the confirmed berth for a specific reservation, not a property of the booking itself. A vessel call booking may have multiple berth assignments over time (e.g., shift from one berth to another during the call).]' ;
    rdfs:domain ind:InfrastructureBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedBerthCode rdf:type rdf:Property ;
    rdfs:label 'Requested Berth Code' ;
    rdfs:comment 'Code identifying the preferred or requested berth location for the vessel call as specified by the shipping line or agent. [Moved from call_booking: This attribute represents the initial berth preference for a specific reservation attempt, not a property of the booking itself. In a multi-berth scenario, the booking may have multiple reservation attempts with different requested berths.]' ;
    rdfs:domain ind:InfrastructureBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationCancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when this berth reservation was cancelled, either due to booking cancellation or berth reallocation.' ;
    rdfs:domain ind:InfrastructureBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Confirmed Timestamp' ;
    rdfs:comment 'Timestamp when this berth reservation was officially confirmed by port operations, locking the berth allocation.' ;
    rdfs:domain ind:InfrastructureBerthReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:participantServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Participant Service Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for each participant-service agreement record. Primary key.' ;
    rdfs:domain ind:ParticipantServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Reference Number' ;
    rdfs:comment 'External reference number for the commercial agreement or contract document that governs this participant-service pricing. Links to contract management system or document repository.' ;
    rdfs:domain ind:ParticipantServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFrequencyOverride rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency Override' ;
    rdfs:comment 'Service-specific billing frequency that overrides standard billing cycles (e.g., per call, weekly, monthly, quarterly). Used when participants negotiate consolidated billing for specific services.' ;
    rdfs:domain ind:ParticipantServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatedRate rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate' ;
    rdfs:comment 'Participant-specific negotiated rate for this service, overriding the standard tariff rate. Used by billing systems to calculate charges. Null indicates standard rate applies.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier rdf:type rdf:Property ;
    rdfs:label 'Volume Tier' ;
    rdfs:comment 'Volume tier classification for this participant-service agreement (e.g., Tier 1: 0-1000 TEU, Tier 2: 1001-5000 TEU, Tier 3: 5000+ TEU). Determines eligibility for volume-based discounts.' ;
    rdfs:domain ind:ParticipantServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentTariffExceptionId rdf:type rdf:Property ;
    rdfs:label 'Shipment Tariff Exception Id' ;
    rdfs:comment 'Primary key for the shipment_tariff_exception association' ;
    rdfs:domain ind:ShipmentTariffException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applied By Employee Id' ;
    rdfs:comment 'Reference to the employee who applied this exception to this shipment in the billing system. Audit trail for operational accountability.' ;
    rdfs:domain ind:ShipmentTariffException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationJustification rdf:type rdf:Property ;
    rdfs:label 'Application Justification' ;
    rdfs:comment 'Detailed business justification for applying this specific exception to this specific shipment. Required for audit and compliance.' ;
    rdfs:domain ind:ShipmentTariffException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Applied Discount Percentage' ;
    rdfs:comment 'The actual percentage discount applied to this shipment under this exception. Captured at application time for audit trail.' ;
    rdfs:domain ind:ShipmentTariffException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedExceptionRateAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Exception Rate Amount' ;
    rdfs:comment 'The actual exceptional rate amount applied to this specific shipment under this exception. May differ from the exception\'s standard rate if further negotiation occurred.' ;
    rdfs:domain ind:ShipmentTariffException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedFreeDaysGranted rdf:type rdf:Property ;
    rdfs:label 'Applied Free Days Granted' ;
    rdfs:comment 'The actual number of extended free days granted to this shipment under this exception. Critical for demurrage calculation.' ;
    rdfs:domain ind:ShipmentTariffException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedWaiverAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Waiver Amount' ;
    rdfs:comment 'The actual monetary amount waived for this shipment under this exception. Tracks the revenue impact per shipment.' ;
    rdfs:domain ind:ShipmentTariffException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'Calculated revenue impact (loss or gain) from applying this exception to this shipment. Used for commercial analysis and reporting.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agencyAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Agency Appointment Id' ;
    rdfs:comment 'Unique surrogate identifier for each vessel agency appointment record. Primary key for the association.' ;
    rdfs:domain ind:AgencyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointingPartyImoCompanyNumber rdf:type rdf:Property ;
    rdfs:label 'Appointing Party Imo Company Number' ;
    rdfs:comment 'IMO company identification number of the entity that made the agency appointment. Links to the vessel ownership/management hierarchy.' ;
    rdfs:domain ind:AgencyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointingPartyName rdf:type rdf:Property ;
    rdfs:label 'Appointing Party Name' ;
    rdfs:comment 'Name of the entity that made the agency appointment (typically the vessel owner, technical manager, or commercial operator). Identifies who has the authority to appoint and terminate the agent.' ;
    rdfs:domain ind:AgencyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Appointment Created By' ;
    rdfs:comment 'User identifier of the person who created the agency appointment record. Used for audit trail and accountability.' ;
    rdfs:domain ind:AgencyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Created Date' ;
    rdfs:comment 'Timestamp when the agency appointment record was created in the system. Used for audit trail and appointment history tracking.' ;
    rdfs:domain ind:AgencyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorityLevel rdf:type rdf:Property ;
    rdfs:label 'Authority Level' ;
    rdfs:comment 'Level of decision-making authority granted to the agent. Full authority allows agent to commit vessel to services and expenses up to approved limits, limited authority requires pre-approval for major items, notification only means agent coordinates but does not commit.' ;
    rdfs:domain ind:AgencyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Limit Amount' ;
    rdfs:comment 'Maximum amount the agent is authorized to commit on behalf of the vessel without seeking additional approval. Null indicates no specific limit or full authority level does not require limits.' ;
    rdfs:domain ind:AgencyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Financial Limit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the financial limit amount.' ;
    rdfs:domain ind:AgencyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfAppointment rdf:type rdf:Property ;
    rdfs:label 'Port Of Appointment' ;
    rdfs:comment 'UN/LOCODE of the port where this agency appointment is valid. Many vessels have different agents at different ports. Null indicates the appointment is valid at all ports.' ;
    rdfs:domain ind:AgencyAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneAccessAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Zone Access Authorization Id' ;
    rdfs:comment 'Unique identifier for this zone access authorization record. Primary key.' ;
    rdfs:domain ind:ZoneAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Level of access granted to the credential holder within this specific zone. Determines what activities are permitted.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationGrantedBy rdf:type rdf:Property ;
    rdfs:label 'Authorization Granted By' ;
    rdfs:comment 'Name or identifier of the security officer or zone manager who granted this specific zone access authorization.' ;
    rdfs:domain ind:ZoneAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle status of this zone access authorization. Controls whether access control systems enforce this authorization.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marsecLevelOverride rdf:type rdf:Property ;
    rdfs:label 'Marsec Level Override' ;
    rdfs:comment 'Zone-specific MARSEC level override for this credential. If set, this authorization is only valid at the specified MARSEC level, overriding the credential\'s general marsec_level_access.' ;
    rdfs:domain ind:ZoneAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeRestrictions rdf:type rdf:Property ;
    rdfs:label 'Time Restrictions' ;
    rdfs:comment 'Temporal restrictions on when this credential can access this zone. Examples: 24/7, business_hours_only, 0600-1800, weekdays_only.' ;
    rdfs:domain ind:ZoneAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneAccessEntitlements rdf:type rdf:Property ;
    rdfs:label 'Zone Access Entitlements' ;
    rdfs:comment 'Comma-separated list of port security zone codes or identifiers that this credential authorizes access to. Examples include restricted areas, cargo handling zones, vessel berths, and administrative buildings. [Moved from access_credential: This comma-separated list of zone codes in access_credential is a denormalized representation of the many-to-many relationship. Each zone entitlement should be a separate record in zone_access_authorization with its own access_level, time_restrictions, and lifecycle attributes. The current attribute conflates multiple authorizations into a single string, preventing proper tracking of zone-specific access rules and authorization history.]' ;
    rdfs:domain ind:ZoneAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseParticipantId rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Participant Id' ;
    rdfs:comment 'Primary key for the emergency_response_participant association' ;
    rdfs:domain ind:EmergencyResponseParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactProtocol rdf:type rdf:Property ;
    rdfs:label 'Contact Protocol' ;
    rdfs:comment 'Specific communication protocol and contact method to be used for this participant in this emergency scenario (e.g., direct phone call, SMS alert, radio channel, email notification).' ;
    rdfs:domain ind:EmergencyResponseParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillParticipationCount rdf:type rdf:Property ;
    rdfs:label 'Drill Participation Count' ;
    rdfs:comment 'Total number of drills and exercises this participant has participated in for this specific emergency response plan. Used for compliance reporting.' ;
    rdfs:domain ind:EmergencyResponseParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillParticipationStatus rdf:type rdf:Property ;
    rdfs:label 'Drill Participation Status' ;
    rdfs:comment 'Whether this participant is required to participate in drills and exercises for this emergency response plan. Determines compliance tracking requirements.' ;
    rdfs:domain ind:EmergencyResponseParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPriority rdf:type rdf:Property ;
    rdfs:label 'Notification Priority' ;
    rdfs:comment 'Priority sequence for notifying this participant when this emergency response plan is activated. Lower numbers indicate earlier notification (1=immediate, 5=informational only).' ;
    rdfs:domain ind:EmergencyResponseParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participantRoleInPlan rdf:type rdf:Property ;
    rdfs:label 'Participant Role In Plan' ;
    rdfs:comment 'The specific role or responsibility assigned to this participant within this emergency response plan. Determines their activation sequence, responsibilities, and resource commitments.' ;
    rdfs:domain ind:EmergencyResponseParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationEndDate rdf:type rdf:Property ;
    rdfs:label 'Participation End Date' ;
    rdfs:comment 'Date on which this participant\'s involvement in this emergency response plan ended or will end. Nullable for active ongoing participation.' ;
    rdfs:domain ind:EmergencyResponseParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationStartDate rdf:type rdf:Property ;
    rdfs:label 'Participation Start Date' ;
    rdfs:comment 'Date from which this participant\'s involvement in this emergency response plan became effective. Supports historical tracking of participant changes.' ;
    rdfs:domain ind:EmergencyResponseParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current status of this participant\'s involvement in this emergency response plan. Only Active participants are included in activation protocols.' ;
    rdfs:domain ind:EmergencyResponseParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceCommitment rdf:type rdf:Property ;
    rdfs:label 'Resource Commitment' ;
    rdfs:comment 'Description of specific resources (personnel, equipment, vessels, facilities) that this participant has committed to provide when this emergency response plan is activated.' ;
    rdfs:domain ind:EmergencyResponseParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulierIcdServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Haulier Icd Service Agreement Id' ;
    rdfs:comment 'Unique identifier for this haulier-ICD service agreement record. Primary key.' ;
    rdfs:domain ind:HaulierIcdServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Monthly Volume Commitment' ;
    rdfs:comment 'Minimum monthly container volume (in TEU) that the haulier commits to transport to/from this ICD facility. Used for capacity planning and contract compliance monitoring.' ;
    rdfs:domain ind:HaulierIcdServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Priority tier assigned to this haulier for service at this specific ICD facility. Determines queue priority, slot allocation, and service level. Values: PLATINUM, GOLD, SILVER, BRONZE, STANDARD.' ;
    rdfs:domain ind:HaulierIcdServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerTeu rdf:type rdf:Property ;
    rdfs:label 'Rate Per Teu' ;
    rdfs:comment 'Negotiated transport rate per TEU (Twenty-foot Equivalent Unit) for container movement between the port and this ICD facility by this haulier. Rate is specific to this haulier-ICD combination.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Reference' ;
    rdfs:comment 'Business reference number or contract identifier for the service level agreement governing this haulier-ICD relationship. Used for contract lookup and commercial reference.' ;
    rdfs:domain ind:Intermodal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialHazardControlId rdf:type rdf:Property ;
    rdfs:label 'Material Hazard Control Id' ;
    rdfs:comment 'Unique identifier for this material-hazard control record. Primary key.' ;
    rdfs:domain ind:MaterialHazardControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who last modified this control record' ;
    rdfs:domain ind:MaterialHazardControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:controlEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness Rating' ;
    rdfs:comment 'Assessment of how effectively the current control measures mitigate this specific hazard for this specific material, based on incident history, audits, and inspections' ;
    rdfs:domain ind:MaterialHazardControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Control Verification Date' ;
    rdfs:comment 'Date when the control measures for this material-hazard combination were last verified through inspection, audit, or testing' ;
    rdfs:domain ind:MaterialHazardControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exposureFrequency rdf:type rdf:Property ;
    rdfs:label 'Exposure Frequency' ;
    rdfs:comment 'Frequency with which workers are exposed to this specific hazard when handling this material. Used to calculate exposure risk ratings.' ;
    rdfs:domain ind:MaterialHazardControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Handling Procedure Reference' ;
    rdfs:comment 'Reference code or document number for the specific safe handling procedure applicable to this material-hazard combination (e.g., SOP-CHEM-045, WI-FUEL-TRANSFER-12)' ;
    rdfs:domain ind:MaterialHazardControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Imdg Compliance Notes' ;
    rdfs:comment 'Specific IMDG Code compliance requirements or notes applicable to this material-hazard combination in the port environment' ;
    rdfs:domain ind:MaterialHazardControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationRestrictions rdf:type rdf:Property ;
    rdfs:label 'Storage Location Restrictions' ;
    rdfs:comment 'Specific storage location requirements or restrictions for this material due to this hazard (e.g., segregation requirements, temperature limits, ventilation requirements, distance from ignition sources)' ;
    rdfs:domain ind:MaterialHazardControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitVendorAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Permit Vendor Authorization Id' ;
    rdfs:comment 'Unique identifier for this permit-vendor authorization record. Primary key.' ;
    rdfs:domain ind:PermitVendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedPersonnelCount rdf:type rdf:Property ;
    rdfs:label 'Authorized Personnel Count' ;
    rdfs:comment 'Number of personnel from this vendor authorized to perform work under this permit. Used for headcount verification and safety compliance.' ;
    rdfs:domain ind:PermitVendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorized Timestamp' ;
    rdfs:comment 'Date and time when this vendor was officially authorized to commence work under this permit.' ;
    rdfs:domain ind:PermitVendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:safetyBriefingCompleted rdf:type rdf:Property ;
    rdfs:label 'Safety Briefing Completed' ;
    rdfs:comment 'Indicates whether this vendor\'s personnel have completed the mandatory safety briefing for this specific permit. Required before work commencement.' ;
    rdfs:domain ind:PermitVendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyBriefingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Safety Briefing Timestamp' ;
    rdfs:comment 'Date and time when the safety briefing was completed for this vendor\'s personnel for this permit.' ;
    rdfs:domain ind:PermitVendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisionLevel rdf:type rdf:Property ;
    rdfs:label 'Supervision Level' ;
    rdfs:comment 'Level of supervision required for this vendor under this permit: direct (continuous oversight), indirect (periodic checks), or self_supervised (competent person).' ;
    rdfs:domain ind:PermitVendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Work Completed Timestamp' ;
    rdfs:comment 'Date and time when this vendor completed their scope of work under this permit and site was cleared.' ;
    rdfs:domain ind:PermitVendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workScope rdf:type rdf:Property ;
    rdfs:label 'Work Scope' ;
    rdfs:comment 'Specific scope of work assigned to this vendor under this permit. Describes the vendor\'s particular responsibilities within the overall permitted activity.' ;
    rdfs:domain ind:PermitVendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotChannelAuthorisationId rdf:type rdf:Property ;
    rdfs:label 'Pilot Channel Authorisation Id' ;
    rdfs:comment 'Primary key for the pilot_channel_authorisation association' ;
    rdfs:domain ind:PilotChannelAuthorisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorisationDate rdf:type rdf:Property ;
    rdfs:label 'Authorisation Date' ;
    rdfs:comment 'Date on which this specific pilot-channel authorisation was officially granted by the port authority or maritime regulator. Used for compliance tracking and authorisation history.' ;
    rdfs:domain ind:PilotChannelAuthorisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorisationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorisation Expiry Date' ;
    rdfs:comment 'Date on which this pilot-channel authorisation expires and must be renewed. Drives operational scheduling and compliance monitoring to ensure only authorised pilots are assigned to channels.' ;
    rdfs:domain ind:PilotChannelAuthorisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorisedFairways rdf:type rdf:Property ;
    rdfs:label 'Authorised Fairways' ;
    rdfs:comment 'Comma-separated list of fairway section codes or names within the port jurisdiction that this pilot is authorised to navigate. Restricts pilot assignments to approved waterway sections in VTMS. Example: \'MAIN_CHANNEL,NORTH_APPROACH,INNER_HARBOUR\'. [Moved from pilot: This comma-separated text field is a denormalized representation of the many-to-many relationship between pilots and channels. Each pilot-channel authorisation should be a separate record in the association product, eliminating the need for this denormalized field. The detection reasoning explicitly identified this as \'currently denormalized as authorised_fairways text field on pilot table\'.]' ;
    rdfs:domain ind:PilotChannelAuthorisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorisingOfficer rdf:type rdf:Property ;
    rdfs:label 'Authorising Officer' ;
    rdfs:comment 'Name or employee reference of the port authority officer or maritime regulator who granted this pilot-channel authorisation. Used for audit trail and regulatory compliance documentation.' ;
    rdfs:domain ind:PilotChannelAuthorisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceEndorsementCode rdf:type rdf:Property ;
    rdfs:label 'Licence Endorsement Code' ;
    rdfs:comment 'Specific endorsement code or reference number issued for this pilot-channel authorisation, linking to the pilot\'s licence documentation and regulatory approval records.' ;
    rdfs:domain ind:PilotChannelAuthorisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVesselDwtAuthorised rdf:type rdf:Property ;
    rdfs:label 'Max Vessel Dwt Authorised' ;
    rdfs:comment 'Maximum vessel Deadweight Tonnage (DWT) in metric tonnes that this pilot is authorised to handle specifically within this channel. Channel-specific authorisation may be more restrictive than the pilot\'s general licence limits.' ;
    rdfs:domain ind:PilotChannelAuthorisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVesselLoaAuthorisedM rdf:type rdf:Property ;
    rdfs:label 'Max Vessel Loa Authorised M' ;
    rdfs:comment 'Maximum vessel Length Overall (LOA) in metres that this pilot is authorised to handle specifically within this channel. May differ from the pilot\'s general max_loa_m based on channel-specific examination and experience requirements.' ;
    rdfs:domain ind:PilotChannelAuthorisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passagesCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Passages Completed Count' ;
    rdfs:comment 'Total number of pilotage passages this pilot has completed in this specific channel. Used for experience tracking, proficiency assessment, and authorisation renewal decisions.' ;
    rdfs:domain ind:PilotChannelAuthorisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationAccessAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Location Access Authorization Id' ;
    rdfs:comment 'Unique surrogate identifier for each location access authorization record. Primary key for the association.' ;
    rdfs:domain ind:LocationAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Approval Date' ;
    rdfs:comment 'Timestamp when this access authorization was officially approved and became enforceable. Used for audit trail and compliance reporting. Must be on or before authorization_start_date.' ;
    rdfs:domain ind:LocationAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorizationEndDate rdf:type rdf:Property ;
    rdfs:label 'Authorization End Date' ;
    rdfs:comment 'Date on which the participants authorization to access this port location expires. Null indicates indefinite authorization subject to ongoing ISPS compliance. Gate systems automatically deny access after this date. Must be on or before the participants ISPS accreditation expiry date.' ;
    rdfs:domain ind:LocationAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationStartDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Start Date' ;
    rdfs:comment 'Date from which the participant is authorized to access this port location. Used by gate control systems to validate time-bound access permissions. Must be on or after the participants ISPS accreditation date.' ;
    rdfs:domain ind:LocationAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentAccessPermitted rdf:type rdf:Property ;
    rdfs:label 'Equipment Access Permitted' ;
    rdfs:comment 'Boolean flag indicating whether the participant is authorized to operate cargo handling equipment (cranes, reach stackers, RTGs) at this port location. Requires additional operator certification validation. Used by equipment management systems to enforce operational safety and authorization.' ;
    rdfs:domain ind:LocationAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalHoursRestriction rdf:type rdf:Property ;
    rdfs:label 'Operational Hours Restriction' ;
    rdfs:comment 'Time-of-day or day-of-week restrictions on when the participant may access this location. Format: JSON string or structured text defining allowed time windows (e.g., \'MON-FRI 06:00-18:00\', \'24/7\', \'DAYLIGHT_ONLY\'). Null indicates no time restrictions. Used by gate control systems to enforce temporal access policies.' ;
    rdfs:domain ind:LocationAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleAccessPermitted rdf:type rdf:Property ;
    rdfs:label 'Vehicle Access Permitted' ;
    rdfs:comment 'Boolean flag indicating whether the participant is authorized to bring vehicles (trucks, forklifts, terminal tractors) into this port location. False indicates pedestrian-only access. Used by gate lane systems to validate vehicle entry permissions.' ;
    rdfs:domain ind:LocationAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:railIcdServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Rail Icd Service Agreement Id' ;
    rdfs:comment 'Unique identifier for the rail-ICD service agreement record. Primary key.' ;
    rdfs:domain ind:RailIcdServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumWagonCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Wagon Count' ;
    rdfs:comment 'Minimum number of wagons (rail cars) that must be provided per service under this agreement. Defines minimum train configuration commitment.' ;
    rdfs:domain ind:RailIcdServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weeklyServiceFrequency rdf:type rdf:Property ;
    rdfs:label 'Weekly Service Frequency' ;
    rdfs:comment 'Number of scheduled rail services per week between the port and the ICD facility under this agreement. Defines minimum service commitment.' ;
    rdfs:domain ind:RailIcdServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorServiceRateCardId rdf:type rdf:Property ;
    rdfs:label 'Vendor Service Rate Card Id' ;
    rdfs:comment 'Unique identifier for this vendor-service rate card record. Primary key. System-generated surrogate.' ;
    rdfs:domain ind:VendorServiceRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Rate Review Date' ;
    rdfs:comment 'Date when this vendor-service rate was last reviewed or renegotiated by procurement. Used for tracking rate review cycles and contract renewal planning.' ;
    rdfs:domain ind:VendorServiceRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Rate Review Date' ;
    rdfs:comment 'Scheduled date for next rate review or renegotiation. Triggers procurement workflow for rate benchmarking and vendor negotiation.' ;
    rdfs:domain ind:VendorServiceRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor is designated as preferred supplier for this service based on rate competitiveness, quality, or strategic relationship. Used by procurement for sourcing prioritization.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Service Level Agreement response time in hours committed by this vendor for this specific service. Used for vendor performance monitoring and contract compliance tracking.' ;
    rdfs:domain ind:VendorServiceRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeDiscountTier rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier' ;
    rdfs:comment 'Volume-based discount tier applicable to this vendor-service combination (e.g., Tier 1: 0-100 units, Tier 2: 101-500 units). References volume discount schedule in procurement contract.' ;
    rdfs:domain ind:VendorServiceRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCommodityApprovalId rdf:type rdf:Property ;
    rdfs:label 'Vendor Commodity Approval Id' ;
    rdfs:comment 'Unique identifier for the vendor-commodity approval record. Primary key. System-generated surrogate.' ;
    rdfs:domain ind:VendorCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastSupplyDate rdf:type rdf:Property ;
    rdfs:label 'Last Supply Date' ;
    rdfs:comment 'Most recent date when this vendor successfully supplied this commodity code to the port. Used to track active vs dormant vendor-commodity relationships.' ;
    rdfs:domain ind:VendorCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Vendor performance quality rating specific to this commodity code, typically on a scale of 0.00 to 5.00. Based on historical supply quality, defect rates, compliance, and delivery performance for this commodity type.' ;
    rdfs:domain ind:VendorCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taskPartConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Task Part Consumption Id' ;
    rdfs:comment 'Unique identifier for this material consumption transaction. Primary key.' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumptionReason rdf:type rdf:Property ;
    rdfs:label 'Consumption Reason' ;
    rdfs:comment 'Classification of why the spare part was consumed in this task. Supports maintenance analytics and parts usage pattern analysis.' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturing lot or batch number of the consumed spare part. Required for traceability, quality control, and warranty claims.' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Quantity Consumed' ;
    rdfs:comment 'Quantity of the spare part consumed during this maintenance task. Used for inventory deduction and cost calculation.' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Quantity of the spare part returned to inventory if not fully consumed. Supports accurate inventory reconciliation and cost adjustment.' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'Date and time when unused spare parts were returned to inventory. Used for inventory transaction completeness.' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sparePartsConsumed rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Consumed' ;
    rdfs:comment 'Comma-separated list of spare part references consumed during this task. Detailed part-level consumption is tracked in separate inventory transaction records. [Moved from work_order_task: This is a denormalized STRING field containing comma-separated part references. It should be replaced by the properly normalized task_part_consumption association table, which provides structured tracking of each part consumption with full transactional detail.]' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPartsCost rdf:type rdf:Property ;
    rdfs:label 'Total Parts Cost' ;
    rdfs:comment 'Total cost of all spare parts and materials consumed during this task. Aggregated from individual inventory transaction line items. [Moved from work_order_task: This aggregate cost should be calculated dynamically by summing (quantity_consumed * unit_cost_at_consumption) from the task_part_consumption association records, rather than stored redundantly on the work_order_task.]' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCostAtConsumption rdf:type rdf:Property ;
    rdfs:label 'Unit Cost At Consumption' ;
    rdfs:comment 'Unit cost of the spare part at the time of consumption. Captured for accurate cost accounting as part costs may fluctuate over time.' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocationAtIssue rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location At Issue' ;
    rdfs:comment 'Physical warehouse location (bin/rack/aisle) from which the part was issued. Supports inventory accuracy and picking efficiency analysis.' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimEligible rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Eligible' ;
    rdfs:comment 'Indicates whether this part consumption is eligible for warranty claim or reimbursement. Used for warranty management and cost recovery.' ;
    rdfs:domain ind:TaskPartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infrastructureAnchorageBookingId rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Anchorage Booking Id' ;
    rdfs:comment 'Primary key for infrastructure_anchorage_booking' ;
    rdfs:domain ind:InfrastructureAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anchorageBookingId rdf:type rdf:Property ;
    rdfs:label 'Anchorage Booking Id' ;
    rdfs:comment 'Unique identifier for this anchorage booking record. Primary key for the association.' ;
    rdfs:domain ind:InfrastructureAnchorageBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BookingAnchorageBooking .

ind:actualAnchorUpTime rdf:type rdf:Property ;
    rdfs:label 'Actual Anchor Up Time' ;
    rdfs:comment 'Actual timestamp when the vessel weighed anchor and departed this anchorage area as confirmed by VTS or AIS monitoring. Populated after the departure event occurs.' ;
    rdfs:domain ind:InfrastructureAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:anchorageBookingStatus rdf:type rdf:Property ;
    rdfs:label 'Anchorage Booking Status' ;
    rdfs:comment 'Current lifecycle status of this anchorage booking. Tracks progression from request through allocation, occupation, and departure.' ;
    rdfs:domain ind:InfrastructureAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anchorageDurationHours rdf:type rdf:Property ;
    rdfs:label 'Anchorage Duration Hours' ;
    rdfs:comment 'Calculated or estimated duration in hours that the vessel will occupy this anchorage area. Used for capacity planning and billing purposes.' ;
    rdfs:domain ind:InfrastructureAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedAnchorUpTime rdf:type rdf:Property ;
    rdfs:label 'Requested Anchor Up Time' ;
    rdfs:comment 'Timestamp when the vessel is expected to weigh anchor and depart this anchorage area. Used for anchorage capacity planning and berth coordination.' ;
    rdfs:domain ind:InfrastructureAnchorageBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:infrastructureBerthAllocationId rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Berth Allocation Id' ;
    rdfs:comment 'Primary key for infrastructure_berth_allocation' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InfrastructureBerthAllocation .

ind:berthAllocationId rdf:type rdf:Property ;
    rdfs:label 'Berth Allocation Id' ;
    rdfs:comment 'Unique identifier for this berth allocation record. Primary key.' ;
    rdfs:domain ind:InfrastructureBerthAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalBerthAllocation .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'The date when this berth allocation expires or terminates. For time-sliced allocations, this defines the end of the allocation window. Nullable for open-ended allocations that follow agreement expiry. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InfrastructureBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Start Date' ;
    rdfs:comment 'The date when this berth allocation becomes effective under the agreement. For time-sliced allocations, this defines the start of the allocation window. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InfrastructureBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusiveUseFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Use Flag' ;
    rdfs:comment 'Boolean flag indicating whether this allocation grants exclusive use rights to the berth during the allocation period. True means no other parties can use the berth; False means shared or time-sliced use is permitted. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InfrastructureBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licensedBerths rdf:type rdf:Property ;
    rdfs:label 'Licensed Berths' ;
    rdfs:comment 'For stevedoring-type agreements: comma-separated list of berth identifiers where the stevedoring company is authorized to perform cargo handling operations (e.g., B01, B02, B05). [Moved from agreement: The licensed_berths attribute in the agreement product is a comma-separated list of berth identifiers, which is a denormalized representation of the many-to-many relationship. This attribute should be removed from agreement and replaced by the properly normalized berth_allocation association, which allows each berth-agreement pairing to have its own allocation terms, dates, priority levels, and throughput commitments. The current string list cannot capture berth-specific allocation attributes.]' ;
    rdfs:domain ind:InfrastructureBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputCommitmentTeu rdf:type rdf:Property ;
    rdfs:label 'Throughput Commitment Teu' ;
    rdfs:comment 'The contractual minimum throughput volume (in Twenty-foot Equivalent Units) that the agreement holder commits to handle at this specific berth. Used for performance monitoring and revenue guarantee calculations. Berth-specific commitment that may differ from overall agreement throughput targets. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InfrastructureBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeWindowSpecification rdf:type rdf:Property ;
    rdfs:label 'Time Window Specification' ;
    rdfs:comment 'For time-sliced allocations, specifies the recurring time windows when this berth is allocated to the agreement holder. Format examples: \'Mon-Fri 08:00-18:00\', \'Weekends only\', \'First week of each month\'. Nullable for non-time-sliced allocations.' ;
    rdfs:domain ind:InfrastructureBerthAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoRailWagonLoadId rdf:type rdf:Property ;
    rdfs:label 'Cargo Rail Wagon Load Id' ;
    rdfs:comment 'Primary key for cargo_rail_wagon_load' ;
    rdfs:domain ind:CargoRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dischargeOperatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Discharge Operator Employee Id' ;
    rdfs:comment 'Reference to the equipment operator or crew member who performed the physical discharge operation for this container. Used for productivity tracking and quality accountability.' ;
    rdfs:domain ind:CargoRailWagonLoad ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:railWagonLoadId rdf:type rdf:Property ;
    rdfs:label 'Rail Wagon Load Id' ;
    rdfs:comment 'Unique system identifier for this rail wagon load record. Primary key for the association.' ;
    rdfs:domain ind:CargoRailWagonLoad ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntermodalRailWagonLoad .

ind:actualDischargeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Discharge Timestamp' ;
    rdfs:comment 'Actual date and time when this container was physically removed from the rail wagon at destination or intermediate stop. Used for turnaround time tracking.' ;
    rdfs:domain ind:CargoRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isHazmatLoad rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Load' ;
    rdfs:comment 'Flag indicating whether this container carries dangerous goods requiring special positioning, separation, and handling during this rail movement. Derived from container hazmat status but tracked at load level for operational safety.' ;
    rdfs:domain ind:CargoRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverweightLoad rdf:type rdf:Property ;
    rdfs:label 'Is Overweight Load' ;
    rdfs:comment 'Flag indicating whether this container load exceeds standard rail weight limits and requires special handling, positioning, or permits for this rail movement.' ;
    rdfs:domain ind:CargoRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lashingEquipmentUsed rdf:type rdf:Property ;
    rdfs:label 'Lashing Equipment Used' ;
    rdfs:comment 'Actual securing equipment applied to this container load (twist locks, chains, straps, corner castings). Used for equipment tracking and safety compliance verification.' ;
    rdfs:domain ind:CargoRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadRemarks rdf:type rdf:Property ;
    rdfs:label 'Load Remarks' ;
    rdfs:comment 'Free-text operational notes about this specific container load, including special handling performed, issues encountered, damage observations, or deviations from standard procedures.' ;
    rdfs:domain ind:CargoRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadWeightKg rdf:type rdf:Property ;
    rdfs:label 'Load Weight Kg' ;
    rdfs:comment 'Verified gross weight of this container at time of loading onto the rail wagon in kilograms. Used for train weight distribution, axle load compliance, and safety verification.' ;
    rdfs:domain ind:CargoRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresReeferPower rdf:type rdf:Property ;
    rdfs:label 'Requires Reefer Power' ;
    rdfs:comment 'Flag indicating whether this reefer container requires electrical power connection during this rail journey. Used for genset wagon assignment and power capacity planning.' ;
    rdfs:domain ind:CargoRailWagonLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerGateTransactionId rdf:type rdf:Property ;
    rdfs:label 'Container Gate Transaction Id' ;
    rdfs:comment 'Unique identifier for this container gate transaction record. Primary key.' ;
    rdfs:domain ind:ContainerGateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionSequence rdf:type rdf:Property ;
    rdfs:label 'Transaction Sequence' ;
    rdfs:comment 'Sequence number indicating the order in which this container was processed during a multi-container truck visit (1 for first container, 2 for second, etc.). Null for single-container visits.' ;
    rdfs:domain ind:ContainerGateTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerTariffExceptionApplicationId rdf:type rdf:Property ;
    rdfs:label 'Container Tariff Exception Application Id' ;
    rdfs:comment 'Unique identifier for this specific application of a tariff exception to a container visit. Primary key.' ;
    rdfs:domain ind:ContainerTariffExceptionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationNotes rdf:type rdf:Property ;
    rdfs:label 'Application Notes' ;
    rdfs:comment 'Free-text notes documenting any special circumstances, manual adjustments, or business context relevant to this specific application of the exception to this container visit.' ;
    rdfs:domain ind:ContainerTariffExceptionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'System timestamp when this tariff exception was applied to this container visit in the billing system. Provides audit trail for when the exception was operationally activated.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionRateAmount rdf:type rdf:Property ;
    rdfs:label 'Exception Rate Amount' ;
    rdfs:comment 'The actual exceptional rate amount applied to this specific container visit under this exception, in the specified currency. May differ from the exception\'s standard rate if further adjustments were made.' ;
    rdfs:domain ind:ContainerTariffExceptionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Driver Authorization Id' ;
    rdfs:comment 'Unique identifier for the driver authorization record. Primary key for the association.' ;
    rdfs:domain ind:DriverAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Expiration date of the driver\'s authorization to operate for this haulier. Used for access control enforcement and compliance auditing. Must be renewed before expiry to maintain terminal access.' ;
    rdfs:domain ind:DriverAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:driverAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Driver Authorization Status' ;
    rdfs:comment 'Current status of the driver authorization. Active indicates valid authorization; suspended indicates temporary hold pending investigation or document renewal; expired indicates authorization_expiry_date has passed; revoked indicates permanent termination of authorization due to compliance breach or contract termination.' ;
    rdfs:domain ind:DriverAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessDate rdf:type rdf:Property ;
    rdfs:label 'Last Access Date' ;
    rdfs:comment 'Date of the most recent terminal access by this driver operating under this haulier\'s authority. Used for activity monitoring and dormant authorization cleanup.' ;
    rdfs:domain ind:DriverAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminalAccessZones rdf:type rdf:Property ;
    rdfs:label 'Terminal Access Zones' ;
    rdfs:comment 'Comma-separated list of terminal zones or restricted areas the driver is authorized to access when operating for this haulier (e.g., \'container yard\', \'hazmat zone\', \'rail interchange\'). Critical for ISPS Code compliance and security perimeter control.' ;
    rdfs:domain ind:DriverAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleTypesAuthorized rdf:type rdf:Property ;
    rdfs:label 'Vehicle Types Authorized' ;
    rdfs:comment 'Comma-separated list of vehicle types the driver is authorized to operate for this haulier (e.g., \'rigid truck\', \'articulated lorry\', \'container chassis\'). Restricts which equipment the driver can use under this haulier relationship.' ;
    rdfs:domain ind:DriverAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityAccessAgreementId rdf:type rdf:Property ;
    rdfs:label 'Facility Access Agreement Id' ;
    rdfs:comment 'Unique system identifier for this facility access agreement record. Primary key.' ;
    rdfs:domain ind:FacilityAccessAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlingRatePerMove rdf:type rdf:Property ;
    rdfs:label 'Handling Rate Per Move' ;
    rdfs:comment 'Negotiated handling charge per container move (lift-on/lift-off) for this participant at this facility. Rate is participant-specific and may differ from standard facility rates based on volume commitments.' ;
    rdfs:domain ind:FacilityAccessAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Handling Flag' ;
    rdfs:comment 'Indicates whether this participant has contracted for priority handling services at this facility, affecting queue position and turnaround time.' ;
    rdfs:domain ind:FacilityAccessAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Sla Turnaround Hours' ;
    rdfs:comment 'Service Level Agreement commitment for container turnaround time at this facility for this participant, measured in hours from gate-in to gate-out availability.' ;
    rdfs:domain ind:FacilityAccessAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageAllocationTeu rdf:type rdf:Property ;
    rdfs:label 'Storage Allocation Teu' ;
    rdfs:comment 'Contracted storage capacity allocated to this participant at this facility, measured in TEU (Twenty-foot Equivalent Units). Used for capacity planning and enforcement of allocation limits.' ;
    rdfs:domain ind:FacilityAccessAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectPermitId rdf:type rdf:Property ;
    rdfs:label 'Project Permit Id' ;
    rdfs:comment 'Unique identifier for this project-permit relationship record. Primary key for the association.' ;
    rdfs:domain ind:ProjectPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceTrackingStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Tracking Status' ;
    rdfs:comment 'Current compliance status of the project against the conditions and requirements of this specific permit. Values: compliant (all conditions met), non_compliant (violations identified), under_review (compliance audit in progress), remediation_in_progress (corrective actions underway), not_applicable (permit not yet active or project phase not covered).' ;
    rdfs:domain ind:ProjectPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date of the most recent compliance review or audit conducted for this project against this permit\'s requirements. Used for tracking compliance monitoring schedules.' ;
    rdfs:domain ind:ProjectPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Timestamp when this project-permit relationship record was last modified.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'Scheduled date for the next compliance review or regulatory inspection for this project under this permit. Used for proactive compliance management.' ;
    rdfs:domain ind:ProjectPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitCostAllocation rdf:type rdf:Property ;
    rdfs:label 'Permit Cost Allocation' ;
    rdfs:comment 'Portion of permit acquisition, application, and compliance costs allocated to this infrastructure project. For permits covering multiple projects, this represents this project\'s share of the total permit cost. Expressed in the project\'s budget currency.' ;
    rdfs:domain ind:ProjectPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitCriticalityToProject rdf:type rdf:Property ;
    rdfs:label 'Permit Criticality To Project' ;
    rdfs:comment 'Assessment of how critical this permit is to the project\'s ability to proceed. Values: critical (project cannot start without this permit), high (major delays if not obtained), medium (impacts specific work packages), low (administrative or post-completion permit).' ;
    rdfs:domain ind:ProjectPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPermitStatus rdf:type rdf:Property ;
    rdfs:label 'Project Permit Status' ;
    rdfs:comment 'Current status of this permit in the context of this specific project. Values: applied (application submitted), under_review (regulatory review in progress), approved (permit granted), active (permit in force for project activities), suspended (temporarily halted), withdrawn (application withdrawn), expired (permit validity ended for this project).' ;
    rdfs:domain ind:ProjectPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectSpecificConditions rdf:type rdf:Property ;
    rdfs:label 'Project Specific Conditions' ;
    rdfs:comment 'Additional conditions, restrictions, or requirements imposed by the regulatory authority specifically for this project under this permit. Supplements the general permit conditions with project-specific obligations.' ;
    rdfs:domain ind:ProjectPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleProjectOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Project Officer' ;
    rdfs:comment 'Name or employee identifier of the project team member responsible for managing compliance with this permit for this specific project. This is the primary point of contact for regulatory inspections and compliance reporting related to this permit-project relationship.' ;
    rdfs:domain ind:ProjectPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectServiceCostId rdf:type rdf:Property ;
    rdfs:label 'Project Service Cost Id' ;
    rdfs:comment 'Unique identifier for this project-service cost record. Primary key.' ;
    rdfs:domain ind:ProjectServiceCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedAmount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Amount' ;
    rdfs:comment 'Planned or budgeted cost for this service within this project, established during project planning phase. Used for variance analysis against actual costs.' ;
    rdfs:domain ind:ProjectServiceCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorReference rdf:type rdf:Property ;
    rdfs:label 'Contractor Reference' ;
    rdfs:comment 'Reference to the contractor, vendor, or internal department that provided this service to the project. Links to vendor master or organizational unit for procurement and performance tracking.' ;
    rdfs:domain ind:ProjectServiceCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Status' ;
    rdfs:comment 'Lifecycle status of this project-service cost: PLANNED (budgeted but not committed), COMMITTED (purchase order issued), ACCRUED (service delivered, invoice pending), INVOICED (invoice received), PAID (payment processed), DISPUTED (under review), CANCELLED (no longer applicable).' ;
    rdfs:domain ind:ProjectServiceCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'Date when this service was completed or ceased for this project. Null if service is ongoing. Used for duration-based billing and project phase tracking.' ;
    rdfs:domain ind:ProjectServiceCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Date when this service began being delivered or consumed for this project. Relevant for time-based services (consulting, equipment rental) and project timeline tracking.' ;
    rdfs:domain ind:ProjectServiceCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Service Subscription Id' ;
    rdfs:comment 'Unique identifier for this service subscription record. Primary key.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTeuUtilized rdf:type rdf:Property ;
    rdfs:label 'Actual Teu Utilized' ;
    rdfs:comment 'Cumulative TEU volume actually utilized by this account on this service during the current contract period. Used for volume commitment tracking and reconciliation.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether this subscription automatically renews at the end of the contract period under the same or updated terms.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookingQuotaPerWeek rdf:type rdf:Property ;
    rdfs:label 'Booking Quota Per Week' ;
    rdfs:comment 'Maximum number of booking slots per week allocated to this account for this service under the subscription terms. Null if unlimited.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedTeuVolume rdf:type rdf:Property ;
    rdfs:label 'Contracted Teu Volume' ;
    rdfs:comment 'Committed annual or contract-period TEU volume that the participant account has contracted for this specific intermodal service. Used for capacity planning and volume discount eligibility. Explicitly identified in detection phase.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatedRatePerTeu rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate Per Teu' ;
    rdfs:comment 'Account-specific negotiated rate per TEU for this intermodal service, potentially different from standard tariff rates. Denominated in the participant account\'s currency. Explicitly identified in detection phase.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Contracted service tier level for this subscription, determining priority access, booking flexibility, and SLA commitments. Values: Standard, Premium, Enterprise, Custom. Explicitly identified in detection phase.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription End Date' ;
    rdfs:comment 'Calendar date when this service subscription expires or is terminated. Nullable for open-ended subscriptions. Explicitly identified in detection phase.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Start Date' ;
    rdfs:comment 'Calendar date when this service subscription becomes active and the participant account gains access to the intermodal service under the contracted terms. Explicitly identified in detection phase.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:volumeCommitmentPct rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Pct' ;
    rdfs:comment 'Percentage of contracted TEU volume that has been utilized to date (actual_teu_utilized / contracted_teu_volume * 100). Used for performance monitoring.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalOrderGangAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Internal Order Gang Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for this internal order gang assignment record. Primary key for the association.' ;
    rdfs:domain ind:InternalOrderGangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'The actual number of labour hours worked by this gang on this internal order. Posted from time sheets or gang deployment records. Used for cost actuals and variance analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costRate rdf:type rdf:Property ;
    rdfs:label 'Cost Rate' ;
    rdfs:comment 'The labour cost rate per hour applicable to this specific gang assignment. May vary by internal order type, work type, shift pattern, or labour agreement. Used for calculating actual costs posted to the internal order.' ;
    rdfs:domain ind:InternalOrderGangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'The planned or budgeted number of labour hours for this gang assignment to this internal order. Used for resource planning and budget forecasting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workType rdf:type rdf:Property ;
    rdfs:label 'Work Type' ;
    rdfs:comment 'Classification of the type of work performed by this gang under this internal order assignment. Examples: crane maintenance, berth repair, dredging support, equipment installation, lashing operations. Used for cost classification and activity-based costing.' ;
    rdfs:domain ind:InternalOrderGangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planPartRequirementId rdf:type rdf:Property ;
    rdfs:label 'Plan Part Requirement Id' ;
    rdfs:comment 'Unique identifier for this maintenance plan part requirement record. Primary key.' ;
    rdfs:domain ind:PlanPartRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutablePartId rdf:type rdf:Property ;
    rdfs:label 'Substitutable Part Id' ;
    rdfs:comment 'Reference to an alternative spare_part that can be used as a substitute if the primary part is unavailable. Supports flexible parts reservation. Identified in detection phase.' ;
    rdfs:domain ind:PlanPartRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePart .

ind:criticalityFlag rdf:type rdf:Property ;
    rdfs:label 'Criticality Flag' ;
    rdfs:comment 'Indicates whether this part is critical for the maintenance plan execution. Critical parts must be available before work order generation. Identified in detection phase.' ;
    rdfs:domain ind:PlanPartRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedUnitCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Cost' ;
    rdfs:comment 'Estimated unit cost of this spare part at the time of maintenance plan creation. Used to calculate maintenance_plan.estimated_cost. May differ from current spare_part.unit_cost due to price changes. Identified in detection phase.' ;
    rdfs:domain ind:PlanPartRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredQuantity rdf:type rdf:Property ;
    rdfs:label 'Required Quantity' ;
    rdfs:comment 'Quantity of this spare part required to complete the maintenance plan. Used for parts reservation and inventory availability checking. Identified in detection phase.' ;
    rdfs:domain ind:PlanPartRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredSpareParts rdf:type rdf:Property ;
    rdfs:label 'Required Spare Parts' ;
    rdfs:comment 'List of spare parts, consumables, and materials required for the maintenance tasks. May include part numbers, quantities, and specifications. Used for inventory planning and procurement. [Moved from maintenance_plan: This STRING field in maintenance_plan is a denormalized placeholder that lists spare parts in a comma-separated or text format. It should be replaced by the properly normalized plan_part_requirement association table, which provides structured, queryable, and relationship-specific data (quantities, criticality, costs) for each part requirement.]' ;
    rdfs:domain ind:PlanPartRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotVesselTypeEndorsementId rdf:type rdf:Property ;
    rdfs:label 'Pilot Vessel Type Endorsement Id' ;
    rdfs:comment 'Primary key for the pilot_vessel_type_endorsement association' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endorsementCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Endorsement Certificate Number' ;
    rdfs:comment 'Unique certificate or reference number assigned to this vessel type endorsement by the issuing authority. Used for regulatory audit and verification.' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementDate rdf:type rdf:Property ;
    rdfs:label 'Endorsement Date' ;
    rdfs:comment 'Date on which this specific vessel type endorsement was granted to the pilot by the licensing authority. Used for tracking endorsement history and calculating experience duration.' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endorsementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Endorsement Expiry Date' ;
    rdfs:comment 'Date on which this vessel type endorsement expires and must be renewed. Drives compliance monitoring and pilot assignment eligibility for this vessel type.' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endorsementRestrictions rdf:type rdf:Property ;
    rdfs:label 'Endorsement Restrictions' ;
    rdfs:comment 'Free-text description of any specific restrictions or conditions applied to this vessel type endorsement (e.g., daylight only, specific berths only, tug assistance required, supervision required).' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementStatus rdf:type rdf:Property ;
    rdfs:label 'Endorsement Status' ;
    rdfs:comment 'Current regulatory status of this specific vessel type endorsement. Determines whether the pilot is currently authorized to pilot vessels of this type.' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPilotageDateForType rdf:type rdf:Property ;
    rdfs:label 'Last Pilotage Date For Type' ;
    rdfs:comment 'Date on which the pilot last conducted pilotage operations on a vessel of this type. Used for recency requirements and endorsement renewal eligibility.' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxDwtForTypeMt rdf:type rdf:Property ;
    rdfs:label 'Max Dwt For Type Mt' ;
    rdfs:comment 'Maximum vessel Deadweight Tonnage (DWT) in metric tonnes that this pilot is authorized to handle specifically for this vessel type under this endorsement. May differ from the pilot\'s general max_dwt_mt based on type-specific qualifications.' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLoaForTypeM rdf:type rdf:Property ;
    rdfs:label 'Max Loa For Type M' ;
    rdfs:comment 'Maximum vessel Length Overall (LOA) in metres that this pilot is authorized to handle specifically for this vessel type under this endorsement. May differ from the pilot\'s general max_loa_m based on type-specific training and experience.' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:practicalAssessmentsCompleted rdf:type rdf:Property ;
    rdfs:label 'Practical Assessments Completed' ;
    rdfs:comment 'Number of supervised practical pilotage assessments completed by the pilot for this specific vessel type. Used to track progression toward full endorsement and recurrent competency validation.' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:simulatorTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Simulator Training Completed' ;
    rdfs:comment 'Indicates whether the pilot has completed mandatory bridge simulator training specific to this vessel type. Required for certain high-risk vessel types (LNG, tanker, large container ships).' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vesselTypeEndorsements rdf:type rdf:Property ;
    rdfs:label 'Vessel Type Endorsements' ;
    rdfs:comment 'Comma-separated list of vessel type endorsements held by the pilot, indicating specialised authorisation for specific vessel categories (e.g., LNG_TANKER, VLCC, RORO, CRUISE, CONTAINER). Drives assignment eligibility for specialist vessel calls. [Moved from pilot: This comma-separated list attribute in the pilot product is a denormalized representation of the many-to-many relationship. The proper model is to capture each endorsement as a separate record in the pilot_vessel_type_endorsement association with full endorsement-specific attributes (dates, limits, status, training). The vessel_type_endorsements attribute should be removed from pilot and replaced by queries against the association product.]' ;
    rdfs:domain ind:PilotVesselTypeEndorsement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantTradeExemptionId rdf:type rdf:Property ;
    rdfs:label 'Participant Trade Exemption Id' ;
    rdfs:comment 'Unique surrogate identifier for each participant trade exemption record. Primary key.' ;
    rdfs:domain ind:ParticipantTradeExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedVolume rdf:type rdf:Property ;
    rdfs:label 'Authorized Volume' ;
    rdfs:comment 'Maximum volume, quantity, or value of goods that the participant is authorized to trade under this exemption. Unit depends on the restriction type (e.g., metric tons, TEUs, USD value).' ;
    rdfs:domain ind:ParticipantTradeExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Authorized Volume Unit' ;
    rdfs:comment 'Unit of measurement for the authorized volume (e.g., metric tons, TEUs, currency for value-based limits).' ;
    rdfs:domain ind:ParticipantTradeExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditions rdf:type rdf:Property ;
    rdfs:label 'Conditions' ;
    rdfs:comment 'Detailed conditions, restrictions, and compliance requirements that the participant must meet to maintain the validity of the exemption.' ;
    rdfs:domain ind:ParticipantTradeExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionReference rdf:type rdf:Property ;
    rdfs:label 'Exemption Reference' ;
    rdfs:comment 'Official reference number or identifier assigned to the exemption or license by the issuing authority. Used for verification during customs clearance and cargo release processes.' ;
    rdfs:domain ind:ParticipantTradeExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exemption Status' ;
    rdfs:comment 'Current lifecycle status of the exemption. Determines whether the exemption can be used for customs clearance and cargo release decisions.' ;
    rdfs:domain ind:ParticipantTradeExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'Date when the exemption was last verified or validated by port compliance officers during a cargo clearance process.' ;
    rdfs:domain ind:ParticipantTradeExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validUntil rdf:type rdf:Property ;
    rdfs:label 'Valid Until' ;
    rdfs:comment 'Date on which the exemption or license expires. After this date, the participant is no longer authorized to conduct the specified trade activities without renewal.' ;
    rdfs:domain ind:ParticipantTradeExemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commodityHandlingAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Commodity Handling Authorization Id' ;
    rdfs:comment 'Unique surrogate identifier for each commodity handling authorization record. Primary key.' ;
    rdfs:domain ind:CommodityHandlingAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dangerousGoodsAuthorized rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Authorized' ;
    rdfs:comment 'Indicates whether this authorization includes permission to handle dangerous goods (IMDG class commodities). Requires additional ISPS and IMDG Code compliance certifications.' ;
    rdfs:domain ind:CommodityHandlingAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handlingAuthorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Handling Authorization Level' ;
    rdfs:comment 'Classification of the authorization scope. FULL = unrestricted handling, RESTRICTED = specific conditions apply, CONDITIONAL = requires additional approvals per shipment, TEMPORARY = time-limited trial authorization.' ;
    rdfs:domain ind:CommodityHandlingAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeLimitTonnes rdf:type rdf:Property ;
    rdfs:label 'Volume Limit Tonnes' ;
    rdfs:comment 'Maximum cargo volume in metric tonnes that the participant is authorized to handle for this commodity type per calendar month. Null indicates no volume restriction. Enforced by Port Community System for capacity planning and risk management.' ;
    rdfs:domain ind:CommodityHandlingAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionCompetencyRequirementId rdf:type rdf:Property ;
    rdfs:label 'Position Competency Requirement Id' ;
    rdfs:comment 'Unique surrogate identifier for each position-competency requirement record' ;
    rdfs:domain ind:PositionCompetencyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of mandatory certifications, licences, or competency credentials required to hold this position (e.g., Marine Pilot Licence, Quay Crane Operator Certificate, ISPS Security Training, Dangerous Goods Handling Certificate). [Moved from position: This comma-separated string in position is a denormalized representation of the M:N relationship. Moving to the association table enables structured queries, individual requirement tracking, and proper relationship data (mandatory_flag, proficiency_level, effective_date) for each position-competency pair.]' ;
    rdfs:domain ind:PositionCompetencyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCompetencies rdf:type rdf:Property ;
    rdfs:label 'Required Competencies' ;
    rdfs:comment 'Comma-separated list of skills, knowledge areas, and behavioural competencies required for successful performance in the position (e.g., Vessel Traffic Management, Container Stacking Algorithms, Crisis Management, NAVIS N4 System Proficiency). [Moved from position: This comma-separated string in position is a denormalized representation of the M:N relationship. Moving to the association table enables structured queries, gap analysis, and proper relationship data management for each position-competency requirement.]' ;
    rdfs:domain ind:PositionCompetencyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementSource rdf:type rdf:Property ;
    rdfs:label 'Requirement Source' ;
    rdfs:comment 'The source or driver for this competency requirement (e.g., regulatory mandate, operational necessity, safety policy). Supports compliance reporting and requirement justification.' ;
    rdfs:domain ind:PositionCompetencyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revalidationRequired rdf:type rdf:Property ;
    rdfs:label 'Revalidation Required' ;
    rdfs:comment 'Indicates whether position holders must undergo periodic revalidation or refresher training for this competency, beyond the competency\'s own renewal requirements.' ;
    rdfs:domain ind:PositionCompetencyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentParticipantId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Participant Id' ;
    rdfs:comment 'Unique identifier for this risk assessment participant involvement record. Primary key for the association.' ;
    rdfs:domain ind:RiskAssessmentParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'The participants formal acceptance status of the residual risk level and proposed controls. For shared operations, each participant must formally accept their portion of the residual risk. Rejected status triggers escalation to port operations management and may result in operational restrictions or permit denial.' ;
    rdfs:domain ind:RiskAssessmentParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Due Date' ;
    rdfs:comment 'Target date by which the participant must implement their committed mitigation actions. Used by port safety officers to track compliance with risk mitigation commitments and trigger follow-up audits.' ;
    rdfs:domain ind:RiskAssessmentParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consultationDate rdf:type rdf:Property ;
    rdfs:label 'Consultation Date' ;
    rdfs:comment 'Date when this participant was formally consulted during the risk assessment process. ISO 45001 requires documented evidence of stakeholder consultation for shared operational risks. This date represents when the participant reviewed the risk assessment and provided input.' ;
    rdfs:domain ind:RiskAssessmentParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationCommitment rdf:type rdf:Property ;
    rdfs:label 'Mitigation Commitment' ;
    rdfs:comment 'Specific mitigation actions, additional controls, or procedural changes that this participant has committed to implement as a condition of risk acceptance. For example, a shipping line may commit to providing certified hot work operators, or a freight forwarder may commit to enhanced IMDG pre-notification. These commitments are tracked and audited by port safety management.' ;
    rdfs:domain ind:RiskAssessmentParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantControlResponsibility rdf:type rdf:Property ;
    rdfs:label 'Participant Control Responsibility' ;
    rdfs:comment 'Description of the specific risk control measures and safeguards that this participant is responsible for implementing and maintaining. For shared operations like vessel bunkering or multi-party cargo handling, different participants have distinct control responsibilities (e.g., shipping line responsible for vessel hot work permits, port operator responsible for shore-side fire watch, freight forwarder responsible for IMDG documentation).' ;
    rdfs:domain ind:RiskAssessmentParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantExposureLevel rdf:type rdf:Property ;
    rdfs:label 'Participant Exposure Level' ;
    rdfs:comment 'Classification of the participants exposure level to the identified hazard. Direct exposure indicates the participant\'s personnel or assets are directly involved in the hazardous activity. Indirect exposure indicates proximity or downstream impact. Required for multi-party risk assessments under ISO 45001 consultation requirements.' ;
    rdfs:domain ind:RiskAssessmentParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantFeedback rdf:type rdf:Property ;
    rdfs:label 'Participant Feedback' ;
    rdfs:comment 'Free-text record of feedback, concerns, or additional hazard identification provided by the participant during consultation. Captures participant-specific operational knowledge and risk perspectives that may not be visible to port safety officers.' ;
    rdfs:domain ind:RiskAssessmentParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantRoleInOperation rdf:type rdf:Property ;
    rdfs:label 'Participant Role In Operation' ;
    rdfs:comment 'The specific operational role this participant plays in the assessed activity (e.g., Vessel Operator, Shore-side Service Provider, Cargo Owner, Stevedore, Customs Inspector). Clarifies why this participant is involved in this specific risk assessment.' ;
    rdfs:domain ind:RiskAssessmentParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Surveyor Authorization Id' ;
    rdfs:comment 'Unique system-generated identifier for each surveyor authorization record. Primary key.' ;
    rdfs:domain ind:SurveyorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorisedSurveyTypes rdf:type rdf:Property ;
    rdfs:label 'Authorised Survey Types' ;
    rdfs:comment 'Comma-separated list of survey types the surveyor is authorized to perform under this specific agreement. May be a subset of the surveyor\'s full scope of authorization, restricted by the agreement terms or client requirements.' ;
    rdfs:domain ind:SurveyorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this surveyor has exclusive rights to perform certain survey types under this agreement, preventing other authorized surveyors from performing those specific surveys. Used in premium service agreements.' ;
    rdfs:domain ind:SurveyorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateOverride rdf:type rdf:Property ;
    rdfs:label 'Rate Override' ;
    rdfs:comment 'Negotiated hourly or daily rate for this surveyor under this specific agreement, overriding standard surveyor rates. Null if standard rates apply. Enables agreement-specific pricing arrangements.' ;
    rdfs:domain ind:SurveyorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:charterId rdf:type rdf:Property ;
    rdfs:label 'Charter Id' ;
    rdfs:comment 'Unique system identifier for this vessel charter agreement record. Primary key.' ;
    rdfs:domain ind:Charter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bareboatCharterFlag rdf:type rdf:Property ;
    rdfs:label 'Bareboat Charter Flag' ;
    rdfs:comment 'Indicates whether this is a bareboat (demise) charter where the charterer takes full possession and operational control of the vessel, effectively operating it as if they were the owner.' ;
    rdfs:domain ind:Charter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:charterType rdf:type rdf:Property ;
    rdfs:label 'Charter Type' ;
    rdfs:comment 'Type of charter arrangement governing this vessel-carrier relationship. TIME_CHARTER: carrier hires vessel for specified period; VOYAGE_CHARTER: carrier hires vessel for specific voyage; BAREBOAT_CHARTER: carrier takes full operational control; SLOT_CHARTER: carrier leases container slots; DEMISE_CHARTER: full transfer of possession and control.' ;
    rdfs:domain ind:Charter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialOperatorFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Operator Flag' ;
    rdfs:comment 'Indicates whether this shipping line is the commercial operator (disponent owner) of the vessel under this charter, responsible for commercial decisions, cargo booking, and freight revenue.' ;
    rdfs:domain ind:Charter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialOperatorImoCompanyNumber rdf:type rdf:Property ;
    rdfs:label 'Commercial Operator Imo Company Number' ;
    rdfs:comment 'Unique IMO company identification number assigned to the commercial operator organization. [Moved from vessel: This is relationship-specific data that varies by charter arrangement. The commercial operator IMO number should be derived from the shipping_line master record linked through this association, not stored redundantly in the vessel record.]' ;
    rdfs:domain ind:Charter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialOperatorName rdf:type rdf:Property ;
    rdfs:label 'Commercial Operator Name' ;
    rdfs:comment 'Name of the entity commercially operating the vessel under charter or management agreement. The disponent owner controls cargo bookings and voyage planning. [Moved from vessel: This attribute currently exists in the vessel product but represents relationship-specific data. A vessel can have different commercial operators through different charter arrangements simultaneously or over time. This belongs in the vessel_charter association with the commercial_operator_flag to properly model the many-to-many reality of vessel charter relationships.]' ;
    rdfs:domain ind:Charter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyReference rdf:type rdf:Property ;
    rdfs:label 'Party Reference' ;
    rdfs:comment 'External reference number or identifier for the charter party agreement document governing this vessel-carrier relationship. Used for contract management and legal reference.' ;
    rdfs:domain ind:Charter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalManagerFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Manager Flag' ;
    rdfs:comment 'Indicates whether this shipping line is responsible for technical management of the vessel under this charter, including maintenance, crew management, and technical operations.' ;
    rdfs:domain ind:Charter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Flag' ;
    rdfs:comment 'Indicates whether this vessel has access restrictions or blacklist status for this specific port location.' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Arrival Datetime' ;
    rdfs:comment 'Timestamp when the vessel arrived at the port location (pilot boarding or berth arrival depending on location type).' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Call Performance Rating' ;
    rdfs:comment 'Overall performance rating for this port call based on operational efficiency, safety compliance, and commercial metrics.' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callPurpose rdf:type rdf:Property ;
    rdfs:label 'Call Purpose' ;
    rdfs:comment 'Primary business purpose of the port call. Determines operational workflows and billing categories.' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Call Sequence Number' ;
    rdfs:comment 'Sequential number of this call for the vessel at this specific port location. Enables tracking of repeat visits (1st call, 2nd call, etc.).' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoVolumeTonnes rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Tonnes' ;
    rdfs:comment 'Total cargo volume handled during this port call in metric tonnes. Aggregated from cargo operations.' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerMovesCount rdf:type rdf:Property ;
    rdfs:label 'Container Moves Count' ;
    rdfs:comment 'Total number of container moves (load + discharge) performed during this port call. Key performance metric for container terminals.' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureDatetime rdf:type rdf:Property ;
    rdfs:label 'Departure Datetime' ;
    rdfs:comment 'Timestamp when the vessel departed from the port location.' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUpdatedDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Updated Datetime' ;
    rdfs:comment 'Timestamp when this port call record was last modified.' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portStayHours rdf:type rdf:Property ;
    rdfs:label 'Port Stay Hours' ;
    rdfs:comment 'Total duration of the port call in hours, calculated from arrival to departure. Used for performance analytics and berth utilization metrics.' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredLocationFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Location Flag' ;
    rdfs:comment 'Indicates whether this port location is a preferred calling point for this vessel based on operational history and performance.' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPortChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Port Charges Amount' ;
    rdfs:comment 'Total port charges billed for this call including berth dues, pilotage, towage, and other marine services.' ;
    rdfs:domain ind:PortCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCommodityApprovalId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Commodity Approval Id' ;
    rdfs:comment 'Unique identifier for the warehouse commodity approval record. Primary key.' ;
    rdfs:domain ind:WarehouseCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'Date when the approval expires and requires renewal. Null for approvals with no expiration.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designatedStorageZone rdf:type rdf:Property ;
    rdfs:label 'Designated Storage Zone' ;
    rdfs:comment 'Specific zone, bay, or area within the warehouse designated for this commodity type (e.g., \'Bay A1-A3\', \'Reefer zone\', \'Bonded section\')' ;
    rdfs:domain ind:WarehouseCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Quantity Tonnes' ;
    rdfs:comment 'Maximum quantity in tonnes of this commodity that can be stored in this warehouse simultaneously, as specified by the approval authority or operational safety limits' ;
    rdfs:domain ind:WarehouseCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segregationRequirements rdf:type rdf:Property ;
    rdfs:label 'Segregation Requirements' ;
    rdfs:comment 'IMDG segregation requirements for this commodity in this warehouse (e.g., \'Segregate from Class 1, 4, 5\', \'Minimum 3m separation from oxidizers\', \'Separate bay required\')' ;
    rdfs:domain ind:WarehouseCommodityApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseImdgApprovalId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Imdg Approval Id' ;
    rdfs:comment 'Unique identifier for this warehouse-IMDG class approval record. Primary key.' ;
    rdfs:domain ind:WarehouseImdgApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Certification Document Reference' ;
    rdfs:comment 'Reference number or document management system identifier for the official approval certificate or compliance documentation. Used for audit trail and regulatory inspections.' ;
    rdfs:domain ind:WarehouseImdgApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContact rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact' ;
    rdfs:comment 'Name and contact information for the designated emergency response coordinator or safety officer responsible for incidents involving this IMDG class in this warehouse. Used for emergency response activation.' ;
    rdfs:domain ind:WarehouseImdgApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionRequirements rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Requirements' ;
    rdfs:comment 'Specific fire suppression system requirements or configurations mandated for storing this IMDG class in this warehouse (e.g., foam system for Class 3 flammable liquids, CO2 for Class 4.2 spontaneously combustible, water spray for Class 8 corrosives). Must align with warehouse.fire_suppression_system_type capability.' ;
    rdfs:domain ind:WarehouseImdgApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgClassApprovals rdf:type rdf:Property ;
    rdfs:label 'Imdg Class Approvals' ;
    rdfs:comment 'Comma-separated list of IMDG hazard classes that the warehouse is certified to store (e.g., \'3,4.1,6.1,8,9\'). Empty if not approved for dangerous goods. Classes: 1-Explosives, 2-Gases, 3-Flammable Liquids, 4-Flammable Solids, 5-Oxidizers, 6-Toxic, 7-Radioactive, 8-Corrosives, 9-Miscellaneous. [Moved from warehouse: This comma-separated list attribute in warehouse represents a denormalized many-to-many relationship. The proper normalized model requires moving this to the association table where each approval is a separate record with its own approval_date, approval_authority, quantity limits, and compliance attributes. The warehouse table should not contain a list of IMDG classes; instead, the relationship should be queried through the warehouse_imdg_approval association.]' ;
    rdfs:domain ind:WarehouseImdgApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumNetExplosiveMass rdf:type rdf:Property ;
    rdfs:label 'Maximum Net Explosive Mass' ;
    rdfs:comment 'Maximum net explosive mass (NEQ) in kilograms permitted for this IMDG class in this warehouse. Applies primarily to Class 1 (Explosives) and defines the upper limit for storage quantity based on warehouse construction, separation distances, and blast protection. Null for non-explosive classes.' ;
    rdfs:domain ind:WarehouseImdgApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStorageQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Storage Quantity Tonnes' ;
    rdfs:comment 'Maximum total quantity in tonnes of this IMDG class that may be stored in this warehouse at any time. Based on warehouse capacity, ventilation, fire suppression capability, and segregation requirements. Used for gate-in acceptance checks and yard planning.' ;
    rdfs:domain ind:WarehouseImdgApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ventilationRequirements rdf:type rdf:Property ;
    rdfs:label 'Ventilation Requirements' ;
    rdfs:comment 'Ventilation system requirements for this IMDG class in this warehouse (e.g., mechanical ventilation for Class 2 gases, natural ventilation acceptable for Class 9). Specifies air change rates or ventilation standards.' ;
    rdfs:domain ind:WarehouseImdgApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectGangAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Project Gang Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for the project gang assignment record. Primary key for the association.' ;
    rdfs:domain ind:ProjectGangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text notes capturing specific requirements, constraints, or observations about this gang assignment (e.g., special safety requirements, equipment dependencies, weather delays).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'The percentage of the gang\'s labour costs to be allocated to this WBS element when the gang is working across multiple projects concurrently. Used for accurate project cost allocation and gang cost apportionment.' ;
    rdfs:domain ind:ProjectGangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labourCostActual rdf:type rdf:Property ;
    rdfs:label 'Labour Cost Actual' ;
    rdfs:comment 'The actual labour cost incurred for this gang assignment to the WBS element, calculated from actual hours and gang pay rates. Posted to SAP CO for project cost tracking.' ;
    rdfs:domain ind:ProjectGangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labourCostPlanned rdf:type rdf:Property ;
    rdfs:label 'Labour Cost Planned' ;
    rdfs:comment 'The planned or budgeted labour cost for this gang assignment, calculated from planned hours and standard gang rates. Used for project budget tracking and variance analysis.' ;
    rdfs:domain ind:ProjectGangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDeploymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Deployment Date' ;
    rdfs:comment 'The date of the most recent vessel operation deployment for this gang. Used for gang activity monitoring, standby management, and workforce utilisation reporting. [Moved from gang: This attribute currently in gang represents the most recent deployment date, which should be derived from the assignment association rather than stored redundantly in the gang master record. The assignment association is the SSOT for deployment history.]' ;
    rdfs:domain ind:ProjectGangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPhase rdf:type rdf:Property ;
    rdfs:label 'Work Phase' ;
    rdfs:comment 'The specific phase of the capital project during which this gang assignment occurs (e.g., Foundation, Structural, Installation, Commissioning). Aligns with project_phase in WBS element for phase-based labour tracking.' ;
    rdfs:domain ind:ProjectGangAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthServiceContractId rdf:type rdf:Property ;
    rdfs:label 'Berth Service Contract Id' ;
    rdfs:comment 'Unique identifier for this berth-vendor service contract relationship. Primary key.' ;
    rdfs:domain ind:BerthServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'The maximum number of hours within which the vendor must respond to a service request or emergency call for this berth. Response time requirements may vary by berth criticality and service type.' ;
    rdfs:domain ind:BerthServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:berthDiscountApplicationId rdf:type rdf:Property ;
    rdfs:label 'Berth Discount Application Id' ;
    rdfs:comment 'Unique identifier for this discount application record. Primary key.' ;
    rdfs:domain ind:BerthDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationReason rdf:type rdf:Property ;
    rdfs:label 'Application Reason' ;
    rdfs:comment 'Business justification for applying this discount to this berth allocation (e.g., \'Customer met quarterly TEU threshold\', \'Promotional campaign for new service\', \'Off-peak berthing incentive\')' ;
    rdfs:domain ind:BerthDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedDiscountValue rdf:type rdf:Property ;
    rdfs:label 'Applied Discount Value' ;
    rdfs:comment 'The actual discount value applied to this specific berth allocation. May differ from the scheme\'s base discount_value due to pro-rating, caps, or threshold calculations specific to this allocation.' ;
    rdfs:domain ind:BerthDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Name' ;
    rdfs:comment 'Name or role of the person who approved this specific discount application (may differ from the scheme\'s general approval authority for case-by-case approvals)' ;
    rdfs:domain ind:BerthDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmountCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Discount Amount Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the applied discount amount' ;
    rdfs:domain ind:BerthDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective From Timestamp' ;
    rdfs:comment 'Timestamp from which this discount application becomes effective for this berth allocation. Typically aligned with berth_window_start or ATB.' ;
    rdfs:domain ind:BerthDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveToTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective To Timestamp' ;
    rdfs:comment 'Timestamp until which this discount application remains effective for this berth allocation. Typically aligned with berth_window_end or ATD.' ;
    rdfs:domain ind:BerthDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:thresholdMetFlag rdf:type rdf:Property ;
    rdfs:label 'Threshold Met Flag' ;
    rdfs:comment 'Indicates whether the qualifying threshold defined in the discount scheme was met at the time of this application' ;
    rdfs:domain ind:BerthDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bolDiscountApplicationId rdf:type rdf:Property ;
    rdfs:label 'Bol Discount Application Id' ;
    rdfs:comment 'Unique identifier for this discount application record. Primary key.' ;
    rdfs:domain ind:BolDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedByUser rdf:type rdf:Property ;
    rdfs:label 'Applied By User' ;
    rdfs:comment 'Username or identifier of the commercial team member who applied this discount to the BOL' ;
    rdfs:domain ind:BolDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmountApplied rdf:type rdf:Property ;
    rdfs:label 'Discount Amount Applied' ;
    rdfs:comment 'The actual monetary discount amount applied to this BOL under this specific discount scheme, calculated based on the scheme rules and BOL characteristics. Used for revenue reconciliation.' ;
    rdfs:domain ind:BolDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Flag' ;
    rdfs:comment 'Indicates whether the BOL\'s eligibility for this discount scheme has been verified against the scheme\'s qualifying criteria (volume thresholds, customer tier, cargo type restrictions, etc.)' ;
    rdfs:domain ind:BolDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeThresholdMet rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Met' ;
    rdfs:comment 'Indicates whether the volume threshold criteria specified in the discount scheme was met by this BOL or the customer\'s cumulative volume at the time of application' ;
    rdfs:domain ind:BolDiscountApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Call Assignment Id' ;
    rdfs:comment 'Unique identifier for this port call assignment record. Primary key.' ;
    rdfs:domain ind:CallAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment End Timestamp' ;
    rdfs:comment 'Timestamp when the employee completed or was relieved from their assignment to this port call. Used for shift handover tracking and labor cost calculation. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentRole rdf:type rdf:Property ;
    rdfs:label 'Assignment Role' ;
    rdfs:comment 'The specific operational role the employee is performing for this port call. Determines responsibilities, authority level, and coordination requirements. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CallAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Timestamp' ;
    rdfs:comment 'Timestamp when the employee began their assignment to this port call. May precede vessel arrival for pre-arrival planning roles. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibilityArea rdf:type rdf:Property ;
    rdfs:label 'Responsibility Area' ;
    rdfs:comment 'The specific operational area or scope of responsibility for this assignment (e.g., \'Berth 5-7\', \'Container Terminal A\', \'VTS Channel 12\', \'Cargo Hold 1-3\'). Supports zone-based coordination and accountability. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CallAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callIcdAllocationId rdf:type rdf:Property ;
    rdfs:label 'Call Icd Allocation Id' ;
    rdfs:comment 'Unique identifier for this port call to ICD facility cargo allocation record. Primary key.' ;
    rdfs:domain ind:CallIcdAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoVolumeTeu rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Teu' ;
    rdfs:comment 'Number of TEU allocated from this specific port call to this specific ICD facility. Represents the planned or actual cargo volume for this distribution relationship.' ;
    rdfs:domain ind:CallIcdAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCargoType rdf:type rdf:Property ;
    rdfs:label 'Primary Cargo Type' ;
    rdfs:comment 'Primary type of cargo being allocated from this port call to this ICD facility. Determines handling requirements and facility capabilities needed.' ;
    rdfs:domain ind:CallIcdAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callInspectionId rdf:type rdf:Property ;
    rdfs:label 'Call Inspection Id' ;
    rdfs:comment 'Unique identifier for this call-inspection association record. Primary key.' ;
    rdfs:domain ind:CallInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyInspectionId rdf:type rdf:Property ;
    rdfs:label 'Safety Inspection Id' ;
    rdfs:comment 'Foreign key to the safety inspection record' ;
    rdfs:domain ind:CallInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:clearanceGrantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearance Granted Timestamp' ;
    rdfs:comment 'Timestamp when departure clearance was granted following successful inspection or rectification completion. Null if clearance not yet granted.' ;
    rdfs:domain ind:CallInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deficienciesFound rdf:type rdf:Property ;
    rdfs:label 'Deficiencies Found' ;
    rdfs:comment 'Number of deficiencies identified during this inspection that are specific to this port call context. Used to determine detention risk and clearance requirements.' ;
    rdfs:domain ind:CallInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Timestamp' ;
    rdfs:comment 'Deadline by which follow-up actions must be completed for this port call. Typically set relative to planned ETD.' ;
    rdfs:domain ind:CallInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vesselCallSecurityAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Vessel Call Security Assignment Id' ;
    rdfs:comment 'Unique identifier for this security personnel assignment to a vessel call. Primary key for the association.' ;
    rdfs:domain ind:VesselCallSecurityAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Number of security incidents or alerts logged by this personnel during this vessel call assignment. Used for performance tracking and risk assessment.' ;
    rdfs:domain ind:VesselCallSecurityAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryZoneAssigned rdf:type rdf:Property ;
    rdfs:label 'Primary Zone Assigned' ;
    rdfs:comment 'Primary security zone or berth location where this personnel is assigned for this vessel call. Links to port facility security zone taxonomy.' ;
    rdfs:domain ind:VesselCallSecurityAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level Required' ;
    rdfs:comment 'Minimum security clearance level required for this assignment based on vessel ISPS security level, cargo classification, and access zones. Must match or exceed personnel clearance.' ;
    rdfs:domain ind:VesselCallSecurityAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerSurchargeApplicationId rdf:type rdf:Property ;
    rdfs:label 'Container Surcharge Application Id' ;
    rdfs:comment 'Unique system identifier for this surcharge application record. Primary key.' ;
    rdfs:domain ind:ContainerSurchargeApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculationBasisValue rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis Value' ;
    rdfs:comment 'The base value used in the surcharge calculation (e.g., base freight amount, TEU count, weight). Provides audit trail for how surcharge_amount_applied was derived.' ;
    rdfs:domain ind:ContainerSurchargeApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationNotes rdf:type rdf:Property ;
    rdfs:label 'Calculation Notes' ;
    rdfs:comment 'Free-text notes explaining special circumstances, manual adjustments, or calculation details for this surcharge application. Used for billing dispute resolution.' ;
    rdfs:domain ind:ContainerSurchargeApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Reference' ;
    rdfs:comment 'Reference to the specific invoice line item where this surcharge appears. Enables reconciliation between surcharge applications and invoices.' ;
    rdfs:domain ind:ContainerSurchargeApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmountApplied rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount Applied' ;
    rdfs:comment 'The calculated surcharge amount applied to this container in the billing currency. This is the result of applying the surcharge rule\'s calculation method to this specific container.' ;
    rdfs:domain ind:ContainerSurchargeApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declarationScreeningId rdf:type rdf:Property ;
    rdfs:label 'Declaration Screening Id' ;
    rdfs:comment 'Unique identifier for this declaration-screening association record. Primary key.' ;
    rdfs:domain ind:DeclarationScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anomalyDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Anomaly Detected Flag' ;
    rdfs:comment 'Indicates whether any anomaly, discrepancy, or alert was detected during the screening of this declaration. True: anomaly found requiring follow-up. False: no issues detected.' ;
    rdfs:domain ind:DeclarationScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpActionTaken rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Taken' ;
    rdfs:comment 'Description of any follow-up action taken as a result of the screening outcome for this declaration. Documents operational response including secondary inspection, hold placement, or clearance authorization.' ;
    rdfs:domain ind:DeclarationScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByChecklistId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Checklist Id' ;
    rdfs:comment 'Reference to the newer inspection checklist version that replaces this one, enabling version lineage tracking and ensuring users are directed to current procedures.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionChecklist .

ind:applicableRegulationCode rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation Code' ;
    rdfs:comment 'Code or reference number of the regulatory standard, maritime convention, or port authority regulation that mandates or governs this inspection checklist (e.g., IMO SOLAS, OSHA 1910, local port authority codes).' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistCode rdf:type rdf:Property ;
    rdfs:label 'Checklist Code' ;
    rdfs:comment 'Unique business identifier code for the inspection checklist, used for external reference and integration with maintenance management systems.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistDescription rdf:type rdf:Property ;
    rdfs:label 'Checklist Description' ;
    rdfs:comment 'Detailed description of the inspection checklist including its objectives, scope, and application context.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistName rdf:type rdf:Property ;
    rdfs:label 'Checklist Name' ;
    rdfs:comment 'Human-readable name of the inspection checklist describing its purpose and scope.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistType rdf:type rdf:Property ;
    rdfs:label 'Checklist Type' ;
    rdfs:comment 'Classification of the inspection checklist by maintenance strategy: preventive (scheduled), corrective (repair-driven), predictive (condition-based), statutory (regulatory compliance), safety (hazard assessment), or operational (pre-use verification).' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalFormAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Form Available Flag' ;
    rdfs:comment 'Indicates whether a digital/mobile version of this inspection checklist is available for electronic data capture, enabling paperless inspections and real-time data integration.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Documentation Retention Years' ;
    rdfs:comment 'Number of years that completed inspection records using this checklist must be retained for regulatory compliance, audit, and liability purposes.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentClass rdf:type rdf:Property ;
    rdfs:label 'Equipment Class' ;
    rdfs:comment 'Specific equipment class or model family this checklist is designed for, enabling targeted inspection procedures for equipment with similar characteristics.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSystemReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External System Reference Code' ;
    rdfs:comment 'Unique identifier of this checklist in the external maintenance management system, used for cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Prescribed frequency at which this inspection checklist should be executed: daily, weekly, monthly, quarterly, semi-annual, annual, biennial, on-demand (event-triggered), or condition-based (sensor/threshold-driven).' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorQualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Inspector Qualification Level' ;
    rdfs:comment 'Minimum qualification or certification level required for personnel authorized to execute this inspection checklist: operator (basic trained), technician (skilled trades), certified inspector (formal certification), engineer (professional engineer), surveyor (third-party), or regulatory authority (government official).' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Mandatory Checkpoint Count' ;
    rdfs:comment 'Number of checkpoints that must be completed for the inspection to be considered valid, distinguishing critical items from optional or conditional checks.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold Percentage' ;
    rdfs:comment 'Minimum percentage of checkpoints that must pass for the overall inspection to be considered successful, expressed as a decimal (e.g., 95.00 for 95%).' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoEvidenceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Required Flag' ;
    rdfs:comment 'Indicates whether photographic evidence must be captured during inspection execution for documentation, compliance, or defect verification purposes.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this inspection checklist is mandated by regulatory or statutory requirements (true) or is voluntary/internal best practice (false).' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the inspection checklist: draft (under development), active (approved for use), under review (being revised), superseded (replaced by newer version), or retired (no longer applicable).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swlVerificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Swl Verification Required Flag' ;
    rdfs:comment 'Indicates whether this checklist includes verification of Safe Working Load (SWL) ratings for lifting equipment, a critical safety parameter for cranes and material handling equipment.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Total Checkpoint Count' ;
    rdfs:comment 'Total number of individual inspection checkpoints or items included in this checklist, used for progress tracking and completeness validation.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeRequired rdf:type rdf:Property ;
    rdfs:label 'Downtime Required' ;
    rdfs:comment 'Indicates whether the asset must be taken out of service to execute the work order.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date after which this work order template version is no longer valid and should not be used for generating new work orders.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequencyInterval rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval' ;
    rdfs:comment 'Numeric value representing the interval between scheduled occurrences of this work order template for preventive maintenance.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyUnit rdf:type rdf:Property ;
    rdfs:label 'Frequency Unit' ;
    rdfs:comment 'Unit of measure for the frequency interval, supporting time-based and usage-based maintenance scheduling.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionChecklist rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist' ;
    rdfs:comment 'Structured checklist of inspection points, measurements, and acceptance criteria to be completed during work order execution.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockoutTagoutRequired rdf:type rdf:Property ;
    rdfs:label 'Lockout Tagout Required' ;
    rdfs:comment 'Indicates whether lockout/tagout procedures are required for safe execution of this work order template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceCategory rdf:type rdf:Property ;
    rdfs:label 'Maintenance Category' ;
    rdfs:comment 'Technical discipline or trade category required to execute the work order template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitRequired rdf:type rdf:Property ;
    rdfs:label 'Permit Required' ;
    rdfs:comment 'Indicates whether a work permit or hot work permit is required before executing work orders generated from this template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCrewSize rdf:type rdf:Property ;
    rdfs:label 'Required Crew Size' ;
    rdfs:comment 'Number of technicians or crew members required to safely and efficiently execute the work order.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredSkills rdf:type rdf:Property ;
    rdfs:label 'Required Skills' ;
    rdfs:comment 'Comma-separated list of technical skills, certifications, or qualifications required for technicians executing this work order.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTools rdf:type rdf:Property ;
    rdfs:label 'Required Tools' ;
    rdfs:comment 'List of specialized tools, equipment, or test instruments required to execute the work order.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsList rdf:type rdf:Property ;
    rdfs:label 'Spare Parts List' ;
    rdfs:comment 'List of spare parts, consumables, and materials typically required for this work order template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swlVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Swl Verification Required' ;
    rdfs:comment 'Indicates whether this work order template requires verification or recertification of Safe Working Load ratings for lifting equipment.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taskList rdf:type rdf:Property ;
    rdfs:label 'Task List' ;
    rdfs:comment 'Detailed step-by-step task instructions and procedures to be followed when executing work orders from this template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique business identifier code for the work order template used for external reference and system integration.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the work order template including scope, objectives, and expected outcomes of the maintenance activity.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the work order template describing the maintenance or repair activity.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateStatus rdf:type rdf:Property ;
    rdfs:label 'Template Status' ;
    rdfs:comment 'Current lifecycle status of the work order template indicating whether it is available for use in generating work orders.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByObligationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Obligation Id' ;
    rdfs:comment 'Reference to the performance obligation that supersedes this one when retired or deprecated. Null if current version or not superseded.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:constraintEstimationMethod rdf:type rdf:Property ;
    rdfs:label 'Constraint Estimation Method' ;
    rdfs:comment 'Method used to estimate variable consideration constraint: expected value (probability-weighted), most likely amount (single best estimate), or not applicable for fixed obligations.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAssetAccountCode rdf:type rdf:Property ;
    rdfs:label 'Contract Asset Account Code' ;
    rdfs:comment 'General Ledger account code for contract asset when performance obligation is satisfied before payment is received. Represents conditional right to consideration.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractModificationImpact rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Impact' ;
    rdfs:comment 'How contract modifications affect this performance obligation: separate contract (new distinct goods/services), prospective (forward-looking adjustment), cumulative catch-up (retrospective adjustment), or not applicable.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfServiceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Cost Of Service Account Code' ;
    rdfs:comment 'General Ledger account code for direct costs associated with delivering this performance obligation. Used for margin analysis and EBITDA reporting.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredRevenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Account Code' ;
    rdfs:comment 'General Ledger account code for deferred revenue liability when payment is received before performance obligation is satisfied. Used for ASC 606 compliance.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distinctFlag rdf:type rdf:Property ;
    rdfs:label 'Distinct Flag' ;
    rdfs:comment 'Indicates whether this performance obligation is distinct and separately identifiable from other obligations in the contract per ASC 606 criteria. True if distinct, False if bundled.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ebitdaClassification rdf:type rdf:Property ;
    rdfs:label 'Ebitda Classification' ;
    rdfs:comment 'Classification for EBITDA-level revenue reporting: operating revenue (core port services), non-operating revenue (one-time or non-core), or ancillary revenue (supplementary services).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceTiming rdf:type rdf:Property ;
    rdfs:label 'Invoice Timing' ;
    rdfs:comment 'Timing of invoice generation relative to service delivery: advance (before service), concurrent (during service), or arrears (after service completion).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navisN4ServiceCode rdf:type rdf:Property ;
    rdfs:label 'Navis N4 Service Code' ;
    rdfs:comment 'Service code in NAVIS N4 TOS that maps to this performance obligation. Used for invoice generation from terminal operations.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Business identifier code for the performance obligation, used for external reference and reporting.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Human-readable name describing the performance obligation (e.g., Container Handling Service, Vessel Berthing, Storage Fee).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the performance obligation by nature: service (e.g., cargo handling), goods (e.g., equipment sale), license, access (e.g., berth access), or combined bundle.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceDurationDays rdf:type rdf:Property ;
    rdfs:label 'Performance Duration Days' ;
    rdfs:comment 'Expected duration in days to satisfy this performance obligation. Null for point-in-time obligations. Used for over-time revenue recognition calculations.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Price Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the standalone selling price (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressMeasurementMethod rdf:type rdf:Property ;
    rdfs:label 'Progress Measurement Method' ;
    rdfs:comment 'Method for measuring progress toward satisfaction of over-time obligations: input method (costs incurred), output method (units delivered), time elapsed (straight-line), or not applicable for point-in-time.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Category' ;
    rdfs:comment 'Category used for regulatory revenue reporting to port authorities, maritime regulators, or government agencies.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Account Code' ;
    rdfs:comment 'General Ledger account code in SAP S/4HANA FI where revenue for this performance obligation is posted. Maps to chart of accounts for financial reporting.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Method by which revenue is recognized for this performance obligation: point in time (upon completion), over time (duration-based), milestone-based (upon achievement), or usage-based (per transaction).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactionCriteria rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Criteria' ;
    rdfs:comment 'Business criteria that define when the performance obligation is considered satisfied (e.g., container loaded onto vessel, vessel departed berth, storage period completed).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standaloneSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Standalone Selling Price' ;
    rdfs:comment 'The price at which the entity would sell the promised good or service separately to a customer. Used for transaction price allocation in multi-element contracts.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardQuantity rdf:type rdf:Property ;
    rdfs:label 'Standard Quantity' ;
    rdfs:comment 'Standard or default quantity associated with this performance obligation when used in contracts (e.g., 1.0 for single container move, 24.0 for daily storage).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tariffItemReference rdf:type rdf:Property ;
    rdfs:label 'Tariff Item Reference' ;
    rdfs:comment 'Reference to the published port tariff item or rate card entry that defines pricing for this performance obligation. Used for regulatory compliance and customer transparency.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Tax treatment classification for this performance obligation: taxable (subject to VAT/GST), exempt (no tax), zero-rated (0% tax but input credit allowed), or out of scope.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Transfer Control Indicator' ;
    rdfs:comment 'Primary indicator used to determine when control transfers to the customer: customer acceptance, physical possession, legal title transfer, payment obligation created, or significant risks and rewards transferred.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableConsiderationFlag rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Flag' ;
    rdfs:comment 'Indicates whether this performance obligation includes variable consideration such as volume discounts, performance bonuses, penalties, or usage-based pricing. True if variable, False if fixed.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variableConsiderationType rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Type' ;
    rdfs:comment 'Type of variable consideration applicable: volume discount, performance bonus, penalty (e.g., demurrage), usage-based, time-based, or none if fixed pricing.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagCountryId rdf:type rdf:Property ;
    rdfs:label 'Flag Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: resource has flag_country_code (STRING) which should reference country master. When resource represents a vessel or flagged asset, the flag country should FK to country table. Using flag_country_id as' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Principal quantitative measurement of the resource\'s capacity or capability (e.g., TEU for containers, DWT for vessels, square meters for terminals).' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionDate rdf:type rdf:Property ;
    rdfs:label 'Commission Date' ;
    rdfs:comment 'Date when the resource was commissioned and put into operational service.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsBondNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Bond Number' ;
    rdfs:comment 'Customs bond or guarantee number associated with the resource for international trade compliance.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed textual description of the resource including specifications, features, and operational characteristics.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Certified' ;
    rdfs:comment 'Indicates whether the resource is certified for handling or transporting hazardous materials per IMDG Code.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReeferCapable rdf:type rdf:Property ;
    rdfs:label 'Is Reefer Capable' ;
    rdfs:comment 'Indicates whether the resource has refrigeration capability for temperature-controlled cargo (applicable to containers, vessels, terminals).' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resourceCode rdf:type rdf:Property ;
    rdfs:label 'Resource Code' ;
    rdfs:comment 'Externally-known unique business identifier for the resource used across operational systems and partner communications.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceName rdf:type rdf:Property ;
    rdfs:label 'Resource Name' ;
    rdfs:comment 'Human-readable name or title of the resource for display and reporting purposes.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceSubtype rdf:type rdf:Property ;
    rdfs:label 'Resource Subtype' ;
    rdfs:comment 'Secondary classification providing granular categorization within the resource type (e.g., container types: 20GP, 40HC, 45HC; vessel types: feeder, panamax, post-panamax).' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portId rdf:type rdf:Property ;
    rdfs:label 'Port Id' ;
    rdfs:comment 'Reference to the parent port facility that owns or operates this terminal.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Port .

ind:craneTypes rdf:type rdf:Property ;
    rdfs:label 'Crane Types' ;
    rdfs:comment 'Comma-separated list of crane types available at the terminal (e.g., STS gantry, RTG, mobile harbor crane, bulk handling crane). Supports equipment capability assessment and vessel compatibility planning.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsFacilityAvailable rdf:type rdf:Property ;
    rdfs:label 'Customs Facility Available' ;
    rdfs:comment 'Indicates whether the terminal has on-site customs inspection and clearance facilities. True if customs office and inspection zones exist, false otherwise.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeTradeZone rdf:type rdf:Property ;
    rdfs:label 'Free Trade Zone' ;
    rdfs:comment 'Indicates whether the terminal operates within a designated free trade zone or foreign trade zone with special customs and tax treatment. True if FTZ status applies, false otherwise.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExpansionDate rdf:type rdf:Property ;
    rdfs:label 'Last Expansion Date' ;
    rdfs:comment 'Date of the most recent major capacity expansion or infrastructure upgrade project completion. Null if no expansions have occurred since commissioning.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxVesselBeamM rdf:type rdf:Property ;
    rdfs:label 'Max Vessel Beam M' ;
    rdfs:comment 'Maximum beam (width) of vessel that can be accommodated at the terminal, measured in meters. Constrained by berth width and approach channel dimensions.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVesselLengthM rdf:type rdf:Property ;
    rdfs:label 'Max Vessel Length M' ;
    rdfs:comment 'Maximum length of vessel that can be accommodated at the terminal, measured in meters. Constrained by berth length and maneuvering basin dimensions.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfBerths rdf:type rdf:Property ;
    rdfs:label 'Number Of Berths' ;
    rdfs:comment 'Total count of vessel berths available at the terminal for simultaneous vessel operations.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfCranes rdf:type rdf:Property ;
    rdfs:label 'Number Of Cranes' ;
    rdfs:comment 'Total count of cargo handling cranes deployed at the terminal, including ship-to-shore gantry cranes, mobile harbor cranes, and rail-mounted gantry cranes.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openStorageAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Open Storage Area Sqm' ;
    rdfs:comment 'Total uncovered outdoor storage area at the terminal measured in square meters. Used for container stacking, bulk cargo stockpiling, and vehicle parking.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:railConnectionAvailable rdf:type rdf:Property ;
    rdfs:label 'Rail Connection Available' ;
    rdfs:comment 'Indicates whether the terminal has direct rail connectivity for intermodal cargo transfer. True if on-dock rail facilities exist, false otherwise.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:railTrackLengthM rdf:type rdf:Property ;
    rdfs:label 'Rail Track Length M' ;
    rdfs:comment 'Total length of rail tracks within the terminal facility measured in meters. Null if no rail connection exists.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityCertification rdf:type rdf:Property ;
    rdfs:label 'Security Certification' ;
    rdfs:comment 'Highest level of international security certification held by the terminal. ISPS (International Ship and Port Facility Security Code) is mandatory for international ports, C-TPAT (Customs-Trade Partnership Against Terrorism) is US program, AEO (Authorized Economic Operator) is EU/international program.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shorePowerAvailable rdf:type rdf:Property ;
    rdfs:label 'Shore Power Available' ;
    rdfs:comment 'Indicates whether the terminal provides shore-side electrical power (cold ironing) to berthed vessels, allowing them to shut down auxiliary engines and reduce emissions. True if shore power infrastructure exists, false otherwise.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminalName rdf:type rdf:Property ;
    rdfs:label 'Terminal Name' ;
    rdfs:comment 'Official business name of the terminal facility.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalType rdf:type rdf:Property ;
    rdfs:label 'Terminal Type' ;
    rdfs:comment 'Classification of terminal based on primary cargo handling capability. Container terminals handle containerized cargo, bulk terminals handle dry or liquid bulk commodities, ro-ro terminals handle roll-on/roll-off vehicles and equipment, general cargo terminals handle break-bulk and non-containerized goods, cruise terminals handle passenger vessels, and multipurpose terminals support mixed operations.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuayLengthM rdf:type rdf:Property ;
    rdfs:label 'Total Quay Length M' ;
    rdfs:comment 'Combined linear length of all quay walls and wharves at the terminal measured in meters. Determines the total vessel berthing capacity.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:truckGateLanes rdf:type rdf:Property ;
    rdfs:label 'Truck Gate Lanes' ;
    rdfs:comment 'Number of truck entry and exit gate lanes at the terminal for road cargo transfer. Determines truck processing capacity and gate throughput.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warehouseAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Warehouse Area Sqm' ;
    rdfs:comment 'Total covered warehouse and storage facility area at the terminal measured in square meters. Used for cargo consolidation, temporary storage, and value-added services.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyClass rdf:type rdf:Property ;
    rdfs:label 'Accuracy Class' ;
    rdfs:comment 'Metrological accuracy classification of the weighing station according to international standards for non-automatic weighing instruments.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetAcquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Asset Acquisition Cost' ;
    rdfs:comment 'Original capital expenditure (CAPEX) cost for procurement and installation of the weighing station, used for asset valuation and depreciation calculations.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Asset Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the asset acquisition cost and financial valuation.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedDataCaptureEnabled rdf:type rdf:Property ;
    rdfs:label 'Automated Data Capture Enabled' ;
    rdfs:comment 'Indicates whether the weighing station is equipped with automated data capture capabilities for real-time weight transmission to port management systems.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalProtectionRating rdf:type rdf:Property ;
    rdfs:label 'Environmental Protection Rating' ;
    rdfs:comment 'Ingress Protection (IP) rating indicating the level of protection against dust and water ingress for outdoor marine environment operation.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadCellCount rdf:type rdf:Property ;
    rdfs:label 'Load Cell Count' ;
    rdfs:comment 'Number of load cells installed in the weighing station platform for weight measurement and distribution.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Maintenance Contract Number' ;
    rdfs:comment 'Reference number of the active maintenance service contract for the weighing station equipment.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceProviderName rdf:type rdf:Property ;
    rdfs:label 'Maintenance Provider Name' ;
    rdfs:comment 'Name of the company or service provider responsible for maintenance and repair of the weighing station.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the weighing station measured in kilograms, representing the upper limit for safe and accurate weighing operations.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPrecisionKg rdf:type rdf:Property ;
    rdfs:label 'Measurement Precision Kg' ;
    rdfs:comment 'Smallest weight increment that the weighing station can accurately measure, expressed in kilograms.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Minimum Capacity Kg' ;
    rdfs:comment 'Minimum weight capacity of the weighing station measured in kilograms, representing the lower threshold for accurate measurement.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Max C' ;
    rdfs:comment 'Maximum ambient temperature in degrees Celsius at which the weighing station can operate within specified accuracy limits.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Min C' ;
    rdfs:comment 'Minimum ambient temperature in degrees Celsius at which the weighing station can operate within specified accuracy limits.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformLengthM rdf:type rdf:Property ;
    rdfs:label 'Platform Length M' ;
    rdfs:comment 'Length of the weighing platform measured in meters, determining the maximum vehicle or cargo size that can be accommodated.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformWidthM rdf:type rdf:Property ;
    rdfs:label 'Platform Width M' ;
    rdfs:comment 'Width of the weighing platform measured in meters, determining the lateral space available for cargo or vehicle positioning.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerSupplyType rdf:type rdf:Property ;
    rdfs:label 'Power Supply Type' ;
    rdfs:comment 'Type of electrical power supply used to operate the weighing station equipment and instrumentation.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Remote Monitoring Enabled' ;
    rdfs:comment 'Indicates whether the weighing station supports remote monitoring and diagnostics capabilities for operational oversight.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solasVgmCompliant rdf:type rdf:Property ;
    rdfs:label 'Solas Vgm Compliant' ;
    rdfs:comment 'Indicates whether the weighing station meets the accuracy and certification requirements for SOLAS VGM container weighing regulations.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weighbridgeType rdf:type rdf:Property ;
    rdfs:label 'Weighbridge Type' ;
    rdfs:comment 'Physical installation type of the weighbridge structure indicating mounting configuration and mobility characteristics.' ;
    rdfs:domain ind:WeighingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCycleId rdf:type rdf:Property ;
    rdfs:label 'Parent Cycle Id' ;
    rdfs:comment 'Reference to the parent billing cycle if this is an adjustment or sub-cycle. Used to maintain hierarchical relationships between regular and adjustment cycles.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCycle .

ind:autoInvoiceGenerationFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Invoice Generation Flag' ;
    rdfs:comment 'Indicates whether invoices for this billing cycle are generated automatically by the billing system or require manual review and approval.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cycle Closed Timestamp' ;
    rdfs:comment 'The date and time when this billing cycle was closed and finalized, preventing further transaction posting.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Business identifier code for the billing cycle, used for external reference and reporting. Typically follows port authority naming conventions.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name of the billing cycle, such as \'Monthly Container Services - January 2024\' or \'Quarterly Vessel Operations Q1-2024\'.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the billing cycle. Active cycles are open for transaction posting; closed cycles are finalized for revenue recognition.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the billing cycle frequency. Determines the recurring pattern for invoice generation and revenue recognition.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeWindowDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Window Days' ;
    rdfs:comment 'Number of days from invoice date during which customers can raise billing disputes for invoices in this cycle. Typically 30-90 days.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalCycleReference rdf:type rdf:Property ;
    rdfs:label 'External Cycle Reference' ;
    rdfs:comment 'External reference number or identifier used by upstream systems (NAVIS N4, SAP) to identify this billing cycle. Used for system integration and reconciliation.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter number (1-4) to which this billing cycle belongs, used for quarterly financial reporting and analysis.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glPeriod rdf:type rdf:Property ;
    rdfs:label 'Gl Period' ;
    rdfs:comment 'The general ledger accounting period in YYYYMM format to which this billing cycle is assigned for financial reporting.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Integration Source System' ;
    rdfs:comment 'The name of the source system from which billing cycle data originates, typically NAVIS N4 TOS or SAP S/4HANA FI.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGenerationDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Generation Date' ;
    rdfs:comment 'The date on which invoices for this billing cycle are generated and issued to customers. Typically occurs after the cycle end date.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAdjustmentCycle rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Cycle' ;
    rdfs:comment 'Indicates whether this is a special adjustment or correction cycle used to process chargebacks, credit memos, or billing corrections outside the regular billing schedule.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Late Fee Applicable Flag' ;
    rdfs:comment 'Indicates whether late payment fees are applicable for invoices in this billing cycle if payment is received after the due date.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Late Fee Percentage' ;
    rdfs:comment 'The percentage rate applied to overdue invoice amounts as a late payment penalty. Expressed as a percentage (e.g., 1.5 for 1.5% per month).' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBilledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Billed Amount' ;
    rdfs:comment 'The total gross amount billed across all invoices in this billing cycle, before adjustments or payments. Used for revenue forecasting and EBITDA reporting.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Total Discount Amount' ;
    rdfs:comment 'The total discount amount applied across all invoices in this billing cycle, including volume discounts, early payment discounts, and promotional adjustments.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoiceCount rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Count' ;
    rdfs:comment 'The total number of invoices generated for this billing cycle. Used for cycle reconciliation and billing volume tracking.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalNetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Net Amount' ;
    rdfs:comment 'The total net amount due across all invoices in this billing cycle after applying discounts and taxes. Represents the actual revenue to be collected.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'The total tax amount (VAT, GST, or other applicable taxes) included in all invoices for this billing cycle.' ;
    rdfs:domain ind:BillingCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Primary key for facility' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:capexProjectId rdf:type rdf:Property ;
    rdfs:label 'Capex Project Id' ;
    rdfs:comment 'Reference to the CAPEX project under which this facility was constructed or upgraded.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:terminalOperatorPortCommunityParticipantId rdf:type rdf:Property ;
    rdfs:label 'Terminal Operator Port Community Participant Id' ;
    rdfs:comment 'Reference to the terminal operator or concessionaire responsible for operating this facility.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortCommunityParticipant .

ind:annualThroughputTonnes rdf:type rdf:Property ;
    rdfs:label 'Annual Throughput Tonnes' ;
    rdfs:comment 'Average annual cargo throughput handled by the facility, measured in metric tonnes. Key performance indicator for capacity planning.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avevaAssetReference rdf:type rdf:Property ;
    rdfs:label 'Aveva Asset Reference' ;
    rdfs:comment 'External identifier linking this facility to AVEVA Marine Engineering system for design and engineering integration.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthLengthM rdf:type rdf:Property ;
    rdfs:label 'Berth Length M' ;
    rdfs:comment 'Total length of the berth or quay wall measured in meters. Critical for vessel berthing planning.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bollardPullCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Bollard Pull Capacity Tonnes' ;
    rdfs:comment 'Maximum bollard pull capacity for mooring operations, measured in tonnes. Indicates the strength of mooring infrastructure.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constructionCostUsd rdf:type rdf:Property ;
    rdfs:label 'Construction Cost Usd' ;
    rdfs:comment 'Total capital cost of constructing the facility, measured in USD. Used for asset valuation and CAPEX tracking.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:craneCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Crane Capacity Tonnes' ;
    rdfs:comment 'Maximum lifting capacity of cranes installed at the facility, measured in tonnes. Applicable to container and cargo terminals.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current lifecycle status of the facility indicating its availability and operational state.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVesselDraftM rdf:type rdf:Property ;
    rdfs:label 'Max Vessel Draft M' ;
    rdfs:comment 'Maximum draft of vessels that can safely berth at this facility, measured in meters.' ;
    rdfs:domain ind:Infrastructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reeferPointsCount rdf:type rdf:Property ;
    rdfs:label 'Reefer Points Count' ;
    rdfs:comment 'Number of electrical connection points available for refrigerated containers at the facility.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Storage Area Sqm' ;
    rdfs:comment 'Total covered or open storage area available at the facility, measured in square meters. Applicable to warehouses and yards.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationRatePct rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Pct' ;
    rdfs:comment 'Current utilization rate of the facility expressed as a percentage of total capacity. Used for capacity planning and expansion analysis.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalCycleId rdf:type rdf:Property ;
    rdfs:label 'Reversal Cycle Id' ;
    rdfs:comment 'Reference to another allocation cycle that reverses the allocations made in this cycle, if applicable.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationCycle .

ind:actualExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Execution Date' ;
    rdfs:comment 'The actual date when the allocation cycle was executed and cost allocations were processed.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The primary basis or driver used for allocating costs in this cycle (e.g., headcount, square footage, revenue, vessel calls, container volume).' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The methodology used for cost allocation in this cycle (direct, step-down, reciprocal, activity-based, proportional, driver-based).' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRunSequence rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Sequence' ;
    rdfs:comment 'The sequence number indicating the order in which this allocation cycle should be executed relative to other cycles in the same period.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Execution Date' ;
    rdfs:comment 'The scheduled date when the allocation cycle is planned to be executed and cost allocations processed.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'The pattern defining how frequently this allocation cycle recurs (monthly, quarterly, semi-annual, annual, custom).' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalAllowed rdf:type rdf:Property ;
    rdfs:label 'Reversal Allowed' ;
    rdfs:comment 'Boolean flag indicating whether allocations made in this cycle can be reversed (true) or are final (false).' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCostCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Target Cost Center Group' ;
    rdfs:comment 'The group or category of target cost centers that will receive allocated costs in this cycle.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Allocated Amount' ;
    rdfs:comment 'The total monetary amount allocated across all cost centers during this allocation cycle.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnitId rdf:type rdf:Property ;
    rdfs:label 'Business Unit Id' ;
    rdfs:comment 'Reference to the business unit or division responsible for sponsoring and executing this investment program.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:generalLedgerAccountId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account Id' ;
    rdfs:comment 'Reference to the general ledger account in the financial accounting (FI) module used for posting investment program transactions.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:sponsorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Employee Id' ;
    rdfs:comment 'Reference to the executive or senior leader who sponsors and provides strategic oversight for this investment program.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Total amount actually spent and posted to the general ledger for this investment program to date, representing realized expenditures.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationMethod rdf:type rdf:Property ;
    rdfs:label 'Capitalization Method' ;
    rdfs:comment 'Accounting treatment method for investment program expenditures: full capitalization to balance sheet, partial capitalization with some expensing, or expense as incurred.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Flag' ;
    rdfs:comment 'Indicates whether this investment program is driven by regulatory compliance requirements (True) or is discretionary (False).' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalImpactAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment Flag' ;
    rdfs:comment 'Indicates whether this investment program requires environmental impact assessment and approval under maritime environmental regulations (True/False).' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedRoiPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Roi Percentage' ;
    rdfs:comment 'Projected return on investment percentage for this investment program, calculated during business case development and used for investment prioritization.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Amount' ;
    rdfs:comment 'Projected total expenditure amount for this investment program based on current execution plans and estimates to completion.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalRateOfReturnPercentage rdf:type rdf:Property ;
    rdfs:label 'Internal Rate Of Return Percentage' ;
    rdfs:comment 'Calculated internal rate of return percentage for this investment program, representing the discount rate at which NPV equals zero.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPresentValueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Present Value Amount' ;
    rdfs:comment 'Calculated net present value of expected future cash flows from this investment program, discounted to present value using the corporate discount rate.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paybackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Payback Period Months' ;
    rdfs:comment 'Expected number of months required to recover the investment through generated cash flows or cost savings.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programCategory rdf:type rdf:Property ;
    rdfs:label 'Program Category' ;
    rdfs:comment 'Business category of the investment program aligned with maritime logistics asset classes: infrastructure, equipment, technology systems, facility upgrades, vessel acquisitions, or terminal development.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Externally-known unique business identifier code for the investment program, used in financial reporting and project tracking systems.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Full descriptive name of the investment program as recognized by stakeholders and management.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the investment program by expenditure category: capital expenditure (CAPEX), operational expenditure (OPEX), maintenance, expansion, modernization, or regulatory compliance.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDepthMeters rdf:type rdf:Property ;
    rdfs:label 'Channel Depth Meters' ;
    rdfs:comment 'Maintained depth of the navigation channel along this route, measured in meters below chart datum. Critical for under-keel clearance calculations.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelWidthMeters rdf:type rdf:Property ;
    rdfs:label 'Channel Width Meters' ;
    rdfs:comment 'Width of the navigation channel along this route in meters. Used for safe passing distance and maneuvering calculations.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compulsoryPilotageFlag rdf:type rdf:Property ;
    rdfs:label 'Compulsory Pilotage Flag' ;
    rdfs:comment 'Indicates whether pilotage is legally compulsory for this route under port regulations. True if mandatory, false if voluntary or exempt vessels exist.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daylightOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Daylight Only Flag' ;
    rdfs:comment 'Indicates whether this route can only be navigated during daylight hours due to safety or regulatory restrictions. True if daylight-only, false if 24-hour operation permitted.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationLatitude rdf:type rdf:Property ;
    rdfs:label 'Destination Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the route destination point in decimal degrees format.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLongitude rdf:type rdf:Property ;
    rdfs:label 'Destination Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the route destination point in decimal degrees format.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationPoint rdf:type rdf:Property ;
    rdfs:label 'Destination Point' ;
    rdfs:comment 'Ending location of the pilotage route, typically a berth, anchorage, or pilot disembarkation station.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceNauticalMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Nautical Miles' ;
    rdfs:comment 'Total navigational distance of the pilotage route measured in nautical miles. Used for time estimation and billing calculations.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalSensitiveAreaFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Sensitive Area Flag' ;
    rdfs:comment 'Indicates whether this route passes through or adjacent to an environmentally sensitive area with special protection measures. True if additional environmental protocols apply.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousCargoRestriction rdf:type rdf:Property ;
    rdfs:label 'Hazardous Cargo Restriction' ;
    rdfs:comment 'Level of restriction applied to vessels carrying hazardous cargo on this route. Values: none (no restrictions), imdg_class_restricted (specific IMDG classes prohibited), no_hazmat (all hazardous materials prohibited), special_approval (case-by-case approval required).' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBeamMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Beam Meters' ;
    rdfs:comment 'Maximum vessel beam (width) in meters that can safely navigate this route. Used for channel width restrictions.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Length Meters' ;
    rdfs:comment 'Maximum vessel length overall in meters that can safely navigate this route. Used for turning basin and berth restrictions.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumWaveHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Wave Height Meters' ;
    rdfs:comment 'Maximum significant wave height in meters under which this route can be safely navigated. Applicable when weather_restricted_flag is true.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumWindSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Maximum Wind Speed Knots' ;
    rdfs:comment 'Maximum sustained wind speed in knots under which this route can be safely navigated. Applicable when weather_restricted_flag is true.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumDraftMeters rdf:type rdf:Property ;
    rdfs:label 'Minimum Draft Meters' ;
    rdfs:comment 'Minimum vessel draft in meters that can safely navigate this route. Used for vessel eligibility determination.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTideHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Minimum Tide Height Meters' ;
    rdfs:comment 'Minimum tide height in meters above chart datum required for safe navigation of this route. Applicable only when tidal_dependency_flag is true.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTugCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Tug Count' ;
    rdfs:comment 'Minimum number of tugs required to assist vessels on this route when towage is mandatory. Applicable when towage_required_flag is true.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originLatitude rdf:type rdf:Property ;
    rdfs:label 'Origin Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the route origin point in decimal degrees format.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLongitude rdf:type rdf:Property ;
    rdfs:label 'Origin Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the route origin point in decimal degrees format.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originPoint rdf:type rdf:Property ;
    rdfs:label 'Origin Point' ;
    rdfs:comment 'Starting location of the pilotage route, typically a pilot boarding station, anchorage, or berth designation.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtakingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Overtaking Permitted Flag' ;
    rdfs:comment 'Indicates whether vessels are permitted to overtake other vessels on this route. True if overtaking is allowed, false if prohibited due to channel width or safety concerns.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pilotExemptionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Pilot Exemption Allowed Flag' ;
    rdfs:comment 'Indicates whether pilot exemption certificates are recognized for this route. True if qualified masters may be granted exemption from compulsory pilotage.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the pilotage route. Used in operational communications and scheduling systems.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name of the pilotage route, typically including origin and destination points.' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the pilotage route based on operational purpose: inbound (vessel entering port), outbound (vessel departing port), shifting (vessel moving within port), harbor (harbor navigation), or channel (channel transit).' ;
    rdfs:domain ind:ShippingPorts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalEndDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal End Date' ;
    rdfs:comment 'Annual recurring end date for seasonal routes in MM-DD format. Applicable when status is seasonal. Represents the date each year when the route ceases operation.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalStartDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Start Date' ;
    rdfs:comment 'Annual recurring start date for seasonal routes in MM-DD format. Applicable when status is seasonal. Represents the date each year when the route becomes operational.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedLimitKnots rdf:type rdf:Property ;
    rdfs:label 'Speed Limit Knots' ;
    rdfs:comment 'Maximum permitted vessel speed through water in knots for this route. Enforced for safety, wake control, or environmental protection.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tidalDependencyFlag rdf:type rdf:Property ;
    rdfs:label 'Tidal Dependency Flag' ;
    rdfs:comment 'Indicates whether this route has tidal restrictions that affect vessel transit windows. True if route requires specific tidal conditions, false otherwise.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trafficSeparationSchemeFlag rdf:type rdf:Property ;
    rdfs:label 'Traffic Separation Scheme Flag' ;
    rdfs:comment 'Indicates whether this route includes or intersects with an International Maritime Organization (IMO) Traffic Separation Scheme. True if TSS rules apply.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:twoWayTrafficFlag rdf:type rdf:Property ;
    rdfs:label 'Two Way Traffic Flag' ;
    rdfs:comment 'Indicates whether this route supports simultaneous two-way vessel traffic. True if bidirectional traffic is permitted, false if one-way or alternating traffic only.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vesselTrafficServiceAreaFlag rdf:type rdf:Property ;
    rdfs:label 'Vessel Traffic Service Area Flag' ;
    rdfs:comment 'Indicates whether this route is within a Vessel Traffic Service area requiring mandatory reporting and communication. True if VTS participation is required.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vtsChannelNumber rdf:type rdf:Property ;
    rdfs:label 'Vts Channel Number' ;
    rdfs:comment 'VHF radio channel number used for Vessel Traffic Service communications along this route. Format: VHF followed by two-digit channel number.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Restricted Flag' ;
    rdfs:comment 'Indicates whether this route has weather-related operational restrictions. True if route is subject to closure or restrictions during adverse weather conditions.' ;
    rdfs:domain ind:PilotageRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteReceptionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Waste Reception Facility Id' ;
    rdfs:comment 'Primary key for waste_reception_facility' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptsGarbage rdf:type rdf:Property ;
    rdfs:label 'Accepts Garbage' ;
    rdfs:comment 'Indicates whether the facility can receive and process general garbage waste from vessels.' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsHazardousWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Hazardous Waste' ;
    rdfs:comment 'Indicates whether the facility is licensed and equipped to handle hazardous waste materials.' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsOilyWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Oily Waste' ;
    rdfs:comment 'Indicates whether the facility can receive and process oily waste from vessels.' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsSewage rdf:type rdf:Property ;
    rdfs:label 'Accepts Sewage' ;
    rdfs:comment 'Indicates whether the facility can receive and process sewage waste from vessels.' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advanceNoticeRequiredHours rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Required Hours' ;
    rdfs:comment 'Minimum number of hours advance notice required for vessels to request waste reception services.' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Capacity Cubic Meters' ;
    rdfs:comment 'Maximum storage capacity of the waste reception facility measured in cubic meters, representing the principal quantitative fact about this resource.' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'Environmental management or quality certification standard that the facility complies with.' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Notes' ;
    rdfs:comment 'Additional notes regarding environmental compliance, restrictions, or special handling requirements for this facility.' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Compliance Status' ;
    rdfs:comment 'Current compliance status based on the most recent regulatory inspection findings.' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputCapacityTonsPerDay rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Tons Per Day' ;
    rdfs:comment 'Maximum daily processing throughput capacity of the facility measured in metric tons per day.' ;
    rdfs:domain ind:WasteReceptionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backupPowerAvailable rdf:type rdf:Property ;
    rdfs:label 'Backup Power Available' ;
    rdfs:comment 'Indicates whether the building has backup power generation capability (e.g., diesel generators, UPS systems) for critical operations continuity.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the building for identification and reference in port operations, engineering drawings, and facility management systems.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingName rdf:type rdf:Property ;
    rdfs:label 'Building Name' ;
    rdfs:comment 'Human-readable name or designation of the building (e.g., Container Terminal Warehouse 3, Administration Building, Customs Inspection Facility).' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingType rdf:type rdf:Property ;
    rdfs:label 'Building Type' ;
    rdfs:comment 'Classification of the building based on its primary functional purpose within the port infrastructure (e.g., warehouse, office, workshop, terminal, customs, inspection facility).' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceilingHeightM rdf:type rdf:Property ;
    rdfs:label 'Ceiling Height M' ;
    rdfs:comment 'Clear ceiling height measured in meters from floor to lowest structural or mechanical obstruction, important for cargo stacking and equipment clearance.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electricalCapacityKva rdf:type rdf:Property ;
    rdfs:label 'Electrical Capacity Kva' ;
    rdfs:comment 'Total electrical power capacity available to the building measured in kilovolt-amperes (kVA), supporting operational equipment and systems.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fireRating rdf:type rdf:Property ;
    rdfs:label 'Fire Rating' ;
    rdfs:comment 'Fire resistance classification of the building structure based on applicable fire safety standards and building codes.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossFloorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Gross Floor Area Sqm' ;
    rdfs:comment 'Total gross floor area of the building measured in square meters, including all floors and enclosed spaces. Critical for capacity planning and space utilization analysis.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hvacSystemType rdf:type rdf:Property ;
    rdfs:label 'Hvac System Type' ;
    rdfs:comment 'Type of heating, ventilation, and air conditioning system installed in the building (e.g., central, split system, natural ventilation, none).' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenovationYear rdf:type rdf:Property ;
    rdfs:label 'Last Renovation Year' ;
    rdfs:comment 'Year when the most recent major renovation, refurbishment, or structural upgrade was completed on the building.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadingDockCount rdf:type rdf:Property ;
    rdfs:label 'Loading Dock Count' ;
    rdfs:comment 'Number of loading docks or bays available at the building for cargo handling and material transfer operations.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule' ;
    rdfs:comment 'Frequency or schedule type for planned preventive maintenance activities on the building and its systems.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLoadCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Load Capacity Tonnes' ;
    rdfs:comment 'Maximum structural load capacity of the building floor system measured in metric tonnes, critical for warehouse and storage facility operations.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfFloors rdf:type rdf:Property ;
    rdfs:label 'Number Of Floors' ;
    rdfs:comment 'Total count of floors or levels in the building structure, including ground floor and any basement or mezzanine levels.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occupancyCapacity rdf:type rdf:Property ;
    rdfs:label 'Occupancy Capacity' ;
    rdfs:comment 'Maximum number of personnel that can safely occupy the building simultaneously based on building codes and safety regulations.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parkingSpaces rdf:type rdf:Property ;
    rdfs:label 'Parking Spaces' ;
    rdfs:comment 'Number of vehicle parking spaces available at or adjacent to the building for staff and visitor use.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roofType rdf:type rdf:Property ;
    rdfs:label 'Roof Type' ;
    rdfs:comment 'Type of roof structure and design used in the building construction (e.g., flat, pitched, gable, shed, curved).' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seismicRating rdf:type rdf:Property ;
    rdfs:label 'Seismic Rating' ;
    rdfs:comment 'Seismic design category or earthquake resistance rating of the building based on structural engineering assessments and local seismic codes.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sprinklerSystemInstalled rdf:type rdf:Property ;
    rdfs:label 'Sprinkler System Installed' ;
    rdfs:comment 'Indicates whether an automatic fire sprinkler system is installed in the building for fire suppression.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:structuralMaterial rdf:type rdf:Property ;
    rdfs:label 'Structural Material' ;
    rdfs:comment 'Primary construction material used in the building\'s structural framework (e.g., steel, concrete, reinforced concrete, masonry).' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usableFloorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Usable Floor Area Sqm' ;
    rdfs:comment 'Net usable floor area in square meters available for operational activities, excluding structural elements, mechanical rooms, and circulation spaces.' ;
    rdfs:domain ind:FacilityBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patrolRouteId rdf:type rdf:Property ;
    rdfs:label 'Patrol Route Id' ;
    rdfs:comment 'Primary key for patrol_route' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessControlPoints rdf:type rdf:Property ;
    rdfs:label 'Access Control Points' ;
    rdfs:comment 'Number of access control points or gates that must be verified during the patrol route.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByAuthority rdf:type rdf:Property ;
    rdfs:label 'Approved By Authority' ;
    rdfs:comment 'Name of the regulatory authority or designated security authority that approved this patrol route.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkpointCount rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Count' ;
    rdfs:comment 'Number of designated checkpoints or verification points along the patrol route.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Time Minutes' ;
    rdfs:comment 'Maximum acceptable time in minutes for security response team to reach any point on this patrol route.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endLocation rdf:type rdf:Property ;
    rdfs:label 'End Location' ;
    rdfs:comment 'Designated ending point or location for the patrol route within the port facility.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Required' ;
    rdfs:comment 'Indicates whether security personnel must use GPS tracking devices when patrolling this route for verification.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentCountLastYear rdf:type rdf:Property ;
    rdfs:label 'Incident Count Last Year' ;
    rdfs:comment 'Number of security incidents reported along this patrol route in the previous 12-month period.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nightPatrolRequired rdf:type rdf:Property ;
    rdfs:label 'Night Patrol Required' ;
    rdfs:comment 'Indicates whether this route requires dedicated patrol coverage during night hours.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patrolFrequencyPerShift rdf:type rdf:Property ;
    rdfs:label 'Patrol Frequency Per Shift' ;
    rdfs:comment 'Required number of times this route must be patrolled during a single security shift.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patrolMode rdf:type rdf:Property ;
    rdfs:label 'Patrol Mode' ;
    rdfs:comment 'Primary method of transportation used by security personnel when conducting patrols on this route.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresArmedPatrol rdf:type rdf:Property ;
    rdfs:label 'Requires Armed Patrol' ;
    rdfs:comment 'Indicates whether security personnel conducting this patrol must be armed according to facility security plan.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresTwoPersonPatrol rdf:type rdf:Property ;
    rdfs:label 'Requires Two Person Patrol' ;
    rdfs:comment 'Indicates whether this route requires a minimum of two security personnel for safety or security protocol compliance.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedAreaFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Area Flag' ;
    rdfs:comment 'Indicates whether the patrol route passes through or monitors restricted areas requiring special clearance.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeDescription rdf:type rdf:Property ;
    rdfs:label 'Route Description' ;
    rdfs:comment 'Detailed description of the patrol route including key landmarks, checkpoints, and areas of focus.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDistanceMeters rdf:type rdf:Property ;
    rdfs:label 'Route Distance Meters' ;
    rdfs:comment 'Total distance of the patrol route measured in meters for planning and resource allocation.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current operational status of the patrol route in the security management system.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startLocation rdf:type rdf:Property ;
    rdfs:label 'Start Location' ;
    rdfs:comment 'Designated starting point or location for the patrol route within the port facility.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watersideInterfaceFlag rdf:type rdf:Property ;
    rdfs:label 'Waterside Interface Flag' ;
    rdfs:comment 'Indicates whether the patrol route includes monitoring of the waterside perimeter or vessel interface areas.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weatherDependent rdf:type rdf:Property ;
    rdfs:label 'Weather Dependent' ;
    rdfs:comment 'Indicates whether patrol operations on this route are affected by weather conditions requiring alternative procedures.' ;
    rdfs:domain ind:PatrolRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appointmentRequired rdf:type rdf:Property ;
    rdfs:label 'Appointment Required' ;
    rdfs:comment 'Indicates whether vehicles must have a pre-scheduled appointment to use this lane.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageProcessingTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Average Processing Time Seconds' ;
    rdfs:comment 'Average time in seconds required to process a single vehicle transaction through this lane.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boothNumber rdf:type rdf:Property ;
    rdfs:label 'Booth Number' ;
    rdfs:comment 'Identifier for the gate booth or control station associated with this lane, if applicable.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceEnabled rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Enabled' ;
    rdfs:comment 'Indicates whether customs clearance activities can be performed at this lane.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoCoordinatesLatitude rdf:type rdf:Property ;
    rdfs:label 'Geo Coordinates Latitude' ;
    rdfs:comment 'Latitude coordinate of the gate lane location in decimal degrees format.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoCoordinatesLongitude rdf:type rdf:Property ;
    rdfs:label 'Geo Coordinates Longitude' ;
    rdfs:comment 'Longitude coordinate of the gate lane location in decimal degrees format.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionLane rdf:type rdf:Property ;
    rdfs:label 'Inspection Lane' ;
    rdfs:comment 'Indicates whether this lane is designated for detailed physical inspection of containers and cargo.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Lane Length Meters' ;
    rdfs:comment 'Physical length of the gate lane measured in meters, from entry point to exit point.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laneName rdf:type rdf:Property ;
    rdfs:label 'Lane Name' ;
    rdfs:comment 'Descriptive name or label for the gate lane to aid in identification and wayfinding.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneNumber rdf:type rdf:Property ;
    rdfs:label 'Lane Number' ;
    rdfs:comment 'Business identifier for the gate lane, typically displayed on signage and used in operational communications (e.g., \'A1\', \'B3\', \'TRUCK-05\').' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Classification of the gate lane based on its operational purpose and traffic flow direction.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneWidthMeters rdf:type rdf:Property ;
    rdfs:label 'Lane Width Meters' ;
    rdfs:comment 'Physical width of the gate lane measured in meters, determining the size of vehicles that can be accommodated.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ocrEnabled rdf:type rdf:Property ;
    rdfs:label 'Ocr Enabled' ;
    rdfs:comment 'Indicates whether the lane is equipped with OCR cameras for automated license plate and container number recognition.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityLane rdf:type rdf:Property ;
    rdfs:label 'Priority Lane' ;
    rdfs:comment 'Indicates whether this lane is designated for priority or expedited processing of pre-approved or trusted carrier vehicles.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingCapacityPerHour rdf:type rdf:Property ;
    rdfs:label 'Processing Capacity Per Hour' ;
    rdfs:comment 'Designed throughput capacity of the lane measured in number of vehicle transactions that can be processed per hour under normal operating conditions.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:radiationScannerEquipped rdf:type rdf:Property ;
    rdfs:label 'Radiation Scanner Equipped' ;
    rdfs:comment 'Indicates whether the lane has radiation detection equipment for security screening of containers.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tosIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Tos Integration Enabled' ;
    rdfs:comment 'Indicates whether the lane is integrated with the terminal operating system for real-time transaction processing and data exchange.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trafficDirection rdf:type rdf:Property ;
    rdfs:label 'Traffic Direction' ;
    rdfs:comment 'Indicates the permitted direction of vehicle traffic flow through the lane.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twentyFourHourOperation rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Hour Operation' ;
    rdfs:comment 'Indicates whether the lane operates continuously on a 24/7 basis.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleCategory rdf:type rdf:Property ;
    rdfs:label 'Vehicle Category' ;
    rdfs:comment 'Type of vehicles permitted to use this gate lane based on cargo status or vehicle configuration.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weighbridgeEquipped rdf:type rdf:Property ;
    rdfs:label 'Weighbridge Equipped' ;
    rdfs:comment 'Indicates whether the lane has an integrated weighbridge for vehicle and cargo weight verification.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:xrayScannerEquipped rdf:type rdf:Property ;
    rdfs:label 'Xray Scanner Equipped' ;
    rdfs:comment 'Indicates whether the lane has X-ray scanning equipment for non-intrusive cargo inspection.' ;
    rdfs:domain ind:GateLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cfsAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Cfs Area Sqm' ;
    rdfs:comment 'Total area of the Container Freight Station facility measured in square meters.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cfsFacilityAvailable rdf:type rdf:Property ;
    rdfs:label 'Cfs Facility Available' ;
    rdfs:comment 'Indicates whether the terminal has a Container Freight Station (CFS) for Less than Container Load (LCL) cargo consolidation and deconsolidation.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsBondedArea rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Area' ;
    rdfs:comment 'Indicates whether the terminal operates a customs bonded area for duty-deferred cargo storage.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gateLanesInbound rdf:type rdf:Property ;
    rdfs:label 'Gate Lanes Inbound' ;
    rdfs:comment 'Number of dedicated inbound gate lanes for truck entry and container delivery to the terminal.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateLanesOutbound rdf:type rdf:Property ;
    rdfs:label 'Gate Lanes Outbound' ;
    rdfs:comment 'Number of dedicated outbound gate lanes for truck exit and container pickup from the terminal.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iso28000Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 28000 Certified' ;
    rdfs:comment 'Indicates whether the terminal holds ISO 28000 certification for supply chain security management.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfAscCranes rdf:type rdf:Property ;
    rdfs:label 'Number Of Asc Cranes' ;
    rdfs:comment 'Total count of Automated Stacking Cranes (ASC) deployed for automated container yard operations.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfMhcUnits rdf:type rdf:Property ;
    rdfs:label 'Number Of Mhc Units' ;
    rdfs:comment 'Total count of Mobile Harbour Cranes (MHC) available for multipurpose cargo handling operations.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfReachStackers rdf:type rdf:Property ;
    rdfs:label 'Number Of Reach Stackers' ;
    rdfs:comment 'Total count of reach stacker vehicles used for container handling and stacking in the yard.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfRtgCranes rdf:type rdf:Property ;
    rdfs:label 'Number Of Rtg Cranes' ;
    rdfs:comment 'Total count of Rubber-Tyred Gantry (RTG) cranes used for container stacking and yard operations.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfStsCranes rdf:type rdf:Property ;
    rdfs:label 'Number Of Sts Cranes' ;
    rdfs:comment 'Total count of Ship-to-Shore (STS) gantry cranes available for loading and unloading containers from vessels. Also known as Quay Cranes (QC).' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalStartDate rdf:type rdf:Property ;
    rdfs:label 'Operational Start Date' ;
    rdfs:comment 'Date when the terminal commenced commercial operations.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reeferPlugsAvailable rdf:type rdf:Property ;
    rdfs:label 'Reefer Plugs Available' ;
    rdfs:comment 'Total number of electrical connection points (plugs) available for refrigerated (reefer) containers requiring temperature control.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tosSystem rdf:type rdf:Property ;
    rdfs:label 'Tos System' ;
    rdfs:comment 'Primary Terminal Operating System deployed for yard management, gate operations, and equipment dispatch. NAVIS N4 and TOPS Expert are industry-leading platforms.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Department Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Calibration session is associated with a department (org_unit). Normalizing department_id (BIGINT) to proper FK. Using department_org_unit_id to distinguish from business_unit_org_unit_id.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:facilitatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Facilitator Employee Id' ;
    rdfs:comment 'Employee identifier of the HR professional or manager facilitating the calibration session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:modifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By Employee Id' ;
    rdfs:comment 'Employee identifier of the user who last modified this calibration session record.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionItems rdf:type rdf:Property ;
    rdfs:label 'Action Items' ;
    rdfs:comment 'List of follow-up action items and responsibilities assigned as a result of the calibration session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calibration Methodology' ;
    rdfs:comment 'The methodology or framework used to calibrate employee assessments during the session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consensusAchieved rdf:type rdf:Property ;
    rdfs:label 'Consensus Achieved' ;
    rdfs:comment 'Indicates whether consensus was achieved among participants on all employee assessments during the session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionsMade rdf:type rdf:Property ;
    rdfs:label 'Decisions Made' ;
    rdfs:comment 'Summary of key decisions made during the calibration session regarding employee ratings, promotions, or development plans.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Indicates whether any calibration decisions require escalation to senior leadership for final approval.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Hcm System Reference' ;
    rdfs:comment 'Reference identifier linking this calibration session to the corresponding record in Oracle HCM Cloud or SAP HR system.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingLocation rdf:type rdf:Property ;
    rdfs:label 'Meeting Location' ;
    rdfs:comment 'Physical location or virtual meeting platform where the calibration session is conducted (e.g., conference room name, Teams link).' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingMode rdf:type rdf:Property ;
    rdfs:label 'Meeting Mode' ;
    rdfs:comment 'Mode of conducting the calibration session, indicating whether participants meet physically, virtually, or in a hybrid format.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlcComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Mlc Compliance Verified' ;
    rdfs:comment 'Indicates whether MLC compliance requirements were verified during the calibration session for maritime workforce.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingScaleUsed rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Used' ;
    rdfs:comment 'Description of the rating scale applied during calibration (e.g., 1-5 scale, exceeds/meets/below expectations).' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Recording Storage Location' ;
    rdfs:comment 'Secure storage location or system path where the session recording is stored, if available.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'The review cycle period this calibration session is part of within the fiscal year.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionAgenda rdf:type rdf:Property ;
    rdfs:label 'Session Agenda' ;
    rdfs:comment 'Agenda outlining the topics, discussion points, and structure of the calibration session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionNotes rdf:type rdf:Property ;
    rdfs:label 'Session Notes' ;
    rdfs:comment 'Confidential notes and key discussion points captured during the calibration session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'Business identifier for the calibration session, formatted as CAL-YYYY-NNNNNN for external reference and tracking.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionObjectives rdf:type rdf:Property ;
    rdfs:label 'Session Objectives' ;
    rdfs:comment 'Detailed objectives and goals for the calibration session, outlining what the session aims to achieve.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionRecordingAvailable rdf:type rdf:Property ;
    rdfs:label 'Session Recording Available' ;
    rdfs:comment 'Indicates whether an audio or video recording of the calibration session is available for reference.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the calibration session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Type of calibration session being conducted, determining the focus and outcomes of the session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDistributionApplied rdf:type rdf:Property ;
    rdfs:label 'Target Distribution Applied' ;
    rdfs:comment 'Indicates whether a target performance distribution curve was applied during calibration to normalize ratings.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalEmployeesReviewed rdf:type rdf:Property ;
    rdfs:label 'Total Employees Reviewed' ;
    rdfs:comment 'Total number of employees whose performance or competencies are being calibrated in this session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalParticipants rdf:type rdf:Property ;
    rdfs:label 'Total Participants' ;
    rdfs:comment 'Total number of participants (managers, HR representatives) attending the calibration session.' ;
    rdfs:domain ind:CalibrationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualCargoTonnage rdf:type rdf:Property ;
    rdfs:label 'Annual Cargo Tonnage' ;
    rdfs:comment 'Total annual cargo throughput measured in metric tons, including containerized and bulk cargo.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualThroughputTeu rdf:type rdf:Property ;
    rdfs:label 'Annual Throughput Teu' ;
    rdfs:comment 'Annual container handling capacity or actual throughput measured in TEU (Twenty-foot Equivalent Units).' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bunkeringAvailable rdf:type rdf:Property ;
    rdfs:label 'Bunkering Available' ;
    rdfs:comment 'Indicates whether the port provides bunkering (fuel supply) services for vessels.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsFacility rdf:type rdf:Property ;
    rdfs:label 'Customs Facility' ;
    rdfs:comment 'Indicates whether the port has on-site customs clearance facilities for import/export processing.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the port was officially established or began operations.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isoCertified rdf:type rdf:Property ;
    rdfs:label 'Iso Certified' ;
    rdfs:comment 'Indicates whether the port holds ISO certification for quality management, environmental management, or other standards.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pilotRequired rdf:type rdf:Property ;
    rdfs:label 'Pilot Required' ;
    rdfs:comment 'Indicates whether maritime pilot services are mandatory for vessels entering or leaving the port.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portName rdf:type rdf:Property ;
    rdfs:label 'Port Name' ;
    rdfs:comment 'Official name of the port facility as recognized by maritime authorities and international shipping organizations.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portType rdf:type rdf:Property ;
    rdfs:label 'Port Type' ;
    rdfs:comment 'Classification of the port based on its primary operational function and geographic location.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:railConnected rdf:type rdf:Property ;
    rdfs:label 'Rail Connected' ;
    rdfs:comment 'Indicates whether the port has direct rail connectivity for intermodal cargo transfer.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reeferConnections rdf:type rdf:Property ;
    rdfs:label 'Reefer Connections' ;
    rdfs:comment 'Number of electrical connection points available for refrigerated containers requiring temperature control.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roadConnected rdf:type rdf:Property ;
    rdfs:label 'Road Connected' ;
    rdfs:comment 'Indicates whether the port has direct road access for truck-based cargo transfer.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipRepairFacilities rdf:type rdf:Property ;
    rdfs:label 'Ship Repair Facilities' ;
    rdfs:comment 'Indicates whether the port has ship repair and maintenance facilities including dry docks or floating docks.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageCapacitySqm rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Sqm' ;
    rdfs:comment 'Total covered and open storage area available for cargo, measured in square meters.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tugServicesAvailable rdf:type rdf:Property ;
    rdfs:label 'Tug Services Available' ;
    rdfs:comment 'Indicates whether tugboat services are available at the port for vessel maneuvering and berthing assistance.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Water Area Sqm' ;
    rdfs:comment 'Total water area within port jurisdiction measured in square meters, including berths, anchorage zones, and navigational channels.' ;
    rdfs:domain ind:Port ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

