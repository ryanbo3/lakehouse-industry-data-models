    rdfs:range xsd:integer .

ind:dataSharingAgreement rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement' ;
    rdfs:comment 'Indicates whether a data sharing agreement exists between the pharmaceutical company and the PBM for real-world evidence and utilization data.' ;
    rdfs:domain ind:Pbm ;
    rdf:type owl:DatatypeProperty ;
