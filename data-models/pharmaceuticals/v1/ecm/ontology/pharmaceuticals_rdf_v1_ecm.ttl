    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for biobank contact and coordination.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentSampleCount rdf:type rdf:Property ;
    rdfs:label 'Current Sample Count' ;
    rdfs:comment 'Total number of biological samples currently stored in the biobank.' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date when the biobank ceased operations or was decommissioned.' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the biobank was officially established and began operations.' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ethicsCommitteeApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Ethics Committee Approval Flag' ;
    rdfs:comment 'Indicates whether the biobank has received ethics committee or institutional review board approval.' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gcpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliant Flag' ;
    rdfs:comment 'Indicates whether the biobank operates in compliance with Good Clinical Practice guidelines.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether the biobank adheres to GDPR requirements for handling personal data and biological samples.' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:informedConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Required Flag' ;
    rdfs:comment 'Indicates whether informed consent is required from donors for sample collection and storage.' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySampleTypes rdf:type rdf:Property ;
    rdfs:label 'Primary Sample Types' ;
    rdfs:comment 'Comma-separated list of primary biological sample types stored (e.g., blood, tissue, DNA, RNA, serum, plasma).' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleAccessPolicy rdf:type rdf:Property ;
    rdfs:label 'Sample Access Policy' ;
    rdfs:comment 'Policy governing how external researchers and organizations can access biobank samples.' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current operational status of the biobank facility in its lifecycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Units' ;
    rdfs:comment 'Maximum number of biological sample storage units (vials, tubes, boxes) the biobank can accommodate.' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageTemperatureRange rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Range' ;
    rdfs:comment 'Temperature range maintained for biological sample preservation (e.g., -80C to -196C for cryogenic storage).' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreas rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Areas' ;
    rdfs:comment 'Comma-separated list of therapeutic areas or disease categories the biobank specializes in (e.g., oncology, immunology, rare diseases).' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentivePlanId rdf:type rdf:Property ;
    rdfs:label 'Incentive Plan Id' ;
    rdfs:comment 'Reference to the incentive compensation plan that governs this performance period. Links to the incentive plan master table.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:brandFocus rdf:type rdf:Property ;
    rdfs:label 'Brand Focus' ;
    rdfs:comment 'Specific brand or product line that is the focus of this performance period. Null if period applies to all brands.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDaysCount rdf:type rdf:Property ;
    rdfs:label 'Business Days Count' ;
    rdfs:comment 'The number of business days (excluding weekends and holidays) within the performance period, used for sales activity normalization.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year associated with this performance period (e.g., 2024).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'The regulatory compliance framework(s) applicable to commercial activities during this performance period (e.g., \'PhRMA Code\', \'Sunshine Act\', \'ABPI Code\'). Supports audit and transparency reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Crm System Version' ;
    rdfs:comment 'The version of the CRM system (Veeva CRM or Salesforce Health Cloud) in use during this performance period. Supports data lineage and system integration tracking.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpEngagementTarget rdf:type rdf:Property ;
    rdfs:label 'Hcp Engagement Target' ;
    rdfs:comment 'The target number of unique Healthcare Professional (HCP) engagements (calls, meetings, events) to be achieved during this performance period.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Current Period' ;
    rdfs:comment 'Boolean flag indicating whether this is the current active performance period (True) or not (False). Only one period should be current at any time.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kolInteractionTarget rdf:type rdf:Property ;
    rdfs:label 'Kol Interaction Target' ;
    rdfs:comment 'The target number of interactions with Key Opinion Leaders (KOLs) during this performance period. Supports strategic relationship management.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Business identifier code for the performance period, used for external reference and reporting (e.g., Q1-2024, FY2024-H1).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name or label for the performance period (e.g., \'Q1 2024 Sales Cycle\', \'FY2024 First Half\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLaunchFlag rdf:type rdf:Property ;
    rdfs:label 'Product Launch Flag' ;
    rdfs:comment 'Boolean flag indicating whether a new product launch occurred during this performance period (True) or not (False). Impacts sales strategy and resource allocation.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalMaterialVersion rdf:type rdf:Property ;
    rdfs:label 'Promotional Material Version' ;
    rdfs:comment 'The approved version or release of promotional materials (Veeva PromoMats) authorized for use during this performance period. Ensures compliance with promotional regulations.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Quota Allocation Method' ;
    rdfs:comment 'The methodology used to allocate sales quotas during this performance period: territory-based, rep-based, team-based, or hybrid.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRegion rdf:type rdf:Property ;
    rdfs:label 'Reporting Region' ;
    rdfs:comment 'Geographic region or market for which this performance period applies (e.g., \'North America\', \'EMEA\', \'APAC\', \'Global\'). Supports regional performance tracking.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Target Amount' ;
    rdfs:comment 'The aggregate sales revenue target set for this performance period, in USD. Used for performance evaluation and incentive compensation.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleDistributionQuota rdf:type rdf:Property ;
    rdfs:label 'Sample Distribution Quota' ;
    rdfs:comment 'The maximum number of product samples authorized for distribution during this performance period. Supports compliance with sample distribution regulations.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speakerProgramBudget rdf:type rdf:Property ;
    rdfs:label 'Speaker Program Budget' ;
    rdfs:comment 'The allocated budget for speaker programs and Key Opinion Leader (KOL) engagements during this performance period, in USD.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryRealignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Territory Realignment Flag' ;
    rdfs:comment 'Boolean flag indicating whether sales territory realignment occurred at the start of this performance period (True) or not (False). Impacts quota and performance tracking.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alignmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Alignment Period' ;
    rdfs:comment 'The planning period for which this district configuration is aligned (e.g., 2024-Q1, 2024-H1, 2024-FY).' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualSalesTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Sales Target' ;
    rdfs:comment 'Annual revenue target assigned to the district in USD.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'Business identifier code for the district used in external systems and reporting.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtType rdf:type rdf:Property ;
    rdfs:label 'District Type' ;
    rdfs:comment 'Classification of the district based on therapeutic area or customer segment focus.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the geographic area covered by the district, including states, counties, or postal codes.' ;
    rdfs:domain ind:District ;
