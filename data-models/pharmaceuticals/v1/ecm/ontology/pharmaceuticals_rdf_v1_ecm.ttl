    rdfs:range xsd:string .

ind:technicalOwner rdf:type rdf:Property ;
    rdfs:label 'Technical Owner' ;
    rdfs:comment 'Name of the technical user or team responsible for implementing and supporting this mapping rule.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationResult rdf:type rdf:Property ;
    rdfs:label 'Validation Result' ;
    rdfs:comment 'Result of the most recent validation test indicating whether the mapping rule passed quality checks.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquirerLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Acquirer Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: M&A events have an acquiring legal entity. The existing \'acquirer_organization_id\' BIGINT attribute should be renamed to \'acquirer_legal_entity_id\' and made a FK to legal_entity.legal_entity_id for re' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:announcementDate rdf:type rdf:Property ;
    rdfs:label 'Announcement Date' ;
    rdfs:comment 'Date when the merger or acquisition was publicly announced to stakeholders, investors, and regulatory bodies.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:antitrustClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Antitrust Clearance Status' ;
    rdfs:comment 'Status of antitrust regulatory review and clearance from competition authorities (FTC, DOJ, EC) to ensure the transaction does not create monopolistic conditions.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Date' ;
    rdfs:comment 'Date when the non-disclosure agreement (NDA) or confidentiality agreement was executed between parties to protect sensitive transaction information.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealAdvisorFirm rdf:type rdf:Property ;
    rdfs:label 'Deal Advisor Firm' ;
    rdfs:comment 'Name of the primary investment banking or advisory firm providing merger and acquisition advisory services, valuation, and transaction structuring.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligenceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completion Date' ;
    rdfs:comment 'Date when the comprehensive due diligence review (financial, legal, operational, regulatory, intellectual property) was completed by the acquiring entity.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeTransferCount rdf:type rdf:Property ;
    rdfs:label 'Employee Transfer Count' ;
    rdfs:comment 'Number of employees transferring from the target organization to the acquiring organization as part of the transaction.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedSynergyAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Synergy Amount' ;
    rdfs:comment 'Projected annual cost savings and revenue synergies expected to be realized from the merger or acquisition, typically measured over a 3-5 year period.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Current status of post-merger integration activities, tracking the operational, systems, and organizational consolidation progress.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intellectualPropertyIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Intellectual Property Included Flag' ;
    rdfs:comment 'Indicates whether the transaction includes transfer of intellectual property assets such as patents, trademarks, trade secrets, or proprietary research and development.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalCounselFirm rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Firm' ;
    rdfs:comment 'Name of the primary law firm providing legal counsel and representation for the merger or acquisition transaction.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingFacilitiesIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Facilities Included Flag' ;
    rdfs:comment 'Indicates whether the transaction includes transfer of pharmaceutical manufacturing plants, production facilities, or Good Manufacturing Practice (GMP) certified sites.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productPortfolioCount rdf:type rdf:Property ;
    rdfs:label 'Product Portfolio Count' ;
    rdfs:comment 'Number of pharmaceutical products, drug formulations, or medical devices included in the transaction scope.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required Flag' ;
    rdfs:comment 'Indicates whether the merger or acquisition requires regulatory approval from antitrust authorities, securities regulators, or industry-specific bodies (FDA, EMA).' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:researchPipelineIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Research Pipeline Included Flag' ;
    rdfs:comment 'Indicates whether the transaction includes transfer of drug development pipeline, clinical trial programs, or investigational new drug (IND) applications.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shareholderApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Shareholder Approval Date' ;
    rdfs:comment 'Date when shareholders formally approved the merger or acquisition transaction through voting at a special or annual meeting.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shareholderApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Shareholder Approval Required Flag' ;
    rdfs:comment 'Indicates whether the transaction requires approval from shareholders of the acquiring or target organization through a formal vote.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionStructure rdf:type rdf:Property ;
    rdfs:label 'Transaction Structure' ;
    rdfs:comment 'Legal and financial structure of the transaction, defining how ownership and assets are transferred between parties.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionValueAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Value Amount' ;
    rdfs:comment 'Total monetary value of the merger or acquisition transaction, representing the purchase price or combined entity valuation.' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transaction value amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:MergerAcquisitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualReviewVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Review Volume' ;
    rdfs:comment 'Estimated or actual number of submissions reviewed by the committee annually, used for capacity planning and resource allocation.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Amount' ;
    rdfs:comment 'Annual budget allocated to support the committee\'s operations, including meeting costs, member compensation, administrative support, and technology infrastructure.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chairEmail rdf:type rdf:Property ;
    rdfs:label 'Chair Email' ;
    rdfs:comment 'Primary email address of the committee chairperson for official committee correspondence and communications.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chairName rdf:type rdf:Property ;
    rdfs:label 'Chair Name' ;
    rdfs:comment 'Full name of the individual serving as the chairperson of the review committee, responsible for leading meetings and overseeing committee operations.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterDescription rdf:type rdf:Property ;
    rdfs:label 'Charter Description' ;
    rdfs:comment 'Detailed description of the committee\'s charter, including its purpose, scope, responsibilities, and authority within the medical affairs organization.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeCode rdf:type rdf:Property ;
    rdfs:label 'Committee Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the review committee for internal reference and system integration.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeName rdf:type rdf:Property ;
    rdfs:label 'Committee Name' ;
    rdfs:comment 'Official name of the review committee as registered within the organization.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeType rdf:type rdf:Property ;
    rdfs:label 'Committee Type' ;
    rdfs:comment 'Classification of the review committee based on its primary function. Ethics committees review ethical considerations, scientific committees evaluate scientific merit, publication committees oversee publication planning, medical information committees manage medical inquiries, HEOR committees assess health economics and outcomes research, and safety committees monitor safety data.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityAgreementRequired rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Required' ;
    rdfs:comment 'Indicates whether committee members are required to sign confidentiality or non-disclosure agreements as a condition of membership.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictOfInterestPolicy rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Policy' ;
    rdfs:comment 'Description of the committee\'s conflict of interest policy, including disclosure requirements and recusal procedures for members with potential conflicts.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsBoardRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Ethics Board Registration Number' ;
    rdfs:comment 'Official registration or identification number assigned to the committee by relevant regulatory or ethics oversight bodies, if applicable.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedReviewAvailable rdf:type rdf:Property ;
    rdfs:label 'Expedited Review Available' ;
    rdfs:comment 'Indicates whether the committee offers an expedited review process for urgent or time-sensitive submissions.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expeditedReviewTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Expedited Review Turnaround Days' ;
    rdfs:comment 'Target number of business days for the committee to complete an expedited review when such process is available.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalMemberCount rdf:type rdf:Property ;
    rdfs:label 'External Member Count' ;
    rdfs:comment 'Number of committee members who are external to the organization, such as key opinion leaders (KOLs), independent experts, or external advisors.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Date when the review committee was officially formed and chartered within the organization.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Geographic Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the primary geographic jurisdiction or region where the committee operates and has authority.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalMemberCount rdf:type rdf:Property ;
    rdfs:label 'Internal Member Count' ;
    rdfs:comment 'Number of committee members who are internal employees of the organization.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCharterReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Charter Review Date' ;
    rdfs:comment 'Date when the committee\'s charter was last reviewed and reaffirmed or updated by the organization\'s governance body.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingFrequency rdf:type rdf:Property ;
    rdfs:label 'Meeting Frequency' ;
    rdfs:comment 'Standard frequency at which the review committee convenes for scheduled meetings.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingPlatform rdf:type rdf:Property ;
    rdfs:label 'Meeting Platform' ;
    rdfs:comment 'Format in which committee meetings are conducted: in-person for physical meetings, virtual for remote meetings, or hybrid for a combination of both.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCharterReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Charter Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of the committee\'s charter to ensure continued alignment with organizational objectives and regulatory requirements.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quorumRequirement rdf:type rdf:Property ;
    rdfs:label 'Quorum Requirement' ;
    rdfs:comment 'Minimum number of committee members required to be present for the committee to conduct official business and make binding decisions.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryOversightRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Oversight Required' ;
    rdfs:comment 'Indicates whether the committee\'s decisions and activities are subject to regulatory oversight or reporting requirements from health authorities.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewScope rdf:type rdf:Property ;
    rdfs:label 'Review Scope' ;
    rdfs:comment 'Detailed description of the types of materials, studies, or activities that fall within the committee\'s review authority, such as investigator-initiated trials (IIT), investigator-sponsored studies (ISS), publications, medical information responses, or real-world evidence (RWE) studies.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secretaryEmail rdf:type rdf:Property ;
    rdfs:label 'Secretary Email' ;
    rdfs:comment 'Primary email address of the committee secretary for administrative communications and meeting coordination.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secretaryName rdf:type rdf:Property ;
    rdfs:label 'Secretary Name' ;
    rdfs:comment 'Full name of the individual serving as the secretary of the review committee, responsible for maintaining meeting minutes and administrative support.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardReviewTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Standard Review Turnaround Days' ;
    rdfs:comment 'Target number of business days for the committee to complete a standard review and provide a decision or recommendation.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMemberCount rdf:type rdf:Property ;
    rdfs:label 'Total Member Count' ;
    rdfs:comment 'Current total number of active members serving on the review committee.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veevaMedcommsIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Veeva Medcomms Integration Enabled' ;
    rdfs:comment 'Indicates whether the committee is integrated with Veeva MedComms system for managing medical communications, publication planning, and scientific content.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:votingThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Voting Threshold Percentage' ;
    rdfs:comment 'Minimum percentage of affirmative votes required for a motion or decision to pass within the committee, expressed as a percentage (e.g., 66.67 for two-thirds majority).' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Id' ;
    rdfs:comment 'Identifier of the newer eConsent document version that supersedes this document. Nullable if this is the current active version.' ;
    rdfs:domain ind:EconsentDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EconsentDocument .

ind:documentContentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Content Url' ;
    rdfs:comment 'URL or storage path to the electronic file containing the full text and media of the eConsent document.' ;
    rdfs:domain ind:EconsentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHash rdf:type rdf:Property ;
    rdfs:label 'Document Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the eConsent document content to ensure integrity and detect tampering.' ;
    rdfs:domain ind:EconsentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentName rdf:type rdf:Property ;
    rdfs:label 'Document Name' ;
    rdfs:comment 'Human-readable name or title of the electronic consent document.' ;
    rdfs:domain ind:EconsentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAgeYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Years' ;
    rdfs:comment 'Minimum age in years for a patient to provide consent using this document. Used to determine if assent or parental consent is required.' ;
    rdfs:domain ind:EconsentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresSignature rdf:type rdf:Property ;
    rdfs:label 'Requires Signature' ;
    rdfs:comment 'Indicates whether this eConsent document requires an electronic signature from the patient or legally authorized representative.' ;
    rdfs:domain ind:EconsentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresWitness rdf:type rdf:Property ;
    rdfs:label 'Requires Witness' ;
    rdfs:comment 'Indicates whether this eConsent document requires a witness signature in addition to the patient signature.' ;
    rdfs:domain ind:EconsentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Name' ;
    rdfs:comment 'Name of the pharmaceutical company or organization sponsoring the clinical trial for which this eConsent document is used.' ;
    rdfs:domain ind:EconsentDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acceptance Required Flag' ;
    rdfs:comment 'Indicates whether formal acceptance or quality approval is required before the service entry can be posted and invoiced.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entrySheetStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Sheet Status' ;
    rdfs:comment 'Current lifecycle status of the service entry sheet in the approval and posting workflow.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External reference number provided by the vendor or service provider, such as their delivery note, timesheet reference, or service report number.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Status' ;
    rdfs:comment 'Status of the invoice verification process for this service entry, indicating whether the vendor invoice has been matched and approved for payment.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedDate rdf:type rdf:Property ;
    rdfs:label 'Posted Date' ;
    rdfs:comment 'Date when the service entry sheet was posted to financial accounting, triggering accounts payable liability recognition.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderItemNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Item Number' ;
    rdfs:comment 'Line item number within the purchase order for which this service entry is recorded.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Outcome of the quality inspection or audit performed on the service deliverables, critical for GMP compliance and supplier performance tracking.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of service units rendered, measured according to the unit of measure specified in the purchase order (e.g., hours, days, tests, batches).' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed textual description of the services performed, including scope, deliverables, and any deviations from the original purchase order specification.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'Date when the service performance period ended.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceEntrySheetNumber rdf:type rdf:Property ;
    rdfs:label 'Service Entry Sheet Number' ;
    rdfs:comment 'Business identifier for the service entry sheet, externally visible and used for tracking and reference in procurement and accounts payable processes.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePerformerName rdf:type rdf:Property ;
    rdfs:label 'Service Performer Name' ;
    rdfs:comment 'Name of the individual or organization unit that performed the service, may differ from the contracting vendor in subcontracting scenarios.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Date when the service performance period began.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archiveDate rdf:type rdf:Property ;
    rdfs:label 'Archive Date' ;
    rdfs:comment 'Date when the document was moved to archive status. Nullable if document is still active.' ;
    rdfs:domain ind:QmsDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Full name of the individual who authored or created the document.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'Comma-separated list of departments, roles, or individuals who should receive or have access to this document.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Required Flag' ;
    rdfs:comment 'Indicates whether electronic signatures are required for approval and execution of this document per 21 CFR Part 11 (True) or not (False).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the document file in kilobytes.' ;
    rdfs:domain ind:QmsDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the individual responsible for maintaining and updating the document.' ;
    rdfs:domain ind:QmsDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document.' ;
    rdfs:domain ind:QmsDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedChangeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Related Change Control Number' ;
    rdfs:comment 'Change control identifier associated with the creation or revision of this document. Nullable if no formal change control was required.' ;
    rdfs:domain ind:QmsDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the document must be retained per regulatory and organizational requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision count indicating the number of times the document has been revised.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationId rdf:type rdf:Property ;
    rdfs:label 'Deviation Id' ;
    rdfs:comment 'Reference to a quality deviation record if this sample is associated with a deviation investigation (e.g., Out of Specification result, sampling procedure deviation). Links sample to Corrective and Preventive Action (CAPA) system.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityDeviation .

ind:compositeSampleFlag rdf:type rdf:Property ;
    rdfs:label 'Composite Sample Flag' ;
    rdfs:comment 'Indicates whether this sample is a composite (pooled from multiple sampling points or containers) or a discrete sample from a single source. Composite sampling is used for homogeneity assessment.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Date and time when the sample was formally registered in the Laboratory Information Management System (LIMS) or Quality Management System (QMS) and assigned a sample number.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retainSampleFlag rdf:type rdf:Property ;
    rdfs:label 'Retain Sample Flag' ;
    rdfs:comment 'Indicates whether this sample must be retained for the regulatory retention period. Retain samples are stored for future investigation of complaints, adverse events, or regulatory inquiries.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retainUntilDate rdf:type rdf:Property ;
    rdfs:label 'Retain Until Date' ;
    rdfs:comment 'Date until which the retain sample must be stored. Typically calculated as product expiration date plus one year, or as defined by regulatory requirements.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity Unit' ;
    rdfs:comment 'Unit of measure for the sample quantity (grams, kilograms, milligrams, milliliters, liters, units, tablets, vials). Must align with product specification units.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingLocation rdf:type rdf:Property ;
    rdfs:label 'Sampling Location' ;
    rdfs:comment 'Physical location or equipment identifier where the sample was collected (e.g., reactor vessel, blending tank, packaging line, warehouse zone). Critical for environmental monitoring and contamination investigation.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percent' ;
    rdfs:comment 'Percent recovery demonstrating the accuracy of the method, typically from validation studies.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analyte rdf:type rdf:Property ;
    rdfs:label 'Analyte' ;
    rdfs:comment 'The specific substance, compound, or parameter being measured or detected by this analytical method.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compendialFlag rdf:type rdf:Property ;
    rdfs:label 'Compendial Flag' ;
    rdfs:comment 'Indicates whether this is a compendial method from an official pharmacopeia (USP, EP, JP) or a proprietary in-house method.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Required' ;
    rdfs:comment 'List or description of laboratory equipment and instruments required to perform this analytical method.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitOfDetection rdf:type rdf:Property ;
    rdfs:label 'Limit Of Detection' ;
    rdfs:comment 'Lowest concentration of analyte that can be detected but not necessarily quantified, expressed in the method\'s unit of measure.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitOfQuantitation rdf:type rdf:Property ;
    rdfs:label 'Limit Of Quantitation' ;
    rdfs:comment 'Lowest concentration of analyte that can be quantitatively determined with suitable precision and accuracy, expressed in the method\'s unit of measure.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matrix rdf:type rdf:Property ;
    rdfs:label 'Matrix' ;
    rdfs:comment 'The type of sample or material to which this method is applied (e.g., tablet, capsule, injectable solution, raw material, bulk drug substance).' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodName rdf:type rdf:Property ;
    rdfs:label 'Method Name' ;
    rdfs:comment 'Descriptive name of the analytical method that clearly identifies its purpose and technique.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodNumber rdf:type rdf:Property ;
    rdfs:label 'Method Number' ;
    rdfs:comment 'Unique business identifier for the analytical method, typically following organizational naming conventions (e.g., HPLC-001234, GC-MS-5678).' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodStatus rdf:type rdf:Property ;
    rdfs:label 'Method Status' ;
    rdfs:comment 'Current lifecycle status of the analytical method indicating its readiness for use in quality control testing.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionRsdPercent rdf:type rdf:Property ;
    rdfs:label 'Precision Rsd Percent' ;
    rdfs:comment 'Relative standard deviation percentage demonstrating the precision of the method, typically from validation studies.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentList rdf:type rdf:Property ;
    rdfs:label 'Reagent List' ;
    rdfs:comment 'List of reagents, standards, and consumables required to perform this analytical method.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:robustnessVerified rdf:type rdf:Property ;
    rdfs:label 'Robustness Verified' ;
    rdfs:comment 'Indicates whether the method robustness has been evaluated and verified during validation studies.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Run Time Minutes' ;
    rdfs:comment 'Typical duration in minutes required to complete one analytical run or sample analysis.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplePreparationTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Sample Preparation Time Minutes' ;
    rdfs:comment 'Typical time in minutes required for sample preparation before analysis.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sopNumber rdf:type rdf:Property ;
    rdfs:label 'Sop Number' ;
    rdfs:comment 'Reference number of the Standard Operating Procedure document that provides detailed instructions for executing this method.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationLimitLower rdf:type rdf:Property ;
    rdfs:label 'Specification Limit Lower' ;
    rdfs:comment 'Lower acceptance limit for the test result as defined in the product specification or pharmacopeia monograph.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Specification Limit Upper' ;
    rdfs:comment 'Upper acceptance limit for the test result as defined in the product specification or pharmacopeia monograph.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stabilityIndicating rdf:type rdf:Property ;
    rdfs:label 'Stability Indicating' ;
    rdfs:comment 'Indicates whether the method is stability-indicating, capable of detecting degradation products and changes over time.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityEventId rdf:type rdf:Property ;
    rdfs:label 'Quality Event Id' ;
    rdfs:comment 'Primary key for quality_event' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To Employee Id' ;
    rdfs:comment 'Reference to the employee or quality professional currently assigned to investigate and resolve the quality event.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qaApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qa Approved By Employee Id' ;
    rdfs:comment 'Reference to the Quality Assurance professional who approved the quality event closure and corrective actions.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qualityAgreementId rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Id' ;
    rdfs:comment 'Reference to the quality agreement governing quality responsibilities if the event involves contract manufacturing or third-party suppliers.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityAgreement .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of corrective actions taken to address the immediate quality event and prevent recurrence.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerComplaintRelated rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Related' ;
    rdfs:comment 'Indicates whether this quality event is associated with or triggered by a customer complaint.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpImpact rdf:type rdf:Property ;
    rdfs:label 'Gmp Impact' ;
    rdfs:comment 'Assessment of the quality events impact on Good Manufacturing Practice compliance and pharmaceutical quality standards.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurredDate rdf:type rdf:Property ;
    rdfs:label 'Occurred Date' ;
    rdfs:comment 'Actual or estimated date when the quality event occurred. May differ from detection date if the event was discovered retrospectively.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientSafetyRisk rdf:type rdf:Property ;
    rdfs:label 'Patient Safety Risk' ;
    rdfs:comment 'Assessment of potential risk to patient safety resulting from this quality event, used to prioritize investigation and response activities.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of preventive actions implemented to address systemic issues and prevent similar quality events in the future.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Qa Approval Required' ;
    rdfs:comment 'Indicates whether Quality Assurance management approval is required before closing this quality event.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qaApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qa Approval Timestamp' ;
    rdfs:comment 'Date and time when Quality Assurance approved the quality event closure.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractAccountId rdf:type rdf:Property ;
    rdfs:label 'Contract Contract Account Id' ;
    rdfs:comment 'Reference to the pricing contract or agreement under which this order is placed.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAccount .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'The commercial channel or route to market through which the order was placed.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'The system or channel through which the sales order was originally captured.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'Authorization number for product returns associated with this order, if applicable.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDistributionFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Distribution Flag' ;
    rdfs:comment 'Indicates whether this order includes or is exclusively for pharmaceutical sample distribution to healthcare professionals.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'The logistics method used to ship the order, particularly important for temperature-sensitive pharmaceutical products.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text field capturing any special handling, storage, or delivery instructions for the order, particularly for controlled substances or temperature-sensitive products.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveLocation rdf:type rdf:Property ;
    rdfs:label 'Archive Location' ;
    rdfs:comment 'Physical or electronic location where obsolete or superseded versions of this SOP are archived for retention.' ;
    rdfs:domain ind:Sop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorDepartment rdf:type rdf:Property ;
    rdfs:label 'Author Department' ;
    rdfs:comment 'Department or organizational unit of the SOP author.' ;
    rdfs:domain ind:Sop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentOwner rdf:type rdf:Property ;
    rdfs:label 'Document Owner' ;
    rdfs:comment 'Name or role of the individual responsible for maintaining and ensuring the accuracy of this SOP.' ;
    rdfs:domain ind:Sop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purposeDescription rdf:type rdf:Property ;
    rdfs:label 'Purpose Description' ;
    rdfs:comment 'Statement of the business purpose and objectives that this SOP is designed to achieve.' ;
    rdfs:domain ind:Sop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact' ;
    rdfs:comment 'Assessment of the SOPs impact on regulatory compliance and inspection readiness (High, Medium, or Low).' ;
    rdfs:domain ind:Sop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedSopNumbers rdf:type rdf:Property ;
    rdfs:label 'Related Sop Numbers' ;
    rdfs:comment 'Comma-separated list of related or cross-referenced SOP numbers that are associated with this procedure.' ;
    rdfs:domain ind:Sop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesSopNumber rdf:type rdf:Property ;
    rdfs:label 'Supersedes Sop Number' ;
    rdfs:comment 'SOP number of the previous version that this current version replaces or supersedes.' ;
    rdfs:domain ind:Sop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Required Flag' ;
    rdfs:comment 'Indicates whether this SOP requires translation into additional languages for multi-site or global operations.' ;
    rdfs:domain ind:Sop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentJobFamilyId rdf:type rdf:Property ;
    rdfs:label 'Parent Job Family Id' ;
    rdfs:comment 'Reference to a parent job family if this job family is part of a hierarchical job family structure.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobFamily .

ind:careerLevelRangeMax rdf:type rdf:Property ;
    rdfs:label 'Career Level Range Max' ;
    rdfs:comment 'Maximum career level or grade associated with roles in this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:careerLevelRangeMin rdf:type rdf:Property ;
    rdfs:label 'Career Level Range Min' ;
    rdfs:comment 'Minimum career level or grade associated with roles in this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'High-level category grouping job families by functional area within the pharmaceutical organization.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the job family for external reference and system integration.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationGradeMax rdf:type rdf:Property ;
    rdfs:label 'Compensation Grade Max' ;
    rdfs:comment 'Maximum compensation grade or band applicable to roles within this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationGradeMin rdf:type rdf:Property ;
    rdfs:label 'Compensation Grade Min' ;
    rdfs:comment 'Minimum compensation grade or band applicable to roles within this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalRoleIndicator rdf:type rdf:Property ;
    rdfs:label 'Critical Role Indicator' ;
    rdfs:comment 'Indicates whether this job family contains roles that are business-critical or quality-critical requiring enhanced succession planning and talent management.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occupationalGroup rdf:type rdf:Property ;
    rdfs:label 'Occupational Group' ;
    rdfs:comment 'Standard occupational classification group aligned with national or international labor statistics frameworks.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Department or functional area that owns and maintains the definition and standards for this job family.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryOversightLevel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Oversight Level' ;
    rdfs:comment 'Level of regulatory oversight and compliance requirements applicable to roles in this job family for FDA and EMA audit readiness.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligibility rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligibility' ;
    rdfs:comment 'Standard remote work or flexible work arrangement eligibility for roles within this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresGxpTraining rdf:type rdf:Property ;
    rdfs:label 'Requires Gxp Training' ;
    rdfs:comment 'Indicates whether roles in this job family require Good Clinical Practice (GCP), Good Manufacturing Practice (GMP), or Good Laboratory Practice (GLP) training for regulatory compliance.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresProfessionalLicense rdf:type rdf:Property ;
    rdfs:label 'Requires Professional License' ;
    rdfs:comment 'Indicates whether roles in this job family require professional licensure such as pharmacist license, medical license, or engineering license.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresQualityCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Quality Certification' ;
    rdfs:comment 'Indicates whether roles in this job family require formal quality management system certifications such as Six Sigma, Lean, or ASQ certifications.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successionPlanningPriority rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Priority' ;
    rdfs:comment 'Priority level for succession planning activities for roles within this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentPoolStrategy rdf:type rdf:Property ;
    rdfs:label 'Talent Pool Strategy' ;
    rdfs:comment 'Strategic approach for building and maintaining talent pipeline for this job family including internal development and external sourcing.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Typical Education Level' ;
    rdfs:comment 'Typical minimum education level required for roles within this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalExperienceYearsMax rdf:type rdf:Property ;
    rdfs:label 'Typical Experience Years Max' ;
    rdfs:comment 'Maximum number of years of relevant professional experience typically associated with roles in this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalExperienceYearsMin rdf:type rdf:Property ;
    rdfs:label 'Typical Experience Years Min' ;
    rdfs:comment 'Minimum number of years of relevant professional experience typically required for roles in this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionEligibility rdf:type rdf:Property ;
    rdfs:label 'Union Eligibility' ;
    rdfs:comment 'Indicates whether roles in this job family are eligible for union membership or collective bargaining representation.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforcePlanningCategory rdf:type rdf:Property ;
    rdfs:label 'Workforce Planning Category' ;
    rdfs:comment 'Category used for workforce planning and headcount forecasting indicating the strategic importance and employment model for this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predecessorFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Framework Id' ;
    rdfs:comment 'Reference to the previous version of this competency framework, if this is a revision. Null for initial versions.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetencyFramework .

ind:applicableRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Regions' ;
    rdfs:comment 'Geographic regions where this framework applies (e.g., North America, Europe, Asia-Pacific). Null indicates global applicability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Indicates whether formal certification is required upon successful completion of all competencies in this framework.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyCount rdf:type rdf:Property ;
    rdfs:label 'Competency Count' ;
    rdfs:comment 'Total number of individual competencies defined within this framework.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameworkCode rdf:type rdf:Property ;
    rdfs:label 'Framework Code' ;
    rdfs:comment 'Unique business identifier code for the competency framework used in regulatory documentation and training systems.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkName rdf:type rdf:Property ;
    rdfs:label 'Framework Name' ;
    rdfs:comment 'Official name of the competency framework (e.g., GMP Manufacturing Competencies, Clinical Research Associate Framework).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkType rdf:type rdf:Property ;
    rdfs:label 'Framework Type' ;
    rdfs:comment 'Classification of the competency framework by primary focus area.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkVersion rdf:type rdf:Property ;
    rdfs:label 'Framework Version' ;
    rdfs:comment 'Version number of the competency framework following semantic versioning (e.g., 1.0, 2.1, 3.0.1).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedTrainingPrograms rdf:type rdf:Property ;
    rdfs:label 'Linked Training Programs' ;
    rdfs:comment 'Comma-separated list of training program codes that support competency development within this framework.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevels rdf:type rdf:Property ;
    rdfs:label 'Proficiency Levels' ;
    rdfs:comment 'Number of proficiency levels defined in this framework (e.g., 3 for Basic/Intermediate/Advanced, 5 for detailed progression scales).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Period Months' ;
    rdfs:comment 'Number of months after which recertification is required for competencies in this framework. Null if recertification is not required.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when this payroll period was officially closed, preventing further changes and locking the period for compliance.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cutoffDate rdf:type rdf:Property ;
    rdfs:label 'Cutoff Date' ;
    rdfs:comment 'The deadline date by which time entries, adjustments, and payroll inputs must be submitted for this period.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'The fiscal month (1-12) to which this payroll period belongs, used for monthly financial reporting.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Indicates whether this is a special adjustment period used for corrections, retroactive payments, or year-end adjustments.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Year End Period' ;
    rdfs:comment 'Indicates whether this is the final payroll period of the fiscal or calendar year, requiring special year-end processing.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Code identifying the legal entity or subsidiary for which this payroll period is defined, supporting multi-entity payroll processing.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollGroup rdf:type rdf:Property ;
    rdfs:label 'Payroll Group' ;
    rdfs:comment 'The payroll group or category this period applies to (e.g., \'Hourly\', \'Salaried\', \'Executive\', \'Contract\'), enabling different pay schedules for different employee populations.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential number of this payroll period within the fiscal or calendar year (e.g., 1-26 for bi-weekly, 1-12 for monthly).' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'The date and time when payroll processing was completed for this period, used for audit trail and compliance verification.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'The tax year to which this payroll period belongs, used for tax withholding calculations and year-end tax reporting (W-2, 1099).' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDays rdf:type rdf:Property ;
    rdfs:label 'Total Days' ;
    rdfs:comment 'The total number of calendar days in this payroll period, calculated from start_date to end_date inclusive.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingDays rdf:type rdf:Property ;
    rdfs:label 'Working Days' ;
    rdfs:comment 'The number of standard working days within this payroll period, excluding weekends and holidays.' ;
    rdfs:domain ind:PayrollPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessControlLevel rdf:type rdf:Property ;
    rdfs:label 'Access Control Level' ;
    rdfs:comment 'Security classification level that determines who can view, use, or modify this document template.' ;
    rdfs:domain ind:DocumentTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether documents generated from this template require formal approval workflow before finalization.' ;
    rdfs:domain ind:DocumentTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required Flag' ;
    rdfs:comment 'Indicates whether documents generated from this template must maintain a complete audit trail of all changes and access events.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessProcess rdf:type rdf:Property ;
    rdfs:label 'Business Process' ;
    rdfs:comment 'The specific business process or workflow that this document template supports within the pharmaceutical operations.' ;
    rdfs:domain ind:DocumentTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'The specific Good Practice domain that this template supports within the pharmaceutical compliance ecosystem.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityLevel rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Level' ;
    rdfs:comment 'Classification of the data integrity controls required for documents generated from this template based on ALCOA+ principles.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesTemplateId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Template Id' ;
    rdfs:comment 'Reference to the previous document template version that this current version replaces or supersedes.' ;
    rdfs:domain ind:DocumentTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique business identifier code for the document template used across the organization for reference and lookup purposes.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the document template that clearly identifies its purpose and content type.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the document template by its functional category within the pharmaceutical compliance framework.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required Flag' ;
    rdfs:comment 'Indicates whether recipients must explicitly acknowledge receipt and review of notifications generated from this template.' ;
    rdfs:domain ind:NotificationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedByUserId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Id' ;
    rdfs:comment 'Identifier of the user who approved this notification template version for production use.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyContent rdf:type rdf:Property ;
    rdfs:label 'Body Content' ;
    rdfs:comment 'Main message body content of the notification template. May include HTML markup and merge field placeholders for dynamic content insertion.' ;
    rdfs:domain ind:NotificationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'Format specification for the body content indicating markup language or text encoding used.' ;
    rdfs:domain ind:NotificationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUserId rdf:type rdf:Property ;
    rdfs:label 'Created By User Id' ;
    rdfs:comment 'Identifier of the user who originally created this notification template record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimeframeHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Timeframe Hours' ;
    rdfs:comment 'Number of hours after notification delivery before escalation is triggered, if escalation is required.' ;
    rdfs:domain ind:NotificationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Id' ;
    rdfs:comment 'Identifier of the user who most recently modified this notification template record.' ;
    rdfs:domain ind:NotificationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Date and time when this notification template was most recently used to generate a notification, recorded in ISO 8601 format with timezone.' ;
    rdfs:domain ind:NotificationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ownerUserId rdf:type rdf:Property ;
    rdfs:label 'Owner User Id' ;
    rdfs:comment 'Identifier of the user or role responsible for maintaining and updating this notification template.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientRole rdf:type rdf:Property ;
    rdfs:label 'Recipient Role' ;
    rdfs:comment 'Target role or function that should receive notifications generated from this template (e.g., Quality Assurance Manager, Compliance Officer, Site Head).' ;
    rdfs:domain ind:NotificationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days that notifications generated from this template must be retained to meet regulatory and compliance record-keeping requirements.' ;
    rdfs:domain ind:NotificationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'Default subject line or title for the notification when delivered. May contain merge field placeholders.' ;
    rdfs:domain ind:NotificationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLevelCount rdf:type rdf:Property ;
    rdfs:label 'Approval Level Count' ;
    rdfs:comment 'Number of approval levels required for workflow instances created from this template.' ;
    rdfs:domain ind:WorkflowTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceDomain rdf:type rdf:Property ;
    rdfs:label 'Compliance Domain' ;
    rdfs:comment 'The specific compliance domain or area that this workflow template addresses within the enterprise compliance program.' ;
    rdfs:domain ind:WorkflowTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Data Retention Years' ;
    rdfs:comment 'Required retention period in years for workflow instances and associated data created from this template to meet regulatory requirements.' ;
    rdfs:domain ind:WorkflowTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationEnabled rdf:type rdf:Property ;
    rdfs:label 'Escalation Enabled' ;
    rdfs:comment 'Indicates whether automatic escalation is enabled for overdue workflow instances created from this template.' ;
    rdfs:domain ind:WorkflowTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Estimated average duration in hours for completing a workflow instance created from this template.' ;
    rdfs:domain ind:WorkflowTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gxpCritical rdf:type rdf:Property ;
    rdfs:label 'Gxp Critical' ;
    rdfs:comment 'Indicates whether this workflow template is classified as GxP-critical requiring enhanced controls and validation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled' ;
    rdfs:comment 'Indicates whether automated notifications are enabled for workflow instances created from this template.' ;
    rdfs:domain ind:WorkflowTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the workflow template including its purpose, scope, and intended use cases within compliance processes.' ;
    rdfs:domain ind:WorkflowTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:additionalMetadata rdf:type rdf:Property ;
    rdfs:label 'Additional Metadata' ;
    rdfs:comment 'JSON or XML formatted string containing additional context-specific metadata not captured in standard fields. Enables extensibility for system-specific audit requirements.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBySystem rdf:type rdf:Property ;
    rdfs:label 'Created By System' ;
    rdfs:comment 'Name of the system or service that created this audit trail record in the centralized audit repository.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureApplied rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Applied' ;
    rdfs:comment 'Indicates whether an electronic signature was applied to this event per 21 CFR Part 11 requirements (True/False).' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entityId rdf:type rdf:Property ;
    rdfs:label 'Entity Id' ;
    rdfs:comment 'Unique identifier of the specific business object instance that was affected (e.g., batch number, protocol ID, specification ID).' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityName rdf:type rdf:Property ;
    rdfs:label 'Entity Name' ;
    rdfs:comment 'Human-readable name or description of the affected entity for audit trail readability.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicates whether this audit event represents an exception or anomaly requiring investigation (True/False).' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldName rdf:type rdf:Property ;
    rdfs:label 'Field Name' ;
    rdfs:comment 'Name of the specific data field or attribute that was modified during the event. Null for non-modification events.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashValue rdf:type rdf:Property ;
    rdfs:label 'Hash Value' ;
    rdfs:comment 'Cryptographic hash of the audit record content to ensure data integrity and detect tampering per 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'New value of the field after the change was applied. Null for delete operations or non-modification events.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oldValue rdf:type rdf:Property ;
    rdfs:label 'Old Value' ;
    rdfs:comment 'Previous value of the field before the change was applied. Null for create operations or non-modification events.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAuditTrailId rdf:type rdf:Property ;
    rdfs:label 'Parent Audit Trail Id' ;
    rdfs:comment 'Reference to a parent audit trail record if this event is part of a cascading or hierarchical audit chain. Null for top-level events.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemModule rdf:type rdf:Property ;
    rdfs:label 'Source System Module' ;
    rdfs:comment 'Specific module or functional area within the source system where the event occurred (e.g., Batch Record, Inventory Management, Clinical Trial Management).' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionId rdf:type rdf:Property ;
    rdfs:label 'Transaction Id' ;
    rdfs:comment 'Unique identifier for the business transaction that triggered this audit event. Enables grouping of related audit records.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userFullName rdf:type rdf:Property ;
    rdfs:label 'User Full Name' ;
    rdfs:comment 'Full legal name of the user who performed the action at the time of the event.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userId rdf:type rdf:Property ;
    rdfs:label 'User Id' ;
    rdfs:comment 'Unique identifier of the user who performed the audited action. Links to enterprise identity management system.' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userRole rdf:type rdf:Property ;
    rdfs:label 'User Role' ;
    rdfs:comment 'Business role or job function of the user at the time the action was performed (e.g., Quality Assurance Manager, Manufacturing Operator, Clinical Data Manager).' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowState rdf:type rdf:Property ;
    rdfs:label 'Workflow State' ;
    rdfs:comment 'State of the business workflow at the time of the event (e.g., Draft, In Review, Approved, Released, Archived).' ;
    rdfs:domain ind:AuditTrail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Confirmation Number' ;
    rdfs:comment 'Confirmation or reference number provided by the bank upon successful receipt and processing of the payment batch.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Dual Approval Required' ;
    rdfs:comment 'Flag indicating whether this payment batch requires approval from two authorized signatories before processing, typically for high-value batches.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Summary description of errors encountered during payment batch processing, including error codes and messages from the payment system or bank.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Flag indicating whether this payment batch is part of a recurring payment schedule (e.g., monthly vendor payments, payroll).' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentFileFormat rdf:type rdf:Property ;
    rdfs:label 'Payment File Format' ;
    rdfs:comment 'Standard format of the payment file transmitted to the bank (NACHA, BAI2, MT940, PAIN.001, CAMT.053, or proprietary format).' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProgramId rdf:type rdf:Property ;
    rdfs:label 'Payment Program Id' ;
    rdfs:comment 'Identifier for the automated payment program or payment run configuration used to generate this batch.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRunDate rdf:type rdf:Property ;
    rdfs:label 'Payment Run Date' ;
    rdfs:comment 'The business date on which the payment batch was executed or is scheduled to be executed.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the payment batch processing was completed and payments were transmitted to the bank.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recurringScheduleId rdf:type rdf:Property ;
    rdfs:label 'Recurring Schedule Id' ;
    rdfs:comment 'Reference to the recurring payment schedule configuration if this batch is part of an automated recurring payment program.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Second Approval Timestamp' ;
    rdfs:comment 'Date and time when the second approval was granted for dual-authorization payment batches.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:secondApprover rdf:type rdf:Property ;
    rdfs:label 'Second Approver' ;
    rdfs:comment 'User ID or name of the second approver for payment batches requiring dual authorization.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Count' ;
    rdfs:comment 'Total number of individual payment transactions included in this batch.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessContinuityTier rdf:type rdf:Property ;
    rdfs:label 'Business Continuity Tier' ;
    rdfs:comment 'Priority tier for business continuity and disaster recovery planning, where Tier 1 represents mission-critical functions requiring immediate recovery.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAuditFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Frequency' ;
    rdfs:comment 'Required frequency of compliance audits for this functional area based on regulatory requirements and internal quality standards.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStewardId rdf:type rdf:Property ;
    rdfs:label 'Data Steward Id' ;
    rdfs:comment 'Reference to the employee responsible for data governance, data quality, and master data management for this functional area.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalSystemCode rdf:type rdf:Property ;
    rdfs:label 'External System Code' ;
    rdfs:comment 'Functional area identifier used in external or legacy systems for cross-system data integration and reconciliation.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaType rdf:type rdf:Property ;
    rdfs:label 'Functional Area Type' ;
    rdfs:comment 'Classification of the functional area by its primary business function within the pharmaceutical value chain.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcount rdf:type rdf:Property ;
    rdfs:label 'Headcount' ;
    rdfs:comment 'Total number of full-time equivalent (FTE) employees assigned to this functional area.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Reference to the primary physical location or site where this functional area operates.' ;
    rdfs:domain ind:FunctionalArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Id' ;
    rdfs:comment 'Reference to the user who last modified this functional area record, supporting audit trail and data governance requirements.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
