ind:claimsProcessingSystem rdf:type rdf:Property ;
    rdfs:label 'Claims Processing System' ;
    rdfs:comment 'Name of the primary claims adjudication and processing system used by the PBM.' ;
    rdfs:domain ind:Pbm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Date' ;
    rdfs:comment 'The date by which contract renewal negotiations must be completed or the contract will auto-renew.' ;
    rdfs:domain ind:Pbm ;
