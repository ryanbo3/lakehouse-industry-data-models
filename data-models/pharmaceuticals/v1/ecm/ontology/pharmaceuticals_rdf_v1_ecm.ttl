    rdfs:range xsd:string .

ind:pbmName rdf:type rdf:Property ;
    rdfs:label 'Pbm Name' ;
    rdfs:comment 'Official legal name of the pharmacy benefit manager organization.' ;
    rdfs:domain ind:Pbm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pbmType rdf:type rdf:Property ;
    rdfs:label 'Pbm Type' ;
    rdfs:comment 'Classification of the PBM based on its operational model and service scope.' ;
