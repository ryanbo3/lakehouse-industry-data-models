    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispensing Fee Amount' ;
    rdfs:comment 'Standard dispensing fee amount paid to the pharmacy per prescription filled, in USD.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'Trade name or DBA name under which the pharmacy operates if different from legal name.' ;
