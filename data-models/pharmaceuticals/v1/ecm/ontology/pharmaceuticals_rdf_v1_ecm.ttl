    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Workflow Step' ;
    rdfs:comment 'Master reference table for workflow_step. Referenced by workflow_step_id.' .

ind:RootCauseAnalysis rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Master reference table for root_cause_analysis. Referenced by root_cause_analysis_id.' .

ind:BusinessProcess rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Business Process' ;
    rdfs:comment 'Master reference table for business_process. Referenced by process_id.' .

ind:DataProcessingActivity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Data Processing Activity' ;
    rdfs:comment 'Master reference table for data_processing_activity. Referenced by data_processing_activity_id.' .

ind:AssayPanel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Assay Panel' ;
    rdfs:comment 'Master reference table for assay_panel. Referenced by assay_panel_id.' .

ind:SynthesisRoute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Synthesis Route' ;
    rdfs:comment 'Master reference table for synthesis_route. Referenced by synthesis_route_id.' .

ind:CompoundLibrary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Compound Library' ;
    rdfs:comment 'Master reference table for compound_library. Referenced by compound_library_id.' .

ind:PaymentRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payment Run' ;
