    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biobankType rdf:type rdf:Property ;
    rdfs:label 'Biobank Type' ;
    rdfs:comment 'Classification of the biobank based on its primary purpose and sample collection focus.' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for biobank inquiries and sample requests.' ;
