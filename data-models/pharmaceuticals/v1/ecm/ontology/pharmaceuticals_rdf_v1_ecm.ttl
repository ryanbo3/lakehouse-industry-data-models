    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesforceTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Territory Code' ;
    rdfs:comment 'External identifier for the district in Salesforce Health Cloud for cross-system alignment.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaCrmTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Territory Code' ;
    rdfs:comment 'External identifier for the district in Veeva CRM system for integration and synchronization.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentRegionId rdf:type rdf:Property ;
    rdfs:label 'Parent Region Id' ;
    rdfs:comment 'Reference to the parent region in the organizational hierarchy. Null for top-level regions.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:annualRevenueTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target Usd' ;
    rdfs:comment 'Annual sales revenue target for the region in US dollars. Used for performance tracking and incentive compensation.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level in the regional hierarchy (e.g., 1=Global, 2=Theater, 3=Country, 4=Area, 5=Territory). Used for organizational rollup and reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketPotentialScore rdf:type rdf:Property ;
    rdfs:label 'Market Potential Score' ;
    rdfs:comment 'Quantitative score (0-100) representing the commercial opportunity and growth potential of the region based on patient population, prescriber density, and market access.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phrmaCodeApplicable rdf:type rdf:Property ;
    rdfs:label 'Phrma Code Applicable' ;
    rdfs:comment 'Indicates whether the PhRMA Code on Interactions with Healthcare Professionals applies to promotional activities in this region (typically US regions).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionType rdf:type rdf:Property ;
    rdfs:label 'Region Type' ;
    rdfs:comment 'Classification of the region based on its organizational purpose: geographic (territory-based), therapeutic (disease area focus), strategic (key account clusters), hybrid (combination), operational (sales operations), or market_access (payer/reimbursement focus).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Email' ;
    rdfs:comment 'Corporate email address of the regional manager for operational communication.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerName rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Name' ;
    rdfs:comment 'Full name of the regional sales manager or commercial leader responsible for this region.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryEnvironment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Environment' ;
    rdfs:comment 'Classification of the promotional and market access regulatory environment: permissive (minimal restrictions), moderate (standard controls), restrictive (significant limitations), highly_restrictive (severe constraints on promotional activities).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceHealthCloudEnabled rdf:type rdf:Property ;
    rdfs:label 'Salesforce Health Cloud Enabled' ;
    rdfs:comment 'Indicates whether Salesforce Health Cloud is deployed for patient services, case management, or specialty pharmacy support in this region.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleDistributionAllowed rdf:type rdf:Property ;
    rdfs:label 'Sample Distribution Allowed' ;
    rdfs:comment 'Indicates whether pharmaceutical product sampling to healthcare professionals is permitted by regulation and company policy in this region.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:speakerProgramAllowed rdf:type rdf:Property ;
    rdfs:label 'Speaker Program Allowed' ;
    rdfs:comment 'Indicates whether healthcare professional speaker programs and advisory boards are permitted in this region per local regulations and compliance policies.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetHcoCount rdf:type rdf:Property ;
    rdfs:label 'Target Hco Count' ;
    rdfs:comment 'Number of healthcare organizations (hospitals, clinics, health systems, integrated delivery networks) targeted within this region.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veevaCrmEnabled rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Enabled' ;
    rdfs:comment 'Indicates whether Veeva CRM is deployed and operational for sales force automation in this region.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Assessed Value Amount' ;
    rdfs:comment 'Monetary value determined as fair market value for the assessed item or service, used for transparency reporting and anti-kickback compliance.' ;
    rdfs:domain ind:FmvAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentScope rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope' ;
    rdfs:comment 'Detailed description of what is being assessed, including deliverables, time commitment, and expected outcomes.' ;
    rdfs:domain ind:FmvAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comparableDataSources rdf:type rdf:Property ;
    rdfs:label 'Comparable Data Sources' ;
    rdfs:comment 'References to market data, industry benchmarks, or comparable transactions used to support the FMV determination.' ;
    rdfs:domain ind:FmvAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityStatus rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Status' ;
    rdfs:comment 'ALCOA+ compliance status indicating whether this FMV assessment record meets attributable, legible, contemporaneous, original, and accurate standards.' ;
    rdfs:domain ind:FmvAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFromBenchmarkPct rdf:type rdf:Property ;
    rdfs:label 'Deviation From Benchmark Pct' ;
    rdfs:comment 'Percentage variance between assessed value and industry benchmark, used to flag outliers requiring additional scrutiny.' ;
    rdfs:domain ind:FmvAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic market context for the FMV assessment, as fair market value varies by region.' ;
    rdfs:domain ind:FmvAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:justificationNotes rdf:type rdf:Property ;
    rdfs:label 'Justification Notes' ;
    rdfs:comment 'Detailed rationale and supporting evidence for the assessed fair market value, critical for regulatory inspection readiness.' ;
    rdfs:domain ind:FmvAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reassessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Reassessment Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of fair market value, ensuring ongoing compliance with current market conditions.' ;
    rdfs:domain ind:FmvAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationMethodology rdf:type rdf:Property ;
    rdfs:label 'Valuation Methodology' ;
    rdfs:comment 'Method used to determine the fair market value, required for audit trail and regulatory defense.' ;
    rdfs:domain ind:FmvAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified this triggering event definition.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:notificationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Notification Template Id' ;
    rdfs:comment 'Identifier of the standard notification template to be used when this triggering event occurs.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NotificationTemplate .

ind:workflowTemplateId rdf:type rdf:Property ;
    rdfs:label 'Workflow Template Id' ;
    rdfs:comment 'Identifier of the standard workflow template to be initiated when this triggering event occurs.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkflowTemplate .

ind:alcoaPlusPrinciple rdf:type rdf:Property ;
    rdfs:label 'Alcoa Plus Principle' ;
    rdfs:comment 'Specific ALCOA+ data integrity principle that this triggering event relates to (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableBusinessFunctions rdf:type rdf:Property ;
    rdfs:label 'Applicable Business Functions' ;
    rdfs:comment 'Comma-separated list of business functions where this triggering event is applicable (e.g., manufacturing, clinical trials, quality control, regulatory affairs).' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTherapeuticAreas rdf:type rdf:Property ;
    rdfs:label 'Applicable Therapeutic Areas' ;
    rdfs:comment 'Comma-separated list of therapeutic areas where this triggering event is applicable (e.g., oncology, immunology, rare diseases). Null if applicable to all areas.' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Role' ;
    rdfs:comment 'Organizational role with authority to approve closure or resolution of this triggering event type.' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedDetectionFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Detection Flag' ;
    rdfs:comment 'Indicates whether this triggering event can be automatically detected by compliance monitoring systems (True) or requires manual identification (False).' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description of the triggering event, including conditions that constitute the event and expected compliance response.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionCriteria rdf:type rdf:Property ;
    rdfs:label 'Detection Criteria' ;
    rdfs:comment 'Technical or business criteria used to detect or identify when this triggering event has occurred.' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:comment 'High-level classification of the triggering event by compliance domain (quality, regulatory, safety, data integrity, GxP, SOX, GDPR).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the type of triggering event in compliance monitoring systems.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Human-readable name of the triggering event (e.g., Deviation Detected, Audit Finding, CAPA Initiated).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'Organizational role or function responsible for managing and responding to this triggering event type (e.g., Quality Assurance Manager, Regulatory Affairs Director).' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific regulatory citation or section reference that mandates monitoring of this triggering event (e.g., 21 CFR 11.10, EU Annex 11 Section 4).' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportableToAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Reportable To Authority Flag' ;
    rdfs:comment 'Indicates whether this triggering event type must be reported to regulatory authorities (True) or is internal only (False).' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingTimeframeDays rdf:type rdf:Property ;
    rdfs:label 'Reporting Timeframe Days' ;
    rdfs:comment 'Number of days within which this triggering event must be reported to regulatory authorities if reportable. Null if not reportable.' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAssessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Required Flag' ;
    rdfs:comment 'Indicates whether this triggering event type requires a formal risk assessment (True) or not (False).' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Required Flag' ;
    rdfs:comment 'Indicates whether this triggering event type requires formal root cause analysis (True) or not (False).' ;
    rdfs:domain ind:TriggeringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esignatureSessionId rdf:type rdf:Property ;
    rdfs:label 'Esignature Session Id' ;
    rdfs:comment 'Primary key for esignature_session' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTrailId rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Id' ;
    rdfs:comment 'Identifier linking this electronic signature session to the corresponding audit trail record, ensuring complete traceability per ALCOA+ data integrity principles.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditTrail .

ind:delegatedFromUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Delegated From User Employee Id' ;
    rdfs:comment 'Identifier of the user who delegated their signature authority to the actual signer, if delegation was used.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Identifier of the document, record, or data object being signed during this electronic signature session.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PolicyDocument .

ind:witnessUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Witness User Employee Id' ;
    rdfs:comment 'Identifier of the user who served as a witness to the primary electronic signature, if witnessing was required.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationName rdf:type rdf:Property ;
    rdfs:label 'Application Name' ;
    rdfs:comment 'Name of the software application or system module through which the electronic signature was executed.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationVersion rdf:type rdf:Property ;
    rdfs:label 'Application Version' ;
    rdfs:comment 'Version number of the software application at the time the electronic signature was captured, supporting system validation and audit requirements.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authentication Timestamp' ;
    rdfs:comment 'Date and time when the user successfully authenticated their identity to initiate or complete the signature session.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the electronic signature session was successfully completed with all required signatures captured, or null if not yet completed.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Date and time when the electronic signature session will expire if not completed, enforcing time-bound signature requirements for compliance.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the electronic signature session was first initiated by the system or user, marking the beginning of the signature workflow.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isDelegated rdf:type rdf:Property ;
    rdfs:label 'Is Delegated' ;
    rdfs:comment 'Indicates whether this electronic signature session was performed under delegated authority, where one user signs on behalf of another per approved delegation rules.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWitnessed rdf:type rdf:Property ;
    rdfs:label 'Is Witnessed' ;
    rdfs:comment 'Indicates whether this electronic signature session required or included a witness signature, common in critical GxP processes.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonForSignature rdf:type rdf:Property ;
    rdfs:label 'Reason For Signature' ;
    rdfs:comment 'Free-text explanation or justification provided by the signer describing why the signature is being applied, supporting audit trail requirements.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of authentication or signature attempts made during this session, used to detect potential security issues or user difficulties.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total duration of the electronic signature session in seconds, from initiation to completion or cancellation, used for performance monitoring and anomaly detection.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'Human-readable business identifier for the electronic signature session, typically displayed in audit reports and compliance documentation.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle state of the electronic signature session, tracking progression from initiation through completion or termination.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Classification of the electronic signature session based on its regulatory and business purpose within the GxP environment.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Signature Algorithm' ;
    rdfs:comment 'Cryptographic algorithm used to generate the signature hash, such as SHA-256 or RSA, supporting technical validation of signature integrity.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureHash rdf:type rdf:Property ;
    rdfs:label 'Signature Hash' ;
    rdfs:comment 'Cryptographic hash of the signed content at the time of signature, ensuring data integrity and detecting any subsequent tampering per ALCOA+ principles.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:username rdf:type rdf:Property ;
    rdfs:label 'Username' ;
    rdfs:comment 'Unique username of the individual performing the electronic signature, required for audit trail and non-repudiation per GxP regulations.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Witness Timestamp' ;
    rdfs:comment 'Date and time when the witness signature was applied, if witnessing was required for this session.' ;
    rdfs:domain ind:EsignatureSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentTemplateId rdf:type rdf:Property ;
    rdfs:label 'Document Template Id' ;
    rdfs:comment 'Reference to the standard document template or form that must be completed for this workflow step.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentTemplate .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Minimum organizational authority level required to approve or complete this workflow step.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailLevel rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Level' ;
    rdfs:comment 'Level of audit trail detail required for this workflow step, ranging from basic timestamp logging to comprehensive change tracking.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Indicates whether formal documentation or evidence must be attached or generated upon completion of this workflow step.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Hours' ;
    rdfs:comment 'Number of hours after which an incomplete workflow step triggers escalation to management or compliance officers.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCriticalControl rdf:type rdf:Property ;
    rdfs:label 'Is Critical Control' ;
    rdfs:comment 'Indicates whether this step represents a critical control point requiring enhanced monitoring and documentation per SOX or GxP requirements.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this workflow step is mandatory for compliance or can be optionally skipped based on business rules.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresElectronicSignature rdf:type rdf:Property ;
    rdfs:label 'Requires Electronic Signature' ;
    rdfs:comment 'Indicates whether this workflow step requires electronic signature per 21 CFR Part 11 or EU Annex 11 regulations.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Role' ;
    rdfs:comment 'The organizational role or job function responsible for executing this workflow step (e.g., \'Quality Assurance Manager\', \'Compliance Officer\', \'Data Steward\').' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDurationHours rdf:type rdf:Property ;
    rdfs:label 'Sla Duration Hours' ;
    rdfs:comment 'Target duration in hours for completing this workflow step, used for compliance monitoring and performance tracking.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepCategory rdf:type rdf:Property ;
    rdfs:label 'Step Category' ;
    rdfs:comment 'Functional category of the workflow step indicating the type of compliance activity performed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCode rdf:type rdf:Property ;
    rdfs:label 'Step Code' ;
    rdfs:comment 'Unique business identifier code for the workflow step, used for external reference and system integration.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepDescription rdf:type rdf:Property ;
    rdfs:label 'Step Description' ;
    rdfs:comment 'Detailed description of the purpose, activities, and expected outcomes of this workflow step.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepName rdf:type rdf:Property ;
    rdfs:label 'Step Name' ;
    rdfs:comment 'Human-readable name of the workflow step.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepStatus rdf:type rdf:Property ;
    rdfs:label 'Step Status' ;
    rdfs:comment 'Current lifecycle status of the workflow step indicating whether it is in active use.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemIntegrationEndpoint rdf:type rdf:Property ;
    rdfs:label 'System Integration Endpoint' ;
    rdfs:comment 'API endpoint or system interface used to trigger or complete this workflow step programmatically.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseCode rdf:type rdf:Property ;
    rdfs:label 'Training Course Code' ;
    rdfs:comment 'Code or identifier of the training course that personnel must complete to be qualified for this workflow step.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowType rdf:type rdf:Property ;
    rdfs:label 'Workflow Type' ;
    rdfs:comment 'Classification of the workflow this step belongs to, aligned with enterprise compliance programs.' ;
    rdfs:domain ind:WorkflowStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Reference to the CAPA record initiated as a result of this root cause analysis.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityCapa .

ind:analysisMethodologyDetails rdf:type rdf:Property ;
    rdfs:label 'Analysis Methodology Details' ;
    rdfs:comment 'Detailed description of how the selected root cause analysis methodology was applied, including tools, techniques, and steps followed.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether corrective actions are required based on the root cause analysis findings.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivenessCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Required' ;
    rdfs:comment 'Indicates whether an effectiveness check is required to verify that implemented corrective and preventive actions successfully addressed the root cause.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceCollected rdf:type rdf:Property ;
    rdfs:label 'Evidence Collected' ;
    rdfs:comment 'Summary of the evidence, data, and documentation collected during the investigation to support the root cause determination.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateCause rdf:type rdf:Property ;
    rdfs:label 'Immediate Cause' ;
    rdfs:comment 'The direct or proximate cause that led to the problem or deviation, identified during the investigation.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationTeam rdf:type rdf:Property ;
    rdfs:label 'Investigation Team' ;
    rdfs:comment 'Comma-separated list or description of the cross-functional team members involved in the root cause analysis (e.g., Quality, Manufacturing, Engineering, Regulatory).' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Key insights, best practices, and lessons learned from the root cause analysis that can be applied to prevent similar issues in the future.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Required' ;
    rdfs:comment 'Indicates whether preventive actions are required to prevent recurrence of similar issues in other areas or processes.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:problemStatement rdf:type rdf:Property ;
    rdfs:label 'Problem Statement' ;
    rdfs:comment 'Clear and concise description of the problem or deviation being investigated, defining the scope of the root cause analysis.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcaNumber rdf:type rdf:Property ;
    rdfs:label 'Rca Number' ;
    rdfs:comment 'Business identifier for the root cause analysis, typically system-generated and externally referenced in quality documentation.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentPerformed rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Performed' ;
    rdfs:comment 'Indicates whether a formal risk assessment was conducted as part of the root cause analysis to evaluate impact and likelihood.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessProcessId rdf:type rdf:Property ;
    rdfs:label 'Business Process Id' ;
    rdfs:comment 'Primary key for business_process' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaLinkageEnabled rdf:type rdf:Property ;
    rdfs:label 'Capa Linkage Enabled' ;
    rdfs:comment 'Indicates whether this process is linked to the CAPA system for tracking corrective and preventive actions.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cfrPart11Applicable rdf:type rdf:Property ;
    rdfs:label 'Cfr Part 11 Applicable' ;
    rdfs:comment 'Indicates whether this process involves electronic records or electronic signatures subject to 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Risk-based criticality assessment of the process based on its impact on product quality, patient safety, and regulatory compliance.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityAlcoaPlusRequired rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Alcoa Plus Required' ;
    rdfs:comment 'Indicates whether this process must adhere to ALCOA+ data integrity principles: Attributable, Legible, Contemporaneous, Original, Accurate, plus Complete, Consistent, Enduring, and Available.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Deviation Tracking Enabled' ;
    rdfs:comment 'Indicates whether deviations from this business process are tracked and investigated per quality management requirements.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electronicSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Required' ;
    rdfs:comment 'Indicates whether this process requires electronic signatures for approval and authorization steps.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:euAnnex11Applicable rdf:type rdf:Property ;
    rdfs:label 'Eu Annex 11 Applicable' ;
    rdfs:comment 'Indicates whether this process involves computerized systems subject to EU GMP Annex 11 requirements.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpClassification rdf:type rdf:Property ;
    rdfs:label 'Gxp Classification' ;
    rdfs:comment 'Indicates which Good Practice regulation applies to this process: Good Manufacturing Practice (GMP), Good Clinical Practice (GCP), Good Laboratory Practice (GLP), Good Distribution Practice (GDP), Good Pharmacovigilance Practice (GVP), or non-GxP.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReadinessScore rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Score' ;
    rdfs:comment 'Quantitative assessment score (0-100) indicating the process\'s readiness for regulatory inspection based on documentation completeness, training records, and compliance evidence.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processCategory rdf:type rdf:Property ;
    rdfs:label 'Process Category' ;
    rdfs:comment 'High-level categorization of the business process by functional area within pharmaceutical operations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCode rdf:type rdf:Property ;
    rdfs:label 'Process Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the business process for external reference and regulatory documentation. Used in audit trails and compliance reports.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processName rdf:type rdf:Property ;
    rdfs:label 'Process Name' ;
    rdfs:comment 'Full descriptive name of the business process as recognized across the enterprise.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processOwner rdf:type rdf:Property ;
    rdfs:label 'Process Owner' ;
    rdfs:comment 'Name or identifier of the individual or role accountable for the design, execution, and compliance of this business process.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processType rdf:type rdf:Property ;
    rdfs:label 'Process Type' ;
    rdfs:comment 'Classification of the process by its role in the enterprise: core operational, support, management oversight, or regulatory compliance.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Retired Timestamp' ;
    rdfs:comment 'Timestamp when this business process was retired or made obsolete. Null if the process is still active.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Date' ;
    rdfs:comment 'Date when the most recent risk assessment was performed for this business process.' ;
    rdfs:domain ind:BusinessProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sopReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sop Reference Number' ;
    rdfs:comment 'Reference number of the primary Standard Operating Procedure document that defines this business process.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlApplicable rdf:type rdf:Property ;
    rdfs:label 'Sox Control Applicable' ;
    rdfs:comment 'Indicates whether this process is subject to Sarbanes-Oxley Act internal control requirements for financial reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlId rdf:type rdf:Property ;
    rdfs:label 'Sox Control Id' ;
    rdfs:comment 'Reference identifier of the SOX control framework element associated with this processing activity.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalControl .

ind:activityName rdf:type rdf:Property ;
    rdfs:label 'Activity Name' ;
    rdfs:comment 'Human-readable name or title of the data processing activity (e.g., \'Clinical Trial Data Collection\', \'Patient Consent Management\', \'Pharmacovigilance Reporting\').' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Activity Reference Number' ;
    rdfs:comment 'Externally-known unique reference code or identifier for the data processing activity used in regulatory filings and audit trails.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the data processing activity based on its primary function within the data lifecycle.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderTransfer rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transfer' ;
    rdfs:comment 'Indicates whether this processing activity involves transfer of data across international borders.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCategory rdf:type rdf:Property ;
    rdfs:label 'Data Category' ;
    rdfs:comment 'Classification of the type of data being processed (e.g., \'Personal Health Information\', \'Clinical Trial Data\', \'Manufacturing Records\', \'Employee Data\').' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDestinationSystem rdf:type rdf:Property ;
    rdfs:label 'Data Destination System' ;
    rdfs:comment 'Name or identifier of the system or application to which processed data is transferred or stored.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessorName rdf:type rdf:Property ;
    rdfs:label 'Data Processor Name' ;
    rdfs:comment 'Name of the third-party organization or internal department acting as data processor for this activity.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionOfficerAssigned rdf:type rdf:Property ;
    rdfs:label 'Data Protection Officer Assigned' ;
    rdfs:comment 'Indicates whether a Data Protection Officer has been assigned oversight responsibility for this processing activity.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'Number of days that data processed under this activity must be retained to meet regulatory and business requirements.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSubjectCategory rdf:type rdf:Property ;
    rdfs:label 'Data Subject Category' ;
    rdfs:comment 'Classification of individuals whose data is being processed (e.g., \'Clinical Trial Participants\', \'Patients\', \'Healthcare Professionals\', \'Employees\').' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Organizational Security Measures' ;
    rdfs:comment 'Description of organizational and procedural safeguards implemented to protect data (e.g., training, access policies, incident response procedures).' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current lifecycle state of the data processing activity within the compliance management system.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorContractReference rdf:type rdf:Property ;
    rdfs:label 'Processor Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the data processing agreement or contract governing the processor relationship.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCountries rdf:type rdf:Property ;
    rdfs:label 'Recipient Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing countries to which data is transferred.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Version number of this data processing activity record, incremented with each modification to support audit trail and change control.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryInspectionReady rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Ready' ;
    rdfs:comment 'Indicates whether documentation and controls for this processing activity are ready for regulatory inspection.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDpia rdf:type rdf:Property ;
    rdfs:label 'Requires Dpia' ;
    rdfs:comment 'Indicates whether a Data Protection Impact Assessment is required for this processing activity under privacy regulations.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionJustification rdf:type rdf:Property ;
    rdfs:label 'Retention Justification' ;
    rdfs:comment 'Business and regulatory rationale for the specified data retention period.' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSecurityMeasures rdf:type rdf:Property ;
    rdfs:label 'Technical Security Measures' ;
    rdfs:comment 'Description of technical safeguards implemented to protect data processed under this activity (e.g., encryption, access controls, audit logging).' ;
    rdfs:domain ind:DataProcessingActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayCount rdf:type rdf:Property ;
    rdfs:label 'Assay Count' ;
    rdfs:comment 'Total number of individual assays included in this panel.' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assayProtocolVersion rdf:type rdf:Property ;
    rdfs:label 'Assay Protocol Version' ;
    rdfs:comment 'Version number of the standard operating procedure or protocol used for this panel.' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerDataPoint rdf:type rdf:Property ;
    rdfs:label 'Cost Per Data Point' ;
    rdfs:comment 'Average cost in USD to generate one data point using this assay panel, used for resource planning and prioritization.' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastValidationDate rdf:type rdf:Property ;
    rdfs:label 'Last Validation Date' ;
    rdfs:comment 'Date of the most recent validation or revalidation of this assay panel under GLP standards.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextValidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Validation Due Date' ;
    rdfs:comment 'Scheduled date for the next required validation or revalidation of this panel.' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:panelCode rdf:type rdf:Property ;
    rdfs:label 'Panel Code' ;
    rdfs:comment 'Unique business identifier code for the assay panel used in laboratory information management systems and electronic lab notebooks.' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelName rdf:type rdf:Property ;
    rdfs:label 'Panel Name' ;
    rdfs:comment 'Human-readable name of the assay panel describing its purpose or target.' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current lifecycle status of the assay panel indicating whether it is active for screening, under development, validated, or retired.' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelType rdf:type rdf:Property ;
    rdfs:label 'Panel Type' ;
    rdfs:comment 'Classification of the assay panel by methodology or purpose (biochemical, cell-based, phenotypic, binding, functional, ADME, toxicity).' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactScientist rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Scientist' ;
    rdfs:comment 'Name of the principal scientist or researcher responsible for this assay panel.' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlFrequency rdf:type rdf:Property ;
    rdfs:label 'Quality Control Frequency' ;
    rdfs:comment 'Frequency at which quality control checks are performed on this assay panel to ensure data integrity and reproducibility.' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningStage rdf:type rdf:Property ;
    rdfs:label 'Screening Stage' ;
    rdfs:comment 'Drug discovery stage at which this panel is typically deployed (primary screening, secondary screening, tertiary screening, lead optimization, preclinical).' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeDays rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Days' ;
    rdfs:comment 'Typical turnaround time in days from sample submission to results delivery for this panel.' ;
    rdfs:domain ind:AssayPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternativeRouteId rdf:type rdf:Property ;
    rdfs:label 'Alternative Route Id' ;
    rdfs:comment 'Reference to an alternative synthesis route for the same target compound, if one exists.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SynthesisRoute .

ind:discoveryProjectId rdf:type rdf:Property ;
    rdfs:label 'Discovery Project Id' ;
    rdfs:comment 'Reference to the drug discovery project under which this synthesis route was developed.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:advantages rdf:type rdf:Property ;
    rdfs:label 'Advantages' ;
    rdfs:comment 'Summary of the key advantages of this synthesis route compared to alternative routes (e.g., higher yield, lower cost, fewer steps, better safety profile).' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalMethods rdf:type rdf:Property ;
    rdfs:label 'Analytical Methods' ;
    rdfs:comment 'Analytical techniques used to characterize intermediates and final product (e.g., Nuclear Magnetic Resonance (NMR), High-Performance Liquid Chromatography (HPLC), Mass Spectrometry (MS)).' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexityScore rdf:type rdf:Property ;
    rdfs:label 'Complexity Score' ;
    rdfs:comment 'Numerical score (typically 1-10) representing the technical complexity of the synthesis route based on reaction difficulty, purification challenges, and specialized equipment requirements.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalReagents rdf:type rdf:Property ;
    rdfs:label 'Critical Reagents' ;
    rdfs:comment 'List of critical or specialized reagents required for key transformations in the synthesis route.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactRating rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Rating' ;
    rdfs:comment 'Assessment of the environmental impact of the synthesis route considering waste generation, solvent usage, and energy consumption.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostPerGramUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Per Gram Usd' ;
    rdfs:comment 'Estimated cost in United States Dollars (USD) to synthesize one gram of the target compound using this route, including materials, labor, and overhead.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Days' ;
    rdfs:comment 'Estimated total time in days required to complete the entire synthesis route from start to finish, including reaction times and purification.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventorName rdf:type rdf:Property ;
    rdfs:label 'Inventor Name' ;
    rdfs:comment 'Name of the primary chemist or research scientist who developed or discovered this synthesis route.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyReactionTypes rdf:type rdf:Property ;
    rdfs:label 'Key Reaction Types' ;
    rdfs:comment 'Comma-separated list of the major chemical reaction types employed in this synthesis route (e.g., coupling, cyclization, reduction, oxidation).' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Date when this synthesis route was most recently executed in the laboratory or manufacturing facility.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limitations rdf:type rdf:Property ;
    rdfs:label 'Limitations' ;
    rdfs:comment 'Summary of known limitations or challenges associated with this synthesis route (e.g., expensive reagents, difficult purification, poor scalability).' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Overall Yield Percent' ;
    rdfs:comment 'Cumulative yield percentage across all steps of the synthesis route, representing the efficiency of the entire synthetic pathway.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patentProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Patent Protected Flag' ;
    rdfs:comment 'Indicates whether this synthesis route is protected by one or more patents owned by or licensed to the organization.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purificationMethods rdf:type rdf:Property ;
    rdfs:label 'Purification Methods' ;
    rdfs:comment 'Primary purification techniques used in the synthesis route (e.g., chromatography, crystallization, distillation).' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Externally-known unique business identifier for the synthesis route, used across research and development systems.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDescription rdf:type rdf:Property ;
    rdfs:label 'Route Description' ;
    rdfs:comment 'Detailed textual description of the synthesis route including key transformations, strategic considerations, and notable features.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name or title of the synthesis route, typically describing the key transformation or target molecule.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current lifecycle status of the synthesis route indicating its readiness and approval state for use in compound production.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the synthesis route strategy (linear, convergent, divergent, parallel, combinatorial, or semi-synthesis).' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scalabilityRating rdf:type rdf:Property ;
    rdfs:label 'Scalability Rating' ;
    rdfs:comment 'Assessment of the synthesis routes suitability for scale-up from laboratory to pilot or commercial manufacturing.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startingMaterialAvailability rdf:type rdf:Property ;
    rdfs:label 'Starting Material Availability' ;
    rdfs:comment 'Assessment of the availability and sourcing ease for the key starting materials required for this synthesis route.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSteps rdf:type rdf:Property ;
    rdfs:label 'Total Steps' ;
    rdfs:comment 'Total number of discrete chemical transformation steps required to complete this synthesis route from starting materials to final product.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of times this synthesis route has been executed since its validation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Name of the senior scientist or quality assurance personnel who validated this synthesis route.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedDate rdf:type rdf:Property ;
    rdfs:label 'Validated Date' ;
    rdfs:comment 'Date when this synthesis route was formally validated and approved for use in compound production.' ;
    rdfs:domain ind:SynthesisRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:concentrationMm rdf:type rdf:Property ;
    rdfs:label 'Concentration Mm' ;
    rdfs:comment 'Standard concentration of compounds in the library expressed in millimolar (mM) units.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversityScore rdf:type rdf:Property ;
    rdfs:label 'Diversity Score' ;
    rdfs:comment 'Calculated chemical diversity score (0-100) indicating the structural variety within the library, higher scores represent greater diversity.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:druggabilityScore rdf:type rdf:Property ;
    rdfs:label 'Druggability Score' ;
    rdfs:comment 'Calculated score (0-100) indicating the likelihood that compounds in this library possess drug-like properties based on physicochemical parameters.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intellectualPropertyStatus rdf:type rdf:Property ;
    rdfs:label 'Intellectual Property Status' ;
    rdfs:comment 'Legal intellectual property classification of the compound library indicating ownership and usage rights.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastQualityCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Quality Check Date' ;
    rdfs:comment 'Date of the most recent quality control assessment performed on the compound library.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:libraryCode rdf:type rdf:Property ;
    rdfs:label 'Library Code' ;
    rdfs:comment 'Unique business identifier code for the compound library used across research systems and publications.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryName rdf:type rdf:Property ;
    rdfs:label 'Library Name' ;
    rdfs:comment 'Human-readable name of the compound library describing its purpose or composition.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryStatus rdf:type rdf:Property ;
    rdfs:label 'Library Status' ;
    rdfs:comment 'Current lifecycle status of the compound library indicating its availability for screening and research activities.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryType rdf:type rdf:Property ;
    rdfs:label 'Library Type' ;
    rdfs:comment 'Classification of the compound library based on its intended use and composition strategy in drug discovery.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'Date when the license agreement for externally sourced compound libraries expires, if applicable.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:molecularWeightRangeMax rdf:type rdf:Property ;
    rdfs:label 'Molecular Weight Range Max' ;
    rdfs:comment 'Maximum molecular weight (in Daltons) of compounds in this library, used to characterize library composition.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:molecularWeightRangeMin rdf:type rdf:Property ;
    rdfs:label 'Molecular Weight Range Min' ;
    rdfs:comment 'Minimum molecular weight (in Daltons) of compounds in this library, used to characterize library composition.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purityThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Purity Threshold Percent' ;
    rdfs:comment 'Minimum required purity percentage for compounds to be included in this library, typically determined by analytical methods.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Result of the most recent quality control assessment indicating compound integrity and purity.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningCampaignCount rdf:type rdf:Property ;
    rdfs:label 'Screening Campaign Count' ;
    rdfs:comment 'Total number of high-throughput screening (HTS) campaigns in which this compound library has been utilized.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screeningReady rdf:type rdf:Property ;
    rdfs:label 'Screening Ready' ;
    rdfs:comment 'Indicates whether the compound library is formatted, quality-controlled, and ready for high-throughput screening (HTS) campaigns.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solventType rdf:type rdf:Property ;
    rdfs:label 'Solvent Type' ;
    rdfs:comment 'Primary solvent used for compound dissolution and storage in the library.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Celsius' ;
    rdfs:comment 'Required storage temperature in degrees Celsius to maintain compound stability and integrity.' ;
    rdfs:domain ind:CompoundLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBatchId rdf:type rdf:Property ;
    rdfs:label 'Payment Batch Id' ;
    rdfs:comment 'External batch identifier assigned by the banking system or payment processor for tracking and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentBatch .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or acknowledgment number received from the bank or payment processor upon successful file receipt.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Number of payment transactions within the run that encountered errors or failed validation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Consolidated error messages or failure reasons for the payment run, used for troubleshooting and resolution.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'The precise date and time when the payment run was executed and payments were initiated.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The accounting period date when the payment run transactions were posted to the general ledger.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isTestRun rdf:type rdf:Property ;
    rdfs:label 'Is Test Run' ;
    rdfs:comment 'Boolean flag indicating whether this is a test or simulation run (true) or a live production payment run (false).' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentCount rdf:type rdf:Property ;
    rdfs:label 'Payment Count' ;
    rdfs:comment 'Total number of individual payment transactions included in this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentFileName rdf:type rdf:Property ;
    rdfs:label 'Payment File Name' ;
    rdfs:comment 'Name of the payment file generated for transmission to the bank or payment processor.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFilePath rdf:type rdf:Property ;
    rdfs:label 'Payment File Path' ;
    rdfs:comment 'Storage location or file path where the payment file is archived for audit and compliance purposes.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPriority rdf:type rdf:Property ;
    rdfs:label 'Processing Priority' ;
    rdfs:comment 'Priority level assigned to the payment run for queue management and execution sequencing.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciled Timestamp' ;
    rdfs:comment 'Date and time when the payment run was successfully reconciled with banking records.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business identifier for the payment run, formatted as PR-YYYYMMDD-NNNN for external reference and audit tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'The aggregate monetary value of all payments in this run before any adjustments or fees.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Date and time when the payment file was transmitted to the bank or payment processor.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date when funds are to be available to payees, used for cash flow planning and bank reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:masterAccountId rdf:type rdf:Property ;
    rdfs:label 'Master Account Id' ;
    rdfs:comment 'Reference to the master bank account if this is a subsidiary or zero balance account. Null if this is a standalone account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'The legal name of the primary account holder as registered with the bank.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Account Manager Email' ;
    rdfs:comment 'The email address of the bank relationship manager for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerName rdf:type rdf:Property ;
    rdfs:label 'Account Manager Name' ;
    rdfs:comment 'The name of the relationship manager or account officer at the bank responsible for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Account Manager Phone' ;
    rdfs:comment 'The phone number of the bank relationship manager for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'The business purpose or function of the bank account (e.g., operating expenses, payroll disbursement, R&D funding, royalty collections).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'The available balance in the bank account after accounting for holds, pending transactions, and reserved funds.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankIdentifierCode rdf:type rdf:Property ;
    rdfs:label 'Bank Identifier Code' ;
    rdfs:comment 'The BIC or SWIFT code uniquely identifying the financial institution for international transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchAddress rdf:type rdf:Property ;
    rdfs:label 'Branch Address' ;
    rdfs:comment 'The physical address of the bank branch holding the account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCity rdf:type rdf:Property ;
    rdfs:label 'Branch City' ;
    rdfs:comment 'The city where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCode rdf:type rdf:Property ;
    rdfs:label 'Branch Code' ;
    rdfs:comment 'The unique code identifying the bank branch within the financial institution\'s network.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCountryCode rdf:type rdf:Property ;
    rdfs:label 'Branch Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the country where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'The name of the specific bank branch where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'The date when the bank account was closed or deactivated. Null if the account is still open.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'The current balance of the bank account in the account\'s primary currency as of the last reconciliation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generalLedgerAccountCode rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account Code' ;
    rdfs:comment 'The GL account code in the chart of accounts to which this bank account is mapped for financial reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The annual interest rate applied to the bank account balance, expressed as a decimal (e.g., 0.0250 for 2.50%).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryAccount rdf:type rdf:Property ;
    rdfs:label 'Is Primary Account' ;
    rdfs:comment 'Indicates whether this is the primary operating bank account for the legal entity or cost center.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isZeroBalanceAccount rdf:type rdf:Property ;
    rdfs:label 'Is Zero Balance Account' ;
    rdfs:comment 'Indicates whether this is a zero balance account that automatically sweeps funds to or from a master account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumBalanceRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Requirement' ;
    rdfs:comment 'The minimum balance that must be maintained in the account to avoid fees or penalties.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReconciliationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reconciliation Due Date' ;
    rdfs:comment 'The date by which the next bank reconciliation must be completed.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date when the bank account was opened and became active.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'The maximum overdraft or credit limit allowed on this bank account. Null if no overdraft facility exists.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The domestic routing number, ABA number, or sort code used to identify the bank branch for electronic transfers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant Flag' ;
    rdfs:comment 'Indicates whether this bank account is subject to SOX compliance controls and audit requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billToAddressId rdf:type rdf:Property ;
    rdfs:label 'Bill To Address Id' ;
    rdfs:comment 'Reference to the billing address where the invoice is sent.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:shipToAddressId rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Id' ;
    rdfs:comment 'Reference to the shipping address where the goods or services were delivered.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'The end date of the period covered by this invoice, relevant for subscription or recurring billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'The start date of the period covered by this invoice, relevant for subscription or recurring billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which the customer raised a dispute for this invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'The general ledger account code to which this invoice revenue is posted.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The date on which revenue from this invoice is recognized in the financial statements per GAAP revenue recognition rules.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'The shipping and handling charges included in this invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'The sum of all line item amounts before taxes, discounts, and adjustments.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'The actual date and time when the costing run execution completed or terminated.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether this costing run requires formal approval from finance management before results are posted to the general ledger.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costingMethod rdf:type rdf:Property ;
    rdfs:label 'Costing Method' ;
    rdfs:comment 'The valuation method applied in this costing run: standard cost, actual cost, moving average, first-in-first-out (FIFO), or last-in-first-out (LIFO).' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingVariant rdf:type rdf:Property ;
    rdfs:label 'Costing Variant' ;
    rdfs:comment 'The SAP costing variant code that defines the costing methodology, valuation strategy, and calculation rules applied in this run.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'The type of foreign exchange rate used for currency conversion in this costing run: period average, period closing, budget rate, or standard rate.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Minutes' ;
    rdfs:comment 'The total time taken to execute the costing run, measured in minutes from start to completion.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includesRndCapitalization rdf:type rdf:Property ;
    rdfs:label 'Includes Rnd Capitalization' ;
    rdfs:comment 'Indicates whether this costing run includes capitalized research and development costs allocated to products under development or newly launched.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesRoyaltyCosts rdf:type rdf:Property ;
    rdfs:label 'Includes Royalty Costs' ;
    rdfs:comment 'Indicates whether this costing run includes royalty and licensing costs associated with intellectual property used in product manufacturing.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodMonth rdf:type rdf:Property ;
    rdfs:label 'Period Month' ;
    rdfs:comment 'The fiscal month within the year for which this costing run is executed, represented as 1-12.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodQuarter rdf:type rdf:Property ;
    rdfs:label 'Period Quarter' ;
    rdfs:comment 'The fiscal quarter for which this costing run is executed, represented as 1-4.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodYear rdf:type rdf:Property ;
    rdfs:label 'Period Year' ;
    rdfs:comment 'The fiscal year for which this costing run is executed, represented as a four-digit year (e.g., 2024).' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postedToGl rdf:type rdf:Property ;
    rdfs:label 'Posted To Gl' ;
    rdfs:comment 'Indicates whether the costing results from this run have been posted to the general ledger for financial reporting.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'The category of products included in this costing run: pharmaceutical drugs, vaccines, consumer health products, medical devices, or all categories.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'The organizational or product scope covered by this costing run: global enterprise, specific region, country, manufacturing site, product line, or therapeutic area.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCompliant rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant' ;
    rdfs:comment 'Indicates whether this costing run was executed following SOX-compliant controls and audit trails for financial reporting integrity.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'The aggregate total cost calculated across all products and cost components in this costing run, expressed in the run currency.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProductsCosted rdf:type rdf:Property ;
    rdfs:label 'Total Products Costed' ;
    rdfs:comment 'The total number of distinct product SKUs or materials for which costs were calculated in this costing run.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationView rdf:type rdf:Property ;
    rdfs:label 'Valuation View' ;
    rdfs:comment 'The accounting perspective used for material valuation: legal entity view, group consolidation view, profit center view, or tax reporting view.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningCount rdf:type rdf:Property ;
    rdfs:label 'Warning Count' ;
    rdfs:comment 'The number of warnings generated during the execution of this costing run, indicating potential data quality or configuration issues.' ;
    rdfs:domain ind:CostingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'The accounting standard or principle governing this ledger (e.g., US GAAP, IFRS, local statutory GAAP, tax accounting, management accounting). Determines valuation, recognition, and disclosure rules.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Reporting Flag' ;
    rdfs:comment 'Indicates whether this ledger supports profit and loss reporting segmented by pharmaceutical brand or product line. True if brand dimension is enabled, False otherwise.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cogsTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Cogs Tracking Flag' ;
    rdfs:comment 'Indicates whether this ledger tracks cost of goods sold by product for pharmaceutical manufacturing and distribution. True if COGS tracking is enabled, False otherwise.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Ledger Flag' ;
    rdfs:comment 'Indicates whether this ledger is used for group consolidation purposes. Consolidation ledgers aggregate financial data from multiple legal entities for consolidated financial statements. True if consolidation ledger, False otherwise.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographyReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Geography Reporting Flag' ;
    rdfs:comment 'Indicates whether this ledger supports profit and loss reporting segmented by geographic region or country. True if geography dimension is enabled, False otherwise.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadingLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Leading Ledger Flag' ;
    rdfs:comment 'Indicates whether this is the leading (primary) ledger for the organization. The leading ledger is the authoritative source for statutory financial reporting and consolidation. True if leading ledger, False otherwise.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the ledger in financial systems. Used as the business identifier for external references and reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Full descriptive name of the ledger (e.g., \'Corporate General Ledger\', \'IFRS Reporting Ledger\', \'Management Accounting Ledger\').' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger based on its accounting purpose. General ledgers capture all financial transactions; subsidiary ledgers track specific account categories; statistical ledgers hold non-financial data; special purpose ledgers support specific reporting requirements; consolidation ledgers aggregate multi-entity data; management ledgers support internal decision-making.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parallelAccountingFlag rdf:type rdf:Property ;
    rdfs:label 'Parallel Accounting Flag' ;
    rdfs:comment 'Indicates whether this ledger is part of a parallel accounting setup, where multiple ledgers track the same transactions under different accounting principles (e.g., GAAP and IFRS). True if parallel ledger, False otherwise.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether financial postings are currently allowed to this ledger. Used to control posting periods and prevent unauthorized entries during period-end close. True if postings allowed, False otherwise.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossAccount rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Account' ;
    rdfs:comment 'General ledger account number used to accumulate net profit or loss for the current period in this ledger. Cleared to retained earnings during year-end close.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainedEarningsAccount rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account' ;
    rdfs:comment 'General ledger account number used to post retained earnings for this ledger during year-end closing. Represents accumulated profits or losses carried forward from prior periods.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyAccountingFlag rdf:type rdf:Property ;
    rdfs:label 'Royalty Accounting Flag' ;
    rdfs:comment 'Indicates whether this ledger tracks royalty payments and revenue related to licensed pharmaceutical intellectual property. True if royalty accounting is enabled, False otherwise.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:therapeuticAreaReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Reporting Flag' ;
    rdfs:comment 'Indicates whether this ledger supports profit and loss reporting segmented by therapeutic area (e.g., oncology, immunology, rare diseases). True if therapeutic area dimension is enabled, False otherwise.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationArea rdf:type rdf:Property ;
    rdfs:label 'Valuation Area' ;
    rdfs:comment 'Defines the valuation perspective for assets and liabilities in this ledger. Legal valuation follows statutory requirements; group valuation supports consolidation; profit center valuation enables segment reporting; tax valuation aligns with tax authority rules.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyEntityId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Entity Id' ;
    rdfs:comment 'Reference to the legal entity that is the counterparty in this intercompany agreement.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:originatingEntityId rdf:type rdf:Property ;
    rdfs:label 'Originating Entity Id' ;
    rdfs:comment 'Reference to the legal entity that originated or initiated this intercompany agreement.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:annualValue rdf:type rdf:Property ;
    rdfs:label 'Annual Value' ;
    rdfs:comment 'Estimated or contracted annual monetary value of the intercompany agreement in the specified currency, used for budgeting and financial planning.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costSharingPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Percentage' ;
    rdfs:comment 'Percentage of costs allocated to the counterparty entity under a cost-sharing arrangement, typically used for R&D cost allocation. Nullable if not a cost-sharing agreement.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeApprover rdf:type rdf:Property ;
    rdfs:label 'Finance Approver' ;
    rdfs:comment 'Name or identifier of the finance executive who approved this intercompany agreement for financial compliance and budgetary alignment.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalApprover rdf:type rdf:Property ;
    rdfs:label 'Legal Approver' ;
    rdfs:comment 'Name or identifier of the legal counsel who approved this intercompany agreement for legal compliance and risk management.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicates whether this intercompany agreement is eligible for automatic renewal upon expiration.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percentage' ;
    rdfs:comment 'Percentage rate applied to calculate royalty payments for intellectual property licensing under this intercompany agreement. Nullable if not a royalty agreement.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the primary tax jurisdiction governing this intercompany agreement for tax compliance and reporting.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Terminated Timestamp' ;
    rdfs:comment 'Timestamp when this intercompany agreement was terminated or cancelled. Nullable if agreement is still active.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'OECD-compliant transfer pricing method applied to transactions under this intercompany agreement to ensure arms-length pricing.' ;
    rdfs:domain ind:IntercompanyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaId rdf:type rdf:Property ;
    rdfs:label 'Business Area Id' ;
    rdfs:comment 'Reference to the business area (e.g., Pharmaceuticals, Consumer Health, Vaccines) for segment reporting and cross-company code consolidation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessArea .

ind:functionalAreaId rdf:type rdf:Property ;
    rdfs:label 'Functional Area Id' ;
    rdfs:comment 'Reference to the functional area (e.g., Research & Development, Manufacturing, Sales & Marketing) for cost-of-sales accounting and functional reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalArea .

ind:investmentProgramId rdf:type rdf:Property ;
    rdfs:label 'Investment Program Id' ;
    rdfs:comment 'Reference to the capital investment program or appropriation request under which this WBS element is funded and tracked.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:parentWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Element Id' ;
    rdfs:comment 'Reference to the parent WBS element in the hierarchical project structure. Null for top-level WBS elements.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:projectManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Manager Employee Id' ;
    rdfs:comment 'Reference to the employee serving as the project manager or work package owner responsible for this WBS element.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:responsibleCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Responsible Cost Center Id' ;
    rdfs:comment 'Reference to the cost center responsible for managing and executing the work defined by this WBS element.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:accountAssignmentElementFlag rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Element Flag' ;
    rdfs:comment 'Indicates whether this WBS element can be used as an account assignment object for purchase orders, expense reports, and other financial transactions.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingElementFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Element Flag' ;
    rdfs:comment 'Indicates whether this WBS element is used as a billing element for customer invoicing in contract research or collaborative development projects.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligible Flag' ;
    rdfs:comment 'Indicates whether costs posted to this WBS element are eligible for capitalization as intangible assets under accounting standards (e.g., IAS 38 for development phase costs).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Optional external identifier linking this WBS element to corresponding records in third-party project management, clinical trial management, or contract research systems.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Planning Budget Amount' ;
    rdfs:comment 'The total approved budget amount allocated to this WBS element for planning and cost control purposes.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningElementFlag rdf:type rdf:Property ;
    rdfs:label 'Planning Element Flag' ;
    rdfs:comment 'Indicates whether this WBS element is used for project planning activities including resource planning, cost planning, and schedule planning.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultsAnalysisKey rdf:type rdf:Property ;
    rdfs:label 'Results Analysis Key' ;
    rdfs:comment 'Key determining the method for calculating work-in-progress (WIP), revenue recognition, and results analysis for this WBS element in project accounting.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementProfileCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Profile Code' ;
    rdfs:comment 'Code defining the rules for periodic settlement of costs from this WBS element to receiving cost objects (e.g., cost centers, assets, general ledger accounts).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalFlag rdf:type rdf:Property ;
    rdfs:label 'Statistical Flag' ;
    rdfs:comment 'Indicates whether this WBS element is statistical (used for reporting and planning only) and does not accept actual cost postings.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying the WBS element in project management and financial systems. Used for cost allocation, budgeting, and reporting.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementDescription rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Description' ;
    rdfs:comment 'Detailed description of the WBS element\'s purpose, scope, and business objectives within the project or program structure.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementName rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Name' ;
    rdfs:comment 'Human-readable name or title of the WBS element describing the project phase, deliverable, or cost center.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementType rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Type' ;
    rdfs:comment 'Classification of the WBS element by its functional purpose: planning (for project planning), billing (for customer billing), account_assignment (for cost allocation), or statistical (for reporting only).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Level' ;
    rdfs:comment 'The hierarchical level of this WBS element within the project structure, where 1 is the top level and higher numbers represent deeper nesting.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Employee Id' ;
    rdfs:comment 'Reference to the authorized user who approved this campaign.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:manufacturingLineId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Line Id' ;
    rdfs:comment 'Reference to the specific production line or suite assigned to this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:campaignNotes rdf:type rdf:Property ;
    rdfs:label 'Campaign Notes' ;
    rdfs:comment 'Free-text notes and comments related to the campaign, including special instructions, deviations, or observations.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignNumber rdf:type rdf:Property ;
    rdfs:label 'Campaign Number' ;
    rdfs:comment 'Business identifier for the campaign, externally known and used in manufacturing execution systems and batch documentation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractManufacturingFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Manufacturing Flag' ;
    rdfs:comment 'Indicates whether this campaign is executed by a Contract Manufacturing Organization (CMO) or Contract Development and Manufacturing Organization (CDMO).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingMode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Mode' ;
    rdfs:comment 'Mode of manufacturing operation: batch, continuous, or semi-continuous processing.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfBatchesCompleted rdf:type rdf:Property ;
    rdfs:label 'Number Of Batches Completed' ;
    rdfs:comment 'Total number of batches successfully completed during this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfBatchesPlanned rdf:type rdf:Property ;
    rdfs:label 'Number Of Batches Planned' ;
    rdfs:comment 'Total number of batches planned to be manufactured during this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processAnalyticalTechnologyFlag rdf:type rdf:Property ;
    rdfs:label 'Process Analytical Technology Flag' ;
    rdfs:comment 'Indicates whether Process Analytical Technology (PAT) is implemented in this campaign for real-time quality monitoring and control.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityByDesignFlag rdf:type rdf:Property ;
    rdfs:label 'Quality By Design Flag' ;
    rdfs:comment 'Indicates whether the campaign follows Quality by Design (QbD) principles as outlined in ICH Q8, Q9, and Q10.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Planned production quantity for the campaign, expressed in the unit of measure specified.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Disposition By User Employee Id' ;
    rdfs:comment 'Reference to the quality assurance personnel who made the final disposition decision. Required for regulatory accountability.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:receivedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Received By User Employee Id' ;
    rdfs:comment 'Reference to the laboratory personnel who received and logged the sample into the LIMS. Part of chain of custody documentation.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:testSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Test Specification Id' ;
    rdfs:comment 'Reference to the test specification or analytical method that defines the testing protocol for this sample. Links to quality control test procedures.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:testedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tested By User Employee Id' ;
    rdfs:comment 'Reference to the analyst or laboratory technician who performed the testing. Required for accountability and audit trail.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:collectionPoint rdf:type rdf:Property ;
    rdfs:label 'Collection Point' ;
    rdfs:comment 'Specific location or process step where the sample was collected (e.g., reactor vessel, blending tank, filling line station 3, packaging line A).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final disposition decision for the sample and associated batch: approved (released for use/distribution), rejected (not suitable), quarantined (held pending investigation), pending review (awaiting QA decision), released (testing complete and approved), or destroyed (disposed per protocol).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationRequired rdf:type rdf:Property ;
    rdfs:label 'Investigation Required' ;
    rdfs:comment 'Indicates whether an out-of-specification (OOS) investigation or other formal investigation is required for this sample. Triggers quality event workflow.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Number' ;
    rdfs:comment 'Externally-known unique sample identifier used in laboratory information management systems (LIMS) and batch records. Human-readable business identifier for tracking and referencing.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current lifecycle status of the sample in the quality control workflow. Tracks progression from collection through testing to final disposition.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultSummary rdf:type rdf:Property ;
    rdfs:label 'Test Result Summary' ;
    rdfs:comment 'Overall outcome of the sample testing: pass (meets specifications), fail (does not meet specifications), out of specification (OOS - requires investigation), pending (testing incomplete), or inconclusive (requires retest).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Testing Completion Timestamp' ;
    rdfs:comment 'Date and time when all analytical testing for the sample was completed. Marks readiness for review and disposition decision.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Testing Start Timestamp' ;
    rdfs:comment 'Date and time when analytical testing of the sample commenced. Used to calculate testing duration and laboratory throughput metrics.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cleanroomGrade rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Grade' ;
    rdfs:comment 'Required cleanroom classification grade for this process step per EU GMP Annex 1 or ISO 14644 standards. Null if cleanroom not required.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationToleranceMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Tolerance Minutes' ;
    rdfs:comment 'Acceptable variance in process step duration before triggering deviation investigation, measured in minutes.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentClass rdf:type rdf:Property ;
    rdfs:label 'Equipment Class' ;
    rdfs:comment 'General class or type of equipment required to execute this process step (e.g., Reactor, Blender, Tablet Press, Filling Line, Autoclave).' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gowningLevel rdf:type rdf:Property ;
    rdfs:label 'Gowning Level' ;
    rdfs:comment 'Required level of personnel gowning for this process step, ranging from basic PPE to full aseptic gowning. Null if gowning not required.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inProcessControlRequired rdf:type rdf:Property ;
    rdfs:label 'In Process Control Required' ;
    rdfs:comment 'Indicates whether in-process controls or testing must be performed during or immediately after this step per batch record requirements.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCriticalStep rdf:type rdf:Property ;
    rdfs:label 'Is Critical Step' ;
    rdfs:comment 'Indicates whether this step is identified as a critical process step (CPS) that directly impacts Critical Quality Attributes (CQA) per Quality by Design (QbD) principles.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phSetpoint rdf:type rdf:Property ;
    rdfs:label 'Ph Setpoint' ;
    rdfs:comment 'Target pH level for this process step. Applicable for synthesis, fermentation, and formulation steps requiring pH control.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phTolerance rdf:type rdf:Property ;
    rdfs:label 'Ph Tolerance' ;
    rdfs:comment 'Acceptable pH variance from setpoint before triggering out-of-specification investigation.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressureSetpointBar rdf:type rdf:Property ;
    rdfs:label 'Pressure Setpoint Bar' ;
    rdfs:comment 'Target pressure for this process step measured in bar. Null if pressure control is not applicable.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressureToleranceBar rdf:type rdf:Property ;
    rdfs:label 'Pressure Tolerance Bar' ;
    rdfs:comment 'Acceptable pressure variance from setpoint in bar before triggering out-of-specification investigation.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresCleanroom rdf:type rdf:Property ;
    rdfs:label 'Requires Cleanroom' ;
    rdfs:comment 'Indicates whether this process step must be performed in a controlled cleanroom environment per cGMP requirements.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresGowning rdf:type rdf:Property ;
    rdfs:label 'Requires Gowning' ;
    rdfs:comment 'Indicates whether personnel must wear specialized gowning or personal protective equipment (PPE) to perform this step.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingRequired rdf:type rdf:Property ;
    rdfs:label 'Sampling Required' ;
    rdfs:comment 'Indicates whether material sampling is required at this process step for quality control or in-process testing purposes.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Numeric ordering of this step within the overall manufacturing process flow. Lower numbers execute first.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedSetpointRpm rdf:type rdf:Property ;
    rdfs:label 'Speed Setpoint Rpm' ;
    rdfs:comment 'Target rotational speed for equipment in this process step measured in revolutions per minute (RPM). Applicable for mixing, blending, and centrifugation steps.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speedToleranceRpm rdf:type rdf:Property ;
    rdfs:label 'Speed Tolerance Rpm' ;
    rdfs:comment 'Acceptable speed variance from setpoint in RPM before triggering out-of-specification investigation.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardOperatingProcedureNumber rdf:type rdf:Property ;
    rdfs:label 'Standard Operating Procedure Number' ;
    rdfs:comment 'Reference number of the governing Standard Operating Procedure document that defines how to execute this process step.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepNumber rdf:type rdf:Property ;
    rdfs:label 'Step Number' ;
    rdfs:comment 'Business identifier for the process step used in batch records and manufacturing instructions (e.g., MIX-010, FILL-020).' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Classification of the manufacturing process step based on its function in the production workflow.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureSetpointC rdf:type rdf:Property ;
    rdfs:label 'Temperature Setpoint C' ;
    rdfs:comment 'Target temperature for this process step in degrees Celsius. Null if temperature control is not applicable.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureToleranceC rdf:type rdf:Property ;
    rdfs:label 'Temperature Tolerance C' ;
    rdfs:comment 'Acceptable temperature variance from setpoint in degrees Celsius before triggering out-of-specification investigation.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workInstructionNumber rdf:type rdf:Property ;
    rdfs:label 'Work Instruction Number' ;
    rdfs:comment 'Reference number of the detailed work instruction document that provides step-by-step execution guidance for operators.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSiteId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Id' ;
    rdfs:comment 'Reference to the manufacturing facility or site where this routing is executed.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:supersededByRoutingId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Routing Id' ;
    rdfs:comment 'Reference to the newer routing that replaces this one when status is superseded. Null if not superseded.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:cgmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cgmp Compliant Flag' ;
    rdfs:comment 'Indicates whether this routing has been validated and approved for current Good Manufacturing Practice compliance.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalProcessFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Process Flag' ;
    rdfs:comment 'Indicates whether this routing contains critical process parameters that directly impact critical quality attributes.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Batch Size' ;
    rdfs:comment 'Maximum allowable batch size that can be manufactured using this routing while maintaining quality standards.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Batch Size' ;
    rdfs:comment 'Minimum allowable batch size that can be manufactured using this routing while maintaining quality standards.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRevalidationDate rdf:type rdf:Property ;
    rdfs:label 'Next Revalidation Date' ;
    rdfs:comment 'Scheduled date for the next periodic revalidation of this routing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qbdEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Qbd Enabled Flag' ;
    rdfs:comment 'Indicates whether this routing incorporates Quality by Design principles with defined design space and control strategy.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingName rdf:type rdf:Property ;
    rdfs:label 'Routing Name' ;
    rdfs:comment 'Human-readable name describing the manufacturing routing process.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing indicating its purpose and usage context in manufacturing operations.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Version' ;
    rdfs:comment 'Version number of the routing to track changes and revisions over time. Follows semantic versioning pattern.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardBatchSize rdf:type rdf:Property ;
    rdfs:label 'Standard Batch Size' ;
    rdfs:comment 'Standard production batch quantity for which this routing is designed.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Cycle Time Minutes' ;
    rdfs:comment 'Expected total time in minutes to complete all operations in this routing under normal conditions.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sterileProcessFlag rdf:type rdf:Property ;
    rdfs:label 'Sterile Process Flag' ;
    rdfs:comment 'Indicates whether this routing requires aseptic or sterile manufacturing conditions.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalOperationCount rdf:type rdf:Property ;
    rdfs:label 'Total Operation Count' ;
    rdfs:comment 'Total number of manufacturing operations or steps defined in this routing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rebateContractId rdf:type rdf:Property ;
    rdfs:label 'Rebate Contract Id' ;
    rdfs:comment 'Reference to the rebate contract governing manufacturer rebates for drugs included in this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketPayerContract .

ind:copayStructure rdf:type rdf:Property ;
    rdfs:label 'Copay Structure' ;
    rdfs:comment 'The cost-sharing structure applied to drugs in this formulary (e.g., flat copayment, percentage coinsurance, deductible-based, or mixed model).' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRegion rdf:type rdf:Property ;
    rdfs:label 'Coverage Region' ;
    rdfs:comment 'Geographic region(s) where the formulary is applicable, represented as comma-separated ISO 3166-1 alpha-3 country codes or state/province codes.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionListUrl rdf:type rdf:Property ;
    rdfs:label 'Exclusion List Url' ;
    rdfs:comment 'URL link to the published list of drugs excluded from coverage under this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyCode rdf:type rdf:Property ;
    rdfs:label 'Formulary Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the formulary for external identification and system integration.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Formulary Document Url' ;
    rdfs:comment 'URL link to the official formulary document or drug list published for member and provider access.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyName rdf:type rdf:Property ;
    rdfs:label 'Formulary Name' ;
    rdfs:comment 'The official name or title of the formulary as recognized by payers, pharmacy benefit managers (PBM), or health systems.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyType rdf:type rdf:Property ;
    rdfs:label 'Formulary Type' ;
    rdfs:comment 'Classification of the formulary based on the payer segment or market it serves (e.g., commercial insurance, Medicare Part D, Medicaid, health exchange, employer-sponsored, hospital, specialty pharmacy).' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genericSubstitutionPolicy rdf:type rdf:Property ;
    rdfs:label 'Generic Substitution Policy' ;
    rdfs:comment 'Policy governing whether and how generic drugs may be substituted for brand-name drugs under this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossToNetAdjustmentRate rdf:type rdf:Property ;
    rdfs:label 'Gross To Net Adjustment Rate' ;
    rdfs:comment 'The average percentage adjustment rate applied to gross drug prices to calculate net revenue after rebates, discounts, and other deductions for this formulary. Expressed as a percentage.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:htaSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Hta Submission Required' ;
    rdfs:comment 'Indicates whether health technology assessment submissions are required for drugs to be considered for inclusion in this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailOrderAvailable rdf:type rdf:Property ;
    rdfs:label 'Mail Order Available' ;
    rdfs:comment 'Indicates whether mail-order pharmacy services are available for drugs covered under this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientAccessProgramLinked rdf:type rdf:Property ;
    rdfs:label 'Patient Access Program Linked' ;
    rdfs:comment 'Indicates whether patient access programs (copay assistance, patient support services) are linked to drugs covered under this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityLimitsApplied rdf:type rdf:Property ;
    rdfs:label 'Quantity Limits Applied' ;
    rdfs:comment 'Indicates whether quantity limits (maximum dispensing quantities per prescription or time period) are enforced on drugs in this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rweDataConsidered rdf:type rdf:Property ;
    rdfs:label 'Rwe Data Considered' ;
    rdfs:comment 'Indicates whether real-world evidence and real-world data are considered in formulary decision-making and drug evaluations.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:therapeuticCategoriesCovered rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Categories Covered' ;
    rdfs:comment 'Comma-separated list of therapeutic categories or drug classes covered by this formulary (e.g., oncology, immunology, cardiovascular, diabetes).' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStructure rdf:type rdf:Property ;
    rdfs:label 'Tier Structure' ;
    rdfs:comment 'The tiering model used by the formulary to classify drugs by cost-sharing level (e.g., generic, preferred brand, non-preferred brand, specialty).' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDossierRequired rdf:type rdf:Property ;
    rdfs:label 'Value Dossier Required' ;
    rdfs:comment 'Indicates whether a value dossier (comprehensive evidence package demonstrating clinical and economic value) is required for formulary inclusion.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accumulatorAdjustmentProgram rdf:type rdf:Property ;
    rdfs:label 'Accumulator Adjustment Program' ;
    rdfs:comment 'Indicates whether the PBM implements accumulator adjustment programs that exclude manufacturer copay assistance from patient out-of-pocket maximums.' ;
    rdfs:domain ind:Pbm ;
    rdf:type owl:DatatypeProperty ;
