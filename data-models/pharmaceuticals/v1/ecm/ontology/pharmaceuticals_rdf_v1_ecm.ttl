    rdfs:comment 'Primary business address of the PBM headquarters location.' ;
    rdfs:domain ind:Pbm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'Three-letter ISO country code for the PBM headquarters location.' ;
    rdfs:domain ind:Pbm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailOrderService rdf:type rdf:Property ;
    rdfs:label 'Mail Order Service' ;
    rdfs:comment 'Indicates whether the PBM offers mail order pharmacy services for maintenance medications.' ;
