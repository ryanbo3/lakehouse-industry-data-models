    rdfs:comment 'DEA registration number for organizations authorized to handle controlled substances. Required for Schedule II-V drug distribution and sample accountability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
