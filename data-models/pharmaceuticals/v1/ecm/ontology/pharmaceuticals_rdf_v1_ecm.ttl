    rdfs:range xsd:string .

ind:headquartersState rdf:type rdf:Property ;
    rdfs:label 'Headquarters State' ;
    rdfs:comment 'Two-letter state or province code for the district headquarters location.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Launch Readiness Status' ;
    rdfs:comment 'Indicates whether the district is prepared for new product launches and promotional campaigns.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Full name of the sales district.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesForceSize rdf:type rdf:Property ;
    rdfs:label 'Sales Force Size' ;
    rdfs:comment 'Number of sales representatives assigned to this district.' ;
