    rdfs:range xsd:boolean .

ind:formularyTierStructure rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier Structure' ;
    rdfs:comment 'The tiering model used by the PBM to categorize drugs and assign patient cost-sharing levels.' ;
    rdfs:domain ind:Pbm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
