    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessOwner rdf:type rdf:Property ;
    rdfs:label 'Business Owner' ;
    rdfs:comment 'Name of the business user or team responsible for defining and maintaining this mapping rule.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirement rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement' ;
    rdfs:comment 'Reference to regulatory or compliance requirement that this mapping rule supports (e.g., FDA 21 CFR Part 11, GDPR, GxP).' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDomain rdf:type rdf:Property ;
    rdfs:label 'Data Domain' ;
    rdfs:comment 'Business data domain to which this mapping rule belongs (e.g., masterdata, clinical, manufacturing, finance).' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityRule rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rule' ;
    rdfs:comment 'Data quality validation rule or constraint applied during the mapping process to ensure data integrity.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultValue rdf:type rdf:Property ;
    rdfs:label 'Default Value' ;
    rdfs:comment 'Default value to be used when source data is null, missing, or does not meet mapping criteria.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'URL link to detailed documentation, specification, or design document for this mapping rule.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorHandlingStrategy rdf:type rdf:Property ;
    rdfs:label 'Error Handling Strategy' ;
    rdfs:comment 'Strategy for handling errors encountered during mapping execution (fail process, log and continue, skip record, or retry).' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nullHandlingStrategy rdf:type rdf:Property ;
    rdfs:label 'Null Handling Strategy' ;
    rdfs:comment 'Strategy for handling null or missing values in source data (reject record, apply default, skip field, or apply transformation).' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the mapping rule describing its purpose.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the mapping rule based on its transformation logic (direct mapping, transformation, conditional logic, lookup-based, aggregation, or derivation).' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceAttribute rdf:type rdf:Property ;
    rdfs:label 'Source Attribute' ;
    rdfs:comment 'Name of the source field or attribute being mapped.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEntity rdf:type rdf:Property ;
    rdfs:label 'Source Entity' ;
    rdfs:comment 'Name of the source entity, table, or object from which data originates.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAttribute rdf:type rdf:Property ;
    rdfs:label 'Target Attribute' ;
    rdfs:comment 'Name of the target field or attribute receiving the mapped data.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEntity rdf:type rdf:Property ;
    rdfs:label 'Target Entity' ;
    rdfs:comment 'Name of the target entity, table, or data product to which data is mapped.' ;
    rdfs:domain ind:MappingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSystem rdf:type rdf:Property ;
