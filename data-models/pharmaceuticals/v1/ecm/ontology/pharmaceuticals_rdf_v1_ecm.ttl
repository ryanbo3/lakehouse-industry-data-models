ind:npi rdf:type rdf:Property ;
    rdfs:label 'Npi' ;
    rdfs:comment 'Unique 10-digit National Provider Identifier assigned by CMS for healthcare organizations. Type 2 NPI for organizational providers. Required for Medicare/Medicaid billing and HIPAA compliance.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationStatus rdf:type rdf:Property ;
    rdfs:label 'Organization Status' ;
    rdfs:comment 'Current operational status of the healthcare organization in the master data system. Drives eligibility for commercial engagement and sample distribution.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership structure of the healthcare organization. Impacts contracting approach, pricing strategy, and regulatory obligations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the healthcare organization main switchboard or administrative office.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the healthcare organization address. Used for geographic segmentation and logistics planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyFocus rdf:type rdf:Property ;
    rdfs:label 'Specialty Focus' ;
    rdfs:comment 'Primary clinical specialty or therapeutic area focus of the healthcare organization (e.g., oncology, cardiology, pediatrics). Used for targeted medical affairs and commercial engagement.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax ID for the healthcare organization. Used for financial transactions, 1099 reporting, and Sunshine Act compliance.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teachingHospitalFlag rdf:type rdf:Property ;
    rdfs:label 'Teaching Hospital Flag' ;
    rdfs:comment 'Indicates whether the organization is a teaching hospital affiliated with a medical school. Teaching hospitals are priority targets for medical affairs and Key Opinion Leader (KOL) engagement.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:traumaLevel rdf:type rdf:Property ;
    rdfs:label 'Trauma Level' ;
    rdfs:comment 'Trauma center designation level indicating capability to provide comprehensive emergency care. Level 1 centers have the highest capability.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL for the healthcare organization. Used for digital engagement and research.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpAdvisoryBoardId rdf:type rdf:Property ;
    rdfs:label 'Hcp Advisory Board Id' ;
    rdfs:comment 'Unique identifier for the advisory board participation record. Primary key for the HCP advisory board data product.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalAffairsOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Medical Affairs Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Medical affairs employees (medical directors, therapeutic area leads) organize and manage advisory boards. Essential for advisory board planning, medical affairs activity tracking, budget management, ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agendaTopics rdf:type rdf:Property ;
    rdfs:label 'Agenda Topics' ;
    rdfs:comment 'Summary of the key topics, clinical questions, or strategic issues discussed during the advisory board meeting. Supports publication planning and medical strategy alignment.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardType rdf:type rdf:Property ;
    rdfs:label 'Board Type' ;
    rdfs:comment 'Classification of the advisory board format and purpose. Distinguishes between ongoing scientific advisory boards, one-time expert consultations, and specialized clinical or strategic advisory committees.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictOfInterestDisclosedFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Disclosed Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP disclosed any conflicts of interest prior to advisory board participation. True if COI disclosure was completed, False otherwise. Required for compliance and publication ethics.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Contract Execution Date' ;
    rdfs:comment 'The date on which the consulting contract with the HCP was fully executed by all parties. Establishes the legal basis for the engagement and payment.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpActions rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions' ;
    rdfs:comment 'Summary of agreed next steps, action items, or follow-up commitments resulting from the advisory board meeting. Supports execution tracking and strategic alignment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpRole rdf:type rdf:Property ;
    rdfs:label 'Hcp Role' ;
    rdfs:comment 'The specific role the HCP performed in the advisory board meeting. Distinguishes between leadership roles (chair, co-chair), general participation (member, consultant), and facilitation roles (speaker, moderator). Impacts honorarium calculation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honorariumCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Honorarium Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the honorarium payment. Supports multi-currency operations and accurate financial reporting across global markets.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolTier rdf:type rdf:Property ;
    rdfs:label 'Kol Tier' ;
    rdfs:comment 'The strategic tier classification of the HCP as a Key Opinion Leader at the time of advisory board participation. Tier 1 represents highest influence and reach. Supports KOL engagement strategy and resource allocation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealAccommodationAmount rdf:type rdf:Property ;
    rdfs:label 'Meal Accommodation Amount' ;
    rdfs:comment 'The total value of meals and lodging provided to the HCP during the advisory board meeting. Reportable under Sunshine Act transparency requirements.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meetingCity rdf:type rdf:Property ;
    rdfs:label 'Meeting City' ;
    rdfs:comment 'The city where the advisory board meeting took place. Required for geographic analysis and regulatory transparency reporting.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Meeting Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country where the advisory board meeting was held. Supports multi-country compliance and regional engagement analysis.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'The date on which the advisory board meeting took place. Used for tracking engagement timing and Sunshine Act reporting period assignment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingEndTime rdf:type rdf:Property ;
    rdfs:label 'Meeting End Time' ;
    rdfs:comment 'The precise timestamp when the advisory board meeting concluded. Used to calculate meeting duration and HCP time commitment.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:meetingFormat rdf:type rdf:Property ;
    rdfs:label 'Meeting Format' ;
    rdfs:comment 'The delivery format of the advisory board meeting. Distinguishes between face-to-face meetings, virtual/remote participation, and hybrid models combining both.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingLocation rdf:type rdf:Property ;
    rdfs:label 'Meeting Location' ;
    rdfs:comment 'The physical location or venue where the advisory board meeting was held. For virtual meetings, may indicate platform or note as virtual. Supports Sunshine Act venue reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingMinutesDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Meeting Minutes Document Reference' ;
    rdfs:comment 'Reference identifier to the official meeting minutes or summary document stored in the document management system (e.g., Veeva Vault). Provides audit trail and detailed record linkage.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingObjectives rdf:type rdf:Property ;
    rdfs:label 'Meeting Objectives' ;
    rdfs:comment 'The stated business or scientific objectives for convening the advisory board. Documents the strategic rationale and expected outcomes from HCP engagement.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingStartTime rdf:type rdf:Property ;
    rdfs:label 'Meeting Start Time' ;
    rdfs:comment 'The precise timestamp when the advisory board meeting commenced. Supports detailed engagement tracking and time-based compliance reporting.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'The actual participation outcome for the HCP. Distinguishes between confirmed attendance, cancellations, no-shows, and declined invitations. Impacts payment processing and engagement metrics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDiscussed rdf:type rdf:Property ;
    rdfs:label 'Product Discussed' ;
    rdfs:comment 'The investigational or marketed drug product that was the focus of the advisory board discussion. May reference INN, brand name, or development code.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'The name of the operational system from which this advisory board record originated (e.g., Veeva CRM, Salesforce Health Cloud). Supports data lineage and system-of-record identification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunshineActReportingYear rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Reporting Year' ;
    rdfs:comment 'The calendar year in which this advisory board payment must be reported to CMS Open Payments database. Determined by payment date, not meeting date.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Amount' ;
    rdfs:comment 'The aggregate value of all payments and transfers of value to the HCP for this advisory board participation, including honorarium, travel, meals, and accommodations. Used for consolidated Sunshine Act reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelReimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Travel Reimbursement Amount' ;
    rdfs:comment 'The amount reimbursed to the HCP for travel expenses related to advisory board participation. Separate from honorarium. Must be reported under Sunshine Act if applicable.' ;
    rdfs:domain ind:HcpAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affiliationId rdf:type rdf:Property ;
    rdfs:label 'Affiliation Id' ;
    rdfs:comment 'Unique identifier for the HCP affiliation relationship record. Primary key for the affiliation entity.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affiliationAffiliatedHcpPhysicianMasterId rdf:type rdf:Property ;
    rdfs:label 'Affiliation Affiliated Hcp Physician Master Id' ;
    rdfs:comment 'Foreign key reference to another HCP in HCP-to-HCP affiliation relationships (e.g., referral networks, group practice partnerships). Nullable when affiliation is HCP-to-HCO.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:mslEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Msl Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Medical Science Liaisons (MSLs) are employees who maintain scientific relationships with affiliated HCPs. Essential for MSL territory assignment, field medical activity tracking, resource planning, an' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:admittingPrivilegesFlag rdf:type rdf:Property ;
    rdfs:label 'Admitting Privileges Flag' ;
    rdfs:comment 'Boolean flag indicating whether the HCP has hospital admitting privileges at this affiliated HCO. True if the HCP can admit patients; False otherwise.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affiliationStatus rdf:type rdf:Property ;
    rdfs:label 'Affiliation Status' ;
    rdfs:comment 'Current lifecycle status of the affiliation relationship. Indicates whether the affiliation is currently valid and operational.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationType rdf:type rdf:Property ;
    rdfs:label 'Affiliation Type' ;
    rdfs:comment 'Classification of the affiliation relationship between the HCP and HCO or between two HCPs. Defines the nature of the professional relationship.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationArrangementType rdf:type rdf:Property ;
    rdfs:label 'Compensation Arrangement Type' ;
    rdfs:comment 'The type of compensation arrangement associated with this affiliation, if any. Required for Sunshine Act transparency reporting and anti-kickback compliance.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Expiration Date' ;
    rdfs:comment 'The date when the HCP\'s credentialing at this affiliated organization expires and requires renewal. Used for compliance monitoring and re-credentialing workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingStatus rdf:type rdf:Property ;
    rdfs:label 'Credentialing Status' ;
    rdfs:comment 'The current credentialing status of the HCP at this affiliated organization. Indicates whether the HCP has completed required credentialing processes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'The department, division, or practice unit within the HCO where the HCP holds this affiliation (e.g., Oncology Department, Cardiology Division).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyInfluenceLevel rdf:type rdf:Property ;
    rdfs:label 'Formulary Influence Level' ;
    rdfs:comment 'Assessment of the HCP\'s level of influence over formulary decisions at this affiliated organization. Used for Key Opinion Leader (KOL) identification and targeting.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullTimeEquivalent rdf:type rdf:Property ;
    rdfs:label 'Full Time Equivalent' ;
    rdfs:comment 'The proportion of full-time work the HCP dedicates to this affiliation, expressed as a decimal (e.g., 1.00 for full-time, 0.50 for half-time). Used for capacity planning and engagement prioritization.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryAffiliation rdf:type rdf:Property ;
    rdfs:label 'Is Primary Affiliation' ;
    rdfs:comment 'Boolean flag indicating whether this is the HCP\'s primary or main affiliation. True if this is the principal place of practice; False otherwise.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kolDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Kol Designation Flag' ;
    rdfs:comment 'Boolean flag indicating whether the HCP is designated as a Key Opinion Leader (KOL) within this affiliation context. True if KOL status applies; False otherwise.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'The date when this affiliation record was last verified or validated. Used for data quality monitoring and re-verification scheduling.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'The username or identifier of the user or system process that last modified this affiliation record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npiAtAffiliation rdf:type rdf:Property ;
    rdfs:label 'Npi At Affiliation' ;
    rdfs:comment 'The National Provider Identifier (NPI) the HCP uses at this specific affiliation. An HCP may have different NPIs for different practice locations or affiliations.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescribingAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Prescribing Authority Flag' ;
    rdfs:comment 'Boolean flag indicating whether the HCP has prescribing authority at this affiliated organization. True if the HCP can prescribe medications; False otherwise.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralDirection rdf:type rdf:Property ;
    rdfs:label 'Referral Direction' ;
    rdfs:comment 'The direction of patient referrals in this affiliation relationship. Indicates whether the HCP receives referrals, sends referrals, or both.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralRelationshipFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Relationship Flag' ;
    rdfs:comment 'Boolean flag indicating whether this affiliation represents a referral relationship (HCP-to-HCP). True if the affiliation involves patient referrals; False otherwise.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'The professional role or job title the HCP holds within this affiliation (e.g., Chief of Cardiology, Attending Physician, Clinical Director, Partner).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyAtAffiliation rdf:type rdf:Property ;
    rdfs:label 'Specialty At Affiliation' ;
    rdfs:comment 'The medical specialty or therapeutic area the HCP practices within this specific affiliation. May differ from the HCP\'s primary specialty if they hold multiple affiliations.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'State License Number' ;
    rdfs:comment 'The state medical license number the HCP holds for practice at this affiliated organization. Required for credentialing and compliance verification.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthScore rdf:type rdf:Property ;
    rdfs:label 'Strength Score' ;
    rdfs:comment 'Quantitative measure of the strength or influence of this affiliation relationship, typically ranging from 0.00 to 100.00. Used for network mapping and prescribing influence analysis.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'The verification status of this affiliation record. Indicates whether the affiliation has been confirmed through primary source verification or other validation processes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Employee Id' ;
    rdfs:comment 'Reference to the compliance officer who approved this contract. Supports accountability and audit requirements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contractLegalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Legal Reviewer Employee Id' ;
    rdfs:comment 'Reference to the legal counsel who reviewed this contract. Supports accountability and audit requirements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:financeAccountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Finance Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: HCP contracts should link to finance accounts payable for HCP payment processing and financial tracking. This enables integrated HCP engagement and payment management with proper financial controls.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:annualCapAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Cap Amount' ;
    rdfs:comment 'Maximum total compensation in USD that can be paid to the HCP under this contract in a calendar year. Enforces anti-kickback compliance and prevents excessive payments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the contract. Used for legal reference, payment processing, and audit trails.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the contract. Controls whether payments can be processed and services can be rendered.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the contract based on the nature of services provided by the HCP. Determines applicable compliance rules and FMV benchmarks.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Screening Date' ;
    rdfs:comment 'Date when the most recent exclusion screening was performed. Must be refreshed monthly per OIG guidance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusionScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Exclusion Screening Status' ;
    rdfs:comment 'Result of screening the HCP against government exclusion lists (OIG, GSA SAM, FDA Debarment). Must be cleared before contract execution and payment.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaDebarmentScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Fda Debarment Screening Result' ;
    rdfs:comment 'Result of screening against the FDA Debarment List. Debarred individuals cannot participate in drug development or approval processes.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmvMethodology rdf:type rdf:Property ;
    rdfs:label 'Fmv Methodology' ;
    rdfs:comment 'Methodology used to determine the FMV rate for this contract. Documents compliance with anti-kickback regulations and ensures defensible compensation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmvRateType rdf:type rdf:Property ;
    rdfs:label 'Fmv Rate Type' ;
    rdfs:comment 'Unit basis for the FMV compensation rate. Determines how payments are calculated and validated against caps.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honorariumRate rdf:type rdf:Property ;
    rdfs:label 'Honorarium Rate' ;
    rdfs:comment 'Fixed honorarium amount in USD for per-engagement or per-deliverable contracts. Used for speaker programs and advisory board participation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hourlyRateMax rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate Max' ;
    rdfs:comment 'Maximum hourly compensation rate in USD for services rendered under this contract. Part of the FMV range used for compliance validation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hourlyRateMin rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate Min' ;
    rdfs:comment 'Minimum hourly compensation rate in USD for services rendered under this contract. Part of the FMV range used for compliance validation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oigScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Oig Screening Result' ;
    rdfs:comment 'Result of screening against the OIG List of Excluded Individuals and Entities. HCPs on the exclusion list cannot receive federal healthcare program payments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Sam Screening Result' ;
    rdfs:comment 'Result of screening against the GSA System for Award Management exclusion list. Ensures HCP is not debarred from federal contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Detailed description of the services the HCP will provide under this contract. Defines deliverables, expectations, and compliance boundaries.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialty rdf:type rdf:Property ;
    rdfs:label 'Specialty' ;
    rdfs:comment 'Medical specialty of the HCP relevant to this contract. Used for FMV rate benchmarking and compliance validation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpKolProfileId rdf:type rdf:Property ;
    rdfs:label 'Hcp Kol Profile Id' ;
    rdfs:comment 'Unique identifier for the KOL profile record. Primary key for the HCP KOL profile entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HcpKolProfile .

ind:primaryTherapeuticAreaId rdf:type rdf:Property ;
    rdfs:label 'Primary Therapeutic Area Id' ;
    rdfs:comment 'Foreign key linking to product.therapeutic_area. Business justification: KOL profiles are segmented by therapeutic area for medical affairs targeting, MSL assignment, and engagement strategy planning. Replaces denormalized primary_therapeutic_area text with structured FK f' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TherapeuticArea .

ind:academicRank rdf:type rdf:Property ;
    rdfs:label 'Academic Rank' ;
    rdfs:comment 'The KOL\'s academic title or rank at their primary affiliated institution. Indicates seniority, teaching responsibilities, and academic influence. [ENUM-REF-CANDIDATE: professor|associate_professor|assistant_professor|clinical_instructor|adjunct_faculty|emeritus|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advisoryBoardParticipationCount rdf:type rdf:Property ;
    rdfs:label 'Advisory Board Participation Count' ;
    rdfs:comment 'Total number of advisory board meetings or panels the KOL has participated in. Indicates level of industry engagement and strategic advisory experience.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinicalTrialInvestigatorFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Investigator Flag' ;
    rdfs:comment 'Indicates whether the KOL has served as a principal investigator (PI) or sub-investigator on clinical trials. True if the HCP has investigator experience, false otherwise. Used to identify KOLs with hands-on clinical research expertise.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Clearance Date' ;
    rdfs:comment 'Date when the most recent compliance clearance was completed and approved. Used to track clearance currency and schedule re-verification.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceClearanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Clearance Expiry Date' ;
    rdfs:comment 'Date when the current compliance clearance expires and re-verification is required. Used to proactively manage compliance renewal workflows.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Clearance Status' ;
    rdfs:comment 'Current compliance and credentialing clearance status for the KOL. Cleared indicates the KOL has passed all compliance checks and is eligible for engagement, pending indicates review in progress, flagged indicates potential compliance concerns requiring investigation, excluded indicates the KOL is on an exclusion list (OIG, SAM) and cannot be engaged, and expired indicates clearance has lapsed and requires renewal.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictOfInterestDisclosure rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Disclosure' ;
    rdfs:comment 'Summary of disclosed conflicts of interest, including financial relationships with other pharmaceutical or medical device companies, equity holdings, consulting arrangements, or advisory roles. Used to manage transparency and mitigate bias in scientific engagements.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressSpeakingCount rdf:type rdf:Property ;
    rdfs:label 'Congress Speaking Count' ;
    rdfs:comment 'Number of presentations, lectures, or speaking engagements the KOL has delivered at medical congresses, symposia, or scientific conferences. Reflects public visibility and thought leadership.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departmentChairFlag rdf:type rdf:Property ;
    rdfs:label 'Department Chair Flag' ;
    rdfs:comment 'Indicates whether the KOL serves as a department chair or division head at their primary institution. True if the KOL holds a leadership position, false otherwise. Reflects institutional leadership and decision-making authority.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fellowshipInstitution rdf:type rdf:Property ;
    rdfs:label 'Fellowship Institution' ;
    rdfs:comment 'Name of the institution where the KOL completed their fellowship training. Indicates specialized training and institutional network.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineAuthorshipFlag rdf:type rdf:Property ;
    rdfs:label 'Guideline Authorship Flag' ;
    rdfs:comment 'Indicates whether the KOL has authored or co-authored clinical practice guidelines, consensus statements, or treatment recommendations. True if guideline authorship exists, false otherwise. Reflects standard-of-care influence.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hIndex rdf:type rdf:Property ;
    rdfs:label 'H Index' ;
    rdfs:comment 'Hirsch index measuring the productivity and citation impact of the KOL\'s published work. An h-index of n means the researcher has n publications with at least n citations each. Used to quantify scientific influence and publication quality.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kolStatus rdf:type rdf:Property ;
    rdfs:label 'Kol Status' ;
    rdfs:comment 'Current lifecycle status of the KOL profile. Active KOLs are eligible for engagement, under review indicates pending compliance or credentialing checks, suspended indicates temporary ineligibility, retired indicates the HCP is no longer practicing, and deceased indicates the HCP has passed away.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCongressSpeakingDate rdf:type rdf:Property ;
    rdfs:label 'Last Congress Speaking Date' ;
    rdfs:comment 'Date of the most recent congress or conference speaking engagement by the KOL. Used to assess recency of public thought leadership activity.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMslInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Msl Interaction Date' ;
    rdfs:comment 'Date of the most recent interaction or engagement between an MSL and the KOL. Used to track engagement recency and plan follow-up activities.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Last Publication Date' ;
    rdfs:comment 'Date of the KOL\'s most recent peer-reviewed publication. Indicates currency of scientific contribution and active research status.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalSchool rdf:type rdf:Property ;
    rdfs:label 'Medical School' ;
    rdfs:comment 'Name of the medical school or institution where the KOL obtained their medical degree. Provides context on educational background and institutional affiliations.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mslEngagementStrategy rdf:type rdf:Property ;
    rdfs:label 'Msl Engagement Strategy' ;
    rdfs:comment 'Strategic priority level for Medical Science Liaison engagement with this KOL. High priority KOLs receive frequent proactive outreach, medium priority receive periodic engagement, low priority are engaged opportunistically, monitor only are tracked but not actively engaged, and do not contact indicates compliance or relationship restrictions.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orcidNumber rdf:type rdf:Property ;
    rdfs:label 'Orcid Number' ;
    rdfs:comment 'Unique persistent digital identifier for the researcher, used to disambiguate authors and link research outputs. Format: 0000-0000-0000-0000.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peerReviewedPublicationCount rdf:type rdf:Property ;
    rdfs:label 'Peer Reviewed Publication Count' ;
    rdfs:comment 'Total number of peer-reviewed journal articles, reviews, and original research publications authored or co-authored by the KOL. Reflects scientific productivity and contribution to medical literature.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAffiliation rdf:type rdf:Property ;
    rdfs:label 'Primary Affiliation' ;
    rdfs:comment 'The main hospital, academic medical center, research institution, or healthcare organization where the KOL holds a primary appointment or practices. Critical for understanding institutional influence and access.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalInvestigatorTrialCount rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Trial Count' ;
    rdfs:comment 'Number of clinical trials where the KOL has served as the principal investigator. Reflects depth of clinical research leadership and trial management experience.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Created Timestamp' ;
    rdfs:comment 'Timestamp when the KOL profile record was first created in the system. Used for audit trail and data lineage tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Profile Updated By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last updated the KOL profile record. Used for audit trail and accountability.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Updated Timestamp' ;
    rdfs:comment 'Timestamp when the KOL profile record was most recently updated. Used for audit trail, change tracking, and data currency assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scopusAuthorNumber rdf:type rdf:Property ;
    rdfs:label 'Scopus Author Number' ;
    rdfs:comment 'Unique identifier assigned by Elsevier Scopus to track the KOL\'s publications and citation metrics. Used for bibliometric analysis and publication tracking.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryTherapeuticAreas rdf:type rdf:Property ;
    rdfs:label 'Secondary Therapeutic Areas' ;
    rdfs:comment 'Additional therapeutic areas where the KOL has recognized expertise or active research involvement. Stored as a delimited list to support multi-specialty KOLs.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:societyLeadershipFlag rdf:type rdf:Property ;
    rdfs:label 'Society Leadership Flag' ;
    rdfs:comment 'Indicates whether the KOL holds or has held a leadership position (board member, committee chair, president) in a professional medical society. True if leadership role exists, false otherwise. Reflects industry influence and governance participation.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:societyMembershipList rdf:type rdf:Property ;
    rdfs:label 'Society Membership List' ;
    rdfs:comment 'List of professional medical societies, associations, or organizations where the KOL holds membership. Examples include American Society of Clinical Oncology (ASCO), American College of Cardiology (ACC), European Society for Medical Oncology (ESMO). Stored as delimited text.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCitationCount rdf:type rdf:Property ;
    rdfs:label 'Total Citation Count' ;
    rdfs:comment 'Cumulative number of citations received across all of the KOL\'s published works. Indicates the breadth of scientific impact and recognition within the research community.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMslInteractionCount rdf:type rdf:Property ;
    rdfs:label 'Total Msl Interaction Count' ;
    rdfs:comment 'Cumulative number of documented interactions between MSLs and the KOL. Reflects depth of relationship and engagement history.' ;
    rdfs:domain ind:HcpKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseId rdf:type rdf:Property ;
    rdfs:label 'License Id' ;
    rdfs:comment 'Unique identifier for the HCP license record. Primary key for the HCP license entity.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardName rdf:type rdf:Property ;
    rdfs:label 'Board Name' ;
    rdfs:comment 'The name of the medical board that issued the board certification. Examples: American Board of Internal Medicine, American Board of Surgery. Applicable only for board certification license types.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'The level of board certification status. Board certified indicates full certification; board eligible indicates eligibility but not yet certified; recertified indicates successful recertification.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstanceAuthority rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Authority' ;
    rdfs:comment 'Indicates whether this license grants the HCP authority to prescribe controlled substances. True if authorized; False otherwise. Requires valid DEA registration.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Data Source Record Reference' ;
    rdfs:comment 'The unique identifier of this license record in the source system. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deaSchedule rdf:type rdf:Property ;
    rdfs:label 'Dea Schedule' ;
    rdfs:comment 'The controlled substance schedules the HCP is authorized to prescribe under their DEA registration. Applicable only for DEA registration license types. Critical for compliance with controlled substance regulations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionDescription rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Description' ;
    rdfs:comment 'Detailed description of any disciplinary actions, sanctions, or restrictions associated with the license. Includes nature of action, date, and resolution status. Used for compliance risk assessment.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Flag' ;
    rdfs:comment 'Indicates whether the license has any associated disciplinary actions, sanctions, or restrictions. True if disciplinary action exists; False otherwise. Triggers compliance review before HCP engagement.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingCountry rdf:type rdf:Property ;
    rdfs:label 'Issuing Country' ;
    rdfs:comment 'The country where the license was issued. Uses three-letter ISO country code. Primarily USA for domestic operations, but may include other countries for global HCP engagement. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|DEU|FRA|JPN|CHN|IND|BRA|AUS — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingState rdf:type rdf:Property ;
    rdfs:label 'Issuing State' ;
    rdfs:comment 'The U.S. state or jurisdiction where the license was issued. Uses two-letter state abbreviation (e.g., CA, NY, TX). For federal licenses like DEA, this may indicate the primary registration state.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The unique license or credential number issued by the licensing authority. This is the official identifier on the license certificate.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current status of the license in its lifecycle. Active licenses are valid for HCP engagement; expired, suspended, or revoked licenses require compliance review before any promotional or medical interaction.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'The category of professional license or credential. Distinguishes between medical licenses, DEA (Drug Enforcement Administration) registrations, board certifications, and specialty credentials. [ENUM-REF-CANDIDATE: medical_license|dea_registration|board_certification|specialty_credential|state_pharmacy_license|nursing_license|controlled_substance_license — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescribingAuthority rdf:type rdf:Property ;
    rdfs:label 'Prescribing Authority' ;
    rdfs:comment 'Indicates whether this license grants the HCP authority to prescribe medications. True if the license allows prescribing; False otherwise. Used to validate HCP eligibility for promotional activities and sample distribution.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Primary License Flag' ;
    rdfs:comment 'Indicates whether this is the HCP\'s primary or principal license. True if primary; False if secondary or supplementary. Used to identify the main license for compliance validation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Record Active Flag' ;
    rdfs:comment 'Indicates whether this license record is currently active in the system. True if active; False if logically deleted or archived. Used for soft delete pattern.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The most recent date the license was renewed. Tracks renewal history for compliance and audit purposes. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Restriction Description' ;
    rdfs:comment 'Detailed description of any restrictions or limitations on the license. Specifies the nature and scope of restrictions for compliance purposes.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Restriction Flag' ;
    rdfs:comment 'Indicates whether the license has any practice restrictions or limitations. True if restrictions exist; False otherwise. Examples: limited to certain procedures, supervision required, geographic restrictions.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyCode rdf:type rdf:Property ;
    rdfs:label 'Specialty Code' ;
    rdfs:comment 'Standardized code representing the medical specialty. May use AMA specialty taxonomy codes or internal classification codes for analytics and reporting.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date the license was last verified against the issuing authority\'s records. Used for compliance audit trails and to ensure data accuracy. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to verify the license. Manual indicates human review; automated indicates system-based verification; third_party_service indicates use of external verification vendors; self_reported indicates HCP-provided data pending verification.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The name of the source used to verify the license. Examples: State Medical Board website, NPPES (National Plan and Provider Enumeration System), third-party credentialing service.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Board Certification Date' ;
    rdfs:comment 'Date when the HCP achieved board certification in their primary specialty.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardCertificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Board Certification Expiration Date' ;
    rdfs:comment 'Expiration date of the current board certification. Requires renewal to maintain certified status.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Board Certification Status' ;
    rdfs:comment 'Current status of board certification for the HCP in their primary specialty.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the healthcare professional. Used for identity verification and credential validation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Dea Expiration Date' ;
    rdfs:comment 'Expiration date of the DEA controlled substance registration. Requires renewal every three years.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deaStatus rdf:type rdf:Property ;
    rdfs:label 'Dea Status' ;
    rdfs:comment 'Current status of the DEA controlled substance registration.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSourceCode rdf:type rdf:Property ;
    rdfs:label 'External Source Code' ;
    rdfs:comment 'Unique identifier for this HCP in the external source system (e.g., IQVIA OneKey ID, Veeva CRM Account ID). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Gender identity of the healthcare professional as self-reported or registered.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpStatus rdf:type rdf:Property ;
    rdfs:label 'Hcp Status' ;
    rdfs:comment 'Current lifecycle status of the HCP record in the master data system. Active indicates the HCP is currently practicing and eligible for engagement.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Primary Email Address' ;
    rdfs:comment 'Primary email address for professional communication with the HCP.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Primary License Expiration Date' ;
    rdfs:comment 'Expiration date of the primary medical license. Requires renewal to maintain active practice authority.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryLicenseIssueDate rdf:type rdf:Property ;
    rdfs:label 'Primary License Issue Date' ;
    rdfs:comment 'Date when the primary medical license was originally issued by the state medical board.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Primary License Number' ;
    rdfs:comment 'Primary state medical license number issued by the state medical board. Authoritative credential for legal practice authority.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseState rdf:type rdf:Property ;
    rdfs:label 'Primary License State' ;
    rdfs:comment 'Two-letter US state code for the jurisdiction that issued the primary medical license (e.g., CA, NY, TX).' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseStatus rdf:type rdf:Property ;
    rdfs:label 'Primary License Status' ;
    rdfs:comment 'Current status of the primary medical license as reported by the state medical board.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Primary Phone Number' ;
    rdfs:comment 'Primary contact phone number for the HCP at their practice location.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Address Line1' ;
    rdfs:comment 'First line of the primary practice address where the HCP sees patients (street address, building number).' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Address Line2' ;
    rdfs:comment 'Second line of the primary practice address (suite, floor, department).' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeCity rdf:type rdf:Property ;
    rdfs:label 'Primary Practice City' ;
    rdfs:comment 'City of the primary practice location.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeCountry rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Country' ;
    rdfs:comment 'Three-letter ISO country code for the primary practice location (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticePostalCode rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Postal Code' ;
    rdfs:comment 'ZIP code or postal code of the primary practice location. Format: 5 digits or 5+4 digits.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeState rdf:type rdf:Property ;
    rdfs:label 'Primary Practice State' ;
    rdfs:comment 'Two-letter US state code for the primary practice location (e.g., CA, NY, TX).' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySpecialty rdf:type rdf:Property ;
    rdfs:label 'Primary Specialty' ;
    rdfs:comment 'Primary medical specialty or therapeutic area of practice for the HCP (e.g., Oncology, Cardiology, Immunology). Aligned with AMA specialty taxonomy.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalDesignation rdf:type rdf:Property ;
    rdfs:label 'Professional Designation' ;
    rdfs:comment 'Professional designation or degree type of the healthcare professional (e.g., MD for Medical Doctor, DO for Doctor of Osteopathic Medicine, PharmD for Doctor of Pharmacy). [ENUM-REF-CANDIDATE: MD|DO|PharmD|RN|NP|PA|DDS|DVM|PhD|Other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondarySpecialty rdf:type rdf:Property ;
    rdfs:label 'Secondary Specialty' ;
    rdfs:comment 'Secondary or sub-specialty area of practice for the HCP, if applicable.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suffix rdf:type rdf:Property ;
    rdfs:label 'Suffix' ;
    rdfs:comment 'Professional or generational suffix appended to the HCP name (e.g., Jr., Sr., MD, PhD). [ENUM-REF-CANDIDATE: Jr|Sr|II|III|IV|V|MD|DO|PhD|PharmD|RN|NP|PA — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpPublicationId rdf:type rdf:Property ;
    rdfs:label 'Hcp Publication Id' ;
    rdfs:comment 'Unique identifier for the HCP publication record. Primary key for the publication entity.' ;
    rdfs:domain ind:HcpPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalAffairsAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Medical Affairs Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Medical affairs employees track and analyze HCP publications for scientific intelligence and KOL profiling. Required for publication tracking workflows, KOL tier assessment, competitive intelligence, ' ;
    rdfs:domain ind:HcpPublication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abstractText rdf:type rdf:Property ;
    rdfs:label 'Abstract Text' ;
    rdfs:comment 'Full text of the publication abstract. Used for natural language processing, topic modeling, and competitive intelligence analysis.' ;
    rdfs:domain ind:HcpPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationAtPublication rdf:type rdf:Property ;
    rdfs:label 'Affiliation At Publication' ;
    rdfs:comment 'Institutional affiliation of the HCP as listed in the publication byline at the time of publication. May differ from current affiliation in HCP master data.' ;
    rdfs:domain ind:HcpPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorOrder rdf:type rdf:Property ;
    rdfs:label 'Author Order' ;
    rdfs:comment 'Numeric position of the HCP in the author list (1 = first author, 2 = second author, etc.). First and last author positions typically indicate greater contribution and influence.' ;
    rdfs:domain ind:HcpPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:citationCount rdf:type rdf:Property ;
    rdfs:label 'Citation Count' ;
    rdfs:comment 'Number of times this publication has been cited by other peer-reviewed articles. Used to assess KOL influence and publication impact.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:companyProductMentioned rdf:type rdf:Property ;
    rdfs:label 'Company Product Mentioned' ;
    rdfs:comment 'Name of the company product (brand name or INN) mentioned or studied in the publication. May be null if publication is not product-specific.' ;
    rdfs:domain ind:HcpPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companySponsoredFlag rdf:type rdf:Property ;
    rdfs:label 'Company Sponsored Flag' ;
    rdfs:comment 'Indicates whether the publication was sponsored, funded, or supported by the company. Critical for Sunshine Act transparency reporting and compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictOfInterestDisclosed rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Disclosed' ;
    rdfs:comment 'Indicates whether the HCP disclosed a conflict of interest or financial relationship with the company in the publication. Required for transparency and compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correspondingAuthorFlag rdf:type rdf:Property ;
    rdfs:label 'Corresponding Author Flag' ;
    rdfs:comment 'Indicates whether the HCP is the corresponding author for this publication. Corresponding authors are primary contacts and typically have leadership roles.' ;
    rdfs:domain ind:HcpPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doi rdf:type rdf:Property ;
    rdfs:label 'Doi' ;
    rdfs:comment 'Persistent digital identifier for the publication used for permanent linking and citation. Format: 10.xxxx/xxxxx.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactFactor rdf:type rdf:Property ;
    rdfs:label 'Impact Factor' ;
    rdfs:comment 'Journal Impact Factor (JIF) at the time of publication. Measures the average number of citations to articles published in the journal. Higher values indicate greater influence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalName rdf:type rdf:Property ;
    rdfs:label 'Journal Name' ;
    rdfs:comment 'Name of the peer-reviewed journal, conference proceedings, or publication venue where the article was published.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or MeSH terms associated with the publication. Used for search, categorization, and topic analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolTierAtPublication rdf:type rdf:Property ;
    rdfs:label 'Kol Tier At Publication' ;
    rdfs:comment 'KOL tier classification of the HCP at the time of publication. Captures historical KOL status for longitudinal influence tracking.' ;
    rdfs:domain ind:HcpPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code of the publication. Used for filtering and regional relevance assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Open Access Flag' ;
    rdfs:comment 'Indicates whether the publication is available as open access (freely accessible to the public without subscription).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peerReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Peer Reviewed Flag' ;
    rdfs:comment 'Indicates whether the publication underwent formal peer review before acceptance. Peer-reviewed publications carry higher scientific credibility.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productRelevance rdf:type rdf:Property ;
    rdfs:label 'Product Relevance' ;
    rdfs:comment 'Assessment of how relevant this publication is to the company\'s marketed or pipeline products. Used for competitive intelligence and medical affairs strategy.' ;
    rdfs:domain ind:HcpPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle status of the publication. Tracks whether the article is officially published, pending, or has been retracted or corrected.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationType rdf:type rdf:Property ;
    rdfs:label 'Publication Type' ;
    rdfs:comment 'Classification of the publication based on its content and format. Determines the level of evidence and influence in medical affairs planning. [ENUM-REF-CANDIDATE: original research|review article|systematic review|meta-analysis|case report|editorial|commentary|letter to editor — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pubmedNumber rdf:type rdf:Property ;
    rdfs:label 'Pubmed Number' ;
    rdfs:comment 'Unique identifier assigned by the National Library of Medicine PubMed database. Used for citation tracking and literature searches.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'Direct URL link to the full-text publication on the publisher\'s website or repository.' ;
    rdfs:domain ind:HcpPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpSpeakerProgramId rdf:type rdf:Property ;
    rdfs:label 'Hcp Speaker Program Id' ;
    rdfs:comment 'Unique identifier for the HCP speaker program record. Primary key for the speaker program entity.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HcpSpeakerProgram .

ind:programManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Medical affairs or commercial training employees manage speaker programs including logistics, compliance oversight, and coordination. Required for speaker program management, compliance oversight, bud' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:audienceSize rdf:type rdf:Property ;
    rdfs:label 'Audience Size' ;
    rdfs:comment 'Number of healthcare professionals who attended the speaker program event. Used for reach metrics and ROI analysis.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Date' ;
    rdfs:comment 'Date when the HCP completed mandatory compliance training covering anti-kickback regulations, Sunshine Act reporting, and promotional guidelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Status' ;
    rdfs:comment 'Current status of the HCP compliance certification. Must be current to participate in speaker programs.' ;
    rdfs:domain ind:HcpSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the speaker bureau contract becomes effective and binding.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the speaker bureau contract expires. Requires renewal to continue the speaker relationship.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:honorariumPaidUsd rdf:type rdf:Property ;
    rdfs:label 'Honorarium Paid Usd' ;
    rdfs:comment 'Actual honorarium payment in US Dollars made to the HCP for delivering the speaker program. Component of total spend and Sunshine Act reportable value.' ;
    rdfs:domain ind:HcpSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:honorariumRateUsd rdf:type rdf:Property ;
    rdfs:label 'Honorarium Rate Usd' ;
    rdfs:comment 'Standard honorarium payment rate in US Dollars per speaker program event. Rate varies by speaker tier and program type.' ;
    rdfs:domain ind:HcpSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialsUsed rdf:type rdf:Property ;
    rdfs:label 'Materials Used' ;
    rdfs:comment 'List or description of promotional materials, slide decks, and educational content used during the speaker program. Must be Medical Legal Regulatory (MLR) approved.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlrApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Mlr Approval Number' ;
    rdfs:comment 'Approval reference number from Medical Legal Regulatory review for the materials used in the speaker program. Ensures promotional compliance.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEventNumber rdf:type rdf:Property ;
    rdfs:label 'Program Event Number' ;
    rdfs:comment 'Business identifier for the individual speaker program event. Externally visible unique code used for tracking and compliance reporting.' ;
    rdfs:domain ind:HcpSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programsDeliveredCount rdf:type rdf:Property ;
    rdfs:label 'Programs Delivered Count' ;
    rdfs:comment 'Cumulative count of speaker programs delivered by this HCP to date. Used for speaker performance tracking and tier progression.' ;
    rdfs:domain ind:HcpSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speakerPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Speaker Performance Rating' ;
    rdfs:comment 'Quantitative performance rating for the speaker program event on a scale of 0.00 to 5.00. Based on audience feedback, content delivery, and engagement metrics.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speakerTier rdf:type rdf:Property ;
    rdfs:label 'Speaker Tier' ;
    rdfs:comment 'Classification of the speaker based on expertise, reach, and engagement level. Determines honorarium rates and program eligibility.' ;
    rdfs:domain ind:HcpSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunshineActReportedDate rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Reported Date' ;
    rdfs:comment 'Date when the transfer of value for this speaker program was submitted to the CMS Open Payments database for Sunshine Act compliance.' ;
    rdfs:domain ind:HcpSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Total Spend Usd' ;
    rdfs:comment 'Total expenditure in US Dollars for the speaker program event including honorarium, venue costs, meals, and materials. Reportable transfer of value under Sunshine Act.' ;
    rdfs:domain ind:HcpSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Training Expiration Date' ;
    rdfs:comment 'Date when the speaker training certification expires. Requires recertification to continue delivering programs.' ;
    rdfs:domain ind:HcpSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalMonitorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Clinical Monitor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Clinical Research Associates (CRAs) and clinical managers (employees) manage investigator relationships and site oversight. Essential for investigator management, site monitoring assignments, clinical' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeTrialsCount rdf:type rdf:Property ;
    rdfs:label 'Active Trials Count' ;
    rdfs:comment 'Number of clinical trials currently active for this investigator. Used to assess investigator capacity and workload.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageEnrollmentRate rdf:type rdf:Property ;
    rdfs:label 'Average Enrollment Rate' ;
    rdfs:comment 'Average number of subjects enrolled per month by this investigator. Calculated metric used for trial planning and site selection.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conflictOfInterestDeclared rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Declared' ;
    rdfs:comment 'Indicates whether the investigator has declared any financial or other conflicts of interest that could affect trial conduct or data integrity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Cv Last Updated Date' ;
    rdfs:comment 'Date when the investigator\'s curriculum vitae was last updated in the system.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cvOnFile rdf:type rdf:Property ;
    rdfs:label 'Cv On File' ;
    rdfs:comment 'Indicates whether a current curriculum vitae is on file for the investigator. CV is required for regulatory submissions and site qualification.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disqualificationDate rdf:type rdf:Property ;
    rdfs:label 'Disqualification Date' ;
    rdfs:comment 'Date when the investigator was disqualified from conducting clinical trials, either by regulatory authority or company decision.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason for investigator disqualification. May include regulatory violations, data integrity issues, or non-compliance with GCP.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fda1572OnFile rdf:type rdf:Property ;
    rdfs:label 'Fda 1572 On File' ;
    rdfs:comment 'Indicates whether a signed FDA Form 1572 (Statement of Investigator) is on file. Required for all US-based clinical trials.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fda1572SignatureDate rdf:type rdf:Property ;
    rdfs:label 'Fda 1572 Signature Date' ;
    rdfs:comment 'Date when the investigator signed the FDA Form 1572 for the current protocol assignment.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Completion Date' ;
    rdfs:comment 'Date when the investigator completed their most recent GCP training certification.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Expiration Date' ;
    rdfs:comment 'Date when the investigator\'s current GCP training certification expires. Investigators must renew training to remain qualified.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingStatus rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Status' ;
    rdfs:comment 'Status of the investigator\'s GCP training certification. GCP training is mandatory for all clinical trial investigators per ICH guidelines.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedTrialFlag rdf:type rdf:Property ;
    rdfs:label 'Initiated Trial Flag' ;
    rdfs:comment 'Indicates whether the investigator has conducted or is conducting investigator-initiated trials (IIT) with company products. IITs are investigator-led studies.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorNumber rdf:type rdf:Property ;
    rdfs:label 'Investigator Number' ;
    rdfs:comment 'Business identifier assigned to the investigator for tracking across clinical trials. May be company-specific or protocol-specific.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Expiration Date' ;
    rdfs:comment 'Date when the current IRB approval expires. Investigators must obtain renewal to continue trial activities.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kolInvestigatorFlag rdf:type rdf:Property ;
    rdfs:label 'Kol Investigator Flag' ;
    rdfs:comment 'Indicates whether the investigator is also classified as a Key Opinion Leader (KOL) in their therapeutic area. KOL investigators have additional engagement opportunities.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date when the investigator\'s performance was last formally reviewed by clinical operations or medical affairs.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Overall performance rating assigned to the investigator based on enrollment, data quality, compliance, and site management. Used for future site selection decisions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Count' ;
    rdfs:comment 'Total number of protocol deviations reported for this investigator across all trials. Quality metric for investigator performance assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the investigator was formally qualified to conduct clinical trials for the company. Represents completion of all qualification requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondaryTherapeuticArea rdf:type rdf:Property ;
    rdfs:label 'Secondary Therapeutic Area' ;
    rdfs:comment 'Secondary therapeutic area of expertise for the investigator. Supports cross-functional trial assignments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousProtocolDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Serious Protocol Deviation Count' ;
    rdfs:comment 'Number of serious protocol deviations reported for this investigator. Serious deviations may impact subject safety or data integrity.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSubjectsEnrolled rdf:type rdf:Property ;
    rdfs:label 'Total Subjects Enrolled' ;
    rdfs:comment 'Cumulative number of subjects enrolled by this investigator across all trials. Key performance indicator for investigator productivity.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTrialsConducted rdf:type rdf:Property ;
    rdfs:label 'Total Trials Conducted' ;
    rdfs:comment 'Total number of clinical trials the investigator has conducted as PI or sub-investigator. Performance metric for investigator selection.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medInfoRequestId rdf:type rdf:Property ;
    rdfs:label 'Med Info Request Id' ;
    rdfs:comment 'Unique identifier for the medical information request. Primary key.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icsrId rdf:type rdf:Property ;
    rdfs:label 'Icsr Id' ;
    rdfs:comment 'Reference to the individual case safety report (ICSR) or adverse event case created as a result of this medical information request.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Icsr .

ind:responderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responder Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Medical information specialists (employees) respond to HCP medical inquiries. Required for medical information response tracking, workload management, quality metrics, turnaround time analysis, and re' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adverseEventFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Flag' ;
    rdfs:comment 'Indicates whether the medical information request contained or led to the identification of a potential adverse event requiring pharmacovigilance follow-up.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the medical information specialist or medical affairs team member assigned to handle the request.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressDate rdf:type rdf:Property ;
    rdfs:label 'Congress Date' ;
    rdfs:comment 'Date of the medical congress or scientific meeting where the request was received.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the medical information request was escalated to senior medical affairs leadership or pharmacovigilance for adverse event (AE) follow-up.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Reason for escalating the medical information request, such as potential adverse event, off-label inquiry requiring legal review, or complex clinical question.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpSpecialty rdf:type rdf:Property ;
    rdfs:label 'Hcp Specialty' ;
    rdfs:comment 'Medical specialty of the healthcare professional who submitted the request (e.g., oncology, cardiology, neurology).' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:literatureReferences rdf:type rdf:Property ;
    rdfs:label 'Literature References' ;
    rdfs:comment 'Citations or references to published clinical literature, prescribing information, or regulatory documents used in the medical information response.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offLabelInquiryFlag rdf:type rdf:Property ;
    rdfs:label 'Off Label Inquiry Flag' ;
    rdfs:comment 'Indicates whether the medical information request pertained to an off-label use of the product not covered by approved labeling.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:questionCategory rdf:type rdf:Property ;
    rdfs:label 'Question Category' ;
    rdfs:comment 'Classification of the medical information question type (clinical efficacy, safety and tolerability, dosing and administration, off-label use, pharmacokinetics, drug interaction, or contraindication). [ENUM-REF-CANDIDATE: clinical_efficacy|safety_tolerability|dosing_administration|off_label_use|pharmacokinetics|drug_interaction|contraindication — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:questionText rdf:type rdf:Property ;
    rdfs:label 'Question Text' ;
    rdfs:comment 'Full text of the medical information question submitted by the healthcare professional.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestChannel rdf:type rdf:Property ;
    rdfs:label 'Request Channel' ;
    rdfs:comment 'Channel through which the medical information request was received (phone, email, congress, field interaction, web portal, or fax).' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the medical information request was received by the medical affairs or medical information team.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business identifier for the medical information request, externally visible and used for tracking and reference.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestPriority rdf:type rdf:Property ;
    rdfs:label 'Request Priority' ;
    rdfs:comment 'Priority level assigned to the medical information request based on urgency and clinical need.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the medical information request (received, in review, pending approval, responded, closed, or escalated).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Precise timestamp when the medical information request was logged in the system.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requesterCountryCode rdf:type rdf:Property ;
    rdfs:label 'Requester Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the healthcare professional who submitted the request is located.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Date when the medical information response was provided to the healthcare professional.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseText rdf:type rdf:Property ;
    rdfs:label 'Response Text' ;
    rdfs:comment 'Full text of the medical information response provided to the healthcare professional, including references to clinical data and approved labeling.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Precise timestamp when the medical information response was sent or delivered.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Response Turnaround Hours' ;
    rdfs:comment 'Number of hours elapsed between request receipt and response delivery, used for service level agreement (SLA) tracking.' ;
    rdfs:domain ind:MedInfoRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prescribingPatternId rdf:type rdf:Property ;
    rdfs:label 'Prescribing Pattern Id' ;
    rdfs:comment 'Unique identifier for the prescribing pattern record.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageDecisionId rdf:type rdf:Property ;
    rdfs:label 'Coverage Decision Id' ;
    rdfs:comment 'Foreign key linking to market.coverage_decision. Business justification: Coverage decisions (PA, step therapy, restrictions) directly drive prescribing patterns. Market access teams measure prescribing impact of coverage policy changes. Fundamental relationship for access ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoverageDecision .

ind:averageDaysSupply rdf:type rdf:Property ;
    rdfs:label 'Average Days Supply' ;
    rdfs:comment 'Average number of days supply per prescription written by the HCP for the product.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandPrescriptions rdf:type rdf:Property ;
    rdfs:label 'Brand Prescriptions' ;
    rdfs:comment 'Number of brand-name (non-generic) prescriptions written by the HCP for the product during the reporting period.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandVsGenericRatio rdf:type rdf:Property ;
    rdfs:label 'Brand Vs Generic Ratio' ;
    rdfs:comment 'Ratio of brand prescriptions to generic prescriptions, indicating HCP preference for brand vs generic products.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveProductPrescriptions rdf:type rdf:Property ;
    rdfs:label 'Competitive Product Prescriptions' ;
    rdfs:comment 'Total number of prescriptions written by the HCP for competing products in the same therapeutic area during the reporting period.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Classification level of the prescribing pattern data indicating sensitivity and access controls required.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProvider rdf:type rdf:Property ;
    rdfs:label 'Data Provider' ;
    rdfs:comment 'Third-party prescription data provider that sourced this prescribing pattern data (e.g., IQVIA, Symphony Health).' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Data Refresh Date' ;
    rdfs:comment 'Date when the prescribing pattern data was last refreshed or updated by the data provider.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSourceCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Data Source Coverage Percent' ;
    rdfs:comment 'Percentage of the HCP\'s total prescribing activity captured by the data provider\'s data sources.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decileClassification rdf:type rdf:Property ;
    rdfs:label 'Decile Classification' ;
    rdfs:comment 'Decile classification of the HCP based on prescribing volume, where D1 represents the top 10% of prescribers and D10 the bottom 10%. [ENUM-REF-CANDIDATE: D1|D2|D3|D4|D5|D6|D7|D8|D9|D10 — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genericPrescriptions rdf:type rdf:Property ;
    rdfs:label 'Generic Prescriptions' ;
    rdfs:comment 'Number of generic prescriptions written by the HCP for the product during the reporting period.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographyLevel rdf:type rdf:Property ;
    rdfs:label 'Geography Level' ;
    rdfs:comment 'Geographic granularity level at which the prescribing data is aggregated.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKeyOpinionLeader rdf:type rdf:Property ;
    rdfs:label 'Is Key Opinion Leader' ;
    rdfs:comment 'Flag indicating whether the HCP is classified as a Key Opinion Leader in the therapeutic area.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newPrescriptionsNrx rdf:type rdf:Property ;
    rdfs:label 'New Prescriptions Nrx' ;
    rdfs:comment 'Number of new prescriptions (first-time prescriptions for a patient) written by the HCP for the product during the reporting period.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patientCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Patient Count Estimate' ;
    rdfs:comment 'Estimated number of unique patients for whom the HCP prescribed the product during the reporting period. This is an aggregated estimate, not patient-level data.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescribingChannel rdf:type rdf:Property ;
    rdfs:label 'Prescribing Channel' ;
    rdfs:comment 'Primary distribution channel through which the HCP\'s prescriptions are fulfilled (retail pharmacy, specialty pharmacy, mail order, hospital).' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescribingRankNational rdf:type rdf:Property ;
    rdfs:label 'Prescribing Rank National' ;
    rdfs:comment 'National ranking of the HCP based on total prescriptions for the product, with 1 being the highest prescriber.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescribingRankRegional rdf:type rdf:Property ;
    rdfs:label 'Prescribing Rank Regional' ;
    rdfs:comment 'Regional ranking of the HCP based on total prescriptions for the product within their geographic territory.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescribingTrend rdf:type rdf:Property ;
    rdfs:label 'Prescribing Trend' ;
    rdfs:comment 'Directional trend of HCP prescribing behavior for the product compared to previous reporting periods.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthorizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Rate Percent' ;
    rdfs:comment 'Percentage of prescriptions that required prior authorization approval from payers.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectionMethod rdf:type rdf:Property ;
    rdfs:label 'Projection Method' ;
    rdfs:comment 'Method used to calculate prescribing volumes when complete data is not available (actual count, statistical projection, extrapolation, or predictive model).' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refillPrescriptions rdf:type rdf:Property ;
    rdfs:label 'Refill Prescriptions' ;
    rdfs:comment 'Number of refill prescriptions written by the HCP for the product during the reporting period.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPrescriptionsTrx rdf:type rdf:Property ;
    rdfs:label 'Total Prescriptions Trx' ;
    rdfs:comment 'Total number of prescriptions written by the HCP for the product during the reporting period, including both new and refill prescriptions.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsPrescribed rdf:type rdf:Property ;
    rdfs:label 'Total Units Prescribed' ;
    rdfs:comment 'Total quantity of product units (tablets, vials, doses) prescribed by the HCP during the reporting period.' ;
    rdfs:domain ind:PrescribingPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleRequestId rdf:type rdf:Property ;
    rdfs:label 'Sample Request Id' ;
    rdfs:comment 'Unique identifier for the drug sample request record. Primary key for sample accountability tracking under 21 CFR Part 203 (Prescription Drug Marketing Act).' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlledSubstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Flag' ;
    rdfs:comment 'Indicates whether the sampled drug product is a DEA-controlled substance requiring additional tracking and HCP DEA validation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address where drug samples were delivered. Typically the HCP practice or clinic address.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address information such as suite number, floor, or building designation for sample delivery location.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City where drug samples were delivered to the HCP.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the sample delivery address. Format: 3 uppercase letters (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which drug samples were delivered to the HCP. In-person delivery by sales rep is most common for accountability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the sample delivery address.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State or province code for the sample delivery address. Used for geographic compliance tracking and territory assignment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'Date when the drug samples were physically delivered to the HCP. Also known as sample drop date. Required for PDMA compliance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityApproved rdf:type rdf:Property ;
    rdfs:label 'Quantity Approved' ;
    rdfs:comment 'Number of sample units approved for fulfillment. May differ from quantity requested based on inventory availability and HCP sample limits.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Number of sample units requested by the HCP. Measured in individual sample units (e.g., bottles, blister packs, vials).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when the sample transaction was reconciled against inventory records. Required for PDMA sample accountability audits.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleValueUsd rdf:type rdf:Property ;
    rdfs:label 'Sample Value Usd' ;
    rdfs:comment 'Fair market value of the dispensed drug samples in US dollars. Required for Sunshine Act transparency reporting and financial reconciliation.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sunshineReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Sunshine Reportable Flag' ;
    rdfs:comment 'Indicates whether this sample transaction must be reported under the Physician Payments Sunshine Act transparency requirements.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sunshineTransferId rdf:type rdf:Property ;
    rdfs:label 'Sunshine Transfer Id' ;
    rdfs:comment 'Unique identifier for the Open Payments (Sunshine Act) transfer of value record. Primary key for the sunshine_transfer data product.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmsSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Cms Submission Id' ;
    rdfs:comment 'The unique identifier assigned by CMS for this Open Payments submission record. Used for tracking and reconciliation with CMS Open Payments database.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:cmsPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Cms Publication Date' ;
    rdfs:comment 'The date on which CMS published this transfer record to the public Open Payments database. Typically June 30 for prior year data.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cmsReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Cms Reporting Status' ;
    rdfs:comment 'The current status of this transfer record in the CMS Open Payments submission lifecycle. Tracks progression from draft through final acceptance. [ENUM-REF-CANDIDATE: draft|pending_review|submitted|accepted|disputed|corrected|deleted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Cms Submission Date' ;
    rdfs:comment 'The date on which this transfer record was submitted to CMS for the Open Payments program. Used for compliance tracking and audit trails.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delayPublicationIndicator rdf:type rdf:Property ;
    rdfs:label 'Delay Publication Indicator' ;
    rdfs:comment 'Indicates whether publication of this transfer has been delayed due to ongoing research, clinical investigation, or product development activities.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Transaction Number' ;
    rdfs:comment 'The company\'s internal transaction or payment reference number from the source financial or CRM system (e.g., SAP document number, Veeva CRM activity ID).' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:natureOfPayment rdf:type rdf:Property ;
    rdfs:label 'Nature Of Payment' ;
    rdfs:comment 'Detailed description of the context and purpose of the payment, including the specific service provided, event attended, or activity performed. Required for CMS transparency reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The monetary value of the transfer in the transaction currency. Represents the gross amount before any adjustments or taxes.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Payment Amount Usd' ;
    rdfs:comment 'The payment amount converted to US Dollars for CMS reporting purposes. Required for all Open Payments submissions regardless of original currency.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Payment Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the payment amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'The nature of the payment or transfer of value as defined by CMS Open Payments categories. Determines reporting requirements and compliance thresholds. [ENUM-REF-CANDIDATE: consulting_fee|speaker_honorarium|meal|travel|lodging|education|research_grant|charitable_contribution|royalty_license|ownership_interest|gift|entertainment|honoraria|current_or_prospective_ownership|compensation_for_services_other_than_consulting|space_rental_or_facility_fees|food_and_beverage — 17 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productIndication rdf:type rdf:Property ;
    rdfs:label 'Product Indication' ;
    rdfs:comment 'The therapeutic indication or disease state for which the associated product is marketed or being discussed in the context of this transfer.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'The marketed name of the drug or biological product associated with this transfer of value. Required when payment is related to a specific product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'The calendar year for which this transfer is being reported to CMS. Determines the applicable reporting deadline and publication cycle.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Recipient Address Line1' ;
    rdfs:comment 'The primary street address of the recipient\'s principal business location. Required for CMS Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCity rdf:type rdf:Property ;
    rdfs:label 'Recipient City' ;
    rdfs:comment 'The city of the recipient\'s principal business location. Required for CMS Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCountry rdf:type rdf:Property ;
    rdfs:label 'Recipient Country' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code of the recipient\'s principal business location. Typically USA for domestic Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPostalCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Postal Code' ;
    rdfs:comment 'The ZIP code of the recipient\'s principal business location in 5-digit or ZIP+4 format. Required for CMS Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientSpecialty rdf:type rdf:Property ;
    rdfs:label 'Recipient Specialty' ;
    rdfs:comment 'The primary medical specialty of the recipient healthcare professional (e.g., Oncology, Cardiology, Internal Medicine). Used for CMS reporting and analytics.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientStateLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Recipient State License Number' ;
    rdfs:comment 'The state medical license number of the recipient healthcare professional. Used for identity verification in Open Payments submissions.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchInformationIndicator rdf:type rdf:Property ;
    rdfs:label 'Research Information Indicator' ;
    rdfs:comment 'Indicates whether this transfer is related to research activities and may qualify for delayed publication under CMS rules.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyPaymentRecipientIndicator rdf:type rdf:Property ;
    rdfs:label 'Third Party Payment Recipient Indicator' ;
    rdfs:comment 'Indicates whether the payment was made to a third party on behalf of the covered recipient (e.g., payment to a charity designated by the HCP).' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyRecipientName rdf:type rdf:Property ;
    rdfs:label 'Third Party Recipient Name' ;
    rdfs:comment 'The name of the third-party entity that received the payment on behalf of the covered recipient. Populated when third_party_payment_recipient_indicator is true.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuityFeeId rdf:type rdf:Property ;
    rdfs:label 'Annuity Fee Id' ;
    rdfs:comment 'Unique surrogate identifier for each patent annuity (maintenance fee) payment obligation or payment record in the portfolio.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical IP operations require employee authorization for annuity payments for budget control, lapse prevention, and SOX compliance. Replaces text field authorized_by with employee FK for audit ' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'The bank transaction reference number or wire transfer confirmation number associated with the annuity fee payment, used for financial reconciliation against the company\'s bank statements and SAP FI records.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Receipt Number' ;
    rdfs:comment 'Official receipt or acknowledgement number issued by the patent office or paying agent confirming successful payment of the annuity fee. Serves as proof of payment for audit and compliance purposes.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredProductName rdf:type rdf:Property ;
    rdfs:label 'Covered Product Name' ;
    rdfs:comment 'The commercial or INN (International Nonproprietary Name) of the pharmaceutical product covered by the patent for which this annuity fee is being maintained. Supports commercial impact analysis and lifecycle management decisions.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitySizeCategory rdf:type rdf:Property ;
    rdfs:label 'Entity Size Category' ;
    rdfs:comment 'The entity size classification applicable to this annuity fee payment, which determines the applicable fee discount at the USPTO and certain other patent offices. Large entities pay full fees; small entities (fewer than 500 employees) pay 60% of large entity fees; micro entities pay 40% of large entity fees.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'The official annuity fee amount due to the patent office in the local jurisdiction currency, as prescribed by the applicable fee schedule for the relevant fee year and entity size category.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fee Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this annuity fee obligation, typically generated by the paying agent or internal IP management system for tracking and reconciliation purposes.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeScheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Version' ;
    rdfs:comment 'The version or effective date of the patent office fee schedule used to determine the annuity fee amount for this payment obligation. Fee schedules are periodically updated by patent offices and the applicable version must be documented for audit purposes.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeYear rdf:type rdf:Property ;
    rdfs:label 'Fee Year' ;
    rdfs:comment 'The renewal year number for which the annuity fee is due, counting from the patent filing or grant date depending on jurisdiction rules (e.g., year 3, year 10, year 20). Critical for determining the applicable fee schedule.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period End Date' ;
    rdfs:comment 'The final date by which a late annuity fee payment can be made with a surcharge to avoid patent lapse, as permitted by the relevant patent office. Varies by jurisdiction (e.g., 6 months in the US, typically with surcharge).' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instructionDate rdf:type rdf:Property ;
    rdfs:label 'Instruction Date' ;
    rdfs:comment 'The date on which the internal instruction or authorization to pay the annuity fee was issued to the paying agent or treasury function. Represents the business event timestamp when the payment process was initiated.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lapseDate rdf:type rdf:Property ;
    rdfs:label 'Lapse Date' ;
    rdfs:comment 'The date on which the patent lapsed in the jurisdiction due to non-payment of the annuity fee. Populated only when payment_status is \'lapsed\'. Critical for tracking portfolio attrition and generic/biosimilar entry risk.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payingAgentName rdf:type rdf:Property ;
    rdfs:label 'Paying Agent Name' ;
    rdfs:comment 'Name of the external annuity service provider or patent renewal agent (e.g., CPA Global, Dennemeyer, Questel, Anaqua) engaged to manage and remit annuity fee payments on behalf of the company in the relevant jurisdiction.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payingAgentReference rdf:type rdf:Property ;
    rdfs:label 'Paying Agent Reference' ;
    rdfs:comment 'The unique reference or docket number assigned by the external paying agent to this annuity fee instruction, used for reconciliation and correspondence with the agent.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementEligible rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Eligible' ;
    rdfs:comment 'Indicates whether the lapsed patent is eligible for reinstatement or restoration under the applicable jurisdiction\'s rules (e.g., USPTO petition for revival, EPO re-establishment of rights). Relevant only when payment_status is \'lapsed\'.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Date' ;
    rdfs:comment 'The date on which the annuity fee payment reminder was dispatched to the responsible party. Null if no reminder has been sent. Used to track notification compliance and escalation timelines.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reminderSentFlag rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Flag' ;
    rdfs:comment 'Indicates whether an automated or manual payment reminder notification has been sent to the responsible IP manager or paying agent ahead of the annuity fee due date. Supports proactive portfolio maintenance workflows.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapPaymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Payment Document Number' ;
    rdfs:comment 'The SAP S/4HANA FI payment document number generated when the annuity fee payment is posted in the financial system, enabling end-to-end reconciliation between IP management records and the general ledger.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Additional surcharge amount applied when the annuity fee is paid during the grace period after the original due date. Zero or null if payment was made on time.' ;
    rdfs:domain ind:AnnuityFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Documented business justification for waiving an annuity fee payment, applicable when payment_status is \'waived\'. Examples include strategic portfolio pruning, patent no longer commercially relevant, or covered product discontinued. Null if not waived.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterdataInnRegistryId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Inn Registry Id' ;
    rdfs:comment 'Foreign key linking to masterdata.inn_registry. Business justification: DMFs describe specific INNs; required for regulatory submissions, molecule-DMF linkage, and supply chain qualification in pharmaceutical manufacturing.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InnRegistry .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical CMC regulatory affairs assigns employees to manage DMFs for amendment coordination, authorization letter issuance, and annual update submissions. Critical for supplier qualification, re' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:apiManufacturerFlag rdf:type rdf:Property ;
    rdfs:label 'Api Manufacturer Flag' ;
    rdfs:comment 'Indicates whether the DMF holder is the manufacturer of the Active Pharmaceutical Ingredient (API) covered by this DMF. True for Type II DMFs where the holder manufactures the drug substance. Used to distinguish API manufacturers from intermediates suppliers, excipient suppliers, and packaging material suppliers.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmcSectionReference rdf:type rdf:Property ;
    rdfs:label 'Cmc Section Reference' ;
    rdfs:comment 'Reference to the specific CMC (Chemistry, Manufacturing, and Controls) section of the eCTD submission (Module 3) that this DMF supports. Used to map the DMF to the corresponding regulatory dossier section for NDA/BLA/ANDA/MAA submissions.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityCommitmentDate rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Commitment Date' ;
    rdfs:comment 'Date on which the regulatory authority acknowledged the confidential nature of the DMF content. The FDA treats DMF content as confidential trade secret information. This date records when the confidentiality commitment was formally established, supporting IP protection and trade secret management.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crossReferenceCount rdf:type rdf:Property ;
    rdfs:label 'Cross Reference Count' ;
    rdfs:comment 'Number of active regulatory applications (NDA, BLA, ANDA, IND, MAA) that currently cross-reference this DMF. Indicates the commercial and regulatory criticality of the DMF; a high count signals high supply chain dependency and elevated risk if the DMF is withdrawn or goes inactive.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dmfNumber rdf:type rdf:Property ;
    rdfs:label 'Dmf Number' ;
    rdfs:comment 'Official DMF number assigned by the regulatory authority (e.g., FDA) upon receipt of the DMF submission. Serves as the primary external identifier used in cross-references within NDA, BLA, ANDA, and IND applications. Format varies by authority (e.g., FDA assigns a numeric DMF number).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmfStatus rdf:type rdf:Property ;
    rdfs:label 'Dmf Status' ;
    rdfs:comment 'Current lifecycle status of the DMF with the regulatory authority. \'active\' indicates the DMF is in good standing and available for cross-reference; \'inactive\' indicates it has not been updated within the required period; \'withdrawn\' indicates the holder has formally withdrawn the file; \'under_review\' indicates a pending agency review; \'closed\' indicates the file has been administratively closed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmfType rdf:type rdf:Property ;
    rdfs:label 'Dmf Type' ;
    rdfs:comment 'Classification of the DMF per FDA categorization: Type I (Manufacturing Site, Facilities, Operating Procedures, and Personnel — discontinued by FDA but retained for legacy), Type II (Drug Substance, Drug Substance Intermediate, and Material Used in Their Preparation, or Drug Product), Type III (Packaging Material), Type IV (Excipient, Colorant, Flavor, Essence, or Material Used in Their Preparation), Type V (FDA-Accepted Reference Information). Drives CMC submission strategy and third-party qualification workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosageForm rdf:type rdf:Property ;
    rdfs:label 'Dosage Form' ;
    rdfs:comment 'Physical form of the drug product or substance covered by the DMF (e.g., tablet, capsule, injectable solution, lyophilized powder, cream, patch). Relevant primarily for Type II (Drug Product) and Type III (Packaging) DMFs. Aligns with FDA/EMA dosage form terminology. [ENUM-REF-CANDIDATE: tablet|capsule|injectable_solution|lyophilized_powder|cream|patch|suspension|gel|suppository|inhalation_powder — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ectd Sequence Number' ;
    rdfs:comment 'Four-digit eCTD sequence number assigned to the DMF submission or amendment within the eCTD lifecycle. Used to track the submission history and version control of the DMF in the regulatory authority\'s electronic submission gateway.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaEstablishmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Fda Establishment Identifier' ;
    rdfs:comment 'FDA Establishment Identifier (FEI) number assigned to the manufacturing facility by the FDA. Used to link the DMF to the FDA\'s establishment registration database, enabling GMP inspection history lookup and import alert monitoring.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Certificate Expiry Date' ;
    rdfs:comment 'Expiry date of the current GMP certificate for the manufacturing site associated with this DMF. Triggers renewal workflows and supplier qualification reviews. An expired GMP certificate may block use of the DMF in new regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Gmp Certificate Number' ;
    rdfs:comment 'Certificate number of the current GMP certificate issued by a recognized regulatory authority or inspection body (e.g., FDA, EMA, PIC/S member authority) for the manufacturing site associated with this DMF. Used for supplier qualification and regulatory compliance verification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or annual update submitted to the regulatory authority for this DMF. FDA requires annual updates to maintain active status. Tracks currency of the file and triggers compliance alerts when updates are overdue.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:letterOfAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Letter Of Authorization Date' ;
    rdfs:comment 'Date on which the DMF holder issued the Letter of Authorization (LOA) permitting the company to cross-reference this DMF in its regulatory submissions. Relevant when the company is the applicant referencing a third-party DMF.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:letterOfAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Letter Of Authorization Required' ;
    rdfs:comment 'Indicates whether a Letter of Authorization (LOA) from the DMF holder is required before an applicant can cross-reference this DMF in their regulatory submission. True for most Type II and Type IV DMFs where the holder controls access to confidential manufacturing information.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingSiteCountryCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the manufacturing site is located. Used for import/export compliance, country-of-origin tracking, supply chain risk management, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAnnualUpdateDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Annual Update Due Date' ;
    rdfs:comment 'Calculated due date for the next mandatory annual update submission to maintain active DMF status with the regulatory authority. Derived from the last amendment date plus 12 months. Used for compliance monitoring and proactive submission planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proprietaryHolderFlag rdf:type rdf:Property ;
    rdfs:label 'Proprietary Holder Flag' ;
    rdfs:comment 'Indicates whether the company itself (Pharmaceuticals) is the holder of this DMF (True) or whether it is a third-party supplier DMF that the company cross-references (False). Drives different workflows: internal DMFs require internal maintenance; third-party DMFs require supplier management and LOA tracking.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rimsTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Rims Tracking Number' ;
    rdfs:comment 'Internal tracking number assigned to this DMF record within the company\'s Regulatory Information Management System (RIMS), such as Veeva Vault RIM. Used for internal workflow management, submission tracking, and audit trail purposes.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeOfAdministration rdf:type rdf:Property ;
    rdfs:label 'Route Of Administration' ;
    rdfs:comment 'Intended route of administration for the drug substance or product covered by the DMF (e.g., oral, intravenous, subcutaneous, topical, inhalation). Applicable for Type II DMFs. Aligns with FDA/EMA route of administration terminology. [ENUM-REF-CANDIDATE: oral|intravenous|subcutaneous|intramuscular|topical|inhalation|transdermal|intrathecal — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFormat rdf:type rdf:Property ;
    rdfs:label 'Submission Format' ;
    rdfs:comment 'Format in which the DMF was submitted to the regulatory authority: \'eCTD\' (Electronic Common Technical Document — mandatory for FDA since 2017 for most submissions), \'paper\' (legacy paper-based submission), or \'NeeS\' (Non-eCTD Electronic Submission — used in some jurisdictions). Determines document management and archival requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'Document identifier in Veeva Vault RIM (Regulatory Information Management) system where the DMF submission package and associated correspondence are stored. Enables traceability between the enterprise data platform record and the source regulatory document management system.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeStatus rdf:type rdf:Property ;
    rdfs:label 'Challenge Status' ;
    rdfs:comment 'Indicates whether this exclusivity period is subject to a legal or regulatory challenge. Paragraph IV = ANDA Paragraph IV certification challenge under Hatch-Waxman; Inter Partes = IPR/PGR challenge at USPTO; Court Order = court-ordered modification; Under Review = authority-initiated review. Critical for generic entry defense strategy.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPackageType rdf:type rdf:Property ;
    rdfs:label 'Data Package Type' ;
    rdfs:comment 'Type of regulatory data package submitted with the application. Full = complete standalone dossier (NCE/NBE); 505(b)(2) = hybrid relying on published literature or prior approvals; Hybrid = EU hybrid application; Bibliographic = based on published scientific literature. Determines applicable exclusivity type and duration.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Category' ;
    rdfs:comment 'Broad category of the exclusivity period indicating whether it applies to a small molecule (NCE/NME), biologic (NBE), orphan drug designation, pediatric extension, or combination product.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityCode rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Code' ;
    rdfs:comment 'Internally assigned unique alphanumeric code identifying this exclusivity period record, used for cross-system referencing and lifecycle management tracking.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Duration Months' ;
    rdfs:comment 'Total duration of the exclusivity period expressed in months as granted by the regulatory authority (e.g., 84 months for US orphan drug, 120 months for EU orphan drug, 144 months for US biologics). Supports duration validation and comparison across jurisdictions.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusivityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Expiry Date' ;
    rdfs:comment 'The date on which the regulatory exclusivity period expires, after which generic or biosimilar applicants may reference the innovator data. Critical for lifecycle management and generic/biosimilar entry defense planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Start Date' ;
    rdfs:comment 'The date on which the regulatory exclusivity period commences, typically aligned with the date of first approval (NDA/BLA/MAA approval date) or orphan designation date depending on exclusivity type.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityStatus rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Status' ;
    rdfs:comment 'Current lifecycle status of the exclusivity period. Active = currently in force; Expired = past expiry date; Withdrawn = voluntarily or involuntarily revoked by authority; Challenged = subject to legal or regulatory challenge; Pending = granted but not yet effective; Suspended = temporarily halted pending review.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityType rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Type' ;
    rdfs:comment 'Classification of the regulatory exclusivity type granted. NCE = New Chemical Entity (5 years US); ODE = Orphan Drug Exclusivity (7 years US / 10 years EU); PED = Pediatric Exclusivity Extension (6 months); DATA = Data Exclusivity for new indication (3 years US); BIOL = Biologics Exclusivity (12 years US); REMS = Risk Evaluation and Mitigation Strategy exclusivity. [ENUM-REF-CANDIDATE: NCE|ODE|PED|DATA|BIOL|REMS|NME|PATENT_LINKAGE — promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstGenericEntryDate rdf:type rdf:Property ;
    rdfs:label 'First Generic Entry Date' ;
    rdfs:comment 'The projected or actual date on which the first generic (ANDA) or biosimilar (351(k) BLA) product may enter the market following expiry or challenge of this exclusivity. Used for lifecycle management, revenue forecasting, and LOE (Loss of Exclusivity) planning.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantingAuthority rdf:type rdf:Property ;
    rdfs:label 'Granting Authority' ;
    rdfs:comment 'Regulatory authority that granted this exclusivity period (e.g., FDA for US market, EMA for EU market, PMDA for Japan, MHRA for UK post-Brexit). Determines jurisdiction and applicable exclusivity rules. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|NMPA|WHO|DEA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOrphanDesignated rdf:type rdf:Property ;
    rdfs:label 'Is Orphan Designated' ;
    rdfs:comment 'Indicates whether the product holds an orphan drug designation from FDA (Orphan Drug Act) or EMA (Regulation EC 141/2000), which is a prerequisite for orphan drug exclusivity (ODE). Distinct from exclusivity_type as designation may exist without exclusivity being granted.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalCounselNotes rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Notes' ;
    rdfs:comment 'Free-text notes from legal counsel regarding this exclusivity period, including litigation strategy, challenge responses, and coordination with patent attorneys. Classified as confidential due to potential attorney-client privilege content.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loeRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Loe Risk Level' ;
    rdfs:comment 'Assessed risk level for Loss of Exclusivity (LOE) based on proximity to expiry, challenge status, and competitive pipeline. Critical for commercial lifecycle management and strategic planning.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDesignationNumber rdf:type rdf:Property ;
    rdfs:label 'Orphan Designation Number' ;
    rdfs:comment 'Official orphan drug designation number assigned by FDA (ODA) or EMA (EC Regulation 141/2000) when exclusivity_type is ODE. Required for orphan drug exclusivity validation and regulatory reporting.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentLinkageFlag rdf:type rdf:Property ;
    rdfs:label 'Patent Linkage Flag' ;
    rdfs:comment 'Indicates whether this exclusivity period is linked to a listed patent in the FDA Orange Book or equivalent patent register, enabling coordination between patent protection and regulatory exclusivity for lifecycle management.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pediatricExtensionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pediatric Extension Expiry Date' ;
    rdfs:comment 'The adjusted expiry date reflecting the 6-month pediatric exclusivity extension, if granted. Null if pediatric_extension_granted is False.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pediatricExtensionGranted rdf:type rdf:Property ;
    rdfs:label 'Pediatric Extension Granted' ;
    rdfs:comment 'Indicates whether a 6-month pediatric exclusivity extension (PED) has been granted under the Best Pharmaceuticals for Children Act (BPCA) or EU Paediatric Regulation, extending the base exclusivity or patent term by 6 months.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipWatchId rdf:type rdf:Property ;
    rdfs:label 'Ip Watch Id' ;
    rdfs:comment 'Foreign key linking to intellectual.ip_watch. Business justification: Freedom-to-Operate (FTO) analyses are often triggered by IP watch alerts (e.g., competitor patent grant, Paragraph IV notice). Linking fto_analysis to ip_watch tracks which competitive intelligence ev' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpWatch .

ind:requestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requestor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical R&D requires tracking which employee requested FTO analysis for project prioritization, budget allocation, and regulatory inspection readiness. Replaces text field requestor_name with s' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedProductNames rdf:type rdf:Property ;
    rdfs:label 'Affected Product Names' ;
    rdfs:comment 'Comma-separated list of proprietary product names or INNs that are commercially affected by the FTO analysis findings or the competitor IP watch activity. Supports portfolio-level impact assessment and lifecycle management decisions.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'The date on which the FTO analysis was formally conducted or the opinion was rendered by the responsible attorney or firm. Represents the principal business event date for this record.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisNumber rdf:type rdf:Property ;
    rdfs:label 'Analysis Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the FTO analysis or IP watch record, used for tracking across legal, regulatory, and business functions. Format: FTO-YYYY-NNNNN.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisStatus rdf:type rdf:Property ;
    rdfs:label 'Analysis Status' ;
    rdfs:comment 'Current lifecycle state of the FTO analysis record: draft (initiated, not yet reviewed), in_review (under attorney or committee review), completed (final opinion issued), superseded (replaced by a newer analysis), or cancelled.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisTitle rdf:type rdf:Property ;
    rdfs:label 'Analysis Title' ;
    rdfs:comment 'Descriptive title of the Freedom-to-Operate analysis or competitive IP watch record, summarizing the product, technology, or process under assessment.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisType rdf:type rdf:Property ;
    rdfs:label 'Analysis Type' ;
    rdfs:comment 'Classification of the analysis record: FTO assessment (go/no-go commercialization opinion), IP watch (ongoing competitor monitoring), patent landscape (broad mapping), clearance opinion (legal freedom-to-use), or freedom-to-use. Drives workflow and reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorFilingDate rdf:type rdf:Property ;
    rdfs:label 'Competitor Filing Date' ;
    rdfs:comment 'Date on which the competitor filed the patent application, ANDA, biosimilar application, or other regulatory/IP submission being monitored. Critical for calculating response timelines and exclusivity defense windows.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the competitor company whose IP activities are being monitored in this watch record (e.g., generic manufacturer filing an ANDA, biosimilar applicant, or third-party patent filer). Central to competitive intelligence.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Competitor Reference Number' ;
    rdfs:comment 'Official reference number of the competitor\'s filing being monitored, such as an ANDA application number, biosimilar BLA number, patent publication number, or IPR petition number. Enables direct lookup in regulatory and patent databases.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conductingAttorney rdf:type rdf:Property ;
    rdfs:label 'Conducting Attorney' ;
    rdfs:comment 'Name of the internal patent attorney or external legal counsel responsible for conducting and signing off on the FTO analysis. Critical for attorney-client privilege tracking and legal accountability.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level assigned to the FTO analysis record, governing access controls and information sharing: restricted (attorney-client privilege, highly sensitive), confidential (internal legal/IP team only), internal (general internal use), or public. Aligns with enterprise data governance policy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designAroundRequired rdf:type rdf:Property ;
    rdfs:label 'Design Around Required' ;
    rdfs:comment 'Indicates whether the FTO analysis concluded that a design-around strategy is required to avoid infringement of identified blocking patents before commercialization can proceed.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmfReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dmf Reference Number' ;
    rdfs:comment 'Reference number of the Drug Master File (DMF) associated with the drug substance or manufacturing process under FTO assessment, if applicable. Links the IP analysis to the CMC regulatory submission package.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalOpinion rdf:type rdf:Property ;
    rdfs:label 'Final Opinion' ;
    rdfs:comment 'The formal legal opinion rendered by the conducting attorney: clear (free to operate without infringement risk), conditional_clear (free to operate subject to design-arounds or licensing), blocked (cannot commercialize without infringing), inconclusive (insufficient information), or pending (opinion not yet issued).' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawFirmName rdf:type rdf:Property ;
    rdfs:label 'Law Firm Name' ;
    rdfs:comment 'Name of the external law firm or patent agency engaged to conduct the FTO analysis, if applicable. Supports vendor management, cost tracking, and attorney-client privilege documentation.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingRequired rdf:type rdf:Property ;
    rdfs:label 'Licensing Required' ;
    rdfs:comment 'Indicates whether the FTO analysis concluded that a license must be obtained from a third-party patent holder before the assessed product or technology can be commercialized.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:litigationFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Flag' ;
    rdfs:comment 'Indicates whether the FTO analysis or IP watch record is associated with active or anticipated patent litigation (e.g., Paragraph IV ANDA challenge, IPR petition, patent infringement suit). Triggers escalation to senior legal counsel.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentExpiryRelevanceDate rdf:type rdf:Property ;
    rdfs:label 'Patent Expiry Relevance Date' ;
    rdfs:comment 'The earliest expiry date among the blocking patents identified in the FTO analysis, representing the date after which the primary IP barrier may no longer apply. Critical for lifecycle management and generic/biosimilar entry defense planning.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestorDepartment rdf:type rdf:Property ;
    rdfs:label 'Requestor Department' ;
    rdfs:comment 'Business department or function that initiated the FTO analysis request (e.g., R&D, Commercial, Regulatory Affairs, Legal). Used for workload tracking and cross-functional reporting.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRationale rdf:type rdf:Property ;
    rdfs:label 'Risk Rationale' ;
    rdfs:comment 'Narrative explanation supporting the assigned risk level, summarizing the key blocking patents, claim analysis findings, and legal reasoning that led to the risk determination. Supports legal review and business decision-making.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed narrative describing the scope of the FTO analysis, including the specific product features, process steps, formulation parameters, or technology elements assessed for potential third-party IP infringement.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyArea rdf:type rdf:Property ;
    rdfs:label 'Technology Area' ;
    rdfs:comment 'Broad technology or therapeutic area classification of the subject matter under FTO assessment (e.g., oncology, immunology, rare diseases, formulation, manufacturing process, delivery device). Supports portfolio-level IP analytics.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatAssessment rdf:type rdf:Property ;
    rdfs:label 'Threat Assessment' ;
    rdfs:comment 'Assessment of the competitive threat posed by the monitored competitor activity: critical (immediate commercial impact expected), high (significant risk to market exclusivity), medium (moderate risk requiring active response), low (limited near-term impact), or monitoring (no immediate action required).' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchType rdf:type rdf:Property ;
    rdfs:label 'Watch Type' ;
    rdfs:comment 'For competitive IP watch records, classifies the type of competitor activity being monitored: patent_filing (new patent applications), anda_submission (Abbreviated New Drug Application), biosimilar_application (biosimilar filing), patent_challenge (IPR/PGR/opposition), regulatory_filing, or trademark. [ENUM-REF-CANDIDATE: patent_filing|anda_submission|biosimilar_application|patent_challenge|regulatory_filing|trademark — promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadInventorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Inventor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical R&D requires tracking lead inventors as employees for invention assignment execution, inventor compensation, and patent prosecution initiation. Replaces text field lead_inventor_name wi' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:patentProsecutionId rdf:type rdf:Property ;
    rdfs:label 'Patent Prosecution Id' ;
    rdfs:comment 'Foreign key linking to intellectual.patent_prosecution. Business justification: Invention disclosure is the first step in the IP lifecycle, submitted by R&D scientists. When a disclosure is approved for patent filing, it should link to the resulting patent_prosecution record. The' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentProsecution .

ind:coInventorNames rdf:type rdf:Property ;
    rdfs:label 'Co Inventor Names' ;
    rdfs:comment 'Semicolon-delimited list of full names of all co-inventors contributing to the disclosed invention. Required for complete inventorship declaration on patent applications per USPTO and EPC requirements.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialRelevanceScore rdf:type rdf:Property ;
    rdfs:label 'Commercial Relevance Score' ;
    rdfs:comment 'IP committee or business development assessment of the commercial value and strategic importance of the invention to the company\'s pipeline and market position. Influences prioritization of patent prosecution resources.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defensivePublicationDate rdf:type rdf:Property ;
    rdfs:label 'Defensive Publication Date' ;
    rdfs:comment 'Date on which the invention was published defensively (e.g., via Research Disclosure or IP.com) to create prior art and prevent third parties from patenting the same invention. Null if defensive publication was not the chosen disposition.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:elbReference rdf:type rdf:Property ;
    rdfs:label 'Elb Reference' ;
    rdfs:comment 'Reference identifier linking this invention disclosure to the corresponding experiment records in the Electronic Lab Notebook (ELN) system (IDBS E-WorkBook or Dotmatics). Provides the evidentiary basis for the invention and supports conception and reduction-to-practice documentation.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselRef rdf:type rdf:Property ;
    rdfs:label 'External Counsel Ref' ;
    rdfs:comment 'Reference identifier or matter number assigned by external patent counsel (law firm) handling the prosecution of the patent application derived from this disclosure. Enables coordination between internal IP team and outside counsel.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftoAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fto Assessment Status' ;
    rdfs:comment 'Status of the Freedom-to-Operate (FTO) analysis conducted to determine whether commercializing the invention would infringe third-party patents. FTO clearance is a prerequisite for commercial development decisions.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftoClearanceOpinion rdf:type rdf:Property ;
    rdfs:label 'Fto Clearance Opinion' ;
    rdfs:comment 'Legal opinion outcome of the FTO analysis: clear (no blocking third-party patents identified), risk identified (potential infringement risk), conditional clear (clear subject to design-around or licensing), or not assessed. Informs go/no-go decisions for development.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventiveStepAssessment rdf:type rdf:Property ;
    rdfs:label 'Inventive Step Assessment' ;
    rdfs:comment 'Assessment of whether the disclosed invention satisfies the non-obviousness (US) or inventive step (EP/PCT) requirement for patentability. Evaluated by IP counsel in conjunction with prior art search findings.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventorAssignmentSigned rdf:type rdf:Property ;
    rdfs:label 'Inventor Assignment Signed' ;
    rdfs:comment 'Indicates whether all inventors have signed the invention assignment agreement transferring IP ownership to the company. A signed assignment is a legal prerequisite for the company to file and own the resulting patent.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventorEmployeeIds rdf:type rdf:Property ;
    rdfs:label 'Inventor Employee Ids' ;
    rdfs:comment 'Semicolon-delimited list of internal employee identifiers for all inventors (lead and co-inventors). Used to link inventors to HR records for assignment agreements and inventorship verification.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCommitteeReviewDate rdf:type rdf:Property ;
    rdfs:label 'Ip Committee Review Date' ;
    rdfs:comment 'Date on which the IP committee formally reviewed the invention disclosure and reached a recommendation. Null if review has not yet occurred.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipCommitteeReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Committee Review Status' ;
    rdfs:comment 'Current status of the invention disclosure within the IP committee review process. Tracks whether the disclosure has been submitted to the committee, is under active review, has been reviewed, or has been deferred for additional information.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noveltyAssessment rdf:type rdf:Property ;
    rdfs:label 'Novelty Assessment' ;
    rdfs:comment 'IP counsel or IP committee assessment of whether the disclosed invention meets the novelty requirement for patentability based on prior art search results. Informs the recommended action decision.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineCompoundFlag rdf:type rdf:Property ;
    rdfs:label 'Pipeline Compound Flag' ;
    rdfs:comment 'Indicates whether the invention is directly associated with an active pipeline compound or program. Pipeline-linked disclosures receive elevated IP prosecution priority and are tracked in lifecycle management reviews.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorArtSearchCompleted rdf:type rdf:Property ;
    rdfs:label 'Prior Art Search Completed' ;
    rdfs:comment 'Indicates whether a formal prior art search has been conducted for this invention disclosure. A completed prior art search is a prerequisite for the IP committee\'s patentability recommendation.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorArtSearchDate rdf:type rdf:Property ;
    rdfs:label 'Prior Art Search Date' ;
    rdfs:comment 'Date on which the prior art search was completed by IP counsel or a designated patent search firm. Used to assess the currency of the search relative to the filing decision.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisionalFilingDate rdf:type rdf:Property ;
    rdfs:label 'Provisional Filing Date' ;
    rdfs:comment 'Date on which a provisional patent application was filed with the USPTO based on this invention disclosure. Establishes the priority date for the subsequent non-provisional application. Null if no provisional was filed.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'IP committee\'s recommended disposition for the invention disclosure: file a patent application, maintain as a trade secret, publish defensively to create prior art, or abandon. Drives the downstream IP prosecution workflow.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFilingDate rdf:type rdf:Property ;
    rdfs:label 'Target Filing Date' ;
    rdfs:comment 'Planned date by which the patent application derived from this disclosure should be filed, as determined by IP counsel and the IP committee. Used for prosecution timeline management and resource planning.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeSecretFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Secret Flag' ;
    rdfs:comment 'Indicates whether the invention has been designated as a trade secret rather than being filed as a patent application. Trade secret designation triggers specific confidentiality controls and access restrictions under the Defend Trade Secrets Act (DTSA) and applicable law.' ;
    rdfs:domain ind:InventionDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAgreementMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Ip Agreement Milestone Id' ;
    rdfs:comment 'Unique surrogate identifier for each milestone record under a licensing, co-development, or collaboration agreement tied to an IP asset. Primary key for this entity.' ;
    rdfs:domain ind:IpAgreementMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalDealOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Deal Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical business development assigns employees to track licensing milestones for achievement verification, payment coordination, and revenue recognition. Replaces text field internal_deal_owner' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:achievedDate rdf:type rdf:Property ;
    rdfs:label 'Achieved Date' ;
    rdfs:comment 'Actual date on which the milestone trigger event was confirmed as achieved. Null if the milestone has not yet been achieved. Used for revenue recognition timing and partner notification.' ;
    rdfs:domain ind:IpAgreementMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalPhase rdf:type rdf:Property ;
    rdfs:label 'Clinical Phase' ;
    rdfs:comment 'Clinical development phase associated with a clinical milestone trigger event (Phase I, Phase II, Phase III, Phase IV). Applicable when milestone_type is \'clinical\'. Aligns with ICH E8 and FDA clinical trial phase definitions.' ;
    rdfs:domain ind:IpAgreementMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselReference rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Reference' ;
    rdfs:comment 'Reference identifier or name of the internal or external legal counsel responsible for advising on this milestone, including patent litigation or dispute resolution matters. Supports coordination with legal on milestone disputes.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedProductName rdf:type rdf:Property ;
    rdfs:label 'Licensed Product Name' ;
    rdfs:comment 'Name of the drug product, drug substance, or technology to which this milestone applies, as defined in the agreement. May reference the International Nonproprietary Name (INN), USAN, or internal compound code.' ;
    rdfs:domain ind:IpAgreementMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Free-text description of the milestone event as defined in the agreement schedule, including specific conditions, indications, territories, or product formulations that must be met for the milestone to be triggered.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestonePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Milestone Payment Amount' ;
    rdfs:comment 'Gross contractual payment amount due upon achievement of this milestone, expressed in the agreement currency. Represents the base monetary obligation before any withholding tax or adjustments.' ;
    rdfs:domain ind:IpAgreementMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneSubtype rdf:type rdf:Property ;
    rdfs:label 'Milestone Subtype' ;
    rdfs:comment 'Granular classification within the milestone type. Examples include: IND Submission, Phase I Completion, Phase II Completion, Phase III Completion, NDA Submission, NDA Approval, BLA Submission, BLA Approval, MAA Submission, MAA Approval, First Commercial Sale, Annual Net Sales Threshold, Orphan Drug Designation, Pediatric Exclusivity Grant. [ENUM-REF-CANDIDATE: IND_submission|phase_I_completion|phase_II_completion|phase_III_completion|NDA_submission|NDA_approval|BLA_submission|BLA_approval|MAA_submission|MAA_approval|first_commercial_sale|net_sales_threshold|orphan_drug_designation|pediatric_exclusivity — promote to reference product]' ;
    rdfs:domain ind:IpAgreementMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Actual date on which the milestone payment was received or disbursed, as confirmed in the bank or SAP FI ledger. Null if payment has not yet been made.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Regulatory authority whose action (e.g., IND acceptance, NDA/BLA/MAA approval) constitutes the trigger event for regulatory milestones. Applicable only to regulatory milestone types. Values include FDA, EMA, MHRA, PMDA, NMPA, WHO, or other. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name of the party (licensor, licensee, or co-development partner) contractually responsible for achieving the milestone trigger event or making the milestone payment. Supports partner relationship management and deal accountability tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Flag' ;
    rdfs:comment 'Indicates whether the milestone payment has been recognized as revenue in the financial statements under ASC 606 / IFRS 15. True = revenue recognized; False = not yet recognized or deferred. Supports finance and SOX compliance reporting.' ;
    rdfs:domain ind:IpAgreementMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Threshold Amount' ;
    rdfs:comment 'Annual or cumulative net sales threshold that must be reached to trigger a commercial sales-based milestone payment, expressed in the agreement currency. Applicable only to commercial milestone types with net sales triggers.' ;
    rdfs:domain ind:IpAgreementMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Invoice Number' ;
    rdfs:comment 'SAP S/4HANA FI invoice or billing document number generated upon milestone achievement and payment invoicing. Enables reconciliation between the IP milestone record and the financial accounting system.' ;
    rdfs:domain ind:IpAgreementMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal sequence number of this milestone within the agreement, as defined in the agreement schedule (e.g., 1 = first milestone, 2 = second milestone). Supports ordered reporting and deal progress tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'Specific contractual event or condition that triggers this milestone obligation, as defined in the agreement (e.g., \'Receipt of written FDA approval of NDA for Product X in the United States\', \'First patient dosed in Phase I clinical trial\'). Supports legal review and milestone verification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipValuationId rdf:type rdf:Property ;
    rdfs:label 'Ip Valuation Id' ;
    rdfs:comment 'Unique surrogate identifier for each IP valuation record in the pharmaceutical IP portfolio. Primary key for the ip_valuation data product.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadValuatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Valuator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical finance requires tracking which employee conducted IP valuations for SOX compliance, transfer pricing documentation, and impairment testing. Replaces text field lead_valuator_name with ' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualAmortizationCharge rdf:type rdf:Property ;
    rdfs:label 'Annual Amortization Charge' ;
    rdfs:comment 'Annual amortization expense amount for the IP asset in the valuation currency, calculated based on the carrying value and amortization method. Used for P&L reporting, R&D capitalization decisions, and COGS allocation in pharmaceutical financial statements.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carryingValue rdf:type rdf:Property ;
    rdfs:label 'Carrying Value' ;
    rdfs:comment 'Net book value of the IP asset on the balance sheet as of the valuation date, after accumulated amortization and any impairment charges. Compared against fair market value to determine whether an impairment loss must be recognized under IAS 36.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRatePct rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Pct' ;
    rdfs:comment 'Risk-adjusted discount rate (expressed as a percentage, e.g., 12.50 for 12.5%) applied in the income approach or DCF valuation to convert projected future cash flows to present value. Reflects the weighted average cost of capital (WACC) or IP-specific risk premium. Critical input for sensitivity analysis and impairment testing.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairMarketValue rdf:type rdf:Property ;
    rdfs:label 'Fair Market Value' ;
    rdfs:comment 'Estimated fair market value of the IP asset as of the valuation date, expressed in the valuation currency. Represents the price at which the asset would change hands between a willing buyer and willing seller, neither being under compulsion. Used for IAS 38 intangible asset recognition and balance sheet reporting.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator Flag' ;
    rdfs:comment 'Indicates whether one or more impairment indicators (as defined under IAS 36) were identified for this IP asset at the valuation date. Triggers a formal impairment test when True. Indicators include clinical trial failure, regulatory rejection, loss of market exclusivity, or significant decline in projected revenues.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAssetType rdf:type rdf:Property ;
    rdfs:label 'Ip Asset Type' ;
    rdfs:comment 'Classification of the IP asset being valued. Determines applicable valuation methodology and accounting treatment under IAS 38. Patents cover NCE/NBE/formulation/process IP; trademarks cover brand assets; trade secrets and know-how cover undisclosed proprietary information; exclusivity types cover regulatory-granted market protections. [ENUM-REF-CANDIDATE: patent|trademark|trade_secret|know_how|data_exclusivity|orphan_drug_exclusivity|dmf|rems — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Support Flag' ;
    rdfs:comment 'Indicates whether this valuation was prepared in connection with patent infringement litigation, inter partes review (IPR), or other IP dispute proceedings. When True, the valuation is subject to legal privilege considerations and must be coordinated with external patent litigation counsel.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakSalesForecast rdf:type rdf:Property ;
    rdfs:label 'Peak Sales Forecast' ;
    rdfs:comment 'Projected peak annual net sales attributable to the IP asset, expressed in valuation currency. Key input to income approach and relief-from-royalty DCF models. Derived from commercial forecasting models and used in licensing negotiation and M&A due diligence.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:probabilityOfSuccessPct rdf:type rdf:Property ;
    rdfs:label 'Probability Of Success Pct' ;
    rdfs:comment 'Risk-adjusted probability (expressed as a percentage, e.g., 65.00 for 65%) that the IP asset will achieve full commercial realization, accounting for clinical development risk, regulatory approval probability, and market access uncertainty. Applied as a risk adjustment factor in rNPV (risk-adjusted Net Present Value) income approach valuations.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportIssueDate rdf:type rdf:Property ;
    rdfs:label 'Report Issue Date' ;
    rdfs:comment 'Date on which the formal valuation report was issued by the valuation firm or internal team. May differ from valuation_date when retrospective valuations are performed for M&A due diligence or tax transfer pricing purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAdjustedNpv rdf:type rdf:Property ;
    rdfs:label 'Risk Adjusted Npv' ;
    rdfs:comment 'Risk-adjusted net present value of the IP asset, calculated by applying the probability_of_success_pct to the DCF-derived NPV. Standard valuation metric in pharmaceutical IP for assets still in clinical development. Expressed in valuation currency.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Pct' ;
    rdfs:comment 'Notional or actual royalty rate (expressed as a percentage of net sales) used in the relief-from-royalty valuation method or as the basis for intercompany licensing transfer pricing. Derived from comparable uncontrolled transactions or industry benchmarks for the relevant therapeutic area and IP type.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAssetNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Number' ;
    rdfs:comment 'SAP S/4HANA Fixed Asset (FI-AA module) asset number assigned to the intangible IP asset on the balance sheet. Enables reconciliation between the IP valuation record and the SAP general ledger intangible asset register for IAS 38 balance sheet reporting and amortization posting.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Flag' ;
    rdfs:comment 'Indicates whether this valuation was prepared specifically to support intercompany IP licensing transfer pricing documentation under OECD guidelines. When True, the valuation must comply with OECD BEPS Action 8-10 arm\'s length principle requirements and be included in the transfer pricing master file.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usefulEconomicLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Economic Life Years' ;
    rdfs:comment 'Estimated remaining useful economic life of the IP asset in years as of the valuation date. For patents, typically aligned with remaining patent term or commercial exclusivity period. Drives amortization schedule and DCF projection horizon under IAS 38.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the valuation amounts (fair market value, carrying value, royalty rate base) are expressed. Enables multi-currency consolidation for global pharmaceutical IP portfolios.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The reference date as of which the IP asset fair market value is determined. This is the principal business event date for the valuation — distinct from the date the report was issued or approved. Required for IAS 38 impairment testing and balance sheet reporting.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationFirmName rdf:type rdf:Property ;
    rdfs:label 'Valuation Firm Name' ;
    rdfs:comment 'Name of the external valuation firm or internal team that performed the IP valuation. Required for SOX audit trail and independence assessment. For external valuations, this is the registered firm name (e.g., Big Four accounting firm, specialist IP valuation boutique).' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'Primary valuation methodology applied to determine the IP asset value. Income DCF (Discounted Cash Flow) projects future cash flows attributable to the IP; Relief-from-Royalty estimates value as avoided royalty payments; Market Comparable benchmarks against observable transactions; Cost Approach estimates reproduction/replacement cost; Multi-Period Excess Earnings (MPEEM) isolates IP contribution from total business earnings.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationNotes rdf:type rdf:Property ;
    rdfs:label 'Valuation Notes' ;
    rdfs:comment 'Free-text field for material assumptions, key value drivers, sensitivity analysis commentary, or qualifications noted by the valuator. Captures context that cannot be expressed in structured fields, such as market access assumptions, competitive landscape considerations, or regulatory risk factors specific to the IP asset.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationPurpose rdf:type rdf:Property ;
    rdfs:label 'Valuation Purpose' ;
    rdfs:comment 'Business purpose for which this valuation was commissioned. Determines applicable standard of value and reporting requirements. Balance sheet and impairment test valuations must comply with IAS 38/IAS 36; M&A due diligence supports deal pricing; transfer pricing supports OECD-compliant intercompany IP licensing; litigation support valuations are prepared for patent infringement proceedings.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Valuation Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number assigned to this valuation engagement, typically issued by the valuation firm or internal finance team. Used for cross-referencing with audit files, board papers, and external valuation reports.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current lifecycle state of the valuation record. Draft indicates work-in-progress; in_review indicates submission to finance/legal for approval; approved indicates SOX-compliant sign-off; superseded indicates replaced by a newer valuation; withdrawn indicates cancelled prior to approval.' ;
    rdfs:domain ind:IpValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadPatentCounselEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Patent Counsel Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical competitive intelligence assigns internal IP counsel to watch items for threat assessment, paragraph IV response coordination, and litigation decision-making. Replaces text field lead_p' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedNdc rdf:type rdf:Property ;
    rdfs:label 'Affected Ndc' ;
    rdfs:comment 'The National Drug Code (NDC) of the specific drug product formulation or SKU threatened by the competitor\'s filing. Enables precise linkage to the commercial product portfolio and Orange Book listings.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityName rdf:type rdf:Property ;
    rdfs:label 'Authority Name' ;
    rdfs:comment 'The name of the regulatory or intellectual property authority with which the competitor\'s filing was made, such as FDA, EMA, USPTO, EPO, PMDA, or NMPA. Provides context for applicable rules and timelines.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biosimilarInterchangeability rdf:type rdf:Property ;
    rdfs:label 'Biosimilar Interchangeability' ;
    rdfs:comment 'Indicates whether the competitor\'s aBLA biosimilar application seeks an interchangeability designation with the company\'s reference biologic product. Interchangeable biosimilars may be substituted at the pharmacy level without prescriber intervention, representing a higher commercial threat.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'The date on which the IP watch record was formally closed, indicating that the threat has been resolved, the litigation concluded, the competitor\'s application was withdrawn or rejected, or the matter is no longer actively monitored.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commercialRevenueAtRisk rdf:type rdf:Property ;
    rdfs:label 'Commercial Revenue At Risk' ;
    rdfs:comment 'Estimated annual revenue (in USD) of the affected product that is at risk of erosion if the competitor\'s generic or biosimilar entry is successful. Used to prioritize IP defense investment and inform lifecycle management decisions.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorCountry rdf:type rdf:Property ;
    rdfs:label 'Competitor Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country of incorporation or principal operations of the competitor entity filing the IP activity.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedDate rdf:type rdf:Property ;
    rdfs:label 'Detected Date' ;
    rdfs:comment 'The date on which the company\'s IP watch function first identified or was notified of the competitor\'s filing or IP activity. Used to measure response time and early warning effectiveness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedGenericEntryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Generic Entry Date' ;
    rdfs:comment 'The estimated date on which the competitor\'s generic drug or biosimilar product could enter the market, based on patent expiry, exclusivity expiry, regulatory approval timelines, and litigation outcomes. Critical for lifecycle management and revenue forecasting.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityAtRisk rdf:type rdf:Property ;
    rdfs:label 'Exclusivity At Risk' ;
    rdfs:comment 'The type of regulatory exclusivity period that may be threatened or circumvented by the competitor\'s filing, such as orphan drug exclusivity, data exclusivity, pediatric exclusivity, New Chemical Entity (NCE) exclusivity, New Biological Entity (NBE) exclusivity, or Risk Evaluation and Mitigation Strategy (REMS) protection.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'The date on which the competitor filed the patent application, ANDA, aBLA, or patent challenge with the relevant regulatory or IP authority. This is the principal real-world event date for the watch record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'The official reference number assigned by the regulatory or IP authority to the competitor\'s filing, such as an ANDA application number, aBLA application number, USPTO patent application number, or IPR petition number. Enables direct cross-referencing with public databases.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftoAnalysisRequired rdf:type rdf:Property ;
    rdfs:label 'Fto Analysis Required' ;
    rdfs:comment 'Indicates whether a Freedom-to-Operate (FTO) analysis is required in response to the competitor\'s patent filing or IP activity, to assess whether the company\'s products or processes may infringe the competitor\'s claims.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftoAnalysisStatus rdf:type rdf:Property ;
    rdfs:label 'Fto Analysis Status' ;
    rdfs:comment 'Current status of the Freedom-to-Operate (FTO) analysis associated with this IP watch record, tracking whether the analysis has been initiated, is in progress, or has been completed.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawsuitFiled rdf:type rdf:Property ;
    rdfs:label 'Lawsuit Filed' ;
    rdfs:comment 'Indicates whether the company has filed a patent infringement lawsuit in response to the competitor\'s Paragraph IV certification or other IP challenge. Triggers the 30-month stay of FDA approval under Hatch-Waxman.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawsuitFilingDate rdf:type rdf:Property ;
    rdfs:label 'Lawsuit Filing Date' ;
    rdfs:comment 'The date on which the company filed the patent infringement lawsuit in response to the IP threat. Must be within 45 days of receiving the Paragraph IV notice letter to trigger the 30-month stay.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outsideCounselFirm rdf:type rdf:Property ;
    rdfs:label 'Outside Counsel Firm' ;
    rdfs:comment 'Name of the external law firm engaged to represent the company in litigation or IP proceedings related to this watch record. Classified as confidential due to legal strategy sensitivity.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paragraphIvCertification rdf:type rdf:Property ;
    rdfs:label 'Paragraph Iv Certification' ;
    rdfs:comment 'Indicates whether the competitor\'s ANDA or 505(b)(2) submission includes a Paragraph IV certification asserting that the company\'s listed patent is invalid or will not be infringed. Triggers the 30-month stay provision under the Hatch-Waxman Act.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paragraphIvNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Paragraph Iv Notice Date' ;
    rdfs:comment 'The date on which the company received the formal Paragraph IV notice letter from the ANDA or 505(b)(2) applicant, as required under the Hatch-Waxman Act. The 45-day window to file suit and trigger the 30-month stay begins from this date.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendedResponse rdf:type rdf:Property ;
    rdfs:label 'Recommended Response' ;
    rdfs:comment 'The recommended strategic or legal response to the identified IP threat, such as filing a patent infringement lawsuit, filing an IPR petition, seeking a preliminary injunction, entering licensing negotiations, or monitoring without action. Classified as confidential due to legal strategy sensitivity.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'The final outcome of the IP dispute or watch activity upon closure, indicating whether the matter was settled (e.g., licensing agreement), won by the company, lost (competitor entry permitted), withdrawn by the competitor, dismissed by the authority, or remains ongoing.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'The statutory or internally-set deadline by which the company must initiate a legal or regulatory response to the IP threat (e.g., 45-day deadline to file suit following Paragraph IV notice, IPR petition deadline of 1 year from service of infringement complaint).' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Narrative summary of the risk assessment conducted by the IP and legal team, describing the basis for the risk level assignment, key vulnerabilities, and potential commercial exposure. Classified as confidential due to legal strategy sensitivity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirtyMonthStayExpiry rdf:type rdf:Property ;
    rdfs:label 'Thirty Month Stay Expiry' ;
    rdfs:comment 'The date on which the 30-month stay of FDA approval expires following a Paragraph IV certification and timely patent infringement lawsuit. Null if no Paragraph IV certification was filed. Critical for generic entry timeline planning.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:watchNotes rdf:type rdf:Property ;
    rdfs:label 'Watch Notes' ;
    rdfs:comment 'Free-text field for additional context, observations, or legal strategy notes related to the IP watch record, entered by the IP analyst or legal counsel. Classified as confidential due to potential legal strategy content.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Watch Reference Number' ;
    rdfs:comment 'Externally-known business identifier assigned to this IP watch record, used for cross-referencing with legal counsel, RIMS, and Veeva Vault RIM module. Typically follows a structured format such as IPW-YYYY-NNNNNN.' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchSource rdf:type rdf:Property ;
    rdfs:label 'Watch Source' ;
    rdfs:comment 'The source or monitoring service through which the IP activity was identified, such as FDA Orange Book, FDA ANDA database, USPTO patent database, EPO database, EMA biosimilar register, Derwent Innovation, Clarivate IP watch service, or internal monitoring. [ENUM-REF-CANDIDATE: fda_orange_book|fda_anda_database|uspto_database|epo_database|ema_register|derwent_innovation|clarivate_watch|internal_monitoring|third_party_service — promote to reference product]' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchStatus rdf:type rdf:Property ;
    rdfs:label 'Watch Status' ;
    rdfs:comment 'Current lifecycle state of the IP watch record, indicating whether the threat is newly identified (open), being assessed (under_review), escalated to legal or senior management, actively monitored (monitoring), or resolved (closed).' ;
    rdfs:domain ind:IpWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Licensor Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Licensing agreements require tracking licensor legal entity for contract management, revenue recognition, and intercompany royalty accounting in pharmaceutical partnerships.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:licensorVendorId rdf:type rdf:Property ;
    rdfs:label 'Licensor Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: In-licensing agreements often involve API/technology suppliers as licensors. Linking enables supplier qualification, audit tracking, and contract management integration. Licensor_name is denormalized;' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:territoryCountryId rdf:type rdf:Property ;
    rdfs:label 'Territory Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: License territories define geographic scope; essential for revenue allocation, royalty calculation, and compliance with territorial restrictions in pharmaceutical licensing.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:changeOfControlProvision rdf:type rdf:Property ;
    rdfs:label 'Change Of Control Provision' ;
    rdfs:comment 'Indicates whether the agreement contains a change-of-control clause that grants termination or renegotiation rights upon acquisition or merger of either party. True = change-of-control provision exists; False = no such provision. Critical for M&A due diligence and IP portfolio valuation.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Commercial Milestone Value' ;
    rdfs:comment 'Aggregate value of all commercial milestone payments (e.g., first commercial sale, annual net sales thresholds) defined in the agreement, expressed in the agreement currency. Supports commercial launch planning and ASC 606 variable consideration estimation.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Development Milestone Value' ;
    rdfs:comment 'Aggregate value of all development-stage milestone payments (e.g., IND submission, Phase I/II/III completion) defined in the agreement, expressed in the agreement currency. Supports clinical development budget planning and ASC 606 variable consideration estimation.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diligenceObligations rdf:type rdf:Property ;
    rdfs:label 'Diligence Obligations' ;
    rdfs:comment 'Narrative description of the commercially reasonable efforts or best efforts diligence obligations imposed on the licensee to develop and commercialize the licensed product. Failure to meet diligence obligations may trigger termination rights. Used for partner relationship management and compliance monitoring.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving disputes between the parties. Arbitration: binding arbitration under specified rules (e.g., ICC, AAA). Litigation: resolution through courts of the governing jurisdiction. Mediation: non-binding mediation before escalation. Expert-determination: technical disputes resolved by independent expert.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldOfUse rdf:type rdf:Property ;
    rdfs:label 'Field Of Use' ;
    rdfs:comment 'Specific therapeutic area, indication, or application domain within which the licensee is permitted to use the licensed IP. Examples: \'oncology\', \'rare diseases\', \'human therapeutics only\', \'diagnostic use\'. Restricts the scope of the license and is critical for exclusivity analysis and sublicensing rights management.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the interpretation and enforcement of the agreement. Determines applicable contract law, dispute resolution procedures, and regulatory compliance obligations.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Licensed Asset Description' ;
    rdfs:comment 'Narrative description of the intellectual property assets covered by the license, including compound names (INN/USAN), patent numbers, know-how, trade secrets, trademarks, or biological sequences. Supports IP portfolio management and freedom-to-operate analysis.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedAssetType rdf:type rdf:Property ;
    rdfs:label 'Licensed Asset Type' ;
    rdfs:comment 'Classification of the primary intellectual property asset type covered by the agreement. Patent: granted patent rights. Know-how: proprietary technical knowledge. Trademark: brand or trade name rights. Data-package: regulatory data exclusivity or clinical data. Biological-sequence: gene or protein sequence rights. Trade-secret: confidential proprietary information. [ENUM-REF-CANDIDATE: patent|know-how|trademark|data-package|biological-sequence|trade-secret|formulation|process — promote to reference product]' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of contractually defined milestone events (development, regulatory, and commercial) specified in the agreement. Used for milestone tracking dashboards, deal management reporting, and ASC 606 performance obligation identification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Regulatory Milestone Value' ;
    rdfs:comment 'Aggregate value of all regulatory milestone payments (e.g., NDA/BLA/MAA submission, FDA/EMA approval) defined in the agreement, expressed in the agreement currency. Supports regulatory affairs planning and ASC 606 variable consideration estimation.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightOfFirstNegotiation rdf:type rdf:Property ;
    rdfs:label 'Right Of First Negotiation' ;
    rdfs:comment 'Indicates whether the agreement grants either party a right of first negotiation (ROFN) for additional territories, indications, or follow-on compounds. True = ROFN exists; False = no ROFN. Relevant for lifecycle management and business development strategy.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyBase rdf:type rdf:Property ;
    rdfs:label 'Royalty Base' ;
    rdfs:comment 'The contractual basis on which royalties are calculated. Net-sales: royalties applied to net sales after standard deductions. Gross-sales: royalties applied to gross sales before deductions. Net-revenue: royalties applied to net revenue. Units-sold: royalties calculated per unit sold. Determines the royalty accounting methodology.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRate rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate' ;
    rdfs:comment 'Contractual royalty rate expressed as a decimal fraction of net sales (e.g., 0.050000 = 5.0%) payable by the licensee to the licensor. Used for royalty accrual calculations, revenue recognition under ASC 606/IFRS 15, and P&L forecasting. Null if the agreement uses a tiered royalty structure captured in a separate milestone/royalty schedule.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sublicensingPermitted rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Permitted' ;
    rdfs:comment 'Indicates whether the licensee has the contractual right to sublicense the licensed IP to third parties (e.g., CMOs, CDMOs, or sub-distributors). True = sublicensing permitted; False = sublicensing prohibited. Impacts CMO/CDMO engagement and supply chain structuring.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationConditions rdf:type rdf:Property ;
    rdfs:label 'Termination Conditions' ;
    rdfs:comment 'Summary of the contractual conditions under which either party may terminate the agreement, including material breach cure periods, insolvency triggers, regulatory failure events, and convenience termination rights. Used by legal counsel for contract management and risk assessment.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDealValue rdf:type rdf:Property ;
    rdfs:label 'Total Deal Value' ;
    rdfs:comment 'Total potential deal value including upfront payments, all milestone payments, and estimated royalties over the agreement term, expressed in the agreement currency. Used for deal valuation, P&L forecasting, and investor disclosure. Represents the gross deal value before probability-weighting.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Total Milestone Value' ;
    rdfs:comment 'Sum of all contractually defined milestone payment amounts across all milestone events in the agreement, expressed in the agreement currency. Represents the maximum milestone-based consideration achievable under the agreement. Used for deal valuation and revenue recognition planning.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Upfront Payment Amount' ;
    rdfs:comment 'One-time upfront license fee or signing payment due at execution of the agreement, expressed in the agreement currency. Recognized as revenue or capitalized as an intangible asset depending on the nature of the license under ASC 606/IFRS 15. Part of the MONETARY_TRIPLET for this MASTER_AGREEMENT.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orangeBookListingId rdf:type rdf:Property ;
    rdfs:label 'Orange Book Listing Id' ;
    rdfs:comment 'Unique surrogate identifier for each Orange Book listing record in the intellectual property portfolio system. Primary key for this data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrangeBookListing .

ind:andaFirstFilerFlag rdf:type rdf:Property ;
    rdfs:label 'Anda First Filer Flag' ;
    rdfs:comment 'Indicates whether a first-filer ANDA applicant has been identified for this patent listing, triggering the 180-day generic exclusivity period under Hatch-Waxman. True if a first filer has been designated; False otherwise. Affects the timing of subsequent generic approvals.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'Name of the NDA/BLA holder (marketing authorization holder) who submitted the patent or exclusivity listing to the FDA Orange Book. Identifies the company responsible for maintaining the listing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delistingDate rdf:type rdf:Property ;
    rdfs:label 'Delisting Date' ;
    rdfs:comment 'Date on which the patent or exclusivity was removed from the FDA Orange Book, either voluntarily by the NDA holder or by FDA order. Null if the listing remains active. Relevant for tracking generic entry eligibility changes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstGenericEligibilityDate rdf:type rdf:Property ;
    rdfs:label 'First Generic Eligibility Date' ;
    rdfs:comment 'Earliest date on which a generic drug product may receive final FDA approval, accounting for both patent expiry and exclusivity expiry dates. Derived from the later of patent expiry, exclusivity expiry, and 30-month stay expiry. Critical for lifecycle management and loss-of-exclusivity (LOE) planning.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingDate rdf:type rdf:Property ;
    rdfs:label 'Listing Date' ;
    rdfs:comment 'Date on which the patent or exclusivity was first listed in the FDA Orange Book by the NDA holder. Establishes the effective date of the listing for Paragraph IV certification and 30-month stay calculations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current status of the Orange Book listing record. \'Active\' indicates the patent or exclusivity is currently listed and enforceable. \'Delisted\' indicates the NDA holder has removed the listing. \'Withdrawn\' indicates FDA-initiated removal. \'Pending\' indicates submission under review. \'Corrected\' indicates an amendment was filed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationStatus rdf:type rdf:Property ;
    rdfs:label 'Litigation Status' ;
    rdfs:comment 'Current status of patent infringement litigation associated with this Orange Book listing, typically arising from a Paragraph IV certification. Tracks whether litigation is active, settled, or resolved by court judgment. Informs LOE risk assessment and legal strategy. [ENUM-REF-CANDIDATE: none|active|settled|judgment_for_patentee|judgment_for_challenger|appeal_pending|dismissed — promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaNumber rdf:type rdf:Property ;
    rdfs:label 'Nda Number' ;
    rdfs:comment 'FDA-assigned application number (NDA, ANDA, or BLA) under which the drug product is approved and listed in the Orange Book. Governs which patents and exclusivities are associated with the approved product.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDrugDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Designation Flag' ;
    rdfs:comment 'Indicates whether the listed drug product holds an FDA Orphan Drug Designation (ODD), conferring 7-year market exclusivity upon approval. True if ODD is active; False otherwise. Relevant for rare disease portfolio strategy and generic entry defense.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paragraphIvDate rdf:type rdf:Property ;
    rdfs:label 'Paragraph Iv Date' ;
    rdfs:comment 'Date on which the first Paragraph IV certification was received by the NDA holder for this listed patent. Initiates the 45-day window to file patent infringement suit and triggers the 30-month stay clock if suit is filed.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paragraphIvFlag rdf:type rdf:Property ;
    rdfs:label 'Paragraph Iv Flag' ;
    rdfs:comment 'Indicates whether a Paragraph IV certification has been filed by an ANDA applicant challenging this listed patent as invalid, unenforceable, or not infringed. True triggers the 45-day notice period and potential 30-month stay of ANDA approval.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentTermExtensionFlag rdf:type rdf:Property ;
    rdfs:label 'Patent Term Extension Flag' ;
    rdfs:comment 'Indicates whether the listed patent has been granted a Patent Term Extension (PTE) under 35 U.S.C. § 156 to compensate for regulatory review time. True if a PTE has been granted; False otherwise. Affects the effective patent expiry date used for generic entry calculations.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentType rdf:type rdf:Property ;
    rdfs:label 'Patent Type' ;
    rdfs:comment 'Classification of the listed patent as covering the drug substance (active ingredient), drug product (formulation/composition), or method of use. Determines the nature of Paragraph IV challenges and carve-out labeling strategies.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentUseCode rdf:type rdf:Property ;
    rdfs:label 'Patent Use Code' ;
    rdfs:comment 'FDA-assigned use code (e.g., U-001) that identifies the specific approved method of use covered by the listed patent. Required for method-of-use patents; determines the scope of Paragraph IV certifications and carve-out labeling eligibility.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pediatricExclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Pediatric Exclusivity Flag' ;
    rdfs:comment 'Indicates whether a 6-month pediatric exclusivity extension has been granted under the Best Pharmaceuticals for Children Act (BPCA), attaching to all existing patents and exclusivities for the listed product. True if pediatric exclusivity is in effect.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceListedDrugFlag rdf:type rdf:Property ;
    rdfs:label 'Reference Listed Drug Flag' ;
    rdfs:comment 'Indicates whether this NDA product is designated as the Reference Listed Drug (RLD) against which ANDA applicants must demonstrate bioequivalence. True if the product is the RLD; False if it is a non-RLD listed product.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remsFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Flag' ;
    rdfs:comment 'Indicates whether the listed drug product is subject to an FDA-approved Risk Evaluation and Mitigation Strategy (REMS). REMS requirements may affect generic applicant ability to demonstrate shared REMS compliance, impacting generic entry timelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spcExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Spc Expiry Date' ;
    rdfs:comment 'Date on which the Supplementary Protection Certificate (SPC) expires in the relevant EU/UK jurisdiction. Represents the effective end of patent-based market protection for the listed product in that market.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spcNumber rdf:type rdf:Property ;
    rdfs:label 'Spc Number' ;
    rdfs:comment 'Reference number of the Supplementary Protection Certificate (SPC) granted in EU/UK jurisdictions to extend patent protection beyond the standard 20-year term for medicinal products. Applicable for EU and UK market listings; null for US Orange Book entries.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticEquivalenceCode rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Equivalence Code' ;
    rdfs:comment 'FDA therapeutic equivalence evaluation code assigned to the drug product in the Orange Book (e.g., AB, AA, BC, BX). \'A\' codes indicate therapeutically equivalent to the RLD; \'B\' codes indicate not therapeutically equivalent. Drives pharmacy substitution decisions and formulary management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirtyMonthStayExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Thirty Month Stay Expiry Date' ;
    rdfs:comment 'Date on which the 30-month stay of ANDA approval expires following a timely-filed patent infringement suit in response to a Paragraph IV certification. After this date, FDA may grant final ANDA approval regardless of ongoing litigation outcome.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustedExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Adjusted Expiry Date' ;
    rdfs:comment 'Final effective expiry date after applying all patent term adjustments (PTA), patent term extensions (PTE) for regulatory review delays, and supplementary protection certificates (SPC). Represents the true end of patent exclusivity for commercial planning purposes.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annuityPaidThroughDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Paid Through Date' ;
    rdfs:comment 'Date through which patent annuity (maintenance) fees have been paid, confirming the patent is in good standing. Used by IP operations to monitor fee payment compliance and prevent unintentional lapse.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClassification rdf:type rdf:Property ;
    rdfs:label 'Asset Classification' ;
    rdfs:comment 'Broader intellectual property asset classification for this record. Primarily \'patent\' for this product, but also supports trade secrets and know-how records anchored to the patent master per the SSOT design. Enables unified IP portfolio reporting across asset types.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExclusivityExpiry rdf:type rdf:Property ;
    rdfs:label 'Data Exclusivity Expiry' ;
    rdfs:comment 'Date on which regulatory data exclusivity (RDE) expires, preventing generic/biosimilar applicants from referencing the originator\'s clinical data. In the US, NCEs receive 5 years; biologics receive 12 years under BPCIA. In the EU, the 8+2+1 rule applies. Complements patent expiry in LOE planning.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ftoClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Fto Clearance Status' ;
    rdfs:comment 'Current freedom-to-operate (FTO) analysis status for this patent relative to the company\'s commercial activities. Cleared indicates no infringement risk identified; at_risk indicates potential third-party patent conflict; blocked indicates active infringement concern; under_review indicates ongoing FTO analysis. Critical for launch readiness and litigation risk management.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'Date on which the patent was officially granted by the patent office, conferring enforceable rights to the assignee. Null for applications still under examination. Used to calculate patent term adjustments (PTA) and supplementary protection certificate (SPC) eligibility.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Status' ;
    rdfs:comment 'Current legal standing of the patent in its jurisdiction lifecycle. Pending indicates application under examination; granted indicates active protection; abandoned/lapsed indicates failure to prosecute or maintain; opposed indicates third-party challenge; litigated indicates active court proceedings. Drives LOE planning and portfolio valuation. [ENUM-REF-CANDIDATE: pending|granted|abandoned|expired|lapsed|opposed|litigated — promote to reference product]' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceFeeDueDate rdf:type rdf:Property ;
    rdfs:label 'Maintenance Fee Due Date' ;
    rdfs:comment 'Next scheduled date by which maintenance (annuity) fees must be paid to the patent office to keep the patent in force. Failure to pay results in lapse of patent rights. Critical for IP portfolio maintenance operations.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orangeBookListed rdf:type rdf:Property ;
    rdfs:label 'Orange Book Listed' ;
    rdfs:comment 'Indicates whether this patent is listed in the FDA Approved Drug Products with Therapeutic Equivalence Evaluations (Orange Book). Orange Book listing triggers Paragraph IV certification obligations for ANDA filers and is central to Hatch-Waxman litigation strategy.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orphanDrugExclusivityExpiry rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Exclusivity Expiry' ;
    rdfs:comment 'Date on which orphan drug market exclusivity expires, granting 7 years (US) or 10 years (EU) of market protection for drugs treating rare diseases. Distinct from patent expiry and critical for rare disease portfolio lifecycle planning.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Number' ;
    rdfs:comment 'Officially assigned patent number issued by the relevant patent office (e.g., USPTO, EPO, WIPO). Serves as the primary external business identifier for the patent. Format varies by jurisdiction (e.g., US10123456B2, EP3456789A1).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pediatricExclusivityExpiry rdf:type rdf:Property ;
    rdfs:label 'Pediatric Exclusivity Expiry' ;
    rdfs:comment 'Date on which the 6-month pediatric exclusivity extension expires, granted by the FDA under the Best Pharmaceuticals for Children Act (BPCA) for conducting pediatric studies. Attaches to and extends both patent and data exclusivity periods.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityDate rdf:type rdf:Property ;
    rdfs:label 'Priority Date' ;
    rdfs:comment 'Earliest claimed priority date, typically the date of the first-filed application in the patent family (provisional or national phase). Determines prior art cutoff and is critical for freedom-to-operate (FTO) analyses and validity challenges.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prosecutionStatus rdf:type rdf:Property ;
    rdfs:label 'Prosecution Status' ;
    rdfs:comment 'Detailed status of the patent application within the prosecution workflow at the patent office. Provides granular tracking beyond legal_status for IP counsel and patent attorneys managing active applications. [ENUM-REF-CANDIDATE: filed|examination|office_action|response_pending|allowed|granted|abandoned — promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpleBookListed rdf:type rdf:Property ;
    rdfs:label 'Purple Book Listed' ;
    rdfs:comment 'Indicates whether this patent is listed in the FDA Purple Book (List of Licensed Biological Products). Relevant for biologics and biosimilar entry defense under the Biologics Price Competition and Innovation Act (BPCIA).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termAdjustmentDays rdf:type rdf:Property ;
    rdfs:label 'Term Adjustment Days' ;
    rdfs:comment 'Number of days added to the patent term by the USPTO as Patent Term Adjustment (PTA) to compensate for delays in patent prosecution caused by the USPTO. Directly impacts the effective expiry date calculation.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Term Extension Days' ;
    rdfs:comment 'Number of days added to the patent term under 35 U.S.C. § 156 (US) to compensate for time lost during FDA regulatory review of the drug product. Maximum extension is 5 years; total remaining term cannot exceed 14 years post-approval.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsiblePatentCounselEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Patent Counsel Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical patent prosecution tracks which internal IP attorney manages each claim for office action responses, amendment strategy, and litigation support. Replaces text field responsible_patent_c' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'The date on which the most recent amendment to this claim was filed or entered. Null if the claim has never been amended. Used to track prosecution history and assess prosecution history estoppel in infringement proceedings.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'The official application number assigned by the patent office upon filing (e.g., US 16/123,456 or EP 19 123 456.7). Used to track prosecution history, office actions, and correspondence with patent counsel. Serves as the primary external identifier for the application.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimAmendmentVersion rdf:type rdf:Property ;
    rdfs:label 'Claim Amendment Version' ;
    rdfs:comment 'Version number tracking amendments made to the claim text during prosecution or post-grant proceedings (e.g., reexamination, IPR). Version 1 represents the originally filed claim; subsequent versions reflect amendments. Used to maintain prosecution history and support claim construction arguments.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimCategory rdf:type rdf:Property ;
    rdfs:label 'Claim Category' ;
    rdfs:comment 'Subject matter category of the claim defining what is being protected. Composition claims protect chemical or biological entities (NCE, NBE, API); method/use claims protect therapeutic uses or manufacturing processes; formulation claims protect drug product (DP) compositions; dosage form claims protect FDF configurations. [ENUM-REF-CANDIDATE: composition|method|process|apparatus|use|formulation|dosage_form|biological — promote to reference product]' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Sequential number of the claim within the patent document as filed or granted (e.g., Claim 1, Claim 2). Claim numbering follows USPTO and EPO conventions and is used in legal proceedings, IPR petitions, and freedom-to-operate analyses.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPriorityDate rdf:type rdf:Property ;
    rdfs:label 'Claim Priority Date' ;
    rdfs:comment 'The earliest effective filing date from which this claim\'s priority is established, including priority claims under Paris Convention or PCT. The priority date determines prior art cutoff and is critical for validity assessments and patent term calculations.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimScopeClassification rdf:type rdf:Property ;
    rdfs:label 'Claim Scope Classification' ;
    rdfs:comment 'Business classification of the claim\'s legal breadth and coverage. Broad claims cover wide ranges of embodiments; narrow claims are limited to specific embodiments. Genus claims cover a class of compounds or methods; species claims cover a specific member. Used in lifecycle management and generic/biosimilar entry defense strategy.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimText rdf:type rdf:Property ;
    rdfs:label 'Claim Text' ;
    rdfs:comment 'Full verbatim text of the claim as it appears in the granted patent or pending application. This is the legally operative language used in infringement assessments, IPR petitions, inter partes review proceedings, and freedom-to-operate (FTO) analyses. Classified confidential due to strategic IP sensitivity.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Structural classification of the claim indicating whether it stands alone (independent) or references and narrows a prior claim (dependent or multiple dependent). Independent claims define the broadest scope; dependent claims add limitations. Critical for infringement analysis and claim charting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpcClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Cpc Classification Code' ;
    rdfs:comment 'The Cooperative Patent Classification (CPC) code assigned by USPTO or EPO, providing more granular technical classification than IPC. Used in patent landscape analyses, freedom-to-operate searches, and competitive intelligence for drug discovery and CMC domains.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftoRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Fto Relevance Flag' ;
    rdfs:comment 'Indicates whether this claim has been identified as relevant in one or more freedom-to-operate (FTO) analyses. FTO-relevant claims require monitoring for potential infringement by third-party products or by the company\'s own pipeline compounds.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipcClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Ipc Classification Code' ;
    rdfs:comment 'The International Patent Classification (IPC) code assigned to this claim, indicating the technical field of the invention (e.g., A61K for pharmaceutical preparations, A61P for therapeutic activity). Used for patent landscape analyses, competitive intelligence, and prior art searches.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iprPetitionNumber rdf:type rdf:Property ;
    rdfs:label 'Ipr Petition Number' ;
    rdfs:comment 'The official PTAB (Patent Trial and Appeal Board) or EPO Opposition Division case number for any active or completed inter partes review (IPR) or opposition proceeding challenging this claim. Null if no IPR or opposition has been filed. Critical for litigation tracking and generic/biosimilar defense strategy.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOrangeBookListed rdf:type rdf:Property ;
    rdfs:label 'Is Orange Book Listed' ;
    rdfs:comment 'Indicates whether this claim is associated with a patent listed in the FDA Orange Book (Approved Drug Products with Therapeutic Equivalence Evaluations). Orange Book listing triggers 30-month stay provisions under Hatch-Waxman upon ANDA Paragraph IV certification, directly impacting generic entry timelines.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPurpleBookListed rdf:type rdf:Property ;
    rdfs:label 'Is Purple Book Listed' ;
    rdfs:comment 'Indicates whether this claim is associated with a patent listed in the FDA Purple Book (Lists of Licensed Biological Products). Purple Book listing is relevant for biosimilar entry defense under the Biologics Price Competition and Innovation Act (BPCIA) patent dance provisions.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:litigationCaseReference rdf:type rdf:Property ;
    rdfs:label 'Litigation Case Reference' ;
    rdfs:comment 'Court case number or docket reference for any active or completed patent infringement litigation involving this claim (e.g., Paragraph IV ANDA litigation, biosimilar patent dance disputes). Classified confidential due to legal privilege sensitivity. Null if no litigation is associated.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moleculeType rdf:type rdf:Property ;
    rdfs:label 'Molecule Type' ;
    rdfs:comment 'Classification of the molecule or biological entity protected by this claim. NCE (New Chemical Entity) for small molecules; NBE (New Biological Entity) for large molecule biologics; biosimilar for follow-on biologics; vaccine, gene therapy, or cell therapy for advanced therapy medicinal products (ATMPs). Determines applicable regulatory pathway and exclusivity provisions.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Claim Number' ;
    rdfs:comment 'For dependent claims, the claim number of the parent claim from which this claim depends. Null for independent claims. Used to reconstruct claim dependency trees for infringement and validity analyses.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patentOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Patent Office Code' ;
    rdfs:comment 'Code identifying the patent office where this claim was filed or is being prosecuted. USPTO (US), EPO (European), UKIPO (UK post-Brexit), JPO (Japan), CNIPA (China), WIPO (PCT international). Determines applicable procedural rules and examination standards. [ENUM-REF-CANDIDATE: USPTO|EPO|UKIPO|JPO|CNIPA|WIPO|PMDA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentTermExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Patent Term Extension Months' ;
    rdfs:comment 'Number of months of patent term extension granted to compensate for regulatory review delays during NDA/BLA/MAA approval processes. In the US, PTE is granted under 35 U.S.C. § 156 (Hatch-Waxman); in Europe, via Supplementary Protection Certificate (SPC). Directly impacts loss-of-exclusivity (LOE) date calculations.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validityStatus rdf:type rdf:Property ;
    rdfs:label 'Validity Status' ;
    rdfs:comment 'Current legal standing of the claim. Valid claims are enforceable; invalid claims have been found unpatentable; cancelled claims were withdrawn during prosecution or post-grant proceedings; amended claims were modified during IPR or reexamination; under_review indicates active challenge proceedings; stayed indicates enforcement is paused pending litigation outcome.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCountryId rdf:type rdf:Property ;
    rdfs:label 'Priority Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Priority country is fundamental to patent family strategy and filing decisions; required for PCT strategy and global patent portfolio management.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:annualMaintenanceCostUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Maintenance Cost Usd' ;
    rdfs:comment 'Total annualized cost in US dollars for maintaining all active member patents in this family, including renewal fees, annuities, and agent fees across all jurisdictions. Used for IP budget planning and portfolio rationalization decisions.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataExclusivityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Exclusivity Expiry Date' ;
    rdfs:comment 'The date on which regulatory data exclusivity (RDE) protection expires for the drug covered by this patent family. Data exclusivity prevents generic/biosimilar applicants from referencing the originator\'s clinical data for a defined period (e.g., 5 years NCE in US, 8+2+1 years in EU).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earliestExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Expiry Date' ;
    rdfs:comment 'The earliest expiration date among all granted member patents in the family, before any patent term extensions or supplementary protection certificates. Critical for generic/biosimilar entry defense strategy planning.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:familyCode rdf:type rdf:Property ;
    rdfs:label 'Family Code' ;
    rdfs:comment 'Internally assigned alphanumeric code uniquely identifying the patent family within the IP management system. Used for cross-referencing across Veeva Vault RIM and SAP IP modules.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Descriptive name assigned to the patent family, typically reflecting the invention title or the compound/technology it covers (e.g., \'Compound X Formulation Family\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyStatus rdf:type rdf:Property ;
    rdfs:label 'Family Status' ;
    rdfs:comment 'Current lifecycle status of the patent family. \'Active\' indicates at least one member patent is in force; \'Pending\' indicates applications under examination; \'Expired\' indicates all members have lapsed; \'Abandoned\' indicates prosecution was discontinued. [ENUM-REF-CANDIDATE: active|pending|expired|abandoned|licensed_out|litigated — promote to reference product]' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'Classification of the patent family grouping methodology. \'Simple\' groups patents sharing the same priority; \'Extended\' includes equivalents; \'INPADOC\' follows the European Patent Office INPADOC definition. [ENUM-REF-CANDIDATE: simple|extended|INPADOC|domestic|international — promote to reference product]' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freedomToOperateStatus rdf:type rdf:Property ;
    rdfs:label 'Freedom To Operate Status' ;
    rdfs:comment 'Current status of the Freedom-to-Operate (FTO) analysis for this patent family. \'Cleared\' indicates no blocking third-party patents identified; \'At Risk\' indicates potential infringement risk; \'Blocked\' indicates a blocking patent exists; \'Under Review\' indicates analysis in progress.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantedMemberCount rdf:type rdf:Property ;
    rdfs:label 'Granted Member Count' ;
    rdfs:comment 'Number of patent applications within the family that have been granted (issued) patents across all jurisdictions. Distinguishes granted protection from pending applications for portfolio strength assessment.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventionCategory rdf:type rdf:Property ;
    rdfs:label 'Invention Category' ;
    rdfs:comment 'Classification of the type of invention covered by the patent family. New Chemical Entity (NCE) covers novel small molecules; New Biological Entity (NBE) covers biologics; formulation covers drug product compositions; process covers manufacturing methods; method_of_use covers therapeutic indications. [ENUM-REF-CANDIDATE: NCE|NBE|formulation|process|combination|device|method_of_use — promote to reference product]' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionTitle rdf:type rdf:Property ;
    rdfs:label 'Invention Title' ;
    rdfs:comment 'The official title of the invention as stated in the priority or PCT application. Reflects the technical scope of the patent family and is used for portfolio reporting and IP strategy communications.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCount rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Count' ;
    rdfs:comment 'Number of distinct national or regional jurisdictions in which the patent family has at least one active member application or granted patent. Measures geographic breadth of IP protection.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latestExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Latest Expiry Date' ;
    rdfs:comment 'The latest expiration date among all granted member patents in the family, including any patent term extensions (PTE) or supplementary protection certificates (SPC). Defines the outer boundary of IP exclusivity for lifecycle management.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensingStatus rdf:type rdf:Property ;
    rdfs:label 'Licensing Status' ;
    rdfs:comment 'Indicates whether the patent family is subject to a licensing arrangement. \'Licensed In\' means the company holds a license from a third party; \'Licensed Out\' means the company has granted a license to a third party; \'Cross Licensed\' indicates a bilateral arrangement.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of individual patent applications and granted patents that are members of this family across all jurisdictions. Indicates the breadth of global IP coverage for the invention.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orphanDrugExclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the invention covered by this patent family has been granted orphan drug designation and associated market exclusivity (7 years in the US, 10 years in the EU). Relevant for rare disease portfolio strategy.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentRegisterListed rdf:type rdf:Property ;
    rdfs:label 'Patent Register Listed' ;
    rdfs:comment 'Indicates whether patents in this family are listed on the EMA European Patent Register or national patent registers linked to marketing authorisations, triggering data exclusivity and market protection provisions.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentTermExtensionGranted rdf:type rdf:Property ;
    rdfs:label 'Patent Term Extension Granted' ;
    rdfs:comment 'Indicates whether a Patent Term Extension (PTE) or Supplementary Protection Certificate (SPC) has been granted for any member of this family, compensating for regulatory review time under FDA or EMA processes.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pctApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Pct Application Number' ;
    rdfs:comment 'The international application number filed under the Patent Cooperation Treaty (PCT) administered by WIPO, if applicable. Format: PCT/[country code][year]/[serial number]. Enables simultaneous patent protection in multiple jurisdictions.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctFilingDate rdf:type rdf:Property ;
    rdfs:label 'Pct Filing Date' ;
    rdfs:comment 'The international filing date of the PCT application, if applicable. Determines the 30/31-month national phase entry deadline for member jurisdictions.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pctPublicationNumber rdf:type rdf:Property ;
    rdfs:label 'Pct Publication Number' ;
    rdfs:comment 'The WIPO publication number assigned to the PCT international application upon publication (e.g., WO2023/123456). Used for public disclosure tracking and prior art searches.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pediatricExclusivityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pediatric Exclusivity Expiry Date' ;
    rdfs:comment 'The expiry date of pediatric exclusivity granted under the Best Pharmaceuticals for Children Act (BPCA) in the US or the Paediatric Regulation in the EU, adding 6 months of additional exclusivity to qualifying patents.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioSegment rdf:type rdf:Property ;
    rdfs:label 'Portfolio Segment' ;
    rdfs:comment 'Strategic classification of the patent family within the IP portfolio. \'Core\' patents protect primary commercial products; \'Defensive\' patents block competitor freedom to operate; \'Licensing\' patents are monetized through out-licensing; \'Acquired\' patents came through M&A.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Priority Application Number' ;
    rdfs:comment 'The application number of the earliest-filed patent application that establishes the priority date for the family. Typically a national or regional application number (e.g., US provisional or EP application).' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleIpCounsel rdf:type rdf:Property ;
    rdfs:label 'Responsible Ip Counsel' ;
    rdfs:comment 'Name or identifier of the internal IP attorney or external patent counsel responsible for managing prosecution and maintenance of this patent family. Used for accountability and workload management in the IP department.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentLitigationId rdf:type rdf:Property ;
    rdfs:label 'Patent Litigation Id' ;
    rdfs:comment 'Unique surrogate identifier for each patent litigation case record in the intellectual property portfolio management system.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentLitigation .

ind:defendantVendorId rdf:type rdf:Property ;
    rdfs:label 'Defendant Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: ANDA Paragraph IV litigation tracks generic manufacturers (vendors) as defendants. Linking enables risk assessment for vendor qualification, supply continuity planning, and commercial impact analysis.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:internalCounselEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Counsel Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical patent litigation requires internal counsel ownership for case strategy, budget management, and outside counsel coordination. Replaces text field internal_counsel_name with employee FK ' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLegalSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Legal Spend Usd' ;
    rdfs:comment 'Cumulative actual legal fees and costs incurred to date for this litigation matter, expressed in US dollars. Sourced from SAP S/4HANA FI/CO module legal spend tracking. Used for legal budget management and P&L reporting.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appealCourt rdf:type rdf:Property ;
    rdfs:label 'Appeal Court' ;
    rdfs:comment 'Name of the appellate court or tribunal hearing the appeal (e.g., U.S. Court of Appeals for the Federal Circuit, U.S. Supreme Court, EPO Board of Appeal). Null if no appeal has been filed.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiled rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed' ;
    rdfs:comment 'Indicates whether an appeal has been filed following the trial court or PTAB judgment. True if an appeal is pending or has been decided; False if no appeal was filed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assertedPatentNumbers rdf:type rdf:Property ;
    rdfs:label 'Asserted Patent Numbers' ;
    rdfs:comment 'Semicolon-delimited list of patent numbers (e.g., US9,123,456; US10,234,567) asserted or challenged in this litigation. These are the Orange Book-listed or Blue Book-listed patents at issue. Links to the patent portfolio for expiry and claim analysis.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNotes rdf:type rdf:Property ;
    rdfs:label 'Case Notes' ;
    rdfs:comment 'Free-text field for internal legal team notes, strategic observations, and case-specific commentary. May include attorney work product summaries, risk assessments, and strategic recommendations. Classified as confidential due to potential attorney-client privilege content.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Official court-assigned or tribunal-assigned docket number uniquely identifying the litigation case (e.g., civil action number, IPR petition number, PGR petition number). Serves as the primary external business identifier for cross-referencing with legal counsel and court records.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePriority rdf:type rdf:Property ;
    rdfs:label 'Case Priority' ;
    rdfs:comment 'Internal priority classification assigned to the litigation case based on revenue at risk, strategic importance, and likelihood of adverse outcome. Critical cases receive executive-level oversight; high cases are monitored by senior IP counsel; medium and low cases follow standard legal management processes.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the litigation case by legal mechanism. Paragraph IV ANDA challenges arise under Hatch-Waxman; IPR and PGR are USPTO trial proceedings; patent infringement suits are district court actions; declaratory judgment actions are filed by generic/biosimilar challengers; biosimilar patent dance refers to BPCIA exchange proceedings. [ENUM-REF-CANDIDATE: paragraph_iv_anda|inter_partes_review|post_grant_review|patent_infringement|declaratory_judgment|biosimilar_patent_dance — promote to reference product]' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtOrTribunal rdf:type rdf:Property ;
    rdfs:label 'Court Or Tribunal' ;
    rdfs:comment 'Name of the judicial or administrative body presiding over the case (e.g., U.S. District Court for the District of Delaware, USPTO Patent Trial and Appeal Board (PTAB), U.S. Court of Appeals for the Federal Circuit, European Patent Office Opposition Division).' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLiabilityUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Liability Usd' ;
    rdfs:comment 'Management\'s best estimate of the potential financial exposure or liability associated with this litigation case, expressed in US dollars. Used for legal reserve provisioning, financial disclosure under ASC 450 (contingencies), and SOX compliance. Includes potential damages, lost profits, and legal costs.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstFilerStatus rdf:type rdf:Property ;
    rdfs:label 'First Filer Status' ;
    rdfs:comment 'Indicates whether the ANDA challenger is the first filer entitled to 180-day generic exclusivity under the Hatch-Waxman Act. True if the defendant holds first-filer status; False otherwise. Relevant for assessing the competitive landscape and timing of generic entry.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:institutionDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Institution Decision Date' ;
    rdfs:comment 'Date on which the PTAB issued its decision on whether to institute the IPR or PGR trial. A decision to institute means the petition met the threshold for review. Null for non-PTAB proceedings.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:judgmentDate rdf:type rdf:Property ;
    rdfs:label 'Judgment Date' ;
    rdfs:comment 'Date on which the court or tribunal issued its final judgment, final written decision (for PTAB proceedings), or order. Null if the case has not yet reached judgment.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadOutsideCounsel rdf:type rdf:Property ;
    rdfs:label 'Lead Outside Counsel' ;
    rdfs:comment 'Full name of the lead attorney at the outside counsel firm responsible for managing this litigation matter. Used for escalation, communication, and legal budget accountability.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Legal Budget Usd' ;
    rdfs:comment 'Approved annual or total budget allocated for legal fees and costs associated with this litigation matter, expressed in US dollars. Used for variance analysis against actual legal spend and budget reforecasting.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextKeyMilestone rdf:type rdf:Property ;
    rdfs:label 'Next Key Milestone' ;
    rdfs:comment 'Description of the next significant procedural or substantive milestone in the litigation (e.g., claim construction hearing, expert discovery deadline, summary judgment motion, PTAB oral argument, appellate briefing deadline). Used for litigation calendar management.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMilestoneDate rdf:type rdf:Property ;
    rdfs:label 'Next Milestone Date' ;
    rdfs:comment 'Scheduled date for the next key procedural or substantive milestone in the litigation. Used for proactive legal calendar management and escalation triggers.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plaintiffName rdf:type rdf:Property ;
    rdfs:label 'Plaintiff Name' ;
    rdfs:comment 'Legal name of the party initiating the litigation (typically the innovator/NDA holder asserting patent rights, or the generic/biosimilar applicant filing a declaratory judgment action). May be the company itself or a subsidiary.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAtRiskUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue At Risk Usd' ;
    rdfs:comment 'Estimated annual revenue at risk if the litigation outcome is unfavorable and generic or biosimilar entry occurs earlier than the patent expiry date. Expressed in US dollars. Critical input for lifecycle management decisions and commercial strategy.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date on which a settlement agreement was executed between the parties, if the case was resolved through settlement rather than judgment. Null for cases resolved by judgment or still active.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementEntryDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Entry Date' ;
    rdfs:comment 'Agreed date on which the generic or biosimilar entrant is permitted to launch its product under the terms of the settlement agreement. Critical for lifecycle management and revenue forecasting. Null for non-settlement outcomes.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suitFiledDate rdf:type rdf:Property ;
    rdfs:label 'Suit Filed Date' ;
    rdfs:comment 'Date on which the NDA holder filed the patent infringement suit in response to the Paragraph IV notice, within the 45-day statutory window. Null for case types where the company is the defendant or for non-Hatch-Waxman proceedings.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialDate rdf:type rdf:Property ;
    rdfs:label 'Trial Date' ;
    rdfs:comment 'Scheduled or actual date of the trial or oral hearing before the court or tribunal. For PTAB proceedings, this is the oral argument date. Null if trial has not been scheduled or the case settled prior to trial.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prosecutionAttorneyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prosecution Attorney Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical IP operations assign internal attorneys to prosecution matters for docket management, office action response coordination, and quality metrics. Replaces text field prosecution_attorney ' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abandonmentDate rdf:type rdf:Property ;
    rdfs:label 'Abandonment Date' ;
    rdfs:comment 'Date the application was formally abandoned, either expressly by the applicant or by operation of law (e.g., failure to respond to office action within statutory period or failure to pay issue fee). Null unless prosecution_stage = \'abandoned\'.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annuityDueDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Due Date' ;
    rdfs:comment 'Date by which the annuity or maintenance fee for the current fee year must be paid to maintain the patent in force. Failure to pay by this date (or within the grace period) results in patent lapse. Critical docketing field.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annuityFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annuity Fee Amount' ;
    rdfs:comment 'Base annuity or maintenance fee amount due for the current fee year, in the currency specified by annuity_fee_currency. Used for IP budget forecasting and cost tracking across the patent portfolio.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annuityFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Annuity Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annuity fee amount (e.g., USD, EUR, JPY, GBP, CNY). Required for multi-currency portfolio cost consolidation and budget reporting.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuityFeeYear rdf:type rdf:Property ;
    rdfs:label 'Annuity Fee Year' ;
    rdfs:comment 'The renewal/annuity year number for which the most recent maintenance fee obligation applies (e.g., year 3, year 7, year 12). Annuity years are counted from the filing date in most jurisdictions. Used for fee schedule management and budget forecasting.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annuityGracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Grace Period End Date' ;
    rdfs:comment 'Last date on which the annuity fee can be paid with a surcharge before the patent lapses. Typically 6 months after annuity_due_date in most jurisdictions. After this date, the patent is irrevocably lapsed unless restoration procedures are available.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annuityPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Payment Date' ;
    rdfs:comment 'Actual date on which the annuity or maintenance fee was paid to the patent office or paying agent. Used to confirm timely payment and to calculate any applicable surcharges.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annuityPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Annuity Payment Status' ;
    rdfs:comment 'Current payment status of the annuity/maintenance fee obligation for the current fee year. Pending = not yet due or awaiting payment; Paid = confirmed payment received; Overdue = past due date, within grace period; Lapsed = grace period expired without payment; Waived = fee waived per applicable rules.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuitySurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Annuity Surcharge Amount' ;
    rdfs:comment 'Late payment surcharge amount applied when the annuity fee is paid after the due date but within the grace period. Tracked separately from the base fee for cost analysis and to identify patterns of late payment.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of the patent application by filing type. Utility = standard non-provisional; Provisional = 12-month placeholder; PCT = Patent Cooperation Treaty international; Continuation/Divisional/CIP = derived from parent application. Determines prosecution rules and term calculations. CIP = Continuation-In-Part.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCount rdf:type rdf:Property ;
    rdfs:label 'Claim Count' ;
    rdfs:comment 'Total number of claims in the current version of the patent application or granted patent, including independent and dependent claims. Affects official filing fees in many jurisdictions and indicates the breadth of IP protection sought.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpcClassification rdf:type rdf:Property ;
    rdfs:label 'Cpc Classification' ;
    rdfs:comment 'Cooperative Patent Classification (CPC) code assigned by USPTO or EPO (e.g., A61K 31/4745). More granular than IPC; used for patent analytics, freedom-to-operate (FTO) searches, and competitive landscape mapping.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinerArtUnit rdf:type rdf:Property ;
    rdfs:label 'Examiner Art Unit' ;
    rdfs:comment 'Patent office art unit or examination division to which the application is assigned (e.g., USPTO Art Unit 1627 for pharmaceutical compositions). Informs prosecution strategy based on art unit allowance rates and examiner tendencies.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinerName rdf:type rdf:Property ;
    rdfs:label 'Examiner Name' ;
    rdfs:comment 'Name of the patent examiner assigned to the application at the patent office. Used for prosecution strategy planning, examiner history analysis, and interview request management.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentClaimCount rdf:type rdf:Property ;
    rdfs:label 'Independent Claim Count' ;
    rdfs:comment 'Number of independent claims in the application or granted patent. Independent claims define the broadest scope of protection and are the primary focus of validity and infringement analyses.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventionType rdf:type rdf:Property ;
    rdfs:label 'Invention Type' ;
    rdfs:comment 'Pharmaceutical classification of the invention being patented. NCE (New Chemical Entity) = novel small molecule; NBE (New Biological Entity) = biologic/biosimilar; formulation = drug product composition; process = manufacturing/synthesis method; method_of_use = therapeutic indication; combination = multi-component therapy. Critical for lifecycle management and generic/biosimilar entry defense strategy.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipcClassification rdf:type rdf:Property ;
    rdfs:label 'Ipc Classification' ;
    rdfs:comment 'International Patent Classification (IPC) code assigned to the application (e.g., A61K 31/00 for pharmaceutical preparations). Used for patent landscape analysis, prior art searches, and competitive intelligence. Multiple codes may be stored as a comma-separated string.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOfficeActionDate rdf:type rdf:Property ;
    rdfs:label 'Last Office Action Date' ;
    rdfs:comment 'Date of the most recent office action received from the patent office. Used to calculate the statutory response deadline and to trigger docketing alerts for prosecution attorneys.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officeActionCount rdf:type rdf:Property ;
    rdfs:label 'Office Action Count' ;
    rdfs:comment 'Total number of office actions (rejections, objections, or requirements) received from the patent office during prosecution of this application. Indicates prosecution complexity and is used for cost estimation and strategy assessment.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officeActionType rdf:type rdf:Property ;
    rdfs:label 'Office Action Type' ;
    rdfs:comment 'Classification of the most recent office action received. Restriction = requirement to elect claims; Non-final = first substantive rejection; Final = final rejection after response; Advisory = after final response; Allowance/Notice of Allowance = claims approved for grant.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Application Number' ;
    rdfs:comment 'Application number of the parent patent application from which this application claims priority (applicable for continuation, divisional, or CIP applications). Used to reconstruct the patent family hierarchy and assess claim scope relative to the parent.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentConfirmationReference rdf:type rdf:Property ;
    rdfs:label 'Payment Confirmation Reference' ;
    rdfs:comment 'Official confirmation or receipt reference number issued by the patent office or paying agent upon successful annuity fee payment. Serves as proof of payment for audit and compliance purposes.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prosecutionStage rdf:type rdf:Property ;
    rdfs:label 'Prosecution Stage' ;
    rdfs:comment 'Current stage of the patent application in the prosecution workflow lifecycle. Drives docketing actions, deadline calculations, and portfolio status reporting. Values: filed, examination, office_action_received, response_submitted, allowance, granted, abandoned. [ENUM-REF-CANDIDATE: filed|examination|office_action_received|response_submitted|allowance|granted|abandoned — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prosecutionStrategy rdf:type rdf:Property ;
    rdfs:label 'Prosecution Strategy' ;
    rdfs:comment 'Free-text description of the prosecution strategy adopted for this application, including claim amendment approach, interview strategy, appeal considerations, and alignment with the broader IP lifecycle management plan. Attorney-client privileged content.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationNumber rdf:type rdf:Property ;
    rdfs:label 'Publication Number' ;
    rdfs:comment 'Official publication number assigned by the patent office upon publication of the application (e.g., US20230123456A1, WO2023/012345A1). Distinct from the application number; used for public citation and prior art searches.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentTermExtensionId rdf:type rdf:Property ;
    rdfs:label 'Patent Term Extension Id' ;
    rdfs:comment 'Unique surrogate identifier for each patent term extension or supplementary protection certificate record in the intellectual property portfolio. Primary key for this entity.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalId rdf:type rdf:Property ;
    rdfs:label 'Approval Id' ;
    rdfs:comment 'Reference to the marketing authorization (NDA, BLA, MAA, or national equivalent) that forms the regulatory basis for the patent term extension or SPC application. The first marketing authorization in the relevant jurisdiction is typically required.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Approval .

ind:applicantDelayDays rdf:type rdf:Property ;
    rdfs:label 'Applicant Delay Days' ;
    rdfs:comment 'Number of days deducted from the regulatory review period due to delays attributable to the applicant (e.g., failure to respond to FDA requests within the prescribed period). Reduces the calculated extension duration under 35 U.S.C. § 156(c)(1). Tracked for audit and dispute resolution purposes.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalPhaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Approval Phase Start Date' ;
    rdfs:comment 'For US PTE calculations: the date on which the regulatory approval phase began, typically the date of NDA/BLA submission to the FDA. Used to calculate the approval phase component of the regulatory review period under 35 U.S.C. § 156(g)(1)(B).' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:basePatentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Base Patent Expiry Date' ;
    rdfs:comment 'The original expiry date of the underlying base patent before any term extension or adjustment is applied. Used as the baseline for calculating the adjusted expiry date and the duration of the extension period.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:basePatentNumber rdf:type rdf:Property ;
    rdfs:label 'Base Patent Number' ;
    rdfs:comment 'The official patent number of the underlying patent for which the term extension or SPC is sought (e.g., US10,123,456 or EP1234567). For SPC purposes, this is the \'basic patent\' as defined under Article 1(c) of EU Regulation 469/2009. Retained as a denormalized field for direct reference without joining to the patent table.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculatedExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Calculated Extension Days' ;
    rdfs:comment 'The number of days of patent term extension calculated based on the regulatory review period formula. For US PTE: one-half of the testing phase plus the approval phase, capped at 5 years with remaining patent life not exceeding 14 years post-approval. For EU SPC: period between IND filing and MA grant minus 5 years, capped at 5 years.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'Current lifecycle status of the patent term extension or SPC application. Tracks the application from initial drafting through filing, examination, and final decision by the granting authority. Critical for LOE (Loss of Exclusivity) date calculation and portfolio management. [ENUM-REF-CANDIDATE: draft|filed|under_review|granted|refused|withdrawn|appealed|lapsed|invalidated — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselReference rdf:type rdf:Property ;
    rdfs:label 'External Counsel Reference' ;
    rdfs:comment 'Reference identifier or name of the external patent law firm or legal counsel managing this patent term extension or SPC application. Used for coordination of legal strategy, correspondence tracking, and matter management. Marked confidential as it reflects privileged legal relationships.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantedExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Granted Extension Days' ;
    rdfs:comment 'The actual number of days of patent term extension officially granted by the granting authority. May differ from the calculated extension if the authority applies different determinations of the regulatory review period or applicant delay deductions. Null until the extension is formally granted.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loeDate rdf:type rdf:Property ;
    rdfs:label 'Loe Date' ;
    rdfs:comment 'The effective Loss of Exclusivity (LOE) date for the product in this jurisdiction, accounting for all applicable exclusivity mechanisms (PTE/SPC, pediatric extension, orphan drug exclusivity, data exclusivity). This is the single most critical date for commercial planning, generic/biosimilar entry defense, and lifecycle management strategy. Represents the date after which generic or biosimilar competition may legally enter the market.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Authorization Date' ;
    rdfs:comment 'The date on which the first marketing authorization for the product was granted in the relevant jurisdiction. This date is critical for calculating the regulatory review period and the permissible extension duration under Hatch-Waxman PTE and EU SPC frameworks.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Marketing Authorization Number' ;
    rdfs:comment 'The official marketing authorization number (NDA number, BLA number, EU MA number, or national equivalent) that forms the regulatory basis for the extension application. For EU SPC, this is the first authorization to place the product on the market in the Community per Article 3(b) of Regulation 469/2009.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanismType rdf:type rdf:Property ;
    rdfs:label 'Mechanism Type' ;
    rdfs:comment 'Classification of the patent term extension mechanism. PTE = US Hatch-Waxman Patent Term Extension under 35 U.S.C. § 156; SPC = EU/UK Supplementary Protection Certificate under EC Regulation 469/2009; national_equivalent = country-specific analogous mechanisms (e.g., Japan, Canada, Australia); pediatric_extension = additional 6-month pediatric exclusivity; data_exclusivity = regulatory data protection period. [ENUM-REF-CANDIDATE: PTE|SPC|national_equivalent|pediatric_extension|data_exclusivity|regulatory_data_protection — promote to reference product]' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oppositionDate rdf:type rdf:Property ;
    rdfs:label 'Opposition Date' ;
    rdfs:comment 'The date on which a third-party opposition, invalidity action, or equivalent challenge was filed against this patent term extension or SPC. Null if no opposition has been filed. Used to track litigation timelines and coordinate with legal counsel.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oppositionFiled rdf:type rdf:Property ;
    rdfs:label 'Opposition Filed' ;
    rdfs:comment 'Indicates whether a third party (e.g., generic manufacturer, biosimilar applicant) has filed an opposition, invalidity action, or equivalent challenge against this patent term extension or SPC. True triggers escalation to the legal team for litigation management and LOE date reassessment.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orphanDrugExclusivity rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Exclusivity' ;
    rdfs:comment 'Indicates whether the product covered by this extension also benefits from orphan drug exclusivity (7 years in the US under the Orphan Drug Act, 10 years in the EU under Regulation (EC) No 141/2000). Used in conjunction with PTE/SPC to determine the effective exclusivity cliff date.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pediatricExtensionEligible rdf:type rdf:Property ;
    rdfs:label 'Pediatric Extension Eligible' ;
    rdfs:comment 'Indicates whether this patent term extension or SPC is eligible for an additional 6-month pediatric extension under the US Best Pharmaceuticals for Children Act (BPCA) or EU Paediatric Regulation (EC) No 1901/2006. True if a Written Request (US) or Paediatric Investigation Plan (EU) has been completed and accepted.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReviewPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Period Days' ;
    rdfs:comment 'The total number of days of the regulatory review period as determined by the granting authority. For US PTE, this is the period from IND filing to NDA/BLA approval, reduced by any applicant-caused delays. Directly determines the maximum permissible extension duration under 35 U.S.C. § 156.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spcProductDefinition rdf:type rdf:Property ;
    rdfs:label 'Spc Product Definition' ;
    rdfs:comment 'For EU/UK SPC applications only: the definition of the \'product\' as per Article 1(b) of EU Regulation 469/2009, specifying the active ingredient or combination of active ingredients of a medicinal product. This definition determines the scope of SPC protection and is critical for freedom-to-operate analyses and generic entry defense.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingPhaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Testing Phase Start Date' ;
    rdfs:comment 'For US PTE calculations: the date on which the regulatory review testing phase began, typically the date of IND (Investigational New Drug) application submission. Used to calculate the testing phase component of the regulatory review period under 35 U.S.C. § 156(g)(1).' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyPaymentId rdf:type rdf:Property ;
    rdfs:label 'Royalty Payment Id' ;
    rdfs:comment 'Unique system-generated identifier for each royalty payment transaction record within the intellectual property portfolio management system.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRoyaltyBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Royalty Business Partner Id' ;
    rdfs:comment 'Reference to the party granting the license (the entity receiving royalty payments in an outbound scenario or paying in an inbound scenario).' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Indicates whether this royalty payment record has been flagged for formal royalty audit review, typically triggered by discrepancies between reported sales and expected royalty amounts or by contractual audit rights.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Period End Date' ;
    rdfs:comment 'End date of the royalty calculation period for which net sales or units sold are being reported and royalties computed. Together with start date defines the reporting window per the licensing agreement.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Period Start Date' ;
    rdfs:comment 'Start date of the royalty calculation period (e.g., quarter or year) for which net sales or units sold are being reported and royalties computed. Aligns with licensing agreement reporting obligations.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Deductions Amount' ;
    rdfs:comment 'Total allowable deductions applied to gross sales to arrive at net sales, as defined in the licensing agreement. Typically includes chargebacks, rebates, returns, freight, and applicable taxes.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total gross sales revenue generated from the licensed product during the calculation period, before any deductions. Used as the starting point for net sales calculation per the licensing agreement definition.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licensedTerritory rdf:type rdf:Property ;
    rdfs:label 'Licensed Territory' ;
    rdfs:comment 'Geographic territory or market for which the royalty payment applies, as defined in the licensing agreement. May be a country code (ISO 3166-1 alpha-3), region, or \'GLOBAL\'. Supports territory-level royalty analytics.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Royalty Amount' ;
    rdfs:comment 'Contractual minimum royalty amount guaranteed per period as specified in the licensing agreement, regardless of actual sales performance. Applicable when the calculated royalty falls below this floor.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Net Sales Amount' ;
    rdfs:comment 'Net sales revenue for the licensed product during the calculation period, calculated as gross sales minus allowable deductions per the licensing agreement definition. Forms the royalty basis for net-sales-based agreements.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this royalty payment transaction, typically matching the SAP FI document number or bank remittance reference used for reconciliation and audit trail.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Royalty Amount' ;
    rdfs:comment 'Calculated royalty amount due for the calculation period, derived by applying the royalty rate to the applicable royalty basis (net sales, gross sales, or units sold). This is the principal monetary fact of the transaction.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Royalty Basis' ;
    rdfs:comment 'The contractual basis upon which the royalty is calculated, as defined in the licensing agreement. Common bases include net sales, gross sales, units sold, milestone achievements, or sublicense revenue.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyReportReference rdf:type rdf:Property ;
    rdfs:label 'Royalty Report Reference' ;
    rdfs:comment 'Reference number or identifier of the royalty statement or sales report submitted by the licensee that forms the basis for this royalty payment calculation. Links the payment to the supporting documentation.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyTierLabel rdf:type rdf:Property ;
    rdfs:label 'Royalty Tier Label' ;
    rdfs:comment 'Label identifying the applicable royalty tier when the licensing agreement specifies tiered rates based on cumulative net sales thresholds (e.g., \'Tier 1: 0-$100M\', \'Tier 2: $100M-$500M\'). Null if the agreement uses a flat rate.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'Number of units of the licensed product sold during the calculation period. Used as the royalty basis for unit-based royalty agreements. Expressed as DECIMAL to accommodate partial units or volume-based measures.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spcFilingId rdf:type rdf:Property ;
    rdfs:label 'Spc Filing Id' ;
    rdfs:comment 'Unique system-generated identifier for each Supplementary Protection Certificate (SPC) filing record in the intellectual property portfolio. Primary key for this entity. Entity role: TRANSACTION_HEADER — an SPC filing is a discrete regulatory/legal application event with its own lifecycle, granting authority, and expiry outcome.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleIpCounselEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Ip Counsel Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical regulatory exclusivity management assigns internal IP counsel to SPC filings for deadline tracking, opposition monitoring, and annuity coordination. Replaces text field responsible_ip_c' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:basicPatentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Basic Patent Expiry Date' ;
    rdfs:comment 'The expiry date of the underlying basic patent. The SPC term commences on the day the basic patent expires and cannot exceed 5 years (or 5.5 years with paediatric extension). Essential for calculating SPC start date and total exclusivity runway.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalLawFirm rdf:type rdf:Property ;
    rdfs:label 'External Law Firm' ;
    rdfs:comment 'Name of the external patent law firm or agent engaged to prosecute or maintain the SPC filing in the relevant jurisdiction. Supports vendor management, legal spend tracking, and coordination of multi-jurisdictional SPC prosecution strategies.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the SPC filing, reflecting the workflow state from initial application through granting authority decision. Drives lifecycle management decisions and generic/biosimilar entry defense strategies. [ENUM-REF-CANDIDATE: pending|granted|refused|withdrawn|lapsed|under_appeal — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstEuMaDate rdf:type rdf:Property ;
    rdfs:label 'First Eu Ma Date' ;
    rdfs:comment 'The date of the first marketing authorization granted within the European Union or European Economic Area for the product. Under EU SPC Regulation, the SPC duration is calculated using the first MA date in the Community, which may differ from the national MA date. Critical for accurate SPC term calculation in EU member states.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paediatricExtensionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Paediatric Extension Expiry Date' ;
    rdfs:comment 'The revised SPC expiry date after application of the 6-month paediatric extension. Populated only when paediatric_extension_granted is True. This date represents the final loss-of-exclusivity (LOE) date for the product in the jurisdiction and is the operative date for generic/biosimilar market entry planning.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paediatricExtensionGranted rdf:type rdf:Property ;
    rdfs:label 'Paediatric Extension Granted' ;
    rdfs:comment 'Indicates whether a 6-month paediatric extension to the SPC has been granted under the EU Paediatric Regulation or equivalent national legislation. A paediatric extension extends the SPC term by an additional 6 months (maximum 5.5 years total) in exchange for completion of a Paediatric Investigation Plan (PIP). Critical for accurate LOE date calculation.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rimsRecordReference rdf:type rdf:Property ;
    rdfs:label 'Rims Record Reference' ;
    rdfs:comment 'The record identifier in the Regulatory Information Management System (RIMS), specifically Veeva Vault RIM, that corresponds to this SPC filing. Enables cross-system traceability between the IP portfolio management system and the regulatory affairs system of record for linked marketing authorization and submission data.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Spc Certificate Number' ;
    rdfs:comment 'The official certificate number assigned by the granting authority upon successful grant of the SPC. Distinct from the application number; this is the formal legal identifier of the granted certificate used in enforcement actions, licensing negotiations, and patent litigation proceedings.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Spc Duration Months' ;
    rdfs:comment 'The duration of SPC protection expressed in months, calculated as the period between the basic patent filing date and the first marketing authorization date, minus 5 years, capped at a maximum of 60 months (5 years). Stored as a raw business fact to support IP portfolio analytics and LOE forecasting without requiring recalculation.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spcFilingType rdf:type rdf:Property ;
    rdfs:label 'Spc Filing Type' ;
    rdfs:comment 'Classification of the SPC filing action type. Original filings establish new SPC protection; extension applications seek paediatric extensions; corrections address errors in granted certificates; transfers record ownership changes; surrenders record voluntary relinquishment of SPC rights.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcStartDate rdf:type rdf:Property ;
    rdfs:label 'Spc Start Date' ;
    rdfs:comment 'The date on which SPC protection commences, which is the day immediately following the expiry of the basic patent. The SPC effectively extends the exclusivity period beyond the standard 20-year patent term to compensate for regulatory approval time lost during clinical development.' ;
    rdfs:domain ind:SpcFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleCounselEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Counsel Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharmaceutical trademark portfolios require internal IP counsel assignment for renewal deadline management, opposition response coordination, and brand protection strategy. Essential for workload bala' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:associatedBrandName rdf:type rdf:Property ;
    rdfs:label 'Associated Brand Name' ;
    rdfs:comment 'The commercial brand name of the pharmaceutical drug product associated with this trademark, if applicable. Links the trademark record to the commercial product portfolio for launch planning and brand protection strategy.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colourClaim rdf:type rdf:Property ;
    rdfs:label 'Colour Claim' ;
    rdfs:comment 'Description of any specific colour or colour combination claimed as a feature of the trademark (e.g., Pantone codes, RGB values, or textual colour descriptions). Relevant for figurative and combined marks where colour is a distinctive element.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclaimerText rdf:type rdf:Property ;
    rdfs:label 'Disclaimer Text' ;
    rdfs:comment 'Any disclaimer of exclusive rights to specific elements of the trademark (e.g., generic or descriptive terms within a combined mark) as required or accepted by the trademark office during examination.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselFirm rdf:type rdf:Property ;
    rdfs:label 'External Counsel Firm' ;
    rdfs:comment 'Name of the external law firm or IP agent responsible for managing the trademark prosecution and maintenance in the relevant jurisdiction. Supports coordination with legal counsel on prosecution strategy and renewal deadlines.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsServicesDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Services Description' ;
    rdfs:comment 'Detailed textual description of the goods and/or services covered by the trademark registration, as specified in the application. For pharmaceutical trademarks, typically describes the therapeutic area, dosage form, and indication of the drug product covered.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innName rdf:type rdf:Property ;
    rdfs:label 'Inn Name' ;
    rdfs:comment 'The WHO-assigned International Nonproprietary Name (INN) of the active pharmaceutical ingredient associated with the trademarked drug product. Used to distinguish the brand trademark from the generic molecule name and to assess potential INN-based conflicts.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Internal Reference Code' ;
    rdfs:comment 'Internal company reference code or docket number assigned to the trademark record in the company\'s IP management system (e.g., Veeva Vault RIM or internal IP docketing system). Enables cross-referencing with internal IP portfolio management tools.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingFlag rdf:type rdf:Property ;
    rdfs:label 'Licensing Flag' ;
    rdfs:comment 'Indicates whether the trademark is subject to one or more active licensing agreements (True) or is exclusively used by the owner entity (False). Supports coordination with the licensing agreements portfolio in the IP domain.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:madridInternationalNumber rdf:type rdf:Property ;
    rdfs:label 'Madrid International Number' ;
    rdfs:comment 'The WIPO-assigned international registration number for trademarks filed under the Madrid Protocol. Populated only when madrid_protocol_flag is True.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:madridProtocolFlag rdf:type rdf:Property ;
    rdfs:label 'Madrid Protocol Flag' ;
    rdfs:comment 'Indicates whether this trademark registration was obtained through the WIPO Madrid Protocol international registration system (True) or through a direct national/regional filing (False). Affects renewal procedures and management workflows.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markType rdf:type rdf:Property ;
    rdfs:label 'Mark Type' ;
    rdfs:comment 'Classification of the trademark by its nature: word mark (text only), figurative mark (logo/image only), combined mark (text and image), three-dimensional mark (shape), sound mark, or colour mark. Drives brand protection strategy and enforcement scope. [ENUM-REF-CANDIDATE: word_mark|figurative_mark|combined_mark|three_dimensional_mark|sound_mark|colour_mark — promote to reference product]' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:niceClassCodes rdf:type rdf:Property ;
    rdfs:label 'Nice Class Codes' ;
    rdfs:comment 'Comma-separated list of Nice Classification class numbers (1–45) under which the trademark is registered. For pharmaceutical trademarks, typically includes Class 5 (pharmaceutical preparations) and potentially Class 10 (medical devices) or Class 44 (medical services). Defines the scope of goods and services covered by the mark.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCode rdf:type rdf:Property ;
    rdfs:label 'Office Code' ;
    rdfs:comment 'Code identifying the trademark office or registry where the application was filed or registration is held (e.g., USPTO for United States, EUIPO for European Union, UKIPO for United Kingdom, JPO for Japan, CNIPA for China, WIPO for international registrations). [ENUM-REF-CANDIDATE: USPTO|EUIPO|UKIPO|JPO|CNIPA|WIPO|CIPO|IP_AUSTRALIA — promote to reference product]' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oppositionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Opposition Deadline Date' ;
    rdfs:comment 'The date by which third parties may file an opposition to the trademark application in the relevant jurisdiction. Critical for monitoring the application\'s progress toward registration and for assessing third-party challenge risk.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oppositionStatus rdf:type rdf:Property ;
    rdfs:label 'Opposition Status' ;
    rdfs:comment 'Current status of any opposition proceedings against the trademark application: not_opposed (no opposition filed), opposition_filed (third-party opposition pending), opposition_withdrawn (opponent withdrew), or opposition_decided (proceeding concluded by the trademark office).' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Owner Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the trademark owner\'s country of domicile or incorporation, as recorded in the trademark register.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityClaimCountryCode rdf:type rdf:Property ;
    rdfs:label 'Priority Claim Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which the priority application was originally filed, as claimed under the Paris Convention.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityClaimDate rdf:type rdf:Property ;
    rdfs:label 'Priority Claim Date' ;
    rdfs:comment 'The date of the earliest priority application claimed under the Paris Convention, if the trademark application claims priority from a prior filing in another jurisdiction. Establishes the effective priority date for multi-jurisdictional filings.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productLaunchCountryCode rdf:type rdf:Property ;
    rdfs:label 'Product Launch Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary market where the associated pharmaceutical drug product is commercially launched or planned for launch under this trademark. Links trademark protection to commercial launch activities.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the trademark registration: pending (application filed, under examination), registered (officially granted), opposed (subject to third-party opposition proceedings), cancelled (registration revoked), expired (lapsed due to non-renewal), or abandoned (application withdrawn or lapsed). Critical for brand protection and commercial launch readiness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalReminderDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Date' ;
    rdfs:comment 'The internal reminder date set for initiating the trademark renewal process, typically set a defined number of months before the official renewal_date. Supports proactive renewal management and avoidance of unintentional lapse.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trademarkName rdf:type rdf:Property ;
    rdfs:label 'Trademark Name' ;
    rdfs:comment 'The brand name, word mark, or slogan that is the subject of the trademark registration (e.g., a proprietary drug brand name). Serves as the primary human-readable identity label for the trademark record.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useAnywhereDate rdf:type rdf:Property ;
    rdfs:label 'Use Anywhere Date' ;
    rdfs:comment 'The date on which the trademark was first used anywhere (not necessarily in commerce) in connection with the identified goods/services. Relevant for establishing priority in use-based trademark systems.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:useInCommerceDate rdf:type rdf:Property ;
    rdfs:label 'Use In Commerce Date' ;
    rdfs:comment 'The date on which the trademark was first used in commerce in connection with the goods/services identified in the registration. Required for use-based trademark systems (e.g., USPTO) and relevant for establishing priority and defending against cancellation for non-use.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:watchServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Watch Service Flag' ;
    rdfs:comment 'Indicates whether a trademark watch service is active for this mark (True), monitoring for conflicting third-party applications in the relevant jurisdictions. Supports proactive brand protection strategy.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchOperatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Batch Operator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GMP regulation 21 CFR 211.188 requires batch records document the operator who performed each manufacturing step. Critical for regulatory inspection readiness, deviation investigation, and GMP account' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Identifier for the manufacturing campaign to which this batch belongs. A campaign is a series of consecutive batches of the same product manufactured in a defined time period using the same equipment and process. Used for campaign-level yield analysis and equipment utilization tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.manufacturing_line. Business justification: Batch records are executed on a specific manufacturing line. The batch_record table has production_line_code (STRING) which should be normalized to a FK to manufacturing_line. This enables access to l' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:supplyInventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Supply Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: Manufacturing batch records must link to supply inventory lots to enable end-to-end traceability from production to distribution. This is critical for product recalls, quality investigations, and supp' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:actualYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Quantity' ;
    rdfs:comment 'The actual quantity of product produced at the end of the manufacturing process. Compared against theoretical yield to calculate yield percentage and identify process inefficiencies or material losses.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Size Quantity' ;
    rdfs:comment 'The planned or target quantity of product to be manufactured in this batch. Expressed in the unit of measure specified in batch_size_uom. Used for yield calculations and material planning.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUom rdf:type rdf:Property ;
    rdfs:label 'Batch Size Uom' ;
    rdfs:comment 'The unit of measure for the batch size quantity. Common units include kilograms (kg) for bulk API, liters (L) for liquids, or discrete units (tablets, vials, capsules) for finished dosage forms. [ENUM-REF-CANDIDATE: kg|g|L|mL|units|tablets|vials|capsules — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch. In-process indicates active manufacturing; Released indicates QA approval for distribution; Rejected indicates failed quality specifications; Quarantine indicates pending investigation or testing; On-hold indicates temporary suspension; Expired indicates past shelf life.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the batch by manufacturing stage. Drug Substance (DS) refers to API production; Drug Product (DP) refers to formulated finished dosage form (FDF). Intermediate refers to in-process materials.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'The number of manufacturing deviations or non-conformances documented during the production of this batch. Deviations require investigation and impact assessment per cGMP. Zero indicates no deviations occurred.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionApproverName rdf:type rdf:Property ;
    rdfs:label 'Disposition Approver Name' ;
    rdfs:comment 'The name of the qualified quality unit personnel who approved the final disposition decision. Must be an authorized individual per the quality management system (QMS).' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'The date on which the final disposition decision was made by the quality unit. Marks the completion of batch review and approval process.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'The final quality decision on the batch. Release indicates approval for distribution; Reject indicates failure to meet specifications; Rework indicates batch will be reprocessed; Destroy indicates batch will be disposed of. This is the authoritative disposition outcome.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionRationale rdf:type rdf:Property ;
    rdfs:label 'Disposition Rationale' ;
    rdfs:comment 'The documented justification for the disposition decision. For rejections, includes the specific quality failures or deviations. For releases, confirms all specifications and cGMP requirements were met. Required for regulatory compliance and audit trail.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringCompliant rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Compliant' ;
    rdfs:comment 'Indicates whether environmental monitoring results (viable and non-viable particulates, temperature, humidity) were within acceptable limits throughout the manufacturing process. Critical for sterile and aseptic manufacturing per cGMP.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formulationVersion rdf:type rdf:Property ;
    rdfs:label 'Formulation Version' ;
    rdfs:comment 'The version number of the product formulation used for this batch. Tracks changes to the formula, process parameters, or specifications. Critical for change control and regulatory submissions (CMC section).' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Classification' ;
    rdfs:comment 'The GMP classification under which this batch was manufactured. cGMP (current Good Manufacturing Practice) is required for commercial and late-stage clinical batches. GMP applies to earlier development batches. Non-GMP may apply to research-only materials.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'The date and time when manufacturing operations for this batch were completed. Marks the end of the production cycle before quality testing and release. Used to calculate cycle time and production efficiency.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'The date and time when manufacturing operations for this batch commenced. Marks the beginning of the batch production cycle. Critical for batch genealogy and process timeline documentation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:patMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Pat Monitoring Enabled' ;
    rdfs:comment 'Indicates whether Process Analytical Technology (PAT) tools were used for real-time monitoring and control of critical quality attributes (CQA) during this batch. PAT enables continuous quality verification per FDA PAT guidance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qbdDesignSpaceCompliance rdf:type rdf:Property ;
    rdfs:label 'Qbd Design Space Compliance' ;
    rdfs:comment 'Indicates whether all critical process parameters (CPP) remained within the approved QbD design space during manufacturing. True indicates full compliance; False indicates deviation requiring investigation. Applicable for products developed under QbD principles per ICH Q8.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Reference' ;
    rdfs:comment 'Reference to the regulatory submission (IND, NDA, BLA, MAA) under which this batch was manufactured. Links the batch to the approved regulatory dossier and ensures manufacturing is conducted per approved CMC specifications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sterilityAssuranceLevel rdf:type rdf:Property ;
    rdfs:label 'Sterility Assurance Level' ;
    rdfs:comment 'The probability of a single viable microorganism being present on a product unit after sterilization. Expressed as SAL-10^-N (e.g., SAL-10^-6 means one in a million probability). Required for sterile products. Not applicable for non-sterile products.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sterilizationMethod rdf:type rdf:Property ;
    rdfs:label 'Sterilization Method' ;
    rdfs:comment 'The sterilization method applied to this batch, if applicable. Required for sterile drug products and certain medical devices. Not applicable for non-sterile products. Method must be validated per regulatory requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoreticalYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Theoretical Yield Quantity' ;
    rdfs:comment 'The expected quantity of product that should be produced based on the master batch record formula and input materials, assuming 100% efficiency with no losses. Used as the baseline for yield percentage calculation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'The ratio of actual yield to theoretical yield expressed as a percentage. Calculated as (actual_yield_quantity / theoretical_yield_quantity) * 100. Deviations from expected yield ranges trigger investigations per cGMP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billOfMaterialsId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Materials Id' ;
    rdfs:comment 'Unique identifier for the bill of materials record. Primary key.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfMaterials .

ind:allergenDeclaration rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration' ;
    rdfs:comment 'Free-text declaration of any known allergens present in the formulation (e.g., lactose, egg protein, soy). Required for labeling and patient safety.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalDerivedMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Animal Derived Material Flag' ;
    rdfs:comment 'Indicates whether any component in this BOM is derived from animal sources. Triggers additional TSE/BSE risk assessment and documentation requirements.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiComponentCount rdf:type rdf:Property ;
    rdfs:label 'Api Component Count' ;
    rdfs:comment 'Number of API components in this BOM. Most formulations have 1-3 APIs; combination products may have more.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'The standard batch size (quantity) for which this BOM is defined. All component quantities are specified relative to this batch size.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, externally visible and used in manufacturing execution and procurement systems.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Only active BOMs may be used in production. Superseded BOMs are retained for historical batch traceability.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version identifier for the BOM. Incremented when formulation or component changes occur. Critical for change control and regulatory traceability.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Reference to the change control record that authorized the creation or modification of this BOM version. Required for GMP compliance and audit trail.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipientComponentCount rdf:type rdf:Property ;
    rdfs:label 'Excipient Component Count' ;
    rdfs:comment 'Number of excipient (inactive ingredient) components in this BOM. Includes binders, fillers, preservatives, stabilizers, etc.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpGradeRequirement rdf:type rdf:Property ;
    rdfs:label 'Gmp Grade Requirement' ;
    rdfs:comment 'The minimum quality grade required for all components in this BOM. Typically GMP or compendial grade for pharmaceutical manufacturing. [ENUM-REF-CANDIDATE: gmp|usp_nf|ep|jp|compendial|food_grade|technical — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halalCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Halal Certified Flag' ;
    rdfs:comment 'Indicates whether this BOM formulation is certified Halal, relevant for certain markets and patient populations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kosherCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kosher Certified Flag' ;
    rdfs:comment 'Indicates whether this BOM formulation is certified Kosher, relevant for certain markets and patient populations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overagePercentage rdf:type rdf:Property ;
    rdfs:label 'Overage Percentage' ;
    rdfs:comment 'Standard overage percentage applied to component quantities to account for process losses, sampling, and testing. Typically 5-15% depending on process capability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingComponentCount rdf:type rdf:Property ;
    rdfs:label 'Packaging Component Count' ;
    rdfs:comment 'Number of packaging material components (primary and secondary) in this BOM. Includes vials, stoppers, labels, cartons, inserts.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qbdDesignSpaceFlag rdf:type rdf:Property ;
    rdfs:label 'Qbd Design Space Flag' ;
    rdfs:comment 'Indicates whether this BOM was developed using Quality by Design principles with an established design space per ICH Q8.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Reference to the regulatory submission (NDA, BLA, MAA) that includes this BOM formulation. Critical for ensuring production matches approved formulation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalComponentCount rdf:type rdf:Property ;
    rdfs:label 'Total Component Count' ;
    rdfs:comment 'Total number of distinct component line items (raw materials, APIs, excipients, packaging) in this BOM. Used for completeness validation.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Total Material Cost' ;
    rdfs:comment 'Total cost of all materials (API, excipients, packaging) for one standard batch. Used for COGS calculation and pricing analysis. Currency assumed USD unless otherwise specified.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmoOversightId rdf:type rdf:Property ;
    rdfs:label 'Cmo Oversight Id' ;
    rdfs:comment 'Unique identifier for the CMO/CDMO oversight record. Primary key for tracking contract manufacturing relationships and performance.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Service Agreement Id' ;
    rdfs:comment 'Foreign key linking to supply.service_agreement. Business justification: CMO oversight tracks performance against service agreements. Contract management requires linking oversight scorecards (OTD, quality metrics) to contractual SLAs for vendor performance evaluation and ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceAgreement .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Boolean flag indicating whether the CMO relationship is currently active. True indicates active manufacturing relationship; False indicates terminated or inactive relationship.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current audit status reflecting the outcome of the most recent quality or cGMP compliance audit conducted at the CMO site.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avlStatus rdf:type rdf:Property ;
    rdfs:label 'Avl Status' ;
    rdfs:comment 'Current status of the CMO on the company\'s Approved Vendor List. Approved vendors have passed qualification audits and are authorized for manufacturing activities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSuccessRate rdf:type rdf:Property ;
    rdfs:label 'Batch Success Rate' ;
    rdfs:comment 'Performance metric representing the percentage of manufacturing batches that pass all quality specifications on first attempt without requiring rework or rejection. Indicates manufacturing process capability.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capaClosureRate rdf:type rdf:Property ;
    rdfs:label 'Capa Closure Rate' ;
    rdfs:comment 'Performance metric representing the percentage of Corrective and Preventive Actions (CAPA) closed on time. Indicates effectiveness of quality management and continuous improvement processes.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cgmpCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Cgmp Certification Status' ;
    rdfs:comment 'Status of the CMO\'s current Good Manufacturing Practice certification. Indicates whether the site maintains valid cGMP compliance certification from relevant regulatory authorities.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmoType rdf:type rdf:Property ;
    rdfs:label 'Cmo Type' ;
    rdfs:comment 'Classification of the contract manufacturing organization based on service scope: CMO (manufacturing only), CDMO (development and manufacturing), or specialized service provider.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedProducts rdf:type rdf:Property ;
    rdfs:label 'Contracted Products' ;
    rdfs:comment 'Comma-separated list or description of drug substances, drug products, or SKUs that the CMO is contracted to manufacture. References internal product master data.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationRate rdf:type rdf:Property ;
    rdfs:label 'Deviation Rate' ;
    rdfs:comment 'Performance metric representing the rate of manufacturing deviations, Out of Specification (OOS) events, or non-conformances per batch or per time period. Lower rates indicate better process control.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingCapacity rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Capacity' ;
    rdfs:comment 'Description of the CMO site\'s manufacturing capacity including batch sizes, annual production volume, or throughput capabilities. Used for capacity planning and supply chain risk management.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next quality or compliance audit of the CMO site. Typically based on risk assessment and regulatory requirements for periodic vendor audits.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Performance metric representing the percentage of manufacturing batches or shipments delivered on or before the committed delivery date. Key performance indicator for supply chain reliability.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Reference' ;
    rdfs:comment 'Reference number or identifier for the Quality Agreement governing quality responsibilities, specifications, and compliance obligations between the company and the CMO.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScorecardRating rdf:type rdf:Property ;
    rdfs:label 'Quality Scorecard Rating' ;
    rdfs:comment 'Composite quality performance rating based on multiple metrics including on-time delivery, batch success rate, deviation rate, audit findings, and CAPA effectiveness. Used for vendor performance management.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionHistory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection History' ;
    rdfs:comment 'Summary of recent regulatory inspections by FDA, EMA, PMDA, or other health authorities, including inspection dates and outcomes (e.g., VAI, OAI, NAI classifications).' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManager rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager' ;
    rdfs:comment 'Name of the internal employee or manager responsible for managing the business relationship, contract performance, and communication with the CMO. Primary point of contact for CMO oversight.' ;
    rdfs:domain ind:CmoOversight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Technical Agreement Reference' ;
    rdfs:comment 'Reference number or identifier for the Technical Agreement defining manufacturing processes, specifications, Critical Process Parameters (CPP), and Critical Quality Attributes (CQA).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Id' ;
    rdfs:comment 'Unique identifier for the environmental monitoring record. Primary key.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturingDeviationId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Deviation Id' ;
    rdfs:comment 'Reference to the quality deviation record if this environmental monitoring result triggered a deviation investigation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingDeviation .

ind:primaryEnvironmentalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Environmental Employee Id' ;
    rdfs:comment 'Reference to the laboratory analyst or quality technician who performed the environmental monitoring and analysis.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sampleId rdf:type rdf:Property ;
    rdfs:label 'Sample Id' ;
    rdfs:comment 'Unique identifier for the environmental monitoring sample, typically generated by the LIMS or MES system.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sample .

ind:actionLimit rdf:type rdf:Property ;
    rdfs:label 'Action Limit' ;
    rdfs:comment 'Action limit threshold for the monitoring type and location. Exceeding this limit requires immediate corrective action and deviation investigation.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actionLimitExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Action Limit Exceeded Flag' ;
    rdfs:comment 'Boolean flag indicating whether the action limit was exceeded (True) or not (False).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertLimit rdf:type rdf:Property ;
    rdfs:label 'Alert Limit' ;
    rdfs:comment 'Alert limit threshold for the monitoring type and location. Exceeding this limit triggers investigation but does not necessarily indicate a deviation.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertLimitExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Limit Exceeded Flag' ;
    rdfs:comment 'Boolean flag indicating whether the alert limit was exceeded (True) or not (False).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cfuCount rdf:type rdf:Property ;
    rdfs:label 'Cfu Count' ;
    rdfs:comment 'Number of colony forming units (CFU) detected in the sample. For viable air, typically reported as CFU per cubic meter; for surface, CFU per plate or per area.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cfuPerCubicMeter rdf:type rdf:Property ;
    rdfs:label 'Cfu Per Cubic Meter' ;
    rdfs:comment 'Normalized CFU count per cubic meter of air sampled, calculated for viable air monitoring.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleanroomClassificationIso rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Classification Iso' ;
    rdfs:comment 'ISO 14644-1 cleanroom classification for the monitored area.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanroomGradeEu rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Grade Eu' ;
    rdfs:comment 'EU GMP Annex 1 cleanroom grade classification for the monitored area.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Exposure Duration Minutes' ;
    rdfs:comment 'Duration in minutes that a passive settle plate or contact plate was exposed. Null for active air sampling.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incubationDurationHours rdf:type rdf:Property ;
    rdfs:label 'Incubation Duration Hours' ;
    rdfs:comment 'Duration in hours for which the microbial sample was incubated before reading.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incubationTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Incubation Temperature Celsius' ;
    rdfs:comment 'Temperature in degrees Celsius at which the microbial sample was incubated.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingOperationPhase rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Operation Phase' ;
    rdfs:comment 'Phase of manufacturing operation during which the environmental monitoring was performed: at-rest (no activity), operational (normal production), or intervention (during maintenance or setup).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocationCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Code' ;
    rdfs:comment 'Unique code identifying the specific location within the cleanroom or controlled area where the sample was taken (e.g., FILL-ROOM-A-LOC-001).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Description' ;
    rdfs:comment 'Human-readable description of the monitoring location (e.g., \'Near filling line conveyor belt, 1 meter from HEPA filter\').' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organismIdentified rdf:type rdf:Property ;
    rdfs:label 'Organism Identified' ;
    rdfs:comment 'Name of the microorganism identified in the sample (e.g., Staphylococcus epidermidis, Bacillus species). Null if no growth or if identification not performed.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:particulateCount05Micron rdf:type rdf:Property ;
    rdfs:label 'Particulate Count 0 5 Micron' ;
    rdfs:comment 'Number of particles equal to or greater than 0.5 microns detected per cubic meter for non-viable particulate monitoring.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:particulateCount50Micron rdf:type rdf:Property ;
    rdfs:label 'Particulate Count 5 0 Micron' ;
    rdfs:comment 'Number of particles equal to or greater than 5.0 microns detected per cubic meter for non-viable particulate monitoring.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleCollectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Timestamp' ;
    rdfs:comment 'Date and time when the environmental monitoring sample was collected.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Sample Volume Liters' ;
    rdfs:comment 'Volume of air sampled in liters for viable or non-viable air monitoring. Null for surface or personnel monitoring.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'Specific method used to collect the environmental sample (e.g., active air sampling with impactor, passive settle plate, contact plate, swab, finger dab, glove print).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendFlag rdf:type rdf:Property ;
    rdfs:label 'Trend Flag' ;
    rdfs:comment 'Boolean flag indicating whether this result is part of an adverse trend requiring investigation (True) or not (False).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Unique identifier for the manufacturing equipment asset. Primary key.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:acquisitionCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCriticality rdf:type rdf:Property ;
    rdfs:label 'Asset Criticality' ;
    rdfs:comment 'Business criticality classification of the equipment based on impact to production, product quality, and regulatory compliance. Critical assets require highest priority for maintenance and spare parts availability.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Number of days between required calibrations for this equipment, as defined in the calibration program.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current calibration status of the equipment. Indicates whether the equipment\'s measurement and control systems are within acceptable tolerances.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the equipment capacity value (e.g., liters for reactors, tablets per hour for tablet presses, vials per hour for filling lines). [ENUM-REF-CANDIDATE: liters|kilograms|tablets_per_hour|vials_per_hour|units_per_batch|square_meters|cubic_meters — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Nominal production capacity or throughput of the equipment. The unit of measure is specified in capacity_unit_of_measure.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleanRoomClassification rdf:type rdf:Property ;
    rdfs:label 'Clean Room Classification' ;
    rdfs:comment 'ISO 14644-1 clean room classification of the area where the equipment is installed. Applicable for equipment in controlled environments for sterile or aseptic manufacturing. [ENUM-REF-CANDIDATE: iso_3|iso_4|iso_5|iso_6|iso_7|iso_8|non_classified — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the equipment was commissioned and made ready for qualification activities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:csvStatus rdf:type rdf:Property ;
    rdfs:label 'Csv Status' ;
    rdfs:comment 'Validation status for computerized equipment systems per 21 CFR Part 11 requirements. Applicable to equipment with electronic controls, data acquisition, or automated processes.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'High-level categorization of equipment by operational function: production (API/DP manufacturing), packaging (primary/secondary), quality control (testing/inspection), utilities (water/HVAC/compressed air), or support (material handling/storage).' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDescription rdf:type rdf:Property ;
    rdfs:label 'Equipment Description' ;
    rdfs:comment 'Detailed description of the equipment including its purpose, key features, and operational characteristics.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Descriptive name of the equipment asset (e.g., Reactor-101, Tablet Press Line 3, Lyophilizer A).' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Classification of the equipment based on its function in the manufacturing process. Includes primary manufacturing equipment, utilities, and support systems. [ENUM-REF-CANDIDATE: reactor|blender|granulator|tablet_press|capsule_filler|coating_machine|lyophilizer|autoclave|filling_machine|packaging_line|labeling_machine|inspection_system|fermentor|centrifuge|dryer|mill|sifter|homogenizer|mixer|sterilizer|isolator|laminar_flow_hood|clean_room_hvac|water_system|compressed_air_system|nitrogen_generator|other — 27 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Critical Flag' ;
    rdfs:comment 'Indicates whether this equipment is classified as GMP-critical, meaning it directly impacts product quality, safety, or efficacy and requires enhanced qualification, calibration, and change control.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the equipment was physically installed at the manufacturing site.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iqCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Iq Completion Date' ;
    rdfs:comment 'Date when Installation Qualification was successfully completed and approved.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date when the equipment was last calibrated.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPmDate rdf:type rdf:Property ;
    rdfs:label 'Last Pm Date' ;
    rdfs:comment 'Date when the last scheduled preventive maintenance was completed on this equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next calibration of the equipment to maintain measurement accuracy and GMP compliance.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPmDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Pm Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance activity on this equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextQualificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Qualification Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic requalification of the equipment to maintain GMP compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the equipment. Operational indicates the equipment is available for production use; under_maintenance indicates scheduled or unscheduled maintenance; quarantined indicates the equipment is restricted from use pending investigation; decommissioned indicates permanent removal from service. [ENUM-REF-CANDIDATE: operational|under_maintenance|quarantined|decommissioned|idle|startup|shutdown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oqCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Oq Completion Date' ;
    rdfs:comment 'Date when Operational Qualification was successfully completed and approved.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pqCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pq Completion Date' ;
    rdfs:comment 'Date when Performance Qualification was successfully completed and approved, confirming the equipment consistently performs as intended in the production environment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current qualification status of the equipment per Good Manufacturing Practice (GMP) requirements. Tracks progression through Installation Qualification (IQ), Operational Qualification (OQ), and Performance Qualification (PQ). [ENUM-REF-CANDIDATE: not_qualified|iq_in_progress|iq_complete|oq_in_progress|oq_complete|pq_in_progress|pq_complete|qualified|requalification_required — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapEquipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Equipment Number' ;
    rdfs:comment 'Equipment master record number in SAP PM module used for maintenance planning, work orders, and asset tracking.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagNumber rdf:type rdf:Property ;
    rdfs:label 'Tag Number' ;
    rdfs:comment 'Unique alphanumeric tag number assigned to the equipment for identification and tracking purposes in the manufacturing facility. This is the business identifier used in operations and maintenance.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer\'s warranty coverage for this equipment expires.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentQualificationId rdf:type rdf:Property ;
    rdfs:label 'Equipment Qualification Id' ;
    rdfs:comment 'Unique identifier for the equipment qualification record. Primary key for this entity.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Reference to the specific production line where the equipment operates. Provides manufacturing context for the qualification.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:acceptanceCriteriaSummary rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Summary' ;
    rdfs:comment 'Summary of the key acceptance criteria defined in the qualification protocol. Defines the pass/fail thresholds for qualification tests.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Reference Number' ;
    rdfs:comment 'Reference number of the associated Corrective and Preventive Action (CAPA) record if corrective action was required. Links to the Quality Management System (QMS).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the system user who created this qualification record. Required for 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csvCategory rdf:type rdf:Property ;
    rdfs:label 'Csv Category' ;
    rdfs:comment 'Computer System Validation (CSV) category per Good Automated Manufacturing Practice (GAMP) 5 guidelines. Category 3 (non-configured products), Category 4 (configured products), and Category 5 (custom applications) require different validation approaches.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Engineering Approval Date' ;
    rdfs:comment 'Date when the Engineering department formally approved the qualification from a technical perspective.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringApproverName rdf:type rdf:Property ;
    rdfs:label 'Engineering Approver Name' ;
    rdfs:comment 'Full name of the Engineering representative who reviewed and approved the technical aspects of the qualification.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionEndDate rdf:type rdf:Property ;
    rdfs:label 'Execution End Date' ;
    rdfs:comment 'Date when qualification testing activities were completed. Marks the conclusion of all qualification tests defined in the protocol.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executionStartDate rdf:type rdf:Property ;
    rdfs:label 'Execution Start Date' ;
    rdfs:comment 'Date when qualification testing activities commenced. Marks the beginning of the qualification execution phase.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpImpactClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Impact Classification' ;
    rdfs:comment 'Classification of the equipment based on its impact on product quality and Good Manufacturing Practice (GMP) compliance. GMP Critical equipment directly impacts product quality and requires full qualification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who last modified this qualification record. Required for 21 CFR Part 11 compliance and audit trail.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Requalification Date' ;
    rdfs:comment 'Scheduled date for the next periodic requalification of the equipment. Ensures ongoing compliance with Current Good Manufacturing Practice (cGMP) requirements.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationLeadEmail rdf:type rdf:Property ;
    rdfs:label 'Qualification Lead Email' ;
    rdfs:comment 'Email address of the qualification lead for communication and coordination purposes.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationLeadName rdf:type rdf:Property ;
    rdfs:label 'Qualification Lead Name' ;
    rdfs:comment 'Full name of the individual responsible for leading and coordinating the qualification activities. Primary point of contact for the qualification project.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Qualification Outcome' ;
    rdfs:comment 'Final result of the qualification activity indicating whether the equipment met all acceptance criteria defined in the qualification protocol.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Protocol Number' ;
    rdfs:comment 'Unique protocol document number that defines the qualification test plan and acceptance criteria. Externally-known business identifier for this qualification activity.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Qualification Scope Description' ;
    rdfs:comment 'Detailed description of the qualification scope including systems, subsystems, and Critical Process Parameters (CPP) or Critical Quality Attributes (CQA) being validated.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification activity performed. IQ (Installation Qualification) verifies equipment is installed correctly; OQ (Operational Qualification) verifies equipment operates within specified parameters; PQ (Performance Qualification) verifies equipment consistently produces quality product under normal operating conditions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Quality Approval Date' ;
    rdfs:comment 'Date when the Quality Assurance unit formally approved the qualification results and released the equipment for production use.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityApproverName rdf:type rdf:Property ;
    rdfs:label 'Quality Approver Name' ;
    rdfs:comment 'Full name of the Quality Assurance (QA) representative who reviewed and approved the qualification results. Required for Good Manufacturing Practice (GMP) compliance.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Reference' ;
    rdfs:comment 'Reference number of the risk assessment document that informed the qualification strategy. Aligns with Quality by Design (QbD) principles.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCasesExecutedCount rdf:type rdf:Property ;
    rdfs:label 'Test Cases Executed Count' ;
    rdfs:comment 'Total number of test cases executed during the qualification activity. Provides a measure of qualification scope and thoroughness.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCasesFailedCount rdf:type rdf:Property ;
    rdfs:label 'Test Cases Failed Count' ;
    rdfs:comment 'Number of test cases that did not meet acceptance criteria during qualification execution. Triggers investigation and Corrective and Preventive Action (CAPA) if applicable.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCasesPassedCount rdf:type rdf:Property ;
    rdfs:label 'Test Cases Passed Count' ;
    rdfs:comment 'Number of test cases that met acceptance criteria during qualification execution. Used to calculate pass rate.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationReportNumber rdf:type rdf:Property ;
    rdfs:label 'Validation Report Number' ;
    rdfs:comment 'Document number of the validation report that summarizes qualification results, deviations, and conclusions. Links to the formal documentation package.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Qualification Status' ;
    rdfs:comment 'Current qualification status of the equipment vendor. Vendors must be qualified before their equipment can be used in Good Manufacturing Practice (GMP) production.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryManufacturingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Manufacturing Employee Id' ;
    rdfs:comment 'Reference to the user or personnel who initiated the deviation record.' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryManufacturingApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Manufacturing Approved By User Employee Id' ;
    rdfs:comment 'Reference to the quality assurance or management user who approved the deviation closure.' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cmoCdmoFlag rdf:type rdf:Property ;
    rdfs:label 'Cmo Cdmo Flag' ;
    rdfs:comment 'Indicates whether the deviation occurred at a contract manufacturing organization (CMO) or contract development and manufacturing organization (CDMO) rather than an internal facility.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'Date when the deviation was first identified or detected.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detectionPhase rdf:type rdf:Property ;
    rdfs:label 'Detection Phase' ;
    rdfs:comment 'Manufacturing or quality control phase during which the deviation was detected: in-process (during production), packaging (during fill-finish or labeling), qc_testing (during in-process or final QC), release_testing (during batch release), stability_testing (during ongoing stability studies), post_release (after product distribution).' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Precise date and time when the deviation was first identified, providing granular traceability for time-sensitive deviations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviationNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Number' ;
    rdfs:comment 'Business identifier for the deviation, typically system-generated or manually assigned following organizational numbering convention. Used for external reference and tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationType rdf:type rdf:Property ;
    rdfs:label 'Deviation Type' ;
    rdfs:comment 'Classification of the deviation by root category: process (procedure not followed), equipment (malfunction or failure), material (raw material or component issue), environmental (cleanroom or facility condition), documentation (batch record or SOP error), personnel (training or human error).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the deviation investigation was completed and root cause determined.' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when formal investigation of the deviation was initiated.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingArea rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Area' ;
    rdfs:comment 'Specific production area, cleanroom, or facility location where the deviation occurred (e.g., API synthesis suite, formulation room, fill line 3, packaging hall B).' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Deviation Description' ;
    rdfs:comment 'Detailed narrative description of the deviation event, including what occurred, when it was observed, and the circumstances surrounding the event.' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDeviationStatus rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Deviation Status' ;
    rdfs:comment 'Current lifecycle state of the deviation: open (newly identified), under_investigation (root cause analysis in progress), pending_capa (awaiting corrective action), closed (investigation and actions complete), cancelled (determined not to be a deviation).' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Specific manufacturing process step or operation during which the deviation occurred (e.g., blending, granulation, tablet compression, sterile filtration, lyophilization).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDisposition rdf:type rdf:Property ;
    rdfs:label 'Product Disposition' ;
    rdfs:comment 'Final disposition decision for the affected batch or product: released (approved for distribution), rejected (destroyed or returned), reworked (reprocessed per approved procedure), quarantined (held pending further evaluation), pending_investigation (disposition not yet determined).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qmsSystemReference rdf:type rdf:Property ;
    rdfs:label 'Qms System Reference' ;
    rdfs:comment 'External reference identifier from the source quality management system (MasterControl, TrackWise, or other QMS) for integration and traceability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the deviation was reported to regulatory authorities, if applicable.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether the deviation must be reported to regulatory authorities (FDA, EMA, etc.) based on severity, product impact, or compliance requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Impact classification of the deviation: critical (direct impact on product quality, safety, or efficacy), major (potential impact requiring investigation), minor (no expected impact on product quality).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capacityKgPerBatch rdf:type rdf:Property ;
    rdfs:label 'Capacity Kg Per Batch' ;
    rdfs:comment 'Maximum batch size capacity in kilograms for bulk processing lines such as granulation, blending, or Active Pharmaceutical Ingredient (API) synthesis. Null for unit-based lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Hour' ;
    rdfs:comment 'Rated production capacity of the line expressed as units per hour. For solid dosage forms, this represents tablets or capsules per hour; for liquids, vials or bottles per hour.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverTimeHours rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Hours' ;
    rdfs:comment 'Average time in hours required to perform a product changeover on this manufacturing line, including cleaning, setup, and line clearance activities per Good Manufacturing Practice (GMP) requirements.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Cleaning Validation Status' ;
    rdfs:comment 'Current status of cleaning validation for the manufacturing line. Critical for preventing cross-contamination and ensuring compliance with Current Good Manufacturing Practice (cGMP) per 21 CFR Part 211.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanroomClassification rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Classification' ;
    rdfs:comment 'ISO 14644 or European Union (EU) Good Manufacturing Practice (GMP) Annex 1 cleanroom classification for the manufacturing line environment. Critical for sterile and aseptic manufacturing operations. [ENUM-REF-CANDIDATE: ISO-5|ISO-6|ISO-7|ISO-8|Grade-A|Grade-B|Grade-C|Grade-D|non-classified — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmoCdmoName rdf:type rdf:Property ;
    rdfs:label 'Cmo Cdmo Name' ;
    rdfs:comment 'Name of the Contract Manufacturing Organization (CMO) or Contract Development and Manufacturing Organization (CDMO) operating this line, if applicable. Null for internally operated lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmoCdmoOperated rdf:type rdf:Property ;
    rdfs:label 'Cmo Cdmo Operated' ;
    rdfs:comment 'Indicates whether this manufacturing line is operated by a Contract Manufacturing Organization (CMO) or Contract Development and Manufacturing Organization (CDMO) rather than owned and operated internally.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the manufacturing line was decommissioned and taken out of service. Null for active lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dosageFormType rdf:type rdf:Property ;
    rdfs:label 'Dosage Form Type' ;
    rdfs:comment 'Type of Finished Dosage Form (FDF) produced on this manufacturing line. Aligns with regulatory submissions and product master data. [ENUM-REF-CANDIDATE: tablet|capsule|injectable|lyophilized-vial|suspension|solution|cream|ointment|patch|inhaler — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Required' ;
    rdfs:comment 'Indicates whether the manufacturing line requires environmental monitoring for viable and non-viable particulates per Good Manufacturing Practice (GMP) Annex 1 for sterile manufacturing.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentTrainComposition rdf:type rdf:Property ;
    rdfs:label 'Equipment Train Composition' ;
    rdfs:comment 'Comma-separated list or description of major equipment units that comprise the manufacturing line, such as \'Mixer-Granulator-Dryer-Mill\' or \'Filling Machine-Capper-Labeler\'. Supports equipment traceability and maintenance planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent preventive or corrective maintenance activity performed on the manufacturing line. Supports equipment reliability and Overall Equipment Effectiveness (OEE) tracking.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Business identifier code for the manufacturing line, used in production scheduling, batch records, and Manufacturing Execution System (MES). Typically alphanumeric and unique within a site.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable name or designation of the manufacturing line, such as \'Tablet Compression Line 3\' or \'Sterile Fill-Finish Suite A\'.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the manufacturing line by its primary production function. Defines the type of manufacturing operation performed on this line. [ENUM-REF-CANDIDATE: granulation|blending|compression|coating|filling|lyophilization|packaging|inspection|labeling|serialization — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Mes Integration Status' ;
    rdfs:comment 'Indicates whether the manufacturing line is integrated with the Manufacturing Execution System (MES) for real-time batch tracking, Critical Process Parameter (CPP) monitoring, and electronic batch record generation.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance activity. Used for production scheduling and capacity planning to avoid conflicts with manufacturing campaigns.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percent' ;
    rdfs:comment 'Target Overall Equipment Effectiveness (OEE) percentage for this manufacturing line. OEE is a key performance indicator combining availability, performance, and quality metrics.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patEnabled rdf:type rdf:Property ;
    rdfs:label 'Pat Enabled' ;
    rdfs:comment 'Indicates whether the line is equipped with Process Analytical Technology (PAT) tools for real-time monitoring and control of Critical Quality Attributes (CQA) and Critical Process Parameters (CPP).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'Primary product family or therapeutic category manufactured on this line, such as \'Oncology Tablets\', \'Sterile Injectables\', or \'Oral Solid Dosage Forms\'. Supports product-line affinity and changeover planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date when the current qualification or validation of the manufacturing line expires and requalification is required. Critical for compliance with Current Good Manufacturing Practice (cGMP) and Quality by Design (QbD) principles.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection by Food and Drug Administration (FDA), European Medicines Agency (EMA), or other regulatory authority. Critical for Pre-Approval Inspection (PAI) and ongoing compliance tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serializationCapable rdf:type rdf:Property ;
    rdfs:label 'Serialization Capable' ;
    rdfs:comment 'Indicates whether the manufacturing line is equipped with serialization and track-and-trace capabilities to comply with Drug Supply Chain Security Act (DSCSA) and Falsified Medicines Directive (FMD) requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Operating shift pattern for the manufacturing line. Determines production capacity and labor planning requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedStatus rdf:type rdf:Property ;
    rdfs:label 'Validated Status' ;
    rdfs:comment 'Current validation state of the manufacturing line under Computer System Validation (CSV) and process validation requirements per 21 CFR Part 11 and Good Manufacturing Practice (GMP) guidelines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitsPerYear rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Year' ;
    rdfs:comment 'Annual production capacity of the site measured in units appropriate to the site type (e.g., kilograms of API, millions of tablets, thousands of vials). Used for capacity planning, supply chain optimization, and network strategy.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emaAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Ema Authorization Number' ;
    rdfs:comment 'EMA manufacturing authorization number or EudraGMP identifier for sites manufacturing medicinal products for the European market. Required for GMP compliance verification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Ema Authorization Status' ;
    rdfs:comment 'Current status of the EMA manufacturing authorization indicating whether the site is actively authorized to manufacture for EU markets, authorization has expired, application is pending, authorization is not required, or has been suspended.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringProgram rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Program' ;
    rdfs:comment 'Indicates whether the site has an active environmental monitoring program for tracking viable and non-viable particulates, temperature, humidity, and other environmental conditions in classified manufacturing areas. Required for sterile and aseptic manufacturing operations.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpPlantCode rdf:type rdf:Property ;
    rdfs:label 'Erp Plant Code' ;
    rdfs:comment 'SAP S/4HANA plant code or equivalent ERP system identifier for the manufacturing site. Links site master data to production planning (PP), materials management (MM), quality management (QM), and warehouse management (WM) modules.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaRegistrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Expiry Date' ;
    rdfs:comment 'Date when the current FDA establishment registration expires. FDA registrations must be renewed annually between October 1 and December 31.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Number' ;
    rdfs:comment 'FDA establishment registration number assigned to the site. Required for all facilities manufacturing drugs for the US market per 21 CFR Part 207. Must be renewed annually.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Status' ;
    rdfs:comment 'Current status of the FDA establishment registration indicating whether the site is actively registered, registration has expired, renewal is pending, registration is not required, or registration has been suspended.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Status' ;
    rdfs:comment 'Overall current Good Manufacturing Practice (cGMP) certification status of the site indicating compliance with pharmaceutical quality standards. Certified means site has passed recent GMP inspection, expired means certification has lapsed, pending means inspection scheduled, not certified means site has not been inspected or failed inspection, conditional means certification granted with specific conditions or CAPA requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001CertificationDate rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certification Date' ;
    rdfs:comment 'Date when the site received ISO 9001 certification. ISO 9001 certificates are typically valid for three years with annual surveillance audits.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the site holds ISO 9001 Quality Management System certification. While not required for pharmaceutical manufacturing, ISO 9001 certification demonstrates commitment to quality management best practices.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastGmpInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Gmp Inspection Date' ;
    rdfs:comment 'Date of the most recent GMP inspection conducted by any regulatory authority (FDA, EMA, PMDA, MHRA, etc.). Used to track inspection frequency and predict next inspection window.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mesSiteIdentifier rdf:type rdf:Property ;
    rdfs:label 'Mes Site Identifier' ;
    rdfs:comment 'Unique identifier for the site in the Manufacturing Execution System (MES). Used to link batch records, equipment data, and process parameters to the physical manufacturing location.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextGmpInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Gmp Inspection Due Date' ;
    rdfs:comment 'Expected or scheduled date for the next GMP inspection. Typically inspections occur every 2-3 years for routine surveillance or more frequently for sites with compliance issues or new product approvals.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patCapability rdf:type rdf:Property ;
    rdfs:label 'Pat Capability' ;
    rdfs:comment 'Indicates whether the site has Process Analytical Technology (PAT) capabilities for real-time monitoring and control of critical process parameters (CPP) and critical quality attributes (CQA) during manufacturing. PAT enables continuous process verification and improved process understanding.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:picsMembershipStatus rdf:type rdf:Property ;
    rdfs:label 'Pics Membership Status' ;
    rdfs:comment 'Indicates whether the site is located in a PIC/S member country, enabling mutual recognition of GMP inspections across participating regulatory authorities. Member status facilitates international regulatory acceptance.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbdImplementationStatus rdf:type rdf:Property ;
    rdfs:label 'Qbd Implementation Status' ;
    rdfs:comment 'Indicates the level of Quality by Design (QbD) principles implementation at the site. QbD is a systematic approach to pharmaceutical development that begins with predefined objectives and emphasizes product and process understanding based on sound science and quality risk management.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Quality Management System' ;
    rdfs:comment 'Primary Quality Management System platform deployed at the site for managing deviations, CAPA (Corrective and Preventive Action), change control, and document management. Critical for compliance and audit readiness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Unique business identifier code for the manufacturing site used across enterprise systems and regulatory submissions. Typically alphanumeric code assigned by corporate master data management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Official legal or business name of the manufacturing facility as registered with regulatory authorities and used in regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mbrAuthorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Mbr Author Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: MBR authorship must be tracked for change control accountability, document lifecycle management, regulatory inspection readiness, and technical transfer. GMP requires documented authorship for all con' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByMbrMasterBatchRecordId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Mbr Master Batch Record Id' ;
    rdfs:comment 'Reference to the newer master batch record that supersedes this version, enabling version lineage tracking.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterBatchRecord .

ind:batchSizeMaximum rdf:type rdf:Property ;
    rdfs:label 'Batch Size Maximum' ;
    rdfs:comment 'The maximum allowable batch size that can be manufactured using this master batch record, supporting scale flexibility.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeMinimum rdf:type rdf:Property ;
    rdfs:label 'Batch Size Minimum' ;
    rdfs:comment 'The minimum allowable batch size that can be manufactured using this master batch record, supporting scale flexibility.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeStandard rdf:type rdf:Property ;
    rdfs:label 'Batch Size Standard' ;
    rdfs:comment 'The standard or nominal batch size for which this master batch record is designed, expressed in the unit of measure defined in batch_size_uom.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cgmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cgmp Compliance Flag' ;
    rdfs:comment 'Indicates whether this master batch record is compliant with current Good Manufacturing Practice (cGMP) regulations per 21 CFR Parts 210 and 211.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Equipment Requirements' ;
    rdfs:comment 'Description of the equipment required for executing this master batch record, including specific equipment types, models, or identifiers.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percentage' ;
    rdfs:comment 'The expected theoretical yield for this batch as a percentage, used to calculate acceptable yield ranges and detect deviations.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulationDetails rdf:type rdf:Property ;
    rdfs:label 'Formulation Details' ;
    rdfs:comment 'Detailed formulation information including active pharmaceutical ingredient (API) and excipient quantities, ratios, and specifications. Business-confidential intellectual property.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inProcessControlSpecifications rdf:type rdf:Property ;
    rdfs:label 'In Process Control Specifications' ;
    rdfs:comment 'Summary of in-process control specifications and acceptance criteria that must be met during batch execution, including critical quality attributes (CQAs).' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle status of the master batch record: draft, under review, approved, active (in use), superseded (replaced by newer version), obsolete, or retired. [ENUM-REF-CANDIDATE: draft|under_review|approved|active|superseded|obsolete|retired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingProcessType rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Process Type' ;
    rdfs:comment 'The type of manufacturing process covered by this master batch record: API synthesis, formulation, fill-finish, packaging, blending, granulation, coating, or lyophilization. [ENUM-REF-CANDIDATE: api_synthesis|formulation|fill_finish|packaging|blending|granulation|coating|lyophilization — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mbrNumber rdf:type rdf:Property ;
    rdfs:label 'Mbr Number' ;
    rdfs:comment 'The externally-known unique business identifier for this master batch record, used across manufacturing, quality, and regulatory systems.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mbrTitle rdf:type rdf:Property ;
    rdfs:label 'Mbr Title' ;
    rdfs:comment 'Human-readable title or name of the master batch record, typically including product name and dosage form.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Yield Percentage' ;
    rdfs:comment 'The minimum acceptable yield percentage below which a batch is considered out of specification (OOS) and requires investigation.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Pat Enabled Flag' ;
    rdfs:comment 'Indicates whether Process Analytical Technology (PAT) is implemented for real-time monitoring and control of critical process parameters (CPPs) and critical quality attributes (CQAs).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processDescription rdf:type rdf:Property ;
    rdfs:label 'Process Description' ;
    rdfs:comment 'High-level description of the manufacturing process steps covered by this master batch record, including key operations and sequence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbdApproachFlag rdf:type rdf:Property ;
    rdfs:label 'Qbd Approach Flag' ;
    rdfs:comment 'Indicates whether this master batch record was developed using Quality by Design (QbD) principles per ICH Q8/Q9/Q10.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'The date on which this master batch record was superseded by a newer version and is no longer used for new batches.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processParameterId rdf:type rdf:Property ;
    rdfs:label 'Process Parameter Id' ;
    rdfs:comment 'Unique identifier for the process parameter definition. Primary key for the process parameter entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessParameter .

ind:processStepId rdf:type rdf:Property ;
    rdfs:label 'Process Step Id' ;
    rdfs:comment 'Reference to the specific manufacturing process step where this parameter is measured or controlled. Links to the master process definition.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessStep .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual measured or recorded value of this parameter during batch execution. Captured from Manufacturing Execution System (MES), PAT instruments, or manual operator entry. Used for batch record documentation and process validation.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Conformance Status' ;
    rdfs:comment 'Assessment of whether the measured value meets the defined control and specification limits. Out of Specification (OOS) or Out of Trend (OOT) results trigger investigation and Corrective and Preventive Action (CAPA) processes.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityJustification rdf:type rdf:Property ;
    rdfs:label 'Criticality Justification' ;
    rdfs:comment 'Scientific rationale and risk assessment documentation explaining why this parameter is classified as critical or non-critical. Required for regulatory submissions and Quality by Design (QbD) documentation per ICH Q8.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityHash rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Hash' ;
    rdfs:comment 'Cryptographic hash or checksum of the parameter measurement record to ensure data integrity and detect unauthorized modifications. Supports 21 CFR Part 11 electronic signature and audit trail requirements.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Investigation Required Flag' ;
    rdfs:comment 'Indicates whether this parameter measurement requires formal investigation due to exceeding control or specification limits. True triggers Quality Assurance (QA) review and potential Corrective and Preventive Action (CAPA).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'The lower boundary of the normal operating range for this parameter. Values below this trigger investigation but may not require batch rejection. Used for statistical process control and continuous process verification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'The minimum acceptable value for this parameter as defined in regulatory filings and approved specifications. Values below this limit may result in batch rejection or deviation investigation per Current Good Manufacturing Practice (cGMP).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'The required frequency or timing for measuring this parameter during batch execution. Defines sampling plan and monitoring requirements per the approved batch record. [ENUM-REF-CANDIDATE: continuous|per_batch|hourly|per_shift|daily|on_demand|at_process_step — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The method by which this parameter is measured or recorded. Indicates whether data is captured through Process Analytical Technology (PAT), manual operator entry, or laboratory testing. [ENUM-REF-CANDIDATE: manual_entry|automated_sensor|pat_instrument|laboratory_analysis|inline_measurement|atline_measurement|offline_measurement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The date and time when this parameter measurement was recorded. Critical for establishing batch record chronology and supporting 21 CFR Part 11 electronic records compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the parameter within the manufacturing process. Used for cross-referencing with Manufacturing Execution System (MES) and Process Analytical Technology (PAT) instruments.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Human-readable name of the process parameter (e.g., Mixing Temperature, Compression Force, pH Level, Dissolution Rate).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterType rdf:type rdf:Property ;
    rdfs:label 'Parameter Type' ;
    rdfs:comment 'Classification of the parameter based on its impact on product quality. Critical Process Parameters (CPPs) have direct impact on Critical Quality Attributes (CQAs) and require stringent control per Quality by Design (QbD) principles.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterVersion rdf:type rdf:Property ;
    rdfs:label 'Parameter Version' ;
    rdfs:comment 'Version number of the parameter specification. Incremented when control limits, specification limits, or other parameter attributes are changed through the change control process. Supports regulatory change history requirements.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The intended setpoint or target value for this parameter as defined in the master batch record or process development documentation. Represents the optimal operating point.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The measurement unit for this parameter (e.g., degrees Celsius, bar, pH units, RPM, minutes, mg/mL). Must be consistent with International System of Units (SI) or industry-standard pharmaceutical units.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'The upper boundary of the normal operating range for this parameter. Values above this trigger investigation but may not require batch rejection. Used for statistical process control and continuous process verification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'The maximum acceptable value for this parameter as defined in regulatory filings and approved specifications. Values above this limit may result in batch rejection or deviation investigation per Current Good Manufacturing Practice (cGMP).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'The date and time when this parameter measurement was reviewed and verified by Quality Assurance (QA) or supervisory personnel. Part of the batch record review and release process.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processParameterResultId rdf:type rdf:Property ;
    rdfs:label 'Process Parameter Result Id' ;
    rdfs:comment 'Unique identifier for the process parameter result record. Primary key for this entity.' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProcessEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Process Employee Id' ;
    rdfs:comment 'Reference to the operator or technician who recorded or verified the measurement. Links to employee master for audit trail.' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:evaluationResult rdf:type rdf:Property ;
    rdfs:label 'Evaluation Result' ;
    rdfs:comment 'Result of comparing the measured value against specification limits: Pass (within limits), Fail (out of specification), Warning (approaching limits), Not Evaluated (no limits defined).' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Actual measured value of the process parameter as recorded during batch execution. This is the primary result field.' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Name of the operator or technician who recorded the measurement. Denormalized for audit and compliance reporting.' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patIndicator rdf:type rdf:Property ;
    rdfs:label 'Pat Indicator' ;
    rdfs:comment 'Indicates whether this measurement was captured using Process Analytical Technology (PAT) real-time monitoring tools per FDA PAT guidance.' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingPoint rdf:type rdf:Property ;
    rdfs:label 'Sampling Point' ;
    rdfs:comment 'Physical location or sampling point within the process equipment where the measurement was taken (e.g., Inlet, Outlet, Mid-Point, Probe Location).' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the validated test method or Standard Operating Procedure (SOP) used for the measurement (e.g., SOP-QC-1234, USP Method 621).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processValidationId rdf:type rdf:Property ;
    rdfs:label 'Process Validation Id' ;
    rdfs:comment 'Unique identifier for the process validation record. Primary key.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessValidation .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Pre-defined acceptance criteria that the validation study must meet to be considered successful. Includes Critical Quality Attributes (CQA) specifications, Critical Process Parameters (CPP) ranges, yield targets, impurity limits, and other quality metrics. Must be established before validation execution.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeMax rdf:type rdf:Property ;
    rdfs:label 'Batch Size Max' ;
    rdfs:comment 'Maximum batch size validated in the study, expressed in the unit of measure appropriate for the product. Defines the upper bound of the validated batch size range.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeMin rdf:type rdf:Property ;
    rdfs:label 'Batch Size Min' ;
    rdfs:comment 'Minimum batch size validated in the study, expressed in the unit of measure appropriate for the product (kg for API, number of units for finished dosage form). Defines the lower bound of the validated batch size range.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cppMonitored rdf:type rdf:Property ;
    rdfs:label 'Cpp Monitored' ;
    rdfs:comment 'List of Critical Process Parameters (CPP) monitored during the validation study. CPPs are process parameters whose variability has an impact on a CQA and therefore should be monitored or controlled to ensure the process produces the desired quality. Examples include temperature, pressure, mixing time, pH, flow rate.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cqaMonitored rdf:type rdf:Property ;
    rdfs:label 'Cqa Monitored' ;
    rdfs:comment 'List of Critical Quality Attributes (CQA) monitored during the validation study. CQAs are physical, chemical, biological, or microbiological properties that should be within an appropriate limit, range, or distribution to ensure the desired product quality. Examples include assay, impurities, dissolution, content uniformity, sterility, endotoxin.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designSpaceDefined rdf:type rdf:Property ;
    rdfs:label 'Design Space Defined' ;
    rdfs:comment 'Indicates whether a design space was defined as part of the validation. Design space is the multidimensional combination and interaction of input variables and process parameters that have been demonstrated to provide assurance of quality per ICH Q8. True if design space was established through QbD approach.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfRuns rdf:type rdf:Property ;
    rdfs:label 'Number Of Runs' ;
    rdfs:comment 'Number of validation batches or runs executed as part of the validation study. Typically minimum 3 consecutive successful batches for process validation per FDA guidance. May vary based on validation type and risk assessment.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oosCount rdf:type rdf:Property ;
    rdfs:label 'Oos Count' ;
    rdfs:comment 'Number of Out of Specification (OOS) results encountered during validation execution. OOS results require investigation per FDA OOS guidance and may impact validation outcome.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patImplementation rdf:type rdf:Property ;
    rdfs:label 'Pat Implementation' ;
    rdfs:comment 'Indicates whether Process Analytical Technology (PAT) tools were implemented as part of the validation. PAT is a system for designing, analyzing, and controlling manufacturing through timely measurements of critical quality and performance attributes with the goal of ensuring final product quality. True if PAT tools (e.g., NIR, Raman, in-line sensors) were used.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Protocol Approval Date' ;
    rdfs:comment 'Date when the validation protocol was approved by Quality Assurance and authorized for execution. Represents the start of the validation lifecycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaApprover rdf:type rdf:Property ;
    rdfs:label 'Qa Approver' ;
    rdfs:comment 'Name of the Quality Assurance representative who reviewed and approved the validation protocol and report. QA approval is required per cGMP regulations.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference to the regulatory filing (IND, NDA, BLA, MAA, eCTD section) where this validation data is or will be submitted. Validation data is typically included in Module 3 (Quality) of the Common Technical Document (CTD).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Report Approval Date' ;
    rdfs:comment 'Date when the validation report was reviewed and approved by Quality Assurance. This is the official validation completion date and triggers the validated state for the process.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revalidationTrigger rdf:type rdf:Property ;
    rdfs:label 'Revalidation Trigger' ;
    rdfs:comment 'Event or condition that triggered the need for revalidation. Examples include: process changes, equipment changes, facility changes, raw material supplier changes, scale-up or scale-down, transfer to new site, out-of-specification results, quality issues, regulatory inspection findings, or periodic review schedule. Supports change control and lifecycle management per ICH Q12.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationApproach rdf:type rdf:Property ;
    rdfs:label 'Validation Approach' ;
    rdfs:comment 'Validation approach methodology. Traditional approach uses fixed process parameters and extensive testing. Quality by Design (QbD) approach uses design space and process understanding per ICH Q8. Hybrid combines traditional and QbD elements. Risk-based approach uses ICH Q9 risk management principles to focus validation efforts.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationLead rdf:type rdf:Property ;
    rdfs:label 'Validation Lead' ;
    rdfs:comment 'Name of the person responsible for leading the validation study. Typically a validation engineer, process engineer, or quality assurance specialist.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationOutcome rdf:type rdf:Property ;
    rdfs:label 'Validation Outcome' ;
    rdfs:comment 'Overall outcome of the validation study. Pass indicates all acceptance criteria were met. Fail indicates one or more acceptance criteria were not met. Conditional indicates validation passed with minor deviations that require corrective action but do not invalidate the study. Inconclusive indicates validation could not be completed or results were ambiguous.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStage rdf:type rdf:Property ;
    rdfs:label 'Validation Stage' ;
    rdfs:comment 'Stage of process validation per FDA lifecycle approach. Stage 1 (Process Design) establishes commercial manufacturing process based on development knowledge. Stage 2 (Process Qualification) confirms process design is capable of reproducible commercial manufacturing. Stage 3 (Continued Process Verification) provides ongoing assurance that process remains in control. Also includes legacy approaches: prospective (validation before routine production), concurrent (validation during routine production), and retrospective (validation using historical data).' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationType rdf:type rdf:Property ;
    rdfs:label 'Validation Type' ;
    rdfs:comment 'Type of validation being performed. Process validation covers manufacturing processes, cleaning validation covers equipment cleaning procedures, computerized system validation covers MES/SCADA/LIMS systems per 21 CFR Part 11, analytical method validation covers laboratory test methods, equipment validation covers production equipment qualification, and sterilization validation covers sterilization cycles.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Production Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Production orders require supervisor assignment for GMP accountability, deviation escalation authority, batch release approval chain, and manufacturing execution oversight. Essential for production ma' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Identifier for the production routing defining the sequence of manufacturing operations, work centers, standard times, and in-process quality checks. Routing must align with the Master Batch Record process flow.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when all production operations were completed and order was confirmed. Captured from Manufacturing Execution System (MES) at final operation completion.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual quantity produced and confirmed at order completion. May differ from planned quantity due to yield loss, in-process rejections, or overproduction within acceptable limits.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when production order execution commenced. Captured from Manufacturing Execution System (MES) at first operation start. Critical for cycle time analysis and Current Good Manufacturing Practice (cGMP) batch record documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cmoCdmoCode rdf:type rdf:Property ;
    rdfs:label 'Cmo Cdmo Code' ;
    rdfs:comment 'Identifier for the external Contract Manufacturing Organization (CMO) or Contract Development and Manufacturing Organization (CDMO) if production is outsourced. Links to supplier master data and quality agreements.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Target quantity to be produced as specified in the production order. Represents the batch size defined in the master batch record or Bill of Materials (BOM).' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Scheduling priority for the production order. Urgent for critical supply shortages or regulatory commitments; high for commercial launch or clinical trial material; normal for routine replenishment; low for strategic inventory build.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbdFlag rdf:type rdf:Property ;
    rdfs:label 'Qbd Flag' ;
    rdfs:comment 'Indicates whether the production order follows Quality by Design (QbD) principles with defined design space, Critical Process Parameters (CPP), and Critical Quality Attributes (CQA) per ICH Q8/Q9/Q10. True for QbD-enabled processes with enhanced process understanding and control strategy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether the production order involves rework or reprocessing of previously manufactured material that did not meet specifications. Rework must be performed according to approved procedures and documented per 21 CFR Part 211.115.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date for production order completion including all manufacturing operations and in-process quality checks.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of material scrapped or rejected during production due to Out of Specification (OOS) results, equipment failures, or process deviations. Scrap must be documented and investigated per Current Good Manufacturing Practice (cGMP) requirements.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationBatchFlag rdf:type rdf:Property ;
    rdfs:label 'Validation Batch Flag' ;
    rdfs:comment 'Indicates whether the production order is a validation batch used for process qualification, process performance qualification (PPQ), or continued process verification. Validation batches require enhanced documentation and are used to demonstrate process capability and reproducibility.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Id' ;
    rdfs:comment 'Unique identifier for the production schedule record. Primary key.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignPlanId rdf:type rdf:Property ;
    rdfs:label 'Campaign Plan Id' ;
    rdfs:comment 'Identifier of the production campaign plan to which this schedule belongs, enabling grouping of related production runs.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:primaryProductionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Employee Id' ;
    rdfs:comment 'Identifier of the production planner or scheduler responsible for creating and maintaining this schedule.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:batchQuantityPlanned rdf:type rdf:Property ;
    rdfs:label 'Batch Quantity Planned' ;
    rdfs:comment 'Number of batches planned for production during the scheduled period.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchSizePlanned rdf:type rdf:Property ;
    rdfs:label 'Batch Size Planned' ;
    rdfs:comment 'Planned quantity or batch size for the scheduled production run, expressed in the product\'s unit of measure.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Type of production campaign (e.g., single-product campaign, multi-product campaign, validation campaign).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Planned capacity utilization percentage for the manufacturing line during the scheduled period.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeReason rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason' ;
    rdfs:comment 'Reason for the scheduled downtime window (e.g., preventive maintenance, line cleaning, product changeover). [ENUM-REF-CANDIDATE: maintenance|cleaning|changeover|validation|calibration|inspection|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeWindowEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Window End Timestamp' ;
    rdfs:comment 'End timestamp of any scheduled downtime window for maintenance, cleaning, or changeover activities.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeWindowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Window Start Timestamp' ;
    rdfs:comment 'Start timestamp of any scheduled downtime window for maintenance, cleaning, or changeover activities.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Executed Timestamp' ;
    rdfs:comment 'Date and time when the production schedule was marked as executed or completed.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:frozenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Frozen Timestamp' ;
    rdfs:comment 'Date and time when the production schedule was frozen, preventing further changes without formal change control.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:patImplementationFlag rdf:type rdf:Property ;
    rdfs:label 'Pat Implementation Flag' ;
    rdfs:comment 'Indicates whether Process Analytical Technology is implemented for real-time monitoring during the scheduled production.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning horizon covered by this production schedule.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning horizon covered by this production schedule.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority level assigned to this production schedule, influencing resource allocation and sequencing decisions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbdPrinciplesAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Qbd Principles Applied Flag' ;
    rdfs:comment 'Indicates whether Quality by Design principles have been applied in the development of this production schedule.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text notes or comments related to the production schedule, capturing special instructions, constraints, or considerations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Type of production schedule indicating the planning level (e.g., master schedule, operational schedule).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDurationHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Hours' ;
    rdfs:comment 'Planned duration of the production run in hours, calculated from scheduled start to end timestamps.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned end date and time for the production run on the manufacturing line.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned start date and time for the production run on the manufacturing line.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplyChainPlanningSystem rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Planning System' ;
    rdfs:comment 'Name of the supply chain planning system that generated or influenced this production schedule (e.g., Kinaxis RapidResponse, Blue Yonder).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyTransferId rdf:type rdf:Property ;
    rdfs:label 'Technology Transfer Id' ;
    rdfs:comment 'Unique identifier for the technology transfer record. Primary key.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnologyTransfer .

ind:sourceSiteId rdf:type rdf:Property ;
    rdfs:label 'Source Site Id' ;
    rdfs:comment 'Reference to the manufacturing site or R&D facility from which the manufacturing process is being transferred.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:analyticalMethodsTransferredFlag rdf:type rdf:Property ;
    rdfs:label 'Analytical Methods Transferred Flag' ;
    rdfs:comment 'Indicates whether analytical test methods have been successfully transferred and qualified at the receiving site.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cgmpComplianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Cgmp Compliance Verified Flag' ;
    rdfs:comment 'Indicates whether the receiving site has been verified to be compliant with current Good Manufacturing Practice (cGMP) requirements per 21 CFR Parts 210 and 211.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleaningProceduresTransferredFlag rdf:type rdf:Property ;
    rdfs:label 'Cleaning Procedures Transferred Flag' ;
    rdfs:comment 'Indicates whether cleaning validation procedures and acceptance criteria have been successfully transferred to the receiving site.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'The target date for completing all technology transfer activities including qualification batches and regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processParametersTransferredFlag rdf:type rdf:Property ;
    rdfs:label 'Process Parameters Transferred Flag' ;
    rdfs:comment 'Indicates whether critical process parameters (CPP) and process controls have been successfully transferred and validated at the receiving site.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationBatchCount rdf:type rdf:Property ;
    rdfs:label 'Qualification Batch Count' ;
    rdfs:comment 'The number of qualification or validation batches required to be manufactured at the receiving site to demonstrate process capability and consistency.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationBatchesCompleted rdf:type rdf:Property ;
    rdfs:label 'Qualification Batches Completed' ;
    rdfs:comment 'The number of qualification batches that have been successfully manufactured and released at the receiving site.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readinessAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Readiness Assessment Date' ;
    rdfs:comment 'The date when the receiving site readiness assessment was completed and approved.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readinessAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Readiness Assessment Status' ;
    rdfs:comment 'Status of the receiving site readiness assessment: not-started (assessment not yet begun), in-progress (assessment underway), completed (assessment finished), approved (site deemed ready for transfer).' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'The date when regulatory approval was received from health authorities to manufacture the product at the receiving site.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryChangeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Control Number' ;
    rdfs:comment 'The change control or variation number associated with regulatory submissions for the site transfer, if applicable.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'The date when regulatory submissions for the site transfer were filed with the relevant health authorities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required Flag' ;
    rdfs:comment 'Indicates whether regulatory submissions (e.g., prior approval supplement, variation) are required for this technology transfer.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stabilityDataTransferredFlag rdf:type rdf:Property ;
    rdfs:label 'Stability Data Transferred Flag' ;
    rdfs:comment 'Indicates whether stability protocols and historical stability data have been transferred and stability studies initiated at the receiving site.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferInitiationDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Initiation Date' ;
    rdfs:comment 'The date when the technology transfer project was formally initiated and the protocol was approved.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferOutcome rdf:type rdf:Property ;
    rdfs:label 'Transfer Outcome' ;
    rdfs:comment 'The final outcome of the technology transfer: successful (all acceptance criteria met), successful-with-deviations (completed with minor issues documented), unsuccessful (failed to meet acceptance criteria), cancelled (terminated before completion).' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Protocol Number' ;
    rdfs:comment 'The externally-known unique protocol number assigned to this technology transfer activity. Used for regulatory and quality management system tracking.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReportApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Report Approval Date' ;
    rdfs:comment 'The date when the final technology transfer report was approved by quality assurance and management.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferReportNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Report Number' ;
    rdfs:comment 'The document number of the final technology transfer report summarizing all activities, results, and conclusions.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStage rdf:type rdf:Property ;
    rdfs:label 'Transfer Stage' ;
    rdfs:comment 'Current stage in the technology transfer lifecycle: initiation (planning and protocol development), knowledge-transfer (documentation and training), process-demonstration (trial runs), qualification-batches (validation batches), regulatory-submission (filing with authorities), approval (regulatory and internal approval), closure (final report and handover). [ENUM-REF-CANDIDATE: initiation|knowledge-transfer|process-demonstration|qualification-batches|regulatory-submission|approval|closure — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Overall status of the technology transfer: planned (scheduled but not started), in-progress (actively executing), on-hold (temporarily suspended), completed (successfully finished), cancelled (terminated before completion).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTeamLeadEmail rdf:type rdf:Property ;
    rdfs:label 'Transfer Team Lead Email' ;
    rdfs:comment 'The email address of the technology transfer team lead for project communications.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTeamLeadName rdf:type rdf:Property ;
    rdfs:label 'Transfer Team Lead Name' ;
    rdfs:comment 'The name of the individual responsible for leading the technology transfer project team.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the technology transfer activity: site-to-site (between internal manufacturing sites), r&d-to-commercial (from development to commercial manufacturing), cmo-onboarding (to contract manufacturing organization), cmo-offboarding (from CMO back to internal or to another CMO), scale-up (pilot to commercial scale), or process-improvement (transfer of improved process).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationId rdf:type rdf:Property ;
    rdfs:label 'Indication Id' ;
    rdfs:comment 'Reference to the specific therapeutic indication or disease area for which this access strategy applies, enabling indication-level access differentiation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Indication .

ind:accessBarrierSeverity rdf:type rdf:Property ;
    rdfs:label 'Access Barrier Severity' ;
    rdfs:comment 'Overall severity rating of the identified access barriers for this strategy: low (minor hurdles), medium (manageable barriers), high (significant barriers requiring targeted remediation), or critical (barriers that may prevent market access).' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessBarrierSummary rdf:type rdf:Property ;
    rdfs:label 'Access Barrier Summary' ;
    rdfs:comment 'Narrative summary of the primary identified access barriers for this product in the target geography and payer segment (e.g., lack of comparative clinical evidence, high ICER, step therapy requirements, prior authorization burden). Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessObjective rdf:type rdf:Property ;
    rdfs:label 'Access Objective' ;
    rdfs:comment 'Overarching strategic access objective statement for this product in the target geography and payer segment (e.g., \'Achieve preferred formulary tier 1 placement in 80% of commercial plans within 12 months of launch\'). Confidential strategic business information.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'Actual date on which the product was commercially launched in the specified geography and payer segment. Compared against planned_launch_date to measure launch execution performance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:copayAssistanceFlag rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Flag' ;
    rdfs:comment 'Indicates whether a copay assistance or copay card program is included in this access strategy to reduce patient out-of-pocket costs and improve commercial insurance access.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this market access strategy becomes operative and binding for downstream access activities including HTA submissions, payer contracting, and patient support programs.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which this market access strategy expires or is superseded. Nullable for open-ended strategies. Used to manage strategy lifecycle and trigger renewal workflows.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossToNetTargetPct rdf:type rdf:Property ;
    rdfs:label 'Gross To Net Target Pct' ;
    rdfs:comment 'Target gross-to-net revenue reduction percentage for this access strategy, representing the expected aggregate discount, rebate, and allowance burden relative to gross list price. Critical for P&L planning and net revenue forecasting. Confidential financial data.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heorStudyPlan rdf:type rdf:Property ;
    rdfs:label 'Heor Study Plan' ;
    rdfs:comment 'Summary of the Health Economics and Outcomes Research (HEOR) study plan, including cost-effectiveness models, budget impact analyses, and quality-of-life studies planned to support payer value dossiers and HTA submissions. Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaBodyCode rdf:type rdf:Property ;
    rdfs:label 'Hta Body Code' ;
    rdfs:comment 'Code identifying the primary HTA body responsible for evaluating this product in the target geography (e.g., NICE, G-BA, HAS, PBAC, CADTH, AIFA). [ENUM-REF-CANDIDATE: NICE|G-BA|HAS|PBAC|CADTH|AIFA|SMC|NCPE|TLV|ZIN — promote to reference product]' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaOutcome rdf:type rdf:Property ;
    rdfs:label 'Hta Outcome' ;
    rdfs:comment 'Outcome of the HTA review by the primary HTA body: pending (under review), positive (recommended), positive_with_restriction (recommended with clinical/population restrictions), negative (not recommended), withdrawn (submission withdrawn), or not_applicable.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaStrategy rdf:type rdf:Property ;
    rdfs:label 'Hta Strategy' ;
    rdfs:comment 'Description of the Health Technology Assessment (HTA) strategy including target HTA bodies (e.g., NICE, G-BA, HAS, PBAC), submission sequencing, evidence package approach, and comparator selection rationale. Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaSubmissionActualDate rdf:type rdf:Property ;
    rdfs:label 'Hta Submission Actual Date' ;
    rdfs:comment 'Actual date on which the HTA dossier was submitted to the primary HTA body. Compared against hta_submission_planned_date to track submission timeliness.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:htaSubmissionPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Hta Submission Planned Date' ;
    rdfs:comment 'Planned date for submission of the HTA dossier or value dossier to the primary HTA body. Used for launch sequencing and access readiness milestone tracking.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icerThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Icer Threshold Amount' ;
    rdfs:comment 'Payer or HTA body willingness-to-pay threshold per quality-adjusted life year (QALY) or other health outcome unit in the target geography. Used to assess pricing headroom and value-based pricing strategy. Confidential strategic financial data.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:icerThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Icer Threshold Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the ICER willingness-to-pay threshold applicable in the target geography (e.g., GBP for NICE, EUR for G-BA/HAS, USD for ICER US).' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPriceAmount rdf:type rdf:Property ;
    rdfs:label 'List Price Amount' ;
    rdfs:comment 'Gross list price (WAC — Wholesale Acquisition Cost in the US, or equivalent list price in other geographies) for the product in the target geography. Confidential commercial pricing data.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'List Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the gross list price of the product in the target geography (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientSupportProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Support Program Flag' ;
    rdfs:comment 'Indicates whether a patient support program (copay assistance, patient assistance program, hub services) is included as a component of this access strategy to improve patient access and adherence.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerSegment rdf:type rdf:Property ;
    rdfs:label 'Payer Segment' ;
    rdfs:comment 'Specific payer segment or channel targeted by this access strategy (e.g., Commercial, Medicare Part D, Medicaid, VA/DoD, Private Insurance, NHS, Statutory Health Insurance). [ENUM-REF-CANDIDATE: Commercial|Medicare Part D|Medicaid|VA/DoD|NHS|Statutory Health Insurance|Private Insurance|Integrated Delivery Network — promote to reference product]' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Planned Launch Date' ;
    rdfs:comment 'Target date for commercial product launch in the specified geography and payer segment, as defined in the launch sequencing plan. Drives milestone planning and access readiness timelines.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementPathway rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Pathway' ;
    rdfs:comment 'Regulatory and payer reimbursement pathway pursued for this product: standard (routine formulary review), accelerated (expedited review), managed_entry (conditional coverage), risk_sharing (payer-manufacturer risk agreement), outcomes_based (payment linked to clinical outcomes), named_patient, or compassionate_use. [ENUM-REF-CANDIDATE: standard|accelerated|managed_entry|risk_sharing|outcomes_based|named_patient|compassionate_use — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweRwdPlan rdf:type rdf:Property ;
    rdfs:label 'Rwe Rwd Plan' ;
    rdfs:comment 'Description of the Real-World Evidence (RWE) and Real-World Data (RWD) generation plan supporting payer negotiations, HTA submissions, and outcomes-based contracting. Includes study designs, data sources, and timelines. Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyCode rdf:type rdf:Property ;
    rdfs:label 'Strategy Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the access strategy, used in cross-functional communications, HTA submissions, and payer contracting documents. Format: MAS-<ProductCode>-<Year>.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyName rdf:type rdf:Property ;
    rdfs:label 'Strategy Name' ;
    rdfs:comment 'Human-readable name of the market access strategy, typically including the product name, indication, and geography (e.g., \'Oncology Product X — US Formulary Access Strategy 2025\').' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyOwner rdf:type rdf:Property ;
    rdfs:label 'Strategy Owner' ;
    rdfs:comment 'Name or employee identifier of the Market Access lead or director accountable for developing and executing this access strategy.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyType rdf:type rdf:Property ;
    rdfs:label 'Strategy Type' ;
    rdfs:comment 'Classification of the access strategy by its business purpose: launch (initial market entry), lifecycle (ongoing management), indication_expansion (new indication), line_extension (new formulation/dosage), or biosimilar_defense (protecting market share against biosimilar entry).' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyVersion rdf:type rdf:Property ;
    rdfs:label 'Strategy Version' ;
    rdfs:comment 'Version number of the access strategy document following major.minor versioning convention (e.g., 1.0, 2.3). Supports document lifecycle management and audit trail requirements.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFormularyTier rdf:type rdf:Property ;
    rdfs:label 'Target Formulary Tier' ;
    rdfs:comment 'Desired formulary tier placement targeted by this access strategy for the specified payer segment. Tier 1 represents preferred/lowest cost-share; specialty and non_formulary represent restricted access positions.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueProposition rdf:type rdf:Property ;
    rdfs:label 'Value Proposition' ;
    rdfs:comment 'Narrative summary of the clinical, economic, and humanistic value proposition communicated to payers and HTA bodies to justify formulary placement and reimbursement. Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementPolicyId rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Policy Id' ;
    rdfs:comment 'Foreign key linking to market.reimbursement_policy. Business justification: Coverage decisions are transactional instances of reimbursement policies. One reimbursement policy (master) generates many coverage decisions (instances for specific plans, periods, or geographies). T' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReimbursementPolicy .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'The date by which the manufacturer must file an appeal or request for reconsideration of a negative or restricted coverage decision, critical for market access operations and legal timelines.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageRestrictionDetail rdf:type rdf:Property ;
    rdfs:label 'Coverage Restriction Detail' ;
    rdfs:comment 'Free-text narrative providing additional detail on the coverage restriction, including specific specialty pharmacy networks, prescriber certification requirements, or REMS program elements.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Coverage Restriction Type' ;
    rdfs:comment 'Type of coverage restriction applied by the payer: specialty pharmacy requirement, restricted distribution program, age restriction, prescriber specialty restriction, site-of-care restriction, or Risk Evaluation and Mitigation Strategy (REMS) requirement. [ENUM-REF-CANDIDATE: specialty_pharmacy|restricted_distribution|age_restriction|prescriber_restriction|site_of_care|rems — promote to reference product]' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredIndication rdf:type rdf:Property ;
    rdfs:label 'Covered Indication' ;
    rdfs:comment 'The specific therapeutic indication or disease condition for which the payer has granted coverage, as stated in the coverage policy document. May be narrower than the full approved label indication.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionCode rdf:type rdf:Property ;
    rdfs:label 'Decision Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this coverage decision by the payer or health authority, used for cross-system reconciliation and audit trails.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Narrative summary of the clinical, economic, or policy rationale provided by the payer or HTA body for the coverage determination, used for appeal preparation and value dossier updates.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionType rdf:type rdf:Property ;
    rdfs:label 'Decision Type' ;
    rdfs:comment 'Classification of the coverage decision scope: national (e.g., CMS national coverage determination), regional (state/province), plan-level, formulary listing, health technology assessment (HTA) outcome, reimbursement determination, or coverage with evidence development. [ENUM-REF-CANDIDATE: national|regional|plan_level|formulary|hta|reimbursement|coverage_with_evidence — promote to reference product]' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdCode rdf:type rdf:Property ;
    rdfs:label 'Icd Code' ;
    rdfs:comment 'ICD-10 or ICD-11 diagnosis code corresponding to the covered indication, used for claims adjudication and outcomes analytics.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineOfTherapy rdf:type rdf:Property ;
    rdfs:label 'Line Of Therapy' ;
    rdfs:comment 'The treatment line for which coverage is granted (e.g., first-line, second-line, adjuvant), reflecting the payer\'s clinical positioning requirements and step therapy policies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:livesCovered rdf:type rdf:Property ;
    rdfs:label 'Lives Covered' ;
    rdfs:comment 'Estimated number of patient lives covered under the payer plan subject to this coverage decision, used for market access impact assessment and revenue forecasting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managedEntryAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Managed Entry Agreement Flag' ;
    rdfs:comment 'Indicates whether this coverage decision is contingent on a managed entry agreement (MEA) or outcomes-based contract between the manufacturer and the payer, such as a performance-based rebate or risk-sharing arrangement.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientAccessProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Access Program Flag' ;
    rdfs:comment 'Indicates whether a patient access program (e.g., copay assistance, free drug program, hub services) is associated with this coverage decision to support patient affordability and adherence.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerType rdf:type rdf:Property ;
    rdfs:label 'Payer Type' ;
    rdfs:comment 'Category of the payer organization issuing the coverage decision: government health authority, commercial insurer, pharmacy benefit manager (PBM), group purchasing organization (GPO), managed care organization, Medicaid, or Medicare. [ENUM-REF-CANDIDATE: government|commercial|pbm|gpo|managed_care|medicaid|medicare — promote to reference product]' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthorizationCriteria rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Criteria' ;
    rdfs:comment 'Narrative description of the clinical and administrative criteria that must be met to obtain prior authorization, including diagnosis requirements, prescriber qualifications, and supporting documentation.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Required' ;
    rdfs:comment 'Indicates whether the payer requires prior authorization (PA) before dispensing the covered product. True means PA must be obtained before the claim is adjudicated.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityLimitDescription rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Description' ;
    rdfs:comment 'Narrative description of the quantity limit imposed by the payer, including the maximum units, dosage, or days supply allowed per dispensing event or coverage period.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Flag' ;
    rdfs:comment 'Indicates whether the payer imposes a quantity limit on dispensing of the covered product per fill or per defined time period.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Sub-national region, state, or province to which this coverage decision applies, for decisions issued at a regional rather than national level (e.g., US state Medicaid programs, German Länder).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementScope rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Scope' ;
    rdfs:comment 'Scope of reimbursement granted under this coverage decision: full reimbursement, partial reimbursement (patient co-pay applies), conditional reimbursement (subject to managed entry agreement or outcomes-based contract), or not reimbursed.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rwe Required Flag' ;
    rdfs:comment 'Indicates whether the payer or HTA body has required the submission of real-world evidence (RWE) or real-world data (RWD) as a condition of this coverage decision or for future coverage renewal.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepTherapyCriteria rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Criteria' ;
    rdfs:comment 'Detailed description of the step therapy requirements, including the specific agents that must be tried and failed, duration of prior therapy, and documentation requirements for exception requests.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepTherapyRequired rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Required' ;
    rdfs:comment 'Indicates whether the payer mandates step therapy (fail-first policy), requiring patients to try and fail one or more alternative therapies before coverage of this product is granted.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formularyId rdf:type rdf:Property ;
    rdfs:label 'Formulary Id' ;
    rdfs:comment 'Foreign key linking to market.formulary. Business justification: Market formulary positions track where a drug is placed within a specific formulary. Currently market_formulary_position has payer_account_id but no direct link to the formulary master table. Adding f' ;
    rdfs:domain ind:Market ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulary .

ind:formularyListingId rdf:type rdf:Property ;
    rdfs:label 'Formulary Listing Id' ;
    rdfs:comment 'Reference to the specific formulary (drug benefit list) managed by the payer in which this product placement is tracked. A payer may maintain multiple formularies across plan types.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormularyListing .

ind:marketPayerContractId rdf:type rdf:Property ;
    rdfs:label 'Market Payer Contract Id' ;
    rdfs:comment 'Reference to the payer or PBM contract under which this formulary position was negotiated. Links formulary placement to rebate obligations and gross-to-net revenue commitments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketPayerContract .

ind:pbmId rdf:type rdf:Property ;
    rdfs:label 'Pbm Id' ;
    rdfs:comment 'Reference to the Pharmacy Benefit Manager (PBM) that administers the formulary on behalf of the payer. PBMs negotiate rebates, manage formulary placement, and adjudicate pharmacy claims.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pbm .

ind:accessRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Type' ;
    rdfs:comment 'The primary type of utilization management restriction applied to this formulary position. Enables systematic access gap analysis and identification of patient access barriers across payer segments. [ENUM-REF-CANDIDATE: none|prior_auth|step_therapy|quantity_limit|specialty_pharmacy|age_restriction|diagnosis_restriction|combination — promote to reference product]' ;
    rdfs:domain ind:MarketFormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coinsuranceRate rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Rate' ;
    rdfs:comment 'The patient coinsurance rate (expressed as a decimal, e.g., 0.20 for 20%) applicable to this formulary tier position. Used when the plan applies percentage-based cost-sharing rather than a fixed copay.' ;
    rdfs:domain ind:MarketFormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'The fixed patient copay amount in USD applicable to this formulary tier position. Used in gross-to-net revenue modeling and patient affordability analysis. Null if the plan uses coinsurance rather than a fixed copay.' ;
    rdfs:domain ind:MarketFormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formularyPositionCode rdf:type rdf:Property ;
    rdfs:label 'Formulary Position Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this formulary position record, used in payer communications, contracting systems, and gross-to-net reconciliation workflows.' ;
    rdfs:domain ind:MarketFormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Formulary Review Date' ;
    rdfs:comment 'The scheduled or actual date of the next payer formulary review cycle for this product. Used by market access teams to plan payer engagement, evidence submissions, and contracting activities.' ;
    rdfs:domain ind:MarketFormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:htaSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Hta Submission Status' ;
    rdfs:comment 'The current status of the Health Technology Assessment (HTA) submission associated with this formulary position. HTA outcomes directly influence formulary tier placement and reimbursement decisions in markets such as the EU.' ;
    rdfs:domain ind:MarketFormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketShareImpactPct rdf:type rdf:Property ;
    rdfs:label 'Market Share Impact Pct' ;
    rdfs:comment 'The estimated percentage of total addressable market share attributable to this formulary position, based on covered lives and payer segment weight. Used in market access scenario modeling and launch readiness assessments.' ;
    rdfs:domain ind:MarketFormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityLimitDays rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Days' ;
    rdfs:comment 'The number of days supply over which the quantity_limit_value applies. For example, a limit of 30 units per 30 days. Enables precise modeling of dispensing restrictions for patient access programs.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityLimitValue rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Value' ;
    rdfs:comment 'The maximum quantity (in dispensing units) of the product that the payer will cover within the quantity limit period defined by quantity_limit_days. Used for access gap and utilization management analysis.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'The contractually agreed rebate percentage (expressed as a decimal, e.g., 0.15 for 15%) payable to the payer or PBM for this formulary position. A key input to gross-to-net revenue calculations and P&L reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateTier rdf:type rdf:Property ;
    rdfs:label 'Rebate Tier' ;
    rdfs:comment 'The rebate tier designation associated with this formulary position as negotiated in the payer or PBM contract. Determines the rebate percentage or per-unit rebate amount owed to the payer in exchange for preferred formulary placement. [ENUM-REF-CANDIDATE: base|preferred|exclusive|performance|supplemental — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyDrugFlag rdf:type rdf:Property ;
    rdfs:label 'Specialty Drug Flag' ;
    rdfs:comment 'Indicates whether the payer classifies this product as a specialty drug under this formulary, which typically triggers specialty tier placement, specialty pharmacy channel requirements, and higher patient cost-sharing.' ;
    rdfs:domain ind:MarketFormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyPharmacyRequired rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Required' ;
    rdfs:comment 'Indicates whether the payer mandates dispensing through a designated specialty pharmacy network for this formulary position. Impacts patient access and distribution channel strategy.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossToNetAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Gross To Net Adjustment Id' ;
    rdfs:comment 'Primary key for gross_to_net_adjustment' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensingPharmacyId rdf:type rdf:Property ;
    rdfs:label 'Dispensing Pharmacy Id' ;
    rdfs:comment 'NCPDP (National Council for Prescription Drug Programs) identifier of the pharmacy that dispensed the drug product for copay assistance claims. Populated only for copay_assistance adjustment type.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pharmacy .

ind:rebateClaimId rdf:type rdf:Property ;
    rdfs:label 'Rebate Claim Id' ;
    rdfs:comment 'Foreign key linking to market.rebate_claim. Business justification: Some gross-to-net adjustments are driven by rebate claims. One GTN adjustment may be linked to one rebate claim (1:N from rebate_claim perspective). Column to remove: copay_claim_id (STRING) is a weak' ;
    rdfs:domain ind:Market ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RebateClaim .

ind:accrualFlag rdf:type rdf:Property ;
    rdfs:label 'Accrual Flag' ;
    rdfs:comment 'Indicates whether this GTN adjustment record represents an accrual estimate (True) or an actual settled/invoiced amount (False). Distinguishes estimated deductions from confirmed payments for financial close accuracy.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentRatePct rdf:type rdf:Property ;
    rdfs:label 'Adjustment Rate Pct' ;
    rdfs:comment 'Contractual or regulatory rate (as a percentage of gross sales or WAC) used to calculate the adjustment amount. Derived from the applicable contract tier, Medicaid best price calculation, or statutory rebate formula.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this GTN adjustment record, used for reconciliation with payer remittances, SAP SD condition records, and financial close processes. Maps to the document number in SAP S/4HANA FI.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the gross-to-net adjustment record, tracking its workflow from initial creation through financial posting or reversal.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentSubtype rdf:type rdf:Property ;
    rdfs:label 'Adjustment Subtype' ;
    rdfs:comment 'Further classification within an adjustment type, enabling granular deduction analysis (e.g., within performance rebates: market share tier, volume threshold, outcomes-based). Supports detailed GTN waterfall reporting.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Category of gross-to-net deduction applied to gross sales. Classifies the revenue deduction by its contractual or regulatory basis. [ENUM-REF-CANDIDATE: base_rebate|performance_rebate|medicaid_best_price|340b|chargeback|copay_assistance|gpo_fee|distribution_fee|patient_assistance|managed_care_rebate|medicare_part_d|state_supplemental_rebate — promote to reference product]' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimDate rdf:type rdf:Property ;
    rdfs:label 'Claim Date' ;
    rdfs:comment 'Date on which the copay assistance claim was adjudicated at the pharmacy. Populated only for copay_assistance adjustment type. Used for copay program spend timing analysis.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:copayAssistancePaidAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Paid Amount' ;
    rdfs:comment 'Dollar amount of copay assistance paid by the manufacturer on behalf of the patient for a specific claim. Equals the adjustment_amount for copay_assistance type records. Drives copay program financial tracking.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether this GTN adjustment record is currently under dispute with the payer, PBM, or government agency. Triggers dispute management workflow and prevents premature financial settlement.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossCopayAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Copay Amount' ;
    rdfs:comment 'Total patient copay obligation before application of copay assistance for a specific claim. Populated only for copay_assistance adjustment type. Used to calculate patient affordability metrics.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicaidBestPriceFlag rdf:type rdf:Property ;
    rdfs:label 'Medicaid Best Price Flag' ;
    rdfs:comment 'Indicates whether this GTN adjustment was considered in the Medicaid Best Price calculation for the applicable reporting period. Critical for CMS Medicaid Drug Rebate Program compliance and AMP/Best Price reporting.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'Net revenue after application of this GTN adjustment (gross_sales_amount minus adjustment_amount). Represents the recognized revenue for ASC 606 reporting purposes.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientDeidentifiedCode rdf:type rdf:Property ;
    rdfs:label 'Patient Deidentified Code' ;
    rdfs:comment 'De-identified patient token for copay assistance claim records, enabling patient-level program utilization analysis while maintaining HIPAA compliance. Populated only for copay_assistance adjustment type. Never contains direct patient PII.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientRemainingLiability rdf:type rdf:Property ;
    rdfs:label 'Patient Remaining Liability' ;
    rdfs:comment 'Residual out-of-pocket cost borne by the patient after copay assistance is applied (gross_copay_amount minus copay_assistance_paid_amount). Measures patient affordability program effectiveness.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueDossierId rdf:type rdf:Property ;
    rdfs:label 'Value Dossier Id' ;
    rdfs:comment 'Foreign key linking to market.value_dossier. Business justification: HEOR studies (health economics and outcomes research) are evidence assets that feed into value dossiers used for payer negotiations and HTA submissions. A HEOR study is typically conducted to support ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ValueDossier .

ind:budgetImpactYear1 rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Year1' ;
    rdfs:comment 'Projected net budget impact to the payer in Year 1 of the budget impact model, expressed in the currency defined by icur_currency_code. Key output for payer affordability assessments.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetImpactYear3 rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Year3' ;
    rdfs:comment 'Projected net budget impact to the payer in Year 3 of the budget impact model, expressed in the currency defined by icur_currency_code. Represents the standard 3-year horizon used in US payer budget impact analyses.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comparatorDescription rdf:type rdf:Property ;
    rdfs:label 'Comparator Description' ;
    rdfs:comment 'Description of the comparator treatment(s) used in the economic model or study (e.g., standard of care, active comparator INN, best supportive care), critical for HTA submissions and payer negotiations.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Data Use Agreement Ref' ;
    rdfs:comment 'Reference number or identifier for the Data Use Agreement (DUA) governing the use of the real-world dataset, ensuring compliance with data licensing and privacy obligations.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaBodyName rdf:type rdf:Property ;
    rdfs:label 'Hta Body Name' ;
    rdfs:comment 'Name of the Health Technology Assessment (HTA) body to which this HEOR evidence is being submitted (e.g., NICE, G-BA, HAS, CADTH, PBAC). Relevant for cost-effectiveness and cost-utility analyses.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icurCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Icur Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the ICUR value (e.g., USD, GBP, EUR), ensuring correct interpretation of the economic model output across geographies.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icurValue rdf:type rdf:Property ;
    rdfs:label 'Icur Value' ;
    rdfs:comment 'Incremental Cost-Utility Ratio (ICUR) expressed as cost per Quality-Adjusted Life Year (QALY) gained, the primary output of cost-utility analyses used in HTA submissions. Expressed in the currency defined by icur_currency_code.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketShareAssumptionPct rdf:type rdf:Property ;
    rdfs:label 'Market Share Assumption Pct' ;
    rdfs:comment 'Assumed market share percentage for the drug product used as the base case input in the budget impact model, reflecting expected uptake within the eligible patient population.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelVersionDate rdf:type rdf:Property ;
    rdfs:label 'Model Version Date' ;
    rdfs:comment 'Date on which the current model version was finalized and approved for use in payer submissions or HTA dossiers.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientPopulationDescription rdf:type rdf:Property ;
    rdfs:label 'Patient Population Description' ;
    rdfs:comment 'Narrative description of the patient population assumptions used in the model, including eligibility criteria, disease stage, line of therapy, and demographic assumptions.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Patient Population Size' ;
    rdfs:comment 'Estimated number of eligible patients in the target population used as the base case assumption in the economic model, relevant for budget impact models and market sizing.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productInn rdf:type rdf:Property ;
    rdfs:label 'Product Inn' ;
    rdfs:comment 'WHO-assigned International Nonproprietary Name (INN) of the drug product that is the subject of the HEOR study, used for global payer and HTA submissions.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qalyGain rdf:type rdf:Property ;
    rdfs:label 'Qaly Gain' ;
    rdfs:comment 'Estimated incremental Quality-Adjusted Life Years (QALYs) gained with the study treatment versus comparator, the primary effectiveness measure in cost-utility analyses for HTA submissions.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rwdDataSourceType rdf:type rdf:Property ;
    rdfs:label 'Rwd Data Source Type' ;
    rdfs:comment 'Type of real-world data source used in the study (e.g., claims database, EHR, registry, patient-reported outcomes). Applicable for retrospective RWD studies and RWE generation. Null for purely modeled studies.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwdDataVendor rdf:type rdf:Property ;
    rdfs:label 'Rwd Data Vendor' ;
    rdfs:comment 'Name of the external data vendor or data provider supplying the real-world dataset (e.g., IQVIA, Optum, Truven, Flatiron Health). Relevant for data use agreement tracking and data provenance.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwdDataVintage rdf:type rdf:Property ;
    rdfs:label 'Rwd Data Vintage' ;
    rdfs:comment 'Date range or vintage period of the real-world dataset used in the study (e.g., \'2018-2022\'), indicating the temporal coverage of the underlying data and its currency for payer submissions.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweIncluded rdf:type rdf:Property ;
    rdfs:label 'Rwe Included' ;
    rdfs:comment 'Indicates whether real-world evidence (RWE) is incorporated into this HEOR study or model, a key differentiator for payer submissions and HTA dossiers.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the HEOR study or evidence asset, used in payer submissions, HTA dossiers, and cross-functional references.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyOwner rdf:type rdf:Property ;
    rdfs:label 'Study Owner' ;
    rdfs:comment 'Name or employee identifier of the HEOR team member or function responsible for the study, accountable for quality, timelines, and payer submission readiness.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetIndication rdf:type rdf:Property ;
    rdfs:label 'Target Indication' ;
    rdfs:comment 'Specific disease indication or clinical condition for which the HEOR evidence is being generated, as used in regulatory submissions and payer negotiations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPayerAudience rdf:type rdf:Property ;
    rdfs:label 'Target Payer Audience' ;
    rdfs:comment 'Primary payer segment or audience for whom the HEOR evidence asset is designed, guiding value messaging and submission strategy. [ENUM-REF-CANDIDATE: commercial_payer|medicare|medicaid|pbm|gpo|hta_body|integrated_delivery_network|self_insured_employer — promote to reference product]' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeHorizon rdf:type rdf:Property ;
    rdfs:label 'Time Horizon' ;
    rdfs:comment 'Duration over which the economic model projects costs and outcomes (e.g., \'5 years\', \'lifetime\', \'10 years\'). A key structural assumption in cost-effectiveness and budget impact models.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentCostInput rdf:type rdf:Property ;
    rdfs:label 'Treatment Cost Input' ;
    rdfs:comment 'Annual per-patient treatment cost used as the primary cost input in the economic model, expressed in the currency defined by icur_currency_code. Reflects WAC, net price, or negotiated price as specified in the model assumptions.' ;
    rdfs:domain ind:MarketHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Submission Date' ;
    rdfs:comment 'Date on which the HTA dossier was formally submitted to the HTA body. This is the principal real-world business event timestamp for the submission transaction, used to calculate review timelines and clock-start for statutory deadlines.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Outcome of the formal appeal filed against the HTA body\'s initial decision. Populated only when appeal_filed is True. Drives revision of the decision_type and downstream contracting actions.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitRating rdf:type rdf:Property ;
    rdfs:label 'Benefit Rating' ;
    rdfs:comment 'The HTA body\'s formal rating of the added therapeutic benefit of the drug compared to the appropriate comparator. Terminology varies by body: G-BA uses \'major/considerable/minor/non-quantifiable/no added benefit\'; NICE uses \'highly clinically effective/clinically effective\'; HAS uses ASMR grades I-V. [ENUM-REF-CANDIDATE: major|considerable|minor|non_quantifiable|no_added_benefit|asmr_i|asmr_ii|asmr_iii|asmr_iv|asmr_v — promote to reference product]' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierReference rdf:type rdf:Property ;
    rdfs:label 'Dossier Reference' ;
    rdfs:comment 'The official dossier or file reference number assigned by the HTA body upon receipt of the submission. Used for all formal correspondence and tracking within the HTA body\'s system.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicModelType rdf:type rdf:Property ;
    rdfs:label 'Economic Model Type' ;
    rdfs:comment 'Type of health economic model included in the HTA submission dossier. Cost-utility analysis (CUA) using QALYs is standard for NICE; cost-effectiveness analysis (CEA) is used by other bodies. Determines the analytical framework for reimbursement recommendation.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidencePackageType rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Type' ;
    rdfs:comment 'Classification of the primary clinical evidence package submitted to the HTA body: randomised controlled trial (RCT), observational study, indirect treatment comparison (ITC), mixed treatment comparison (MTC), single-arm trial, or real-world evidence (RWE). Influences the HTA body\'s confidence in the benefit assessment.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgency rdf:type rdf:Property ;
    rdfs:label 'External Agency' ;
    rdfs:comment 'Name of any external agency, health economics consultancy, or contract research organisation (CRO) engaged to support dossier preparation, economic modelling, or submission management for this HTA engagement.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icerCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Icer Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the ICER value submitted (e.g., GBP for NICE, EUR for HAS/G-BA, CAD for CADTH, AUD for PBAC). Required to interpret the submitted ICER in the correct monetary context.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icerSubmitted rdf:type rdf:Property ;
    rdfs:label 'Icer Submitted' ;
    rdfs:comment 'The incremental cost-effectiveness ratio (ICER) as submitted by the company in the economic model, expressed in cost per quality-adjusted life year (QALY) gained or cost per life year gained. Confidential as it reflects internal pricing and modelling assumptions used in payer negotiations.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managedAccessScheme rdf:type rdf:Property ;
    rdfs:label 'Managed Access Scheme' ;
    rdfs:comment 'Indicates whether the HTA decision is conditional on a managed access scheme (MAS), such as NICE\'s Managed Access Agreements (MAA) or Cancer Drugs Fund (CDF) arrangements, requiring further real-world evidence collection during the access period.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientAccessProgram rdf:type rdf:Property ;
    rdfs:label 'Patient Access Program' ;
    rdfs:comment 'Indicates whether a patient access program (PAP) or copay assistance program has been established in conjunction with this HTA submission to support patient affordability and access pending or following the reimbursement decision.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Submission Date' ;
    rdfs:comment 'Target date on which the completed HTA dossier is planned to be formally submitted to the HTA body. Used for project planning, resource allocation, and commercial launch timeline alignment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Price Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the recommended price range values (e.g., GBP, EUR, CAD, AUD). Required to interpret price bounds in the correct monetary context for each jurisdiction.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedPriceLower rdf:type rdf:Property ;
    rdfs:label 'Recommended Price Lower' ;
    rdfs:comment 'Lower bound of the price range recommended or implied by the HTA body\'s decision, expressed in the local currency. Used in payer contracting and gross-to-net revenue management. Confidential as it reflects sensitive pricing negotiation data.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedPriceUpper rdf:type rdf:Property ;
    rdfs:label 'Recommended Price Upper' ;
    rdfs:comment 'Upper bound of the price range recommended or implied by the HTA body\'s decision, expressed in the local currency. Used alongside the lower bound to define the acceptable price corridor for payer negotiations and contracting.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementConditions rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Conditions' ;
    rdfs:comment 'Free-text description of any conditions, restrictions, or requirements attached to the HTA body\'s reimbursement recommendation (e.g., restricted to second-line use, mandatory prior authorisation, patient registry requirement, managed access scheme). Drives contracting and access program design.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweRequired rdf:type rdf:Property ;
    rdfs:label 'Rwe Required' ;
    rdfs:comment 'Indicates whether the HTA body\'s decision requires the generation and submission of real-world evidence (RWE) or real-world data (RWD) as a condition of continued reimbursement or as part of a managed access arrangement.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionLead rdf:type rdf:Property ;
    rdfs:label 'Submission Lead' ;
    rdfs:comment 'Name or identifier of the internal market access lead or HTA manager responsible for coordinating and owning this submission. Used for accountability, escalation, and stakeholder communication.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDossierVersion rdf:type rdf:Property ;
    rdfs:label 'Value Dossier Version' ;
    rdfs:comment 'Version identifier of the global value dossier (GVD) used as the basis for this HTA submission. Tracks which version of the evidence synthesis and value story was submitted, enabling audit trail and version control across multiple country submissions.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willingnessToPayThreshold rdf:type rdf:Property ;
    rdfs:label 'Willingness To Pay Threshold' ;
    rdfs:comment 'The HTA body\'s published or applied willingness-to-pay threshold per QALY (or equivalent outcome unit) for the relevant jurisdiction at the time of submission. Used to assess whether the submitted ICER falls within the acceptable range for reimbursement recommendation.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outcomesBasedContractId rdf:type rdf:Property ;
    rdfs:label 'Outcomes Based Contract Id' ;
    rdfs:comment 'Unique surrogate identifier for the outcomes-based contract record in the Databricks Silver Layer. Primary key for this master agreement entity.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseRebatePct rdf:type rdf:Property ;
    rdfs:label 'Base Rebate Pct' ;
    rdfs:comment 'Baseline rebate percentage guaranteed to the payer regardless of outcome performance, expressed as a percentage of net sales. Forms the floor of the rebate schedule.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive business name for this outcomes-based contract, typically referencing the payer, product, and indication (e.g., \'BlueCross Oncology OBC – Product X 2024\').' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'Name or employee identifier of the Market Access or Managed Care team member responsible for managing this outcomes-based contract and overseeing reconciliation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement Flag' ;
    rdfs:comment 'Indicates whether a formal data sharing agreement (DSA) is in place with the payer to enable access to claims or EHR data required for outcome measurement.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceType rdf:type rdf:Property ;
    rdfs:label 'Data Source Type' ;
    rdfs:comment 'Type of real-world data source used to measure outcomes: claims_data (medical/pharmacy claims), ehr_data (electronic health records), registry_data (disease registry), rwe_rwd (real-world evidence/data), clinical_trial (trial data), payer_database (payer-specific database).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern this contract (e.g., USA, GBR, DEU). Determines applicable regulatory and legal framework.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRebatePct rdf:type rdf:Property ;
    rdfs:label 'Max Rebate Pct' ;
    rdfs:comment 'Maximum rebate percentage payable to the payer if outcome performance falls to the worst-case scenario, expressed as a percentage of net sales. Forms the ceiling of the rebate schedule.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Detailed description of the methodology used to measure the outcome metric, including patient identification criteria, data collection approach, statistical method, and adjudication process.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'End date of the current or most recent outcome measurement period, after which observed outcomes are locked for reconciliation.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Months' ;
    rdfs:comment 'Duration in months of each outcome measurement period over which patient cohort outcomes are observed and aggregated before reconciliation is triggered.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'Start date of the current or most recent outcome measurement period for which data collection and patient cohort tracking is active.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mostFavoredNationClause rdf:type rdf:Property ;
    rdfs:label 'Most Favored Nation Clause' ;
    rdfs:comment 'Indicates whether this outcomes-based contract includes a Most Favored Nation (MFN) clause, requiring that the payer receives terms no less favorable than those offered to any other payer.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observedOutcomeRate rdf:type rdf:Property ;
    rdfs:label 'Observed Outcome Rate' ;
    rdfs:comment 'Actual measured value of the outcome metric for the patient cohort during the measurement period (e.g., observed ORR of 0.58 or 58%). Compared against performance_threshold_value to determine rebate adjustment.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outcomeMetricName rdf:type rdf:Property ;
    rdfs:label 'Outcome Metric Name' ;
    rdfs:comment 'Name of the primary clinical or economic outcome metric used to evaluate contract performance (e.g., \'Overall Response Rate\', \'Progression-Free Survival at 12 months\', \'Hospital Readmission Rate\', \'HbA1c Reduction\').' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeMetricType rdf:type rdf:Property ;
    rdfs:label 'Outcome Metric Type' ;
    rdfs:comment 'Classification of the outcome metric: clinical (e.g., ORR, OS, PFS), economic (e.g., cost per QALY, hospitalization cost), patient_reported (e.g., QoL score), or composite (combination of multiple endpoints).' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientCohortSize rdf:type rdf:Property ;
    rdfs:label 'Patient Cohort Size' ;
    rdfs:comment 'Number of eligible patients included in the outcome measurement cohort for the measurement period, used to validate statistical significance and rebate calculation.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Performance Threshold Value' ;
    rdfs:comment 'Numeric threshold value for the outcome metric that triggers rebate adjustments. For example, an ORR threshold of 0.65 (65%) or a PFS threshold of 12.0 months. Compared against observed outcome rate during reconciliation.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Adjustment Amount' ;
    rdfs:comment 'Monetary value of the rebate adjustment triggered by outcome performance variance, expressed in the contract currency. Used for gross-to-net revenue management and financial accruals.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAdjustmentPct rdf:type rdf:Property ;
    rdfs:label 'Rebate Adjustment Pct' ;
    rdfs:comment 'Incremental rebate percentage adjustment triggered by the observed outcome variance from threshold. Applied on top of the base rebate to compute the total rebate owed for the measurement period.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'Frequency at which outcome measurements are reconciled and rebate adjustments are calculated and invoiced to the payer (monthly, quarterly, semi-annual, annual).' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationLagDays rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Lag Days' ;
    rdfs:comment 'Number of days after the measurement period end date allowed for data collection, outcome adjudication, and reconciliation completion before rebate payment is due.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rweStudyReference rdf:type rdf:Property ;
    rdfs:label 'Rwe Study Reference' ;
    rdfs:comment 'Reference identifier or protocol number of the Real-World Evidence (RWE) or Real-World Data (RWD) study that underpins the outcome measurement methodology for this contract.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdDirection rdf:type rdf:Property ;
    rdfs:label 'Threshold Direction' ;
    rdfs:comment 'Specifies whether the observed outcome must be above, below, or equal to the threshold to meet the performance target (e.g., \'above\' for ORR, \'below\' for readmission rate).' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for the performance threshold value (e.g., \'percentage\', \'months\', \'score\', \'events_per_100_patients\', \'USD\').' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFromThreshold rdf:type rdf:Property ;
    rdfs:label 'Variance From Threshold' ;
    rdfs:comment 'Calculated difference between the observed outcome rate and the performance threshold value (observed minus threshold). Positive values indicate outperformance; negative values indicate underperformance triggering rebate adjustment.' ;
    rdfs:domain ind:OutcomesBasedContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualProgramBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Program Budget' ;
    rdfs:comment 'Total approved annual budget allocated to fund this patient access program, inclusive of benefit payouts and administrative costs. Used for financial planning, P&L management, and gross-to-net revenue forecasting.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitCapAmount rdf:type rdf:Property ;
    rdfs:label 'Benefit Cap Amount' ;
    rdfs:comment 'Maximum monetary benefit amount that a single patient may receive under this program per benefit period (e.g., annual cap of $25,000 for copay assistance). Used for gross-to-net revenue management and program budget forecasting.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitCapCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Benefit Cap Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the benefit cap amount (e.g., USD, EUR, GBP). Required for multi-country program management and financial reporting.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitPeriod rdf:type rdf:Property ;
    rdfs:label 'Benefit Period' ;
    rdfs:comment 'Time period over which the benefit cap applies and resets. Determines how program utilization is tracked and reported for gross-to-net revenue deductions.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityCriteriaSummary rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria Summary' ;
    rdfs:comment 'Narrative summary of the patient eligibility criteria for program enrollment, including insurance status requirements, income thresholds, diagnosis requirements, and prior treatment conditions. Sourced from the program design document.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Entity or mechanism funding the patient access program. Manufacturer-funded programs have direct gross-to-net revenue impact; foundation-funded programs may have different OIG compliance implications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubServiceProvider rdf:type rdf:Property ;
    rdfs:label 'Hub Service Provider' ;
    rdfs:comment 'Name of the third-party hub services organization contracted to administer patient enrollment, benefits verification, prior authorization support, and case management for this program (e.g., Lash Group, ConnectiveRx, Inovalon).' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeThresholdRequired rdf:type rdf:Property ;
    rdfs:label 'Income Threshold Required' ;
    rdfs:comment 'Indicates whether the program requires patients to meet a defined income or financial need threshold as part of eligibility screening. True for patient assistance programs (PAP); typically False for copay assistance programs.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceStatusRequirement rdf:type rdf:Property ;
    rdfs:label 'Insurance Status Requirement' ;
    rdfs:comment 'Specifies the insurance coverage status required for patient eligibility. Copay assistance programs typically require commercially insured patients; PAPs typically target uninsured or underinsured populations.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewed rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewed' ;
    rdfs:comment 'Indicates whether the program design and terms have been reviewed and approved by the legal department for compliance with anti-kickback statutes, GDPR, HIPAA, and applicable local regulations.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programNotes rdf:type rdf:Property ;
    rdfs:label 'Program Notes' ;
    rdfs:comment 'Free-text field for additional operational notes, special conditions, or exceptions associated with this patient access program. Used by market access and hub operations teams for case-by-case documentation.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorizationRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authorization Ref' ;
    rdfs:comment 'Reference number or identifier for the regulatory authorization underpinning this program (e.g., FDA Expanded Access IND number, EMA compassionate use authorization, named patient program reference). Links to the regulatory submission record.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Program Flag' ;
    rdfs:comment 'Indicates whether this patient access program is associated with or operates under an FDA-mandated Risk Evaluation and Mitigation Strategy (REMS). REMS programs have additional compliance and reporting obligations.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyTerms rdf:type rdf:Property ;
    rdfs:label 'Supply Terms' ;
    rdfs:comment 'Description of the product supply terms under this program, including dispensing quantity, supply duration, dosage form, and whether supply is provided directly by the manufacturer or through a specialty pharmacy or CMO/CDMO partner.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Owner Employee Id' ;
    rdfs:comment 'Identifier of the internal market access account manager or payer relations director responsible for managing the relationship with this payer. Maps to the HR employee master for accountability and CRM ownership.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentPayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Payer Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent payer organization in a payer hierarchy (e.g., a regional health plan rolling up to a national parent). Enables hierarchical covered-lives aggregation and enterprise-level contracting.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayerAccount .

ind:cmsPayerCode rdf:type rdf:Property ;
    rdfs:label 'Cms Payer Code' ;
    rdfs:comment 'Official CMS-assigned payer identifier used in Medicare and Medicaid claims processing and enrollment data. Enables cross-referencing with CMS plan finder, Part D enrollment, and government reimbursement data.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractingAuthority rdf:type rdf:Property ;
    rdfs:label 'Contracting Authority' ;
    rdfs:comment 'Indicates whether this payer account holds direct contracting authority (True) or operates under a parent/umbrella contract managed by another payer entity. Determines whether a direct rebate or pricing agreement can be executed.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copayAccumulatorPolicy rdf:type rdf:Property ;
    rdfs:label 'Copay Accumulator Policy' ;
    rdfs:comment 'Indicates whether this payer has implemented a copay accumulator adjustment program that prevents manufacturer copay assistance from counting toward patient deductibles and out-of-pocket maximums. Impacts gross-to-net and patient affordability.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copayAssistanceAccepted rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Accepted' ;
    rdfs:comment 'Indicates whether this payer accepts manufacturer copay assistance cards or patient support programs for its commercially insured members. Government payers (Medicare, Medicaid) are prohibited from accepting copay assistance under Anti-Kickback Statute.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coveredLives rdf:type rdf:Property ;
    rdfs:label 'Covered Lives' ;
    rdfs:comment 'Total number of beneficiaries or members covered under the payer\'s health plan(s). Key metric for assessing payer reach and prioritizing market access investment. Sourced from CMS enrollment data or payer-reported figures.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formularyDecisionCycle rdf:type rdf:Property ;
    rdfs:label 'Formulary Decision Cycle' ;
    rdfs:comment 'Frequency at which the payer\'s pharmacy and therapeutics (P&T) committee reviews and updates formulary coverage decisions. Critical for planning HTA submission and contracting timelines.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyInfluenceScore rdf:type rdf:Property ;
    rdfs:label 'Formulary Influence Score' ;
    rdfs:comment 'Proprietary numeric score (0–100) reflecting the payer\'s ability to drive formulary adoption and steer prescribing behavior across its covered lives. Used in payer prioritization and contracting strategy.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formularyTierPosition rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier Position' ;
    rdfs:comment 'Current formulary tier placement of the company\'s lead product(s) on this payer\'s formulary. Reflects the outcome of market access negotiations and directly impacts patient access and copay levels.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Scope' ;
    rdfs:comment 'Scope of the payer\'s geographic coverage indicating whether the plan operates nationally, regionally, at state/province level, locally, or across multiple countries. Informs market access strategy and contracting jurisdiction.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpoMembership rdf:type rdf:Property ;
    rdfs:label 'Gpo Membership' ;
    rdfs:comment 'Name of the Group Purchasing Organization (GPO) to which this payer or its affiliated health system belongs (e.g., Vizient, Premier, HealthTrust). Relevant for hospital and institutional formulary contracting.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCountryCode rdf:type rdf:Property ;
    rdfs:label 'Hq Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the payer organization\'s primary headquarters location (e.g., USA, GBR, DEU). Determines applicable regulatory framework, pricing regulations, and reimbursement authority.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaBody rdf:type rdf:Property ;
    rdfs:label 'Hta Body' ;
    rdfs:comment 'Name of the Health Technology Assessment (HTA) body associated with this payer\'s reimbursement decision-making process (e.g., NICE, HAS, G-BA, AIFA, SMC). Drives value dossier format and HEOR evidence requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContractReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Contract Review Date' ;
    rdfs:comment 'Date of the most recent formal contract or rebate agreement review with this payer. Used to track contracting cycle compliance and trigger renewal workflows.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:naicCode rdf:type rdf:Property ;
    rdfs:label 'Naic Code' ;
    rdfs:comment 'Five-digit NAIC company code assigned to licensed insurance entities in the United States. Used for regulatory identification, state insurance filings, and cross-referencing with insurance regulatory databases.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerAccountCode rdf:type rdf:Property ;
    rdfs:label 'Payer Account Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned to the payer organization, used in contracting, SAP SD customer master, and Veeva CRM account records for cross-system reconciliation.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerName rdf:type rdf:Property ;
    rdfs:label 'Payer Name' ;
    rdfs:comment 'Full legal name of the payer organization as registered with regulatory or governmental authorities (e.g., \'UnitedHealthcare Insurance Company\', \'Centers for Medicare & Medicaid Services\'). Used as the primary identity label for the payer.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerSubtype rdf:type rdf:Property ;
    rdfs:label 'Payer Subtype' ;
    rdfs:comment 'Further granular classification within the payer type (e.g., Medicare Advantage, Medicaid Managed Care, Part D Plan Sponsor, NHS England, Statutory Health Insurer, PBM Formulary Manager). [ENUM-REF-CANDIDATE: medicare_advantage|medicaid_managed_care|part_d_sponsor|fee_for_service|nhs|statutory_health_insurer|pbm_formulary — promote to reference product]' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pbmAffiliation rdf:type rdf:Property ;
    rdfs:label 'Pbm Affiliation' ;
    rdfs:comment 'Name of the Pharmacy Benefit Manager (PBM) affiliated with or contracted by this payer to manage drug benefit administration, formulary design, and rebate negotiations (e.g., Express Scripts, CVS Caremark, OptumRx).' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTherapeuticFocus rdf:type rdf:Property ;
    rdfs:label 'Primary Therapeutic Focus' ;
    rdfs:comment 'The primary therapeutic area(s) or disease categories that the payer\'s formulary and coverage policies emphasize (e.g., oncology, immunology, rare diseases, cardiovascular). Informs product-specific formulary positioning strategy.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptCommitteeMeetingMonth rdf:type rdf:Property ;
    rdfs:label 'Pt Committee Meeting Month' ;
    rdfs:comment 'Calendar month (1–12) in which the payer\'s Pharmacy and Therapeutics (P&T) committee typically convenes for formulary review. Used to time value dossier submissions and contracting negotiations.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rebateEligible rdf:type rdf:Property ;
    rdfs:label 'Rebate Eligible' ;
    rdfs:comment 'Indicates whether this payer account is eligible to participate in pharmaceutical rebate programs. Drives gross-to-net revenue calculations and rebate contract eligibility in SAP SD.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reimbursementAuthority rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Authority' ;
    rdfs:comment 'Name of the governmental or statutory body that holds formal authority over reimbursement listing decisions for this payer (e.g., CMS, NHS England, GKV-Spitzenverband, CNAM). Distinct from HTA body which assesses clinical value.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweDataSharingAgreement rdf:type rdf:Property ;
    rdfs:label 'Rwe Data Sharing Agreement' ;
    rdfs:comment 'Indicates whether a Real-World Evidence (RWE) or Real-World Data (RWD) data sharing agreement is in place with this payer. RWE partnerships support value-based contracting, outcomes-based agreements, and payer negotiations.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Strategic tier classification assigned by the market access team reflecting the payer\'s relative importance based on covered lives, formulary influence, and revenue impact. Tier 1 represents highest-priority national accounts.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueBasedContractEligible rdf:type rdf:Property ;
    rdfs:label 'Value Based Contract Eligible' ;
    rdfs:comment 'Indicates whether this payer has the infrastructure and willingness to enter into outcomes-based or value-based contracting arrangements. Drives HEOR evidence generation strategy and RWE data requirements.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adminFeePct rdf:type rdf:Property ;
    rdfs:label 'Admin Fee Pct' ;
    rdfs:comment 'Administrative fee percentage charged by the PBM or GPO for contract administration, data services, and formulary management, expressed as a percentage of net sales. Deducted in gross-to-net calculations.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether the contract automatically renews at the end of the effective period unless either party provides notice of termination within the specified notice period.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookOfBusinessLives rdf:type rdf:Property ;
    rdfs:label 'Book Of Business Lives' ;
    rdfs:comment 'The number of covered lives (plan members) within the payer\'s book of business that are subject to this contract. Used for rebate volume estimation, market access analytics, and payer segmentation.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:copayAssistanceAllowed rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Allowed' ;
    rdfs:comment 'Indicates whether the contract permits the manufacturer to offer copay assistance or patient support programs to members covered under this payer\'s plan. Some commercial contracts restrict copay card use.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingRequired rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Required' ;
    rdfs:comment 'Indicates whether the contract includes a data sharing provision requiring the payer or PBM to provide claims data, utilization data, or outcomes data to the manufacturer. Relevant for outcomes-based and value-based contracts.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingScope rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Scope' ;
    rdfs:comment 'Specifies the type of data the payer or PBM is contractually obligated to share with the manufacturer under the data sharing provision. Null if data_sharing_required is False.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Rebate Amount' ;
    rdfs:comment 'The estimated total rebate liability for a full contract year based on projected sales volume and contracted rebate rates. Used for gross-to-net accrual budgeting and financial planning. Not a calculated aggregate — represents the contractually agreed estimate.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityProvision rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Provision' ;
    rdfs:comment 'Indicates whether the contract grants the contracted product exclusive or preferred formulary positioning within its therapeutic class, excluding or restricting competitor products.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formularyTier rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier' ;
    rdfs:comment 'The formulary tier position secured for the contracted product under this payer agreement. Directly impacts patient access, copay levels, and rebate obligations. Central to PBM formulary management mechanics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalRebatePct rdf:type rdf:Property ;
    rdfs:label 'Incremental Rebate Pct' ;
    rdfs:comment 'Additional rebate percentage earned above the base rebate upon achievement of performance or formulary tier thresholds. Used in tiered and performance-based contract structures.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetricType rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Type' ;
    rdfs:comment 'The type of performance metric used to determine eligibility for incremental or performance-based rebates. Applicable for performance rebate, outcomes-based, and value-based contract types.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceProtectionClause rdf:type rdf:Property ;
    rdfs:label 'Price Protection Clause' ;
    rdfs:comment 'Indicates whether the contract includes a price protection provision that triggers additional rebates if the manufacturer raises the list price (WAC) above a specified threshold, typically tied to CPI or a fixed percentage.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceProtectionThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Price Protection Threshold Pct' ;
    rdfs:comment 'The maximum allowable annual WAC price increase percentage before price protection rebates are triggered under the contract. Null if price_protection_clause is False.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Rebate Payment Frequency' ;
    rdfs:comment 'The agreed schedule for rebate payment remittance from the manufacturer to the payer or PBM. Drives rebate accrual timing and cash flow planning in SAP FI.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebatePaymentLagDays rdf:type rdf:Property ;
    rdfs:label 'Rebate Payment Lag Days' ;
    rdfs:comment 'The number of days after the close of a rebate period within which the rebate invoice must be paid. Used for cash flow forecasting and accrual true-up calculations.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'The number of days prior to the effective end date by which either party must provide written notice of intent not to renew the contract. Applicable when auto_renewal is True.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemContractCode rdf:type rdf:Property ;
    rdfs:label 'Source System Contract Code' ;
    rdfs:comment 'The native contract identifier from the originating system of record (e.g., SAP S/4HANA SD rebate agreement number, Salesforce Health Cloud contract record ID). Enables traceability back to the operational source system.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationManagementRestrictions rdf:type rdf:Property ;
    rdfs:label 'Utilization Management Restrictions' ;
    rdfs:comment 'Specifies the utilization management restrictions applied to the contracted product on the payer\'s formulary (e.g., prior authorization, step therapy, quantity limits). Impacts patient access and market share performance metrics.' ;
    rdfs:domain ind:MarketPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentsMade rdf:type rdf:Property ;
    rdfs:label 'Commitments Made' ;
    rdfs:comment 'Description of any formal or informal commitments made by either party during the engagement (e.g., data provision, follow-up analysis, contract term adjustments). Confidential negotiation record.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discussionTopics rdf:type rdf:Property ;
    rdfs:label 'Discussion Topics' ;
    rdfs:comment 'Structured summary of the key topics discussed during the engagement, such as formulary positioning, rebate terms, outcomes-based contract parameters, HEOR evidence, or RWE data sharing.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementChannel rdf:type rdf:Property ;
    rdfs:label 'Engagement Channel' ;
    rdfs:comment 'Mode of interaction through which the engagement was conducted. Supports channel analytics and compliance documentation requirements.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCode rdf:type rdf:Property ;
    rdfs:label 'Engagement Code' ;
    rdfs:comment 'Externally referenceable business identifier for the engagement, formatted as PE-{YYYY}-{NNNNNN}. Used in correspondence, CRM records, and meeting minutes.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEndTime rdf:type rdf:Property ;
    rdfs:label 'Engagement End Time' ;
    rdfs:comment 'Precise date and time when the engagement session concluded. Used together with start time to compute meeting duration.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementOutcome rdf:type rdf:Property ;
    rdfs:label 'Engagement Outcome' ;
    rdfs:comment 'Overall qualitative outcome assessment of the engagement from the market access team\'s perspective. Used for pipeline scoring and account strategy adjustment.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStartTime rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Time' ;
    rdfs:comment 'Precise date and time when the engagement session began, in ISO 8601 format with timezone offset. Used for scheduling, duration calculation, and audit.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpCompleted rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed' ;
    rdfs:comment 'Indicates whether all follow-up actions arising from this engagement have been completed. True = all actions closed; False = open actions remain.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which all follow-up actions from this engagement must be completed. Used for SLA tracking and account management reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formularyTierDiscussed rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier Discussed' ;
    rdfs:comment 'The formulary tier position (e.g., Tier 1, Tier 2, Preferred Specialty) that was discussed or targeted during this engagement. Supports formulary access tracking.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heorEvidencePresentedFlag rdf:type rdf:Property ;
    rdfs:label 'Heor Evidence Presented Flag' ;
    rdfs:comment 'Indicates whether Health Economics and Outcomes Research (HEOR) evidence (e.g., cost-effectiveness models, budget impact analyses, QoL data) was formally presented during the engagement.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalAttendees rdf:type rdf:Property ;
    rdfs:label 'Internal Attendees' ;
    rdfs:comment 'Comma-separated list of company-side attendees including market access managers, medical science liaisons (MSL), HEOR leads, and account directors.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyMessagesDelivered rdf:type rdf:Property ;
    rdfs:label 'Key Messages Delivered' ;
    rdfs:comment 'Summary of the approved value messages and clinical/economic evidence presented to the payer during the engagement. Supports message tracking and compliance review.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingMinutesRef rdf:type rdf:Property ;
    rdfs:label 'Meeting Minutes Ref' ;
    rdfs:comment 'Reference identifier or URL to the formal meeting minutes document stored in the document management system (e.g., Veeva Vault). Supports audit trail and compliance documentation.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationStage rdf:type rdf:Property ;
    rdfs:label 'Negotiation Stage' ;
    rdfs:comment 'Current stage of the payer negotiation lifecycle associated with this engagement. Supports pipeline tracking and forecasting of gross-to-net revenue impact. [ENUM-REF-CANDIDATE: pre_engagement|initial_discussion|proposal_presented|counter_proposal|final_negotiation|agreement_reached|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextEngagementPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Next Engagement Planned Date' ;
    rdfs:comment 'Planned date for the next scheduled engagement with this payer account, as agreed or anticipated at the close of this engagement.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomesContractDiscussedFlag rdf:type rdf:Property ;
    rdfs:label 'Outcomes Contract Discussed Flag' ;
    rdfs:comment 'Indicates whether an outcomes-based or value-based contract arrangement was discussed during this engagement. Supports value-based contracting pipeline tracking.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerAttendees rdf:type rdf:Property ;
    rdfs:label 'Payer Attendees' ;
    rdfs:comment 'Comma-separated list of names and titles of payer-side attendees (e.g., P&T committee members, medical directors, pharmacy directors). Stored as free text; structured attendee data managed in CRM.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerPositionSummary rdf:type rdf:Property ;
    rdfs:label 'Payer Position Summary' ;
    rdfs:comment 'Narrative summary of the payer\'s stated position, concerns, or feedback expressed during the engagement. Confidential negotiation intelligence used for account strategy.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateDiscussedFlag rdf:type rdf:Property ;
    rdfs:label 'Rebate Discussed Flag' ;
    rdfs:comment 'Indicates whether rebate terms or rebate structures were a topic of discussion during this engagement. True = rebate discussed; False = not discussed.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rweDataDiscussedFlag rdf:type rdf:Property ;
    rdfs:label 'Rwe Data Discussed Flag' ;
    rdfs:comment 'Indicates whether Real-World Evidence (RWE) or Real-World Data (RWD) was presented or discussed as part of the payer engagement. Supports RWE utilization tracking.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemEngagementCode rdf:type rdf:Property ;
    rdfs:label 'Source System Engagement Code' ;
    rdfs:comment 'Original identifier of this engagement record in the upstream CRM or market access system (e.g., Salesforce Health Cloud activity ID or Veeva CRM call record ID). Supports data lineage and reconciliation.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCountryId rdf:type rdf:Property ;
    rdfs:label 'Market Country Id' ;
    rdfs:comment 'Reference to the geographic market or country for which this pricing decision is applicable.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:precedingDecisionId rdf:type rdf:Property ;
    rdfs:label 'Preceding Decision Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately prior pricing decision that this record supersedes or amends. Enables full price history chain reconstruction for audit and IRP analysis.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingDecision .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or designation of the internal governance body or individual (e.g., Global Pricing Committee, Regional Pricing Board, CFO, VP Market Access) that formally approved this pricing decision.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceilingPrice rdf:type rdf:Property ;
    rdfs:label 'Ceiling Price' ;
    rdfs:comment 'Maximum approved price within the authorized price corridor above which the product must not be priced in this market. Prevents excessive pricing relative to IRP basket and regulatory constraints. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Distribution or sales channel to which this pricing decision applies, such as retail pharmacy, hospital formulary, government procurement, tender, specialty pharmacy, or direct-to-payer.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorBreachThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Corridor Breach Threshold Pct' ;
    rdfs:comment 'Percentage deviation from the target price that triggers an automated corridor breach alert for proactive price erosion monitoring. For example, a value of 5.00 means a 5% deviation from target_price triggers an alert.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorPrice rdf:type rdf:Property ;
    rdfs:label 'Floor Price' ;
    rdfs:comment 'Minimum approved price within the authorized price corridor below which the product must not be sold in this market. Used for IRP management and cross-country price erosion prevention. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governmentReferencePrice rdf:type rdf:Property ;
    rdfs:label 'Government Reference Price' ;
    rdfs:comment 'Officially approved or regulated price set by a government authority (e.g., NHS reference price, ASMR-based French price, German AMNOG price). Applicable in markets with statutory price regulation. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossToNetPct rdf:type rdf:Property ;
    rdfs:label 'Gross To Net Pct' ;
    rdfs:comment 'Estimated gross-to-net adjustment percentage representing the aggregate deduction from WAC list price to net realized price, inclusive of all rebates, chargebacks, and mandatory discounts. Used for revenue forecasting and P&L management.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irpBasketCountries rdf:type rdf:Property ;
    rdfs:label 'Irp Basket Countries' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes that constitute the IRP reference basket monitored for this pricing decision (e.g., \'DEU|FRA|GBR|ESP|ITA\'). Used to assess cross-country price erosion risk and inform launch sequencing.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irpConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Irp Constraint Flag' ;
    rdfs:comment 'Indicates whether this pricing decision is constrained by International Reference Pricing (IRP) rules in the target market. True = IRP constraint applies; False = no IRP constraint.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irpReferencePrice rdf:type rdf:Property ;
    rdfs:label 'Irp Reference Price' ;
    rdfs:comment 'The IRP-derived price constraint calculated from the basket countries at the time of this decision. Represents the maximum price permissible under IRP rules for this market. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:launchSequencePriority rdf:type rdf:Property ;
    rdfs:label 'Launch Sequence Priority' ;
    rdfs:comment 'Numeric priority rank assigned to this market in the global launch sequencing plan, where lower values indicate earlier launch. Used to optimize IRP risk by controlling the order of country launches.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listPriceWac rdf:type rdf:Property ;
    rdfs:label 'List Price Wac' ;
    rdfs:comment 'Approved Wholesale Acquisition Cost (WAC) or ex-factory list price per unit for the product in the specified market and channel. This is the gross list price before any rebates, discounts, or government adjustments. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Frequency at which the IRP basket and price corridor compliance are reviewed for this pricing decision. Drives scheduling of automated IRP monitoring workflows.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Approved net price after application of mandatory rebates, statutory discounts, and government-mandated deductions. Represents the effective realized price per unit. Expressed in currency_code.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packSizeDescription rdf:type rdf:Property ;
    rdfs:label 'Pack Size Description' ;
    rdfs:comment 'Human-readable description of the pack configuration to which this pricing decision applies (e.g., \'30 tablets x 10mg\', \'1 vial x 100mg/10mL\'). Ensures unambiguous identification of the priced SKU.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangePct rdf:type rdf:Property ;
    rdfs:label 'Price Change Pct' ;
    rdfs:comment 'Percentage change in list price (WAC) relative to the immediately preceding approved pricing decision for the same product, market, and channel. Positive values indicate a price increase; negative values indicate a price decrease.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerUnitType rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit Type' ;
    rdfs:comment 'Defines the unit basis on which all price values in this decision are expressed (e.g., per pack, per tablet, per vial, per mg of active pharmaceutical ingredient, per mL, per dose).' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingRationale rdf:type rdf:Property ;
    rdfs:label 'Pricing Rationale' ;
    rdfs:comment 'Narrative justification for the pricing decision, documenting the strategic, clinical, health-economic, and competitive factors considered. Supports regulatory transparency requirements and internal audit.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Ref' ;
    rdfs:comment 'Reference number of the regulatory submission (e.g., NDA, BLA, MAA, eCTD sequence) associated with this pricing decision. Links pricing to the regulatory approval that enables commercialization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Status' ;
    rdfs:comment 'Current reimbursement status of the product under this pricing decision in the target market. Determines patient access and payer coverage scope.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPrice rdf:type rdf:Property ;
    rdfs:label 'Target Price' ;
    rdfs:comment 'Optimal or target price within the approved price corridor, representing the commercially preferred price point balancing access, revenue, and IRP risk. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeAccountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Finance Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Market rebate claims should link to finance accounts receivable for rebate accrual and revenue recognition. This enables accurate gross-to-net calculations and financial reporting for pharmaceutical r' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:accrualPeriod rdf:type rdf:Property ;
    rdfs:label 'Accrual Period' ;
    rdfs:comment 'Financial reporting quarter (e.g., 2024-Q3) in which the rebate liability or receivable is accrued in the general ledger. Aligns rebate expense recognition with the period of sale per ASC 606 and gross-to-net accounting policies.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimDirection rdf:type rdf:Property ;
    rdfs:label 'Claim Direction' ;
    rdfs:comment 'Indicates whether the rebate claim represents an amount payable by the manufacturer to the payer (outbound rebate) or receivable from a payer/GPO (inbound credit). Drives gross-to-net accounting treatment.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period End Date' ;
    rdfs:comment 'Last day of the measurement period for which eligible units and rebate amounts are being claimed. Together with claim_period_start_date defines the rebate accrual window.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period Start Date' ;
    rdfs:comment 'First day of the measurement period (quarter or month) for which eligible units and rebate amounts are being claimed. Aligns with the contractual reporting period.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle state of the rebate claim. Tracks progression from initial draft through submission, payer review, approval or dispute, and final payment settlement. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|disputed|paid|voided — promote to reference product]' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Monetary value of the portion of the rebate claim currently under dispute. May be less than or equal to net_rebate_amount. Used to calculate the undisputed payable amount and to set dispute reserves.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleUnits rdf:type rdf:Property ;
    rdfs:label 'Eligible Units' ;
    rdfs:comment 'Total number of units (prescriptions, unit doses, or pack equivalents) dispensed during the claim period that qualify for rebate under the contract terms. Basis for rebate amount calculation.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Rebate Amount' ;
    rdfs:comment 'Total calculated rebate amount before any adjustments, offsets, or administrative fees. Computed as eligible_units × wac_price × rebate_rate. Primary input to gross-to-net revenue deduction accounting.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketSharePct rdf:type rdf:Property ;
    rdfs:label 'Market Share Pct' ;
    rdfs:comment 'Product market share within the payer\'s covered lives during the claim period, expressed as a percentage. Used to validate performance tier achievement and to support market share rebate calculations.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicaidRebateFlag rdf:type rdf:Property ;
    rdfs:label 'Medicaid Rebate Flag' ;
    rdfs:comment 'Indicates whether this claim is subject to the CMS Medicaid Drug Rebate Program (MDRP) reporting and payment obligations. Drives separate regulatory reporting workflows and AMP/Best Price calculations.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Net Rebate Amount' ;
    rdfs:comment 'Final rebate amount after applying all adjustments and administrative fee deductions. Represents the actual liability or receivable recorded in the finance domain for rebate accrual and payment settlement.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Bank or ERP payment reference number (e.g., SAP payment document number or wire transfer reference) associated with the settlement of this rebate claim. Used for cash application and bank reconciliation.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Period Adjustment Flag' ;
    rdfs:comment 'Indicates whether this rebate claim includes a true-up or correction for a prior reporting period. When true, the adjustment_amount field captures the prior period correction value for audit trail purposes.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebateRate rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate' ;
    rdfs:comment 'Contractually agreed rebate rate expressed as a percentage of WAC or net price applicable to this claim. May reflect a base rate, a performance tier rate, or a blended rate depending on claim type.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wacPrice rdf:type rdf:Property ;
    rdfs:label 'Wac Price' ;
    rdfs:comment 'Wholesale Acquisition Cost (WAC) per unit at the time of the claim period. Serves as the base price from which rebate percentages are calculated for gross-to-net revenue deduction accounting.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Id' ;
    rdfs:comment 'Reference to the newer reimbursement policy record that replaces this one when a policy is revised or superseded. Enables policy lineage tracking and coverage change audit trails.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReimbursementPolicy .

ind:appealDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision Date' ;
    rdfs:comment 'The date on which the payer or health authority issued a final decision on the appeal of this reimbursement policy. Null if no appeal has been filed or if the appeal is still pending.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Current status of any formal appeal filed against a negative or restrictive coverage decision under this policy. Tracks the appeal lifecycle for coverage decision audit trails and access gap remediation.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current coverage determination status of the pharmaceutical product under this policy. Indicates whether the product is reimbursed, excluded, conditionally covered, or under review by the payer or health authority.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthority rdf:type rdf:Property ;
    rdfs:label 'Decision Authority' ;
    rdfs:comment 'Name of the body, committee, or organization that issued the coverage decision (e.g., CMS, NICE, G-BA, HAS, AIFA, P&T Committee). Identifies the authoritative source of the reimbursement determination.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedPopulation rdf:type rdf:Property ;
    rdfs:label 'Excluded Population' ;
    rdfs:comment 'Description of patient subgroups or clinical scenarios explicitly excluded from coverage under this policy (e.g., \'pediatric patients under 18\', \'patients with prior EGFR mutation therapy\'). Critical for access gap analysis.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic level at which this reimbursement policy applies. Distinguishes national coverage determinations from regional, state/provincial, or plan-level policies for coverage landscape analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name or title of the reimbursement policy as issued by the payer or health authority (e.g., \'Medicare Part D Coverage Policy for Oncology Agents\').' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned by the payer or health authority to uniquely identify this reimbursement policy. Used for cross-referencing with payer portals and regulatory submissions.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle state of the reimbursement policy record. Distinguishes active policies governing current reimbursement from superseded, expired, or draft policies.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the reimbursement policy by its scope and mechanism. Distinguishes national coverage determinations, regional policies, plan-level formulary decisions, prior authorization criteria, step therapy requirements, and quantity limit policies. [ENUM-REF-CANDIDATE: national_coverage|regional_coverage|plan_level_coverage|formulary_decision|individual_coverage_determination|prior_authorization|step_therapy|quantity_limit — promote to reference product]' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementRate rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Rate' ;
    rdfs:comment 'The reimbursement rate or allowed amount established by this policy, expressed as a percentage of list price, a fixed fee schedule amount, or an ASP-based rate. Confidential commercial data used for gross-to-net revenue management.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementRateBasis rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Rate Basis' ;
    rdfs:comment 'The pricing methodology or benchmark used to calculate the reimbursement rate under this policy (e.g., ASP+6%, WAC-based, fee schedule, negotiated price). Critical for gross-to-net revenue management and payer contracting.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Source System Policy Code' ;
    rdfs:comment 'The native identifier for this reimbursement policy record in the originating operational system (e.g., Veeva Vault RIM, RIMS, or payer portal). Supports data lineage and reconciliation with source systems.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVendorId rdf:type rdf:Property ;
    rdfs:label 'Data Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: RWE datasets are procured from specialized data vendors (IQVIA, Optum, Flatiron) under licensing agreements. Pharmaceutical companies manage these as vendor relationships with contracts, audits, and c' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:datasetOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dataset Owner Employee Id' ;
    rdfs:comment 'Employee identifier of the internal business owner responsible for this dataset\'s governance, DUA compliance, and fitness-for-purpose assessments within the Market Access or HEOR function.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:passStudyId rdf:type rdf:Property ;
    rdfs:label 'Pass Study Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.pass_study. Business justification: Post-authorization safety studies (PASS) use real-world evidence datasets as data sources. PASS protocols specify RWE datasets (claims, EHR, registries) for safety endpoint assessment. Linking rwe_dat' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PassStudy .

ind:safetySignalId rdf:type rdf:Property ;
    rdfs:label 'Safety Signal Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.safety_signal. Business justification: Real-world evidence datasets are used to validate or refute safety signals. Signal validation studies analyze RWE data to confirm signal causality, estimate incidence rates, and identify risk factors.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetySignal .

ind:accessRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Notes' ;
    rdfs:comment 'Free-text notes describing any access restrictions, embargoes, or special conditions governing use of this dataset beyond the standard DUA terms. Confidential as it may contain contractual details.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualLicenseCost rdf:type rdf:Property ;
    rdfs:label 'Annual License Cost' ;
    rdfs:comment 'Annual cost of the data license or subscription fee paid to the data vendor for access to this dataset. Confidential as it reflects vendor pricing terms. Used in HEOR budget planning and ROI assessments.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataEndDate rdf:type rdf:Property ;
    rdfs:label 'Data End Date' ;
    rdfs:comment 'Latest date of patient data or clinical events captured in the dataset. Together with data_start_date defines the data vintage window. Payers assess recency of evidence based on this field.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataQualityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Data Quality Assessment Date' ;
    rdfs:comment 'Date on which the most recent internal data quality assessment was completed for this dataset. Determines whether the quality tier classification is current and valid.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataQualityTier rdf:type rdf:Property ;
    rdfs:label 'Data Quality Tier' ;
    rdfs:comment 'Internal quality classification of the dataset based on completeness, accuracy, and fitness-for-purpose assessments: gold (highest quality, validated for regulatory submissions), silver (good quality, suitable for payer negotiations), bronze (exploratory use only).' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRefreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Refresh Frequency' ;
    rdfs:comment 'Frequency at which the dataset is updated with new data from the vendor: monthly, quarterly, semi_annual, annual, one_time (static snapshot), ad_hoc. Informs evidence currency for ongoing payer negotiations.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStartDate rdf:type rdf:Property ;
    rdfs:label 'Data Start Date' ;
    rdfs:comment 'Earliest date of patient data or clinical events captured in the dataset. Defines the temporal boundary of the data vintage for payer and HTA evidence assessments.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:datasetCode rdf:type rdf:Property ;
    rdfs:label 'Dataset Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the dataset, used in payer submissions, HTA dossiers, and HEOR study references. Follows the RWE-XXXX naming convention.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetName rdf:type rdf:Property ;
    rdfs:label 'Dataset Name' ;
    rdfs:comment 'Human-readable title of the RWD/RWE dataset (e.g., \'US Oncology Claims Database 2019-2023\'). Used in value dossiers, HTA submissions, and payer negotiations.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetStatus rdf:type rdf:Property ;
    rdfs:label 'Dataset Status' ;
    rdfs:comment 'Current lifecycle status of the dataset asset: active (available for use), archived (historical, no longer updated), under_review (undergoing quality or legal review), restricted (access limited pending DUA resolution), expired (data use agreement lapsed).' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetType rdf:type rdf:Property ;
    rdfs:label 'Dataset Type' ;
    rdfs:comment 'Classification of the data source type: claims (insurance claims database), ehr (Electronic Health Record), registry (disease or product registry), pro (Patient-Reported Outcomes), rct_extension (RCT long-term extension), administrative (hospital/government administrative data), other. [ENUM-REF-CANDIDATE: claims|ehr|registry|pro|rct_extension|administrative|other — promote to reference product]' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deIdentificationMethod rdf:type rdf:Property ;
    rdfs:label 'De Identification Method' ;
    rdfs:comment 'Method used to de-identify patient data in the dataset: safe_harbor (HIPAA Safe Harbor), expert_determination (HIPAA Expert Determination), pseudonymized (GDPR pseudonymization), aggregated (summary-level only), not_applicable (non-patient data). Critical for HIPAA and GDPR compliance.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Dua Expiry Date' ;
    rdfs:comment 'Date on which the Data Use Agreement for this dataset expires. Triggers renewal workflow to ensure continued compliant access. Datasets with expired DUAs must not be used in active payer submissions.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:duaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dua Reference Number' ;
    rdfs:comment 'Reference number of the executed Data Use Agreement governing access to and permitted use of this dataset. Confidential as it contains contractual terms. Required for compliance with HIPAA, GDPR, and vendor contractual obligations.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heorStudyReference rdf:type rdf:Property ;
    rdfs:label 'Heor Study Reference' ;
    rdfs:comment 'Reference code or identifier linking this dataset to the primary HEOR study or analysis plan that utilizes it. Enables traceability from dataset asset to published evidence.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaSubmissionEligible rdf:type rdf:Property ;
    rdfs:label 'Hta Submission Eligible' ;
    rdfs:comment 'Indicates whether this dataset has been assessed and approved for use in HTA submissions (e.g., NICE, G-BA, HAS, CADTH). True = eligible; False = not eligible or pending review.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'License Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annual_license_cost (e.g., USD, EUR, GBP). Required for multi-currency financial reporting and budget consolidation.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedValueDossierCode rdf:type rdf:Property ;
    rdfs:label 'Linked Value Dossier Code' ;
    rdfs:comment 'Business code of the value dossier in which this dataset is cited as supporting evidence. Provides traceability between the RWD/RWE asset inventory and HTA/payer submission documents.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientCount rdf:type rdf:Property ;
    rdfs:label 'Patient Count' ;
    rdfs:comment 'Total number of unique patients included in the dataset. Key metric for payers and HTA bodies assessing statistical power and representativeness of the evidence.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payerNegotiationEligible rdf:type rdf:Property ;
    rdfs:label 'Payer Negotiation Eligible' ;
    rdfs:comment 'Indicates whether this dataset is approved for use in direct payer contract negotiations and rebate discussions. True = eligible; False = not approved for payer use.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedUseScope rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Scope' ;
    rdfs:comment 'Description of the contractually permitted uses of the dataset as defined in the DUA (e.g., internal HEOR analysis only, payer submissions, HTA submissions, publication). Confidential as it reflects contractual terms with the data vendor.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEndpointType rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Type' ;
    rdfs:comment 'Primary clinical or economic endpoint measurable from this dataset: os (Overall Survival), pfs (Progression-Free Survival), orr (Objective Response Rate), qol (Quality of Life), heor (Health Economics and Outcomes Research), safety (adverse event profiling), utilization (healthcare resource utilization), other. [ENUM-REF-CANDIDATE: os|pfs|orr|qol|heor|safety|utilization|other — promote to reference product]' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationAllowed rdf:type rdf:Property ;
    rdfs:label 'Publication Allowed' ;
    rdfs:comment 'Indicates whether the DUA permits publication of analyses derived from this dataset in peer-reviewed journals or conference proceedings. True = publication permitted; False = internal use only.' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rweStudyDesign rdf:type rdf:Property ;
    rdfs:label 'Rwe Study Design' ;
    rdfs:comment 'Epidemiological study design applied to generate evidence from this dataset: retrospective_cohort, prospective_cohort, case_control, cross_sectional, chart_review, other. Determines the level of evidence accepted by HTA bodies and payers. [ENUM-REF-CANDIDATE: retrospective_cohort|prospective_cohort|case_control|cross_sectional|chart_review|other — promote to reference product]' ;
    rdfs:domain ind:RweDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Tender Submission Id' ;
    rdfs:comment 'Unique surrogate identifier for each pharmaceutical tender submission record in the silver layer lakehouse.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketAccessStrategyId rdf:type rdf:Property ;
    rdfs:label 'Market Access Strategy Id' ;
    rdfs:comment 'Reference to the market access strategy that governs the pricing, reimbursement, and competitive positioning approach for this tender submission.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessStrategy .

ind:awardDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Award Decision Date' ;
    rdfs:comment 'Date on which the tender authority communicated the award decision (awarded or not awarded) for this submission. Used for tender cycle time analytics and market access reporting.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardStatus rdf:type rdf:Property ;
    rdfs:label 'Award Status' ;
    rdfs:comment 'Outcome of the tender evaluation indicating whether the submission was awarded, not awarded, partially awarded, pending decision, or under appeal. Core field for awarded tender tracking and win/loss analytics.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Awarded Unit Price' ;
    rdfs:comment 'Final unit price confirmed in the tender award, which may differ from the submitted unit price following negotiation or price adjustment by the tender authority. Used for gross-to-net revenue management.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardedVolume rdf:type rdf:Property ;
    rdfs:label 'Awarded Volume' ;
    rdfs:comment 'Actual volume of product units awarded by the tender authority, which may differ from the committed volume in cases of partial awards or volume adjustments. Expressed in the same unit of measure as committed_volume.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Volume' ;
    rdfs:comment 'Volume of product units committed by the company in the tender submission, expressed in the unit of measure specified by the tender authority (e.g., packs, vials, doses). Used for supply chain planning and awarded tender tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorLowestPrice rdf:type rdf:Property ;
    rdfs:label 'Competitor Lowest Price' ;
    rdfs:comment 'Lowest competitor unit price identified during tender intelligence gathering, expressed in the tender currency. Used for competitive benchmarking and tender strategy calibration.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Months' ;
    rdfs:comment 'Duration of the awarded tender contract expressed in months. Used for tender strategy planning, supply chain forecasting, and revenue recognition scheduling.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netSubmittedPrice rdf:type rdf:Property ;
    rdfs:label 'Net Submitted Price' ;
    rdfs:comment 'Net price per unit after applying any confidential discounts, rebates, or price adjustments included in the tender submission. Represents the effective price used for gross-to-net revenue management and tender strategy analytics.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'Pack size or presentation of the tendered product (e.g., 30 tablets, 10 vials x 10 mL). Corresponds to the Stock Keeping Unit (SKU) submitted in the tender and used for volume commitment calculations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBenchmarkCountryCode rdf:type rdf:Property ;
    rdfs:label 'Price Benchmark Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the reference country used for international reference pricing (IRP) benchmarking in this tender submission. Supports cross-market price corridor management.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNotes rdf:type rdf:Property ;
    rdfs:label 'Submission Notes' ;
    rdfs:comment 'Free-text field for capturing additional context, conditions, or qualifications associated with the tender submission, such as supply contingencies, regulatory approval dependencies, or special pricing conditions.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionOwner rdf:type rdf:Property ;
    rdfs:label 'Submission Owner' ;
    rdfs:comment 'Name or employee identifier of the market access or tender management professional responsible for preparing and submitting this tender. Supports accountability and escalation workflows.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Submitted Unit Price' ;
    rdfs:comment 'The per-unit price submitted by the company in the tender bid, expressed in the tender currency. This is the gross list price offered to the tender authority before any volume-based adjustments or confidential rebates.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tender Authority Name' ;
    rdfs:comment 'Full legal name of the government procurement authority, national health system, hospital group, or purchasing organization that issued the tender (e.g., NHS England, AIFA, Ministry of Health Brazil).' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Tender Authority Type' ;
    rdfs:comment 'Classification of the tender-issuing body, distinguishing between national health systems, government ministries, hospital groups, regional procurement authorities, Group Purchasing Organizations (GPO), and Pharmacy Benefit Managers (PBM).' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderLotNumber rdf:type rdf:Property ;
    rdfs:label 'Tender Lot Number' ;
    rdfs:comment 'Lot or line number within a multi-lot tender, identifying the specific product or therapeutic category lot to which this submission applies. Enables granular tracking within complex multi-product tenders.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderOpeningDate rdf:type rdf:Property ;
    rdfs:label 'Tender Opening Date' ;
    rdfs:comment 'Date on which the tender authority officially opens and evaluates submitted bids. Marks the transition from submission to evaluation phase in the tender lifecycle.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tenderReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tender Reference Number' ;
    rdfs:comment 'Externally assigned reference number issued by the tender authority to uniquely identify the tender lot or procurement event. Used for cross-referencing with government procurement portals and tender authority communications.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderType rdf:type rdf:Property ;
    rdfs:label 'Tender Type' ;
    rdfs:comment 'Procurement procedure type used by the tender authority (e.g., open, restricted, negotiated, framework agreement, direct award). Determines the competitive dynamics and submission requirements.' ;
    rdfs:domain ind:TenderSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Volume Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the committed volume in the tender submission (e.g., pack, vial, dose, unit, kg, liter). Ensures consistent volume reporting across tender markets.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetImpactModelRef rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Model Ref' ;
    rdfs:comment 'Reference identifier or document name for the budget impact model (BIM) associated with this dossier, enabling traceability to the underlying economic model file stored in Veeva Vault or equivalent document management system.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalEvidenceSummary rdf:type rdf:Property ;
    rdfs:label 'Clinical Evidence Summary' ;
    rdfs:comment 'Structured narrative summarizing the key clinical evidence supporting the product\'s value proposition, including pivotal trial results, patient population, efficacy outcomes, and safety profile as presented to payers.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'Outcome of the HTA or payer review of this dossier. Positive indicates full reimbursement recommended; positive_with_restrictions indicates conditional coverage; negative indicates rejection.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierCode rdf:type rdf:Property ;
    rdfs:label 'Dossier Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the value dossier across market access systems and payer submissions. Follows the pattern GVD-<PRODUCT_CODE>-<YEAR>-v<VERSION>.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierOwner rdf:type rdf:Property ;
    rdfs:label 'Dossier Owner' ;
    rdfs:comment 'Name or identifier of the internal market access team member or function responsible for authoring, maintaining, and updating this value dossier.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierStatus rdf:type rdf:Property ;
    rdfs:label 'Dossier Status' ;
    rdfs:comment 'Current lifecycle state of the value dossier. Draft indicates work-in-progress; approved indicates internal sign-off; published indicates submission to payer or HTA body; superseded indicates replaced by a newer version.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierType rdf:type rdf:Property ;
    rdfs:label 'Dossier Type' ;
    rdfs:comment 'Classification of the dossier by its intended use and audience. Global dossiers serve as the master template; local adaptations are country-specific derivatives. [ENUM-REF-CANDIDATE: global|local_adaptation|payer_specific|hta_submission|reimbursement_dossier|formulary_submission — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this version of the value dossier is considered active and valid for use in payer negotiations, HTA submissions, or formulary discussions.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date after which this version of the value dossier is no longer considered current and should be superseded by a newer version. Nullable for currently active dossiers.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formularyTierTarget rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier Target' ;
    rdfs:comment 'Desired formulary tier placement being sought from the payer or pharmacy benefit manager (PBM) based on the evidence presented in the dossier.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heorEvidenceSummary rdf:type rdf:Property ;
    rdfs:label 'Heor Evidence Summary' ;
    rdfs:comment 'Summary of the Health Economics and Outcomes Research (HEOR) evidence included in the dossier, covering cost-effectiveness analyses, cost-utility analyses, budget impact models, and quality-of-life (QoL) data.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalAffairsReviewed rdf:type rdf:Property ;
    rdfs:label 'Medical Affairs Reviewed' ;
    rdfs:comment 'Indicates whether the Medical Affairs function has completed a formal scientific review and sign-off of the clinical evidence sections of this dossier version.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetPayerType rdf:type rdf:Property ;
    rdfs:label 'Target Payer Type' ;
    rdfs:comment 'Classification of the primary payer audience for whom the dossier is tailored. Determines the evidence framing and economic model emphasis. [ENUM-REF-CANDIDATE: national_hta|regional_hta|commercial_payer|pbm|gpo|government_formulary|hospital_formulary — promote to reference product]' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionDate rdf:type rdf:Property ;
    rdfs:label 'Version Date' ;
    rdfs:comment 'Calendar date on which the current version of the dossier was finalized and approved for use.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Primary key for address' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are currently in use, inactive addresses are no longer valid but retained for historical reference, pending addresses are awaiting approval or validation, and archived addresses are historical records retained for compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose within pharmaceutical operations. Registered addresses are used for regulatory filings and legal documentation, operational addresses represent active business locations, shipping addresses are used for logistics and distribution, billing addresses are used for invoicing, clinical site addresses represent trial locations, and manufacturing addresses represent production facilities.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet DUNS number uniquely identifying the business entity at this address. Used for vendor qualification, supply chain due diligence, and compliance with pharmaceutical procurement standards.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified Flag' ;
    rdfs:comment 'Boolean indicator identifying whether the address location holds current Good Manufacturing Practice (cGMP) certification. True indicates the site is certified for pharmaceutical manufacturing under FDA, EMA, or other regulatory authority standards.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate in decimal degrees format. Used for geospatial analytics, supply chain route optimization, clinical trial site mapping, and emergency response planning for manufacturing facilities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line containing street number, street name, and building identifier. This is the main address component used for physical location identification and postal delivery.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as suite number, floor, building name, department, or unit identifier. Optional field used when address_line_1 is insufficient for precise location identification.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line for complex addresses requiring additional location context such as industrial park name, campus identifier, or district information. Rarely used but necessary for large pharmaceutical manufacturing complexes or research campuses.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate in decimal degrees format. Used in conjunction with latitude for precise geolocation, distribution center proximity analysis, and cold chain logistics planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdmGoldenRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Mdm Golden Record Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this address is the authoritative golden record in the Master Data Management (MDM) system. True indicates this is the single source of truth (SSOT) for this address across all enterprise systems.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Address Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this is the primary or default address for the associated entity (vendor, customer, plant, site). True indicates this is the main address used for official correspondence and regulatory filings.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySiteIdentifier rdf:type rdf:Property ;
    rdfs:label 'Regulatory Site Identifier' ;
    rdfs:comment 'Official site registration number or establishment identifier assigned by regulatory authorities such as FDA Establishment Identifier (FEI), EMA site number, or PMDA registration number. Required for regulatory submissions and inspection tracking.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapAddressNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Address Number' ;
    rdfs:comment 'SAP S/4HANA system address number linking this master data address to the corresponding address record in SAP modules (MM, SD, FI). Enables cross-system reconciliation and ensures consistency between lakehouse and operational ERP system.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizationDate rdf:type rdf:Property ;
    rdfs:label 'Standardization Date' ;
    rdfs:comment 'Date when the address was last validated or standardized against postal authority databases. Used to determine when re-validation is required, as addresses may become outdated due to postal code changes or street renaming.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardizationSource rdf:type rdf:Property ;
    rdfs:label 'Standardization Source' ;
    rdfs:comment 'The authoritative postal service or third-party vendor used to validate and standardize the address format. Identifies which national postal authority or address verification service confirmed the address accuracy. [ENUM-REF-CANDIDATE: USPS|Royal_Mail|Deutsche_Post|Canada_Post|Australia_Post|manual|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcClassificationId rdf:type rdf:Property ;
    rdfs:label 'Atc Classification Id' ;
    rdfs:comment 'Primary key for atc_classification' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtcClassification .

ind:innRegistryId rdf:type rdf:Property ;
    rdfs:label 'Inn Registry Id' ;
    rdfs:comment 'Foreign key linking to masterdata.inn_registry. Business justification: ATC level 5 codes reference INN substances. New FK inn_registry_id → inn_registry.masterdata_inn_registry_id. Remove inn_name as redundant.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InnRegistry .

ind:administrationRoute rdf:type rdf:Property ;
    rdfs:label 'Administration Route' ;
    rdfs:comment 'The route by which the drug is administered: O=Oral, P=Parenteral, R=Rectal, V=Vaginal, N=Nasal, Implant=Implant, Inhal=Inhalation, Instill=Instillation, SL=Sublingual/Buccal, TD=Transdermal. Critical for DDD assignment and clinical use. [ENUM-REF-CANDIDATE: O|P|R|V|N|Implant|Inhal|Instill|SL|TD — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel rdf:type rdf:Property ;
    rdfs:label 'Atc Level' ;
    rdfs:comment 'The hierarchical level of the ATC code: 1=Anatomical main group (1 character), 2=Therapeutic subgroup (3 characters), 3=Pharmacological subgroup (4 characters), 4=Chemical subgroup (5 characters), 5=Chemical substance (7 characters).' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atcLevel1Code rdf:type rdf:Property ;
    rdfs:label 'Atc Level 1 Code' ;
    rdfs:comment 'First level anatomical main group code (single letter A-V) representing the organ or system on which the drug acts.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel1Description rdf:type rdf:Property ;
    rdfs:label 'Atc Level 1 Description' ;
    rdfs:comment 'Full description of the anatomical main group (e.g., \'Alimentary tract and metabolism\', \'Blood and blood forming organs\', \'Cardiovascular system\').' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel2Code rdf:type rdf:Property ;
    rdfs:label 'Atc Level 2 Code' ;
    rdfs:comment 'Second level therapeutic subgroup code (3 characters) representing the therapeutic main group.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel2Description rdf:type rdf:Property ;
    rdfs:label 'Atc Level 2 Description' ;
    rdfs:comment 'Full description of the therapeutic subgroup (e.g., \'Drugs used in diabetes\', \'Antithrombotic agents\').' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel3Code rdf:type rdf:Property ;
    rdfs:label 'Atc Level 3 Code' ;
    rdfs:comment 'Third level pharmacological subgroup code (4 characters) representing the pharmacological or therapeutic subgroup.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel3Description rdf:type rdf:Property ;
    rdfs:label 'Atc Level 3 Description' ;
    rdfs:comment 'Full description of the pharmacological subgroup (e.g., \'Blood glucose lowering drugs, excl. insulins\', \'Platelet aggregation inhibitors excl. heparin\').' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel4Code rdf:type rdf:Property ;
    rdfs:label 'Atc Level 4 Code' ;
    rdfs:comment 'Fourth level chemical subgroup code (5 characters) representing the chemical or therapeutic subgroup.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel4Description rdf:type rdf:Property ;
    rdfs:label 'Atc Level 4 Description' ;
    rdfs:comment 'Full description of the chemical subgroup (e.g., \'Biguanides\', \'Adenosine diphosphate (ADP) receptor inhibitors\').' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel5Code rdf:type rdf:Property ;
    rdfs:label 'Atc Level 5 Code' ;
    rdfs:comment 'Fifth level chemical substance code (7 characters) representing the specific chemical substance or combination.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel5Description rdf:type rdf:Property ;
    rdfs:label 'Atc Level 5 Description' ;
    rdfs:comment 'Full description of the chemical substance, typically the INN (International Nonproprietary Name) or combination name (e.g., \'metformin\', \'clopidogrel\').' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcNote rdf:type rdf:Property ;
    rdfs:label 'Atc Note' ;
    rdfs:comment 'Additional notes, clarifications, or special instructions related to the ATC classification, including usage restrictions, combination product details, or cross-references to related codes.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcStatus rdf:type rdf:Property ;
    rdfs:label 'Atc Status' ;
    rdfs:comment 'Current lifecycle status of the ATC code: active=currently in use, inactive=temporarily suspended, withdrawn=permanently removed from WHO ATC index, pending=under review for inclusion, deprecated=superseded by another code.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biosimilarReferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Biosimilar Reference Flag' ;
    rdfs:comment 'Indicates whether this biological substance serves as a reference product for biosimilar development and approval (True) or not (False). Relevant for biologics license applications.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:combinationProductFlag rdf:type rdf:Property ;
    rdfs:label 'Combination Product Flag' ;
    rdfs:comment 'Indicates whether this ATC code represents a fixed-dose combination product containing two or more active pharmaceutical ingredients (True) or a single active substance (False).' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dddValue rdf:type rdf:Property ;
    rdfs:label 'Ddd Value' ;
    rdfs:comment 'The assumed average maintenance dose per day for a drug used for its main indication in adults, expressed as a numeric value. Used for drug utilization studies and pharmacoeconomic analysis.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:therapeuticEquivalenceGroup rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Equivalence Group' ;
    rdfs:comment 'Grouping code for substances considered therapeutically equivalent or interchangeable for the same indication, used in formulary management and substitution policies.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this ATC classification record becomes effective and valid for use in regulatory submissions, pharmacovigilance reporting, and commercial analytics.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this ATC classification record remains valid. Null indicates the record is currently active with no planned end date.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:whoPublicationYear rdf:type rdf:Property ;
    rdfs:label 'Who Publication Year' ;
    rdfs:comment 'The year this ATC code was officially published or last updated by the WHO Collaborating Centre for Drug Statistics Methodology.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avlFlag rdf:type rdf:Property ;
    rdfs:label 'Avl Flag' ;
    rdfs:comment 'Boolean indicator whether this business partner is on the Approved Vendor List. True indicates the partner is approved for procurement and manufacturing activities.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number for payment processing. Encrypted at rest and in transit per PCI DSS and SOX requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingIndicator rdf:type rdf:Property ;
    rdfs:label 'Blocking Indicator' ;
    rdfs:comment 'Indicates whether the business partner is blocked for specific business functions (sales, purchasing, payment) due to compliance, quality, or financial issues.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bpCategory rdf:type rdf:Property ;
    rdfs:label 'Bp Category' ;
    rdfs:comment 'Classification of the business partner entity type: person (individual), organization (company/institution), or group (corporate group).' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bpNumber rdf:type rdf:Property ;
    rdfs:label 'Bp Number' ;
    rdfs:comment 'The externally-known unique business partner number assigned by SAP S/4HANA. This is the authoritative business identifier used across all systems for external party identity.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bpRole rdf:type rdf:Property ;
    rdfs:label 'Bp Role' ;
    rdfs:comment 'Comma-separated list of roles assigned to this business partner. Roles include: supplier, customer, carrier, CMO (Contract Manufacturing Organization), CRO (Contract Research Organization), CDMO (Contract Development and Manufacturing Organization), distributor, wholesaler, hospital, pharmacy, GPO (Group Purchasing Organization), government agency. A single BP may hold multiple roles.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPartnerStatus rdf:type rdf:Property ;
    rdfs:label 'Business Partner Status' ;
    rdfs:comment 'Current lifecycle status of the business partner record. Active indicates the partner is approved for transactions; inactive/suspended/terminated indicate various states of non-availability.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the credit limit amount.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment '13-digit GS1 Global Location Number uniquely identifying the business partners physical, functional, or legal entity location. Used in supply chain and EDI transactions.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Expiry Date' ;
    rdfs:comment 'Expiration date of the current GMP certification. Triggers re-qualification workflows and AVL review.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number for SEPA and international wire transfers. Used for business partners in IBAN-participating countries.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the business partner as registered with government authorities. Used for contracts, regulatory submissions, and legal documentation.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsSupplierCode rdf:type rdf:Property ;
    rdfs:label 'Lims Supplier Code' ;
    rdfs:comment 'Cross-system identifier linking this business partner to the supplier master in LIMS for reagent, reference standard, and consumable procurement tracking.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Risk classification assigned to the business partner based on criticality of supplied materials, quality history, regulatory compliance, and business continuity factors.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'SWIFT/BIC code identifying the business partners bank for international payments and wire transfers.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaAccountCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Account Code' ;
    rdfs:comment 'Cross-system identifier linking this business partner to the corresponding account record in Veeva CRM for commercial and medical affairs integration.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortName rdf:type rdf:Property ;
    rdfs:label 'Account Short Name' ;
    rdfs:comment 'Abbreviated name or label for the GL account used in reports and user interfaces where space is limited.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'For balance sheet accounts, specifies whether the account is classified as current or non-current asset/liability, or equity. Not applicable for P&L accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaIntegration rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Integration' ;
    rdfs:comment 'Boolean flag indicating whether this account is integrated with the Controlling module for cost center, internal order, and profitability analysis postings.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'For accounts that are cost elements, specifies whether it is a primary cost element (posted from FI) or secondary cost element (used for internal allocations). Not applicable if cost_element_indicator is false.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Element Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this GL account is also defined as a cost element in Controlling (CO) module, enabling cost center and internal order postings.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Specifies which currency perspective this account primarily operates in: local currency, group currency, hard currency, index-based currency, or global company currency. Supports multi-currency pharmaceutical operations.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'Indicates which primary financial statement this account appears on: balance sheet (statement of financial position), profit and loss (income statement), cash flow statement, or statement of retained earnings.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsMappingCode rdf:type rdf:Property ;
    rdfs:label 'Ifrs Mapping Code' ;
    rdfs:comment 'The IFRS financial statement line item code that this account maps to for IFRS-compliant financial reporting. Enables parallel accounting and consolidated reporting under IFRS standards.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Boolean flag indicating whether individual line item details are stored and can be displayed for this account. Essential for accounts requiring detailed transaction audit trails.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneRevenueIndicator rdf:type rdf:Property ;
    rdfs:label 'Milestone Revenue Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this revenue account is used for milestone-based revenue recognition common in pharmaceutical licensing and collaboration agreements (e.g., regulatory approval milestones, sales milestones).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Boolean flag indicating whether this account uses open item management, requiring line items to be explicitly cleared (e.g., for receivables, payables, clearing accounts).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plClassification rdf:type rdf:Property ;
    rdfs:label 'Pl Classification' ;
    rdfs:comment 'For income statement accounts, specifies the detailed classification within the P&L structure (operating vs non-operating, revenue vs expense categories). Not applicable for balance sheet accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Posting Block Indicator' ;
    rdfs:comment 'Boolean flag indicating whether direct postings to this account are currently blocked. When true, the account can only receive postings through specific controlled processes.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterUpdateIndicator rdf:type rdf:Property ;
    rdfs:label 'Profit Center Update Indicator' ;
    rdfs:comment 'Boolean flag indicating whether postings to this account automatically update profit center accounting, enabling segment reporting and profitability analysis by therapeutic area or product line.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rdCapitalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Rd Capitalization Eligible' ;
    rdfs:comment 'Boolean flag indicating whether costs posted to this account are eligible for capitalization as intangible assets under development (e.g., post-IND development costs). Critical for pharmaceutical R&D accounting under IAS 38 and ASC 730.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this is a reconciliation account (subledger control account) that summarizes detailed transactions from subsidiary ledgers such as Accounts Receivable, Accounts Payable, or Asset Accounting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyAccrualIndicator rdf:type rdf:Property ;
    rdfs:label 'Royalty Accrual Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this account is used for royalty expense accruals or royalty revenue recognition, common in pharmaceutical licensing arrangements and patent agreements.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'The default sort key used for organizing and displaying line items within this account (e.g., by posting date, document number, reference). Improves usability for high-volume accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The tax treatment category for this account, determining how transactions posted to this account are handled for tax reporting purposes (e.g., \'VAT_INPUT\', \'VAT_OUTPUT\', \'NON_TAXABLE\', \'EXEMPT\').' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usGaapMappingCode rdf:type rdf:Property ;
    rdfs:label 'Us Gaap Mapping Code' ;
    rdfs:comment 'The US GAAP financial statement line item code that this account maps to for US GAAP-compliant financial reporting. Supports dual reporting requirements for pharmaceutical companies with US operations.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Employee Id' ;
    rdfs:comment 'Employee identifier of the person responsible for managing and controlling costs within this cost center. Used for accountability and approval workflows.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityTypeIndicator rdf:type rdf:Property ;
    rdfs:label 'Activity Type Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this cost center performs activity-based costing and maintains activity types for internal cost allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'The controlling area to which this cost center is assigned. Controlling area is the highest organizational unit in management accounting, representing a closed system for cost accounting purposes.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used for allocating costs from this cost center to other cost objects (e.g., direct allocation, activity-based costing, assessment, distribution). Supports COGS calculation and transfer pricing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Classification of the cost center by functional area. Production includes manufacturing and API production; R&D includes drug discovery, preclinical, and clinical development; Quality Control includes QC labs and QA functions; Regulatory Affairs includes submission and compliance activities.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Extended textual description of the cost center\'s purpose, scope, and responsibilities within the organization.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full descriptive name of the cost center, providing human-readable identification for reporting and analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active cost centers accept postings; Inactive cost centers are closed; Blocked cost centers exist but cannot receive new postings; Planned cost centers are defined for future use.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Granular classification of the cost center type within its category, enabling detailed cost analysis and allocation logic.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area classification for cost-of-sales accounting and external financial reporting per IFRS/GAAP requirements. Typical values include manufacturing, R&D, sales, administration.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Standard hierarchy assignment for cost center grouping and roll-up reporting in management accounting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Indicates which types of postings are locked for this cost center. Unlocked allows all postings; Locked_actual prevents actual cost postings; Locked_plan prevents planning postings; Locked_all prevents all postings.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Group' ;
    rdfs:comment 'Planning group assignment for cost center planning and budgeting cycles, enabling coordinated planning across related cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant Flag' ;
    rdfs:comment 'Indicates whether this cost center is subject to SOX financial controls and audit requirements, typically for cost centers involved in financial reporting processes.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statisticalCostCenterFlag rdf:type rdf:Property ;
    rdfs:label 'Statistical Cost Center Flag' ;
    rdfs:comment 'Indicates whether this is a statistical cost center used for informational purposes only, without actual cost postings.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalTrialRegistrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Registration Required Flag' ;
    rdfs:comment 'Indicates whether the country mandates registration of clinical trials in a public registry (e.g., ClinicalTrials.gov, EU Clinical Trials Register, CTRI India) before trial initiation. True if registration required, False otherwise. Impacts CTMS workflows and regulatory compliance.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlledSubstanceScheduleSystem rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Schedule System' ;
    rdfs:comment 'Name of the controlled substance classification system used in the country (e.g., DEA Schedules I-V for USA, UK Misuse of Drugs Act Classes A/B/C, Japan Narcotics and Psychotropics Control Law). Determines manufacturing, storage, distribution, and prescribing requirements for controlled APIs and drug products. Impacts supply chain security and regulatory submissions.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Official English name of the country or territory as recognized by the United Nations and used in regulatory submissions, commercial documentation, and reporting (e.g., United States of America, United Kingdom, Japan, China, Germany).' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryStatus rdf:type rdf:Property ;
    rdfs:label 'Country Status' ;
    rdfs:comment 'Current operational status of the country for pharmaceutical business activities. Active: normal operations permitted. Inactive: no current operations or market presence. Restricted: limited operations due to regulatory or business constraints. Sanctioned: operations prohibited due to international sanctions or trade restrictions. Impacts supply chain routing, clinical trial site selection, and commercial activities.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyRegulation rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Regulation' ;
    rdfs:comment 'Name of the primary data privacy and protection regulation applicable in the country (e.g., GDPR for EU, HIPAA for USA, LGPD for Brazil, PDPA for Singapore). Governs handling of patient data in clinical trials, pharmacovigilance, and commercial activities. Critical for EDC system configuration, eTMF management, and data transfer agreements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionLicenseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Distribution License Required Flag' ;
    rdfs:comment 'Indicates whether a separate wholesale distribution license or GDP certification is required to distribute pharmaceutical products within the country. True if distribution license required, False otherwise. Impacts supply chain partner qualification and logistics planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpInspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Gmp Inspection Authority' ;
    rdfs:comment 'Name of the authority responsible for conducting GMP inspections of pharmaceutical manufacturing facilities within the country (may differ from the primary regulatory authority in some jurisdictions). Critical for manufacturing site qualification, PAI scheduling, and quality compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichRegionFlag rdf:type rdf:Property ;
    rdfs:label 'Ich Region Flag' ;
    rdfs:comment 'Indicates whether the country is a member of an ICH region (USA, EU, Japan, Canada, Switzerland). ICH membership determines applicability of harmonized technical requirements for pharmaceutical registration (CTD/eCTD format, stability testing, quality guidelines). True if ICH member, False otherwise.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ichRegionName rdf:type rdf:Property ;
    rdfs:label 'Ich Region Name' ;
    rdfs:comment 'Name of the ICH region to which the country belongs, if applicable. Used to determine which ICH guidelines and harmonized standards apply to regulatory submissions and CMC documentation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha2Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 2 Code' ;
    rdfs:comment 'Two-letter country code as defined by ISO 3166-1 alpha-2 standard. Used for regulatory submissions, labeling, and system integrations (e.g., US, GB, JP, CN, DE).' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha3Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 3 Code' ;
    rdfs:comment 'Three-letter country code as defined by ISO 3166-1 alpha-3 standard. Used in eCTD submissions, regulatory documents, and SAP S/4HANA master data (e.g., USA, GBR, JPN, CHN, DEU).' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoNumericCode rdf:type rdf:Property ;
    rdfs:label 'Iso Numeric Code' ;
    rdfs:comment 'Three-digit numeric country code as defined by ISO 3166-1 numeric standard. Used in systems requiring numeric-only identifiers (e.g., 840 for USA, 826 for GBR, 392 for JPN).' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketAccessTier rdf:type rdf:Property ;
    rdfs:label 'Market Access Tier' ;
    rdfs:comment 'Commercial prioritization tier for market access and launch planning. Tier 1: high-value markets with established reimbursement frameworks and large patient populations (e.g., USA, Germany, Japan). Tier 2: significant markets with moderate access complexity. Tier 3: smaller markets or those with challenging reimbursement. Emerging: developing markets with growth potential. Drives commercial strategy, HEOR investment, and launch sequencing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentFilingAuthority rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Authority' ;
    rdfs:comment 'Name of the national intellectual property office responsible for patent applications and grants (e.g., USPTO, EPO, JPO, CNIPA, UKIPO). Used for tracking patent filings, patent term extensions, and exclusivity periods for NCEs and NBEs.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmaceuticalMarketClassification rdf:type rdf:Property ;
    rdfs:label 'Pharmaceutical Market Classification' ;
    rdfs:comment 'Classification of the country\'s pharmaceutical regulatory maturity and market structure. Regulated markets have stringent GMP, GCP, and pharmacovigilance requirements (e.g., USA, EU, Japan). Semi-Regulated markets have evolving frameworks. Emerging markets have developing regulatory infrastructure. Unregulated markets have minimal oversight. Drives market access strategy, clinical trial site selection, and supply chain compliance requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacovigilanceRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Pharmacovigilance Requirement Level' ;
    rdfs:comment 'Classification of the country\'s pharmacovigilance and adverse event reporting requirements. Stringent: mandatory ICSR reporting, SUSAR expedited reporting, periodic safety update reports (e.g., USA, EU, Japan). Moderate: ICSR reporting required with longer timelines. Basic: minimal AE reporting. None: no formal PV requirements. Drives Argus Safety configuration and safety reporting workflows.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:picsMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Pics Member Flag' ;
    rdfs:comment 'Indicates whether the country\'s regulatory authority is a member of PIC/S, enabling mutual recognition of GMP inspections and reducing duplicate inspections for manufacturing sites. True if PIC/S member, False otherwise.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for the country\'s primary official language (e.g., en, ja, zh, de, fr). Used for labeling requirements, patient information leaflets, regulatory submission language, and Veeva PromoMats localization.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Code' ;
    rdfs:comment 'Standardized code or abbreviation for the primary regulatory authority (e.g., FDA, EMA, MHRA, PMDA, NMPA). Used in Veeva Vault RIM, RIMS systems, and regulatory submission workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the primary national regulatory authority responsible for pharmaceutical product approvals, post-market surveillance, and GMP inspections (e.g., FDA, EMA, MHRA, PMDA, NMPA, Health Canada, TGA, Anvisa). Critical for routing regulatory submissions and managing compliance obligations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementFrameworkType rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Framework Type' ;
    rdfs:comment 'Description of the country\'s pharmaceutical reimbursement and pricing framework (e.g., government-negotiated pricing, health technology assessment (HTA) required, free pricing, reference pricing, value-based agreements). Impacts pricing strategy, market access timelines, and HEOR evidence requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Serialization Requirement Flag' ;
    rdfs:comment 'Indicates whether the country mandates unique serialization and track-and-trace for pharmaceutical products to prevent counterfeiting (e.g., EU FMD, US DSCSA, China NMPA serialization, South Korea PMDA serialization). True if serialization required, False otherwise. Drives packaging line configuration and supply chain system requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Commonly used short name for the country or territory, used in user interfaces, reports, and operational systems (e.g., United States, UK, Japan, China, Germany).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subRegion rdf:type rdf:Property ;
    rdfs:label 'Sub Region' ;
    rdfs:comment 'Sub-region classification within the broader region (e.g., Northern America, Western Europe, Eastern Asia, South-Eastern Asia, Southern Asia). Used for granular market segmentation and supply chain optimization.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeMoietyInn rdf:type rdf:Property ;
    rdfs:label 'Active Moiety Inn' ;
    rdfs:comment 'The INN of the active moiety (the molecule or ion responsible for physiological or pharmacological action) when the registered substance is a salt, ester, or other derivative. For example, imatinib mesylate (salt) has imatinib as the active moiety.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biosimilarReferenceInn rdf:type rdf:Property ;
    rdfs:label 'Biosimilar Reference Inn' ;
    rdfs:comment 'For biosimilar substances, the INN of the reference biologic product to which this biosimilar is compared. Null for non-biosimilar substances or originator biologics.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakthroughTherapyDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy Designation Flag' ;
    rdfs:comment 'Boolean indicator of whether the substance has received breakthrough therapy designation from the FDA, indicating preliminary clinical evidence of substantial improvement over existing therapies for serious conditions.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:casRegistryNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Registry Number' ;
    rdfs:comment 'The unique numerical identifier assigned by the Chemical Abstracts Service to the chemical substance. CAS numbers are globally recognized identifiers for chemical compounds used in regulatory filings, scientific literature, and supply chain documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innDefinition rdf:type rdf:Property ;
    rdfs:label 'Inn Definition' ;
    rdfs:comment 'The official WHO definition or description of the substance associated with the INN, including its chemical nature, biological origin, or therapeutic purpose. Provides context for the INN assignment.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innLanguageVariants rdf:type rdf:Property ;
    rdfs:label 'Inn Language Variants' ;
    rdfs:comment 'Alternative language-specific spellings or transliterations of the INN (e.g., Latin, French, Spanish, Russian, Arabic, Chinese). Stored as a delimited list or JSON structure to support multilingual regulatory submissions and labeling.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innStatus rdf:type rdf:Property ;
    rdfs:label 'Inn Status' ;
    rdfs:comment 'Current status of the INN designation in the WHO publication lifecycle. Proposed indicates initial submission; Recommended indicates WHO expert committee approval; Published indicates final inclusion in WHO INN list; Withdrawn indicates retraction.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innStem rdf:type rdf:Property ;
    rdfs:label 'Inn Stem' ;
    rdfs:comment 'The suffix or stem used in the INN name that indicates the pharmacological or chemical class (e.g., -mab for monoclonal antibodies, -tinib for tyrosine kinase inhibitors, -pril for ACE inhibitors). INN stems provide systematic nomenclature consistency.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacologicalClass rdf:type rdf:Property ;
    rdfs:label 'Pharmacological Class' ;
    rdfs:comment 'The therapeutic or pharmacological classification of the substance based on its mechanism of action or therapeutic use (e.g., kinase inhibitor, monoclonal antibody, beta-lactam antibiotic, ACE inhibitor). Provides insight into the drug\'s mode of action and therapeutic category.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceClass rdf:type rdf:Property ;
    rdfs:label 'Substance Class' ;
    rdfs:comment 'High-level classification of the pharmaceutical substance type. Small molecule refers to chemically synthesized drugs; Biologic refers to protein-based therapeutics; Vaccine refers to immunization products; Gene therapy and Cell therapy refer to advanced therapeutic modalities; Oligonucleotide refers to nucleic acid-based drugs.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usanName rdf:type rdf:Property ;
    rdfs:label 'Usan Name' ;
    rdfs:comment 'The United States Adopted Name for the pharmaceutical substance as designated by the USAN Council. May differ from INN in some cases but typically aligns with WHO INN nomenclature.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whoInnListNumber rdf:type rdf:Property ;
    rdfs:label 'Who Inn List Number' ;
    rdfs:comment 'The sequential WHO INN list number in which the substance was published. WHO publishes INN lists periodically; this number references the specific publication edition.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:whoPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Who Publication Date' ;
    rdfs:comment 'The date on which the INN was officially published by the WHO in the INN list. Represents the formal recognition date of the nonproprietary name.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:whoPublicationReference rdf:type rdf:Property ;
    rdfs:label 'Who Publication Reference' ;
    rdfs:comment 'The full citation or reference to the WHO document or publication in which the INN was announced. Typically includes WHO Drug Information volume and issue number.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the parent legal entity in the organizational hierarchy. Null for top-level holding companies. Used to construct the legal entity hierarchy for consolidation and reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the ultimate parent legal entity at the top of the organizational hierarchy. Used for global consolidation and group-level reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'The consolidation group or reporting unit to which this legal entity belongs for financial consolidation purposes. Used to aggregate financial results across multiple legal entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStewardName rdf:type rdf:Property ;
    rdfs:label 'Data Steward Name' ;
    rdfs:comment 'The name of the individual or role responsible for maintaining the accuracy and completeness of this legal entity master data record. Part of the MDM governance framework.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the legal entity was officially dissolved or terminated. Null for active entities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emaOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Ema Organization Code' ;
    rdfs:comment 'The organization identifier assigned by the European Medicines Agency for entities involved in pharmaceutical activities in the European Union. Used in regulatory submissions and correspondence.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'The current operational and legal status of the entity. Active entities are currently operating, inactive entities are dormant but legally registered, dissolved entities have been legally terminated, merged entities have been combined with another entity, acquired entities have been purchased by another organization, and pending formation entities are in the process of incorporation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'The month in which the legal entity\'s fiscal year ends, represented as an integer from 1 (January) to 12 (December). Used for financial reporting and tax purposes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'The primary currency in which the legal entity conducts its business and maintains its books of account, represented as a 3-letter ISO currency code.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was officially incorporated or registered in its jurisdiction.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'The standard industry classification code for the legal entity\'s primary business activity. May use NAICS, SIC, or ISIC classification systems.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Status' ;
    rdfs:comment 'The current ISO quality management system certifications held by this legal entity (e.g., ISO 9001, ISO 13485). Multiple certifications may be listed.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Of Incorporation' ;
    rdfs:comment 'The country or jurisdiction where the legal entity is incorporated or registered, represented as a 3-letter ISO country code.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalForm rdf:type rdf:Property ;
    rdfs:label 'Legal Form' ;
    rdfs:comment 'The legal form or structure of the entity as defined by the jurisdiction of incorporation (e.g., Corporation, Limited Liability Company, Public Limited Company, Private Limited Company, Partnership). Uses ISO 20275 Entity Legal Forms codes where applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'The 20-character ISO 17442 Legal Entity Identifier code used for global entity identification in financial transactions and regulatory reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBusinessActivity rdf:type rdf:Property ;
    rdfs:label 'Primary Business Activity' ;
    rdfs:comment 'Description of the primary business activity or operations conducted by this legal entity (e.g., pharmaceutical manufacturing, research and development, distribution, holding company).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'The first line of the official registered address of the legal entity as recorded with the jurisdiction of incorporation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'The second line of the official registered address of the legal entity, typically containing suite, floor, or building information.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'The city or municipality of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Country' ;
    rdfs:comment 'The country of the registered address, represented as a 3-letter ISO country code.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'The postal code or ZIP code of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'The state, province, or administrative region of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'The currency used for external financial reporting and consolidation, represented as a 3-letter ISO currency code. May differ from functional currency for subsidiaries.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sap Company Code' ;
    rdfs:comment 'The 4-character SAP S/4HANA company code assigned to this legal entity. Company codes are the smallest organizational unit for which a complete self-contained set of accounts can be drawn up for external reporting purposes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchangeListing rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange Listing' ;
    rdfs:comment 'The stock exchange(s) on which the legal entity\'s securities are listed, if publicly traded. Uses ISO 10383 Market Identifier Codes (MIC) where applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker Symbol' ;
    rdfs:comment 'The ticker symbol or trading symbol for the legal entity\'s publicly traded securities, if applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'The VAT registration number assigned by the tax authority for entities registered for VAT purposes. Applicable primarily in jurisdictions with VAT systems.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagedIndicator rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Indicator' ;
    rdfs:comment 'Flag indicating whether the material requires batch-level tracking and management for traceability and quality control purposes.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which the material is discontinued and no longer available for new orders or production, supporting product lifecycle management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the material including packaging, expressed in the weight unit of measure.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'Classification of hazardous materials per GHS (Globally Harmonized System) or DOT hazard classes for transportation and safety management.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Flag indicating whether the material is classified as hazardous per regulatory definitions, requiring special handling and documentation.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Lims Material Code' ;
    rdfs:comment 'Material identifier used in the LIMS system for laboratory testing, quality control, and certificate of analysis tracking.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Manufacturer\'s unique part number or catalog number for the material, used for procurement and supplier management.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Short textual description of the material for identification and display purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Hierarchical grouping code for materials used for procurement, planning, and reporting purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material indicating its availability for use in operations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Mes Material Code' ;
    rdfs:comment 'Material identifier used in the MES system for production tracking, batch records, and manufacturing operations.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum number of days of remaining shelf life required at goods receipt or before use in production, ensuring adequate time for processing and distribution.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Weight of the material excluding packaging, expressed in the weight unit of measure.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Indicates how the material is obtained: externally purchased, internally manufactured, or both. Consignment indicates vendor-owned inventory.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Flag indicating whether incoming goods or production batches of this material require quality inspection before release for use.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Retest Interval Days' ;
    rdfs:comment 'Number of days after which stored material must be retested to confirm continued compliance with specifications, applicable to APIs and intermediates.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serialNumberProfile rdf:type rdf:Property ;
    rdfs:label 'Serial Number Profile' ;
    rdfs:comment 'Configuration profile defining serial number management requirements for the material, used for unit-level traceability.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Total shelf life of the material from manufacturing date to expiration, expressed in days. Critical for GMP compliance and inventory management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required environmental conditions for material storage including temperature range, humidity, and light protection requirements per stability data.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureSensitiveIndicator rdf:type rdf:Property ;
    rdfs:label 'Temperature Sensitive Indicator' ;
    rdfs:comment 'Flag indicating whether the material requires temperature-controlled storage and transportation (cold chain management).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Physical volume of the material, used for storage and transportation planning.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for the volume field.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for gross and net weight fields.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthUnitOfMeasureId rdf:type rdf:Property ;
    rdfs:label 'Strength Unit Of Measure Id' ;
    rdfs:comment 'Foreign key linking to masterdata.unit_of_measure. Business justification: NDC codes have a \'strength\' STRING attribute (e.g., \'500mg\', \'10mg/mL\') that combines a numeric value and a unit of measure. Best practice is to split this into strength_value (DECIMAL) and strength_u' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitOfMeasure .

ind:activeIngredientCount rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Count' ;
    rdfs:comment 'The number of distinct active pharmaceutical ingredients (APIs) in the drug product. Most products have 1; combination products have 2 or more.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biosimilarFlag rdf:type rdf:Property ;
    rdfs:label 'Biosimilar Flag' ;
    rdfs:comment 'Indicates whether the biological product is a biosimilar (highly similar to an FDA-approved reference biological product). True if biosimilar, False otherwise.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endMarketingDate rdf:type rdf:Property ;
    rdfs:label 'End Marketing Date' ;
    rdfs:comment 'The date on which the drug product was discontinued from commercial marketing in the United States. Null if the product is still actively marketed.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interchangeableBiosimilarFlag rdf:type rdf:Property ;
    rdfs:label 'Interchangeable Biosimilar Flag' ;
    rdfs:comment 'Indicates whether the biosimilar product has been designated by the FDA as interchangeable with the reference biological product, allowing pharmacy-level substitution. True if interchangeable, False otherwise.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelerCode rdf:type rdf:Property ;
    rdfs:label 'Labeler Code' ;
    rdfs:comment 'The first segment of the NDC identifying the labeler (manufacturer, repackager, or distributor) assigned by the FDA. Typically 4 or 5 digits.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelerName rdf:type rdf:Property ;
    rdfs:label 'Labeler Name' ;
    rdfs:comment 'The legal name of the company responsible for labeling and marketing the drug product (manufacturer, repackager, or distributor).' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Listing Expiration Date' ;
    rdfs:comment 'The date on which the NDC listing expires or was discontinued in the FDA National Drug Code Directory. Products with expired listings are no longer actively marketed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingStatus rdf:type rdf:Property ;
    rdfs:label 'Marketing Status' ;
    rdfs:comment 'The current marketing and distribution status of the drug product in the United States. Indicates whether the product is actively marketed as prescription, over-the-counter, or has been discontinued.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcNumber rdf:type rdf:Property ;
    rdfs:label 'Ndc Number' ;
    rdfs:comment 'The 10-digit or 11-digit National Drug Code assigned by the FDA to uniquely identify a drug product marketed in the United States. Format may be 5-4-1, 5-4-2, 5-3-2, or 4-4-2 depending on labeler, product, and package code segments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'The third segment of the NDC identifying the package size and type. Typically 1 or 2 digits.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'A textual description of the package configuration, including quantity, container type, and packaging hierarchy (e.g., \'100 TABLET in 1 BOTTLE\', \'10 BLISTER PACK in 1 CARTON\').' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmClass rdf:type rdf:Property ;
    rdfs:label 'Pharm Class' ;
    rdfs:comment 'The pharmacologic class or mechanism of action (MOA) of the active ingredient, describing how the drug works at the molecular or physiological level.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'The second segment of the NDC identifying the specific strength, dosage form, and formulation of the drug product. Typically 3 or 4 digits.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proprietaryName rdf:type rdf:Property ;
    rdfs:label 'Proprietary Name' ;
    rdfs:comment 'The brand or trade name under which the drug product is marketed (e.g., Lipitor, Advil). May be null for generic products marketed under nonproprietary name only.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repackagerFlag rdf:type rdf:Property ;
    rdfs:label 'Repackager Flag' ;
    rdfs:comment 'Indicates whether the labeler is a repackager (repackages bulk drug product into smaller units) rather than the original manufacturer. True if repackager, False if original manufacturer or distributor.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rxOtcIndicator rdf:type rdf:Property ;
    rdfs:label 'Rx Otc Indicator' ;
    rdfs:comment 'Indicates whether the drug product requires a prescription (Rx) or is available over-the-counter (OTC) without a prescription.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startMarketingDate rdf:type rdf:Property ;
    rdfs:label 'Start Marketing Date' ;
    rdfs:comment 'The date on which the drug product was first commercially marketed in the United States under this NDC.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the enterprise hierarchy. Enables hierarchical traversal and roll-up reporting across business units, divisions, departments, and teams. Null for top-level units.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:gcpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gcp Regulated Flag' ;
    rdfs:comment 'Indicates whether this organizational unit operates under GCP (Good Clinical Practice) regulations. True for clinical development, medical affairs, and pharmacovigilance units conducting or supporting clinical trials.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or market where this organizational unit operates (e.g., North America, Europe, Asia Pacific, Latin America). Used for regional performance analysis and market segmentation.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Glp Regulated Flag' ;
    rdfs:comment 'Indicates whether this organizational unit operates under GLP (Good Laboratory Practice) regulations. True for preclinical research and toxicology laboratories conducting non-clinical safety studies.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Regulated Flag' ;
    rdfs:comment 'Indicates whether this organizational unit operates under GMP (Good Manufacturing Practice) or cGMP (Current Good Manufacturing Practice) regulations. True for manufacturing, quality control, and quality assurance units handling drug substances or drug products.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headcountFte rdf:type rdf:Property ;
    rdfs:label 'Headcount Fte' ;
    rdfs:comment 'Total full-time equivalent employee count allocated to this organizational unit. Used for workforce planning, budget allocation, and productivity analysis. Includes full-time, part-time, and contractor resources normalized to FTE.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. Active units are operational and staffed. Inactive units are temporarily suspended. Pending units are approved but not yet operational. Dissolved units have been permanently closed.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qmsScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Qms Scope Flag' ;
    rdfs:comment 'Indicates whether this organizational unit is within the scope of the enterprise Quality Management System (QMS). True for units subject to ISO 9001 certification and quality audits.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapOrgUnitCode rdf:type rdf:Property ;
    rdfs:label 'Sap Org Unit Code' ;
    rdfs:comment 'Native SAP S/4HANA organizational unit identifier from the Organizational Management (OM) module. Used for bidirectional synchronization and cross-system reconciliation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLocation rdf:type rdf:Property ;
    rdfs:label 'Site Location' ;
    rdfs:comment 'Physical site or facility name where the organizational unit is primarily located. Used for facility management, space planning, and operational logistics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Business-assigned unique code for the organizational unit. Used for cross-system integration and reporting. Typically aligned with SAP S/4HANA organizational element codes (cost center, profit center, business area).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitLevel rdf:type rdf:Property ;
    rdfs:label 'Unit Level' ;
    rdfs:comment 'Numeric level of the unit in the organizational hierarchy. Level 1 represents top-level enterprise units, with increasing numbers for deeper nesting. Supports hierarchy depth analysis and roll-up aggregation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full official name of the organizational unit as recognized in corporate documentation and reporting systems. Used for display in reports, dashboards, and organizational charts.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitShortName rdf:type rdf:Property ;
    rdfs:label 'Unit Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the organizational unit. Used in space-constrained displays and informal communication.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organizational unit by its role in the enterprise structure. Determines reporting hierarchy level and management accountability scope. [ENUM-REF-CANDIDATE: business_unit|division|department|function|team|cost_center|profit_center — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Capacity Units' ;
    rdfs:comment 'Maximum annual production capacity of the plant expressed in standard units (e.g., kilograms of API, millions of dosage units), used for capacity planning and network design.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityClass rdf:type rdf:Property ;
    rdfs:label 'Capacity Class' ;
    rdfs:comment 'Classification of the plant\'s production or operational capacity relative to other facilities in the network, used for supply chain planning and network optimization.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaSiteNumber rdf:type rdf:Property ;
    rdfs:label 'Ema Site Number' ;
    rdfs:comment 'Unique site identifier assigned by the European Medicines Agency for manufacturing and testing facilities within the European Economic Area.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalPermitStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Status' ;
    rdfs:comment 'Current status of environmental operating permits required for pharmaceutical manufacturing operations at the plant facility.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Date' ;
    rdfs:comment 'Date when the plant received its current Good Manufacturing Practice certification from the relevant regulatory authority.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limsSystem rdf:type rdf:Property ;
    rdfs:label 'Lims System' ;
    rdfs:comment 'Name and version of the Laboratory Information Management System used at the plant for sample tracking, testing, and Certificate of Analysis generation.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingExecutionSystem rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Execution System' ;
    rdfs:comment 'Name and version of the Manufacturing Execution System used at the plant for batch execution, electronic batch records, and production tracking.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Anticipated or scheduled date for the next regulatory inspection based on inspection frequency requirements and risk classification.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Full business name of the plant facility as registered with regulatory authorities and used in official documentation.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantType rdf:type rdf:Property ;
    rdfs:label 'Plant Type' ;
    rdfs:comment 'Classification of the plant facility based on its primary operational function within the pharmaceutical enterprise.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sap Plant Code' ;
    rdfs:comment 'Four-character plant code used in SAP S/4HANA ERP system for materials management, production planning, and financial controlling.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisPeriod rdf:type rdf:Property ;
    rdfs:label 'Analysis Period' ;
    rdfs:comment 'The fiscal period for which this profit center configuration is effective, in YYYYMM format. Supports period-specific profit center assignments and reorganizations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group' ;
    rdfs:comment 'The cost center group or range associated with this profit center. Links profit center to underlying cost centers for cost allocation and variance analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The department or organizational unit code associated with this profit center. Links profit center to the organizational hierarchy for reporting and governance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dummyProfitCenterFlag rdf:type rdf:Property ;
    rdfs:label 'Dummy Profit Center Flag' ;
    rdfs:comment 'Indicates whether this is a dummy or placeholder profit center used for technical postings, system balancing, or temporary allocations. True if dummy, False if operational.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node' ;
    rdfs:comment 'The node identifier in the profit center standard hierarchy. Enables roll-up reporting and aggregation of P&L across organizational structures (e.g., by therapeutic area, geography, or product line).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'The product line or portfolio grouping associated with this profit center. May represent a brand family, drug class, or commercial franchise.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The full business name or description of the profit center. Human-readable label used in financial reports and management dashboards.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'The current lifecycle status of the profit center. Active profit centers are operational and accept postings. Planned profit centers are set up but not yet operational. Closed profit centers are historical and no longer accept postings.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'The classification type of the profit center indicating its primary business function. Operating profit centers generate revenue; support and corporate profit centers provide shared services.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'The segment classification for external segment reporting per IFRS 8 and US GAAP. Typically represents therapeutic area (oncology, immunology, rare diseases), product line, or geographic market.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityStorageUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Storage Units' ;
    rdfs:comment 'Maximum storage capacity of this location measured in storage units (pallets, bins, cubic meters, or location-specific unit). Used for warehouse space planning and inventory optimization.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deaLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Dea License Number' ;
    rdfs:comment 'DEA registration number for storage locations authorized to hold controlled substances (Schedule II-V). Format: 2 letters + 7 digits. Required for controlled substance accountability and regulatory inspections. Null for non-controlled substance storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deaScheduleAuthorized rdf:type rdf:Property ;
    rdfs:label 'Dea Schedule Authorized' ;
    rdfs:comment 'Highest DEA controlled substance schedule this storage location is authorized to hold. Schedule II requires vault-level security. Not applicable for non-controlled substance storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdp Compliant Flag' ;
    rdfs:comment 'Indicates whether this storage location meets GDP requirements for pharmaceutical distribution. True for qualified distribution centers with temperature mapping, security, and traceability controls. False for non-GDP locations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpZoneClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Zone Classification' ;
    rdfs:comment 'Cleanroom classification per EU GMP Annex 1 or ISO 14644. Grade A for aseptic processing, Grade D for general manufacturing. Unclassified for non-GMP warehouses. Drives gowning, environmental monitoring, and personnel flow requirements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatStorageClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Storage Class' ;
    rdfs:comment 'Classification of hazardous materials authorized for storage per OSHA and DOT regulations. Determines segregation requirements, fire suppression systems, and emergency response protocols. Non-hazardous for general storage.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Max Percent' ;
    rdfs:comment 'Maximum allowable relative humidity percentage for this storage location. Excursions may impact product stability and require OOT investigation. Null if humidity control is not required.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityMinPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Min Percent' ;
    rdfs:comment 'Minimum allowable relative humidity percentage for this storage location. Required for hygroscopic API and moisture-sensitive drug products. Null if humidity control is not required.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Date' ;
    rdfs:comment 'Date of the most recent qualification or requalification of this storage location per CSV and GMP requirements. Includes temperature mapping, humidity validation, and security system testing. Drives requalification scheduling.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Zone Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated as a quarantine zone for materials pending QC release, under investigation, or rejected. True for quarantine areas, false for released goods storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnsProcessingFlag rdf:type rdf:Property ;
    rdfs:label 'Returns Processing Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated for processing returned goods, including customer returns, expired products, and recalls. True for returns processing areas requiring segregation and disposition workflows.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingLocationFlag rdf:type rdf:Property ;
    rdfs:label 'Sampling Location Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated for QC sampling activities. True for sampling areas where materials are temporarily held for sample collection per sampling plans.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Physical security classification for this storage location. High for DEA vaults and high-value products requiring 24/7 surveillance, access control, and intrusion detection. Medium for controlled access areas. Standard for general warehouses.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Segregation Required Flag' ;
    rdfs:comment 'Indicates whether materials in this storage location must be physically segregated from other materials due to cross-contamination risk, regulatory requirements, or product incompatibility. True for quarantine zones, controlled substances, and hazmat.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Business identifier for the storage location. Alphanumeric code used across SAP WM, LIMS, and MES systems for warehouse management and batch traceability. Typically 4-10 characters.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationName rdf:type rdf:Property ;
    rdfs:label 'Storage Location Name' ;
    rdfs:comment 'Human-readable name of the storage location. Examples: Cold Room 2-8C Building A, DEA Vault Schedule II, Quarantine Zone QC Lab 3, Hazmat Storage Flammables.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Storage Location Status' ;
    rdfs:comment 'Current operational status of the storage location. Blocked status prevents goods movements pending CAPA resolution or requalification. Under qualification indicates validation in progress per CSV requirements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Classification of the storage location by functional purpose. Determines applicable GMP, GDP, and DEA controls. Critical for regulatory inspection readiness and batch traceability. [ENUM-REF-CANDIDATE: warehouse|cold_room|freezer|controlled_substance_vault|quarantine_zone|qc_sampling_area|returns_processing|hazmat_storage|bulk_storage|finished_goods|raw_material|packaging_material|work_in_process — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowable temperature for this storage location in degrees Celsius. Excursions beyond this threshold trigger deviation investigations and potential batch impact assessments.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum allowable temperature for this storage location in degrees Celsius. Critical for cold-chain integrity and stability compliance. Examples: 2.0 for refrigerated, -25.0 for freezer, -85.0 for ultra-low freezer.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMonitoringSystem rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitoring System' ;
    rdfs:comment 'Type of temperature monitoring system deployed at this storage location. Continuous automated systems provide real-time alerts for excursions. Periodic manual monitoring uses data loggers with batch review. Not monitored for ambient storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Wms Integration Flag' ;
    rdfs:comment 'Indicates whether this storage location is integrated with a WMS for automated goods movements, bin management, and real-time inventory tracking. True for WMS-managed locations, false for manual locations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemCrosswalkId rdf:type rdf:Property ;
    rdfs:label 'System Crosswalk Id' ;
    rdfs:comment 'Unique identifier for the system crosswalk mapping record. Primary key for the cross-system identifier mapping table.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mappingRuleId rdf:type rdf:Property ;
    rdfs:label 'Mapping Rule Id' ;
    rdfs:comment 'Reference to the business rule or transformation logic used to establish this identifier mapping. Links to MDM governance documentation and mapping specifications.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MappingRule .

ind:mergerAcquisitionEventId rdf:type rdf:Property ;
    rdfs:label 'Merger Acquisition Event Id' ;
    rdfs:comment 'Reference to the specific merger, acquisition, or divestiture event that triggered the creation of this identifier mapping. Null for mappings created during normal operations.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MergerAcquisitionEvent .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Numeric score (0.00 to 100.00) representing the confidence level in the accuracy of this identifier mapping. Higher scores indicate greater certainty in the mapping relationship. Used for data quality management and reconciliation prioritization.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goldenRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Golden Record Flag' ;
    rdfs:comment 'Indicates whether this mapping represents the authoritative Master Data Management (MDM) golden record relationship for this entity. True for the primary system-of-record mapping.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Regulated Flag' ;
    rdfs:comment 'Indicates whether this identifier mapping is subject to Good Manufacturing Practice (GMP), Good Clinical Practice (GCP), or Good Laboratory Practice (GLP) regulatory requirements. True for mappings involving regulated master data.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Timestamp' ;
    rdfs:comment 'Timestamp of the most recent reconciliation process that validated this identifier mapping against source and target systems. Used for audit trail and data quality monitoring.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mappingDirection rdf:type rdf:Property ;
    rdfs:label 'Mapping Direction' ;
    rdfs:comment 'Indicates whether the mapping is unidirectional (source to target only) or bidirectional (can be used in both directions for identifier resolution).' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingMethod rdf:type rdf:Property ;
    rdfs:label 'Mapping Method' ;
    rdfs:comment 'Method by which the identifier mapping was established. Manual indicates data steward creation; automated indicates system-generated; ML-derived indicates machine learning algorithm output.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergerAcquisitionFlag rdf:type rdf:Property ;
    rdfs:label 'Merger Acquisition Flag' ;
    rdfs:comment 'Indicates whether this identifier mapping was created as part of a merger, acquisition, or divestiture data harmonization effort. True for M&A-related mappings requiring special governance.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceEntityDescription rdf:type rdf:Property ;
    rdfs:label 'Source Entity Description' ;
    rdfs:comment 'Human-readable description or name of the entity as it appears in the source system. Aids in manual validation and troubleshooting of identifier mappings.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source Identifier' ;
    rdfs:comment 'The identifier value as it exists in the source system. This is the original identifier that needs to be mapped to the target system.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemInstance rdf:type rdf:Property ;
    rdfs:label 'Source System Instance' ;
    rdfs:comment 'Specific instance or environment of the source system (e.g., production, quality assurance, development). Important for multi-instance SAP S/4HANA or Veeva Vault deployments.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEntityDescription rdf:type rdf:Property ;
    rdfs:label 'Target Entity Description' ;
    rdfs:comment 'Human-readable description or name of the entity as it appears in the target system. Aids in manual validation and troubleshooting of identifier mappings.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetIdentifier rdf:type rdf:Property ;
    rdfs:label 'Target Identifier' ;
    rdfs:comment 'The corresponding identifier value in the target system. This is the mapped identifier that the source identifier resolves to.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSystemCode rdf:type rdf:Property ;
    rdfs:label 'Target System Code' ;
    rdfs:comment 'Code identifying the target system to which the identifier is mapped. Examples: SAP_S4, VEEVA_VAULT, LIMS_LABWARE, ARGUS, MEDIDATA, MES, VEEVA_CRM.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSystemInstance rdf:type rdf:Property ;
    rdfs:label 'Target System Instance' ;
    rdfs:comment 'Specific instance or environment of the target system (e.g., production, quality assurance, development). Important for multi-instance SAP S/4HANA or Veeva Vault deployments.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Timestamp when this identifier mapping was last validated or approved by a data steward. Critical for regulatory compliance and data quality assurance.' ;
    rdfs:domain ind:SystemCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicableMaterialTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Material Types' ;
    rdfs:comment 'Comma-separated list of SAP material types or substance categories for which this UOM is applicable. Examples: API (Active Pharmaceutical Ingredient), DS (Drug Substance), DP (Drug Product), FDF (Finished Dosage Form), excipient, raw material, packaging material. Guides UOM selection during material master creation and transaction processing.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionGroup rdf:type rdf:Property ;
    rdfs:label 'Conversion Group' ;
    rdfs:comment 'Logical grouping of UOMs that can be converted among each other. UOMs within the same conversion group share a common dimension and can be mathematically converted (e.g., mass group: mg, g, kg; volume group: mL, L). Used to enforce conversion rules and prevent invalid cross-dimensional conversions.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decimalPrecision rdf:type rdf:Property ;
    rdfs:label 'Decimal Precision' ;
    rdfs:comment 'Number of decimal places typically used when recording measurements in this unit. Guides data entry validation and reporting formats. Example: 3 for milligrams (0.001), 6 for micrograms (0.000001), 0 for tablets (whole units).' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dimensionType rdf:type rdf:Property ;
    rdfs:label 'Dimension Type' ;
    rdfs:comment 'The fundamental physical dimension represented by this unit of measure per dimensional analysis. Aligns with SI base quantities and derived quantities. Used for dimensional consistency validation in formulation calculations and process parameter specifications. [ENUM-REF-CANDIDATE: length|mass|time|temperature|amount_of_substance|electric_current|luminous_intensity|area|volume|velocity|acceleration|force|pressure|energy|power|frequency|dimensionless — 17 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseUom rdf:type rdf:Property ;
    rdfs:label 'Is Base Uom' ;
    rdfs:comment 'Indicates whether this UOM is the base unit for its material or substance in SAP Material Master. Base UOMs serve as the reference for all alternative UOM conversions within a material. True if base UOM, False otherwise.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCommercialUom rdf:type rdf:Property ;
    rdfs:label 'Is Commercial Uom' ;
    rdfs:comment 'Indicates whether this UOM is used for commercial transactions, sales orders, and distribution (SAP SD module). Commercial UOMs may differ from manufacturing or laboratory UOMs. True if used in commercial contexts, False otherwise.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLaboratoryUom rdf:type rdf:Property ;
    rdfs:label 'Is Laboratory Uom' ;
    rdfs:comment 'Indicates whether this UOM is used in laboratory testing, quality control, and LIMS (Laboratory Information Management System). Laboratory UOMs support analytical testing, stability studies, and Certificate of Analysis (CoA) reporting. True if used in laboratory contexts, False otherwise.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManufacturingUom rdf:type rdf:Property ;
    rdfs:label 'Is Manufacturing Uom' ;
    rdfs:comment 'Indicates whether this UOM is used in manufacturing operations, batch production, and MES (Manufacturing Execution System). Manufacturing UOMs align with production planning (PP) and shop floor data collection. True if used in manufacturing, False otherwise.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoUnitCode rdf:type rdf:Property ;
    rdfs:label 'Iso Unit Code' ;
    rdfs:comment 'Standardized unit code per ISO 80000 and UN/CEFACT Recommendation 20. Enables interoperability across international regulatory submissions (eCTD) and supply chain systems. Examples: GRM (gram), KGM (kilogram), MLT (milliliter), LTR (liter).' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdmApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Mdm Approval Status' ;
    rdfs:comment 'Approval workflow status for this unit of measure within the MDM governance process. Draft records are under construction; pending_review records await data steward approval; approved records are released for operational use; rejected records require rework. Enforces data quality gates before UOM activation.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'Citation of the regulatory or pharmacopeial standard that defines or governs the use of this unit of measure. Examples: USP <1> Injections, Ph. Eur. 2.9.40 Uniformity of Dosage Units, FDA 21 CFR Part 210 Current Good Manufacturing Practice, ICH Q6A Specifications. Supports compliance traceability for regulatory submissions (IND, NDA, BLA, MAA).' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapInternalUom rdf:type rdf:Property ;
    rdfs:label 'Sap Internal Uom' ;
    rdfs:comment 'SAP S/4HANA internal unit of measure code used in Material Master (MM), Production Planning (PP), Quality Management (QM), and Warehouse Management (WM) modules. Maps external UOM codes to SAP-specific representations for ERP transaction processing.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Si Conversion Factor' ;
    rdfs:comment 'Numeric multiplier to convert this UOM to its SI base unit. Enables automated unit conversion across systems. Example: for milligram to kilogram, factor is 0.000001; for milliliter to liter, factor is 0.001. Null for dimensionless units.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasureStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure Status' ;
    rdfs:comment 'Current lifecycle status of the unit of measure in the master data repository. Active UOMs are available for use in transactions; inactive UOMs are retained for historical data but not selectable for new entries; deprecated UOMs are phased out per regulatory or business changes; pending_approval UOMs await MDM governance review before activation.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCategory rdf:type rdf:Property ;
    rdfs:label 'Uom Category' ;
    rdfs:comment 'Classification of the unit of measure by measurement type. Segments UOMs into functional categories for pharmaceutical operations: mass (mg, g, kg), volume (mL, L), concentration (mg/mL, %w/v), potency (IU, mcg), packaging (vial, ampoule, blister, tablet, capsule), analytical (ppm, ppb, CFU/mL), time (hour, day), temperature (Celsius, Fahrenheit), pressure (bar, psi), count (each, piece). [ENUM-REF-CANDIDATE: mass|volume|concentration|potency|packaging|analytical|time|temperature|pressure|count — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'Short alphanumeric code representing the unit of measure. Used as the business identifier across SAP S/4HANA, LIMS, and MES systems. Examples: MG, G, KG, ML, L, IU, MCG, PPM, PPB, CFU.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomDescription rdf:type rdf:Property ;
    rdfs:label 'Uom Description' ;
    rdfs:comment 'Full descriptive name of the unit of measure. Provides human-readable explanation of the UOM code. Examples: Milligram, Gram, Kilogram, Milliliter, Liter, International Unit, Microgram, Parts Per Million, Parts Per Billion, Colony Forming Unit per Milliliter.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalAffairsLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Medical Affairs Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Congress events require medical affairs lead for strategic planning, budget management, KOL engagement coordination, and post-congress follow-up. FK enables resource allocation, performance tracking, ' ;
    rdfs:domain ind:Medical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abstractSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Abstract Submission Deadline' ;
    rdfs:comment 'Final date by which abstracts must be submitted to the congress organizer for consideration. Critical milestone for publication planning and scientific communication timelines.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Actual total expenditure incurred for company participation at this congress, expressed in US Dollars (USD). Compared against planned_budget_usd for variance analysis and financial reporting.' ;
    rdfs:domain ind:Medical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyParticipationType rdf:type rdf:Property ;
    rdfs:label 'Company Participation Type' ;
    rdfs:comment 'Primary mode of company participation at the congress. Determines the nature of company presence and associated compliance obligations. [ENUM-REF-CANDIDATE: sponsor|exhibitor|presenter|attendee_only|satellite_symposium|none — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressAcronym rdf:type rdf:Property ;
    rdfs:label 'Congress Acronym' ;
    rdfs:comment 'Widely recognized abbreviation or acronym for the congress (e.g., \'ASCO\', \'EHA\', \'ASH\', \'ESMO\'). Used for reporting, tagging, and search.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressFormat rdf:type rdf:Property ;
    rdfs:label 'Congress Format' ;
    rdfs:comment 'Delivery format of the congress indicating whether attendance is physical, fully virtual, or a combination of both. Impacts logistics planning and MSL deployment.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressStatus rdf:type rdf:Property ;
    rdfs:label 'Congress Status' ;
    rdfs:comment 'Current lifecycle status of the congress event record. Drives planning workflows, resource commitments, and post-congress follow-up actions.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressType rdf:type rdf:Property ;
    rdfs:label 'Congress Type' ;
    rdfs:comment 'Classification of the congress by geographic scope and format. Drives resource allocation and strategic prioritization decisions. [ENUM-REF-CANDIDATE: international|national|regional|local|virtual|hybrid — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Congress Website Url' ;
    rdfs:comment 'Official URL of the congress website. Used for reference, abstract submission access, and registration links.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyRegistrationDeadline rdf:type rdf:Property ;
    rdfs:label 'Early Registration Deadline' ;
    rdfs:comment 'Deadline for early-bird registration, typically associated with reduced registration fees. Used for budget planning and attendee management.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:editionYear rdf:type rdf:Property ;
    rdfs:label 'Edition Year' ;
    rdfs:comment 'Calendar year of this specific edition of the congress (e.g., 2024). Enables year-over-year comparison of company participation and scientific output.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTotalAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Attendee Count' ;
    rdfs:comment 'Estimated total number of delegates attending the congress as reported by the organizer. Indicates congress scale and reach for strategic prioritization.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featuredCompoundList rdf:type rdf:Property ;
    rdfs:label 'Featured Compound List' ;
    rdfs:comment 'Comma-separated list of company compounds, drug substances (DS), or drug products (DP) featured in presentations or activities at this congress (e.g., INN or internal compound codes). Enables portfolio-level congress coverage analysis.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasBoothPresence rdf:type rdf:Property ;
    rdfs:label 'Has Booth Presence' ;
    rdfs:comment 'Indicates whether the company has a physical or virtual exhibition booth at the congress. Drives booth logistics, staffing, and material preparation workflows.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasSatelliteSymposium rdf:type rdf:Property ;
    rdfs:label 'Has Satellite Symposium' ;
    rdfs:comment 'Indicates whether the company is organizing or co-sponsoring a satellite symposium or industry-sponsored session at the congress. Triggers additional compliance and medical review requirements.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcpTransferOfValueUsd rdf:type rdf:Property ;
    rdfs:label 'Hcp Transfer Of Value Usd' ;
    rdfs:comment 'Total monetary value of transfers of value to Healthcare Professionals (HCPs) associated with this congress (e.g., speaker fees, travel reimbursements, registration fees paid on behalf of HCPs). Required for EFPIA, Sunshine Act, and country-specific HCP disclosure reporting.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heorRweActivitiesCount rdf:type rdf:Property ;
    rdfs:label 'Heor Rwe Activities Count' ;
    rdfs:comment 'Number of Health Economics and Outcomes Research (HEOR) or Real-World Evidence (RWE) presentations, posters, or engagements conducted at the congress. Tracks HEOR/RWE scientific communication output.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iitIssDiscussionsCount rdf:type rdf:Property ;
    rdfs:label 'Iit Iss Discussions Count' ;
    rdfs:comment 'Number of Investigator-Initiated Trial (IIT) or Investigator-Sponsored Study (ISS) discussions initiated or advanced during the congress. Tracks pipeline of externally-sponsored research opportunities.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kolEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Count' ;
    rdfs:comment 'Number of Key Opinion Leader (KOL) interactions or engagements conducted by company representatives during the congress. Key metric for KOL relationship management and medical affairs effectiveness.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oralPresentationCount rdf:type rdf:Property ;
    rdfs:label 'Oral Presentation Count' ;
    rdfs:comment 'Number of oral presentations featuring company-sponsored data or company-affiliated authors accepted and delivered at the congress. Key metric for scientific communication output tracking.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organizerName rdf:type rdf:Property ;
    rdfs:label 'Organizer Name' ;
    rdfs:comment 'Name of the professional society, association, or body that organizes and owns the congress (e.g., \'American Society of Clinical Oncology\', \'European Society for Medical Oncology\').' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Planned Budget Usd' ;
    rdfs:comment 'Total planned budget allocated for company participation at this congress, expressed in US Dollars (USD). Includes booth costs, sponsorship fees, satellite symposium costs, travel, and logistics. Used for financial planning and P&L tracking.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postCongressFollowupDueDate rdf:type rdf:Property ;
    rdfs:label 'Post Congress Followup Due Date' ;
    rdfs:comment 'Target date by which post-congress follow-up actions (e.g., MSL follow-up calls, medical information responses, publication submissions) must be completed. Drives post-congress activity management.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postCongressFollowupStatus rdf:type rdf:Property ;
    rdfs:label 'Post Congress Followup Status' ;
    rdfs:comment 'Current completion status of post-congress follow-up activities. Used to track medical affairs accountability and ensure timely scientific communication and KOL engagement after the event.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posterPresentationCount rdf:type rdf:Property ;
    rdfs:label 'Poster Presentation Count' ;
    rdfs:comment 'Number of poster presentations featuring company-sponsored data or company-affiliated authors accepted and displayed at the congress. Tracks scientific communication breadth.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategicImportanceTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance Tier' ;
    rdfs:comment 'Company-assigned strategic priority tier for this congress. Tier 1 = highest priority flagship congresses requiring maximum resource investment; Tier 2 = important regional or specialty congresses; Tier 3 = lower priority or monitoring-only congresses.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCompanyAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Total Company Attendee Count' ;
    rdfs:comment 'Total number of company employees (including MSLs, medical directors, commercial staff) attending the congress. Supports headcount planning and HCP engagement compliance reporting.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veevaMedcommsEventCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Medcomms Event Code' ;
    rdfs:comment 'External identifier assigned to this congress event within Veeva Vault MedComms, used for cross-system traceability and reconciliation with the source system of record.' ;
    rdfs:domain ind:CongressEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressingContentId rdf:type rdf:Property ;
    rdfs:label 'Addressing Content Id' ;
    rdfs:comment 'Foreign key linking to medical.content. Business justification: Evidence gaps drive content creation. Once a gap is addressed through development of new content assets (e.g., data summaries, scientific platforms), the gap record should reference the content that a' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Content .

ind:iitSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Iit Submission Id' ;
    rdfs:comment 'Foreign key linking to medical.iit_submission. Business justification: Evidence gaps may be addressed by Investigator-Initiated Trials. evidence_gap has proposed_study_type and may link to the actual IIT that addresses the gap. Adding iit_submission_id FK (nullable, popu' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IitSubmission .

ind:linkedStudyMedicalHeorStudyId rdf:type rdf:Property ;
    rdfs:label 'Linked Study Medical Heor Study Id' ;
    rdfs:comment 'Reference to the study or evidence generation activity (IIT, ISS, RWE study, HEOR model) that has been initiated or planned to address this evidence gap. Populated once a study is formally assigned.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalHeorStudy .

ind:medicalAdvisoryBoardId rdf:type rdf:Property ;
    rdfs:label 'Medical Advisory Board Id' ;
    rdfs:comment 'Foreign key linking to medical.medical_advisory_board. Business justification: Evidence gaps are often identified or prioritized by medical advisory boards. evidence_gap currently has advisory_board_reference as STRING. Normalizing to FK to medical_advisory_board.medical_advisor' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalAdvisoryBoard .

ind:recordOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Record Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Evidence gap management requires designated owner for gap resolution tracking, study prioritization, cross-functional coordination, and regulatory commitment fulfillment. FK enables accountability for' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'The date on which the evidence gap was formally closed or addressed, confirmed by availability of study results, publication, or regulatory/payer acceptance of the generated evidence.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:comparator rdf:type rdf:Property ;
    rdfs:label 'Comparator' ;
    rdfs:comment 'The comparator treatment, standard of care, or active control against which evidence is lacking (e.g., pembrolizumab, best supportive care, placebo). Relevant for gaps requiring head-to-head or comparative effectiveness evidence.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundCode rdf:type rdf:Property ;
    rdfs:label 'Compound Code' ;
    rdfs:comment 'Internal compound or molecule identifier (e.g., development code, INN, or USAN) for the drug substance or biologic to which this evidence gap is associated. Links to the compound master record.' ;
    rdfs:domain ind:Medical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossFunctionalImpact rdf:type rdf:Property ;
    rdfs:label 'Cross Functional Impact' ;
    rdfs:comment 'Indicates which business functions beyond medical affairs are impacted by this evidence gap. Drives cross-functional alignment and resource commitment in integrated evidence planning.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Budget Usd' ;
    rdfs:comment 'Estimated budget in US dollars required to fund the study or evidence generation activity proposed to address this gap. Used for HEOR/RWE portfolio budgeting and resource allocation within medical affairs.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Resolution Date' ;
    rdfs:comment 'Target date by which the evidence gap is expected to be addressed through completion of the proposed study or evidence generation activity. Used for integrated evidence planning and milestone tracking.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceMaturityLevel rdf:type rdf:Property ;
    rdfs:label 'Evidence Maturity Level' ;
    rdfs:comment 'Assessment of the current state of available evidence for this gap: no_evidence (complete absence), limited_evidence (sparse or low-quality data), emerging_evidence (early signals from small studies), established_evidence (sufficient but not definitive). Drives prioritisation decisions.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feasibilityScore rdf:type rdf:Property ;
    rdfs:label 'Feasibility Score' ;
    rdfs:comment 'Numeric score (1–10) reflecting the operational and scientific feasibility of conducting a study to address this gap, considering patient availability, site infrastructure, data availability (RWD), and budget. Higher scores indicate greater feasibility.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gapCode rdf:type rdf:Property ;
    rdfs:label 'Gap Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the evidence gap, used in integrated evidence plans, advisory board materials, and cross-functional communications. Format: EG-{TA_CODE}-{SEQUENCE}.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapDescription rdf:type rdf:Property ;
    rdfs:label 'Gap Description' ;
    rdfs:comment 'Detailed narrative describing the specific knowledge deficit, including the scientific question that remains unanswered, the patient population affected, and the clinical or health-economic context.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapSource rdf:type rdf:Property ;
    rdfs:label 'Gap Source' ;
    rdfs:comment 'The origin or trigger that led to identification of this evidence gap. Payer feedback indicates reimbursement-driven gaps; regulatory_request indicates FDA/EMA post-marketing commitments; publication_gap_analysis indicates systematic literature review findings. [ENUM-REF-CANDIDATE: payer_feedback|regulatory_request|publication_gap_analysis|advisory_board_insight|hcp_feedback|internal_review|competitive_intelligence — promote to reference product]' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapStatus rdf:type rdf:Property ;
    rdfs:label 'Gap Status' ;
    rdfs:comment 'Current lifecycle state of the evidence gap record, tracking progression from initial identification through study execution to resolution or closure. [ENUM-REF-CANDIDATE: identified|under_review|study_planned|study_ongoing|addressed|closed|deprioritised — promote to reference product]' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapTitle rdf:type rdf:Property ;
    rdfs:label 'Gap Title' ;
    rdfs:comment 'Short, human-readable title summarising the evidence gap, used in dashboards, integrated evidence plans, and stakeholder presentations.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapType rdf:type rdf:Property ;
    rdfs:label 'Gap Type' ;
    rdfs:comment 'Classification of the nature of the evidence gap: clinical_efficacy (unmet proof of benefit), clinical_safety (uncharacterised risk), health_economic (HEOR/cost-effectiveness), real_world_effectiveness (RWE/RWD gap), mechanistic_biomarker (MOA/biomarker gap), patient_reported_outcomes (PRO/QoL gap).' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyScope rdf:type rdf:Property ;
    rdfs:label 'Geography Scope' ;
    rdfs:comment 'The geographic region or country scope for which the evidence gap is relevant (e.g., USA, EU5, JPN, global). Uses ISO 3166-1 alpha-3 country codes or regional designations aligned with regulatory and market access strategy.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iepReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Iep Reference Code' ;
    rdfs:comment 'Reference code linking this evidence gap to the formal Integrated Evidence Plan (IEP) document for the compound or therapeutic area. Enables traceability between individual gaps and the overarching evidence strategy.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kol Identified Flag' ;
    rdfs:comment 'Indicates whether a Key Opinion Leader (KOL) or external scientific expert has been identified to support the evidence generation activity addressing this gap. True = KOL identified and engaged.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Payer Relevance Flag' ;
    rdfs:comment 'Indicates whether this evidence gap has been identified as relevant to payer or health technology assessment (HTA) decision-making, reimbursement negotiations, or formulary access. True = payer/HTA relevance confirmed.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Prioritisation tier assigned by the medical affairs function reflecting urgency, strategic importance, and resource allocation. Critical gaps typically block regulatory submissions or payer negotiations; high gaps affect label expansions or market access.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedStudyType rdf:type rdf:Property ;
    rdfs:label 'Proposed Study Type' ;
    rdfs:comment 'The type of study or evidence generation activity proposed to address this gap. RCT (Randomised Controlled Trial), observational, RWE/RWD study, IIT (Investigator-Initiated Trial), ISS (Investigator-Sponsored Study), HEOR model, systematic review, registry, or biomarker study. [ENUM-REF-CANDIDATE: rct|observational|rwe_rwd|iit|iss|heor_model|systematic_review|registry|biomarker_study — promote to reference product]' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Commitment Flag' ;
    rdfs:comment 'Indicates whether this evidence gap is associated with a formal post-marketing commitment or post-marketing requirement issued by a regulatory authority (FDA, EMA, MHRA, PMDA). True = formal regulatory commitment exists.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicImportanceScore rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance Score' ;
    rdfs:comment 'Numeric score (1–10) assigned during integrated evidence planning to reflect the strategic importance of addressing this gap relative to the compound\'s lifecycle, competitive landscape, and market access objectives. Higher scores indicate greater strategic value.' ;
    rdfs:domain ind:EvidenceGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCommitteeId rdf:type rdf:Property ;
    rdfs:label 'Review Committee Id' ;
    rdfs:comment 'Reference to the internal medical affairs review committee responsible for evaluating and rendering a decision on the IIT/ISS submission.' ;
    rdfs:domain ind:Medical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewCommittee .

ind:supplyBatchRecordId rdf:type rdf:Property ;
    rdfs:label 'Supply Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.batch_record. Business justification: Investigator-initiated trials require full traceability of supplied investigational product to manufacturing batch for GMP compliance, safety reporting (ICSRs), product complaints, and regulatory insp' ;
    rdfs:domain ind:Medical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:actualStudyEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual Study End Date' ;
    rdfs:comment 'The actual date on which the IIT/ISS study completed data collection or last patient last visit. Populated at study closeout; used for financial reconciliation and reporting obligations.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStudyStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Study Start Date' ;
    rdfs:comment 'The actual date on which the IIT/ISS study commenced patient enrollment or data collection. Populated upon study activation; used for milestone tracking and timeline variance analysis.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeoutStatus rdf:type rdf:Property ;
    rdfs:label 'Closeout Status' ;
    rdfs:comment 'Current status of the IIT/ISS study closeout process, including financial reconciliation, final report receipt, and compound accountability. Distinct from submission_status which tracks the overall lifecycle.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundSupplyQuantity rdf:type rdf:Property ;
    rdfs:label 'Compound Supply Quantity' ;
    rdfs:comment 'The quantity of investigational compound requested by the investigator for the IIT/ISS study (expressed in the unit defined by compound_supply_unit). Null if compound_supply_requested is False.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compoundSupplyRequested rdf:type rdf:Property ;
    rdfs:label 'Compound Supply Requested' ;
    rdfs:comment 'Indicates whether the investigator has requested company-supplied investigational compound (drug product or drug substance) as part of the IIT/ISS submission, in addition to or instead of a monetary grant.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compoundSupplyUnit rdf:type rdf:Property ;
    rdfs:label 'Compound Supply Unit' ;
    rdfs:comment 'Unit of measure for the requested investigational compound supply quantity (e.g., vials, tablets, mg, g, kg, doses). Required when compound_supply_requested is True.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursed Amount' ;
    rdfs:comment 'The cumulative monetary amount actually disbursed to the investigator or institution to date against the approved grant. Used for financial tracking, budget variance, and reconciliation at closeout. Satisfies MONETARY_TRIPLET (net/actual amount) for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Medical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Due Date' ;
    rdfs:comment 'The contractually agreed date by which the investigator must submit the final study report to the company following study completion.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalReportReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Received Date' ;
    rdfs:comment 'The actual date on which the company received the final study report from the investigator. Used to track reporting compliance and trigger final grant disbursement milestones.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantAmount rdf:type rdf:Property ;
    rdfs:label 'Grant Amount' ;
    rdfs:comment 'The total monetary grant amount approved for the IIT/ISS study, representing the gross financial commitment by the company to fund the investigator\'s research. Satisfies MONETARY_TRIPLET (gross base amount) for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grantCurrency rdf:type rdf:Property ;
    rdfs:label 'Grant Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the approved grant amount (e.g., USD, EUR, GBP, JPY). Required for multi-currency financial reporting and reconciliation. Satisfies MONETARY_TRIPLET (currency code) for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStudyEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned Study End Date' ;
    rdfs:comment 'The anticipated date on which the IIT/ISS study is planned to complete data collection or last patient last visit, as proposed by the investigator.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStudyStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Study Start Date' ;
    rdfs:comment 'The anticipated date on which the IIT/ISS study is planned to begin patient enrollment or data collection, as proposed by the investigator.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationReviewPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Publication Review Period Days' ;
    rdfs:comment 'The number of calendar days the company is entitled to review manuscripts or abstracts prior to submission for publication, as agreed in the publication rights agreement.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationRightsAgreed rdf:type rdf:Property ;
    rdfs:label 'Publication Rights Agreed' ;
    rdfs:comment 'Indicates whether a publication rights agreement has been executed between the company and the investigator, governing the investigator\'s right to publish study results and the company\'s review period.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDecision rdf:type rdf:Property ;
    rdfs:label 'Review Decision' ;
    rdfs:comment 'The formal decision rendered by the internal IIT review committee on the submission (approved, conditionally approved, rejected, deferred for additional information, or withdrawn by investigator).' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Review Decision Date' ;
    rdfs:comment 'The date on which the internal review committee rendered its formal decision on the IIT/ISS submission.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Reporting Required' ;
    rdfs:comment 'Indicates whether the IIT/ISS agreement requires the investigator to report Serious Adverse Events (SAEs) and Suspected Unexpected Serious Adverse Reactions (SUSARs) to the company\'s pharmacovigilance (PV) team.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scientificRationale rdf:type rdf:Property ;
    rdfs:label 'Scientific Rationale' ;
    rdfs:comment 'Investigator-provided scientific justification for the proposed IIT/ISS study, including the hypothesis, mechanism of action (MOA) relevance, unmet medical need, and alignment with the compound\'s development program.' ;
    rdfs:domain ind:IitSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDesign rdf:type rdf:Property ;
    rdfs:label 'Study Design' ;
    rdfs:comment 'Narrative description of the study design including methodology (e.g., randomized controlled trial, single-arm, retrospective cohort, prospective observational), blinding, and control arms as proposed by the investigator.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medEducationProgramId rdf:type rdf:Property ;
    rdfs:label 'Med Education Program Id' ;
    rdfs:comment 'Unique surrogate identifier for the medical education program record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedEducationProgram .

ind:actualAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Actual Attendee Count' ;
    rdfs:comment 'Actual number of HCPs or attendees who participated in the program. Populated post-event. Compared against planned_attendee_count to measure program reach effectiveness.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Usd' ;
    rdfs:comment 'Total approved budget allocated for the medical education program in US Dollars, as sanctioned through the compliance and finance review process. Includes faculty fees, venue, materials, and logistics. Used for financial oversight and fair market value (FMV) compliance.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmeCreditsAwarded rdf:type rdf:Property ;
    rdfs:label 'Cme Credits Awarded' ;
    rdfs:comment 'Number of CME/CPD credits (AMA PRA Category 1 Credits or equivalent) that attendees can earn upon successful completion of the program. Zero for non-accredited programs.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'Mode of delivery for the educational program. in_person = live face-to-face event; virtual = live online webinar/webcast; hybrid = simultaneous in-person and virtual; enduring_material = on-demand recorded or written content; print = printed educational material.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facultyCount rdf:type rdf:Property ;
    rdfs:label 'Faculty Count' ;
    rdfs:comment 'Total number of faculty members (KOLs, speakers, moderators) engaged for the program. Used for fair market value (FMV) compliance calculations and speaker bureau management.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpEngagementTriggered rdf:type rdf:Property ;
    rdfs:label 'Follow Up Engagement Triggered' ;
    rdfs:comment 'Indicates whether the program triggered a follow-up engagement action (e.g., MSL visit, medical information request, IIT inquiry) with one or more attendees. True = follow-up triggered; False = no follow-up. Used to measure downstream HCP engagement conversion from medical education.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heorComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Heor Component Flag' ;
    rdfs:comment 'Indicates whether the program includes a Health Economics and Outcomes Research (HEOR) or Real-World Evidence (RWE) component. True = HEOR/RWE content included; False = no HEOR component. Used for HEOR program portfolio tracking.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iitIssLinked rdf:type rdf:Property ;
    rdfs:label 'Iit Iss Linked' ;
    rdfs:comment 'Indicates whether this program is associated with an Investigator-Initiated Trial (IIT) or Investigator-Sponsored Study (ISS). True = IIT/ISS linkage exists; False = no IIT/ISS linkage. Used for medical affairs portfolio integration and grant compliance tracking.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kolEngagementFlag rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Flag' ;
    rdfs:comment 'Indicates whether one or more Key Opinion Leaders (KOLs) are engaged as faculty or advisors for this program. True = KOL involvement; False = no KOL involvement. Drives KOL relationship management tracking and Sunshine Act reporting obligations.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningAffiliateCode rdf:type rdf:Property ;
    rdfs:label 'Owning Affiliate Code' ;
    rdfs:comment 'Code identifying the company affiliate or business unit responsible for organizing and funding the program (e.g., US Medical Affairs, EU Medical Affairs). Used for cross-affiliate reporting and budget attribution.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Planned Attendee Count' ;
    rdfs:comment 'Target number of HCPs or attendees planned for the program at the time of program design. Used for budget planning, venue capacity management, and post-event reach measurement against target.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postProgramSurveyFlag rdf:type rdf:Property ;
    rdfs:label 'Post Program Survey Flag' ;
    rdfs:comment 'Indicates whether a post-program survey was administered to attendees to capture educational impact, knowledge gain, and satisfaction. True = survey administered; False = no survey. Drives CME outcome measurement and program effectiveness analytics.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationPlanLinked rdf:type rdf:Property ;
    rdfs:label 'Publication Plan Linked' ;
    rdfs:comment 'Indicates whether this program is linked to a formal publication plan (e.g., congress abstract, manuscript, poster). True = linked to publication plan; False = standalone program. Supports scientific communications portfolio management.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rweDataCollectionFlag rdf:type rdf:Property ;
    rdfs:label 'Rwe Data Collection Flag' ;
    rdfs:comment 'Indicates whether the program involves collection of Real-World Data (RWD) from attendees or participants for RWE generation purposes. True = RWD collected; False = no data collection. Triggers additional IRB/ethics review requirements.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyResponseRatePct rdf:type rdf:Property ;
    rdfs:label 'Survey Response Rate Pct' ;
    rdfs:comment 'Percentage of attendees who completed the post-program survey, calculated as (survey_responses_received / actual_attendee_count) × 100. Used to assess program engagement quality and survey methodology effectiveness.' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAudienceType rdf:type rdf:Property ;
    rdfs:label 'Target Audience Type' ;
    rdfs:comment 'Primary HCP or stakeholder audience segment for whom the program is designed. Drives faculty selection, content level, and accreditation requirements. [ENUM-REF-CANDIDATE: oncologist|hematologist|rheumatologist|neurologist|general_practitioner|pharmacist|nurse|payer|patient_advocate|mixed_hcp — promote to reference product]' ;
    rdfs:domain ind:MedEducationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaMedcommsCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Medcomms Code' ;
    rdfs:comment 'Source system record identifier from Veeva Vault MedComms for this program. Used for data lineage, cross-system reconciliation, and audit trail back to the system of record.' ;
    rdfs:domain ind:Medical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceConflictOfInterestId rdf:type rdf:Property ;
    rdfs:label 'Compliance Conflict Of Interest Id' ;
    rdfs:comment 'Foreign key linking to compliance.conflict_of_interest. Business justification: Medical advisory boards should link to compliance conflict of interest declarations for HCP participants. This enables integrated COI management and compliance oversight for medical affairs activities' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictOfInterest .

ind:primaryMedicalChairpersonHcpPhysicianMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Medical Chairperson Hcp Physician Master Id' ;
    rdfs:comment 'FK to hcp.hcp_master' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:annualBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Usd' ;
    rdfs:comment 'Total approved annual budget in USD allocated for the advisory board, covering honoraria, travel, venue, and operational costs. Used for financial planning and P&L reporting.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boardCode rdf:type rdf:Property ;
    rdfs:label 'Board Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the advisory board across systems, used in Veeva MedComms and transparency reporting submissions.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardStatus rdf:type rdf:Property ;
    rdfs:label 'Board Status' ;
    rdfs:comment 'Current lifecycle status of the advisory board, indicating whether it is actively convening, in planning, suspended, or formally dissolved.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Charter Document Ref' ;
    rdfs:comment 'Reference identifier or URL to the advisory board charter document stored in Veeva Vault MedComms, defining governance rules, scope, member obligations, and FMV compensation terms.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmvAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Fmv Assessment Date' ;
    rdfs:comment 'Date on which the independent FMV assessment was conducted to validate the honorarium rate, ensuring compliance with anti-kickback statutes and transparency regulations.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fmvAssessmentVendor rdf:type rdf:Property ;
    rdfs:label 'Fmv Assessment Vendor' ;
    rdfs:comment 'Name of the third-party vendor or internal function that conducted the FMV assessment for the advisory board honorarium rate.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmvCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fmv Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the FMV honorarium amount (e.g., USD, EUR, GBP), supporting multi-country advisory board operations.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmvHonorariumUsd rdf:type rdf:Property ;
    rdfs:label 'Fmv Honorarium Usd' ;
    rdfs:comment 'Approved Fair Market Value (FMV) honorarium rate in US dollars payable to advisory board members per meeting engagement, as determined by an independent FMV assessment. Required for Sunshine Act and transparency reporting compliance.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heorFocus rdf:type rdf:Property ;
    rdfs:label 'Heor Focus' ;
    rdfs:comment 'Indicates whether the advisory board has a specific Health Economics and Outcomes Research (HEOR) or Real-World Evidence (RWE) focus, distinguishing it from purely clinical or scientific boards.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iitIssOversight rdf:type rdf:Property ;
    rdfs:label 'Iit Iss Oversight' ;
    rdfs:comment 'Indicates whether this advisory board has a mandate to provide scientific oversight or recommendations for Investigator-Initiated Trials (IIT) or Investigator-Sponsored Studies (ISS).' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meetingCadence rdf:type rdf:Property ;
    rdfs:label 'Meeting Cadence' ;
    rdfs:comment 'Planned frequency at which the advisory board convenes, as defined in the board charter. Drives scheduling and budget planning.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Minutes Approval Required' ;
    rdfs:comment 'Indicates whether formal approval of meeting minutes by board members is required as part of the governance process for this advisory board.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryRegion rdf:type rdf:Property ;
    rdfs:label 'Primary Region' ;
    rdfs:comment 'Primary geographic region in which the advisory board operates (e.g., North America, Europe, Asia-Pacific), used for regional medical affairs reporting and budget allocation.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quorumThreshold rdf:type rdf:Property ;
    rdfs:label 'Quorum Threshold' ;
    rdfs:comment 'Minimum number of advisory board members required to be present at a meeting for official proceedings and decisions to be valid, as defined in the board charter.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scientificInsightsCaptured rdf:type rdf:Property ;
    rdfs:label 'Scientific Insights Captured' ;
    rdfs:comment 'Indicates whether a formal scientific insights capture process is in place for this advisory board, ensuring that expert input is systematically documented and fed back into medical strategy.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaMedcommsRecordCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Medcomms Record Code' ;
    rdfs:comment 'Unique record identifier from Veeva Vault MedComms that corresponds to this advisory board, enabling traceability between the lakehouse silver layer and the source system of record.' ;
    rdfs:domain ind:MedicalAdvisoryBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousVersionAffairsPlanId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Affairs Plan Id' ;
    rdfs:comment 'Reference to the medical_affairs_plan_id of the immediately preceding version of this plan, enabling version chain traceability and comparison of strategic evolution across planning cycles.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffairsPlan .

ind:primaryAffairsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Affairs Employee Id' ;
    rdfs:comment 'Identifier of the Medical Affairs leader (e.g., VP Medical Affairs, Therapeutic Area Medical Director) who is the accountable owner of this plan. References the employee or user master record.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryAffairsApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Affairs Approved By Employee Id' ;
    rdfs:comment 'Identifier of the individual (Medical Director, VP Medical Affairs, or governance committee chair) who granted final approval for this medical affairs plan. Supports 21 CFR Part 11 electronic signature audit trail.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:evidenceGenerationBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Evidence Generation Budget Usd' ;
    rdfs:comment 'Portion of the total medical affairs budget allocated specifically to evidence generation activities including RWE/RWD studies, IIT/ISS grants, registries, and HEOR research for the planning cycle.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceGenerationPriority rdf:type rdf:Property ;
    rdfs:label 'Evidence Generation Priority' ;
    rdfs:comment 'Description of the top-ranked evidence generation priorities for the planning cycle, including RWE/RWD studies, HEOR research, IIT/ISS programs, and registry participation. Informs publication planning and scientific communication strategy.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heorPriorityFlag rdf:type rdf:Property ;
    rdfs:label 'Heor Priority Flag' ;
    rdfs:comment 'Indicates whether Health Economics and Outcomes Research (HEOR) is designated as a strategic priority within this medical affairs plan, triggering dedicated budget allocation and resource planning for cost-effectiveness, burden-of-disease, and quality-of-life studies.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iitIssTargetCount rdf:type rdf:Property ;
    rdfs:label 'Iit Iss Target Count' ;
    rdfs:comment 'Planned number of Investigator-Initiated Trials (IIT) and Investigator-Sponsored Studies (ISS) to be supported or initiated during the planning cycle. Reflects the company\'s commitment to independent evidence generation.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kolEngagementBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Budget Usd' ;
    rdfs:comment 'Portion of the total medical affairs budget allocated to KOL engagement activities including advisory boards, scientific exchange meetings, speaker honoraria, and KOL relationship management programs.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kolEngagementTargetCount rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Target Count' ;
    rdfs:comment 'Planned number of Key Opinion Leader (KOL) engagements (advisory boards, scientific exchanges, speaker programs) targeted for the planning cycle. Used to track MSL deployment effectiveness and KOL relationship management goals.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:launchReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'Launch Readiness Flag' ;
    rdfs:comment 'Indicates whether this medical affairs plan includes a formal commercial launch readiness component, bridging clinical development and commercial operations. Triggers integration with the commercial launch readiness checklist and market access planning.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalEducationPlanIncluded rdf:type rdf:Property ;
    rdfs:label 'Medical Education Plan Included' ;
    rdfs:comment 'Indicates whether a formal medical education program plan (CME/CE activities, disease awareness initiatives, HCP training programs) is included within this medical affairs plan.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mslHeadcountTarget rdf:type rdf:Property ;
    rdfs:label 'Msl Headcount Target' ;
    rdfs:comment 'Planned number of Medical Science Liaisons (MSLs) to be deployed in support of this medical affairs plan during the planning cycle. Drives field force sizing and territory planning decisions.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningCycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle End Date' ;
    rdfs:comment 'The date on which the planning cycle covered by this medical affairs plan concludes. Nullable for open-ended or rolling plans.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningCycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle Start Date' ;
    rdfs:comment 'The date on which the planning cycle covered by this medical affairs plan becomes effective. Aligns with fiscal year or multi-year strategic planning horizon start.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productBrandName rdf:type rdf:Property ;
    rdfs:label 'Product Brand Name' ;
    rdfs:comment 'Approved commercial brand name of the drug product covered by this plan, if applicable. May be null for pre-approval compounds still in development phase.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Publication Budget Usd' ;
    rdfs:comment 'Portion of the total medical affairs budget allocated to publication planning activities including medical writing, journal submission fees, congress abstract and poster production, and publication agency fees.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationPlanIncluded rdf:type rdf:Property ;
    rdfs:label 'Publication Plan Included' ;
    rdfs:comment 'Indicates whether a formal publication plan (covering manuscripts, congress abstracts, posters, and oral presentations) is embedded within or formally linked to this medical affairs plan.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rweRwdStrategy rdf:type rdf:Property ;
    rdfs:label 'Rwe Rwd Strategy' ;
    rdfs:comment 'Description of the Real-World Evidence (RWE) and Real-World Data (RWD) generation strategy for the planning cycle, including data sources (registries, claims, EHR), study designs, and intended regulatory or market access use of evidence.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scientificPlatformVersion rdf:type rdf:Property ;
    rdfs:label 'Scientific Platform Version' ;
    rdfs:comment 'Version identifier of the scientific messaging platform (core scientific narrative, MOA messaging, clinical data summaries) that underpins this medical affairs plan. Ensures alignment between MSL field communications and approved scientific content.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicObjectiveSummary rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective Summary' ;
    rdfs:comment 'Narrative summary of the overarching medical affairs strategic objectives for the planning cycle, including evidence generation priorities, unmet medical need statements, and scientific platform goals. Classified confidential due to competitive sensitivity.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Total Budget Usd' ;
    rdfs:comment 'Total approved budget allocated to this medical affairs plan for the planning cycle, expressed in US Dollars. Encompasses all sub-categories including MSL operations, evidence generation, publications, KOL engagement, HEOR, and medical education.' ;
    rdfs:domain ind:Medical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veevaVaultDocNumber rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Doc Number' ;
    rdfs:comment 'External document identifier assigned by Veeva Vault MedComms to the source medical affairs plan document. Enables direct cross-reference and deep-link navigation to the authoritative document in the system of record.' ;
    rdfs:domain ind:AffairsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceMedicalPublicationId rdf:type rdf:Property ;
    rdfs:label 'Source Medical Publication Id' ;
    rdfs:comment 'Foreign key linking to medical.medical_publication. Business justification: Content assets are often derived from publications (e.g., publication reprints, data summaries from published studies). The content record should reference the source publication when applicable. This' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalPublication .

ind:approvedClaimsSummary rdf:type rdf:Property ;
    rdfs:label 'Approved Claims Summary' ;
    rdfs:comment 'Summary of the specific approved scientific and clinical claims contained in this content asset that have passed MLR review. Distinguishes on-label approved claims from investigational or off-label scientific information. Critical for compliance with FDA and EMA promotional and non-promotional communication regulations.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Classification of the content asset by its functional type within medical affairs. [ENUM-REF-CANDIDATE: standard_response_letter|medical_information_letter|slide_deck|scientific_dossier|disease_backgrounder|clinical_evidence_summary|scientific_communication_platform|publication|congress_abstract|medical_education_material|field_medical_tool — promote to reference product]' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'The file format or media type of the content asset as stored in Veeva MedComms Vault. Determines rendering and distribution capabilities for MSL field tools, medical information portals, and scientific communication platforms.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Evidence Level' ;
    rdfs:comment 'Classification of the highest level of clinical evidence supporting the key scientific messages in this content asset. Follows standard evidence hierarchy (e.g., Phase 3 RCT, Real-World Evidence (RWE), meta-analysis). Informs the strength of claims and appropriate use context. [ENUM-REF-CANDIDATE: phase_1|phase_2|phase_3|phase_4|rwe|meta_analysis|case_report|expert_opinion — promote to reference product]' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heorContentFlag rdf:type rdf:Property ;
    rdfs:label 'Heor Content Flag' ;
    rdfs:comment 'Indicates whether this content asset contains Health Economics and Outcomes Research (HEOR) data, health technology assessment (HTA) evidence, or pharmacoeconomic analyses. Governs applicability for payer and market access communications.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iitRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Iit Related Flag' ;
    rdfs:comment 'Indicates whether this content asset is associated with or derived from an Investigator-Initiated Trial (IIT) or Investigator-Sponsored Study (ISS). Relevant for tracking the scientific output and evidence generation from company-supported independent research.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyScientificMessages rdf:type rdf:Property ;
    rdfs:label 'Key Scientific Messages' ;
    rdfs:comment 'Structured summary of the core scientific messages and approved claims contained within this content asset. Represents the distilled scientific narrative that MSLs and medical information specialists are authorized to communicate. Stored as a structured text summary.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlrReviewDate rdf:type rdf:Property ;
    rdfs:label 'Mlr Review Date' ;
    rdfs:comment 'The date on which the Medical/Legal/Regulatory (MLR) review committee completed its review and rendered the mlr_review_outcome for this content asset version.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mlrReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Mlr Review Outcome' ;
    rdfs:comment 'The formal outcome of the Medical/Legal/Regulatory (MLR) review committee for this content asset. Captures the final disposition from the cross-functional review including medical, legal, and regulatory reviewers. Distinct from approval_status in that it records the committee decision rather than the workflow state.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onLabelFlag rdf:type rdf:Property ;
    rdfs:label 'On Label Flag' ;
    rdfs:comment 'Indicates whether the scientific content and claims in this asset are within the approved product labeling (on-label) as per the FDA-approved Prescribing Information or EMA Summary of Product Characteristics (SmPC). False indicates the content contains investigational or off-label scientific information subject to additional use restrictions.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentPlatformCode rdf:type rdf:Property ;
    rdfs:label 'Parent Platform Code' ;
    rdfs:comment 'Reference to the parent scientific communication platform or evidence-based messaging framework under which this content asset is organized. Supports the platform hierarchy (disease-level → compound-level → indication-level) for structured scientific narrative management.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformLevel rdf:type rdf:Property ;
    rdfs:label 'Platform Level' ;
    rdfs:comment 'Hierarchical level of the scientific communication platform (evidence-based messaging framework) to which this content belongs. Disease-level platforms define overarching disease narratives; compound-level platforms define compound-specific scientific stories; indication-level platforms define approved or investigational indication-specific messaging.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweContentFlag rdf:type rdf:Property ;
    rdfs:label 'Rwe Content Flag' ;
    rdfs:comment 'Indicates whether this content asset incorporates Real-World Evidence (RWE) or Real-World Data (RWD) from post-marketing studies, registries, electronic health records, or claims databases. Relevant for FDA RWE framework compliance and EMA real-world data guidance.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportingEvidenceReferences rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence References' ;
    rdfs:comment 'Bibliographic references and citations (e.g., clinical trial publications, regulatory documents, systematic reviews) that provide the evidentiary basis for the scientific claims in this content asset. Stored as a structured citation list or reference string.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Number' ;
    rdfs:comment 'External document identifier assigned by Veeva MedComms (Vault) as the system-of-record identifier for this content asset. Used for cross-system traceability and audit.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:croCmoEngagementId rdf:type rdf:Property ;
    rdfs:label 'Cro Cmo Engagement Id' ;
    rdfs:comment 'Foreign key linking to procurement.cro_cmo_engagement. Business justification: Medical grants may fund specific CRO/CMO service contracts for investigator-initiated trials, real-world evidence studies, or HEOR research. Real business process: Medical Affairs tracks which grants ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CroCmoEngagement .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the accrediting organization that has accredited or will accredit the educational activity funded by this grant (e.g., ACCME, EACCME, Royal College of Physicians). Applicable for IME grants; null for charitable donations and sponsorships.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementSignedDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Signed Date' ;
    rdfs:comment 'Date on which the grant agreement or letter of agreement was fully executed (signed by both parties). No disbursement may occur prior to this date per PhRMA Code requirements.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Calendar date on which the recipient organization formally submitted the grant application. Marks the start of the grant lifecycle and triggers the compliance review clock.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Final monetary amount approved for disbursement following compliance review and fair market value assessment. May differ from requested_amount if the review committee adjusts the grant value. Drives payment processing in SAP S/4HANA FI module.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetYear rdf:type rdf:Property ;
    rdfs:label 'Budget Year' ;
    rdfs:comment 'Fiscal year against which the grant is budgeted and expensed. Used for annual medical affairs budget planning, accrual management, and year-end financial close in SAP S/4HANA.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceReviewerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewer Name' ;
    rdfs:comment 'Full name of the compliance officer or committee member who completed the compliance review and rendered the determination. Supports audit trail and accountability requirements under 21 CFR Part 11.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efpiaDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Efpia Disclosure Required' ;
    rdfs:comment 'Indicates whether this grant must be disclosed under the EFPIA Disclosure Code for European recipients. Drives inclusion in the annual EFPIA transparency report submitted by the company.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalReportDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Date' ;
    rdfs:comment 'Date on which the final activity report was received from the recipient organization. Used to confirm grant closure eligibility and trigger any remaining disbursements or reconciliation actions.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalReportReceived rdf:type rdf:Property ;
    rdfs:label 'Final Report Received' ;
    rdfs:comment 'Indicates whether the recipient organization has submitted the required final activity report demonstrating that grant funds were used for the stated purpose. Required for grant closure and financial reconciliation.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmvAssessed rdf:type rdf:Property ;
    rdfs:label 'Fmv Assessed' ;
    rdfs:comment 'Indicates whether a formal Fair Market Value (FMV) assessment has been completed for this grant. FMV assessment is required to ensure the grant amount does not constitute an improper inducement under anti-kickback statutes and PhRMA Code.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmvAssessmentAmount rdf:type rdf:Property ;
    rdfs:label 'Fmv Assessment Amount' ;
    rdfs:comment 'The fair market value amount determined during the FMV assessment process, expressed in the grant currency. Used to validate that the approved_amount does not exceed fair market value, mitigating anti-kickback risk.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to the grant at initiation (e.g., MG-2024-000123). Used in correspondence with recipient organizations, compliance reporting, and audit trails. Sourced from Veeva MedComms grant management module.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantStatus rdf:type rdf:Property ;
    rdfs:label 'Grant Status' ;
    rdfs:comment 'Current lifecycle state of the grant record. Progresses from draft through compliance review to approval, active disbursement, and completion or rejection. Drives workflow routing in Veeva MedComms. [ENUM-REF-CANDIDATE: draft|under_review|approved|active|completed|rejected|withdrawn — promote to reference product]' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantType rdf:type rdf:Property ;
    rdfs:label 'Grant Type' ;
    rdfs:comment 'Classification of the grant by its intended purpose and regulatory category. Independent Medical Education (IME) grants fund accredited educational programs; charitable donations are philanthropic contributions; sponsorships fund events or publications; educational grants support non-accredited learning; unrestricted grants allow recipient discretion. [ENUM-REF-CANDIDATE: IME_grant|charitable_donation|sponsorship|educational_grant|unrestricted_grant — promote to reference product]' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentEducationalContent rdf:type rdf:Property ;
    rdfs:label 'Independent Educational Content' ;
    rdfs:comment 'Indicates whether the funded educational activity maintains full independence from the company\'s promotional activities and commercial interests. A core requirement for IME grants under PhRMA Code and ACCME standards.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalAffairsRegion rdf:type rdf:Property ;
    rdfs:label 'Medical Affairs Region' ;
    rdfs:comment 'Geographic region of the medical affairs organization responsible for this grant (e.g., North America, Europe, Asia Pacific, Latin America). Used for regional budget allocation and compliance reporting segmentation.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mslOwnerName rdf:type rdf:Property ;
    rdfs:label 'Msl Owner Name' ;
    rdfs:comment 'Full name of the Medical Science Liaison (MSL) responsible for managing the relationship with the recipient organization and overseeing the grant. Used for accountability tracking and KOL relationship management reporting.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMilestone rdf:type rdf:Property ;
    rdfs:label 'Payment Milestone' ;
    rdfs:comment 'Defines the payment disbursement structure for the grant. Single payment releases the full approved amount at once; tranche-based releases funds in stages tied to deliverables; upon_completion releases payment after the funded activity concludes.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Narrative description of the specific educational, scientific, or charitable purpose the grant is intended to fund. Must demonstrate independence from promotional intent. Reviewed during compliance assessment to confirm alignment with IME or charitable objectives.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCountryCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the recipient organization\'s registered address (e.g., USA, GBR, DEU). Determines applicable regulatory disclosure framework (Sunshine Act for USA, EFPIA for EU, ABPI for GBR).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientOrgType rdf:type rdf:Property ;
    rdfs:label 'Recipient Org Type' ;
    rdfs:comment 'Category of the recipient organization. Determines applicable compliance rules, disclosure obligations, and fair market value benchmarks. Medical societies and academic institutions are subject to PhRMA Code provisions; patient advocacy organizations have additional OIG guidance.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingObligation rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation' ;
    rdfs:comment 'Indicates whether this grant is subject to mandatory transparency reporting obligations (e.g., U.S. Open Payments/Sunshine Act, EFPIA Disclosure Code, ABPI). Drives inclusion in annual disclosure submissions.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedAmount rdf:type rdf:Property ;
    rdfs:label 'Requested Amount' ;
    rdfs:comment 'Gross monetary amount requested by the recipient organization in the grant application, expressed in the transaction currency. Compared against fair market value benchmarks and approved budget during compliance review.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sunshineActCategory rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Category' ;
    rdfs:comment 'Open Payments (Sunshine Act) transfer-of-value category under which this grant must be reported to CMS. Applicable for grants to U.S. covered recipients. Null for non-U.S. grants.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSampleSize rdf:type rdf:Property ;
    rdfs:label 'Actual Sample Size' ;
    rdfs:comment 'Actual number of patients or data records included in the final study analysis. Compared against planned sample size to assess study feasibility and statistical validity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataPrivacyComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Compliance Status' ;
    rdfs:comment 'Status of the study\'s compliance with applicable data privacy regulations including GDPR, HIPAA, and local data protection laws. Assessed by the Data Privacy Officer prior to study initiation and reviewed at key milestones.' ;
    rdfs:domain ind:MedicalHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceName rdf:type rdf:Property ;
    rdfs:label 'Data Source Name' ;
    rdfs:comment 'Name of the specific database, registry, or data vendor used as the primary data source (e.g., IQVIA Pharmetrics, Optum Clinformatics, SEER Registry, Flatiron Health EHR). Critical for assessing data quality and regulatory acceptability of RWE.' ;
    rdfs:domain ind:MedicalHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heorModelType rdf:type rdf:Property ;
    rdfs:label 'Heor Model Type' ;
    rdfs:comment 'Type of economic model used in the study, applicable to cost-effectiveness and budget impact analyses. Null or \'not_applicable\' for purely observational RWE/RWD studies. Determines model validation requirements for HTA submissions.' ;
    rdfs:domain ind:MedicalHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Number' ;
    rdfs:comment 'Official reference number issued by the IRB or Ethics Committee upon study approval. Required for regulatory submissions and publication. Null if IRB approval is not required or not yet obtained.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'Narrative summary of the principal study findings and conclusions, including primary endpoint results and clinical/economic significance. Populated upon study completion and used for scientific communications, payer dossiers, and KOL briefings.' ;
    rdfs:domain ind:MedicalHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passStudyFlag rdf:type rdf:Property ;
    rdfs:label 'Pass Study Flag' ;
    rdfs:comment 'Indicates whether this study is a Post-Authorization Safety Study (PASS) required by EMA as a condition of marketing authorization. True triggers mandatory EMA PASS reporting obligations and specific protocol requirements.' ;
    rdfs:domain ind:MedicalHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientPopulation rdf:type rdf:Property ;
    rdfs:label 'Patient Population' ;
    rdfs:comment 'Description of the target patient population for the study, including key inclusion/exclusion criteria such as age range, disease stage, prior treatment history, and geographic scope. Defines the generalisability of study findings.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDoi rdf:type rdf:Property ;
    rdfs:label 'Publication Doi' ;
    rdfs:comment 'Digital Object Identifier (DOI) of the peer-reviewed publication associated with this study. Null if not yet published. Enables direct linkage to published evidence for scientific communications and regulatory dossiers.' ;
    rdfs:domain ind:MedicalHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryUseIntent rdf:type rdf:Property ;
    rdfs:label 'Regulatory Use Intent' ;
    rdfs:comment 'Intended regulatory or strategic use of the study findings. Determines whether the study must comply with FDA post-marketing study commitments, EMA PASS requirements, or payer dossier standards.' ;
    rdfs:domain ind:MedicalHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweStudyFlag rdf:type rdf:Property ;
    rdfs:label 'Rwe Study Flag' ;
    rdfs:comment 'Indicates whether this study generates Real-World Evidence (RWE) using Real-World Data (RWD) sources such as claims, EHR, or registries. True for RWE studies; False for purely economic modeling studies. Drives FDA/EMA RWE regulatory pathway applicability.' ;
    rdfs:domain ind:MedicalHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorshipType rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Type' ;
    rdfs:comment 'Indicates whether the study is company-sponsored, an Investigator-Initiated Trial (IIT), an Investigator-Sponsored Study (ISS), a collaborative study, or externally grant-funded. Determines contractual, IP, and publication rights.' ;
    rdfs:domain ind:MedicalHeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingMslEngagementId rdf:type rdf:Property ;
    rdfs:label 'Originating Msl Engagement Id' ;
    rdfs:comment 'Foreign key linking to medical.msl_engagement. Business justification: Medical inquiries often originate from MSL engagements with HCPs. During an MSL interaction, the HCP may ask a question that triggers a formal medical information request. The inquiry should reference' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MslEngagement .

ind:primaryContentId rdf:type rdf:Property ;
    rdfs:label 'Primary Content Id' ;
    rdfs:comment 'Foreign key linking to medical.content. Business justification: Medical information inquiries are responded to using approved content assets (standard response letters, medical information documents). The inquiry should reference the primary content asset used in ' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Content .

ind:requesterMasterId rdf:type rdf:Property ;
    rdfs:label 'Requester Master Id' ;
    rdfs:comment 'Reference to the party (Healthcare Professional, patient, caregiver, or payer) who submitted the medical inquiry. Links to the HCP or contact master record.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:inquiryCategory rdf:type rdf:Property ;
    rdfs:label 'Inquiry Category' ;
    rdfs:comment 'Primary classification of the medical inquiry topic. Drives routing to appropriate medical information specialists and determines regulatory handling requirements. [ENUM-REF-CANDIDATE: safety|efficacy|dosing|off_label|pharmacokinetics|drug_interaction|storage|other — promote to reference product]' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryNumber rdf:type rdf:Property ;
    rdfs:label 'Inquiry Number' ;
    rdfs:comment 'Externally-visible business reference number assigned to the inquiry, used for tracking and correspondence with the requester. Sourced from Veeva MedComms case numbering.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryStatus rdf:type rdf:Property ;
    rdfs:label 'Inquiry Status' ;
    rdfs:comment 'Current workflow lifecycle state of the medical inquiry from receipt through closure. Drives SLA monitoring and workload management in the medical information function. [ENUM-REF-CANDIDATE: received|in_review|pending_response|responded|closed|escalated — promote to reference product]' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryText rdf:type rdf:Property ;
    rdfs:label 'Inquiry Text' ;
    rdfs:comment 'Full verbatim text of the medical information question as submitted by the requester. Classified as confidential due to potential inclusion of patient or clinical context. Stored for audit trail and response quality review.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdverseEventRelated rdf:type rdf:Property ;
    rdfs:label 'Is Adverse Event Related' ;
    rdfs:comment 'Indicates whether the inquiry contains information that may constitute a reportable Adverse Event (AE) or Serious Adverse Event (SAE). Triggers pharmacovigilance triage and potential ICSR submission workflow.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOffLabel rdf:type rdf:Property ;
    rdfs:label 'Is Off Label' ;
    rdfs:comment 'Indicates whether the inquiry pertains to an off-label use of the product (i.e., use outside the approved indication, dosage, population, or route of administration). Critical compliance flag for regulatory reporting and response protocol.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:literatureReferenceIds rdf:type rdf:Property ;
    rdfs:label 'Literature Reference Ids' ;
    rdfs:comment 'Comma-separated list of internal document or publication IDs from the medical information library used in the response. Enables tracking of which standard response documents and publications are most frequently utilized.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time the medical inquiry was received by the medical information team. This is the principal business event timestamp used for SLA calculation and regulatory reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requesterEmail rdf:type rdf:Property ;
    rdfs:label 'Requester Email' ;
    rdfs:comment 'Email address of the inquiry requester used for response delivery and follow-up communication. Classified as restricted PII under GDPR and HIPAA.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterType rdf:type rdf:Property ;
    rdfs:label 'Requester Type' ;
    rdfs:comment 'Classification of the individual or entity submitting the medical inquiry. Determines response protocol, regulatory obligations, and permissible content of the response (e.g., off-label information may only be provided to HCPs).' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseChannel rdf:type rdf:Property ;
    rdfs:label 'Response Channel' ;
    rdfs:comment 'Communication channel used to deliver the medical information response to the requester. May differ from the inquiry channel (e.g., inquiry received by phone, response sent by email).' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target response time in hours as defined by the medical information SLA policy for this inquiry category and priority. Used to measure compliance with internal and contractual response time commitments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Source System Case Number' ;
    rdfs:comment 'Original case or record identifier from the source system (Veeva MedComms) used for traceability and reconciliation between the Silver layer and the operational system of record.' ;
    rdfs:domain ind:Inquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advisoryBoardMember rdf:type rdf:Property ;
    rdfs:label 'Advisory Board Member' ;
    rdfs:comment 'Indicates whether the KOL currently holds or has held an advisory board membership with the company. Triggers conflict-of-interest disclosure requirements and fair market value (FMV) compensation tracking.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalTrialInvestigator rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Investigator' ;
    rdfs:comment 'Indicates whether the KOL has served as a Principal Investigator (PI) or Sub-Investigator on any company-sponsored or investigator-initiated clinical trial. Relevant for engagement eligibility and transparency reporting.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coiDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Coi Disclosure Date' ;
    rdfs:comment 'Date on which the KOL most recently completed and submitted their conflict-of-interest disclosure form for the current reporting cycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coiDisclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Coi Disclosure Status' ;
    rdfs:comment 'Current status of the KOL\'s conflict-of-interest (COI) disclosure for the current reporting period. Mandatory for regulatory compliance under Sunshine Act, EFPIA, and company SOPs before any engagement or payment.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressSpeaker rdf:type rdf:Property ;
    rdfs:label 'Congress Speaker' ;
    rdfs:comment 'Indicates whether the KOL has delivered a presentation, keynote, or symposium talk at a major scientific congress or medical conference relevant to the company\'s therapeutic areas.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentToContact rdf:type rdf:Property ;
    rdfs:label 'Consent To Contact' ;
    rdfs:comment 'Indicates whether the KOL has provided valid consent to be contacted by the company\'s medical affairs team, in compliance with GDPR, HIPAA, and applicable local privacy regulations. Must be TRUE before any outreach is initiated.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalInfluenceScore rdf:type rdf:Property ;
    rdfs:label 'Digital Influence Score' ;
    rdfs:comment 'Composite numeric score (0–100 scale) quantifying the KOL\'s digital and social media influence across platforms such as Twitter/X, LinkedIn, ResearchGate, and medical forums. Sourced from digital analytics tools integrated with Veeva MedComms.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:efpiaYtdAmount rdf:type rdf:Property ;
    rdfs:label 'Efpia Ytd Amount' ;
    rdfs:comment 'Cumulative year-to-date total of all transfers of value reportable under the EFPIA Disclosure Code for EU-based HCPs and healthcare organisations, expressed in EUR. Supports annual EFPIA transparency publication.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementFrequencyYtd rdf:type rdf:Property ;
    rdfs:label 'Engagement Frequency Ytd' ;
    rdfs:comment 'Total number of documented medical affairs interactions with this KOL in the current calendar year. Supports engagement intensity monitoring and compliance with interaction frequency guidelines.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fmvTier rdf:type rdf:Property ;
    rdfs:label 'Fmv Tier' ;
    rdfs:comment 'Assigned fair market value (FMV) tier for this KOL, determining the permissible hourly or per-engagement compensation rate for advisory, speaking, and consulting services. Tiers are calibrated annually against independent FMV benchmarks to ensure OIG and anti-kickback compliance.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full legal name of the Key Opinion Leader as registered in the source system, used for correspondence, transparency reporting, and engagement records.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heorExpert rdf:type rdf:Property ;
    rdfs:label 'Heor Expert' ;
    rdfs:comment 'Indicates whether the KOL has recognised expertise in Health Economics and Outcomes Research (HEOR), Real-World Evidence (RWE), or health technology assessment (HTA). Supports HEOR engagement and payer evidence generation strategy.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iitSponsor rdf:type rdf:Property ;
    rdfs:label 'Iit Sponsor' ;
    rdfs:comment 'Indicates whether the KOL has sponsored or led an Investigator-Initiated Trial (IIT) or Investigator-Sponsored Study (ISS) supported by the company. Drives IIT grant management and medical affairs relationship depth scoring.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:influenceTier rdf:type rdf:Property ;
    rdfs:label 'Influence Tier' ;
    rdfs:comment 'Hierarchical classification of the KOL\'s scientific and clinical influence scope: global (international thought leader), regional (multi-country), national (single country), or local (sub-national). Drives engagement strategy and resource allocation.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolType rdf:type rdf:Property ;
    rdfs:label 'Kol Type' ;
    rdfs:comment 'Categorical classification of the thought leader type, distinguishing established KOLs from emerging leaders, patient advocates, health economists, and principal investigators relevant to medical affairs strategy.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEngagementDate rdf:type rdf:Property ;
    rdfs:label 'Last Engagement Date' ;
    rdfs:comment 'Date of the most recent documented medical affairs interaction with the KOL (e.g., MSL field visit, advisory board meeting, medical information inquiry response, congress interaction). Used for engagement recency analysis and relationship maintenance planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary institutional or professional email address for the KOL, used for medical affairs correspondence, advisory board invitations, and publication collaboration.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryInstitution rdf:type rdf:Property ;
    rdfs:label 'Primary Institution' ;
    rdfs:comment 'Name of the primary hospital, university, research centre, or academic medical centre with which the KOL is currently affiliated. Used for institutional relationship mapping and conflict-of-interest assessment.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTherapeuticArea rdf:type rdf:Property ;
    rdfs:label 'Primary Therapeutic Area' ;
    rdfs:comment 'The principal therapeutic area in which the KOL holds recognised scientific expertise (e.g., Oncology, Immunology, Rare Diseases). Aligns with the company\'s therapeutic area taxonomy for strategic segmentation.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationPlanningParticipant rdf:type rdf:Property ;
    rdfs:label 'Publication Planning Participant' ;
    rdfs:comment 'Indicates whether the KOL is actively engaged in the company\'s publication planning programme as an author, reviewer, or steering committee member. Managed via Veeva MedComms publication planning module.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipDepthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Depth Score' ;
    rdfs:comment 'Composite numeric score (0–100 scale) reflecting the depth and quality of the company\'s medical affairs relationship with the KOL, based on engagement frequency, interaction type, responsiveness, and collaboration history. Sourced from Veeva MedComms engagement analytics.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rweCollaborator rdf:type rdf:Property ;
    rdfs:label 'Rwe Collaborator' ;
    rdfs:comment 'Indicates whether the KOL is actively engaged as a collaborator in the company\'s Real-World Evidence (RWE) or Real-World Data (RWD) generation programmes, including registry studies, database analyses, or observational research.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sunshineActYtdAmount rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Ytd Amount' ;
    rdfs:comment 'Cumulative year-to-date total of all transfers of value (payments, honoraria, meals, travel, research grants) made to this KOL reportable under the U.S. Sunshine Act / Open Payments programme (42 CFR §403.904), expressed in USD. Resets annually at the start of each reporting year.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCitations rdf:type rdf:Property ;
    rdfs:label 'Total Citations' ;
    rdfs:comment 'Cumulative number of citations received across all publications attributed to the KOL, as sourced from Scopus or Web of Science. Complements H-index as a measure of scientific impact.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPublications rdf:type rdf:Property ;
    rdfs:label 'Total Publications' ;
    rdfs:comment 'Total number of peer-reviewed publications (journal articles, reviews, meta-analyses) attributed to the KOL as indexed in PubMed or Scopus. Reflects scientific output volume for influence scoring.' ;
    rdfs:domain ind:MedicalKolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the journal or congress formally accepted the submission for publication or presentation. Used to calculate submission-to-acceptance cycle time.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorshipStrategy rdf:type rdf:Property ;
    rdfs:label 'Authorship Strategy' ;
    rdfs:comment 'Strategic classification of the authorship approach for this publication, indicating the degree of company versus Key Opinion Leader (KOL) or independent investigator involvement. Governs compliance with ICMJE authorship criteria and GPP3 transparency requirements.' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressPresentationDate rdf:type rdf:Property ;
    rdfs:label 'Congress Presentation Date' ;
    rdfs:comment 'Specific date on which the poster or oral presentation was delivered at the congress. Distinct from publication_date for congress-type submissions.' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correspondingAuthorName rdf:type rdf:Property ;
    rdfs:label 'Corresponding Author Name' ;
    rdfs:comment 'Full name of the corresponding author responsible for post-publication correspondence. Distinct from lead author in multi-author publications.' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Data Disclosure Date' ;
    rdfs:comment 'Planned or actual date on which the underlying clinical or research data is disclosed through this publication, aligned with regulatory milestones (e.g., NDA/BLA submission, patent expiry). Critical for coordinating publication timing with regulatory strategy.' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:embargoEndDate rdf:type rdf:Property ;
    rdfs:label 'Embargo End Date' ;
    rdfs:comment 'Date on which the publication embargo is lifted, permitting public dissemination of results. Critical for coordinating press releases, HCP communications, and commercial activities with regulatory and publication timelines.' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heorRweFlag rdf:type rdf:Property ;
    rdfs:label 'Heor Rwe Flag' ;
    rdfs:comment 'Indicates whether this publication presents Health Economics and Outcomes Research (HEOR) or Real-World Evidence (RWE) / Real-World Data (RWD) findings, as distinct from interventional clinical trial results.' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iitIssFlag rdf:type rdf:Property ;
    rdfs:label 'Iit Iss Flag' ;
    rdfs:comment 'Indicates whether this publication arises from an investigator-initiated trial (IIT) or investigator-sponsored study (ISS) rather than a company-sponsored clinical program. Governs grant management and publication support processes.' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issn rdf:type rdf:Property ;
    rdfs:label 'Issn' ;
    rdfs:comment 'International Standard Serial Number of the journal in which the publication appears or is targeted. Enables unambiguous journal identification for impact factor tracking and citation metrics.' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuthorName rdf:type rdf:Property ;
    rdfs:label 'Lead Author Name' ;
    rdfs:comment 'Full name of the primary (first-listed) author of the publication. Used for KOL relationship management, authorship tracking, and scientific communication reporting.' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMilestoneAlignment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Milestone Alignment' ;
    rdfs:comment 'Regulatory development milestone to which this publication\'s data disclosure timeline is aligned (e.g., NDA/BLA submission, approval). Ensures publication strategy supports regulatory strategy without premature data disclosure. [ENUM-REF-CANDIDATE: pre_ind|ind_filing|phase1_completion|phase2_completion|phase3_completion|nda_bla_submission|approval|post_approval — promote to reference product]' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetJournalName rdf:type rdf:Property ;
    rdfs:label 'Target Journal Name' ;
    rdfs:comment 'Strategically planned target journal identified during publication planning, prior to actual submission. Used for authorship strategy alignment and data disclosure timeline planning.' ;
    rdfs:domain ind:MedicalPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Number' ;
    rdfs:comment 'Document identifier in Veeva Vault MedComms system of record, enabling traceability between the lakehouse silver layer record and the source document management system.' ;
    rdfs:domain ind:Medical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productAssetMedicinalProductId rdf:type rdf:Property ;
    rdfs:label 'Product Asset Medicinal Product Id' ;
    rdfs:comment 'Identifier of the approved drug product or pipeline asset (compound, molecule, or biologic) discussed during the engagement. Supports product-level MSL activity analysis.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicinalProduct .

ind:adverseEventReported rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Reported' ;
    rdfs:comment 'Indicates whether an Adverse Event (AE) or Serious Adverse Event (SAE) was reported or disclosed during this MSL engagement. Triggers mandatory pharmacovigilance (PV) reporting workflow per regulatory requirements.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceAttestation rdf:type rdf:Property ;
    rdfs:label 'Compliance Attestation' ;
    rdfs:comment 'Indicates whether the MSL has attested that the engagement was conducted in compliance with applicable regulations, company SOPs, PhRMA Code, and EFPIA HCP Code. Mandatory for regulatory audit readiness.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPackageShared rdf:type rdf:Property ;
    rdfs:label 'Data Package Shared' ;
    rdfs:comment 'Name or identifier of the scientific data package, publication, or medical communication material shared with the HCP during the engagement. Supports content effectiveness tracking.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Engagement End Timestamp' ;
    rdfs:comment 'Precise date and time when the MSL engagement concluded. Used together with engagement_start_timestamp to derive interaction duration for productivity metrics.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementNotes rdf:type rdf:Property ;
    rdfs:label 'Engagement Notes' ;
    rdfs:comment 'Free-text field for the MSL to record additional context, scientific discussion details, or HCP feedback not captured in structured fields. Confidential business record stored per 21 CFR Part 11 electronic records requirements.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Timestamp' ;
    rdfs:comment 'Precise date and time when the MSL engagement began. Enables duration calculation and scheduling analysis. Complements engagement_date with time-level precision.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpAction rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action' ;
    rdfs:comment 'Description of the specific follow-up action committed to by the MSL at the conclusion of the engagement (e.g., send publication, schedule advisory board, submit medical information response).' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heorTopicDiscussed rdf:type rdf:Property ;
    rdfs:label 'Heor Topic Discussed' ;
    rdfs:comment 'Indicates whether Health Economics and Outcomes Research (HEOR) data, Real-World Evidence (RWE), or Real-World Data (RWD) was a primary topic of discussion during the engagement.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iitIssDiscussed rdf:type rdf:Property ;
    rdfs:label 'Iit Iss Discussed' ;
    rdfs:comment 'Indicates whether an Investigator-Initiated Trial (IIT) or Investigator-Sponsored Study (ISS) was discussed during the engagement. Supports IIT/ISS pipeline tracking in medical affairs.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insightSummary rdf:type rdf:Property ;
    rdfs:label 'Insight Summary' ;
    rdfs:comment 'Structured summary of key scientific insights, HCP perspectives, unmet medical needs, or competitive intelligence captured by the MSL during the engagement. Confidential business intelligence used for medical strategy and pipeline decisions.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the nature of the MSL engagement. Proactive scientific exchange is MSL-initiated; reactive medical inquiry is HCP-initiated. Advisory board and congress interactions are event-based. IIT/ISS discussions relate to investigator-initiated trials or studies. [ENUM-REF-CANDIDATE: proactive_scientific_exchange|reactive_medical_inquiry|advisory_board|congress_interaction|iit_discussion|iss_discussion — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalInquiryReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Inquiry Received' ;
    rdfs:comment 'Indicates whether the HCP submitted a medical information inquiry during this engagement that requires a formal medical information response. Triggers downstream medical information workflow.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offLabelDiscussion rdf:type rdf:Property ;
    rdfs:label 'Off Label Discussion' ;
    rdfs:comment 'Indicates whether any off-label use of a product was discussed during the engagement. Confidential compliance-sensitive flag required for regulatory audit and legal review. Must be managed per FDA and EMA off-label communication guidelines.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeClassification rdf:type rdf:Property ;
    rdfs:label 'Outcome Classification' ;
    rdfs:comment 'Standardized classification of the outcome of the MSL engagement. Drives follow-up workflow management and field medical impact reporting. [ENUM-REF-CANDIDATE: insight_captured|follow_up_required|no_action|referral_made|publication_shared — promote to reference product]' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productComplaintReported rdf:type rdf:Property ;
    rdfs:label 'Product Complaint Reported' ;
    rdfs:comment 'Indicates whether a product quality complaint was disclosed by the HCP during this engagement. Triggers quality management and CAPA workflow per GMP requirements.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scientificTopic rdf:type rdf:Property ;
    rdfs:label 'Scientific Topic' ;
    rdfs:comment 'Free-text or standardized label describing the primary scientific topic or data discussed during the engagement (e.g., mechanism of action, clinical trial results, safety profile, HEOR data, RWE findings).' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaActivityCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Activity Code' ;
    rdfs:comment 'External identifier of the source activity record in Veeva MedComms CRM. Used for traceability and reconciliation back to the system of record. Serves as the BUSINESS_IDENTIFIER for this transaction.' ;
    rdfs:domain ind:MslEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMslEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Msl Employee Id' ;
    rdfs:comment 'Corporate HR employee identifier sourced from SAP S/4HANA HR module, linking the MSL to their official employment record for payroll, compliance, and headcount reporting.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:heorSupportEligible rdf:type rdf:Property ;
    rdfs:label 'Heor Support Eligible' ;
    rdfs:comment 'Indicates whether the MSL is trained and authorized to engage HCPs and payers on Health Economics and Outcomes Research (HEOR) topics, Real-World Evidence (RWE), and Real-World Data (RWD) discussions.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iitReviewEligible rdf:type rdf:Property ;
    rdfs:label 'Iit Review Eligible' ;
    rdfs:comment 'Indicates whether the MSL is authorized to receive, evaluate, and facilitate Investigator-Initiated Trial (IIT) or Investigator-Sponsored Study (ISS) proposals from HCPs and KOLs in their territory.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kolEngagementCapacity rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Capacity' ;
    rdfs:comment 'Maximum number of active Key Opinion Leader (KOL) relationships the MSL is authorized and resourced to manage concurrently. Used for territory planning, workload balancing, and field medical capacity modeling.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageProficiencies rdf:type rdf:Property ;
    rdfs:label 'Language Proficiencies' ;
    rdfs:comment 'Pipe-delimited list of ISO 639-1 language codes representing languages in which the MSL can conduct scientific engagements (e.g., \'EN|FR|DE\'). Supports territory assignment in multilingual markets.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalInformationCertified rdf:type rdf:Property ;
    rdfs:label 'Medical Information Certified' ;
    rdfs:comment 'Indicates whether the MSL has completed required training and certification to respond to unsolicited medical information requests from HCPs, in compliance with FDA and EMA promotional regulations.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mslType rdf:type rdf:Property ;
    rdfs:label 'Msl Type' ;
    rdfs:comment 'Functional classification of the MSL role distinguishing field-based, regional, and global medical science liaison roles. Determines reporting hierarchy and engagement scope.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStageFocus rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage Focus' ;
    rdfs:comment 'Development pipeline stage of the product(s) the MSL primarily supports. Determines the nature of scientific communications, IIT/ISS engagement, and KOL interaction strategy. [ENUM-REF-CANDIDATE: discovery|preclinical|phase_1|phase_2|phase_3|launch|post_market — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFocusPrimary rdf:type rdf:Property ;
    rdfs:label 'Product Focus Primary' ;
    rdfs:comment 'The primary pharmaceutical product or brand the MSL is assigned to support in their scientific engagement activities. Aligns with commercial launch plans and medical affairs publication strategy.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Profile Effective Date' ;
    rdfs:comment 'Date from which the MSL profile record is considered active and authoritative for field medical operations, territory assignments, and engagement tracking.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileEndDate rdf:type rdf:Property ;
    rdfs:label 'Profile End Date' ;
    rdfs:comment 'Date on which the MSL profile record becomes inactive, typically corresponding to termination, role change, or organizational restructuring. Null for currently active profiles.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationPlanningRole rdf:type rdf:Property ;
    rdfs:label 'Publication Planning Role' ;
    rdfs:comment 'Designates the MSL\'s role in the medical affairs publication planning process as managed in Veeva MedComms. Determines access to publication plans, data packages, and scientific communication materials.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Standardized code for the broader geographic region in which the MSL operates (e.g., NORAM, EMEA, APAC, LATAM). Supports regional headcount analytics and cross-territory coverage reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scientificDegree rdf:type rdf:Property ;
    rdfs:label 'Scientific Degree' ;
    rdfs:comment 'Highest academic or professional degree held by the MSL. Used for credentialing validation, HCP engagement eligibility, and regulatory compliance with GCP and medical affairs standards. [ENUM-REF-CANDIDATE: PharmD|PhD|MD|DO|MS|MBA|BSc|RPh|NP|PA — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Seniority Level' ;
    rdfs:comment 'Career seniority classification of the MSL within the field medical organization. Used for headcount analytics, compensation benchmarking, and territory complexity assignment.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyCertification rdf:type rdf:Property ;
    rdfs:label 'Specialty Certification' ;
    rdfs:comment 'Professional certification or board specialty held by the MSL (e.g., CMSL - Certified Medical Science Liaison, board-certified pharmacist, oncology-certified nurse). Supports credentialing and compliance tracking.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaPrimary rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Primary' ;
    rdfs:comment 'The principal therapeutic area of scientific expertise for the MSL (e.g., Oncology, Immunology, Rare Diseases, Cardiovascular). Drives territory assignment, KOL alignment, and scientific communication planning. [ENUM-REF-CANDIDATE: oncology|immunology|rare_diseases|cardiovascular|neuroscience|infectious_diseases|metabolic_diseases|respiratory — promote to reference product]' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaSecondary rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Secondary' ;
    rdfs:comment 'Optional secondary therapeutic area of scientific expertise for the MSL, supporting cross-functional coverage and pipeline product launches in adjacent disease areas. [ENUM-REF-CANDIDATE: oncology|immunology|rare_diseases|cardiovascular|neuroscience|infectious_diseases|metabolic_diseases|respiratory — promote to reference product]' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaMedcommsAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Veeva Medcomms Access Level' ;
    rdfs:comment 'Access permission level granted to the MSL within the Veeva MedComms platform for scientific content, publication plans, and medical communication materials. Governs content visibility and workflow participation.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of professional experience in medical affairs, clinical, or scientific roles. Used for seniority validation, territory complexity matching, and KOL engagement capability assessment.' ;
    rdfs:domain ind:MslProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dosageRegimen rdf:type rdf:Property ;
    rdfs:label 'Dosage Regimen' ;
    rdfs:comment 'Prescribed dosage regimen for the named patient, including dose amount, frequency, and route of administration as specified by the requesting physician (e.g., \'200 mg orally twice daily\'). Captured as free text to accommodate compound-specific regimens.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsCommitteeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Ethics Committee Approval Date' ;
    rdfs:comment 'Date on which the IRB/IEC granted approval for the named patient request. Null if approval is pending, not required, or waived.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ethicsCommitteeApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Ethics Committee Approval Status' ;
    rdfs:comment 'Approval status from the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) for the named patient / compassionate use request. Some regulatory pathways (e.g., FDA individual expanded access) may waive IRB review under emergency provisions.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icsrReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Icsr Reporting Required' ;
    rdfs:comment 'Indicates whether expedited Individual Case Safety Report (ICSR) reporting obligations apply to this named patient request under applicable pharmacovigilance regulations. True for all expanded access programs under FDA 21 CFR Part 312.32 and EMA GVP Module VI.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeReportDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Report Date' ;
    rdfs:comment 'Date on which the treatment outcome was formally reported by the requesting physician to the medical affairs / pharmacovigilance team. Null if outcome reporting is pending.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientAgeAtRequest rdf:type rdf:Property ;
    rdfs:label 'Patient Age At Request' ;
    rdfs:comment 'Age of the patient in whole years at the time the named patient request was submitted. Captured in lieu of date of birth to minimize PHI exposure per GDPR/HIPAA de-identification standards. Used for pediatric/geriatric eligibility assessment and safety signal stratification.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patientReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Patient Reference Code' ;
    rdfs:comment 'Pseudonymized / anonymized patient identifier assigned by the requesting institution to enable safety follow-up and outcome reporting without exposing direct patient identity. Compliant with GDPR Article 89 pseudonymization requirements and HIPAA Safe Harbor de-identification. The actual patient identity is held only in the requesting institution\'s records.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientSex rdf:type rdf:Property ;
    rdfs:label 'Patient Sex' ;
    rdfs:comment 'Biological sex of the patient as reported by the requesting physician. Used for pharmacokinetic (PK) and pharmacodynamic (PD) safety analysis and ICSR reporting to regulatory authorities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedTreatmentDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Treatment Duration Days' ;
    rdfs:comment 'Anticipated duration of treatment under the named patient program, expressed in whole days. Used for supply planning, safety monitoring scheduling, and treatment outcome assessment.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the quantity requested and supplied (e.g., vials, tablets, capsules, grams). Aligns with the compound\'s Certificate of Analysis (CoA) and SAP material master unit of measure. [ENUM-REF-CANDIDATE: vials|tablets|capsules|grams|mg|mL|units — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Approval Date' ;
    rdfs:comment 'Date on which the relevant regulatory authority (FDA, EMA, MHRA, PMDA, etc.) granted approval or authorization for the named patient request.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthorityApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Approval Status' ;
    rdfs:comment 'Status of the regulatory authority review and approval for the named patient / expanded access request (e.g., FDA IND authorization, EMA compassionate use opinion). Distinct from ethics committee approval.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsApplicable rdf:type rdf:Property ;
    rdfs:label 'Rems Applicable' ;
    rdfs:comment 'Indicates whether the requested compound is subject to an FDA Risk Evaluation and Mitigation Strategy (REMS) program, which may impose additional dispensing, monitoring, or patient enrollment requirements for the named patient supply.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the expanded access / compassionate use request scope: individual (single patient), intermediate (small group), or treatment protocol (larger population). Aligns with FDA 21 CFR Part 312 Subpart I categorization.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingInstitution rdf:type rdf:Property ;
    rdfs:label 'Requesting Institution' ;
    rdfs:comment 'Name of the hospital, clinic, or healthcare institution from which the named patient request originates. Used for supply logistics, ethics committee correspondence, and KOL relationship management.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Safety Report Due Date' ;
    rdfs:comment 'Deadline by which the next required safety / pharmacovigilance report (ICSR or periodic) must be submitted to the regulatory authority for this named patient request. Calculated from treatment start date and applicable reporting timelines.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyFulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Supply Fulfillment Status' ;
    rdfs:comment 'Current status of the drug supply fulfillment for the named patient request, tracking the physical supply chain from allocation through delivery. Integrates with SAP S/4HANA MM/WM and Kinaxis RapidResponse supply planning.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:susarReported rdf:type rdf:Property ;
    rdfs:label 'Susar Reported' ;
    rdfs:comment 'Indicates whether a Suspected Unexpected Serious Adverse Reaction (SUSAR) has been reported for this named patient during the treatment period. Triggers expedited 7-day or 15-day reporting to regulatory authorities and DSMB notification.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Treatment End Date' ;
    rdfs:comment 'Actual or projected date on which the patient\'s treatment under the named patient program concluded or is expected to conclude. Null if treatment is ongoing. Used for outcome reporting and supply chain closure.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Treatment Outcome' ;
    rdfs:comment 'Reported clinical outcome for the patient at the conclusion of or during the named patient treatment. Aligns with ICH E2B(R3) outcome codes used in ICSR reporting to FDA FAERS and EMA EudraVigilance.' ;
    rdfs:domain ind:NamedPatientRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Start Date' ;
    rdfs:comment 'Actual date on which the patient commenced treatment with the investigational compound under the named patient program. Triggers safety monitoring obligations and ICSR reporting clock.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adverseEventId rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Id' ;
    rdfs:comment 'Primary key for adverse_event' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionTakenStudyDrug rdf:type rdf:Property ;
    rdfs:label 'Action Taken Study Drug' ;
    rdfs:comment 'Action taken with the investigational product or study drug in response to the adverse event.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeTerm rdf:type rdf:Property ;
    rdfs:label 'Ae Term' ;
    rdfs:comment 'The verbatim description of the adverse event as reported by the patient, investigator, or healthcare professional.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'The duration of the adverse event in days, calculated from onset date to resolution date. Null if ongoing or fatal.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedness rdf:type rdf:Property ;
    rdfs:label 'Expectedness' ;
    rdfs:comment 'Indicates whether the adverse event was expected based on the current Investigator Brochure or product labeling.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraPtName rdf:type rdf:Property ;
    rdfs:label 'Meddra Pt Name' ;
    rdfs:comment 'MedDRA preferred term name describing the adverse event in standardized medical terminology.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraSocCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Soc Code' ;
    rdfs:comment 'MedDRA system organ class code representing the highest level of the MedDRA hierarchy for the adverse event.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraSocName rdf:type rdf:Property ;
    rdfs:label 'Meddra Soc Name' ;
    rdfs:comment 'MedDRA system organ class name representing the body system affected by the adverse event.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'The date when the adverse event was first reported to the sponsor or investigator.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'The type of individual who initially reported the adverse event.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingTimelineComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Timeline Compliance Status' ;
    rdfs:comment 'Indicates whether the adverse event was reported to regulatory authorities within the required timeline (e.g., 7 days for fatal/life-threatening SAEs, 15 days for other SAEs).' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousnessCriteriaCongenitalAnomaly rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Congenital Anomaly' ;
    rdfs:comment 'Indicates whether the adverse event resulted in a congenital anomaly or birth defect.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteriaDeath rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Death' ;
    rdfs:comment 'Indicates whether the adverse event resulted in death.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteriaDisability rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Disability' ;
    rdfs:comment 'Indicates whether the adverse event resulted in persistent or significant disability or incapacity.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteriaHospitalization rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Hospitalization' ;
    rdfs:comment 'Indicates whether the adverse event resulted in initial or prolonged inpatient hospitalization.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteriaLifeThreatening rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Life Threatening' ;
    rdfs:comment 'Indicates whether the adverse event was life-threatening at the time of the event.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteriaMedicallyImportant rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Medically Important' ;
    rdfs:comment 'Indicates whether the adverse event was considered medically important and may jeopardize the patient or require intervention to prevent one of the other serious outcomes.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessFlag rdf:type rdf:Property ;
    rdfs:label 'Seriousness Flag' ;
    rdfs:comment 'Indicates whether the adverse event meets regulatory criteria for seriousness (death, life-threatening, hospitalization, disability, congenital anomaly, or other medically important condition).' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityGrade rdf:type rdf:Property ;
    rdfs:label 'Severity Grade' ;
    rdfs:comment 'Severity grade of the adverse event using CTCAE scale: Grade 1 (Mild), Grade 2 (Moderate), Grade 3 (Severe), Grade 4 (Life-threatening), Grade 5 (Death).' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:susarFlag rdf:type rdf:Property ;
    rdfs:label 'Susar Flag' ;
    rdfs:comment 'Indicates whether the adverse event qualifies as a SUSAR (serious, unexpected, and suspected to be related to the investigational product), requiring expedited reporting to regulatory authorities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentAdministered rdf:type rdf:Property ;
    rdfs:label 'Treatment Administered' ;
    rdfs:comment 'Description of any treatment, medication, or intervention administered to manage or resolve the adverse event.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerResultId rdf:type rdf:Property ;
    rdfs:label 'Biomarker Result Id' ;
    rdfs:comment 'Unique identifier for the biomarker result record. Primary key for this entity.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alleleFrequency rdf:type rdf:Property ;
    rdfs:label 'Allele Frequency' ;
    rdfs:comment 'The variant allele frequency (VAF) expressed as a decimal (e.g., 0.45 for 45% mutant allele frequency).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayVersion rdf:type rdf:Property ;
    rdfs:label 'Assay Version' ;
    rdfs:comment 'The version or lot number of the assay kit used, critical for traceability and regulatory compliance.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerCode rdf:type rdf:Property ;
    rdfs:label 'Biomarker Code' ;
    rdfs:comment 'Standardized code for the biomarker using LOINC, SNOMED CT, or HGNC nomenclature for genomic markers.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerName rdf:type rdf:Property ;
    rdfs:label 'Biomarker Name' ;
    rdfs:comment 'The name of the biomarker or molecular marker being measured (e.g., PD-L1, EGFR, KRAS, HER2, TMB, MSI).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdxApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Cdx Approved Flag' ;
    rdfs:comment 'Indicates whether this biomarker assay is an FDA-approved or EMA-approved companion diagnostic (CDx) for a specific therapeutic indication.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdxDrugIndication rdf:type rdf:Property ;
    rdfs:label 'Cdx Drug Indication' ;
    rdfs:comment 'The specific drug and indication for which this companion diagnostic is approved (e.g., pembrolizumab for NSCLC with PD-L1 ≥50%).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutoffValue rdf:type rdf:Property ;
    rdfs:label 'Cutoff Value' ;
    rdfs:comment 'The threshold value used to determine positive vs negative result interpretation for this biomarker (e.g., PD-L1 ≥50% for pembrolizumab eligibility).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryCliaNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Clia Number' ;
    rdfs:comment 'The CLIA certification number of the testing laboratory, required for clinical diagnostic testing in the United States.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mutationType rdf:type rdf:Property ;
    rdfs:label 'Mutation Type' ;
    rdfs:comment 'The type of genetic mutation detected (e.g., missense, nonsense, frameshift, deletion, insertion, amplification, fusion).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'Indicates whether the biomarker assay passed internal quality control checks (e.g., passed, failed, not applicable).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceRangeLower rdf:type rdf:Property ;
    rdfs:label 'Reference Range Lower' ;
    rdfs:comment 'The lower bound of the normal or reference range for this biomarker, if applicable.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Reference Range Upper' ;
    rdfs:comment 'The upper bound of the normal or reference range for this biomarker, if applicable.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultDate rdf:type rdf:Property ;
    rdfs:label 'Result Date' ;
    rdfs:comment 'The date on which the biomarker result was finalized and reported by the laboratory.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resultInterpretation rdf:type rdf:Property ;
    rdfs:label 'Result Interpretation' ;
    rdfs:comment 'The clinical interpretation of the biomarker result (e.g., positive, negative, indeterminate, high, low, mutation detected, wild type). [ENUM-REF-CANDIDATE: positive|negative|indeterminate|high|low|normal|abnormal|mutation_detected|wild_type — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Specimen Collection Date' ;
    rdfs:comment 'The date on which the biological specimen was collected from the subject.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date on which the biomarker assay was performed by the laboratory.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'The name of the laboratory or Contract Research Organization (CRO) that performed the biomarker assay.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantAnnotation rdf:type rdf:Property ;
    rdfs:label 'Variant Annotation' ;
    rdfs:comment 'Detailed annotation of the genetic variant using HGVS nomenclature (e.g., c.2573T>G, p.L858R).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caregiverId rdf:type rdf:Property ;
    rdfs:label 'Caregiver Id' ;
    rdfs:comment 'Unique identifier for the caregiver or legally authorized representative (LAR) record. Primary key for the caregiver entity.' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternatePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Phone Number' ;
    rdfs:comment 'Secondary contact phone number for the caregiver. Provides backup communication channel for urgent trial-related matters.' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Authority Documentation Reference' ;
    rdfs:comment 'Reference number or identifier for the legal documentation establishing caregiver authority. Links to document management system for audit trail and regulatory inspection readiness.' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityDocumentationType rdf:type rdf:Property ;
    rdfs:label 'Authority Documentation Type' ;
    rdfs:comment 'Type of legal documentation establishing the caregiver\'s authority to act on behalf of the participant. Required for LAR validation and informed consent compliance.' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Authority Verification Date' ;
    rdfs:comment 'Date on which the caregiver\'s legal authority was verified by the trial site or patient support program administrator. Required for informed consent validity and audit compliance.' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorityVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Authority Verified By' ;
    rdfs:comment 'Name or identifier of the site personnel or program administrator who verified the caregiver\'s legal authority. Required for audit trail and regulatory compliance.' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caregiverStatus rdf:type rdf:Property ;
    rdfs:label 'Caregiver Status' ;
    rdfs:comment 'Current lifecycle status of the caregiver designation. Active indicates the caregiver is currently authorized; inactive indicates the designation has ended; pending verification indicates documentation is under review.' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentToContactFlag rdf:type rdf:Property ;
    rdfs:label 'Consent To Contact Flag' ;
    rdfs:comment 'Indicates whether the caregiver has provided consent to be contacted for trial updates, patient support programs, and adherence monitoring. True if consent given, False otherwise. Required for GDPR and privacy compliance.' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:larDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Lar Designation Flag' ;
    rdfs:comment 'Indicates whether this caregiver is formally designated as a legally authorized representative with authority to provide informed consent on behalf of the participant. True if LAR, False if supportive caregiver only.' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for the caregiver\'s preferred communication language. Required for informed consent delivery and patient support program materials in appropriate language.' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Created By' ;
    rdfs:comment 'User identifier or system account that created the caregiver record. Required for audit trail and accountability per GCP and 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'User identifier or system account that last updated the caregiver record. Required for audit trail and accountability per GCP and 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipToParticipant rdf:type rdf:Property ;
    rdfs:label 'Relationship To Participant' ;
    rdfs:comment 'Nature of the relationship between the caregiver and the participant. Critical for determining authority to consent and legal standing in pediatric, rare disease, and incapacitated patient populations. [ENUM-REF-CANDIDATE: parent|legal_guardian|spouse|domestic_partner|adult_child|sibling|healthcare_proxy|court_appointed_guardian — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Caregiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalObservationId rdf:type rdf:Property ;
    rdfs:label 'Clinical Observation Id' ;
    rdfs:comment 'Primary key for clinical_observation' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'Role or qualification of the person who performed or interpreted the observation (e.g., principal investigator, sub-investigator, central reviewer, laboratory technician, radiologist). [ENUM-REF-CANDIDATE: PRINCIPAL_INVESTIGATOR|SUB_INVESTIGATOR|CENTRAL_REVIEWER|LABORATORY_TECHNICIAN|RADIOLOGIST|PATHOLOGIST|OTHER — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerType rdf:type rdf:Property ;
    rdfs:label 'Biomarker Type' ;
    rdfs:comment 'Classification of biomarker (e.g., companion diagnostic (CDx), tumor mutational burden (TMB), programmed death-ligand 1 (PD-L1), microsatellite instability (MSI), pharmacogenomic (PGx) panel, circulating tumor DNA (ctDNA)). Applicable only to biomarker and genomic observations.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalEndpointType rdf:type rdf:Property ;
    rdfs:label 'Clinical Endpoint Type' ;
    rdfs:comment 'Type of clinical endpoint assessment (e.g., RECIST 1.1 tumor response, iRECIST, DAS28 disease activity score, ECOG performance status, Karnofsky performance status, quality of life (QoL) score). Applicable only to clinical endpoint observations.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDatetime rdf:type rdf:Property ;
    rdfs:label 'Collection Datetime' ;
    rdfs:comment 'Date and time when the specimen was collected or the observation was performed. Critical for pharmacokinetic (PK) and pharmacodynamic (PD) analysis and longitudinal trending.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deltaFromBaselineFlag rdf:type rdf:Property ;
    rdfs:label 'Delta From Baseline Flag' ;
    rdfs:comment 'Boolean flag indicating whether this observation represents a change from baseline value. True if this is a delta calculation, False if this is an absolute measurement. Used for longitudinal analysis and safety monitoring.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endpointResponse rdf:type rdf:Property ;
    rdfs:label 'Endpoint Response' ;
    rdfs:comment 'Categorical response or outcome for clinical endpoint assessments (e.g., complete response (CR), partial response (PR), stable disease (SD), progressive disease (PD) for RECIST; remission, relapse for DAS28). Uses standardized response criteria.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryIdentifier rdf:type rdf:Property ;
    rdfs:label 'Laboratory Identifier' ;
    rdfs:comment 'Unique identifier for the laboratory or assay vendor (e.g., CLIA number, CAP accreditation number, vendor assay catalog ID). Used for traceability and regulatory submissions.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the laboratory, imaging center, or facility that performed the test or assessment. Used for quality control and result reconciliation.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mutationDetected rdf:type rdf:Property ;
    rdfs:label 'Mutation Detected' ;
    rdfs:comment 'Specific genetic mutation or variant detected (e.g., EGFR L858R, KRAS G12C, BRCA1 c.68_69delAG). Uses HGVS (Human Genome Variation Society) nomenclature for precision.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfRangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Out Of Range Indicator' ;
    rdfs:comment 'Flag indicating whether the result is within, above, or below the reference range. Critical for safety monitoring and adverse event (AE) detection.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedDatetime rdf:type rdf:Property ;
    rdfs:label 'Record Created Datetime' ;
    rdfs:comment 'Timestamp when this observation record was first created in the source system. Used for audit trail and data lineage tracking per Good Clinical Practice (GCP) and 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedDatetime rdf:type rdf:Property ;
    rdfs:label 'Record Updated Datetime' ;
    rdfs:comment 'Timestamp when this observation record was last modified in the source system. Used for audit trail and change tracking per Good Clinical Practice (GCP) and 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultValueText rdf:type rdf:Property ;
    rdfs:label 'Result Value Text' ;
    rdfs:comment 'Text or categorical result value for qualitative observations (e.g., positive/negative, normal/abnormal, gene mutation detected). Used when result is not numeric.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCode rdf:type rdf:Property ;
    rdfs:label 'Test Code' ;
    rdfs:comment 'Standardized code for the test or assessment. Typically LOINC code for laboratory tests, SNOMED CT for clinical findings, or proprietary assay identifier for genomic tests.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCodeSystem rdf:type rdf:Property ;
    rdfs:label 'Test Code System' ;
    rdfs:comment 'The coding system or terminology used for the test_code field. Identifies the standard vocabulary (LOINC, SNOMED CT, CDISC controlled terminology, or proprietary assay catalog).' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concomitantMedicationId rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication Id' ;
    rdfs:comment 'Unique identifier for the concomitant medication record. Primary key for this entity.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dose rdf:type rdf:Property ;
    rdfs:label 'Dose' ;
    rdfs:comment 'The numeric dose amount of the concomitant medication administered per administration event. Used with dose_unit to specify complete dosing information.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicationClass rdf:type rdf:Property ;
    rdfs:label 'Medication Class' ;
    rdfs:comment 'The therapeutic or pharmacological class of the concomitant medication (e.g., antibiotic, antihypertensive, analgesic, anticoagulant). Used for safety signal detection and drug-drug interaction screening.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ongoingFlag rdf:type rdf:Property ;
    rdfs:label 'Ongoing Flag' ;
    rdfs:comment 'Boolean indicator of whether the concomitant medication is still being taken by the subject at the time of data capture or database lock. True if ongoing, False if stopped.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorToStudyFlag rdf:type rdf:Property ;
    rdfs:label 'Prior To Study Flag' ;
    rdfs:comment 'Boolean indicator of whether the concomitant medication was started before the subject enrolled in the clinical trial. True if started prior, False if started during study.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prohibitedConcomitantFlag rdf:type rdf:Property ;
    rdfs:label 'Prohibited Concomitant Flag' ;
    rdfs:comment 'Boolean indicator of whether the concomitant medication is prohibited per the clinical trial protocol. True if prohibited, False if allowed. Critical for protocol deviation tracking.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipToAe rdf:type rdf:Property ;
    rdfs:label 'Relationship To Ae' ;
    rdfs:comment 'Investigator assessment of the relationship between the concomitant medication and any reported adverse event. Used for causality assessment in pharmacovigilance.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopDate rdf:type rdf:Property ;
    rdfs:label 'Stop Date' ;
    rdfs:comment 'The date on which the subject stopped taking the concomitant medication. Null if medication is ongoing at time of data capture.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:whoDrugCode rdf:type rdf:Property ;
    rdfs:label 'Who Drug Code' ;
    rdfs:comment 'Standardized WHO Drug Dictionary code for the concomitant medication. Used for global pharmacovigilance reporting and drug-drug interaction analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisId rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Id' ;
    rdfs:comment 'Unique identifier for the diagnosis record. Primary key for the diagnosis entity.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:masterdataOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: Diagnosis adjudication is performed by organizational units (medical affairs, independent review committee) for endpoint assessment, eligibility confirmation, and medical monitoring. Essential for cli' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:anatomicalLocation rdf:type rdf:Property ;
    rdfs:label 'Anatomical Location' ;
    rdfs:comment 'Anatomical site or body system affected by the diagnosis (e.g., lung, liver, central nervous system). May use standardized anatomical terminology.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerSubtype rdf:type rdf:Property ;
    rdfs:label 'Biomarker Subtype' ;
    rdfs:comment 'Molecular or biomarker-defined subtype of the disease (e.g., HER2-positive, EGFR-mutant, PD-L1 high). Used for precision medicine and stratification.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Classification of the diagnosis: pre_existing (medical history prior to study), primary (main study indication), secondary (additional study-relevant diagnosis), comorbidity (concurrent condition), surgical (surgical history), family_history (familial condition).' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisDate rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Date' ;
    rdfs:comment 'Date when the diagnosis was formally assessed or recorded in the study or medical record. May differ from onset_date.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diagnosisMethod rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Method' ;
    rdfs:comment 'Method by which the diagnosis was established: histological (biopsy/pathology), clinical (physical exam/symptoms), radiological (imaging), laboratory (lab tests), genetic (molecular testing), autopsy, self_reported. [ENUM-REF-CANDIDATE: histological|clinical|radiological|laboratory|genetic|autopsy|self_reported — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseStage rdf:type rdf:Property ;
    rdfs:label 'Disease Stage' ;
    rdfs:comment 'Stage or grade of the disease at diagnosis. May include TNM staging for oncology (e.g., T2N1M0), ECOG Performance Status, NYHA class, or other disease-specific staging systems.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecogPerformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Ecog Performance Status' ;
    rdfs:comment 'ECOG Performance Status score at the time of diagnosis (0-5 scale). 0=fully active, 5=dead. Used for patient functional assessment in oncology trials.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:familyMemberRelationship rdf:type rdf:Property ;
    rdfs:label 'Family Member Relationship' ;
    rdfs:comment 'Relationship of the family member with the diagnosis (for family_history condition_type only). Null for non-family-history diagnoses. [ENUM-REF-CANDIDATE: parent|sibling|child|grandparent|aunt_uncle|cousin|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:histologyType rdf:type rdf:Property ;
    rdfs:label 'Histology Type' ;
    rdfs:comment 'Histological or pathological classification of the disease (e.g., adenocarcinoma, squamous cell carcinoma, diffuse large B-cell lymphoma). Applicable primarily to oncology diagnoses.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd 10 Code' ;
    rdfs:comment 'ICD-10 diagnosis code representing the condition. Standard medical classification system used for billing, epidemiology, and health management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laterality rdf:type rdf:Property ;
    rdfs:label 'Laterality' ;
    rdfs:comment 'Laterality of the diagnosis for paired organs or structures: left, right, bilateral, not_applicable.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Code' ;
    rdfs:comment 'MedDRA Lowest Level Term (LLT) or Preferred Term (PT) code for the diagnosis. Used for regulatory reporting and pharmacovigilance.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraTerm rdf:type rdf:Property ;
    rdfs:label 'Meddra Term' ;
    rdfs:comment 'MedDRA Preferred Term (PT) text description of the diagnosis.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorTreatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Treatment Flag' ;
    rdfs:comment 'Indicates whether the patient received prior treatment for this condition before study enrollment or current assessment. True if prior treatment exists.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipToStudyIndication rdf:type rdf:Property ;
    rdfs:label 'Relationship To Study Indication' ;
    rdfs:comment 'Indicates whether this diagnosis is the primary study indication, related to the study indication, unrelated, or unknown. Used for eligibility and stratification.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatim rdf:type rdf:Property ;
    rdfs:label 'Verbatim' ;
    rdfs:comment 'Free-text verbatim description of the diagnosis as reported by the investigator, physician, or patient. Original uncoded term.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Endpoint Assessment Id' ;
    rdfs:comment 'Primary key for endpoint_assessment' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorAssessmentEndpointAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Prior Assessment Endpoint Assessment Id' ;
    rdfs:comment 'Reference to the previous endpoint assessment record for this subject and endpoint type, enabling longitudinal tracking and progression analysis.' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EndpointAssessment .

ind:assessmentCategory rdf:type rdf:Property ;
    rdfs:label 'Assessment Category' ;
    rdfs:comment 'High-level category of the endpoint assessment: tumor response, disease activity score, functional status, quality of life, biomarker measurement, or imaging-based assessment.' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCompletionFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Completion Flag' ;
    rdfs:comment 'Boolean indicator of whether the endpoint assessment was successfully completed (True) or not completed (False).' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentName rdf:type rdf:Property ;
    rdfs:label 'Assessment Name' ;
    rdfs:comment 'Standardized name of the clinical assessment or measurement being performed (e.g., RECIST 1.1 Tumor Assessment, ECOG Performance Status, DAS28 Score).' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTime rdf:type rdf:Property ;
    rdfs:label 'Assessment Time' ;
    rdfs:comment 'Precise timestamp when the endpoint assessment was performed, including time of day for time-sensitive measurements.' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:centralReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Central Review Flag' ;
    rdfs:comment 'Boolean indicator of whether this assessment underwent independent central review or adjudication (True) or was site-assessed only (False).' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:centralReviewResult rdf:type rdf:Property ;
    rdfs:label 'Central Review Result' ;
    rdfs:comment 'Result or interpretation provided by the independent central review committee, if central review was performed.' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeFromBaseline rdf:type rdf:Property ;
    rdfs:label 'Change From Baseline' ;
    rdfs:comment 'Calculated change in the endpoint measurement from the baseline value. Positive or negative values indicate improvement or worsening depending on the endpoint.' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluability Status' ;
    rdfs:comment 'Determination of whether this assessment is evaluable for efficacy analysis per protocol criteria (evaluable, non-evaluable, or pending adjudication).' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonEvaluabilityReason rdf:type rdf:Property ;
    rdfs:label 'Non Evaluability Reason' ;
    rdfs:comment 'Reason why the assessment was deemed non-evaluable for efficacy analysis (e.g., poor image quality, missing baseline, major protocol violation).' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notDoneReason rdf:type rdf:Property ;
    rdfs:label 'Not Done Reason' ;
    rdfs:comment 'Reason why the scheduled endpoint assessment was not performed (e.g., subject withdrawal, adverse event, equipment failure, protocol deviation).' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Description' ;
    rdfs:comment 'Detailed description of the protocol deviation related to this endpoint assessment, if applicable.' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultCategory rdf:type rdf:Property ;
    rdfs:label 'Result Category' ;
    rdfs:comment 'Categorical interpretation of the assessment result. For oncology: CR (Complete Response), PR (Partial Response), SD (Stable Disease), PD (Progressive Disease), NE (Not Evaluable). For other therapeutic areas: remission, response, non-response, improvement, worsening.' ;
    rdfs:domain ind:EndpointAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentId rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Id' ;
    rdfs:comment 'Primary key for informed_consent' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentingInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Consenting Investigator Id' ;
    rdfs:comment 'Unique identifier for the principal investigator or sub-investigator who obtained the informed consent. Applicable for clinical trial consents.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:econsentDocumentId rdf:type rdf:Property ;
    rdfs:label 'Econsent Document Id' ;
    rdfs:comment 'Unique document identifier or reference number from the eConsent platform. Used for audit trail and document retrieval. Null for paper consents.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EconsentDocument .

ind:biomarkerSubstudyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Biomarker Substudy Consent Flag' ;
    rdfs:comment 'Indicates whether the patient consented to participate in biomarker or translational research sub-studies. True if consented, False if declined or not applicable.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCategory rdf:type rdf:Property ;
    rdfs:label 'Consent Category' ;
    rdfs:comment 'Category of consent record. Distinguishes between clinical informed consent (ICF), re-consent events, consent withdrawals, GDPR privacy consent, HIPAA authorization, and data sharing consent.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'Channel or interface through which consent was captured. Distinguishes between web portal, mobile app, paper form, in-person at site, telephonic, or email.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Document Url' ;
    rdfs:comment 'URL or file path to the signed consent document stored in the document management system (e.g., Veeva Vault, eTMF). Used for regulatory inspection readiness.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'Date when the consent expires or is no longer valid. Null for consents without expiration. Applicable for time-limited privacy consents or trial-specific consents.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedDate rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Date' ;
    rdfs:comment 'Date when the informed consent was obtained from the patient or legally authorized representative (LAR). Primary business event timestamp for consent lifecycle.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Timestamp' ;
    rdfs:comment 'Precise timestamp when consent was obtained. Used for eConsent systems and audit trail. Complements consent_obtained_date with time-of-day precision.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentPurpose rdf:type rdf:Property ;
    rdfs:label 'Consent Purpose' ;
    rdfs:comment 'Specific purpose for which consent was obtained. Examples: clinical_trial_participation, data_processing, research, marketing, data_sharing, pharmacovigilance, patient_support_program. Free-text or controlled vocabulary.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSignatureMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Signature Method' ;
    rdfs:comment 'Method by which the patient or LAR signed the consent. Examples: wet_signature (ink on paper), electronic_signature, digital_signature (PKI-based), biometric, verbal_recorded.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentWithdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawal Date' ;
    rdfs:comment 'Date when the patient withdrew consent. Null if consent has not been withdrawn. Critical for GCP compliance and data subject rights.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSubjectRightsFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Fulfillment Date' ;
    rdfs:comment 'Date when the data subject rights request was fulfilled or completed. Null if request is pending or no request exists.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSubjectRightsRequestDate rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Request Date' ;
    rdfs:comment 'Date when the data subject rights request was received. Null if no request. Critical for GDPR compliance (30-day response requirement).' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSubjectRightsRequestType rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Request Type' ;
    rdfs:comment 'Type of data subject rights request associated with this consent record. Examples: access, erasure, portability, rectification, restriction, objection. Null if no request. Applicable for GDPR compliance.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:futureUseConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Future Use Consent Flag' ;
    rdfs:comment 'Indicates whether the patient consented to future use of their data or biological samples for research purposes beyond the current study. True if consented, False if declined.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'GDPR Article 6 or Article 9 lawful basis for processing personal data. Examples: consent, legitimate_interest, legal_obligation, vital_interests, public_task, explicit_consent_special_category. Applicable for EU/EEA patients.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneticSubstudyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Genetic Substudy Consent Flag' ;
    rdfs:comment 'Indicates whether the patient consented to participate in genetic or genomic sub-studies. True if consented, False if declined or not applicable.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Flag' ;
    rdfs:comment 'Indicates whether HIPAA authorization was obtained for use and disclosure of protected health information (PHI). True if authorization obtained, False if not applicable or declined. Applicable for US patients.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icfVersion rdf:type rdf:Property ;
    rdfs:label 'Icf Version' ;
    rdfs:comment 'Version number or identifier of the informed consent form document used. Critical for regulatory traceability and protocol amendment tracking. Applicable for clinical trial consents.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reConsentReason rdf:type rdf:Property ;
    rdfs:label 'Re Consent Reason' ;
    rdfs:comment 'Reason for re-consenting the patient. Examples: protocol_amendment, new_safety_information, icf_version_update, regulatory_requirement. Applicable when consent_category is re_consent.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalScope rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Scope' ;
    rdfs:comment 'Scope of consent withdrawal. Indicates whether patient withdrew from entire study, data use only, biological sample use only, or future contact. Critical for GCP compliance.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Full name of the impartial witness who observed the consent process. Required when patient or LAR cannot read, or as per local regulations.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Date' ;
    rdfs:comment 'Date when the impartial witness signed the informed consent form. Null if no witness was required.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the patient\'s residential address. Used for patient contact, investigational product shipment, and patient support services. Protected health information (PHI).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the patient\'s residential address (apartment, suite, unit number). Optional field for complete address capture.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsSubjectNumber rdf:type rdf:Property ;
    rdfs:label 'Ctms Subject Number' ;
    rdfs:comment 'Subject identifier assigned by the Clinical Trial Management System (Oracle Clinical or Siebel CTMS). Used to link patient records to clinical trial enrollment and visit data.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassificationLevel rdf:type rdf:Property ;
    rdfs:label 'Data Classification Level' ;
    rdfs:comment 'Classification level of the patient record based on sensitivity and regulatory requirements. Determines access controls and handling procedures.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent Flag' ;
    rdfs:comment 'Indicates whether the patient has provided consent for data processing and sharing under GDPR and HIPAA regulations. True if consent obtained, false otherwise.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuationReason rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Reason' ;
    rdfs:comment 'Reason for patient discontinuation from clinical trial or patient support program. Critical for safety analysis and protocol deviation tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcSubjectNumber rdf:type rdf:Property ;
    rdfs:label 'Edc Subject Number' ;
    rdfs:comment 'Patient identifier in the Electronic Data Capture system (Medidata Rave). Links patient to case report forms (CRFs) and clinical trial data collection.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehrMrn rdf:type rdf:Property ;
    rdfs:label 'Ehr Mrn' ;
    rdfs:comment 'Medical record number from external electronic health record systems. Used for real-world data (RWD) integration and health economics outcomes research (HEOR).' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethnicity rdf:type rdf:Property ;
    rdfs:label 'Ethnicity' ;
    rdfs:comment 'Self-reported ethnicity of the patient. Required for clinical trial diversity reporting and subgroup analysis per FDA and EMA guidelines.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'Self-identified gender of the patient. Captured separately from biological sex to support inclusive clinical research and patient-centered care.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpid rdf:type rdf:Property ;
    rdfs:label 'Gpid' ;
    rdfs:comment 'Global patient identifier used across all systems and geographies to uniquely identify a patient. Pseudonymized token for cross-system linkage while maintaining HIPAA and GDPR compliance.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Status' ;
    rdfs:comment 'Status of informed consent for clinical trial participation or data usage. Critical for GCP compliance and patient rights protection.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpiToken rdf:type rdf:Property ;
    rdfs:label 'Mpi Token' ;
    rdfs:comment 'Master patient index linkage token used to resolve patient identity across disparate source systems. Enables patient matching and deduplication while preserving privacy.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'Nationality of the patient represented as ISO 3166-1 alpha-3 country code. Used for regulatory reporting and cross-border clinical trial management.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientStatus rdf:type rdf:Property ;
    rdfs:label 'Patient Status' ;
    rdfs:comment 'Current lifecycle status of the patient in clinical trials or patient support programs. Tracks patient engagement and follow-up requirements.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'Primary language spoken by the patient. Used for informed consent delivery, patient communication, and patient-reported outcomes (PRO) instrument selection.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pseudonymizationToken rdf:type rdf:Property ;
    rdfs:label 'Pseudonymization Token' ;
    rdfs:comment 'Pseudonymized identifier used to protect patient identity in research datasets and analytics. Enables HIPAA and GDPR compliant data sharing while maintaining linkability.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvCasePatientReference rdf:type rdf:Property ;
    rdfs:label 'Pv Case Patient Reference' ;
    rdfs:comment 'Patient identifier in the pharmacovigilance safety reporting system (Argus Safety or Oracle AERS). Links patient to adverse event reports and ICSRs.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:race rdf:type rdf:Property ;
    rdfs:label 'Race' ;
    rdfs:comment 'Self-reported race of the patient. Required for clinical trial diversity reporting and subgroup safety and efficacy analysis per FDA and EMA guidelines.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sex rdf:type rdf:Property ;
    rdfs:label 'Sex' ;
    rdfs:comment 'Biological sex assigned at birth. Used for clinical trial eligibility, safety analysis, and pharmacokinetic (PK) / pharmacodynamic (PD) assessments.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyPharmacyCode rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Code' ;
    rdfs:comment 'Patient identifier in specialty pharmacy and patient support program systems. Used for copay assistance, adherence monitoring, and patient services.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Patient Enrollment Id' ;
    rdfs:comment 'Unique identifier for the patient enrollment record. Primary key for this entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatientEnrollment .

ind:enrollmentId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Id' ;
    rdfs:comment 'Unique identifier for this patient support program enrollment record. Primary key.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalEnrollment .

ind:investigationalCompoundId rdf:type rdf:Property ;
    rdfs:label 'Investigational Compound Id' ;
    rdfs:comment 'Foreign key linking to discovery.compound. Business justification: Clinical trials test discovery compounds in patients. Translational medicine requires tracking which investigational compound (IND-enabling candidate) each patient received. Essential for efficacy/saf' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:registryId rdf:type rdf:Property ;
    rdfs:label 'Registry Id' ;
    rdfs:comment 'Foreign key linking to patient.registry. Business justification: Patient enrollments can be for clinical trials OR patient registries. The existing trial_id FK handles clinical trial enrollments, but registry enrollments need a separate FK to link to the registry m' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:supportProgramId rdf:type rdf:Property ;
    rdfs:label 'Support Program Id' ;
    rdfs:comment 'Foreign key linking to the patient support program in which the patient is enrolled' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupportProgram .

ind:benefitAmountReceived rdf:type rdf:Property ;
    rdfs:label 'Benefit Amount Received' ;
    rdfs:comment 'Cumulative financial assistance amount (in USD) that this specific patient has received through this specific program enrollment. Tracked for benefit cap enforcement, Sunshine Act reporting, and program ROI analysis.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cohortIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cohort Identifier' ;
    rdfs:comment 'Identifier for the enrollment cohort or wave. Used in dose-escalation studies, adaptive trials, or phased enrollment programs to track enrollment groups.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentToProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Consent To Program Flag' ;
    rdfs:comment 'Indicates whether the patient has provided informed consent specific to this program\'s data collection, communication, and benefit processing. Separate from general clinical trial consent. Required for HIPAA compliance and program operations.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disenrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Date' ;
    rdfs:comment 'Date when the patient was disenrolled from this support program. Null for active enrollments. Used for benefit period closure and retention analytics.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disenrollmentReason rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Reason' ;
    rdfs:comment 'Reason code or description for why the patient was disenrolled from this program (e.g., treatment completed, patient request, insurance change to government payer, benefit maximum reached, non-compliance). Critical for retention analysis and program optimization.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionEventType rdf:type rdf:Property ;
    rdfs:label 'Disposition Event Type' ;
    rdfs:comment 'Type of disposition event that ended or changed the patients enrollment status: completed (finished protocol per plan), withdrawn (voluntary or investigator-initiated discontinuation), lost_to_followup (contact lost), death (patient died), screen_failure (did not meet eligibility), protocol_deviation (removed due to protocol violation).' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionPrimaryReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Primary Reason' ;
    rdfs:comment 'Primary reason code for the disposition event. Standardized per CDISC Controlled Terminology (e.g., adverse event, lack of efficacy, protocol violation, patient decision, lost to follow-up, death, completed per protocol).' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionSecondaryReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Secondary Reason' ;
    rdfs:comment 'Secondary or contributing reason code for the disposition event. Provides additional context beyond the primary reason.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Type of enrollment program: clinical_trial (interventional study), support_program (patient assistance program), registry (observational registry), expanded_access (pre-approval access), compassionate_use (emergency use).' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the last documented contact with the patient. Used for tracking lost-to-follow-up and vital status.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDoseDate rdf:type rdf:Property ;
    rdfs:label 'Last Dose Date' ;
    rdfs:comment 'Date the patient received their last dose of investigational product. Critical for safety follow-up and disposition tracking.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Patient Enrollment Date' ;
    rdfs:comment 'Date when the patient was enrolled in this specific support program. Critical for program eligibility, benefit period calculation, and compliance reporting.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Patient Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of this enrollment. Tracks progression from pending through active participation to completion or disenrollment. Used for operational reporting and benefit eligibility determination.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Method' ;
    rdfs:comment 'Patient\'s preferred method of contact for communications related to this specific program enrollment. May differ from general patient contact preferences.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Population Flag' ;
    rdfs:comment 'Boolean flag indicating whether the patient is included in the safety analysis population. Typically true if the patient received at least one dose of investigational product.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentArm rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm' ;
    rdfs:comment 'Treatment arm or cohort to which the patient was assigned (e.g., active drug, placebo, dose level, combination therapy). May be coded to maintain blinding.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationId rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Id' ;
    rdfs:comment 'Primary key for protocol_deviation' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Date' ;
    rdfs:comment 'The date on which corrective action was implemented to address the protocol deviation.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of the immediate corrective action taken to address the protocol deviation and prevent recurrence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationDate rdf:type rdf:Property ;
    rdfs:label 'Deviation Date' ;
    rdfs:comment 'The date on which the protocol deviation occurred or was identified to have occurred.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deviationStatus rdf:type rdf:Property ;
    rdfs:label 'Deviation Status' ;
    rdfs:comment 'Current lifecycle status of the protocol deviation record: open (newly identified), under review (being investigated), closed (resolved and documented), or pending CAPA (awaiting corrective action completion).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedBy rdf:type rdf:Property ;
    rdfs:label 'Identified By' ;
    rdfs:comment 'Name or role of the individual who identified or discovered the protocol deviation (e.g., site coordinator, clinical research associate, principal investigator).' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnDataIntegrity rdf:type rdf:Property ;
    rdfs:label 'Impact On Data Integrity' ;
    rdfs:comment 'Assessment of the protocol deviation\'s impact on the reliability and validity of clinical trial data: none, low, moderate, or high.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnSubjectSafety rdf:type rdf:Property ;
    rdfs:label 'Impact On Subject Safety' ;
    rdfs:comment 'Assessment of the protocol deviation\'s impact on the safety and well-being of the trial participant: none, low, moderate, or high.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportability Flag' ;
    rdfs:comment 'Indicates whether the protocol deviation is reportable to regulatory authorities (FDA, EMA, etc.) based on severity and impact criteria. True if reportable, False if not.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or role of the individual who reviewed and assessed the protocol deviation for severity and impact.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Documented analysis of the underlying root cause(s) that led to the protocol deviation, used to inform preventive actions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'Classification of the deviation severity: major (significant impact on subject safety or data integrity), minor (minimal impact), or critical (immediate threat to subject safety or trial integrity).' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference to the source document or record in the originating system (e.g., Veeva Vault document ID, Medidata Rave form ID) for audit trail purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEnrollment rdf:type rdf:Property ;
    rdfs:label 'Current Enrollment' ;
    rdfs:comment 'Current number of participants actively enrolled in the registry as of the last update.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataCollectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Collection Frequency' ;
    rdfs:comment 'Frequency at which data is collected from registry participants. Continuous indicates real-time or near-real-time collection; event-driven indicates collection triggered by specific clinical events. [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|annually|event_driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Primary method used to collect registry data. EDC: electronic data capture systems; Medical records: chart review and abstraction; Patient reported: direct from participants; Claims: insurance/billing data; Hybrid: multiple methods.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcSystem rdf:type rdf:Property ;
    rdfs:label 'Edc System' ;
    rdfs:comment 'Name of the electronic data capture system or platform used for registry data collection (e.g., Medidata Rave, Oracle Clinical, REDCap).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliance Flag' ;
    rdfs:comment 'Indicates whether the registry is subject to and compliant with EU GDPR regulations for personal data protection (True) or not applicable (False).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingAuthority rdf:type rdf:Property ;
    rdfs:label 'Governing Authority' ;
    rdfs:comment 'Primary regulatory authority that oversees or mandates the registry. Multiple indicates oversight by more than one regulatory body. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|multiple — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Compliance Flag' ;
    rdfs:comment 'Indicates whether the registry is subject to and compliant with HIPAA regulations for protected health information (True) or not applicable (False).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:informedConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Required' ;
    rdfs:comment 'Indicates whether participants must provide informed consent to participate in the registry (True) or consent is waived (False).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Required' ;
    rdfs:comment 'Indicates whether the registry requires Institutional Review Board or Ethics Committee approval (True) or is exempt (False).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the individual responsible for operational management and day-to-day administration of the registry.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Anticipated date for completion of all registry activities including final data collection and analysis. May be null for indefinite registries.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Name' ;
    rdfs:comment 'Name of the principal investigator or lead researcher responsible for the scientific conduct of the registry.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Protocol Effective Date' ;
    rdfs:comment 'Date when the current version of the registry protocol became effective.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registryCode rdf:type rdf:Property ;
    rdfs:label 'Registry Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the registry for internal tracking and cross-system reference.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryName rdf:type rdf:Property ;
    rdfs:label 'Registry Name' ;
    rdfs:comment 'Official name of the patient registry as registered with regulatory authorities and used in protocol documentation.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryStatus rdf:type rdf:Property ;
    rdfs:label 'Registry Status' ;
    rdfs:comment 'Current operational status of the registry. Planning: protocol development phase; Active: operational and collecting data; Enrolling: actively recruiting participants; Closed to enrollment: no new participants but follow-up continues; Completed: all data collection finished; Terminated: ended prematurely; Suspended: temporarily paused. [ENUM-REF-CANDIDATE: planning|active|enrolling|closed_to_enrollment|completed|terminated|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryType rdf:type rdf:Property ;
    rdfs:label 'Registry Type' ;
    rdfs:comment 'Classification of the registry based on its primary purpose and regulatory mandate. Disease registries track natural history of specific conditions; pregnancy registries monitor maternal and fetal outcomes; PASS registries fulfill post-marketing safety commitments; REMS registries are mandated by Risk Evaluation and Mitigation Strategy programs.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether the registry is mandated by a regulatory authority as a condition of drug approval or post-marketing requirement (True) or is voluntary/observational (False).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsoringOrganization rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Organization' ;
    rdfs:comment 'Name of the pharmaceutical company, research institution, or consortium that sponsors and funds the registry.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEnrollment rdf:type rdf:Property ;
    rdfs:label 'Target Enrollment' ;
    rdfs:comment 'Planned total number of participants to be enrolled in the registry as specified in the protocol.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportedOutcomeId rdf:type rdf:Property ;
    rdfs:label 'Reported Outcome Id' ;
    rdfs:comment 'Primary key for reported_outcome' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Window End Date' ;
    rdfs:comment 'End date of the protocol-defined assessment window during which the PRO should be completed. Used to determine compliance with the study schedule.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Window Start Date' ;
    rdfs:comment 'Start date of the protocol-defined assessment window during which the PRO should be completed. Used to determine compliance with the study schedule.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Flag' ;
    rdfs:comment 'Indicates whether this PRO assessment represents the baseline measurement collected before the start of investigational product administration. True indicates baseline assessment; False indicates post-baseline assessment.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicallyMeaningfulChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Clinically Meaningful Change Flag' ;
    rdfs:comment 'Indicates whether the change in PRO score from baseline or previous assessment meets the threshold for clinically meaningful change as defined by the instrument validation studies or regulatory guidance. True indicates clinically meaningful change; False indicates change below the threshold.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionMethod rdf:type rdf:Property ;
    rdfs:label 'Completion Method' ;
    rdfs:comment 'Method or modality by which the patient completed the PRO instrument (e.g., ePRO electronic system, paper questionnaire, telephone interview, mobile app, web portal). Important for data quality assessment and regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Status of the PRO assessment completion. Indicates whether the instrument was fully completed, partially completed, not done, missed, or deferred to a later timepoint.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the patient completed the PRO instrument. Provides granular temporal data for ePRO systems and compliance monitoring.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the PRO assessment was completed within the protocol-specified timeframe and according to the study procedures. True indicates compliant completion; False indicates non-compliance or protocol deviation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:domainName rdf:type rdf:Property ;
    rdfs:label 'Domain Name' ;
    rdfs:comment 'Name of the health domain or subscale measured by this outcome (e.g., Physical Functioning, Emotional Well-being, Pain, Fatigue, Social Functioning). Represents the specific aspect of quality of life being assessed.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentName rdf:type rdf:Property ;
    rdfs:label 'Instrument Name' ;
    rdfs:comment 'Name of the validated patient-reported outcome instrument or questionnaire used to collect this data (e.g., EQ-5D, FACT-G, SF-36, PROMIS, EORTC QLQ-C30).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentVersion rdf:type rdf:Property ;
    rdfs:label 'Instrument Version' ;
    rdfs:comment 'Version number or edition of the PRO instrument used (e.g., EQ-5D-5L, SF-36v2). Critical for ensuring consistency and comparability of results across timepoints and studies.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemIdentifier rdf:type rdf:Property ;
    rdfs:label 'Item Identifier' ;
    rdfs:comment 'Unique identifier for the specific question or item within the PRO instrument (e.g., Q1, Q2, Item_3). Used to map individual responses to the instrument structure.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemText rdf:type rdf:Property ;
    rdfs:label 'Item Text' ;
    rdfs:comment 'Full text of the question or item presented to the patient. Provides context for interpreting the response value.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingItemsCount rdf:type rdf:Property ;
    rdfs:label 'Missing Items Count' ;
    rdfs:comment 'Number of items within the PRO instrument that were not answered by the patient. Used to assess data completeness and determine whether the instrument can be scored according to its validation rules.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseLabel rdf:type rdf:Property ;
    rdfs:label 'Response Label' ;
    rdfs:comment 'Human-readable label corresponding to the response value (e.g., Not at all, A little bit, Moderately, Quite a bit, Extremely). Provides semantic meaning to numeric or coded responses.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseValue rdf:type rdf:Property ;
    rdfs:label 'Response Value' ;
    rdfs:comment 'Raw response value provided by the patient for this specific item. May be numeric, categorical, or free-text depending on the instrument design.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscaleScore rdf:type rdf:Property ;
    rdfs:label 'Subscale Score' ;
    rdfs:comment 'Score calculated for a specific domain or subscale within the PRO instrument (e.g., Physical Component Score, Mental Component Score). Allows granular analysis of specific health dimensions.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalScore rdf:type rdf:Property ;
    rdfs:label 'Total Score' ;
    rdfs:comment 'Overall composite score calculated from all items in the PRO instrument. Represents the aggregate quality of life or health status measure. Calculation methodology is instrument-specific.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adherenceDataSource rdf:type rdf:Property ;
    rdfs:label 'Adherence Data Source' ;
    rdfs:comment 'Primary source of medication adherence data for programs with adherence monitoring enabled. [ENUM-REF-CANDIDATE: specialty_pharmacy|epro|connected_device|patient_reported|claims_data|mixed|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adherenceMonitoringEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Adherence Monitoring Enabled Flag' ;
    rdfs:comment 'Indicates whether this program includes medication adherence tracking and intervention services.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialPayerOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Payer Only Flag' ;
    rdfs:comment 'Indicates whether the program is restricted to commercial insurance patients only (true) or allows government payer patients (false). Copay programs must exclude government payers per Anti-Kickback Statute.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'Primary email address for program inquiries and patient support communications.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Primary toll-free or direct phone number for patients and healthcare providers (HCPs) to contact the support program.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyClassification rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Classification' ;
    rdfs:comment 'Classification level for patient data collected and processed through this support program under HIPAA and GDPR requirements.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentMethod rdf:type rdf:Property ;
    rdfs:label 'Enrollment Method' ;
    rdfs:comment 'Primary method(s) by which patients can enroll in the support program.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nurseEducatorSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Nurse Educator Support Flag' ;
    rdfs:comment 'Indicates whether the program provides dedicated nurse educator support for patient education and clinical guidance.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalVendorName rdf:type rdf:Property ;
    rdfs:label 'Operational Vendor Name' ;
    rdfs:comment 'Name of the third-party vendor or hub services provider contracted to administer the patient support program operations.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthorizationSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Support Flag' ;
    rdfs:comment 'Indicates whether the program assists patients and providers with insurance prior authorization processes.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reimbursementSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Support Flag' ;
    rdfs:comment 'Indicates whether the program provides reimbursement navigation and claims appeal support services.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyPharmacyNetwork rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Network' ;
    rdfs:comment 'Names of specialty pharmacy partners integrated with this patient support program for coordinated dispensing and adherence tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBenefitDisbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Benefit Disbursed Amount' ;
    rdfs:comment 'Cumulative financial assistance amount (in USD) disbursed through this program since inception for copay assistance programs.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorContractNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Number' ;
    rdfs:comment 'Contract reference number for the agreement with the operational vendor managing this program.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentExposureId rdf:type rdf:Property ;
    rdfs:label 'Treatment Exposure Id' ;
    rdfs:comment 'Unique identifier for the treatment exposure record. Primary key for this entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentExposure .

ind:administeredBy rdf:type rdf:Property ;
    rdfs:label 'Administered By' ;
    rdfs:comment 'Name or identifier of the healthcare professional (HCP) who administered the investigational product.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrationDate rdf:type rdf:Property ;
    rdfs:label 'Administration Date' ;
    rdfs:comment 'Calendar date on which the investigational product was administered to the subject.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:administrationSite rdf:type rdf:Property ;
    rdfs:label 'Administration Site' ;
    rdfs:comment 'Anatomical site or location where the investigational product was administered (e.g., left arm, right thigh, abdomen). Relevant for injectable and topical routes.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrationTime rdf:type rdf:Property ;
    rdfs:label 'Administration Time' ;
    rdfs:comment 'Precise date and time when the investigational product was administered. Critical for pharmacokinetic (PK) and pharmacodynamic (PD) analysis.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:concomitantMedicationFlag rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication Flag' ;
    rdfs:comment 'Indicator whether the subject was taking other concomitant medications at the time of this treatment exposure. Important for drug-drug interaction analysis.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeDose rdf:type rdf:Property ;
    rdfs:label 'Cumulative Dose' ;
    rdfs:comment 'Total cumulative dose of the investigational product administered to the subject from treatment start through this exposure event. Critical for dose-response modeling and safety assessment.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cycle Number' ;
    rdfs:comment 'Sequential cycle number for treatments administered in repeated cycles (common in oncology protocols).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doseAdministered rdf:type rdf:Property ;
    rdfs:label 'Dose Administered' ;
    rdfs:comment 'Actual dose amount of the investigational product administered to the subject during this exposure event.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doseModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Dose Modification Flag' ;
    rdfs:comment 'Indicator whether the administered dose was modified from the planned protocol dose. True if dose was adjusted, false if administered as planned.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doseModificationReason rdf:type rdf:Property ;
    rdfs:label 'Dose Modification Reason' ;
    rdfs:comment 'Clinical rationale or reason for modifying the dose from the protocol-specified amount (e.g., adverse event, organ dysfunction, drug interaction).' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationOfInfusionMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Of Infusion Minutes' ;
    rdfs:comment 'Duration in minutes for intravenous infusion administration. Applicable only for IV infusion routes.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDose rdf:type rdf:Property ;
    rdfs:label 'Planned Dose' ;
    rdfs:comment 'Protocol-specified dose amount that was planned to be administered according to the study design.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Treatment Compliance Percentage' ;
    rdfs:comment 'Percentage of planned doses actually taken by the subject, calculated as (actual doses / planned doses) * 100. Measures adherence to protocol.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reporterCountryId rdf:type rdf:Property ;
    rdfs:label 'Reporter Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Reporter country determines regulatory reporting obligations, timelines (15-day vs 90-day rules), and format requirements (E2B versions). Critical for pharmacovigilance compliance and case routing to ' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:aeOnsetDate rdf:type rdf:Property ;
    rdfs:label 'Ae Onset Date' ;
    rdfs:comment 'Date of onset of the adverse event/reaction as reported by the reporter. Corresponds to ICH E2B(R3) E.i.4. Used for time-to-onset analysis, dechallenge/rechallenge assessment, and signal detection.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeOutcome rdf:type rdf:Property ;
    rdfs:label 'Ae Outcome' ;
    rdfs:comment 'Outcome of the adverse event at the time of reporting. Corresponds to ICH E2B(R3) E.i.7. Fatal outcome triggers mandatory expedited reporting and mortality signal analysis.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNarrative rdf:type rdf:Property ;
    rdfs:label 'Case Narrative' ;
    rdfs:comment 'Free-text medical narrative summarizing the adverse event, patient history, suspect drug details, clinical course, and outcome. Authored by the medical reviewer. Corresponds to ICH E2B(R3) H.1. Classified confidential as it may contain de-identified but sensitive clinical information.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNullificationFlag rdf:type rdf:Property ;
    rdfs:label 'Case Nullification Flag' ;
    rdfs:comment 'Indicates whether this case version represents a nullification (retraction) of a previously submitted ICSR. True = nullification report submitted to health authorities. Corresponds to ICH E2B(R3) C.1.11.1.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current workflow state of the ICSR within the pharmacovigilance case management system (Argus Safety). Drives SLA monitoring for 7-day and 15-day regulatory reporting deadlines. [ENUM-REF-CANDIDATE: new|in_triage|in_processing|pending_review|closed|archived|nullified — promote to reference product]' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Case Version Number' ;
    rdfs:comment 'Sequential version counter for the ICSR record. Version 1 = initial report; subsequent integers represent follow-up reports with new or amended information. Nullification reports are tracked via case_nullification_flag. Supports full version history per ICH E2B(R3) C.1.2 and 21 CFR Part 11 audit trail requirements.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:duplicateAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Duplicate Assessment Outcome' ;
    rdfs:comment 'Result of the duplicate case detection assessment performed during intake triage. Duplicate cases are linked to the master case and suppressed from regulatory submission counts. Critical for accurate signal detection and aggregate reporting.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Edc Reconciliation Status' ;
    rdfs:comment 'Status of SAE reconciliation between the pharmacovigilance database (Argus Safety) and the clinical trial EDC system (Medidata Rave). Applicable when report_type = \'clinical_trial\'. Ensures consistency between safety database and clinical database per ICH E6(R2) GCP requirements.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listednessAssessment rdf:type rdf:Property ;
    rdfs:label 'Listedness Assessment' ;
    rdfs:comment 'Assessment of whether the adverse drug reaction is listed (expected) in the current Reference Safety Information (RSI) — Company Core Data Sheet (CCDS) or approved product labeling. Unlisted + serious = SUSAR (Suspected Unexpected Serious Adverse Reaction), triggering expedited reporting. Corresponds to ICH E2B(R3) G.k.9.i.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:literatureReference rdf:type rdf:Property ;
    rdfs:label 'Literature Reference' ;
    rdfs:comment 'PubMed Identifier (PMID) or Digital Object Identifier (DOI) for literature-sourced ICSRs. Populated when report_type = \'literature\'. Corresponds to ICH E2B(R3) C.4.r.1. Supports systematic literature review (SLR) traceability.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCriteriaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Minimum Criteria Met Flag' ;
    rdfs:comment 'Indicates whether the ICSR meets the four ICH E2B minimum criteria for a valid case: (1) identifiable reporter, (2) identifiable patient, (3) suspect drug, (4) adverse event. Cases not meeting minimum criteria are tracked but not submitted. Corresponds to ICH E2D minimum information requirements.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mostRecentInfoDate rdf:type rdf:Property ;
    rdfs:label 'Most Recent Info Date' ;
    rdfs:comment 'Date of the most recent follow-up information received for this case, resetting the regulatory clock for follow-up submissions. Corresponds to ICH E2B(R3) C.1.5.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientAgeUnit rdf:type rdf:Property ;
    rdfs:label 'Patient Age Unit' ;
    rdfs:comment 'Unit of measurement for patient_age_value. Corresponds to ICH E2B(R3) D.2.2b. Supports neonatal and pediatric cases where age is expressed in days, weeks, or months.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientAgeValue rdf:type rdf:Property ;
    rdfs:label 'Patient Age Value' ;
    rdfs:comment 'De-identified patient age at the time of the adverse event onset, expressed as a numeric value. Must be used in conjunction with patient_age_unit. Stored per GDPR/HIPAA de-identification standards. Corresponds to ICH E2B(R3) D.2.2a.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientWeightKg rdf:type rdf:Property ;
    rdfs:label 'Patient Weight Kg' ;
    rdfs:comment 'Patient body weight in kilograms at the time of the adverse event, as reported. De-identified per GDPR/HIPAA. Corresponds to ICH E2B(R3) D.3. Used for dose-weight relationship analysis in signal detection.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryAeMeddraPt rdf:type rdf:Property ;
    rdfs:label 'Primary Ae Meddra Pt' ;
    rdfs:comment 'MedDRA (Medical Dictionary for Regulatory Activities) Preferred Term (PT) coding for the primary adverse event/reaction reported. Corresponds to ICH E2B(R3) E.i.2.1b. Standardized coding enables cross-case signal detection and regulatory submission.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAeMeddraSoc rdf:type rdf:Property ;
    rdfs:label 'Primary Ae Meddra Soc' ;
    rdfs:comment 'MedDRA System Organ Class (SOC) for the primary adverse event, derived from the MedDRA PT hierarchy. Supports aggregate signal detection by organ system and PSUR/PBRER tabulation requirements.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Deadline' ;
    rdfs:comment 'Calculated deadline date by which the ICSR must be submitted to the relevant health authority (FDA, EMA, PMDA, NMPA, TGA). Derived from receipt_date plus applicable reporting window (7 or 15 calendar days for expedited reports; 90 days for non-expedited). SLA-critical field for compliance monitoring.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Status' ;
    rdfs:comment 'Current submission status of the ICSR to the applicable health authority. Tracks compliance against 7-day and 15-day expedited reporting deadlines. Overdue status triggers escalation per PV SLA management procedures.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the ICSR source channel per ICH E2B(R3) C.1.3. Drives regulatory reporting obligations and processing workflows. Spontaneous reports from HCPs/patients, literature-sourced cases (PMID/DOI), clinical trial SAEs, solicited reports from patient support programs, and other sources.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Sender Case Number' ;
    rdfs:comment 'Internal case number assigned by the company (MAH/sponsor) in the source system (Argus Safety / Oracle AERS). Corresponds to ICH E2B(R3) C.1.8.1. Used for internal tracking and reconciliation with the worldwide unique case ID.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousFlag rdf:type rdf:Property ;
    rdfs:label 'Serious Flag' ;
    rdfs:comment 'Indicates whether the adverse event meets ICH E2A seriousness criteria (death, life-threatening, hospitalization, disability, congenital anomaly, or medically significant). True = Serious Adverse Event (SAE). Drives expedited 7-day or 15-day regulatory reporting obligation. Corresponds to ICH E2B(R3) E.i.3.2.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteria rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria' ;
    rdfs:comment 'Specific ICH E2A seriousness criterion or criteria met by the adverse event. Multiple criteria may apply. Corresponds to ICH E2B(R3) E.i.3.2a-f. [ENUM-REF-CANDIDATE: death|life_threatening|hospitalization|disability|congenital_anomaly|medically_significant — promote to reference product]' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Source Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the adverse event occurred. Corresponds to ICH E2B(R3) C.1.17.1. Determines applicable regulatory authority for submission routing (FDA, EMA, PMDA, NMPA, TGA, MHRA).' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspectProductIndication rdf:type rdf:Property ;
    rdfs:label 'Suspect Product Indication' ;
    rdfs:comment 'Medical indication (disease/condition) for which the suspect drug was prescribed or used, coded using MedDRA terminology. Corresponds to ICH E2B(R3) G.k.7.r.2b. Supports benefit-risk assessment and signal contextualization.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetHealthAuthority rdf:type rdf:Property ;
    rdfs:label 'Target Health Authority' ;
    rdfs:comment 'Primary health authority to which this ICSR must be submitted. Determined by source_country_code and product registration status. Drives submission format selection (MedWatch 3500A, EudraVigilance E2B, J-ICSR, NMPA XML). [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|NMPA|MHRA|TGA|WHO|ANVISA|Health_Canada|other — promote to reference product]' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:worldwideUniqueCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Worldwide Unique Case Number' ;
    rdfs:comment 'Globally unique case identifier assigned at intake, conforming to ICH E2B(R3) C.1.1 format (sender identifier + case number). Used for cross-regional deduplication and regulatory submission tracking across FDA MedWatch, EudraVigilance, J-ICSR, and NMPA.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmpId rdf:type rdf:Property ;
    rdfs:label 'Rmp Id' ;
    rdfs:comment 'Reference to the Risk Management Plan (RMP) from which this PASS commitment originates, if applicable. Null if the PASS arises from a PSUR recommendation or Article 20/31 referral rather than an RMP.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rmp .

ind:argusStudyCode rdf:type rdf:Property ;
    rdfs:label 'Argus Study Code' ;
    rdfs:comment 'Study identifier as recorded in the Argus Safety / Oracle AERS pharmacovigilance system. Used for cross-system traceability between the PASS commitment record and safety case data associated with the study.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Authority Approval Status' ;
    rdfs:comment 'Status of the regulatory authority\'s review and approval of the PASS protocol or study design. Reflects the PRAC/CHMP assessment outcome for EU studies or FDA review status for US PMR/PMC studies.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentSource rdf:type rdf:Property ;
    rdfs:label 'Commitment Source' ;
    rdfs:comment 'Identifies the regulatory or scientific trigger that originated the PASS commitment. Supports traceability from commitment to regulatory action. [ENUM-REF-CANDIDATE: rmp|psur_recommendation|article_20_referral|article_31_referral|ma_condition|fda_pmr|fda_pmc|dsmb_recommendation — promote to reference product]' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSources rdf:type rdf:Property ;
    rdfs:label 'Data Sources' ;
    rdfs:comment 'Description of the data sources to be used in the PASS study, such as electronic health records (EHR), claims databases, disease registries, spontaneous reporting databases, or prospective cohort data. Multiple sources may be listed.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encepRegisterNumber rdf:type rdf:Property ;
    rdfs:label 'Encep Register Number' ;
    rdfs:comment 'Official registration number assigned by the ENCePP EU PAS Register upon study registration. Mandatory for non-interventional PASS studies conducted in the EU per GVP Module VIII. Format typically EUPAS followed by numeric digits.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Submission Date' ;
    rdfs:comment 'Actual date on which the final study report was submitted to the regulatory authority. Null if the final report has not yet been submitted. Used for compliance tracking.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interimReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Interim Report Due Date' ;
    rdfs:comment 'Regulatory deadline by which the interim progress report must be submitted to the relevant health authority. Derived from the MA condition or PMR/PMC commitment schedule.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interimReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Interim Report Submission Date' ;
    rdfs:comment 'Actual date on which the interim study report was submitted to the regulatory authority. Used to assess compliance with commitment timelines and identify potential delays.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isInterventional rdf:type rdf:Property ;
    rdfs:label 'Is Interventional' ;
    rdfs:comment 'Indicates whether the PASS study involves any intervention in the standard of care (True) or is purely observational/non-interventional (False). Non-interventional studies are subject to GVP Module VIII; interventional studies are subject to GCP and clinical trial regulations.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaediatricStudy rdf:type rdf:Property ;
    rdfs:label 'Is Paediatric Study' ;
    rdfs:comment 'Indicates whether the PASS study includes or is specifically designed for a paediatric population (True). Triggers additional regulatory requirements under the EU Paediatric Regulation and FDA PREA/BPCA.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAuthority rdf:type rdf:Property ;
    rdfs:label 'Lead Authority' ;
    rdfs:comment 'Primary regulatory authority responsible for oversight and assessment of this PASS study. Uses standard authority abbreviations. For EU studies, typically EMA/PRAC; for US studies, FDA. [ENUM-REF-CANDIDATE: EMA|FDA|MHRA|PMDA|NMPA|WHO|ANSM|BfArM|AIFA|SWISSMEDIC — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySafetyEndpoint rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Endpoint' ;
    rdfs:comment 'Description of the primary safety outcome measure(s) to be evaluated in the PASS study, such as incidence rate of a specific adverse event, risk of a serious adverse reaction, or mortality endpoint.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Protocol Reference Number' ;
    rdfs:comment 'Document control number or version identifier of the approved study protocol as maintained in the eTMF or Veeva Vault RIM system. Used for traceability between the PASS record and the protocol document.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Protocol Submission Date' ;
    rdfs:comment 'Date on which the PASS study protocol was formally submitted to the relevant regulatory authority (e.g., PRAC for EU studies, FDA for US PMR/PMC) for review and approval.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:psurReference rdf:type rdf:Property ;
    rdfs:label 'Psur Reference' ;
    rdfs:comment 'Reference number or submission identifier of the Periodic Safety Update Report (PSUR) or Periodic Benefit-Risk Evaluation Report (PBRER) that recommended or triggered this PASS commitment, if applicable.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'Indicates whether the PASS is imposed as a condition of the Marketing Authorization (MA) by the regulatory authority or is undertaken voluntarily by the Marketing Authorization Holder (MAH). Distinguishes EU imposed conditions from US FDA Post-Marketing Requirements (PMR) and Post-Marketing Commitments (PMC).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyConcernAddressed rdf:type rdf:Property ;
    rdfs:label 'Safety Concern Addressed' ;
    rdfs:comment 'Description of the specific identified risk, potential risk, or missing information from the RMP or safety profile that this PASS study is designed to characterize or quantify. Directly links the study to the pharmacovigilance safety concern.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyEndDate rdf:type rdf:Property ;
    rdfs:label 'Study End Date' ;
    rdfs:comment 'Actual or planned date on which data collection for the PASS study is completed. Null if the study is ongoing. Used to calculate study duration and track commitment deadlines.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyObjectives rdf:type rdf:Property ;
    rdfs:label 'Study Objectives' ;
    rdfs:comment 'Narrative description of the primary and secondary scientific objectives of the PASS study, including the specific safety questions to be addressed as defined in the approved study protocol.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyPopulationDescription rdf:type rdf:Property ;
    rdfs:label 'Study Population Description' ;
    rdfs:comment 'Narrative description of the target study population including inclusion/exclusion criteria, therapeutic indication, age groups, and any special populations (e.g., paediatric, elderly, renally impaired) as defined in the study protocol.' ;
    rdfs:domain ind:PassStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psurId rdf:type rdf:Property ;
    rdfs:label 'Psur Id' ;
    rdfs:comment 'Unique surrogate identifier for the PSUR/PBRER/PADER/DSUR master record in the pharmacovigilance data lakehouse.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Psur .

ind:mahLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Mah Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: PSUR is submitted by specific MAH legal entity. Determines signatory authority, regulatory obligations, and submission routing. Critical for regulatory compliance and multi-entity portfolio management' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:psurEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Psur Employee Id' ;
    rdfs:comment 'Reference to the pharmacovigilance scientist or medical writer assigned as lead author responsible for drafting this PSUR. Supports preparation milestone tracking and accountability.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:psurMedicalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Psur Medical Reviewer Employee Id' ;
    rdfs:comment 'Reference to the qualified physician or clinical pharmacologist responsible for the medical review and benefit-risk evaluation section of this PSUR. Required for regulatory compliance.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:psurQppvEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Psur Qppv Employee Id' ;
    rdfs:comment 'Reference to the EU Qualified Person for Pharmacovigilance (QPPV) who is responsible for oversight and approval of this PSUR prior to submission to EMA. Mandatory for EU-authorised products.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:benefitRiskConclusion rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Conclusion' ;
    rdfs:comment 'Overall benefit-risk evaluation conclusion for the product as determined by the medical reviewer for this PSUR period. A finding of unfavourable or inconclusive may trigger regulatory action, label update, or risk management plan revision.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeCaseCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Case Count' ;
    rdfs:comment 'Total number of Individual Case Safety Reports (ICSRs) received from the IBD through the data lock point across all reporting intervals, providing the full post-marketing safety case history for the product.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeExposurePatientYears rdf:type rdf:Property ;
    rdfs:label 'Cumulative Exposure Patient Years' ;
    rdfs:comment 'Total cumulative patient-years of exposure to the product from IBD through data lock point, calculated from treatment duration data. Used as the primary denominator for incidence rate calculations in benefit-risk assessment.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeExposurePatients rdf:type rdf:Property ;
    rdfs:label 'Cumulative Exposure Patients' ;
    rdfs:comment 'Estimated cumulative number of patients exposed to the product from the IBD through the data lock point, derived from post-marketing surveillance, clinical trials, and sales data. Used as denominator for cumulative incidence rate calculations.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataLockPoint rdf:type rdf:Property ;
    rdfs:label 'Data Lock Point' ;
    rdfs:comment 'The cut-off date up to which all safety data (adverse events, literature, clinical studies) are included in this PSUR. No new data arising after this date is incorporated into the current report period.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:draftCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Draft Completion Date' ;
    rdfs:comment 'Date on which the initial draft of the PSUR was completed by the lead author and made available for internal review. Used to track preparation milestones against the submission deadline.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:haAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Ha Assessment Outcome' ;
    rdfs:comment 'Outcome of the health authority\'s assessment of this PSUR, indicating any regulatory action required. [ENUM-REF-CANDIDATE: pending|no_action|label_update|rmp_update|referral|suspension|withdrawal — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalBirthDate rdf:type rdf:Property ;
    rdfs:label 'International Birth Date' ;
    rdfs:comment 'The date of first marketing authorisation for the product in any country worldwide, used as the anchor date for calculating PSUR submission deadlines and reporting intervals per ICH E2C(R2). SLA-critical field.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intervalCaseCount rdf:type rdf:Property ;
    rdfs:label 'Interval Case Count' ;
    rdfs:comment 'Total number of Individual Case Safety Reports (ICSRs) received during the current reporting interval (between interval_start_date and data_lock_point), including both spontaneous and solicited reports.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intervalEndDate rdf:type rdf:Property ;
    rdfs:label 'Interval End Date' ;
    rdfs:comment 'End date of the current PSUR reporting interval, which is typically equal to the data lock point. Defines the close of the reporting window for interval case counts and exposure data.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intervalSaeCount rdf:type rdf:Property ;
    rdfs:label 'Interval Sae Count' ;
    rdfs:comment 'Number of Serious Adverse Events (SAEs) reported during the current reporting interval. SAEs include fatal, life-threatening, hospitalisation-requiring, or permanently disabling events per ICH E2A criteria.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intervalStartDate rdf:type rdf:Property ;
    rdfs:label 'Interval Start Date' ;
    rdfs:comment 'Start date of the current PSUR reporting interval (the period covered by this report). Together with interval_end_date defines the reporting window for interval case counts and exposure data.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intervalSusarCount rdf:type rdf:Property ;
    rdfs:label 'Interval Susar Count' ;
    rdfs:comment 'Number of Suspected Unexpected Serious Adverse Reactions (SUSARs) identified during the current reporting interval. SUSARs require expedited reporting and are tracked separately for signal detection purposes.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelUpdateRequired rdf:type rdf:Property ;
    rdfs:label 'Label Update Required' ;
    rdfs:comment 'Indicates whether the safety findings in this PSUR require an update to the product label (SmPC, Package Insert, or Patient Information Leaflet). A True value initiates a label change management workflow.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newSafetySignalsCount rdf:type rdf:Property ;
    rdfs:label 'New Safety Signals Count' ;
    rdfs:comment 'Number of new safety signals identified during the reporting interval through signal detection activities (disproportionality analysis, literature review, spontaneous reports). Drives benefit-risk re-evaluation.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:psusaProcedureNumber rdf:type rdf:Property ;
    rdfs:label 'Psusa Procedure Number' ;
    rdfs:comment 'EMA-assigned procedure number for the PSUR Single Assessment (PSUSA) process applicable to centrally authorised products in the EU. Used to track the PSUSA workflow and outcome in Veeva Vault RIM and RIMS.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qc Completion Date' ;
    rdfs:comment 'Date on which quality control review of the PSUR was completed, verifying accuracy of case counts, exposure data, and regulatory formatting prior to QPPV approval and submission.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier assigned to this PSUR/PBRER/PADER/DSUR submission, used in regulatory correspondence and tracking systems such as Argus Safety and Veeva Vault RIM.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle workflow state of the PSUR record, tracking progression from initial drafting through medical review, QC, approval, and regulatory submission. Drives SLA monitoring and escalation workflows. [ENUM-REF-CANDIDATE: draft|in_review|qc_review|approved|submitted|accepted|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Regulatory-mandated submission frequency for this PSUR, which varies by product age, risk profile, and authority requirements. Drives automated SLA deadline calculation from the IBD.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Number' ;
    rdfs:comment 'Sequential ordinal number of this PSUR reporting period for the product (e.g., 1st, 2nd, 3rd PSUR), enabling chronological tracking of the full PSUR history for a product.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmpUpdateRequired rdf:type rdf:Property ;
    rdfs:label 'Rmp Update Required' ;
    rdfs:comment 'Indicates whether the benefit-risk findings in this PSUR necessitate an update to the product\'s Risk Management Plan (RMP). A True value triggers a formal RMP revision workflow in the pharmacovigilance system.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Native record identifier from the originating pharmacovigilance system (Argus Safety, Oracle AERS, or Veeva Vault RIM) for this PSUR record, enabling traceability and reconciliation between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'Mandatory regulatory deadline by which this PSUR must be submitted to the applicable health authority, calculated from the IBD and reporting frequency. SLA-critical field monitored for compliance.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pvActionId rdf:type rdf:Property ;
    rdfs:label 'Pv Action Id' ;
    rdfs:comment 'Unique surrogate identifier for the pharmacovigilance action record. Primary key for this entity. Entity role: TRANSACTION_HEADER — represents a discrete regulatory/safety action with a defined lifecycle triggered by a validated signal, PSUR finding, RMP update, or health authority request.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saeReportId rdf:type rdf:Property ;
    rdfs:label 'Sae Report Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.sae_report. Business justification: SAE events can trigger PV actions (regulatory notifications, safety measures). Add sae_report_id FK (nullable - only when action is triggered by SAE). The triggering_event_type field indicates the tri' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SaeReport .

ind:susarId rdf:type rdf:Property ;
    rdfs:label 'Susar Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.susar. Business justification: SUSAR events can trigger PV actions (label changes, regulatory notifications). Add susar_id FK (nullable - only when action is triggered by SUSAR). The triggering_event_type field indicates the trigge' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Susar .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative description of the pharmacovigilance action, including the specific risk minimization measures to be implemented, rationale, and expected patient safety impact. Captured from Argus Safety case narrative or Veeva Vault RIM action record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Externally-known business identifier for the PV action, formatted as PVA-{YYYY}-{NNNNNN}. Used in regulatory correspondence, authority notifications, and cross-system tracking within Argus Safety/Oracle AERS and Veeva Vault RIM.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle state of the pharmacovigilance action, tracking progression from initiation through completion or cancellation. Drives workflow routing in safety management systems.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the regulatory or safety action being taken. Includes labeling updates (CCDS/SmPC/USPI changes), Dear Healthcare Professional Communication (DHPC), restricted indication, market suspension/withdrawal, Risk Evaluation and Mitigation Strategy (REMS) modification, Risk Management Plan (RMP) update trigger, and Post-Authorization Safety Study (PASS) initiation. [ENUM-REF-CANDIDATE: labeling_update|dhpc|restricted_indication|market_suspension|market_withdrawal|rems_modification|rmp_update|pass_initiation — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Argus Case Number' ;
    rdfs:comment 'Source system case or action number from Argus Safety/Oracle AERS, the operational system of record for pharmacovigilance. Enables bidirectional traceability between the lakehouse silver layer and the source PV system.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Authority Notification Required' ;
    rdfs:comment 'Indicates whether this pharmacovigilance action requires formal notification to one or more health authorities (FDA, EMA, MHRA, PMDA, etc.) prior to or upon implementation. Drives regulatory submission workflows.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitRiskImpact rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Impact' ;
    rdfs:comment 'Assessment of how this pharmacovigilance action affects the overall benefit-risk balance of the medicinal product. Informs PSUR/PBRER benefit-risk conclusions and regulatory authority communications.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dhpcDistributionScope rdf:type rdf:Property ;
    rdfs:label 'Dhpc Distribution Scope' ;
    rdfs:comment 'Geographic scope of the Dear Healthcare Professional Communication (DHPC) distribution when action_type is dhpc. Indicates whether the communication is national, regional, or global. Not applicable for non-DHPC actions.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Assessment Date' ;
    rdfs:comment 'Date on which the effectiveness assessment of this pharmacovigilance action was completed or is scheduled. Supports periodic benefit-risk evaluation and regulatory reporting cycles.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Assessment Outcome' ;
    rdfs:comment 'Outcome of the post-implementation effectiveness assessment, indicating whether the pharmacovigilance action successfully minimized the identified risk. Informs subsequent signal management and RMP update decisions.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Assessment Status' ;
    rdfs:comment 'Status of the post-implementation effectiveness assessment for this pharmacovigilance action. Tracks whether the action achieved its intended risk minimization objective, as required by EMA GVP Module XVI and FDA REMS assessment requirements.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationEvidenceRef rdf:type rdf:Property ;
    rdfs:label 'Implementation Evidence Ref' ;
    rdfs:comment 'Document reference number or Veeva Vault document ID for the evidence package demonstrating that the pharmacovigilance action has been implemented (e.g., updated label version, DHPC distribution confirmation, REMS modification approval letter).' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date on which the pharmacovigilance action was formally initiated or triggered. Represents the principal real-world business event timestamp (day-level precision) for regulatory timeline tracking and compliance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelingDocumentType rdf:type rdf:Property ;
    rdfs:label 'Labeling Document Type' ;
    rdfs:comment 'Type of labeling document affected when action_type is labeling_update. Identifies whether the Company Core Data Sheet (CCDS), Summary of Product Characteristics (SmPC), US Prescribing Information (USPI), Patient Information Leaflet (PIL), or package insert is being updated. Null or not_applicable for non-labeling actions.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingSectionAffected rdf:type rdf:Property ;
    rdfs:label 'Labeling Section Affected' ;
    rdfs:comment 'Specific section(s) of the labeling document being updated (e.g., Section 4.4 Special Warnings, Section 4.8 Undesirable Effects, Boxed Warning, Contraindications). Applicable only for labeling_update action type.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketScope rdf:type rdf:Property ;
    rdfs:label 'Market Scope' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes identifying the markets affected by this pharmacovigilance action. Supports multi-jurisdictional impact assessment and country-level regulatory tracking.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifiedAuthorities rdf:type rdf:Property ;
    rdfs:label 'Notified Authorities' ;
    rdfs:comment 'Comma-separated list of health authority codes (e.g., FDA, EMA, MHRA, PMDA, NMPA) that have been or must be notified of this action. Supports multi-jurisdictional regulatory tracking.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline Date' ;
    rdfs:comment 'Mandatory deadline imposed by a health authority (FDA, EMA, MHRA, PMDA, NMPA) for completion or notification of this pharmacovigilance action. Distinct from the internally-set target_completion_date. Non-compliance may result in regulatory sanctions.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remsProgramName rdf:type rdf:Property ;
    rdfs:label 'Rems Program Name' ;
    rdfs:comment 'Name of the FDA-approved Risk Evaluation and Mitigation Strategy (REMS) program being modified when action_type is rems_modification. Nullable for non-REMS actions.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventReference rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Reference' ;
    rdfs:comment 'Free-text or structured reference number identifying the specific triggering event (e.g., signal case number, PSUR submission number, authority correspondence reference). Provides cross-system traceability.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvAdverseReactionId rdf:type rdf:Property ;
    rdfs:label 'Pv Adverse Reaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each adverse reaction record within the pharmacovigilance system. Primary key for the pv_adverse_reaction data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:causalityMethod rdf:type rdf:Property ;
    rdfs:label 'Causality Method' ;
    rdfs:comment 'The methodology or algorithm used to perform the causality assessment (e.g., WHO-UMC scale, Naranjo algorithm, company-specific algorithm). Supports audit trail and methodological consistency across cases.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codedBy rdf:type rdf:Property ;
    rdfs:label 'Coded By' ;
    rdfs:comment 'User identifier of the medical coder or system process that performed or confirmed the MedDRA coding. Required for audit trail under 21 CFR Part 11 electronic records compliance. Stores the user login or system account name.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingDate rdf:type rdf:Property ;
    rdfs:label 'Coding Date' ;
    rdfs:comment 'Date on which the MedDRA coding was completed for this adverse reaction. Used for coding turnaround time metrics, audit trail, and compliance with regulatory submission timelines.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:codingMethod rdf:type rdf:Property ;
    rdfs:label 'Coding Method' ;
    rdfs:comment 'Indicates whether the MedDRA coding was performed automatically by the safety system (auto-coded), manually by a medical coder (manual review), or auto-coded and subsequently confirmed by manual review. Supports coding quality metrics and audit trail requirements.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listednessDetermination rdf:type rdf:Property ;
    rdfs:label 'Listedness Determination' ;
    rdfs:comment 'Determination of whether this adverse reaction is listed (expected) or unlisted (unexpected) in the current Reference Safety Information (RSI), such as the Company Core Data Sheet (CCDS) or Investigator Brochure (IB). Unlisted serious reactions in clinical trials constitute Suspected Unexpected Serious Adverse Reactions (SUSARs) requiring expedited reporting.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraHlgtCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Hlgt Code' ;
    rdfs:comment 'MedDRA High Level Group Term (HLGT) code, one level above HLT in the MedDRA hierarchy. Supports broader therapeutic area grouping for signal detection and regulatory submissions.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraHltCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Hlt Code' ;
    rdfs:comment 'MedDRA High Level Term (HLT) code representing the grouping level above the Preferred Term. Used for aggregate signal detection and periodic safety update report (PSUR) tabulations.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalConfirmation rdf:type rdf:Property ;
    rdfs:label 'Medical Confirmation' ;
    rdfs:comment 'Indicates whether the adverse reaction has been medically confirmed by a healthcare professional (HCP). Medically confirmed cases carry greater weight in signal detection and regulatory reporting. Corresponds to ICH E2B(R3) field A.1.7.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeCode rdf:type rdf:Property ;
    rdfs:label 'Outcome Code' ;
    rdfs:comment 'Standardized outcome of the adverse reaction at the time of reporting. Values align with ICH E2B(R3) outcome codes: recovered/resolved, recovering/resolving, not recovered/not resolved, fatal, unknown, recovered with sequelae. Mandatory for regulatory submissions.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Reaction Duration Days' ;
    rdfs:comment 'Duration of the adverse reaction in days, calculated from onset to resolution. Stored as a business attribute when explicitly reported by the reporter or calculated during case processing. Supports time-to-resolution analytics and benefit-risk assessments.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reactionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reaction Sequence Number' ;
    rdfs:comment 'Sequential line number of this adverse reaction within the parent ICSR, enabling ordering and identification of multiple events within a single case. Corresponds to the reaction/event sequence in ICH E2B(R3) message structure.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reactionStatus rdf:type rdf:Property ;
    rdfs:label 'Reaction Status' ;
    rdfs:comment 'Current workflow processing status of this adverse reaction record within the pharmacovigilance case management system: new (received, not yet processed), under review, coded (MedDRA coding complete), medically reviewed, closed (finalized), or deleted (voided). Drives case management workflow in Argus Safety.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Type' ;
    rdfs:comment 'Classification of the regulatory reporting obligation triggered by this adverse reaction: 7-day expedited (unexpected fatal/life-threatening SUSAR), 15-day expedited (other serious unexpected), periodic (PSUR/PBRER), non-expedited, or not reportable. Drives submission workflow and deadline tracking.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSourceType rdf:type rdf:Property ;
    rdfs:label 'Reporting Source Type' ;
    rdfs:comment 'Classification of the original source from which this adverse reaction was reported: spontaneous (unsolicited), clinical trial, published literature, regulatory authority, or other. Determines applicable reporting timelines and regulatory obligations. Corresponds to ICH E2B(R3) field A.1.4.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityDescription rdf:type rdf:Property ;
    rdfs:label 'Severity Description' ;
    rdfs:comment 'Narrative severity classification of the adverse reaction using standard WHO/ICH terminology: mild, moderate, severe, life-threatening, or fatal. Complements CTCAE grade for non-oncology cases and post-market surveillance where CTCAE grading is not used.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalDetectionFlag rdf:type rdf:Property ;
    rdfs:label 'Signal Detection Flag' ;
    rdfs:comment 'Indicates whether this adverse reaction record has been flagged as contributing to a potential pharmacovigilance signal under review. Set by the signal detection process in the safety database. Supports signal management workflow and regulatory signal reporting obligations.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeToOnsetDays rdf:type rdf:Property ;
    rdfs:label 'Time To Onset Days' ;
    rdfs:comment 'Number of days from the first dose of the suspect drug to the onset of the adverse reaction. A key pharmacovigilance metric used in signal detection, causality assessment, and benefit-risk evaluation. Derived from drug start date and reaction onset date during case processing.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verbatimTerm rdf:type rdf:Property ;
    rdfs:label 'Verbatim Term' ;
    rdfs:comment 'The exact adverse event term as reported by the original reporter (patient, healthcare professional, or literature source) before MedDRA coding. Preserved verbatim for coding audit trail and signal detection. Required per ICH E2B(R3) field B.2.i.1.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pv Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for the pharmacovigilance agreement record in the Silver Layer lakehouse. Primary key for this entity. Role: MASTER_AGREEMENT.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PvAgreement .

ind:argusAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Argus Agreement Ref' ;
    rdfs:comment 'Reference identifier used in Argus Safety / Oracle AERS to link this pharmacovigilance agreement to the partner configuration for automated ICSR routing and exchange. Enables traceability between the agreement record and the operational safety system configuration.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyCountry rdf:type rdf:Property ;
    rdfs:label 'Counterparty Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the counterparty\'s principal place of business. Determines applicable national competent authority reporting requirements and data privacy regulations (e.g., GDPR, HIPAA).' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyPvContactEmail rdf:type rdf:Property ;
    rdfs:label 'Counterparty Pv Contact Email' ;
    rdfs:comment 'Email address of the designated pharmacovigilance contact at the counterparty organisation. Used for operational safety data exchange communications and escalation notifications.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyPvContactName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Pv Contact Name' ;
    rdfs:comment 'Name of the designated pharmacovigilance contact person at the counterparty organisation responsible for safety data exchange under this agreement. Required for operational communication and escalation.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExchangeFormat rdf:type rdf:Property ;
    rdfs:label 'Data Exchange Format' ;
    rdfs:comment 'Specifies the technical format used for exchanging Individual Case Safety Reports (ICSRs) between parties. E2B_R2 = ICH E2B(R2) XML format; E2B_R3 = ICH E2B(R3) FHIR-based format; PAPER = paper-based exchange; PROPRIETARY = system-specific format; NOT_SPECIFIED = format not yet defined. Drives technical integration requirements with Argus Safety/Oracle AERS.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExchangeMethod rdf:type rdf:Property ;
    rdfs:label 'Data Exchange Method' ;
    rdfs:comment 'Technical transmission method used for exchanging safety data between parties. EVWEB = EMA EudraVigilance Web Trader; GATEWAY = automated gateway-to-gateway; SFTP = secure file transfer; EMAIL = encrypted email; MANUAL = manual entry; API = direct API integration. Determines system configuration in Argus Safety.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icsrExchangeDays rdf:type rdf:Property ;
    rdfs:label 'Icsr Exchange Days' ;
    rdfs:comment 'Number of calendar days within which Individual Case Safety Reports (ICSRs) must be exchanged between the MAH and the counterparty following initial receipt. Typically 7 days for fatal/life-threatening SUSARs and 15 days for other serious cases per GVP Module VI. Drives compliance monitoring and SLA tracking.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isGdprDpaInPlace rdf:type rdf:Property ;
    rdfs:label 'Is Gdpr Dpa In Place' ;
    rdfs:comment 'Indicates whether a GDPR-compliant Data Processing Agreement (DPA) is in place with the counterparty covering the personal data exchanged as part of pharmacovigilance activities. Mandatory for EU-based safety data exchange under GDPR Article 28.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date of the most recent periodic compliance review conducted for this pharmacovigilance agreement. Used to track review frequency and identify overdue reviews per GVP Module I requirements for oversight of outsourced PV activities.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'Date on which the next periodic compliance review of this pharmacovigilance agreement is scheduled. Drives workflow scheduling and resource planning for the PV compliance team.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:psurResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Psur Responsible Party' ;
    rdfs:comment 'Designates which party bears primary responsibility for authoring and submitting Periodic Safety Update Reports (PSURs) / Periodic Benefit-Risk Evaluation Reports (PBRERs) to regulatory authorities. MAH = Marketing Authorisation Holder; COUNTERPARTY = partner organisation; JOINT = shared responsibility; NOT_APPLICABLE = PSURs not in scope of this agreement.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qppvContactName rdf:type rdf:Property ;
    rdfs:label 'Qppv Contact Name' ;
    rdfs:comment 'Name of the Qualified Person Responsible for Pharmacovigilance (QPPV) designated by the MAH under this agreement. The QPPV is a mandatory regulatory role under EU GVP legislation responsible for the PV system. Captured for regulatory compliance and audit purposes.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Responsible Party' ;
    rdfs:comment 'Designates which party is responsible for submitting safety reports (ICSRs, SUSARs, PSURs, RMPs) to national competent authorities (FDA, EMA, MHRA, PMDA, etc.) for products in scope. Determines accountability in regulatory inspections and audits.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Days' ;
    rdfs:comment 'Number of calendar days before the agreement expiry date that a renewal notification must be issued to the counterparty. Drives automated alerting in the PV agreement management system to prevent lapses in safety data exchange coverage.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmpResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Rmp Responsible Party' ;
    rdfs:comment 'Designates which party is responsible for maintaining and updating the Risk Management Plan (RMP) for products covered under this agreement. Relevant for EU-authorised products where RMP is mandatory per GVP Module V.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalManagementResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Signal Management Responsible Party' ;
    rdfs:comment 'Designates which party is responsible for signal detection, assessment, and management activities for products covered under this agreement. MAH = Marketing Authorisation Holder; COUNTERPARTY = partner; JOINT = shared; NOT_APPLICABLE = signal management not in scope. Aligns with GVP Module IX obligations.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:susarExchangeDays rdf:type rdf:Property ;
    rdfs:label 'Susar Exchange Days' ;
    rdfs:comment 'Number of calendar days within which Suspected Unexpected Serious Adverse Reactions (SUSARs) must be exchanged between parties. Typically 7 days for fatal/life-threatening and 15 days for non-fatal/non-life-threatening SUSARs per GVP Module VI and ICH E2D. Separate from general ICSR exchange timelines.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Description of the geographic territories or regulatory jurisdictions covered by this agreement (e.g., specific countries, regions, or global). Determines which national competent authorities are in scope for regulatory reporting obligations under this agreement.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorListId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Id' ;
    rdfs:comment 'Foreign key linking to procurement.approved_vendor_list. Business justification: Each pharmacovigilance product should reference its approved vendor list entry to ensure only qualified suppliers are used for safety-reportable products. Critical for regulatory inspection readiness,' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedVendorList .

ind:authorizationCountryId rdf:type rdf:Property ;
    rdfs:label 'Authorization Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Product authorization country determines regulatory jurisdiction, reporting requirements (expedited timelines, formats), and applicable safety regulations. Essential for routing ICSRs to correct healt' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:discoveryCompoundId rdf:type rdf:Property ;
    rdfs:label 'Discovery Compound Id' ;
    rdfs:comment 'Foreign key linking to discovery.compound. Business justification: Core traceability for safety signal investigation. When adverse events emerge, pharmacovigilance teams must access the original discovery compound structure, preclinical safety data, and SAR to assess' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:primaryManufacturerVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Manufacturer Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Every marketed pharmaceutical product has a primary manufacturing source that must be tracked for pharmacovigilance purposes including batch recalls, quality complaints, and regulatory inspections. Es' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:supplierQualityAgreementId rdf:type rdf:Property ;
    rdfs:label 'Supplier Quality Agreement Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_quality_agreement. Business justification: PV products must reference their supplier quality agreements which define pharmacovigilance responsibilities, ICSR exchange timelines, and deviation notification requirements. Essential for PV agreeme' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierQualityAgreement .

ind:argusProductCode rdf:type rdf:Property ;
    rdfs:label 'Argus Product Code' ;
    rdfs:comment 'Native product identifier from the Argus Safety / Oracle AERS pharmacovigilance system. Used for cross-system reconciliation and traceability between the Silver Layer PV product master and the operational PV case processing system.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Official marketing authorisation or approval number issued by the health authority for the product in a specific country or region (e.g., NDA number, BLA number, EU MA number). Used to link PV records to regulatory approvals.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationType rdf:type rdf:Property ;
    rdfs:label 'Authorization Type' ;
    rdfs:comment 'Type of regulatory marketing authorisation application under which the product is approved (e.g., NDA — New Drug Application, BLA — Biologics License Application, MAA — Marketing Authorisation Application). Determines submission pathway and reporting requirements. [ENUM-REF-CANDIDATE: NDA|BLA|MAA|ANDA|NDS|other — promote to reference product]' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaProductNumber rdf:type rdf:Property ;
    rdfs:label 'Ema Product Number' ;
    rdfs:comment 'EMA-assigned product number for centrally authorised products in the EU. Used for EudraVigilance submissions, PSUR repository submissions, and EU regulatory correspondence.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudravigilanceMpCode rdf:type rdf:Property ;
    rdfs:label 'Eudravigilance Mp Code' ;
    rdfs:comment 'EudraVigilance Medicinal Product Dictionary (EVMPD) identifier assigned by EMA for the product. Required for electronic ICSR submissions to EudraVigilance and EU regulatory reporting.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Expedited Reporting Required' ;
    rdfs:comment 'Indicates whether this product is subject to expedited (7-day or 15-day) Individual Case Safety Report (ICSR) reporting obligations to health authorities. Drives case processing timelines in Argus Safety.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orphanDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Orphan Designation Flag' ;
    rdfs:comment 'Indicates whether the product holds an orphan drug designation for a rare disease indication. True = orphan designation granted; False = no orphan designation. Affects PV reporting thresholds and PSUR requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:psmfReference rdf:type rdf:Property ;
    rdfs:label 'Psmf Reference' ;
    rdfs:comment 'Reference identifier linking this product to the applicable Pharmacovigilance System Master File (PSMF) that describes the PV system governing this product. Mandatory for EU GVP Module II compliance.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psurDueDate rdf:type rdf:Property ;
    rdfs:label 'Psur Due Date' ;
    rdfs:comment 'Next scheduled due date for submission of the Periodic Safety Update Report (PSUR) or Periodic Benefit-Risk Evaluation Report (PBRER) to the relevant health authority. Calculated from IBD and submission frequency.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:psurFrequency rdf:type rdf:Property ;
    rdfs:label 'Psur Frequency' ;
    rdfs:comment 'Regulatory-mandated frequency for Periodic Safety Update Report (PSUR) / Periodic Benefit-Risk Evaluation Report (PBRER) submission for this product. Drives the PSUR scheduling calendar.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvStatus rdf:type rdf:Property ;
    rdfs:label 'Pv Status' ;
    rdfs:comment 'Current lifecycle status of the product within the pharmacovigilance system. Drives case processing eligibility, signal detection inclusion, and PSUR scheduling. Active = currently under PV surveillance; Suspended = temporarily halted; Withdrawn = marketing authorisation withdrawn; Under_review = under regulatory review; Archived = historical record only.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmpRequired rdf:type rdf:Property ;
    rdfs:label 'Rmp Required' ;
    rdfs:comment 'Indicates whether a Risk Management Plan (RMP) is required for this product by the applicable health authority. True = RMP is mandated; False = RMP not required. Drives risk minimisation activity tracking.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pvSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Pv Submission Id' ;
    rdfs:comment 'Unique surrogate identifier for each pharmacovigilance regulatory submission record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalSubmissionPvSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Original Submission Pv Submission Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original pv_submission_id when this record represents a resubmission, follow-up, or amendment. Null for original submissions. Enables reconstruction of the full resubmission history chain.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PvSubmission .

ind:productId rdf:type rdf:Property ;
    rdfs:label 'Product Id' ;
    rdfs:comment 'Reference to the medicinal product (Drug Product / Drug Substance) that is the subject of the safety report or aggregate submission. Links to the master product record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pharmaceuticals .

ind:safetyReportIcsrId rdf:type rdf:Property ;
    rdfs:label 'Safety Report Icsr Id' ;
    rdfs:comment 'The unique safety report identifier assigned within the source pharmacovigilance system (Argus Safety / Oracle AERS case number), used for cross-referencing between the submission record and the originating safety case. Distinct from the submission_number assigned by the health authority.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Icsr .

ind:submissionCountryId rdf:type rdf:Property ;
    rdfs:label 'Submission Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Submission target country determines format (E2B R2/R3, CIOMS), gateway (EudraVigilance, FDA ESG, MHRA Yellow Card), and timelines. Operational requirement for submission routing and compliance tracki' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:acknowledgementCode rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Code' ;
    rdfs:comment 'Technical acknowledgement code returned by the health authority gateway per HL7 v2 / E2B messaging standards. AA = Application Accept; AE = Application Error; CA = Commit Accept; CE = Commit Error; TA = Technical Accept; TE = Technical Error. Drives automated error handling and resubmission workflows.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'Timestamp when the technical acknowledgement (ACK) message was received from the health authority gateway confirming successful receipt of the submission. Distinct from substantive acceptance. Used for SLA compliance evidence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Authority Case Number' ;
    rdfs:comment 'The case or report reference number assigned by the receiving health authority upon acceptance of the submission (e.g., EudraVigilance case number, FDA FAERS case ID). Used for follow-up queries and regulatory correspondence. Populated after authority acceptance.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfFirstReceipt rdf:type rdf:Property ;
    rdfs:label 'Date Of First Receipt' ;
    rdfs:comment 'The date the company first received the minimum valid safety information constituting a reportable case (Day 0 for regulatory clock purposes). This is the anchor date from which the 7-day or 15-day expedited reporting deadline is calculated for ICSRs. Corresponds to ICH E2B(R3) C.1.4.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysToDeadline rdf:type rdf:Property ;
    rdfs:label 'Days To Deadline' ;
    rdfs:comment 'Number of calendar days remaining between the current date and the regulatory_deadline at the time of last record update. Negative values indicate overdue submissions. Used for SLA monitoring dashboards and automatic escalation triggers. Note: this is a snapshot value captured at record update time, not a live calculation.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Structured error code returned by the health authority gateway or E2B validation engine upon rejection or technical failure (e.g., EudraVigilance business rule error code, FAERS conformance error code). Enables automated error categorisation and routing to the appropriate remediation team.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayPortal rdf:type rdf:Property ;
    rdfs:label 'Gateway Portal' ;
    rdfs:comment 'The specific electronic gateway or web portal used to transmit this submission to the health authority. Determines technical format and protocol requirements. EudraVigilance Gateway and EVWEB are EMA channels; FAERS Gateway is the FDA channel for ICSRs; MHRA Sentinel is the UK post-Brexit channel. [ENUM-REF-CANDIDATE: EUDRAVIGILANCE_GATEWAY|EUDRAVIGILANCE_EVWEB|FAERS_GATEWAY|MHRA_SENTINEL|PMDA_GATEWAY|NMPA_GATEWAY|VIGIBASE_WHO|DIRECT_EMAIL|PAPER — promote to reference product]' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Health Authority Code' ;
    rdfs:comment 'Code identifying the target regulatory health authority to which this submission is directed. FDA = U.S. Food and Drug Administration; EMA = European Medicines Agency; MHRA = Medicines and Healthcare products Regulatory Agency (UK); PMDA = Pharmaceuticals and Medical Devices Agency (Japan); NMPA = National Medical Products Administration (China). [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|ANVISA|TGA|HEALTH_CANADA|SWISSMEDIC|COFEPRIS|KFDA|MEDSAFE — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'Indicates whether this submission is subject to expedited regulatory reporting requirements (7-day or 15-day clock). True = expedited; False = periodic/non-expedited. Drives SLA escalation logic and compliance monitoring.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnTime rdf:type rdf:Property ;
    rdfs:label 'Is On Time' ;
    rdfs:comment 'Indicates whether the submission was transmitted on or before the regulatory_deadline. True = submitted on time; False = submitted late. Key compliance KPI field populated at time of submission. Used for regulatory compliance reporting and CAPA tracking.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:messageFormat rdf:type rdf:Property ;
    rdfs:label 'Message Format' ;
    rdfs:comment 'The technical format standard used for the submission message. E2B_R2_XML = ICH E2B(R2) XML format (used by some national authorities); E2B_R3_XML = ICH E2B(R3) XML format (required by EMA EudraVigilance and FDA from 2022); ECTD = Electronic Common Technical Document format (for aggregate reports); PDF = portable document format for ad-hoc communications; PAPER = legacy paper submission.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline' ;
    rdfs:comment 'The mandatory regulatory deadline date by which this submission must be transmitted to the health authority, calculated from the date of first receipt (Day 0) of the safety information. For expedited ICSRs: Day 7 (fatal/life-threatening) or Day 15 (serious). For PSURs/PBRERs: per approved data lock point schedule. SLA-critical field used for automatic escalation.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Report Period End' ;
    rdfs:comment 'End date of the data collection period (Data Lock Point, DLP) for aggregate reports (PSUR, PBRER, PADER, DSUR). Defines the cut-off date for safety data included in the report. Null for individual case (ICSR) submissions.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Report Period Start' ;
    rdfs:comment 'Start date of the data collection period covered by this submission. Applicable primarily to aggregate reports (PSUR, PBRER, PADER, DSUR) defining the International Birth Date (IBD) or period start. Null for individual case (ICSR) submissions.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportTypeQualifier rdf:type rdf:Property ;
    rdfs:label 'Report Type Qualifier' ;
    rdfs:comment 'Qualifier indicating whether this is an initial report, a follow-up update to a previously submitted case, or a nullification (withdrawal) of a previously submitted report. Corresponds directly to ICH E2B(R3) C.1.2 field.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleQppv rdf:type rdf:Property ;
    rdfs:label 'Responsible Qppv' ;
    rdfs:comment 'Name or identifier of the Qualified Person for Pharmacovigilance (QPPV) responsible for this submission under EU GVP regulations. The QPPV bears legal accountability for the completeness and accuracy of pharmacovigilance submissions to the EMA and EU member states.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderIdentifier rdf:type rdf:Property ;
    rdfs:label 'Sender Identifier' ;
    rdfs:comment 'Unique identifier of the sending organisation as registered with the health authority gateway (e.g., EudraVigilance sender ID, FDA FAERS sender code). Required for gateway authentication and message routing.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderOrganisation rdf:type rdf:Property ;
    rdfs:label 'Sender Organisation' ;
    rdfs:comment 'Name of the pharmaceutical company or Marketing Authorisation Holder (MAH) submitting the report, as declared in the E2B message header (ICH E2B(R3) C.1.3.1). Required field in all E2B transmissions.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionVersion rdf:type rdf:Property ;
    rdfs:label 'Submission Version' ;
    rdfs:comment 'Sequential version number of this submission for a given safety case or aggregate report. Version 1 = initial submission; Version 2+ = follow-up or amendment submissions. Corresponds to ICH E2B(R3) C.1.2 (report type: initial/follow-up/nullification).' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionReference rdf:type rdf:Property ;
    rdfs:label 'Transmission Reference' ;
    rdfs:comment 'Unique message transmission identifier assigned by the health authority gateway at the point of receipt (e.g., EudraVigilance message ID, FAERS transmission reference). Distinct from the authority_case_number; this is the technical envelope identifier used for gateway-level tracing and acknowledgement matching.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterReporterId rdf:type rdf:Property ;
    rdfs:label 'Master Reporter Id' ;
    rdfs:comment 'Reference to the canonical/master reporter record when this record has been identified as a duplicate. Null if this record is itself the master. Supports deduplication and case re-linking workflows in the PV system.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reporter .

ind:anonymizedReporterCode rdf:type rdf:Property ;
    rdfs:label 'Anonymized Reporter Code' ;
    rdfs:comment 'Privacy-compliant pseudonymous identifier assigned to the reporter in lieu of personal identifiers, enabling case aggregation and follow-up management without exposing PII. Mandatory under GDPR and HIPAA for PV processing.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusReporterCode rdf:type rdf:Property ;
    rdfs:label 'Argus Reporter Code' ;
    rdfs:comment 'Source system identifier for the reporter as assigned by Argus Safety / Oracle AERS. Used for lineage tracing and deduplication against the operational PV system.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPreference rdf:type rdf:Property ;
    rdfs:label 'Contact Preference' ;
    rdfs:comment 'Preferred channel for follow-up communication as indicated by the reporter. Drives the follow-up workflow in Argus Safety. \'no_contact\' indicates the reporter has declined further contact, which must be respected per GDPR consent obligations.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Department or unit within the reporter\'s organization (e.g., Oncology Ward, Clinical Pharmacology, Drug Safety). Supports routing of follow-up queries to the correct organizational unit.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duplicateFlag rdf:type rdf:Property ;
    rdfs:label 'Duplicate Flag' ;
    rdfs:comment 'Indicates whether this reporter record has been identified as a potential or confirmed duplicate of another reporter record. Duplicate reporters must be resolved before case processing to prevent double-counting in aggregate safety analyses.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fax rdf:type rdf:Property ;
    rdfs:label 'Fax' ;
    rdfs:comment 'Fax number of the reporter or their institution, used for formal follow-up correspondence in jurisdictions where fax remains a regulatory-accepted communication channel (e.g., Japan PMDA submissions).' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstReportDate rdf:type rdf:Property ;
    rdfs:label 'First Report Date' ;
    rdfs:comment 'Date on which the reporter submitted their first adverse event report to the company. Used for longitudinal reporter relationship analysis and tenure-based reliability assessment.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpDeadline rdf:type rdf:Property ;
    rdfs:label 'Follow Up Deadline' ;
    rdfs:comment 'Target date by which a follow-up response from the reporter is required to meet regulatory submission timelines (e.g., 15-day expedited reporting for SUSARs and SAEs). Calculated based on initial receipt date and applicable regulatory clock.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether outstanding follow-up queries have been sent to this reporter and a response is pending. Drives the follow-up management workflow in Argus Safety to ensure timely case completion within regulatory timeframes.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprErasureDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Erasure Date' ;
    rdfs:comment 'Date on which the GDPR Right to Erasure request was processed and PII fields were anonymized. Null if no erasure request has been received. Required for GDPR compliance audit trail.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprErasureRequested rdf:type rdf:Property ;
    rdfs:label 'Gdpr Erasure Requested' ;
    rdfs:comment 'Indicates whether the reporter has submitted a Right to Erasure (Right to be Forgotten) request under GDPR Article 17. When true, PII fields must be anonymized while retaining the anonymized case record for pharmacovigilance regulatory obligations under GDPR Article 17(3)(c).' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'First/given name of the individual reporter. Stored in restricted classification per GDPR and HIPAA. Used for follow-up correspondence and duplicate detection. May be withheld or anonymized per reporter consent.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHcp rdf:type rdf:Property ;
    rdfs:label 'Is Hcp' ;
    rdfs:comment 'Indicates whether the reporter is a qualified Healthcare Professional (HCP). HCP-reported cases carry higher regulatory weight and may trigger expedited 15-day reporting obligations to FDA, EMA, and other health authorities.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Date' ;
    rdfs:comment 'Date of the most recent adverse event report submitted by this reporter. Used to identify active versus dormant reporters and to support follow-up prioritization.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Name of the institution, hospital, clinic, regulatory authority, or company from which the reporter submitted the adverse event report. Relevant for institutional reporters and regulatory authority submissions.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualification rdf:type rdf:Property ;
    rdfs:label 'Qualification' ;
    rdfs:comment 'Professional qualification of the reporter, particularly relevant for Healthcare Professional (HCP) reporters. Determines the clinical credibility weighting of the report and regulatory classification. ICH E2B(R3) field A.2.1.2. [ENUM-REF-CANDIDATE: physician|pharmacist|nurse|dentist|other_health_professional|consumer|unknown — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityScore rdf:type rdf:Property ;
    rdfs:label 'Reliability Score' ;
    rdfs:comment 'Internal PV team assessment of the reporter\'s historical reliability based on completeness and accuracy of prior submissions. Used to weight signal detection analysis and prioritize follow-up resources. Assigned by the PV case processor.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterStatus rdf:type rdf:Property ;
    rdfs:label 'Reporter Status' ;
    rdfs:comment 'Current operational status of the reporter record within the PV system. Inactive or blocked reporters are excluded from new case assignments. Supports duplicate detection and data quality management.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterType rdf:type rdf:Property ;
    rdfs:label 'Reporter Type' ;
    rdfs:comment 'Classification of the reporter by their relationship to the adverse event. Drives regulatory reporting obligations and follow-up workflows. ICH E2B(R3) field A.2.1.1. [ENUM-REF-CANDIDATE: healthcare_professional|patient_consumer|lawyer|regulatory_authority|literature|other — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReportsSubmitted rdf:type rdf:Property ;
    rdfs:label 'Total Reports Submitted' ;
    rdfs:comment 'Cumulative count of Individual Case Safety Reports (ICSRs) submitted by this reporter. Used for duplicate detection, reporter profiling, and reliability assessment. Updated upon each new case linkage.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousVersionRmpId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Rmp Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding version of this RMP, enabling full version chain reconstruction and audit trail for regulatory inspections.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rmp .

ind:additionalPvActivityCount rdf:type rdf:Property ;
    rdfs:label 'Additional Pv Activity Count' ;
    rdfs:comment 'Number of additional pharmacovigilance activities (beyond routine) specified in the PV plan of this RMP, such as Post-Authorization Safety Studies (PASS), drug utilization studies, or enhanced pharmacovigilance programs.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:argusRmpCode rdf:type rdf:Property ;
    rdfs:label 'Argus Rmp Code' ;
    rdfs:comment 'Source system identifier for this RMP record as stored in Argus Safety / Oracle AERS, used for data lineage, reconciliation, and integration with the pharmacovigilance safety database.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Authority Approval Date' ;
    rdfs:comment 'Date on which the health authority formally approved or accepted this version of the RMP. Null if not yet approved.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessEvaluationPlan rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Evaluation Plan' ;
    rdfs:comment 'Description of the plan to evaluate the effectiveness of risk minimization measures, including key performance indicators, data sources, and evaluation timelines as required by EU GVP Module XVI.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedRiskCount rdf:type rdf:Property ;
    rdfs:label 'Identified Risk Count' ;
    rdfs:comment 'Number of important identified risks documented in the safety specification of this RMP version. An identified risk is one for which there is adequate evidence of an association with the medicinal product.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:missingInformationCount rdf:type rdf:Property ;
    rdfs:label 'Missing Information Count' ;
    rdfs:comment 'Number of missing information items documented in the safety specification, representing gaps in knowledge about the safety of the medicinal product (e.g., use in pregnancy, pediatric use).' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passCommitmentCount rdf:type rdf:Property ;
    rdfs:label 'Pass Commitment Count' ;
    rdfs:comment 'Number of Post-Authorization Safety Study (PASS) commitments included in this RMP version, representing studies imposed as conditions of marketing authorization or undertaken voluntarily.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:potentialRiskCount rdf:type rdf:Property ;
    rdfs:label 'Potential Risk Count' ;
    rdfs:comment 'Number of important potential risks documented in the safety specification of this RMP version. A potential risk is one for which there is some basis for suspicion but insufficient evidence to confirm.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pvPlanType rdf:type rdf:Property ;
    rdfs:label 'Pv Plan Type' ;
    rdfs:comment 'Indicates whether the pharmacovigilance plan for this RMP includes only routine PV activities (spontaneous reporting, PSUR/PBRER) or also includes additional PV activities such as PASS studies, registries, or enhanced surveillance.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMinimizationType rdf:type rdf:Property ;
    rdfs:label 'Risk Minimization Type' ;
    rdfs:comment 'Indicates whether risk minimization measures in this RMP are limited to routine measures (product labeling, SmPC, PIL) or also include additional risk minimization measures (educational materials, controlled access programs, REMS for US).' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmpNumber rdf:type rdf:Property ;
    rdfs:label 'Rmp Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the RMP document, used in regulatory submissions and authority correspondence (e.g., RMP-2024-001).' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmpType rdf:type rdf:Property ;
    rdfs:label 'Rmp Type' ;
    rdfs:comment 'Classification of the RMP format based on the regulatory authority template: EU GVP Module V (EMA/MHRA), FDA Risk Evaluation and Mitigation Strategy (REMS), PMDA RMP (Japan), or WHO RMP. [ENUM-REF-CANDIDATE: EU_RMP|FDA_REMS|PMDA_RMP|MHRA_RMP|WHO_RMP — promote to reference product]' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySpecificationSummary rdf:type rdf:Property ;
    rdfs:label 'Safety Specification Summary' ;
    rdfs:comment 'Narrative summary of the safety specification section of the RMP, covering the epidemiology of the indication, non-clinical safety findings, clinical trial safety data, and post-marketing experience.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeIndication rdf:type rdf:Property ;
    rdfs:label 'Scope Indication' ;
    rdfs:comment 'The approved or proposed therapeutic indication(s) covered by this RMP, as defined in the marketing authorization or clinical development program (e.g., treatment of relapsed/refractory multiple myeloma).' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopePopulation rdf:type rdf:Property ;
    rdfs:label 'Scope Population' ;
    rdfs:comment 'Description of the target patient population covered by this RMP, including age groups, special populations (pediatric, geriatric, renal/hepatic impairment), and any population restrictions.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalDetectionReference rdf:type rdf:Property ;
    rdfs:label 'Signal Detection Reference' ;
    rdfs:comment 'Reference identifier(s) to pharmacovigilance signal detection records or PRAC signal assessments that triggered or informed this RMP version update.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionChangeRationale rdf:type rdf:Property ;
    rdfs:label 'Version Change Rationale' ;
    rdfs:comment 'Documented rationale for updating this RMP version, including the trigger (e.g., new safety signal, PSUR outcome, authority request, new indication, PASS completion) and summary of changes from the previous version.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousVersionRsiId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Rsi Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding version of this RSI document for the same product and document type. Enables version chain traversal for historical listedness assessment and change impact analysis.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rsi .

ind:applicableRegion rdf:type rdf:Property ;
    rdfs:label 'Applicable Region' ;
    rdfs:comment 'Geographic region or regulatory jurisdiction for which this RSI document is authoritative (e.g., \'USA\', \'EU\', \'JPN\', \'GLOBAL\'). Determines which RSI version is used for listedness assessment in region-specific expedited reporting. Use ISO 3-letter country codes or \'GLOBAL\' for CCDS.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusRsiCode rdf:type rdf:Property ;
    rdfs:label 'Argus Rsi Code' ;
    rdfs:comment 'Native identifier of this RSI record in the Argus Safety / Oracle AERS pharmacovigilance system. Enables bidirectional traceability between the Databricks Silver Layer and the operational PV system for reconciliation and audit purposes.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Categorized reason for issuing this new RSI version. Supports root cause analysis and regulatory inspection readiness. [ENUM-REF-CANDIDATE: new_safety_signal|regulatory_request|periodic_review|label_update|clinical_data|spontaneous_reports|post_market_study|other — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'Narrative summary of the key changes introduced in this RSI version compared to the previous version (e.g., \'Added hepatotoxicity as listed reaction; updated frequency of nausea from common to very common\'). Supports impact assessment for ongoing ICSRs and SUSAR re-evaluation.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLanguage rdf:type rdf:Property ;
    rdfs:label 'Document Language' ;
    rdfs:comment 'ISO 639-1 language code of the RSI document (e.g., \'en\', \'de\', \'fr\', \'ja\'). The English version is typically the master; translations may exist for regional submissions. Listedness assessment is performed against the language-appropriate version.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emeaProductNumber rdf:type rdf:Property ;
    rdfs:label 'Emea Product Number' ;
    rdfs:comment 'EMA centralized procedure product number (EMEA/H/C/XXXXXX) associated with this RSI when document_type is \'SmPC\'. Links the RSI to the EU marketing authorization for EudraVigilance reporting and PSUR obligations.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentVersion rdf:type rdf:Property ;
    rdfs:label 'Is Current Version' ;
    rdfs:comment 'Flag indicating whether this record represents the currently active version of the RSI for the given product, document type, and region. True = this is the version used for all new ICSR listedness assessments. Supports efficient querying without date-range filtering.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listedReactionCount rdf:type rdf:Property ;
    rdfs:label 'Listed Reaction Count' ;
    rdfs:comment 'Total number of distinct adverse reactions enumerated as listed/expected in this RSI version, expressed as MedDRA Preferred Terms. Provides a quick summary metric for version comparison and completeness validation without querying the reaction detail table.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ndaBlaNumber rdf:type rdf:Property ;
    rdfs:label 'Nda Bla Number' ;
    rdfs:comment 'FDA NDA or BLA application number associated with this RSI, applicable when document_type is \'USPI\' for approved marketed products. Links the RSI to the approved marketing authorization for expedited and periodic safety reporting.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psurDataLockPoint rdf:type rdf:Property ;
    rdfs:label 'Psur Data Lock Point' ;
    rdfs:comment 'Data lock point date for the Periodic Safety Update Report (PSUR) / Periodic Benefit-Risk Evaluation Report (PBRER) cycle in which this RSI version was first used. Supports traceability of RSI changes across PSUR reporting periods.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rmpReference rdf:type rdf:Property ;
    rdfs:label 'Rmp Reference' ;
    rdfs:comment 'Reference identifier or version of the Risk Management Plan (RMP) that was current when this RSI version was issued. The RMP\'s safety specification informs the listed reactions in the RSI and must be consistent with it.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rsiCode rdf:type rdf:Property ;
    rdfs:label 'Rsi Code' ;
    rdfs:comment 'Business-assigned unique code identifying this RSI document record, typically encoding product abbreviation, year, and sequence number. Used as the externally-known identifier across pharmacovigilance systems including Argus Safety.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rsiStatus rdf:type rdf:Property ;
    rdfs:label 'Rsi Status' ;
    rdfs:comment 'Current lifecycle status of the RSI document version. \'draft\' = under preparation; \'approved\' = internally approved but not yet effective; \'active\' = currently in force for listedness assessment; \'superseded\' = replaced by a newer version; \'retired\' = no longer applicable; \'withdrawn\' = removed from use. Only one version per product/document type should be \'active\' at any time.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:susarApplicable rdf:type rdf:Property ;
    rdfs:label 'Susar Applicable' ;
    rdfs:comment 'Indicates whether this RSI is used for SUSAR determination in clinical trials. True when document_type is \'IB\' or \'CCDS\' and the product is under active clinical investigation. Drives the 7/15-day expedited reporting clock for unexpected serious reactions.' ;
    rdfs:domain ind:Rsi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:causalityAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Causality Assessor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Causality assessment is a regulatory-critical determination requiring named accountability. Tracking the assessor employee enables audit trail compliance, workload management, and qualification verifi' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:edcCaseReference rdf:type rdf:Property ;
    rdfs:label 'Edc Case Reference' ;
    rdfs:comment 'Case or subject reference number from the clinical trial EDC system (e.g., Medidata Rave subject ID or AE sequence number) used to reconcile the SAE record between the safety database and the clinical database.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFatal rdf:type rdf:Property ;
    rdfs:label 'Is Fatal' ;
    rdfs:comment 'Indicates whether the SAE resulted in the death of the patient. Triggers mandatory expedited 7-day reporting to health authorities and escalation to senior medical review.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listedness rdf:type rdf:Property ;
    rdfs:label 'Listedness' ;
    rdfs:comment 'Assessment of whether the adverse reaction is listed (expected) in the current Reference Safety Information (RSI) such as the Investigator Brochure or SmPC. Determines whether the event qualifies as unexpected for SUSAR classification.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientAgeAtOnset rdf:type rdf:Property ;
    rdfs:label 'Patient Age At Onset' ;
    rdfs:comment 'Age of the patient in years at the time the serious adverse event began. Used for demographic analysis, signal detection, and population-specific risk assessment.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatorySubmissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Due Date' ;
    rdfs:comment 'Deadline by which the SAE/SUSAR must be submitted to the relevant health authority (FDA, EMA, etc.). Calculated from receipt_date based on applicable reporting timeline (7-day for fatal/life-threatening SUSAR; 15-day for other SUSARs; 30-day for non-expedited).' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteAwarenessDate rdf:type rdf:Property ;
    rdfs:label 'Site Awareness Date' ;
    rdfs:comment 'Date on which the investigational site or sponsor first became aware of the SAE. Used to calculate the 24-hour initial notification SLA and the 7/15-day regulatory reporting clock per ICH E2A and GCP requirements.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionAuthority rdf:type rdf:Property ;
    rdfs:label 'Submission Authority' ;
    rdfs:comment 'Health authority to which the SAE/ICSR was submitted (e.g., FDA via FAERS, EMA via EudraVigilance). A single SAE may require submission to multiple authorities; this field captures the primary authority for this record. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspectDrugDose rdf:type rdf:Property ;
    rdfs:label 'Suspect Drug Dose' ;
    rdfs:comment 'Dose of the suspect medicinal product administered at the time of the SAE, including numeric value and unit (e.g., \'100 mg\', \'5 mg/kg\'). Stored as string to accommodate varied unit formats from source systems.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspectDrugRoute rdf:type rdf:Property ;
    rdfs:label 'Suspect Drug Route' ;
    rdfs:comment 'Route by which the suspect medicinal product was administered (e.g., oral, intravenous, subcutaneous). Coded using EDQM standard terms per ICH E2B(R3) requirements.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Description' ;
    rdfs:comment 'Free-text description of the treatment(s) administered to manage the SAE, including concomitant medications, procedures, or interventions. Captured in the case narrative.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Assessor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Signal assessment requires named ownership for regulatory accountability and workload distribution. Tracking assessor employee enables signal triage management, qualification verification, and audit t' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analysisPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Period End Date' ;
    rdfs:comment 'End date of the data analysis period used for signal detection. Together with analysis_period_start_date, defines the cumulative or interval data window reviewed.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Period Start Date' ;
    rdfs:comment 'Start date of the data analysis period used for signal detection. Defines the temporal window of adverse event data reviewed to identify the signal.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Assessment Summary' ;
    rdfs:comment 'Narrative summary of the formal signal assessment findings, including methodology applied, data sources reviewed, clinical interpretation, and conclusions. Supports regulatory dossier preparation and PRAC submissions.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCount rdf:type rdf:Property ;
    rdfs:label 'Case Count' ;
    rdfs:comment 'Total number of Individual Case Safety Reports (ICSRs) or adverse event cases contributing to this safety signal at the time of detection or most recent assessment. Used as a threshold criterion alongside disproportionality metrics.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourceDatabase rdf:type rdf:Property ;
    rdfs:label 'Data Source Database' ;
    rdfs:comment 'Name of the specific pharmacovigilance database or data source from which the signal was detected (e.g., FDA FAERS, WHO VigiBase, EudraVigilance, company spontaneous database, published literature). Supports traceability of signal origin.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebgmValue rdf:type rdf:Property ;
    rdfs:label 'Ebgm Value' ;
    rdfs:comment 'Empirical Bayes Geometric Mean (EBGM) — a Bayesian disproportionality metric used in the FDA FAERS database analysis. EBGM ≥2 is a commonly applied threshold for signal detection.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fatalCaseCount rdf:type rdf:Property ;
    rdfs:label 'Fatal Case Count' ;
    rdfs:comment 'Number of fatal outcome cases among the cases contributing to this safety signal. Fatal cases receive highest priority in signal triage and may trigger expedited regulatory notification.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icValue rdf:type rdf:Property ;
    rdfs:label 'Ic Value' ;
    rdfs:comment 'Information Component (IC) — a Bayesian disproportionality metric used by the WHO Uppsala Monitoring Centre (UMC) VigiBase. Positive IC values indicate a drug-event association stronger than expected by chance.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelChangeRecommended rdf:type rdf:Property ;
    rdfs:label 'Label Change Recommended' ;
    rdfs:comment 'Indicates whether the signal assessment has resulted in a formal recommendation to update the product label (SmPC, USPI, or equivalent). Triggers regulatory submission activities.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pracNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Prac Notification Date' ;
    rdfs:comment 'Actual date on which the PRAC rapporteur was notified of the safety signal. Compared against prac_notification_due_date to assess SLA compliance.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pracNotificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Prac Notification Due Date' ;
    rdfs:comment 'SLA-critical deadline by which the PRAC rapporteur must be notified of the validated safety signal per EMA regulatory requirements. Drives escalation workflows and compliance monitoring.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prrValue rdf:type rdf:Property ;
    rdfs:label 'Prr Value' ;
    rdfs:comment 'Proportional Reporting Ratio (PRR) — a disproportionality analysis metric quantifying the ratio of the proportion of reports for a drug-event combination versus all other drugs. Values >2 with chi-squared >4 and ≥3 cases typically indicate a signal.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:psurReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Psur Referral Flag' ;
    rdfs:comment 'Indicates whether this safety signal has been referred for inclusion and evaluation in the next Periodic Safety Update Report (PSUR) / Periodic Benefit-Risk Evaluation Report (PBRER).' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryActionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Required' ;
    rdfs:comment 'Indicates whether the safety signal assessment has determined that a regulatory action is required (e.g., label update, DHPC, REMS modification, product withdrawal). Drives downstream regulatory affairs workflows.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Type' ;
    rdfs:comment 'Type of regulatory action determined to be required based on the signal assessment outcome. [ENUM-REF-CANDIDATE: label_update|rems_modification|dhpc|psur_referral|product_withdrawal|contraindication_addition|none — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rorValue rdf:type rdf:Property ;
    rdfs:label 'Ror Value' ;
    rdfs:comment 'Reporting Odds Ratio (ROR) — a disproportionality analysis metric representing the odds of a specific adverse event being reported for a drug versus all other drugs. Complements PRR in signal detection.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seriousCaseCount rdf:type rdf:Property ;
    rdfs:label 'Serious Case Count' ;
    rdfs:comment 'Number of Serious Adverse Event (SAE) cases among the total cases contributing to this signal. Serious cases include fatal, life-threatening, hospitalization, disability, or congenital anomaly outcomes per ICH E2A.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalDescription rdf:type rdf:Property ;
    rdfs:label 'Signal Description' ;
    rdfs:comment 'Detailed narrative description of the safety signal including the nature of the concern, clinical context, patient population affected, and initial evidence summary. Supports signal triage and assessment documentation.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalNumber rdf:type rdf:Property ;
    rdfs:label 'Signal Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier assigned to the safety signal upon creation in Argus Safety / Oracle AERS. Used for cross-system referencing, regulatory correspondence, and PRAC rapporteur notifications.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalSourceType rdf:type rdf:Property ;
    rdfs:label 'Signal Source Type' ;
    rdfs:comment 'Classification of the data source from which the safety signal was detected. [ENUM-REF-CANDIDATE: spontaneous_database|literature|clinical_trial|real_world_data|social_media|health_authority — promote to reference product]' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStatus rdf:type rdf:Property ;
    rdfs:label 'Signal Status' ;
    rdfs:comment 'Current lifecycle state of the safety signal per GVP Module IX workflow: new (detected, not yet triaged), under_evaluation (active assessment in progress), validated (confirmed as a genuine safety concern), refuted (assessed and dismissed), closed (final disposition reached and documented).' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalTitle rdf:type rdf:Property ;
    rdfs:label 'Signal Title' ;
    rdfs:comment 'Concise, human-readable title describing the safety signal, typically formatted as [Drug Name] and [Adverse Event Term]. Used in regulatory correspondence, PRAC submissions, and internal safety committee communications.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalType rdf:type rdf:Property ;
    rdfs:label 'Signal Type' ;
    rdfs:comment 'Classification of the signal as new (not previously known), strengthened (existing signal with increased evidence), weakened (existing signal with decreased evidence), or refuted (previously identified signal now dismissed).' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Reference number or identifier from the originating data source (e.g., FAERS case number, EudraVigilance report ID, literature PubMed ID, clinical trial NCT number) that triggered or contributed to the signal detection.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageDate rdf:type rdf:Property ;
    rdfs:label 'Triage Date' ;
    rdfs:comment 'Date on which the safety signal was formally triaged by the pharmacovigilance team to determine priority and assign for full assessment. Marks the transition from detection to active evaluation.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedTreatmentArm rdf:type rdf:Property ;
    rdfs:label 'Assigned Treatment Arm' ;
    rdfs:comment 'The treatment arm to which the subject was assigned (e.g., investigational product, comparator, placebo), populated after unblinding. Required for causality assessment and regulatory reporting when unblinding has occurred.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaEudravigilanceSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Ema Eudravigilance Submission Date' ;
    rdfs:comment 'The date on which the SUSAR was submitted to the EMA via the EudraVigilance Clinical Trial Module (EVCTM). Null if not yet submitted or not applicable.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectednessDetermination rdf:type rdf:Property ;
    rdfs:label 'Expectedness Determination' ;
    rdfs:comment 'The sponsor\'s determination of whether the adverse reaction is expected or unexpected based on comparison against the current Investigator\'s Brochure (IB) or Reference Safety Information (RSI). An \'unexpected\' determination is a prerequisite for SUSAR classification.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaIndSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Fda Ind Submission Date' ;
    rdfs:comment 'The date on which the SUSAR was submitted to the FDA as an IND safety report under 21 CFR Part 312.32. Null if not yet submitted or not applicable. Used for SLA compliance tracking.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpNumber rdf:type rdf:Property ;
    rdfs:label 'Follow Up Number' ;
    rdfs:comment 'Sequential number of the follow-up report for this SUSAR (e.g., 1 for first follow-up, 2 for second). Zero or null for initial reports. Used to track the version history of regulatory submissions.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Initial Receipt Date' ;
    rdfs:comment 'The date on which the sponsor first received valid minimum information about the adverse reaction, triggering the start of the expedited reporting clock. Day 0 for 7-day and 15-day SLA calculations per ICH E2A.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationalProductDose rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Dose' ;
    rdfs:comment 'The dose of the investigational product administered to the subject at the time of the adverse reaction, including amount and unit (e.g., \'100 mg\', \'5 mg/kg\'). Stored as a string to accommodate varied dose expressions.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationalProductName rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Name' ;
    rdfs:comment 'The International Nonproprietary Name (INN) or code name of the investigational medicinal product (IMP) suspected to have caused the adverse reaction. Captured at the time of SUSAR assessment.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationalProductRoute rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Route' ;
    rdfs:comment 'The route of administration of the investigational product (e.g., oral, intravenous, subcutaneous). Coded per EDQM standard terminology as required for ICH E2B(R3) submissions.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorCausality rdf:type rdf:Property ;
    rdfs:label 'Investigator Causality' ;
    rdfs:comment 'The treating investigator\'s assessment of the causal relationship between the investigational product and the adverse reaction, as reported on the Case Report Form (CRF). Captured separately from sponsor causality per ICH E2A requirements.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLifeThreatening rdf:type rdf:Property ;
    rdfs:label 'Is Life Threatening' ;
    rdfs:comment 'Indicates whether the adverse reaction was life-threatening at the time of occurrence (i.e., the subject was at immediate risk of death). Together with is_fatal, determines applicability of the 7-day reporting clock.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mhraSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Mhra Submission Date' ;
    rdfs:comment 'The date on which the SUSAR was submitted to the UK Medicines and Healthcare products Regulatory Agency (MHRA). Null if not applicable.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:narrativeText rdf:type rdf:Property ;
    rdfs:label 'Narrative Text' ;
    rdfs:comment 'The free-text clinical narrative describing the SUSAR, including the sequence of events, medical history, treatment, and outcome. Required for all regulatory submissions per ICH E2B(R3). Classified as confidential due to sensitive clinical content.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmdaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Pmda Submission Date' ;
    rdfs:comment 'The date on which the SUSAR was submitted to the Japan Pharmaceuticals and Medical Devices Agency (PMDA). Null if not applicable.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reactionMeddraPtCode rdf:type rdf:Property ;
    rdfs:label 'Reaction Meddra Pt Code' ;
    rdfs:comment 'The MedDRA (Medical Dictionary for Regulatory Activities) Preferred Term code representing the primary adverse reaction. Mandatory for regulatory submissions to FDA, EMA, MHRA, and PMDA.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionMeddraPtName rdf:type rdf:Property ;
    rdfs:label 'Reaction Meddra Pt Name' ;
    rdfs:comment 'The human-readable MedDRA Preferred Term name corresponding to the reaction_meddra_pt_code. Stored for reporting clarity and to avoid repeated lookups against the MedDRA dictionary.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionMeddraSocName rdf:type rdf:Property ;
    rdfs:label 'Reaction Meddra Soc Name' ;
    rdfs:comment 'The MedDRA System Organ Class (SOC) under which the primary adverse reaction is classified. Used for signal detection, aggregate analysis, and PSUR/PBRER reporting by therapeutic area.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionOnsetDate rdf:type rdf:Property ;
    rdfs:label 'Reaction Onset Date' ;
    rdfs:comment 'The date on which the suspected unexpected serious adverse reaction first manifested in the subject. Used for temporal causality assessment and time-to-onset analysis.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reactionOutcome rdf:type rdf:Property ;
    rdfs:label 'Reaction Outcome' ;
    rdfs:comment 'The outcome of the adverse reaction at the time of reporting. [ENUM-REF-CANDIDATE: recovered|recovering|not_recovered|recovered_with_sequelae|fatal|unknown — promote to reference product]' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingClockType rdf:type rdf:Property ;
    rdfs:label 'Reporting Clock Type' ;
    rdfs:comment 'Indicates whether this SUSAR is subject to a 7-day expedited reporting clock (fatal or life-threatening) or a 15-day reporting clock (all other serious unexpected reactions). Drives SLA enforcement and regulatory deadline calculation.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Date' ;
    rdfs:comment 'The calculated calendar date by which the SUSAR must be submitted to all applicable health authorities, derived from initial_receipt_date plus the applicable reporting clock (7 or 15 calendar days). SLA-critical field with criminal liability for non-compliance.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorCausality rdf:type rdf:Property ;
    rdfs:label 'Sponsor Causality' ;
    rdfs:comment 'The sponsor\'s assessment of the causal relationship between the investigational product and the adverse reaction. A causality of \'related\' or \'not assessable\' (where benefit of doubt applies) is required for SUSAR classification.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAge rdf:type rdf:Property ;
    rdfs:label 'Subject Age' ;
    rdfs:comment 'The age of the clinical trial subject in years at the time the adverse reaction occurred. Required for regulatory submissions and demographic analysis. Classified as restricted PHI.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectSex rdf:type rdf:Property ;
    rdfs:label 'Subject Sex' ;
    rdfs:comment 'The biological sex of the clinical trial subject as recorded in the case report. Required for ICH E2B(R3) regulatory submissions and demographic safety analysis. Classified as restricted PHI.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPhase rdf:type rdf:Property ;
    rdfs:label 'Trial Phase' ;
    rdfs:comment 'The phase of the clinical trial in which the SUSAR occurred (Phase I through Phase IV). Influences regulatory reporting obligations and signal assessment context.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspectDrugId rdf:type rdf:Property ;
    rdfs:label 'Suspect Drug Id' ;
    rdfs:comment 'Unique surrogate identifier for the suspect or concomitant drug record within an Individual Case Safety Report (ICSR). Primary key of this entity.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Procurement Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: Links suspect drug batches to receiving records enabling verification of receiving conditions (temperature excursions, packaging damage, storage) that may contribute to adverse events. Essential for c' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:additionalDosingText rdf:type rdf:Property ;
    rdfs:label 'Additional Dosing Text' ;
    rdfs:comment 'Free-text field capturing any additional dosing information not captured in structured fields, such as dose titration schedules, special administration instructions, or deviations from prescribed dosing. Maps to ICH E2B(R3) element G.k.4.r.6.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchLotNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Lot Number' ;
    rdfs:comment 'Manufacturing batch or lot number of the drug product administered to the patient. Critical for product quality investigations, batch recalls, and manufacturing defect signal detection. Maps to ICH E2B(R3) element G.k.4.r.7.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingStatus rdf:type rdf:Property ;
    rdfs:label 'Coding Status' ;
    rdfs:comment 'Status of the WHO Drug Dictionary coding process for this drug record: coded (coding complete), pending (awaiting coding), not coded (unable to code), auto-coded (coded by automated system), or manually coded (coded by a pharmacovigilance specialist).' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfAdministration rdf:type rdf:Property ;
    rdfs:label 'Country Of Administration' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the drug was administered to the patient. Used for regional signal detection and regulatory reporting stratification.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeDoseAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Dose Amount' ;
    rdfs:comment 'Total cumulative dose of the drug received by the patient from start to stop date (or to the date of the adverse event). Used in dose-response analyses and exposure-based signal detection. Maps to ICH E2B(R3) element G.k.5a.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeDoseUnit rdf:type rdf:Property ;
    rdfs:label 'Cumulative Dose Unit' ;
    rdfs:comment 'Unit of measurement for the cumulative dose amount (e.g., mg, g, IU). Must be interpreted in conjunction with cumulative_dose_amount. Maps to ICH E2B(R3) element G.k.5b.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseAmount rdf:type rdf:Property ;
    rdfs:label 'Dose Amount' ;
    rdfs:comment 'Numeric quantity of the drug administered per dose as reported. Must be interpreted in conjunction with dose_unit. Maps to ICH E2B(R3) element G.k.4.r.1a.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dosingFrequency rdf:type rdf:Property ;
    rdfs:label 'Dosing Frequency' ;
    rdfs:comment 'Frequency at which the drug was administered (e.g., once daily, twice daily, weekly). Maps to ICH E2B(R3) element G.k.4.r.3. [ENUM-REF-CANDIDATE: once daily|twice daily|three times daily|four times daily|weekly|biweekly|monthly|as needed|continuous|every 8 hours — promote to reference product]' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Drug Authorization Number' ;
    rdfs:comment 'Marketing authorization or approval number (e.g., NDA number, BLA number, MAA number) of the drug product. Links the drug record to the regulatory approval and supports regulatory reporting obligations.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugRole rdf:type rdf:Property ;
    rdfs:label 'Drug Role' ;
    rdfs:comment 'Role of the drug in the adverse event case: suspect (primary drug under investigation), concomitant (taken alongside but not suspected), interacting (suspected drug-drug interaction), or treatment (used to treat the adverse event). Maps to ICH E2B(R3) element G.k.1.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Drug Sequence Number' ;
    rdfs:comment 'Sequential number identifying the position of this drug record within the parent ICSR, used for ordering and referencing multiple drugs in a single case (e.g., drug 1, drug 2). Maps to ICH E2B(R3) element G.k.1.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indicationVerbatim rdf:type rdf:Property ;
    rdfs:label 'Indication Verbatim' ;
    rdfs:comment 'Indication for drug use as reported verbatim by the reporter, prior to MedDRA coding. Preserved for traceability and coding audit. Maps to ICH E2B(R3) element G.k.7.r.2a.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCompanyProduct rdf:type rdf:Property ;
    rdfs:label 'Is Company Product' ;
    rdfs:comment 'Indicates whether the drug is a product owned or marketed by the reporting company (True) or a competitor/third-party product (False). Determines regulatory reporting obligations and case ownership.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentDrugCode rdf:type rdf:Property ;
    rdfs:label 'Parent Drug Code' ;
    rdfs:comment 'WHO Drug Dictionary parent drug code representing the active moiety or parent compound, used to group drug products sharing the same active substance for aggregate signal detection and PSUR analyses.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemDrugCode rdf:type rdf:Property ;
    rdfs:label 'Source System Drug Code' ;
    rdfs:comment 'Identifier of this drug record in the originating pharmacovigilance source system (e.g., Argus Safety case drug ID or Oracle AERS drug sequence identifier). Supports data lineage, reconciliation, and audit traceability between the lakehouse silver layer and the system of record.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimDrugName rdf:type rdf:Property ;
    rdfs:label 'Verbatim Drug Name' ;
    rdfs:comment 'Drug name exactly as reported by the reporter (patient, healthcare professional, or other source) before any coding or standardization. Preserved for traceability and audit. Maps to ICH E2B(R3) element G.k.2.2.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whoDrugName rdf:type rdf:Property ;
    rdfs:label 'Who Drug Name' ;
    rdfs:comment 'Standardized drug name as coded against the WHO Drug Dictionary (WHO-DD), representing the preferred term for the medicinal product. Enables cross-case aggregation and signal detection.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateVendorAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Alternate Vendor Available Flag' ;
    rdfs:comment 'Indicates whether an alternate approved vendor exists for this material. Critical for supply chain risk management and business continuity.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'Date when the current approval expires and re-qualification is required. Nullable for indefinite approvals subject to periodic review.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalJustification rdf:type rdf:Property ;
    rdfs:label 'Approval Justification' ;
    rdfs:comment 'Business and quality rationale for granting this AVL approval. Documents the basis for the qualification decision.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalScope rdf:type rdf:Property ;
    rdfs:label 'Approval Scope' ;
    rdfs:comment 'Detailed scope of the approval including grade, batch size limits, therapeutic application, or other constraints. Defines the boundaries within which procurement is authorized.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the quality or procurement authority who granted the AVL approval. Provides accountability for the approval decision.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByTitle rdf:type rdf:Property ;
    rdfs:label 'Approved By Title' ;
    rdfs:comment 'Job title or role of the approving authority. Ensures appropriate authorization level for the approval.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Standard interval in months between quality audits for this vendor-material combination. Determined by risk classification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avlNumber rdf:type rdf:Property ;
    rdfs:label 'Avl Number' ;
    rdfs:comment 'Business identifier for the AVL entry. Externally-known unique code used in procurement documents and quality records to reference this approval.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Change Control Required Flag' ;
    rdfs:comment 'Indicates whether changes to this vendor-material combination require formal change control and regulatory notification. True for GMP-critical materials.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Required Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis must accompany each shipment from this vendor. Mandatory for most GMP materials.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionalApprovalConditions rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Conditions' ;
    rdfs:comment 'Specific conditions or restrictions that apply when approval status is Conditionally Approved. Defines limitations on procurement until conditions are met.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delistingReason rdf:type rdf:Property ;
    rdfs:label 'Delisting Reason' ;
    rdfs:comment 'Reason for permanent removal from the Approved Vendor List. Documents the basis for terminating the vendor relationship.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpGradeApproved rdf:type rdf:Property ;
    rdfs:label 'Gmp Grade Approved' ;
    rdfs:comment 'The quality grade or compendial standard for which the vendor is approved to supply this material. Critical for regulatory compliance. [ENUM-REF-CANDIDATE: Pharmaceutical Grade|USP Grade|EP Grade|JP Grade|Technical Grade|Food Grade|Cosmetic Grade — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Audit Outcome' ;
    rdfs:comment 'Overall outcome or conclusion of the most recent vendor audit. Influences approval status and re-qualification decisions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCategory rdf:type rdf:Property ;
    rdfs:label 'Material Category' ;
    rdfs:comment 'Classification of the material or service type covered by this approval. Defines the procurement category for which the vendor is qualified. [ENUM-REF-CANDIDATE: API|Excipient|Packaging Material|Laboratory Supply|Equipment|Service|Raw Material — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSpecificationReference rdf:type rdf:Property ;
    rdfs:label 'Material Specification Reference' ;
    rdfs:comment 'Reference to the internal specification document or standard that defines the quality requirements for the material or service. Links to quality specifications in the Quality Management System (QMS).' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRequalificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Requalification Due Date' ;
    rdfs:comment 'Scheduled date for the next vendor re-qualification activity. Triggers quality audit and review processes to maintain AVL status.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requalificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Requalification Frequency Months' ;
    rdfs:comment 'Standard interval in months between re-qualification activities for this vendor-material combination. Defines the periodic review cycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Sole Source Flag' ;
    rdfs:comment 'Indicates whether this is the only approved vendor for this material. Identifies single points of failure in the supply chain.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date when the AVL approval was suspended. Marks the effective date when procurement was halted.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason for suspension of the AVL approval. Documents quality issues, audit findings, or compliance concerns that led to suspension.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the audit finding record. Primary key.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierAuditId rdf:type rdf:Property ;
    rdfs:label 'Supplier Audit Id' ;
    rdfs:comment 'Reference to the parent supplier audit during which this finding was raised. Links to the supplier_audit product.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierAudit .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the lead auditor or audit team member who identified and documented this finding during the supplier audit.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Completion Date' ;
    rdfs:comment 'Actual date when the vendor completed implementation of the CAPA. Null if CAPA is still in progress.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaDescription rdf:type rdf:Property ;
    rdfs:label 'Capa Description' ;
    rdfs:comment 'Detailed description of the corrective and preventive actions proposed or implemented by the vendor to address the finding and prevent recurrence.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Due Date' ;
    rdfs:comment 'Target completion date for the CAPA implementation, agreed upon between the auditing organization and the vendor.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaOwnerName rdf:type rdf:Property ;
    rdfs:label 'Capa Owner Name' ;
    rdfs:comment 'Name of the individual at the vendor organization responsible for implementing and completing the CAPA.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaOwnerTitle rdf:type rdf:Property ;
    rdfs:label 'Capa Owner Title' ;
    rdfs:comment 'Job title or role of the CAPA owner at the vendor organization (e.g., Quality Manager, Production Supervisor, QA Director).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Capa Verification Date' ;
    rdfs:comment 'Date when the CAPA verification was completed and the effectiveness of the corrective action was confirmed.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Verification Status' ;
    rdfs:comment 'Status of the verification process to confirm that the CAPA was effectively implemented and addresses the root cause. Rejected status requires rework.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaVerifierName rdf:type rdf:Property ;
    rdfs:label 'Capa Verifier Name' ;
    rdfs:comment 'Name of the individual from the auditing organization who verified the effectiveness of the CAPA implementation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingClassification rdf:type rdf:Property ;
    rdfs:label 'Finding Classification' ;
    rdfs:comment 'Severity classification of the audit finding. Critical: immediate risk to product quality or patient safety; Major: significant GMP/GDP non-compliance; Minor: isolated deviation; Observation: improvement opportunity without non-compliance.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingClosureDate rdf:type rdf:Property ;
    rdfs:label 'Finding Closure Date' ;
    rdfs:comment 'Date when the audit finding was formally closed after successful CAPA verification and acceptance. Null if finding remains open.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the audit observation, including what was observed, where it was observed, and why it constitutes a non-compliance or improvement opportunity.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'Finding Identified Date' ;
    rdfs:comment 'Date when the finding was first observed and documented during the audit. Represents the principal business event timestamp for this finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this audit finding for tracking and communication purposes. Typically follows format AUDIT-YEAR-SEQ (e.g., AUD-2024-001).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the audit finding. Tracks progression from identification through CAPA implementation to closure.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpArea rdf:type rdf:Property ;
    rdfs:label 'Gmp Area' ;
    rdfs:comment 'The GMP functional area or system where the finding was identified (e.g., Quality Control, Production, Materials Management, Equipment Maintenance, Documentation, Facilities).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousFindingReference rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Reference' ;
    rdfs:comment 'Reference number of the previous audit finding if this is a repeat observation. Null if this is a new finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of the specific regulatory requirement, guideline, or standard that was not met. Examples: 21 CFR 211.68, EU GMP Annex 11, ICH Q7, ISO 13485 clause 7.5.3.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this finding is a repeat observation from a previous audit of the same vendor, suggesting ineffective CAPA or systemic issues.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskToPatientSafety rdf:type rdf:Property ;
    rdfs:label 'Risk To Patient Safety' ;
    rdfs:comment 'Assessment of the potential impact of this finding on patient safety if the underlying issue is not corrected.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskToProductQuality rdf:type rdf:Property ;
    rdfs:label 'Risk To Product Quality' ;
    rdfs:comment 'Assessment of the potential impact of this finding on the quality, safety, or efficacy of drug products supplied by the vendor.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingEvidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence Location' ;
    rdfs:comment 'Reference to the location or document management system path where supporting evidence (photos, documents, test results) for this finding is stored.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Date' ;
    rdfs:comment 'Date when the vendor formally responded to the finding with their proposed CAPA plan.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractPriceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Contract Price Schedule Id' ;
    rdfs:comment 'Unique identifier for the contract price schedule entry. Primary key.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByScheduleContractPriceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Contract Price Schedule Id' ;
    rdfs:comment 'Reference to the contract_price_schedule_id that supersedes this entry. Null if this is the current active schedule.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractPriceSchedule .

ind:costPlusPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Plus Percentage' ;
    rdfs:comment 'Markup percentage applied to vendor cost when price_basis is cost_plus. Null for other pricing bases.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostIncluded rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Included' ;
    rdfs:comment 'Indicates whether freight and shipping costs are included in the price per unit (True) or billed separately (False).' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms (Incoterms) defining the delivery and risk transfer point for this price schedule entry, such as EXW, FOB, CIF, DDP. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexReference rdf:type rdf:Property ;
    rdfs:label 'Index Reference' ;
    rdfs:comment 'External index or benchmark used for indexed pricing, such as CPI (Consumer Price Index), PPI (Producer Price Index) for chemicals, or commodity market indices. Null if price_basis is not indexed.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Standard lead time in days from PO issuance to delivery for materials or services under this price schedule.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Material master code identifying the specific raw material, API (Active Pharmaceutical Ingredient), excipient, packaging component, or laboratory supply covered by this price schedule entry. Aligns with SAP material master.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum order quantity allowed under this price schedule entry. Null if no upper limit applies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum order quantity required to qualify for this price schedule entry. Null if no MOQ applies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'Pricing methodology applied to this schedule line: fixed (static price), indexed (tied to external index), cost_plus (vendor cost plus margin), or market_based (subject to market rate adjustments).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business reason for the most recent price change, such as market adjustment, volume discount, contract renegotiation, or index escalation.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit' ;
    rdfs:comment 'Contracted price per unit of measure for the material or service. Used for PO (Purchase Order) pricing and COGS (Cost of Goods Sold) calculation.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'Effective end date until which this price schedule entry remains valid. Null for open-ended pricing agreements.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'Effective start date from which this price schedule entry is valid and applicable to purchase orders.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleLineNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Number' ;
    rdfs:comment 'Sequential line number within the contract price schedule, used for ordering and referencing specific pricing tiers or periods.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Service master code for contracted services such as CRO (Contract Research Organization), CMO (Contract Manufacturing Organization), or CDMO (Contract Development and Manufacturing Organization) services. Null if the schedule line applies to materials.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the volume break threshold, ensuring alignment with the material or service UOM. [ENUM-REF-CANDIDATE: KG|L|EA|M|M2|M3|HR|DAY|DOSE|VIAL|BOX|PALLET — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeBreakThreshold rdf:type rdf:Property ;
    rdfs:label 'Volume Break Threshold' ;
    rdfs:comment 'Minimum order quantity or cumulative volume threshold that triggers this pricing tier. Null if no volume-based tiering applies.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether periodic quality audits of the CRO/CMO/CDMO are required as part of this engagement.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'Planned or actual date when the engagement activities conclude. Nullable for open-ended engagements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Engagement Owner Email' ;
    rdfs:comment 'Email address of the internal engagement owner.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementOwnerName rdf:type rdf:Property ;
    rdfs:label 'Engagement Owner Name' ;
    rdfs:comment 'Name of the internal employee responsible for managing and overseeing this engagement.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'Date when the engagement activities officially commenced.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementTitle rdf:type rdf:Property ;
    rdfs:label 'Engagement Title' ;
    rdfs:comment 'Descriptive title of the engagement summarizing the scope and purpose.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Required' ;
    rdfs:comment 'Indicates whether the engagement requires the CRO to operate under Good Clinical Practice (GCP) guidelines for clinical trial conduct.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glpComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Glp Compliance Required' ;
    rdfs:comment 'Indicates whether the engagement requires the CRO to operate under Good Laboratory Practice (GLP) standards for preclinical safety studies.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Required' ;
    rdfs:comment 'Indicates whether the engagement requires the CRO/CMO/CDMO to operate under current Good Manufacturing Practice (cGMP) regulations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governanceMeetingCadence rdf:type rdf:Property ;
    rdfs:label 'Governance Meeting Cadence' ;
    rdfs:comment 'Frequency of scheduled governance and oversight meetings between the organization and the CRO/CMO/CDMO.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastGovernanceMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Last Governance Meeting Date' ;
    rdfs:comment 'Date of the most recent governance meeting held with the CRO/CMO/CDMO.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextGovernanceMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Next Governance Meeting Date' ;
    rdfs:comment 'Scheduled date for the next governance meeting with the CRO/CMO/CDMO.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryTechnicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Technical Contact Email' ;
    rdfs:comment 'Email address of the primary technical contact at the CRO/CMO/CDMO.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTechnicalContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Technical Contact Name' ;
    rdfs:comment 'Name of the primary technical contact person at the CRO/CMO/CDMO responsible for technical coordination and issue resolution.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTechnicalContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Technical Contact Phone' ;
    rdfs:comment 'Phone number of the primary technical contact at the CRO/CMO/CDMO.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productProgramReference rdf:type rdf:Property ;
    rdfs:label 'Product Program Reference' ;
    rdfs:comment 'Reference to the internal product development program or project that this engagement supports.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Impact Flag' ;
    rdfs:comment 'Indicates whether this engagement impacts regulatory filings such as IND (Investigational New Drug), NDA (New Drug Application), BLA (Biologics License Application), or MAA (Marketing Authorization Application).' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Type' ;
    rdfs:comment 'Type of regulatory filing impacted by this engagement: IND for investigational new drug, NDA for new drug application, BLA for biologics license application, MAA for marketing authorization application, ANDA for abbreviated new drug application, DME for drug master file, or not applicable if no filing impact. [ENUM-REF-CANDIDATE: ind|nda|bla|maa|anda|dme|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfWorkSummary rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Summary' ;
    rdfs:comment 'High-level description of the activities, deliverables, and responsibilities covered under this engagement.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyTransferCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Technology Transfer Completion Date' ;
    rdfs:comment 'Date when technology transfer activities were successfully completed and validated.' ;
    rdfs:domain ind:CroCmoEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technologyTransferStatus rdf:type rdf:Property ;
    rdfs:label 'Technology Transfer Status' ;
    rdfs:comment 'Status of technology transfer activities for transferring manufacturing processes, analytical methods, or clinical protocols to the CRO/CMO/CDMO.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique identifier for the delivery schedule line. Primary key for this entity.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.shipment. Business justification: Vendor delivery schedules result in inbound shipments tracked in supply domain. Essential for OTIF measurement, ASN reconciliation, and linking procurement commitments to physical receipt and cold cha' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:poLineItemId rdf:type rdf:Property ;
    rdfs:label 'Po Line Item Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line_item. Business justification: Delivery schedules in SAP MM are maintained at the line item level, not the header level. While delivery_schedule already has FK to purchase_order, adding FK to po_line_item provides the correct granu' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLineItem .

ind:receivingPlantId rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Delivery schedules specify receiving plant for inbound logistics planning and goods receipt preparation. Plant master provides receiving hours and dock capacity for pharmaceutical supply chain executi' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:receivingStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location Id' ;
    rdfs:comment 'Foreign key linking to masterdata.storage_location. Business justification: Delivery schedules specify storage location for inbound logistics and goods receipt posting. Storage location master provides capacity and temperature control for pharmaceutical delivery planning.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:schedulingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Agreement Id' ;
    rdfs:comment 'Reference to the scheduling agreement with the vendor that governs this delivery schedule. Used for long-term procurement arrangements with scheduled releases.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyAgreement .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The actual date on which the material was received at the destination. Populated upon goods receipt posting. Used for schedule adherence analysis and vendor performance evaluation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'The unique identifier of the Advanced Shipping Notice document received from the vendor. Used to correlate shipment notification with goods receipt.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Asn Received Date' ;
    rdfs:comment 'The date on which the Advanced Shipping Notice was received from the vendor. Used to measure vendor compliance with ASN lead time requirements.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Asn Received Flag' ;
    rdfs:comment 'Indicates whether an Advanced Shipping Notice (ASN) has been received from the vendor for this delivery schedule line. ASN provides advance notification of shipment details and enables proactive receiving preparation.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'The name of the logistics carrier or freight forwarder responsible for transporting the material from the vendor to the receiving location.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the vendor in response to the scheduled delivery date. May differ from the scheduled date if the vendor cannot meet the original request. Used for supply planning and risk assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'The quantity of material confirmed by the vendor for delivery. May differ from the scheduled quantity if the vendor cannot fulfill the full request. Used for supply planning adjustments.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'The actual quantity of material received and posted in the goods receipt. Used for invoice verification and schedule adherence tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDelayDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Delay Days' ;
    rdfs:comment 'The number of calendar days by which the actual delivery date exceeded the confirmed delivery date. Positive values indicate late delivery; negative values indicate early delivery. Used for vendor performance scoring.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Tolerance Percentage' ;
    rdfs:comment 'The acceptable percentage variance (over or under) from the scheduled quantity that the buyer will accept without requiring approval. Used for automated goods receipt processing and tolerance checking.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'The Incoterms code that defines the responsibilities, costs, and risks between buyer and seller for this delivery. Examples include EXW (Ex Works), FOB (Free On Board), CIF (Cost Insurance and Freight), DDP (Delivered Duty Paid).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'The unique identifier of the quality inspection lot created for this goods receipt. Used to track sampling, testing, and release decisions in the Laboratory Information Management System (LIMS).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdeliveryTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Overdelivery Tolerance Percentage' ;
    rdfs:comment 'The maximum acceptable percentage by which the vendor may exceed the scheduled quantity. Separate from underdelivery tolerance to provide asymmetric control.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the received material must undergo quality inspection before being released for use. Typically true for Good Manufacturing Practice (GMP) materials including APIs, excipients, and packaging components.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance Percentage' ;
    rdfs:comment 'The percentage difference between the delivered quantity and the confirmed quantity. Calculated as ((delivered_quantity - confirmed_quantity) / confirmed_quantity) * 100. Used for vendor performance evaluation.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Max Celsius' ;
    rdfs:comment 'The maximum acceptable temperature in degrees Celsius for temperature-controlled shipments. Excursions beyond this threshold may compromise material quality and require investigation.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Min Celsius' ;
    rdfs:comment 'The minimum acceptable temperature in degrees Celsius for temperature-controlled shipments. Used for cold chain validation and compliance verification.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleAdherenceStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Adherence Status' ;
    rdfs:comment 'Classification of the delivery performance relative to the confirmed delivery date and quantity. On-time indicates delivery within tolerance; early and late indicate timing deviations; partial indicates quantity shortfall; cancelled indicates the schedule line was not fulfilled.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleChangeReason rdf:type rdf:Property ;
    rdfs:label 'Schedule Change Reason' ;
    rdfs:comment 'Free-text explanation of why the delivery schedule was modified after initial creation. Captures business context for date or quantity changes, cancellations, or expedited deliveries.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'The originally planned date on which the material is expected to be delivered to the receiving location. This is the buyer\'s requested delivery date communicated to the vendor.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledQuantity rdf:type rdf:Property ;
    rdfs:label 'Scheduled Quantity' ;
    rdfs:comment 'The quantity of material originally scheduled for delivery on the scheduled delivery date. Expressed in the material\'s base unit of measure.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingPoint rdf:type rdf:Property ;
    rdfs:label 'Shipping Point' ;
    rdfs:comment 'The vendor\'s facility or location from which the material is being shipped. Used for logistics planning and transit time calculation.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this delivery requires temperature-controlled transportation to maintain material stability and quality. Critical for biologics, vaccines, and temperature-sensitive Active Pharmaceutical Ingredients (APIs).' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'The carrier-provided tracking number for the shipment. Enables real-time visibility of in-transit materials and proactive exception management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underdeliveryTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Underdelivery Tolerance Percentage' ;
    rdfs:comment 'The maximum acceptable percentage by which the vendor may fall short of the scheduled quantity without triggering a deviation or requiring approval.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Document Number' ;
    rdfs:comment 'Reference number of the Certificate of Analysis document provided by the vendor. Used for linking quality documentation to received materials.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Received Flag' ;
    rdfs:comment 'Indicates whether the Certificate of Analysis has been received from the vendor. CoA is mandatory for pharmaceutical materials to verify quality specifications and compliance with Drug Master File (DMF) requirements.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'External delivery note or packing slip number provided by the vendor. Used for cross-referencing shipment documentation and vendor records.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Status' ;
    rdfs:comment 'Current status of the goods receipt transaction. Tracks the lifecycle from initial posting through quality inspection and potential reversal or cancellation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Date when the material was manufactured by the vendor. Used for shelf-life calculation and stability monitoring of Active Pharmaceutical Ingredients (APIs) and excipients.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'SAP material document number generated during goods receipt posting (MIGO transaction). Serves as the official system reference for inventory movement.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'Fiscal year in which the material document was posted. Used in combination with material document number for unique identification in SAP.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP movement type code that classifies the type of goods receipt transaction (e.g., 101 for GR against PO, 501 for transfer posting). Determines accounting entries and inventory impact.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingCondition rdf:type rdf:Property ;
    rdfs:label 'Packaging Condition' ;
    rdfs:comment 'Assessment of the physical condition of packaging upon receipt. Damaged or tampered packaging may trigger quality investigation and material rejection per GDP requirements.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingConditionNotes rdf:type rdf:Property ;
    rdfs:label 'Packaging Condition Notes' ;
    rdfs:comment 'Free-text notes describing any packaging damage, discrepancies, or observations made during receipt inspection. Supports quality investigations and vendor performance evaluation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between the received quantity and the purchase order quantity. Positive values indicate over-delivery; negative values indicate under-delivery. Triggers procurement follow-up and invoice reconciliation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity of material physically received and accepted at the receiving location. Used for inventory posting and variance analysis against purchase order quantity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingPersonName rdf:type rdf:Property ;
    rdfs:label 'Receiving Person Name' ;
    rdfs:comment 'Name of the warehouse or laboratory personnel who physically received and verified the materials. Used for accountability and audit trail in GMP environments.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Timestamp' ;
    rdfs:comment 'Date and time when the materials were physically received at the facility. Distinct from posting date; used for lead time analysis and cold-chain monitoring.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional comments or observations recorded during goods receipt. May include special handling instructions, deviations from standard procedures, or notes for quality assurance review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of the received stock based on quality status. Unrestricted stock is available for use; quality inspection stock awaits QC clearance; blocked stock cannot be used; restricted stock has limited usage.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureExcursionFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Flag' ;
    rdfs:comment 'Indicates whether a temperature excursion was detected during shipment or receipt. Critical for cold-chain materials such as biologics, vaccines, and temperature-sensitive Active Pharmaceutical Ingredients (APIs).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxRecorded rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Recorded' ;
    rdfs:comment 'Maximum temperature recorded during shipment or storage of cold-chain materials. Excursions beyond specified limits trigger quality investigation and potential material rejection.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinRecorded rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Recorded' ;
    rdfs:comment 'Minimum temperature recorded during shipment or storage of cold-chain materials. Used to verify compliance with storage conditions specified in the Drug Product (DP) or Drug Substance (DS) specifications.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Total inventory value of the received goods in the company currency. Calculated as received quantity multiplied by material standard price or moving average price. Posted to inventory and accounts payable.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Batch Number' ;
    rdfs:comment 'Batch or lot number assigned by the vendor to the received materials. Critical for traceability, quality control, and pharmacovigilance in pharmaceutical manufacturing.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomingInspectionId rdf:type rdf:Property ;
    rdfs:label 'Incoming Inspection Id' ;
    rdfs:comment 'Unique identifier for the incoming inspection record. Primary key for this entity.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GMP regulations require full traceability of who performed incoming inspections for APIs/excipients. Essential for deviation investigations, training effectiveness analysis, regulatory audits, and ins' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assayResultUnit rdf:type rdf:Property ;
    rdfs:label 'Assay Result Unit' ;
    rdfs:comment 'Unit of measure for the assay result (e.g., %, mg/g, IU/mg).' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayResultValue rdf:type rdf:Property ;
    rdfs:label 'Assay Result Value' ;
    rdfs:comment 'Quantitative assay result indicating the purity or potency of the material, typically expressed as a percentage.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assaySpecificationMax rdf:type rdf:Property ;
    rdfs:label 'Assay Specification Max' ;
    rdfs:comment 'Maximum acceptable assay value per the approved material specification.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assaySpecificationMin rdf:type rdf:Property ;
    rdfs:label 'Assay Specification Min' ;
    rdfs:comment 'Minimum acceptable assay value per the approved material specification.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaReviewDate rdf:type rdf:Property ;
    rdfs:label 'Coa Review Date' ;
    rdfs:comment 'Date when the Certificate of Analysis review was completed by the quality control team.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coaReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Coa Review Status' ;
    rdfs:comment 'Status of the quality review of the vendor-supplied Certificate of Analysis: not started, in review, approved, or rejected.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Reason' ;
    rdfs:comment 'Detailed reason for the inspection decision, especially for rejected or conditionally released materials (e.g., OOS assay, failed identity, CoA discrepancy).' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityTestResult rdf:type rdf:Property ;
    rdfs:label 'Identity Test Result' ;
    rdfs:comment 'Result of the identity test confirming the material is what it is claimed to be (pass, fail, or not tested).' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impurityProfileResult rdf:type rdf:Property ;
    rdfs:label 'Impurity Profile Result' ;
    rdfs:comment 'Overall result of impurity testing indicating whether all individual and total impurities are within specification limits.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completion Date' ;
    rdfs:comment 'Date when all inspection testing and Certificate of Analysis (CoA) review were completed and final decision was recorded.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionDecision rdf:type rdf:Property ;
    rdfs:label 'Inspection Decision' ;
    rdfs:comment 'Final quality decision for the incoming material: approved for use, rejected, or conditionally released pending further evaluation.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Date' ;
    rdfs:comment 'Date when the incoming inspection activities commenced in the quality control laboratory.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Material Batch Number' ;
    rdfs:comment 'Vendor-supplied batch or lot number of the incoming material as stated on the Certificate of Analysis (CoA).' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microbiologicalTestResult rdf:type rdf:Property ;
    rdfs:label 'Microbiological Test Result' ;
    rdfs:comment 'Result of microbiological testing (total aerobic count, yeast/mold, pathogens) if applicable to the material type.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplesDrawnCount rdf:type rdf:Property ;
    rdfs:label 'Samples Drawn Count' ;
    rdfs:comment 'Number of samples drawn from the incoming material lot for testing per the approved sampling plan.' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testMethodsApplied rdf:type rdf:Property ;
    rdfs:label 'Test Methods Applied' ;
    rdfs:comment 'Comma-separated list of compendial or validated test methods applied during inspection (e.g., USP <621>, EP 2.2.1, JP 17).' ;
    rdfs:domain ind:IncomingInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineItemId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Item Id' ;
    rdfs:comment 'Unique identifier for the invoice line item. Primary key.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceEntrySheetId rdf:type rdf:Property ;
    rdfs:label 'Service Entry Sheet Id' ;
    rdfs:comment 'Reference to the service entry sheet for service-based invoice lines, used in CRO/CMO/CDMO engagements.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceEntrySheet .

ind:gmpMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Material Flag' ;
    rdfs:comment 'Indicates whether this line item is for a GMP-regulated material requiring enhanced quality and traceability controls.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOrder rdf:type rdf:Property ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'Internal order number for cost tracking and allocation, often used for campaign or initiative-specific spend.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Quantity of material or service units invoiced on this line.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the invoice document, used for ordering and reference.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Block Flag' ;
    rdfs:comment 'Indicates whether this invoice line is blocked for payment pending resolution of variances or quality issues.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Reason for payment block, if applicable (e.g., price variance, missing CoA, quality hold).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Timestamp when this invoice line was posted to the general ledger for financial accounting.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per unit of measure as stated on the invoice line.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Project WBS element for project-based procurement, used in clinical trial or R&D project accounting.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'Defines how the line item cost is assigned in financial accounting. K=Cost Center, F=Order, A=Asset, P=Project, N=Network, Q=Quality. Determines GL account posting and cost allocation.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Management Flag' ;
    rdfs:comment 'Indicates whether this material requires batch number tracking at goods receipt. True for APIs, excipients, and other GMP-critical materials requiring lot traceability.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Indicates whether this line item has been marked for deletion. Deleted line items are excluded from delivery schedules and supplier communications but retained for audit trail.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The requested or confirmed delivery date for this line item. Used for production planning, inventory management, and supplier on-time delivery performance tracking.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Relevant Flag' ;
    rdfs:comment 'Indicates whether this line item is subject to GMP regulations and requires enhanced quality documentation, supplier qualification, and Certificate of Analysis (CoA) at receipt. True for materials used in drug substance or drug product manufacturing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Flag' ;
    rdfs:comment 'Indicates whether a goods receipt transaction is required for this line item. Typically true for materials, false for services or non-stock items.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Flag' ;
    rdfs:comment 'Indicates whether an invoice is expected for this line item. Controls invoice verification process and three-way match requirements in accounts payable.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'The procurement item category that determines the business process flow (standard purchase, consignment, subcontracting, service procurement, etc.). Controls goods receipt, invoice verification, and inventory management behavior.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemStatus rdf:type rdf:Property ;
    rdfs:label 'Line Item Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order line item. Tracks progression from order placement through delivery, invoicing, and closure. Used for procurement analytics and supplier performance monitoring.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of material or service ordered on this line item. Represents the original purchase order commitment to the supplier.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity unit to which the net price applies (e.g., price per 1, per 10, per 100 units). Used to calculate the effective unit price when suppliers quote prices for bulk quantities.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Flag' ;
    rdfs:comment 'Indicates whether incoming goods receipt requires quality inspection and release before use. True for GMP-critical materials, APIs, and materials subject to supplier quality agreements.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Additional short text description or notes for this line item. Provides supplementary information beyond the standard material description, such as special handling instructions or supplier-specific details.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLineValue rdf:type rdf:Property ;
    rdfs:label 'Total Line Value' ;
    rdfs:comment 'The total monetary value of this line item, calculated as (ordered_quantity / price_unit) * net_price. Represents the financial commitment for this line before taxes and additional charges.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Buyer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pharma procurement requires tracking which buyer created each PO for audit trails, workload analysis, performance metrics, and SOX compliance. Critical for segregation of duties validation and regulat' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User ID of the manager or authorized approver who released the purchase order for transmission to vendor. Nullable for orders below approval threshold or still in draft status.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Flag' ;
    rdfs:comment 'Boolean indicator whether materials on this purchase order require batch number tracking and Certificate of Analysis (CoA) documentation. True for all GMP materials and critical raw materials.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the purchase order was cancelled before completion. Nullable for non-cancelled orders.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCharges rdf:type rdf:Property ;
    rdfs:label 'Freight Charges' ;
    rdfs:comment 'Transportation and logistics costs associated with delivery of goods. May be vendor-charged or buyer-arranged depending on Incoterms. Nullable if freight is included in material price.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port specified in the Incoterms agreement where risk and cost transfer occurs. Examples: Port of Shanghai, Vendor Warehouse Munich.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the purchase order document was created in the system. Used as the baseline for lead time calculations and payment term start dates.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known unique purchase order document number assigned by SAP MM system. Ten-digit numeric identifier used across procurement, receiving, and accounts payable processes.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order. Draft indicates not yet approved, released indicates approved and transmitted to vendor, partially/fully received tracks goods receipt progress, partially/fully invoiced tracks invoice matching status, closed indicates completed three-way match, cancelled indicates order termination. [ENUM-REF-CANDIDATE: draft|released|partially_received|fully_received|partially_invoiced|fully_invoiced|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order document type. Standard for one-time procurement, blanket for long-term agreements with release schedules, contract for framework agreements, subcontracting for external processing, consignment for vendor-owned inventory, stock transfer for inter-plant movements.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Three-character code identifying the buyer or procurement team responsible for this purchase order. Used for workload distribution, performance tracking, and vendor communication routing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Four-character code identifying the organizational unit responsible for procurement activities. Determines approval authority, contract terms, and vendor relationships. Typically aligned to regional or business unit structure.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Date by which the buyer requests delivery of goods or completion of services. Used for production planning and vendor performance measurement.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Reference to the internal purchase requisition document that originated this purchase order. Links procurement to demand planning and budget approval workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the purchase order including all line items, before taxes and freight charges. Expressed in the currency specified in currency_code. Used for budget tracking and vendor spend analysis.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Grand total of the purchase order including line item values, taxes, and freight charges. Represents the complete financial commitment to the vendor.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Acknowledgement Date' ;
    rdfs:comment 'Date when the vendor confirmed receipt and acceptance of the purchase order. Nullable until vendor confirmation received via EDI or portal.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Unique identifier for the purchase requisition record. Primary key.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Identifier of the preferred or suggested vendor for sourcing this requisition. Optional field; may be specified by requester based on prior relationships or sourcing strategy. Links to vendor master data.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:primaryPurchaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Employee Id' ;
    rdfs:comment 'Identifier of the employee who created and submitted the purchase requisition. Links to employee master data for approval routing and accountability.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requesterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requester Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requestingPlantId rdf:type rdf:Property ;
    rdfs:label 'Requesting Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Requisitions specify receiving plant for MRP planning, goods receipt processing, and inventory management. Plant master provides GMP certification status, capacity, and storage conditions for pharmace' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:approvalWorkflowStage rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Stage' ;
    rdfs:comment 'Current stage in the multi-level approval workflow. Tracks which approval authority level the requisition is awaiting. Workflow stages vary by requisition value and material category per company policy. [ENUM-REF-CANDIDATE: not_submitted|pending_supervisor|pending_manager|pending_procurement|pending_finance|pending_quality|approved|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line 1' ;
    rdfs:comment 'First line of the delivery address for the requested materials or services. May differ from plant default address for special delivery instructions.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Estimated total value of the purchase requisition in the company currency. Used for approval threshold determination and budget checking. May be system-calculated from material price or manually entered.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpRelevant rdf:type rdf:Property ;
    rdfs:label 'Gmp Relevant' ;
    rdfs:comment 'Indicates whether the requisition is for GMP-regulated materials or services that require qualified suppliers and quality agreements. True for APIs, excipients, and materials used in drug product manufacturing.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority level assigned to the requisition indicating urgency of need. Influences approval routing speed and sourcing strategy. Critical priority may be used for production-critical APIs or clinical trial materials.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number generated from this requisition. Populated when requisition is converted to a purchase order in SAP MM (ME21N). Null if not yet sourced.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Approval Required' ;
    rdfs:comment 'Indicates whether the requisition requires approval from Quality Assurance before purchase order creation. Typically true for GMP materials, laboratory reagents, and critical manufacturing supplies.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the purchase requisition was rejected by an approver. Null if not rejected.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requester needs the material or service delivered. Drives procurement lead time calculations and supplier selection.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the procurement workflow. Tracks progression from creation through approval, sourcing, and purchase order generation. [ENUM-REF-CANDIDATE: created|pending_approval|approved|rejected|sourced|po_created|partially_ordered|fully_ordered|cancelled|closed — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the purchase requisition based on procurement category. Determines downstream processing rules and approval workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingDate rdf:type rdf:Property ;
    rdfs:label 'Sourcing Date' ;
    rdfs:comment 'Date when the requisition was assigned to a purchase order. Marks the transition from requisition to committed procurement.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for additional instructions or requirements related to the requisition. May include handling requirements, packaging specifications, or delivery constraints specific to pharmaceutical materials.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the purchase requisition was originally created in the system. Represents the business event timestamp for requisition initiation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourcingBidId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Bid Id' ;
    rdfs:comment 'Unique identifier for the sourcing bid record. Primary key.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingEventId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Id' ;
    rdfs:comment 'Reference to the parent sourcing event (Request for Information (RFI), Request for Proposal (RFP), Request for Quotation (RFQ)) for which this bid was submitted.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingEvent .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the bid was awarded and the vendor was selected as the supplier for the sourcing event.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidNumber rdf:type rdf:Property ;
    rdfs:label 'Bid Number' ;
    rdfs:comment 'Externally-known unique business identifier for this bid submission, typically assigned by the vendor or sourcing system.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Status' ;
    rdfs:comment 'Current lifecycle status of the bid in the evaluation and selection process.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisProvided rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Provided' ;
    rdfs:comment 'Indicates whether the vendor provided a sample Certificate of Analysis (CoA) with the bid to demonstrate material quality and compliance.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialScore rdf:type rdf:Property ;
    rdfs:label 'Commercial Score' ;
    rdfs:comment 'Score assigned by the evaluation team assessing the commercial attractiveness of the bid (price, payment terms, lead time, Minimum Order Quantity (MOQ)). Typically on a 0-100 scale.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Destination location or plant where the vendor will deliver the material or service.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugMasterFileNumber rdf:type rdf:Property ;
    rdfs:label 'Drug Master File Number' ;
    rdfs:comment 'Drug Master File (DMF) number provided by the vendor for Active Pharmaceutical Ingredient (API) or excipient sourcing, if applicable.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorComments rdf:type rdf:Property ;
    rdfs:label 'Evaluator Comments' ;
    rdfs:comment 'Free-text comments and observations from the evaluation team regarding the bid, including strengths, weaknesses, risks, and recommendations.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant' ;
    rdfs:comment 'Indicates whether the vendor confirmed Good Manufacturing Practice (GMP) compliance for the material or service in this bid.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoCertificationStandard rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Standard' ;
    rdfs:comment 'Specific International Organization for Standardization (ISO) standard(s) the vendor is certified to (e.g., ISO 9001:2015, ISO 13485:2016).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCertified rdf:type rdf:Property ;
    rdfs:label 'Iso Certified' ;
    rdfs:comment 'Indicates whether the vendor holds relevant International Organization for Standardization (ISO) certifications (e.g., ISO 9001, ISO 13485) for the material or service in this bid.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Score assigned by the quality team assessing the vendors quality management system, Good Manufacturing Practice (GMP) certification, audit history, and quality track record. Typically on a 0-100 scale.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Quoted Lead Time Days' ;
    rdfs:comment 'Number of days the vendor commits to deliver the material or service from order placement to delivery.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotedTotalPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Total Price' ;
    rdfs:comment 'Total price quoted by the vendor for the entire quantity or scope of the sourcing event. Expressed in the currency specified in currency_code.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'Unit price quoted by the vendor for the material or service being sourced. Expressed in the currency specified in currency_code.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Confirmed' ;
    rdfs:comment 'Indicates whether the vendor confirmed compliance with applicable regulatory requirements (Food and Drug Administration (FDA), European Medicines Agency (EMA), Pharmaceuticals and Medical Devices Agency (PMDA), etc.) for the material or service.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleProvided rdf:type rdf:Property ;
    rdfs:label 'Sample Provided' ;
    rdfs:comment 'Indicates whether the vendor provided a physical sample of the material with the bid for evaluation and testing.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Score' ;
    rdfs:comment 'Score assigned by the evaluation team assessing the vendors technical compliance with specifications, Good Manufacturing Practice (GMP), Good Laboratory Practice (GLP), and regulatory requirements. Typically on a 0-100 scale.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEvaluatedCost rdf:type rdf:Property ;
    rdfs:label 'Total Evaluated Cost' ;
    rdfs:comment 'Total cost of ownership calculated by the evaluation team, including quoted price, logistics costs, quality risk adjustments, and other factors. Used for comparative bid analysis.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'End date of the period during which the vendors quoted prices and terms are valid and binding.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Start date of the period during which the vendors quoted prices and terms are valid and binding.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the vendor representative for communication regarding this bid.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the vendor representative who submitted the bid and serves as the primary contact for this sourcing event.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Phone number of the vendor representative for communication regarding this bid.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Identifier of the vendor awarded the contract from this sourcing event. Links to vendor master data.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:auditRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Requirement Flag' ;
    rdfs:comment 'Indicates whether the sourcing event requires vendors to undergo a GMP or quality audit before contract award.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardedBidAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Bid Amount' ;
    rdfs:comment 'Total contract value or bid amount of the winning vendor\'s proposal.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Bid Submission Deadline' ;
    rdfs:comment 'Date and time by which vendors must submit their bids. After this timestamp, the event is closed to new submissions.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:commercialWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Commercial Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to commercial terms (payment terms, delivery, MOQ, etc.) in the overall bid scoring model (0-100).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'Procurement commodity category or spend category for the sourcing event (e.g., Active Pharmaceutical Ingredients, Excipients, Packaging Materials, Laboratory Supplies, CRO Services, CMO Services).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Estimated total contract value or spend amount for the sourcing event, used for planning and budgeting purposes.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Completion Date' ;
    rdfs:comment 'Date when bid evaluation was completed and final vendor selection was made.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Structured description of the evaluation criteria used to assess vendor bids (e.g., price, quality, delivery time, technical capability, compliance). May be stored as JSON or delimited text listing criteria names.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Date' ;
    rdfs:comment 'Date when bid evaluation process began.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed description of the sourcing event, including scope of work, materials or services being procured, technical requirements, and any special instructions for vendors.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Business identifier for the sourcing event, typically generated by SAP Ariba or procurement system. Externally visible reference number used in communications with vendors.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Event Owner Email' ;
    rdfs:comment 'Email address of the event owner for vendor communications and inquiries.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventOwnerName rdf:type rdf:Property ;
    rdfs:label 'Event Owner Name' ;
    rdfs:comment 'Name of the procurement professional or buyer responsible for managing the sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the sourcing event: Draft (being prepared), Published (sent to vendors), Open (accepting bids), Closed (bid submission ended), Evaluation (bids being reviewed), Awarded (vendor selected), Cancelled (event terminated). [ENUM-REF-CANDIDATE: Draft|Published|Open|Closed|Evaluation|Awarded|Cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTitle rdf:type rdf:Property ;
    rdfs:label 'Event Title' ;
    rdfs:comment 'Descriptive title of the sourcing event, summarizing the procurement need or category being sourced.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Type of sourcing event: RFI (Request for Information), RFP (Request for Proposal), RFQ (Request for Quotation), Auction, Reverse Auction, or eRFX (electronic request for X).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Gdp Requirement Flag' ;
    rdfs:comment 'Indicates whether the sourcing event requires vendors to comply with GDP standards for distribution and logistics.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Requirement Flag' ;
    rdfs:comment 'Indicates whether the sourcing event requires vendors to be GMP-certified or comply with GMP standards.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invitedVendorCount rdf:type rdf:Property ;
    rdfs:label 'Invited Vendor Count' ;
    rdfs:comment 'Total number of vendors invited to participate in the sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Price Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to price in the overall bid evaluation scoring model (0-100).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAgreementRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Required' ;
    rdfs:comment 'Indicates whether a formal Supplier Quality Agreement (SQA) is required as part of the contract award.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:respondingVendorCount rdf:type rdf:Property ;
    rdfs:label 'Responding Vendor Count' ;
    rdfs:comment 'Number of vendors who submitted bids or responses to the sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:savingsAchieved rdf:type rdf:Property ;
    rdfs:label 'Savings Achieved' ;
    rdfs:comment 'Cost savings achieved through the sourcing event, calculated as the difference between baseline/target cost and awarded bid amount.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Technical Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to technical evaluation criteria in the overall bid scoring model (0-100).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Standard or custom terms and conditions applicable to the sourcing event and resulting contract, including legal, commercial, and compliance requirements.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipientId rdf:type rdf:Property ;
    rdfs:label 'Excipient Id' ;
    rdfs:comment 'Foreign key linking to product.excipient. Business justification: Sourcing material for excipients must link to excipient master for specification compliance, allergen/GMO status verification, compendial grade confirmation, and quality documentation traceability. Pa' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Excipient .

ind:primarySourcingPreferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Sourcing Preferred Vendor Id' ;
    rdfs:comment 'Identifier of the preferred or primary vendor for this material. Links to the vendor master in the procurement domain.' ;
    rdfs:domain ind:SourcingMaterial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'ABC classification for inventory management: A (high value, tight control), B (moderate value), C (low value, simple control). Based on consumption value analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required Flag' ;
    rdfs:comment 'Indicates whether this material requires temperature-controlled storage and transportation (cold chain logistics).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether this material is classified as hazardous and requires special handling, storage, and transportation procedures.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt for this material. Used to identify slow-moving or obsolete inventory.' ;
    rdfs:domain ind:SourcingMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchasePrice rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Price' ;
    rdfs:comment 'Most recent actual purchase price paid for this material. Used for price variance analysis and future procurement negotiations.' ;
    rdfs:domain ind:SourcingMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'Maximum inventory level for this material to prevent overstocking and optimize working capital.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level at which a purchase requisition should be automatically triggered to replenish stock. Used in material requirements planning.' ;
    rdfs:domain ind:SourcingMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Minimum inventory level maintained as buffer stock to prevent stockouts due to demand variability or supply delays.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Serial Number Managed Flag' ;
    rdfs:comment 'Indicates whether this material requires individual serial number tracking for complete unit-level traceability.' ;
    rdfs:domain ind:SourcingMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Standard procurement lead time in days from purchase order creation to goods receipt. Used for material requirements planning and order scheduling.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Standard or planned unit price for this material used for cost accounting and budgeting purposes. Currency is defined at the plant or company code level.' ;
    rdfs:domain ind:SourcingMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max Celsius' ;
    rdfs:comment 'Maximum storage temperature requirement in degrees Celsius for this material. Critical for cold chain and temperature-sensitive materials.' ;
    rdfs:domain ind:SourcingMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min Celsius' ;
    rdfs:comment 'Minimum storage temperature requirement in degrees Celsius for this material. Critical for cold chain and temperature-sensitive materials.' ;
    rdfs:domain ind:SourcingMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Employee Id' ;
    rdfs:comment 'Internal employee identifier for the lead auditor, used for traceability and accountability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:paiId rdf:type rdf:Property ;
    rdfs:label 'Pai Id' ;
    rdfs:comment 'Foreign key linking to regulatory.pai. Business justification: Supplier audits are often triggered by or coordinated with regulatory PAI findings at vendor sites. Pharma quality teams link internal supplier audits to PAI records to verify CAPA closure, assess reg' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pai .

ind:auditClosureDate rdf:type rdf:Property ;
    rdfs:label 'Audit Closure Date' ;
    rdfs:comment 'Date when the audit was formally closed after all findings were resolved, CAPAs verified, and final documentation completed.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCost rdf:type rdf:Property ;
    rdfs:label 'Audit Cost' ;
    rdfs:comment 'Total cost incurred for conducting the audit, including travel, accommodation, auditor time, and vendor fees (if applicable). Captured for cost tracking and budget management.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique identifier for the audit, typically assigned by the Quality Management System (QMS) or audit management system.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Report Number' ;
    rdfs:comment 'Unique identifier for the final audit report document, used for document control and retrieval from Veeva Vault QualityDocs.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including specific processes, systems, product lines, or GMP/GDP areas covered (e.g., API manufacturing, sterile fill-finish, cold chain distribution, quality control laboratory).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Audit Team Members' ;
    rdfs:comment 'Comma-separated list of names or employee IDs of additional audit team members who participated in the audit, including subject matter experts (SMEs) and technical specialists.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on its purpose: initial qualification (first-time vendor assessment), periodic surveillance (routine scheduled audit), for-cause (triggered by quality issue or complaint), pre-approval (before contract award), re-qualification (after suspension or major change), or desktop review (document-only assessment).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Capa Approval Date' ;
    rdfs:comment 'Date when the vendor\'s CAPA plan was reviewed and approved by the quality team.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Submission Date' ;
    rdfs:comment 'Actual date when the vendor submitted their CAPA plan for review and approval.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Capa Verification Method' ;
    rdfs:comment 'Method used to verify the effectiveness of implemented CAPAs: document-review (review of evidence documents), follow-up-audit (on-site verification audit), remote-verification (virtual assessment), sample-testing (product testing to confirm improvement), or not-applicable (no CAPA required).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Gdp Compliance Rating' ;
    rdfs:comment 'Overall assessment of the vendor\'s compliance with Good Distribution Practice (GDP) requirements, applicable for distributors and logistics providers.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Rating' ;
    rdfs:comment 'Overall assessment of the vendor\'s compliance with Good Manufacturing Practice (GMP) requirements based on audit findings.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationsCount rdf:type rdf:Property ;
    rdfs:label 'Observations Count' ;
    rdfs:comment 'Number of observations noted. Observations are areas for improvement or best practice recommendations that do not constitute regulatory non-compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallAuditOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Outcome' ;
    rdfs:comment 'Summary conclusion of the audit: approved (vendor meets all requirements), approved-with-conditions (vendor approved pending minor CAPA closure), not-approved (vendor fails to meet critical requirements), or follow-up-required (additional audit needed).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitySystemRating rdf:type rdf:Property ;
    rdfs:label 'Quality System Rating' ;
    rdfs:comment 'Overall assessment of the vendor\'s Quality Management System (QMS) maturity and effectiveness.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferences rdf:type rdf:Property ;
    rdfs:label 'Regulatory References' ;
    rdfs:comment 'Comma-separated list of regulatory citations relevant to the audit scope and findings (e.g., 21 CFR 211.68, EU GMP Annex 11, ICH Q7, ISO 13485).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned end date for the on-site audit or assessment activities.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of findings (critical, major, minor, and observations) identified during the audit.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Vault Document Reference' ;
    rdfs:comment 'Unique document identifier in Veeva Vault QualityDocs where the full audit report, supporting evidence, and CAPA documentation are stored.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededAgreementSupplierQualityAgreementId rdf:type rdf:Property ;
    rdfs:label 'Superseded Agreement Supplier Quality Agreement Id' ;
    rdfs:comment 'Reference to the previous supplier quality agreement that this version supersedes or replaces.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierQualityAgreement .

ind:agreementTitle rdf:type rdf:Property ;
    rdfs:label 'Agreement Title' ;
    rdfs:comment 'Descriptive title of the supplier quality agreement document.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsClause rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Clause' ;
    rdfs:comment 'Contractual clause defining the organizations right to audit the suppliers facilities, processes, and quality systems, including frequency and scope.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNotificationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Change Notification Lead Time Days' ;
    rdfs:comment 'Minimum number of days advance notice the supplier must provide before implementing any change covered by the agreement.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Change Notification Required' ;
    rdfs:comment 'Indicates whether the supplier is obligated to notify the organization of any changes to materials, processes, facilities, or quality systems.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaFormatSpecification rdf:type rdf:Property ;
    rdfs:label 'Coa Format Specification' ;
    rdfs:comment 'Detailed specification of the required format, content, and data elements for the Certificate of Analysis.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaRequired rdf:type rdf:Property ;
    rdfs:label 'Coa Required' ;
    rdfs:comment 'Indicates whether the supplier is required to provide a Certificate of Analysis with each shipment or batch.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityClause rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause' ;
    rdfs:comment 'Contractual provisions governing the protection and handling of confidential information exchanged between the parties.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Deviation Notification Required' ;
    rdfs:comment 'Indicates whether the supplier must notify the organization of any deviations, Out of Specification (OOS) results, or quality incidents.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationNotificationTimeframeHours rdf:type rdf:Property ;
    rdfs:label 'Deviation Notification Timeframe Hours' ;
    rdfs:comment 'Maximum number of hours within which the supplier must notify the organization of a deviation or quality incident.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdpComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Gdp Compliance Required' ;
    rdfs:comment 'Indicates whether the supplier must comply with Good Distribution Practice guidelines for storage and transportation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpResponsibilityMatrix rdf:type rdf:Property ;
    rdfs:label 'Gmp Responsibility Matrix' ;
    rdfs:comment 'Documented allocation of GMP responsibilities between the organization and the supplier, specifying who is accountable for each quality activity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Organization Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative from the organization who signed the quality agreement.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Organization Signatory Title' ;
    rdfs:comment 'Job title or position of the organization signatory who executed the quality agreement.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Organization Signature Date' ;
    rdfs:comment 'Date on which the organization signatory executed the quality agreement.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualitySpecificationsReference rdf:type rdf:Property ;
    rdfs:label 'Quality Specifications Reference' ;
    rdfs:comment 'Reference to the detailed quality specifications, acceptance criteria, and testing requirements applicable to the materials or services covered by this agreement.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Requirements' ;
    rdfs:comment 'Specific regulatory standards and compliance requirements the supplier must adhere to, including FDA, EMA, PMDA, and other applicable regulations.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfSupply rdf:type rdf:Property ;
    rdfs:label 'Scope Of Supply' ;
    rdfs:comment 'Detailed description of the materials, products, services, or manufacturing steps covered under this supplier quality agreement.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Supplier Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative from the supplier organization who signed the quality agreement.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Supplier Signatory Title' ;
    rdfs:comment 'Job title or position of the supplier signatory who executed the quality agreement.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Signature Date' ;
    rdfs:comment 'Date on which the supplier signatory executed the quality agreement.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Contractual terms and conditions under which either party may terminate the supplier quality agreement, including notice periods and grounds for termination.' ;
    rdfs:domain ind:SupplierQualityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract automatically renews at the end of its term. True means the contract will extend for another period unless terminated; False means it expires without action.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary amounts in this contract (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDescription rdf:type rdf:Property ;
    rdfs:label 'Contract Description' ;
    rdfs:comment 'Free-text description of the contract scope, covering materials, services, or categories included. Provides business context for contract purpose and coverage.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'Total monetary value of the supply contract over its lifetime. For value contracts, this is the maximum spend allowed. For quantity contracts, this is the estimated total value based on committed volumes and unit prices.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceEscalationClause rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Clause' ;
    rdfs:comment 'Contractual terms defining how and when prices may be adjusted during the contract term. May reference inflation indices, raw material cost changes, or periodic review schedules.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceIndexReference rdf:type rdf:Property ;
    rdfs:label 'Price Index Reference' ;
    rdfs:comment 'External price index or benchmark used for indexed pricing (e.g., CPI, commodity index, published API price index). Only applicable when price_basis is indexed.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Number' ;
    rdfs:comment 'Reference number of the associated Supplier Quality Agreement (SQA) or Quality Technical Agreement (QTA). Links to quality management system documentation.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Period Months' ;
    rdfs:comment 'Number of months the contract extends for each automatic renewal cycle. Only applicable when auto_renewal_flag is True.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headquartersCountryId rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Vendor headquarters country determines tax jurisdiction, regulatory authority oversight, trade compliance requirements, and FCPA risk classification for pharmaceutical procurement due diligence and ve' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:annualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Amount' ;
    rdfs:comment 'Total procurement spend with this vendor in the current fiscal year, in the organization\'s reporting currency. Used for vendor segmentation and strategic sourcing decisions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditOutcome rdf:type rdf:Property ;
    rdfs:label 'Audit Outcome' ;
    rdfs:comment 'Result of the most recent vendor audit. Approved: no critical findings. Approved with Observations: minor findings requiring follow-up. Conditional Approval: major findings requiring CAPA (Corrective and Preventive Action) before full approval. Not Approved: critical findings, vendor disqualified.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Primary business classification of the vendor based on the goods or services provided. API (Active Pharmaceutical Ingredient) supplier, excipient supplier, packaging material supplier, laboratory equipment supplier, service provider, CRO (Contract Research Organization), CMO (Contract Manufacturing Organization), or CDMO (Contract Development and Manufacturing Organization). [ENUM-REF-CANDIDATE: api_supplier|excipient_supplier|packaging_supplier|equipment_supplier|service_provider|cro|cmo|cdmo — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Business reason for vendor deactivation or blocking (e.g., quality issues, regulatory non-compliance, business closure, contract termination, poor performance).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gdp Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds current GDP (Good Distribution Practice) certification, required for distributors and logistics service providers handling pharmaceutical products.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the vendor\'s headquarters street address.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the vendor\'s headquarters is located.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the vendor\'s headquarters address.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region where the vendor\'s headquarters is located.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for vendor payments (e.g., USD, EUR, GBP, JPY, CNY).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether the vendor has been designated as a preferred supplier based on quality performance, pricing, delivery reliability, and strategic partnership criteria.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityAgreementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Effective Date' ;
    rdfs:comment 'Date when the current Quality Agreement with the vendor became effective.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityAgreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Expiry Date' ;
    rdfs:comment 'Date when the current Quality Agreement expires and requires renewal or renegotiation.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Flag' ;
    rdfs:comment 'Indicates whether a formal Quality Agreement or Supplier Quality Agreement (SQA) is in place with the vendor. Required for GMP-critical suppliers per ICH Q10.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the vendor in SAP MM module. Used for procurement transactions and purchase orders.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor. Active: approved for procurement. Inactive: not currently used but qualified. Suspended: temporarily blocked pending investigation. Pending Qualification: undergoing qualification process. Disqualified: failed qualification. Blocked: permanently blocked from procurement.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Strategic tier classification of the vendor. Tier 1: critical strategic partners with high spend and risk. Tier 2: important suppliers with moderate spend. Tier 3: transactional suppliers with low spend and risk.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorComplaintId rdf:type rdf:Property ;
    rdfs:label 'Vendor Complaint Id' ;
    rdfs:comment 'Unique identifier for the vendor complaint record. Primary key.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedInventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Affected Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: Vendor complaints reference specific received inventory lots with quality defects. Essential for CAPA tracking, lot quarantine decisions, and linking supplier quality issues to affected supply chain i' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:affectedMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Affected Material Code' ;
    rdfs:comment 'Material number or Stock Keeping Unit (SKU) of the raw material, Active Pharmaceutical Ingredient (API), excipient, or packaging component that is the subject of the complaint.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedMaterialDescription rdf:type rdf:Property ;
    rdfs:label 'Affected Material Description' ;
    rdfs:comment 'Human-readable description of the affected material or service.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintClosureDate rdf:type rdf:Property ;
    rdfs:label 'Complaint Closure Date' ;
    rdfs:comment 'Date when the complaint was formally closed after satisfactory resolution and CAPA verification.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complaintDate rdf:type rdf:Property ;
    rdfs:label 'Complaint Date' ;
    rdfs:comment 'Date when the complaint was formally raised and logged in the Quality Management System (QMS).' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the non-conformance, including observed defects, test results, and impact assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Complaint Owner Email' ;
    rdfs:comment 'Email address of the complaint owner for communication and escalation purposes.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintOwnerName rdf:type rdf:Property ;
    rdfs:label 'Complaint Owner Name' ;
    rdfs:comment 'Name of the quality assurance or procurement professional responsible for managing the complaint through resolution.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for the vendor complaint, used for tracking and communication with the vendor.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Resolution Status' ;
    rdfs:comment 'Final resolution outcome of the complaint indicating whether the vendor response and corrective actions were deemed satisfactory.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSeverity rdf:type rdf:Property ;
    rdfs:label 'Complaint Severity' ;
    rdfs:comment 'Severity classification of the complaint based on impact to product quality, patient safety, and regulatory compliance. Critical indicates immediate risk to patient safety or product integrity; major indicates significant quality impact; minor indicates low impact.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current lifecycle status of the vendor complaint in the resolution workflow. [ENUM-REF-CANDIDATE: open|under investigation|awaiting vendor response|vendor response received|resolved|closed|escalated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Classification of the complaint based on the nature of the non-conformance. Values include Out of Specification (OOS) result, foreign matter contamination, mislabelling, documentation error, delivery damage, or temperature excursion during transit.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialClaimAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Claim Amount' ;
    rdfs:comment 'Monetary value of the financial claim raised against the vendor for the non-conforming material or service, including material cost, rework cost, disposal cost, and any associated penalties.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialClaimCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Financial Claim Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial claim amount.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialClaimStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Claim Status' ;
    rdfs:comment 'Status of the financial claim processing and settlement with the vendor.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactToPatientSafety rdf:type rdf:Property ;
    rdfs:label 'Impact To Patient Safety' ;
    rdfs:comment 'Assessment of the potential or actual risk to patient safety resulting from the non-conforming material or service.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactToProductQuality rdf:type rdf:Property ;
    rdfs:label 'Impact To Product Quality' ;
    rdfs:comment 'Assessment of the potential or actual impact of the non-conformance on finished drug product quality and Critical Quality Attributes (CQA).' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Notification Date' ;
    rdfs:comment 'Date when the vendor was formally notified of the complaint.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Due Date' ;
    rdfs:comment 'Expected or contractual due date by which the vendor must provide a formal response including root cause analysis and corrective action plan.' ;
    rdfs:domain ind:VendorComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The baseline date used for calculating payment due date and discount periods per payment terms.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockedForPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked For Payment Flag' ;
    rdfs:comment 'Indicates whether the invoice is blocked for payment pending resolution of issues (e.g., pricing dispute, quality issue, missing documentation).' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the accounts payable workflow: draft, pending three-way match, matched, approved, posted to GL, paid, cancelled, or on hold. [ENUM-REF-CANDIDATE: draft|pending_match|matched|approved|posted|paid|cancelled|on_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Id' ;
    rdfs:comment 'Unique identifier for the vendor performance record. Primary key for the vendor performance scorecard.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Most recent GMP audit score for the vendor site. Typically scored on a 0-100 scale based on audit findings and compliance observations.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Lead Time Days' ;
    rdfs:comment 'Average lead time in days from purchase order issuance to goods receipt during the evaluation period. Key supply chain planning metric.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capaClosureRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Capa Closure Rate Percentage' ;
    rdfs:comment 'Percentage of CAPA actions assigned to the vendor that were closed on time during the evaluation period. Measures vendor commitment to continuous improvement.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coa Compliance Percentage' ;
    rdfs:comment 'Percentage of shipments with compliant Certificate of Analysis documentation meeting GMP and quality requirements.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationAttributionCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Attribution Count' ;
    rdfs:comment 'Number of manufacturing or quality deviations attributed to vendor-supplied materials or services during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Documentation Accuracy Percentage' ;
    rdfs:comment 'Percentage of shipments with complete and accurate documentation including CoA, packing lists, and regulatory certificates during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period. Defines the close of the measurement window for KPI calculation.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period. Defines the beginning of the measurement window for KPI calculation.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Name of the procurement or quality professional who completed the performance evaluation and scorecard.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorRole rdf:type rdf:Property ;
    rdfs:label 'Evaluator Role' ;
    rdfs:comment 'Role or title of the evaluator. Typically procurement manager, quality assurance manager, or supplier quality engineer.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialClaimsAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Claims Amount' ;
    rdfs:comment 'Total monetary value of financial claims filed against the vendor for quality issues, delivery failures, or contract breaches during the evaluation period. Expressed in the vendor\'s payment currency.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inFullDeliveryPercentage rdf:type rdf:Property ;
    rdfs:label 'In Full Delivery Percentage' ;
    rdfs:comment 'Percentage of deliveries that met the full ordered quantity during the evaluation period. Component of OTIF metric.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Count' ;
    rdfs:comment 'Total number of non-conformance records raised against the vendor during the evaluation period. Includes quality, delivery, and documentation non-conformances.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliveryPercentage rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Percentage' ;
    rdfs:comment 'Percentage of deliveries that arrived on or before the requested delivery date during the evaluation period. Component of OTIF metric.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifPercentage rdf:type rdf:Property ;
    rdfs:label 'Otif Percentage' ;
    rdfs:comment 'Percentage of deliveries that arrived on time and in full during the evaluation period. Key supply chain performance metric.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Rating' ;
    rdfs:comment 'Composite overall performance rating based on weighted KPIs. Determines vendor tier status and re-qualification triggers.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceTrend rdf:type rdf:Property ;
    rdfs:label 'Performance Trend' ;
    rdfs:comment 'Directional trend of vendor performance compared to previous evaluation periods. Supports strategic supplier relationship management decisions.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityComplaintsCount rdf:type rdf:Property ;
    rdfs:label 'Quality Complaints Count' ;
    rdfs:comment 'Total number of quality complaints raised against the vendor during the evaluation period. Includes OOS, foreign matter, mislabeling, and other quality issues.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reQualificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Qualification Required Flag' ;
    rdfs:comment 'Indicates whether vendor re-qualification is triggered based on performance thresholds. True if performance falls below acceptable levels requiring formal re-qualification process.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectedLotsCount rdf:type rdf:Property ;
    rdfs:label 'Rejected Lots Count' ;
    rdfs:comment 'Number of material lots or batches rejected during incoming inspection or quality control during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsivenessRating rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Rating' ;
    rdfs:comment 'Qualitative rating of vendor responsiveness to inquiries, change requests, and issue resolution. Assessed by procurement and quality teams.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardType rdf:type rdf:Property ;
    rdfs:label 'Scorecard Type' ;
    rdfs:comment 'Type of performance scorecard. Indicates the frequency and purpose of the evaluation cycle.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Spend Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total spend amount. Indicates the currency in which vendor transactions are denominated.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureExcursionCount rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Count' ;
    rdfs:comment 'Number of shipments with documented temperature excursions outside specified storage and transport conditions during the evaluation period. Critical for temperature-sensitive APIs and biologics.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseOrdersCount rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Orders Count' ;
    rdfs:comment 'Total number of purchase orders issued to the vendor during the evaluation period. Provides context for performance metrics.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Spend Amount' ;
    rdfs:comment 'Total monetary value of purchases from the vendor during the evaluation period. Expressed in the vendor\'s payment currency.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorQualificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Qualification Id' ;
    rdfs:comment 'Unique identifier for the vendor qualification record. Primary key for the vendor qualification entity.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVendorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Employee Id' ;
    rdfs:comment 'Reference to the quality assurance professional responsible for managing this vendor qualification. Typically a QA manager or supplier quality engineer.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryVendorModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Vendor Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the vendor qualification record. Links to the employee or system user record for audit trail purposes.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedForPurchasing rdf:type rdf:Property ;
    rdfs:label 'Approved For Purchasing' ;
    rdfs:comment 'Indicates whether the vendor is approved for active purchasing. True if purchasing is allowed, false if vendor is blocked or restricted. Drives procurement system integration.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date when the qualifying audit or assessment was conducted. Denormalized from the audit record for quick reference and reporting.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIso13485 rdf:type rdf:Property ;
    rdfs:label 'Certification Iso 13485' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 13485 Medical Devices Quality Management certification. Applicable for vendors supplying medical device components or combination products.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationIso9001 rdf:type rdf:Property ;
    rdfs:label 'Certification Iso 9001' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 9001 Quality Management System certification. True if certified, false otherwise.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRegulatoryInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Regulatory Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection (FDA, EMA, MHRA, etc.) at the vendor site. Used to assess regulatory compliance currency.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes capturing additional context, conditions, restrictions, or special requirements associated with this qualification. Used for business communication and audit trail.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the vendor qualification record. Externally visible unique number used in quality documentation and audit trails. Format: VQ-YYYYNNNN.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScope rdf:type rdf:Property ;
    rdfs:label 'Qualification Scope' ;
    rdfs:comment 'Detailed description of the scope of qualification, including specific materials, services, processes, or capabilities covered by this qualification. Free-text field capturing business context.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Status' ;
    rdfs:comment 'Status of regulatory inspections (FDA, EMA, MHRA, etc.) at the vendor site. Inspected indicates successful regulatory inspection, not-inspected indicates no inspection on record, inspection-pending indicates scheduled inspection, inspection-failed indicates failed inspection with outstanding issues, not-applicable for vendors not subject to regulatory inspection.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Establishment Number' ;
    rdfs:comment 'Unique FDA establishment identifier assigned to the vendor site for regulatory registration and inspection tracking.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpCertified rdf:type rdf:Property ;
    rdfs:label 'Gdp Certified' ;
    rdfs:comment 'Indicates whether the vendor site holds current Good Distribution Practice certification for pharmaceutical distribution.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCertified rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified' ;
    rdfs:comment 'Indicates whether the vendor site holds current Good Manufacturing Practice certification.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or role of the primary contact person at the vendor site.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCapacity rdf:type rdf:Property ;
    rdfs:label 'Site Capacity' ;
    rdfs:comment 'Description of the production, storage, or service delivery capacity of the vendor site, including units and volume.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current operational and qualification status of the vendor site in the procurement system.' ;
    rdfs:domain ind:VendorSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bioequivalenceStudyId rdf:type rdf:Property ;
    rdfs:label 'Bioequivalence Study Id' ;
    rdfs:comment 'Unique identifier for the bioequivalence study record. Primary key.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:croVendorId rdf:type rdf:Property ;
    rdfs:label 'Cro Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Bioequivalence studies are conducted by Contract Research Organizations (CROs). Vendor FK enables procurement contract management, invoice reconciliation, audit tracking, and GCP compliance verificati' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:dossierDocumentId rdf:type rdf:Property ;
    rdfs:label 'Dossier Document Id' ;
    rdfs:comment 'The document management system identifier for the final clinical study report.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DossierDocument .

ind:primaryBioequivalenceDrugProductId rdf:type rdf:Property ;
    rdfs:label 'Primary Bioequivalence Drug Product Id' ;
    rdfs:comment 'Foreign key reference to the test drug product being evaluated for bioequivalence. This is typically the generic or new formulation.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugProduct .

ind:principalInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Principal investigator accountability for GCP compliance, protocol execution, data integrity, and regulatory submissions. Currently plain text; FK enables GCP training verification, workload tracking,' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:studyCountryId rdf:type rdf:Property ;
    rdfs:label 'Study Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: BE studies conducted in specific countries for regulatory acceptance (country-specific BE guidelines), site management (CRO selection), regulatory strategy (bridging studies). Replaces denormalized st' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:apiName rdf:type rdf:Property ;
    rdfs:label 'Api Name' ;
    rdfs:comment 'The name of the active pharmaceutical ingredient being studied, typically the INN or USAN name.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auc90CiLower rdf:type rdf:Property ;
    rdfs:label 'Auc 90 Ci Lower' ;
    rdfs:comment 'The lower bound of the 90% confidence interval for the AUC ratio. Must typically be ≥80% for bioequivalence.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auc90CiUpper rdf:type rdf:Property ;
    rdfs:label 'Auc 90 Ci Upper' ;
    rdfs:comment 'The upper bound of the 90% confidence interval for the AUC ratio. Must typically be ≤125% for bioequivalence.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bioanalyticalMatrix rdf:type rdf:Property ;
    rdfs:label 'Bioanalytical Matrix' ;
    rdfs:comment 'The biological matrix in which drug concentrations were measured (e.g., plasma, serum, whole blood).' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bioanalyticalMethod rdf:type rdf:Property ;
    rdfs:label 'Bioanalytical Method' ;
    rdfs:comment 'The analytical method used to measure drug concentrations in biological samples (e.g., LC-MS/MS, HPLC).' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bioequivalenceConclusion rdf:type rdf:Property ;
    rdfs:label 'Bioequivalence Conclusion' ;
    rdfs:comment 'The final statistical conclusion of whether the test product is bioequivalent to the reference product based on the 90% confidence interval criteria.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmax90CiLower rdf:type rdf:Property ;
    rdfs:label 'Cmax 90 Ci Lower' ;
    rdfs:comment 'The lower bound of the 90% confidence interval for the Cmax ratio. Must typically be ≥80% for bioequivalence.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmax90CiUpper rdf:type rdf:Property ;
    rdfs:label 'Cmax 90 Ci Upper' ;
    rdfs:comment 'The upper bound of the 90% confidence interval for the Cmax ratio. Must typically be ≤125% for bioequivalence.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ectdModuleReference rdf:type rdf:Property ;
    rdfs:label 'Ectd Module Reference' ;
    rdfs:comment 'The eCTD module and section reference where this bioequivalence study is included in the regulatory submission (typically Module 5).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastingFedCondition rdf:type rdf:Property ;
    rdfs:label 'Fasting Fed Condition' ;
    rdfs:comment 'Indicates whether the study was conducted under fasting conditions, fed conditions, or both to assess food effect.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pkParameterAucRatio rdf:type rdf:Property ;
    rdfs:label 'Pk Parameter Auc Ratio' ;
    rdfs:comment 'The geometric mean ratio of area under the plasma concentration-time curve (AUC) for test versus reference product, expressed as a percentage.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pkParameterCmaxRatio rdf:type rdf:Property ;
    rdfs:label 'Pk Parameter Cmax Ratio' ;
    rdfs:comment 'The geometric mean ratio of maximum plasma concentration (Cmax) for test versus reference product, expressed as a percentage.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceProductFormulationCode rdf:type rdf:Property ;
    rdfs:label 'Reference Product Formulation Code' ;
    rdfs:comment 'The specific formulation code or batch identifier of the reference product used in the bioequivalence study.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceProductStrength rdf:type rdf:Property ;
    rdfs:label 'Reference Product Strength' ;
    rdfs:comment 'The dosage strength of the reference product administered in the study, including value and unit (e.g., 500 mg).' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Number' ;
    rdfs:comment 'The regulatory application number (ANDA, NDA, MAA) to which this bioequivalence study is submitted or referenced.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyPopulation rdf:type rdf:Property ;
    rdfs:label 'Study Population' ;
    rdfs:comment 'The type of population enrolled in the study. Most bioequivalence studies use healthy volunteers.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Study Protocol Number' ;
    rdfs:comment 'The unique protocol identifier assigned to this bioequivalence study by the sponsor or regulatory authority.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studySiteName rdf:type rdf:Property ;
    rdfs:label 'Study Site Name' ;
    rdfs:comment 'The name of the clinical site or facility where the bioequivalence study was conducted.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCountCompleted rdf:type rdf:Property ;
    rdfs:label 'Subject Count Completed' ;
    rdfs:comment 'The number of subjects who completed all study periods and assessments per protocol.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectCountEnrolled rdf:type rdf:Property ;
    rdfs:label 'Subject Count Enrolled' ;
    rdfs:comment 'The actual number of subjects enrolled and dosed in the bioequivalence study.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectCountPlanned rdf:type rdf:Property ;
    rdfs:label 'Subject Count Planned' ;
    rdfs:comment 'The planned number of subjects to be enrolled in the bioequivalence study as specified in the protocol.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testProductFormulationCode rdf:type rdf:Property ;
    rdfs:label 'Test Product Formulation Code' ;
    rdfs:comment 'The specific formulation code or batch identifier of the test product used in the bioequivalence study.' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testProductStrength rdf:type rdf:Property ;
    rdfs:label 'Test Product Strength' ;
    rdfs:comment 'The dosage strength of the test product administered in the study, including value and unit (e.g., 500 mg).' ;
    rdfs:domain ind:BioequivalenceStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationProductId rdf:type rdf:Property ;
    rdfs:label 'Combination Product Id' ;
    rdfs:comment 'Unique identifier for the combination product record. Primary key.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CombinationProduct .

ind:biologicConstituentClassification rdf:type rdf:Property ;
    rdfs:label 'Biologic Constituent Classification' ;
    rdfs:comment 'Regulatory status of the biologic constituent under BLA (Biologics License Application) or biosimilar pathway.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biologicConstituentName rdf:type rdf:Property ;
    rdfs:label 'Biologic Constituent Name' ;
    rdfs:comment 'Name of the biological product component if the combination product includes a biologic (e.g., monoclonal antibody, vaccine antigen, cell therapy).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmcDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Cmc Documentation Reference' ;
    rdfs:comment 'Reference identifier to the CMC section of regulatory submissions documenting manufacturing processes, specifications, and controls for both drug and device constituents.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationProductCode rdf:type rdf:Property ;
    rdfs:label 'Combination Product Code' ;
    rdfs:comment 'Business identifier code assigned to the combination product for internal tracking and regulatory submissions.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationType rdf:type rdf:Property ;
    rdfs:label 'Combination Type' ;
    rdfs:comment 'Classification of the combination product based on constituent components (e.g., drug-device for auto-injectors, drug-biologic for antibody-drug conjugates).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossLabelingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Labeling Requirement Flag' ;
    rdfs:comment 'Indicates whether the combination product requires coordinated labeling across drug and device constituents to ensure consistent safety and efficacy information.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceConstituentClassification rdf:type rdf:Property ;
    rdfs:label 'Device Constituent Classification' ;
    rdfs:comment 'FDA device classification and regulatory pathway for the device constituent (510k=premarket notification, PMA=premarket approval, De Novo=novel device classification).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceConstituentName rdf:type rdf:Property ;
    rdfs:label 'Device Constituent Name' ;
    rdfs:comment 'Name or description of the device component of the combination product (e.g., auto-injector, prefilled syringe, transdermal patch delivery system, drug-eluting stent).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceDesignHistoryFileReference rdf:type rdf:Property ;
    rdfs:label 'Device Design History File Reference' ;
    rdfs:comment 'Reference identifier to the Design History File documenting the device constituent design, development, and verification activities per Quality System Regulation (QSR).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugConstituentClassification rdf:type rdf:Property ;
    rdfs:label 'Drug Constituent Classification' ;
    rdfs:comment 'Regulatory status of the drug constituent (NDA=New Drug Application, ANDA=Abbreviated New Drug Application, BLA=Biologics License Application, IND=Investigational New Drug).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugConstituentName rdf:type rdf:Property ;
    rdfs:label 'Drug Constituent Name' ;
    rdfs:comment 'Name of the drug substance or drug product component of the combination product, including Active Pharmaceutical Ingredient (API) identification.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugConstituentStrength rdf:type rdf:Property ;
    rdfs:label 'Drug Constituent Strength' ;
    rdfs:comment 'Quantitative composition of the drug constituent expressed with unit of measure (e.g., 50 mg, 0.3 mL of 1 mg/mL solution).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Status' ;
    rdfs:comment 'Current GMP compliance status for the combination product manufacturing operations based on FDA inspection outcomes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanFactorsStudyStatus rdf:type rdf:Property ;
    rdfs:label 'Human Factors Study Status' ;
    rdfs:comment 'Status of human factors engineering and usability validation studies required for the device constituent to demonstrate safe and effective use by intended users.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadCenter rdf:type rdf:Property ;
    rdfs:label 'Lead Center' ;
    rdfs:comment 'FDA center assigned primary jurisdiction for premarket review and regulation (CDER=Center for Drug Evaluation and Research, CDRH=Center for Devices and Radiological Health, CBER=Center for Biologics Evaluation and Research).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryModeOfAction rdf:type rdf:Property ;
    rdfs:label 'Primary Mode Of Action' ;
    rdfs:comment 'The single mode of action that provides the most important therapeutic action of the combination product, used to determine lead center assignment.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Requirement Flag' ;
    rdfs:comment 'Indicates whether the combination product is subject to a Risk Evaluation and Mitigation Strategy to ensure benefits outweigh risks.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rldAssignmentDate rdf:type rdf:Property ;
    rdfs:label 'Rld Assignment Date' ;
    rdfs:comment 'Date when the FDA assigned the lead center designation for this combination product following RLD submission.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Months' ;
    rdfs:comment 'Approved shelf life of the combination product in months from date of manufacture, based on stability studies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceComponentId rdf:type rdf:Property ;
    rdfs:label 'Device Component Id' ;
    rdfs:comment 'Unique identifier for the device component record in drug-device combination products. Primary key.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Supplier Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Device component suppliers require business partner master integration for quality agreements, supplier qualification (AVL management), supplier audits, procurement (PO processing), supplier performan' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:biocompatibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Biocompatibility Status' ;
    rdfs:comment 'Status of biocompatibility testing per ISO 10993 standards to ensure materials are safe for patient contact.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCode rdf:type rdf:Property ;
    rdfs:label 'Component Code' ;
    rdfs:comment 'Unique business identifier code for the device component used across regulatory submissions and manufacturing systems.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentName rdf:type rdf:Property ;
    rdfs:label 'Component Name' ;
    rdfs:comment 'Official name of the device component as registered with regulatory authorities.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designHistoryFileReference rdf:type rdf:Property ;
    rdfs:label 'Design History File Reference' ;
    rdfs:comment 'Reference identifier to the Design History File containing all design and development documentation per FDA QSR requirements.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceClass rdf:type rdf:Property ;
    rdfs:label 'Device Class' ;
    rdfs:comment 'FDA device classification (Class I, II, or III) based on risk level and regulatory controls required.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceMasterFileNumber rdf:type rdf:Property ;
    rdfs:label 'Device Master File Number' ;
    rdfs:comment 'FDA Device Master File number containing confidential detailed information about the device component manufacturing and specifications.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Classification of the device component type used in the combination product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseAccuracySpecification rdf:type rdf:Property ;
    rdfs:label 'Dose Accuracy Specification' ;
    rdfs:comment 'Specification for dose delivery accuracy expressed as percentage or absolute value tolerance range.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseDeliveryMechanism rdf:type rdf:Property ;
    rdfs:label 'Dose Delivery Mechanism' ;
    rdfs:comment 'Technical description of how the device component delivers the drug substance to the patient including mechanism of action and delivery rate control.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingNumber rdf:type rdf:Property ;
    rdfs:label 'Drawing Number' ;
    rdfs:comment 'Engineering drawing number for the device component design and dimensional specifications.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanFactorsStudyReference rdf:type rdf:Property ;
    rdfs:label 'Human Factors Study Reference' ;
    rdfs:comment 'Reference identifier to the human factors validation study documentation and results.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanFactorsValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Human Factors Validation Status' ;
    rdfs:comment 'Status of human factors engineering validation studies to ensure safe and effective use by intended users.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether the device component record is currently active and in use.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Detailed description of materials used in the device component construction including polymers, metals, elastomers, and coatings.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:needleGauge rdf:type rdf:Property ;
    rdfs:label 'Needle Gauge' ;
    rdfs:comment 'Gauge size of the needle component if applicable to the device type (e.g., 27G for auto-injectors).' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:needleLengthMm rdf:type rdf:Property ;
    rdfs:label 'Needle Length Mm' ;
    rdfs:comment 'Length of the needle component in millimeters if applicable to the device type.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominalDoseVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Nominal Dose Volume Ml' ;
    rdfs:comment 'The intended volume of drug product that the device component is designed to deliver in milliliters.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'Regulatory approval or clearance number from health authorities (e.g., FDA 510(k), PMA number) for the device component.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Specification Document Reference' ;
    rdfs:comment 'Reference identifier to the detailed technical specification document defining all design requirements and acceptance criteria.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sterilityRequirement rdf:type rdf:Property ;
    rdfs:label 'Sterility Requirement' ;
    rdfs:comment 'Indicates whether the device component must be manufactured and maintained in sterile condition.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Status' ;
    rdfs:comment 'Current qualification status of the device component supplier based on quality system audits and performance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useErrorRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Use Error Risk Level' ;
    rdfs:comment 'Risk level assessment for potential use errors based on human factors analysis and failure mode effects analysis.' ;
    rdfs:domain ind:DeviceComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalCountryId rdf:type rdf:Property ;
    rdfs:label 'Approval Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Drug products approved in specific jurisdictions for market authorization tracking, regulatory submissions (country-specific dossiers), supply planning (market-specific manufacturing), labeling (count' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:developmentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Development Cost Center Id' ;
    rdfs:comment 'Foreign key linking to masterdata.cost_center. Business justification: Drug products assigned to cost centers for R&D capitalization (IAS 38), portfolio accounting, project costing. Enables financial tracking of development costs by product, capitalization decisions (tec' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:developmentLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Development Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Product development lead for formulation design, process development, scale-up, and tech transfer. Core R&D accountability for CMC sections of regulatory submissions and manufacturing readiness. Essen' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rldProductId rdf:type rdf:Property ;
    rdfs:label 'Rld Product Id' ;
    rdfs:comment 'Reference to the RLD drug product if this product is a generic or biosimilar requiring bioequivalence demonstration.' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugProduct .

ind:blackBoxWarningFlag rdf:type rdf:Property ;
    rdfs:label 'Black Box Warning Flag' ;
    rdfs:comment 'Indicates whether the drug product labeling includes a black box warning (boxed warning) for serious or life-threatening risks.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmcSummary rdf:type rdf:Property ;
    rdfs:label 'Cmc Summary' ;
    rdfs:comment 'High-level summary of the chemistry, manufacturing, and controls information for the drug product, including formulation composition and manufacturing process overview.' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipients rdf:type rdf:Property ;
    rdfs:label 'Excipients' ;
    rdfs:comment 'List of inactive ingredients (excipients) used in the drug product formulation, such as binders, fillers, preservatives, and colorants.' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationType rdf:type rdf:Property ;
    rdfs:label 'Formulation Type' ;
    rdfs:comment 'Classification of the drug product formulation based on release characteristics (e.g., immediate release, extended release, delayed release, modified release, controlled release).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moa rdf:type rdf:Property ;
    rdfs:label 'Moa' ;
    rdfs:comment 'Description of the biochemical or physiological mechanism by which the drug product exerts its therapeutic effect.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'The primary packaging configuration for the drug product (e.g., bottle, blister pack, vial, ampule, prefilled syringe, tube).' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Prescription Status' ;
    rdfs:comment 'Indicates whether the drug product requires a prescription (Rx), is available over-the-counter (OTC), or is behind-the-counter.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rldFlag rdf:type rdf:Property ;
    rdfs:label 'Rld Flag' ;
    rdfs:comment 'Indicates whether this drug product is designated as a Reference Listed Drug by the FDA for bioequivalence studies.' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strengthValue rdf:type rdf:Property ;
    rdfs:label 'Strength Value' ;
    rdfs:comment 'Numeric value of the active pharmaceutical ingredient strength for computational and analytical purposes.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: API manufacturer legal entity required for Drug Master File (DMF) holder identification, supplier qualification, regulatory filings (CTD Module 3), GMP compliance tracking. Replaces denormalized manuf' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:technicalOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technical Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Subject matter expert accountability for CMC documentation, DMF maintenance, regulatory filings, and manufacturing support. Required for regulatory inspections and technical transfer activities. Stand' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bcsClassification rdf:type rdf:Property ;
    rdfs:label 'Bcs Classification' ;
    rdfs:comment 'BCS classification of the drug substance based on solubility and permeability characteristics (Class I: high solubility/high permeability, Class II: low solubility/high permeability, Class III: high solubility/low permeability, Class IV: low solubility/low permeability).' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalName rdf:type rdf:Property ;
    rdfs:label 'Chemical Name' ;
    rdfs:comment 'Systematic IUPAC chemical name describing the molecular structure of the drug substance according to international nomenclature standards.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nceDesignation rdf:type rdf:Property ;
    rdfs:label 'Nce Designation' ;
    rdfs:comment 'Indicates whether the drug substance has been designated as a New Chemical Entity by regulatory authorities, qualifying for extended data exclusivity periods.' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:particleSizeSpecification rdf:type rdf:Property ;
    rdfs:label 'Particle Size Specification' ;
    rdfs:comment 'Defined particle size distribution range or specification for the drug substance, critical for dissolution and bioavailability (e.g., D50 < 10 microns).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacopoeialMonograph rdf:type rdf:Property ;
    rdfs:label 'Pharmacopoeial Monograph' ;
    rdfs:comment 'Reference to the official pharmacopoeial monograph (USP, EP, JP, or other) that defines quality standards for the drug substance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalForm rdf:type rdf:Property ;
    rdfs:label 'Physical Form' ;
    rdfs:comment 'Physical state or form of the drug substance at standard conditions (e.g., crystalline solid, liquid, lyophilized powder).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polymorphicForm rdf:type rdf:Property ;
    rdfs:label 'Polymorphic Form' ;
    rdfs:comment 'Specific crystalline or amorphous form of the drug substance, identifying the polymorph used in manufacturing (e.g., Form I, Form II, anhydrous, hydrate).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Summary of regulatory approval status across major markets (FDA, EMA, PMDA, etc.), indicating where the drug substance has received marketing authorization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Retest Period Months' ;
    rdfs:comment 'Time period in months after which the drug substance should be re-examined to ensure it still meets specifications before use in manufacturing.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saltForm rdf:type rdf:Property ;
    rdfs:label 'Salt Form' ;
    rdfs:comment 'Chemical salt form of the drug substance if applicable (e.g., hydrochloride, sodium, sulfate), or \'free base\' or \'free acid\' if not a salt.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solubilityProfile rdf:type rdf:Property ;
    rdfs:label 'Solubility Profile' ;
    rdfs:comment 'Aqueous solubility characteristics of the drug substance across physiologically relevant pH ranges, critical for formulation development and bioavailability.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version identifier for the current quality specification document defining acceptance criteria for the drug substance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityProfile rdf:type rdf:Property ;
    rdfs:label 'Stability Profile' ;
    rdfs:comment 'Summary of the drug substance\'s stability characteristics under various storage conditions, including temperature and humidity sensitivity.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stereochemistry rdf:type rdf:Property ;
    rdfs:label 'Stereochemistry' ;
    rdfs:comment 'Three-dimensional spatial arrangement of atoms in the drug substance molecule, including chirality and isomeric configuration (e.g., R/S designation, E/Z configuration).' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synthesisRouteVersion rdf:type rdf:Property ;
    rdfs:label 'Synthesis Route Version' ;
    rdfs:comment 'Version identifier for the chemical synthesis route or manufacturing process used to produce the drug substance, enabling change control and traceability.' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticClass rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Class' ;
    rdfs:comment 'Primary therapeutic classification of the drug substance based on its clinical use and pharmacological properties.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether the excipient contains or is derived from known allergens. Critical for patient safety labeling and formulation risk assessment.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenType rdf:type rdf:Property ;
    rdfs:label 'Allergen Type' ;
    rdfs:comment 'Specific allergen classification if allergen_flag is true. Examples include lactose (milk-derived), gelatin (animal-derived), or gluten.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalDerivedFlag rdf:type rdf:Property ;
    rdfs:label 'Animal Derived Flag' ;
    rdfs:comment 'Indicates whether the excipient is derived from animal sources. Important for TSE/BSE risk assessment and religious/dietary considerations.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compendialGrade rdf:type rdf:Property ;
    rdfs:label 'Compendial Grade' ;
    rdfs:comment 'Pharmacopoeial grade or quality standard to which the excipient conforms. Indicates the regulatory monograph governing quality specifications.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compendialMonograph rdf:type rdf:Property ;
    rdfs:label 'Compendial Monograph' ;
    rdfs:comment 'Specific pharmacopoeial monograph reference number or title that defines quality standards, test methods, and acceptance criteria for the excipient.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipientCode rdf:type rdf:Property ;
    rdfs:label 'Excipient Code' ;
    rdfs:comment 'Unique business identifier or material master code for the excipient used across manufacturing, procurement, and formulation systems. Typically aligned with ERP material master.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipientName rdf:type rdf:Property ;
    rdfs:label 'Excipient Name' ;
    rdfs:comment 'Common or trade name of the excipient as used in formulation documentation and manufacturing records.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCategory rdf:type rdf:Property ;
    rdfs:label 'Functional Category' ;
    rdfs:comment 'Primary functional role of the excipient in drug product formulation. Defines the excipient\'s purpose in the dosage form.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoStatus rdf:type rdf:Property ;
    rdfs:label 'Gmo Status' ;
    rdfs:comment 'Indicates whether the excipient is derived from genetically modified organisms. Required for labeling in certain jurisdictions.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationReference rdf:type rdf:Property ;
    rdfs:label 'Specification Reference' ;
    rdfs:comment 'Document reference or identifier for the approved quality specification defining acceptance criteria, test methods, and release requirements for the excipient.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlantId rdf:type rdf:Property ;
    rdfs:label 'Development Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Formulation development site tracking for technology transfer documentation, scale-up studies, process validation, site-specific design space. Critical for CMC regulatory submissions (CTD Module 3), m' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:scientistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Scientist Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Formulation scientist responsible for QbD design space, CPP/CQA definition, stability strategy, and regulatory documentation. Direct accountability for formulation performance and regulatory defense. ' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:apiCount rdf:type rdf:Property ;
    rdfs:label 'Api Count' ;
    rdfs:comment 'Number of distinct active pharmaceutical ingredients (APIs) in the formulation. Most formulations have 1 API; combination products have 2 or more.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Batch Size Target' ;
    rdfs:comment 'Planned or standard batch size for manufacturing this formulation, expressed in the unit specified by batch_size_uom. Used for scale-up calculations and manufacturing planning.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bioequivalenceReference rdf:type rdf:Property ;
    rdfs:label 'Bioequivalence Reference' ;
    rdfs:comment 'Reference to bioequivalence or bioavailability studies conducted for this formulation, particularly relevant for generic formulations or formulation changes requiring bridging studies.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositionDescription rdf:type rdf:Property ;
    rdfs:label 'Composition Description' ;
    rdfs:comment 'Detailed textual description of the formulation composition, including all active and inactive ingredients, their roles, and quantities. Supports CMC Module 3 documentation and regulatory submissions.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cppSummary rdf:type rdf:Property ;
    rdfs:label 'Cpp Summary' ;
    rdfs:comment 'Summary of critical process parameters (CPPs) identified for this formulation. CPPs are process parameters whose variability has an impact on a critical quality attribute (CQA) and therefore should be monitored or controlled.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cqaSummary rdf:type rdf:Property ;
    rdfs:label 'Cqa Summary' ;
    rdfs:comment 'Summary of critical quality attributes (CQAs) for this formulation. CQAs are physical, chemical, biological, or microbiological properties that should be within an appropriate limit, range, or distribution to ensure the desired product quality.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when this formulation record was first created in the system. Part of audit trail for formulation lifecycle management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designSpaceDescription rdf:type rdf:Property ;
    rdfs:label 'Design Space Description' ;
    rdfs:comment 'Textual summary of the QbD design space, including key input variables, process parameters, and their acceptable ranges. References supporting studies and risk assessments.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipientCount rdf:type rdf:Property ;
    rdfs:label 'Excipient Count' ;
    rdfs:comment 'Number of distinct inactive ingredients (excipients) in the formulation. Includes fillers, binders, disintegrants, lubricants, coatings, preservatives, and other functional excipients.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formulationCode rdf:type rdf:Property ;
    rdfs:label 'Formulation Code' ;
    rdfs:comment 'Business identifier for the formulation, used across manufacturing, regulatory, and quality systems. Typically follows internal coding conventions for Chemistry Manufacturing and Controls (CMC) documentation.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationName rdf:type rdf:Property ;
    rdfs:label 'Formulation Name' ;
    rdfs:comment 'Human-readable name or title of the formulation, often including the drug product name, strength, and dosage form (e.g., \'Compound XYZ 50mg Tablet Formulation\').' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationStatus rdf:type rdf:Property ;
    rdfs:label 'Formulation Status' ;
    rdfs:comment 'Current lifecycle status of the formulation. Tracks progression from early development through commercial manufacturing and potential discontinuation.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpGradeRequired rdf:type rdf:Property ;
    rdfs:label 'Gmp Grade Required' ;
    rdfs:comment 'Indicates the GMP grade required for manufacturing this formulation: clinical (for investigational products), commercial (for marketed products), or both (for formulations used in both contexts).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when this formulation record was last modified. Tracks changes to formulation specifications, status, or metadata.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentProtected rdf:type rdf:Property ;
    rdfs:label 'Patent Protected' ;
    rdfs:comment 'Indicates whether this formulation is covered by one or more patents, providing intellectual property protection. Links to patent records in the intellectual property domain.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pharmacopoeialStandard rdf:type rdf:Property ;
    rdfs:label 'Pharmacopoeial Standard' ;
    rdfs:comment 'Primary pharmacopoeial standard to which this formulation conforms (USP = United States Pharmacopeia, EP = European Pharmacopoeia, JP = Japanese Pharmacopoeia, BP = British Pharmacopoeia, IP = Indian Pharmacopoeia, ChP = Chinese Pharmacopoeia).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbdDesignSpaceDefined rdf:type rdf:Property ;
    rdfs:label 'Qbd Design Space Defined' ;
    rdfs:comment 'Indicates whether a Quality by Design (QbD) design space has been established for this formulation, defining the multidimensional combination of input variables and process parameters that ensure quality.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scaleUpFactor rdf:type rdf:Property ;
    rdfs:label 'Scale Up Factor' ;
    rdfs:comment 'Ratio of commercial batch size to development batch size, indicating the degree of scale-up achieved. Used to assess scale-up risk and process robustness.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stabilityProfileSummary rdf:type rdf:Property ;
    rdfs:label 'Stability Profile Summary' ;
    rdfs:comment 'Summary of stability characteristics for this formulation, including storage conditions, shelf life, and key degradation pathways. References formal stability studies conducted per ICH Q1A guidelines.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitDoseStrength rdf:type rdf:Property ;
    rdfs:label 'Unit Dose Strength' ;
    rdfs:comment 'Quantity of active pharmaceutical ingredient (API) per unit dose (e.g., 50 mg per tablet, 100 mg/mL for solution). Expressed in the unit specified by unit_dose_strength_uom.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulationIngredientId rdf:type rdf:Property ;
    rdfs:label 'Formulation Ingredient Id' ;
    rdfs:comment 'Unique identifier for each ingredient record within a formulation. Primary key for the formulation ingredient entity.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormulationIngredient .

ind:batchQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Batch Quantity Uom' ;
    rdfs:comment 'Unit of measure for the batch quantity: kilograms (kg), grams (g), liters (L), milliliters (mL), or units.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalQualityAttributeFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Quality Attribute Flag' ;
    rdfs:comment 'Indicates whether this ingredient is designated as a Critical Quality Attribute under Quality by Design (QbD) principles, requiring enhanced control and monitoring.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingredientFunction rdf:type rdf:Property ;
    rdfs:label 'Ingredient Function' ;
    rdfs:comment 'Specific functional role of the ingredient in the formulation such as binder, filler, disintegrant, lubricant, coating agent, or flavoring agent. Critical for Quality by Design (QbD) and regulatory submissions.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientName rdf:type rdf:Property ;
    rdfs:label 'Ingredient Name' ;
    rdfs:comment 'Common or trade name of the ingredient as used in manufacturing documentation and internal systems.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ingredient Sequence Number' ;
    rdfs:comment 'Sequential ordering of ingredients within the formulation, used for manufacturing instructions and regulatory documentation.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingredientType rdf:type rdf:Property ;
    rdfs:label 'Ingredient Type' ;
    rdfs:comment 'Classification of the ingredient role in the formulation: Active Pharmaceutical Ingredient (API), excipient, solvent, preservative, stabilizer, or colorant.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overageJustification rdf:type rdf:Property ;
    rdfs:label 'Overage Justification' ;
    rdfs:comment 'Business and scientific rationale for the overage percentage, including stability data, manufacturing loss studies, or regulatory requirements. Required for regulatory submissions and quality documentation.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerBatch rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Batch' ;
    rdfs:comment 'Total amount of the ingredient required for a standard manufacturing batch. Used for batch record generation, material planning, and manufacturing execution.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityPerUnitDose rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Unit Dose' ;
    rdfs:comment 'Amount of the ingredient present in a single unit dose (e.g., one tablet, one capsule, one vial). Used for labeling, regulatory submissions, and quality control.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retestPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retest Period Days' ;
    rdfs:comment 'Number of days after which the ingredient must be retested to confirm it still meets specifications before use in manufacturing. Part of stability and quality management programs.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Product Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Product manager accountability for lifecycle management, regulatory submissions, launch planning, and strategic decisions. Essential for portfolio management reporting and regulatory inspection readin' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:referenceProductId rdf:type rdf:Property ;
    rdfs:label 'Reference Product Id' ;
    rdfs:comment 'For biosimilar products only: the medicinal_product_id of the reference biologic (originator product) to which this biosimilar has demonstrated similarity. Null for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicinalProduct .

ind:registrationCountryId rdf:type rdf:Property ;
    rdfs:label 'Registration Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Products registered in specific countries/markets for regulatory compliance (market authorization tracking), commercial operations (launch planning), pharmacovigilance (country-specific safety reporti' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:analyticalSimilarityOutcome rdf:type rdf:Property ;
    rdfs:label 'Analytical Similarity Outcome' ;
    rdfs:comment 'For biosimilar products only: the outcome of the analytical similarity assessment comparing the biosimilar to the reference product across structural, functional, and physicochemical characteristics. Not Applicable for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extrapolationStatus rdf:type rdf:Property ;
    rdfs:label 'Extrapolation Status' ;
    rdfs:comment 'For biosimilar products only: indicates the extent to which clinical data from one indication of the reference product has been extrapolated to support approval for other indications of the biosimilar. Not Applicable for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstApprovalDate rdf:type rdf:Property ;
    rdfs:label 'First Approval Date' ;
    rdfs:comment 'The date on which the medicinal product received its first regulatory approval from any major regulatory authority (FDA, EMA, PMDA, etc.).' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interchangeabilityDesignation rdf:type rdf:Property ;
    rdfs:label 'Interchangeability Designation' ;
    rdfs:comment 'For biosimilar products only: indicates whether the FDA has designated this biosimilar as interchangeable with the reference product, allowing automatic substitution at the pharmacy level. Not Applicable for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorBlaNumber rdf:type rdf:Property ;
    rdfs:label 'Originator Bla Number' ;
    rdfs:comment 'For biosimilar products only: the FDA BLA number of the reference biologic product (e.g., BLA125057 for Humira). Null for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorMaaNumber rdf:type rdf:Property ;
    rdfs:label 'Originator Maa Number' ;
    rdfs:comment 'For biosimilar products only: the EMA Marketing Authorization Application number of the reference biologic product. Null for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pediatricIndication rdf:type rdf:Property ;
    rdfs:label 'Pediatric Indication' ;
    rdfs:comment 'Indicates whether the medicinal product has an approved indication for use in pediatric populations (patients under 18 years of age).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prescriptionRequired rdf:type rdf:Property ;
    rdfs:label 'Prescription Required' ;
    rdfs:comment 'Indicates whether the medicinal product requires a prescription from a licensed healthcare professional for dispensing (true for Rx products, false for OTC products).' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qbdApproach rdf:type rdf:Property ;
    rdfs:label 'Qbd Approach' ;
    rdfs:comment 'Indicates whether the medicinal product was developed using Quality by Design (QbD) principles with defined design space, critical quality attributes (CQAs), and critical process parameters (CPPs).' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Designation' ;
    rdfs:comment 'Special regulatory designations granted to the medicinal product (e.g., Orphan Drug, Breakthrough Therapy, Fast Track, Priority Review, Accelerated Approval, PRIME designation). Multiple designations may be concatenated.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration Id' ;
    rdfs:comment 'Unique identifier for the packaging configuration record. Primary key.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingConfiguration .

ind:packagingPlantId rdf:type rdf:Property ;
    rdfs:label 'Packaging Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Packaging operations site assignment for capacity planning, serialization compliance (plant-level aggregation), secondary packaging operations, distribution planning. Required for Track & Trace regula' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:aggregationHierarchy rdf:type rdf:Property ;
    rdfs:label 'Aggregation Hierarchy' ;
    rdfs:comment 'Description of the parent-child aggregation structure for serialized units (e.g., unit > case > pallet) used in track-and-trace systems.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childResistantPackaging rdf:type rdf:Property ;
    rdfs:label 'Child Resistant Packaging' ;
    rdfs:comment 'Indicates whether the packaging meets child-resistant standards to prevent accidental ingestion by children.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureType rdf:type rdf:Property ;
    rdfs:label 'Closure Type' ;
    rdfs:comment 'Type of closure used to seal the primary container, ensuring product integrity and preventing contamination. [ENUM-REF-CANDIDATE: rubber_stopper|screw_cap|flip_off_cap|child_resistant_cap|tamper_evident_seal|heat_seal|crimp_seal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Unique business identifier for the packaging configuration used across manufacturing, supply chain, and commercial systems.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Human-readable name describing the packaging configuration, typically including container type, pack size, and market designation.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationType rdf:type rdf:Property ;
    rdfs:label 'Configuration Type' ;
    rdfs:comment 'Classification of the packaging configuration based on its intended use and distribution channel.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Fill Volume Ml' ;
    rdfs:comment 'Volume of drug product filled into the primary container, measured in milliliters. Critical for dosing accuracy and overfill calculations.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'GS1 Global Trade Item Number (GTIN-14) used for supply chain identification and track-and-trace serialization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headspaceVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Headspace Volume Ml' ;
    rdfs:comment 'Volume of air or inert gas in the primary container above the drug product, important for stability and oxidation control.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lightProtectionRequired rdf:type rdf:Property ;
    rdfs:label 'Light Protection Required' ;
    rdfs:comment 'Indicates whether the packaging must protect the drug product from light exposure to prevent photodegradation.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketAuthorizationCountry rdf:type rdf:Property ;
    rdfs:label 'Market Authorization Country' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary market or regulatory jurisdiction for which this packaging configuration is authorized.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureProtectionRequired rdf:type rdf:Property ;
    rdfs:label 'Moisture Protection Required' ;
    rdfs:comment 'Indicates whether the packaging must provide moisture barrier protection to prevent hygroscopic degradation.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nominalFillVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Nominal Fill Volume Ml' ;
    rdfs:comment 'Labeled or declared fill volume on the packaging, which may differ from actual fill volume due to overfill requirements.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageInsertVersion rdf:type rdf:Property ;
    rdfs:label 'Package Insert Version' ;
    rdfs:comment 'Version identifier of the package insert or patient information leaflet included with this packaging configuration.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContainerMaterial rdf:type rdf:Property ;
    rdfs:label 'Primary Container Material' ;
    rdfs:comment 'Material composition of the primary container, critical for stability and compatibility with the drug substance. [ENUM-REF-CANDIDATE: glass_type_i|glass_type_ii|glass_type_iii|plastic_hdpe|plastic_ldpe|plastic_pet|plastic_pp|aluminum|laminate — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContainerType rdf:type rdf:Property ;
    rdfs:label 'Primary Container Type' ;
    rdfs:comment 'Type of primary container that is in direct contact with the drug product, part of the container closure system (CCS). [ENUM-REF-CANDIDATE: vial|ampoule|blister|bottle|syringe|cartridge|pen|inhaler|sachet|tube|pouch — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPackagingMaterial rdf:type rdf:Property ;
    rdfs:label 'Secondary Packaging Material' ;
    rdfs:comment 'Material composition of the secondary packaging, selected for protection, sustainability, and regulatory compliance.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPackagingType rdf:type rdf:Property ;
    rdfs:label 'Secondary Packaging Type' ;
    rdfs:comment 'Type of secondary packaging that contains one or more primary containers, providing additional protection and labeling space. [ENUM-REF-CANDIDATE: carton|wallet|box|tray|shrink_wrap|bundle|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationLevel rdf:type rdf:Property ;
    rdfs:label 'Serialization Level' ;
    rdfs:comment 'Level at which unique serialization is applied for track-and-trace compliance (unit, pack, case, or pallet level).' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Description' ;
    rdfs:comment 'Detailed textual description of storage conditions including temperature range, humidity, light protection, and orientation requirements.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum storage temperature in degrees Celsius required to maintain product stability and efficacy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum storage temperature in degrees Celsius required to maintain product stability and efficacy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tamperEvidentFeature rdf:type rdf:Property ;
    rdfs:label 'Tamper Evident Feature' ;
    rdfs:comment 'Type of tamper-evident feature incorporated into the packaging to ensure product integrity and patient safety.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tertiaryPackagingType rdf:type rdf:Property ;
    rdfs:label 'Tertiary Packaging Type' ;
    rdfs:comment 'Type of tertiary or shipper packaging used for bulk distribution and logistics, containing multiple secondary packs.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPerPrimaryPack rdf:type rdf:Property ;
    rdfs:label 'Units Per Primary Pack' ;
    rdfs:comment 'Number of individual dosage units (tablets, capsules, vials) contained in the primary packaging.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsPerSecondaryPack rdf:type rdf:Property ;
    rdfs:label 'Units Per Secondary Pack' ;
    rdfs:comment 'Number of primary containers included in one secondary package unit.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsPerTertiaryPack rdf:type rdf:Property ;
    rdfs:label 'Units Per Tertiary Pack' ;
    rdfs:comment 'Number of secondary packages contained in one tertiary shipper or case for distribution.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pharmaceuticalProductId rdf:type rdf:Property ;
    rdfs:label 'Pharmaceutical Product Id' ;
    rdfs:comment 'Unique identifier for the pharmaceutical product record. Primary key for the administrable pharmaceutical product entity per IDMP ISO 11616 standard.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specifiedSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Specified Substance Id' ;
    rdfs:comment 'Reference to the primary active pharmaceutical ingredient (API) or drug substance contained in this administrable pharmaceutical product. Links to the molecular entity responsible for therapeutic effect.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpecifiedSubstance .

ind:administrableDoseForm rdf:type rdf:Property ;
    rdfs:label 'Administrable Dose Form' ;
    rdfs:comment 'The pharmaceutical dose form of the product after any necessary preparation steps and as administered to the patient (e.g., solution for injection, powder for oral suspension, inhalation aerosol). Distinct from manufactured dose form.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrationDevice rdf:type rdf:Property ;
    rdfs:label 'Administration Device' ;
    rdfs:comment 'The medical device or delivery system used to administer the pharmaceutical product (e.g., pre-filled syringe, auto-injector, nebulizer, infusion pump, metered-dose inhaler). Relevant for combination products.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationValue rdf:type rdf:Property ;
    rdfs:label 'Concentration Value' ;
    rdfs:comment 'The numeric concentration of the active pharmaceutical ingredient (API) in the administrable product. Used in conjunction with concentration unit for precise dosing.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dosingInstructions rdf:type rdf:Property ;
    rdfs:label 'Dosing Instructions' ;
    rdfs:comment 'Standard dosing instructions for the administrable pharmaceutical product, including recommended dose, frequency, and duration. Derived from approved prescribing information.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationSummary rdf:type rdf:Property ;
    rdfs:label 'Indication Summary' ;
    rdfs:comment 'A concise summary of the approved therapeutic indications for which this pharmaceutical product may be administered. Derived from approved product labeling.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Interchangeability Status' ;
    rdfs:comment 'For biological products, indicates whether the product has been designated as interchangeable with the reference product, allowing automatic substitution at the pharmacy level without prescriber intervention.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingAuthorizationHolder rdf:type rdf:Property ;
    rdfs:label 'Marketing Authorization Holder' ;
    rdfs:comment 'The legal entity that holds the marketing authorization for the pharmaceutical product and is responsible for its quality, safety, and efficacy. Also known as the license holder or applicant.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phpidCode rdf:type rdf:Property ;
    rdfs:label 'Phpid Code' ;
    rdfs:comment 'ISO 11616 compliant PhPID code uniquely identifying the administrable pharmaceutical product at the international level. Used for regulatory submissions and global product identification.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationInstructions rdf:type rdf:Property ;
    rdfs:label 'Preparation Instructions' ;
    rdfs:comment 'Instructions for preparing the pharmaceutical product for administration, including reconstitution, dilution, or mixing requirements. Critical for products requiring preparation before administration.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preservativeFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Preservative Free Flag' ;
    rdfs:comment 'Indicates whether the administrable pharmaceutical product is formulated without preservatives. Critical for products intended for intrathecal, intraocular, or neonatal use.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Required Flag' ;
    rdfs:comment 'Indicates whether a Risk Evaluation and Mitigation Strategy is required by FDA for this pharmaceutical product due to serious safety concerns. Impacts distribution and prescribing requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeAfterPreparationHours rdf:type rdf:Property ;
    rdfs:label 'Shelf Life After Preparation Hours' ;
    rdfs:comment 'The maximum time in hours that the pharmaceutical product remains stable and safe for administration after preparation (reconstitution, dilution, or opening). Critical for hospital pharmacy and clinical administration.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Total Volume Ml' ;
    rdfs:comment 'The total volume of the administrable pharmaceutical product in milliliters, applicable to liquid dose forms. Used for dose calculation and administration instructions.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfPresentation rdf:type rdf:Property ;
    rdfs:label 'Unit Of Presentation' ;
    rdfs:comment 'The discrete unit in which the pharmaceutical product is presented for administration (e.g., vial, syringe, tablet, capsule, ampoule, inhaler). Represents the smallest administrable unit.' ;
    rdfs:domain ind:PharmaceuticalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productChangeControlId rdf:type rdf:Property ;
    rdfs:label 'Product Change Control Id' ;
    rdfs:comment 'Unique identifier for the product change control record. Primary key.' ;
    rdfs:domain ind:ProductChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comparabilityProtocolId rdf:type rdf:Property ;
    rdfs:label 'Comparability Protocol Id' ;
    rdfs:comment 'Reference to the comparability protocol used to assess whether the change maintains product comparability and does not adversely affect quality, safety, or efficacy.' ;
    rdfs:domain ind:ProductChangeControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Protocol .

ind:affectedMarkets rdf:type rdf:Property ;
    rdfs:label 'Affected Markets' ;
    rdfs:comment 'Comma-separated list of geographic markets or regulatory jurisdictions affected by this change (e.g., USA, EU, JPN, CHN). Supports multi-market change coordination and regulatory strategy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Business category of the change indicating the affected area. CMC (Chemistry, Manufacturing, and Controls), manufacturing site, labeling, safety update, specification change, packaging, stability protocol, process parameter, analytical method, or excipient modification. [ENUM-REF-CANDIDATE: CMC|Manufacturing Site|Labeling|Safety|Specification|Packaging|Stability|Process|Analytical Method|Excipient — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed narrative description of the proposed or implemented change, including rationale, scope, and technical details. Captures the business justification and scientific basis for the modification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle status of the change control record within the regulatory and quality management workflow. [ENUM-REF-CANDIDATE: Draft|Submitted|Under Review|Approved|Rejected|Implemented|Withdrawn|Closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the regulatory change according to the applicable regulatory framework. Type IA/IB/II for EMA variations, PAS (Prior Approval Supplement), CBE (Changes Being Effected) for FDA, or Partial Change Application for PMDA. [ENUM-REF-CANDIDATE: Type IA|Type IB|Type II|PAS|CBE-30|CBE-0|Annual Report|Partial Change Application|Major Variation|Minor Variation — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficacyImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Efficacy Impact Level' ;
    rdfs:comment 'Assessed level of impact on product efficacy and therapeutic performance. High or Critical levels may require additional clinical data or bioequivalence studies.' ;
    rdfs:domain ind:ProductChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Date when the approved change was or will be implemented in commercial manufacturing, distribution, or labeling. Critical for supply chain and manufacturing execution planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Name or identifier of the person or department who initiated the change control request. Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:ProductChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether regulatory notification to the health authority is required for this change type. True if notification is mandatory, False if the change can be implemented without prior notification.' ;
    rdfs:domain ind:ProductChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Approval Required Flag' ;
    rdfs:comment 'Indicates whether prior approval from the health authority is required before implementing the change. True for PAS (Prior Approval Supplement) or Type II variations, False for CBE or Type IA/IB.' ;
    rdfs:domain ind:ProductChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Level' ;
    rdfs:comment 'Assessed level of impact on product quality attributes (CQA - Critical Quality Attributes). Drives the rigor of validation and testing requirements.' ;
    rdfs:domain ind:ProductChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCommitment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Commitment' ;
    rdfs:comment 'Description of any commitments made to the health authority as part of the change approval, such as post-approval studies, annual reports, or specific monitoring activities.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Level' ;
    rdfs:comment 'Assessed level of impact on patient safety and product safety profile. High or Critical levels trigger additional pharmacovigilance and risk management activities.' ;
    rdfs:domain ind:ProductChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityStudyRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Stability Study Required Flag' ;
    rdfs:comment 'Indicates whether additional stability studies are required to support the change. True if new stability data must be generated to demonstrate product shelf-life is maintained.' ;
    rdfs:domain ind:ProductChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Validation Required Flag' ;
    rdfs:comment 'Indicates whether process validation, analytical method validation, or computer system validation (CSV) is required to support this change. True if validation activities are mandatory.' ;
    rdfs:domain ind:ProductChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biomarkerRequirement rdf:type rdf:Property ;
    rdfs:label 'Biomarker Requirement' ;
    rdfs:comment 'Description of any required biomarker, genetic marker, or diagnostic test result that must be present for the patient to be eligible for this indication. Examples include specific gene mutations, protein expression levels, or companion diagnostic test results. Null if no biomarker requirement exists.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakthroughDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Designation Flag' ;
    rdfs:comment 'Boolean indicator of whether this product-indication combination has received breakthrough therapy designation from FDA, indicating preliminary clinical evidence of substantial improvement over existing therapies for serious conditions. True indicates breakthrough designation granted; False indicates not designated.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalTrialIdentifier rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Identifier' ;
    rdfs:comment 'Primary clinical trial registry identifier for the pivotal study that supported approval of this product-indication combination. Format examples: NCT########, EUCTR####-######-##, ISRCTN########. Null for indications not yet in clinical trials or approved without trial data.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationPartners rdf:type rdf:Property ;
    rdfs:label 'Combination Partners' ;
    rdfs:comment 'List or description of other drugs, biologics, or therapeutic modalities that are approved or recommended for use in combination with this product for this indication. Null if monotherapy or combination_therapy_flag is False.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationTherapyFlag rdf:type rdf:Property ;
    rdfs:label 'Combination Therapy Flag' ;
    rdfs:comment 'Boolean indicator of whether this indication requires or recommends the product be used in combination with other therapeutic agents. True indicates combination therapy; False indicates monotherapy or therapy-agnostic indication.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contraindicationSummary rdf:type rdf:Property ;
    rdfs:label 'Contraindication Summary' ;
    rdfs:comment 'Summary of absolute contraindications or patient populations for whom this product-indication is not recommended or is prohibited due to safety concerns. Includes conditions, co-medications, or patient characteristics that preclude use.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseSeverity rdf:type rdf:Property ;
    rdfs:label 'Disease Severity' ;
    rdfs:comment 'The severity classification of the disease or condition for which this indication applies. Mild indicates minor symptoms; moderate indicates significant symptoms; severe indicates major impact on function; critical indicates immediate life risk; life_threatening indicates high mortality risk; not_applicable for preventive indications.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10Description rdf:type rdf:Property ;
    rdfs:label 'Icd 10 Description' ;
    rdfs:comment 'Full text description of the ICD-10 code representing the disease or condition.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationName rdf:type rdf:Property ;
    rdfs:label 'Indication Name' ;
    rdfs:comment 'The common or clinical name of the therapeutic indication or disease state that the product is approved or being investigated to treat.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationType rdf:type rdf:Property ;
    rdfs:label 'Indication Type' ;
    rdfs:comment 'The therapeutic purpose or clinical use category of the product for this indication. Treatment is active disease management; prevention is disease avoidance; diagnosis is disease detection; prophylaxis is pre-exposure prevention; palliation is symptom relief; risk_reduction is lowering disease probability.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelClaimText rdf:type rdf:Property ;
    rdfs:label 'Label Claim Text' ;
    rdfs:comment 'The exact verbatim text from the approved product label or package insert describing the indication, including any limitations, patient population specifics, or conditional use statements. This is the regulatory-approved language for marketing and prescribing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingId rdf:type rdf:Property ;
    rdfs:label 'Labeling Id' ;
    rdfs:comment 'Unique identifier for the product labeling record. Primary key for the product labeling entity.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelId rdf:type rdf:Property ;
    rdfs:label 'Label Id' ;
    rdfs:comment 'Unique document identifier or reference number for the label file stored in the document management system (e.g., Veeva Vault document ID).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Label .

ind:adverseReactionsText rdf:type rdf:Property ;
    rdfs:label 'Adverse Reactions Text' ;
    rdfs:comment 'Full text of the Adverse Reactions section from the label, summarizing the most common and serious adverse events observed in clinical trials and post-marketing surveillance.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalPharmacologyText rdf:type rdf:Property ;
    rdfs:label 'Clinical Pharmacology Text' ;
    rdfs:comment 'Full text of the Clinical Pharmacology section from the label, describing the mechanism of action (MOA), pharmacokinetics (PK), and pharmacodynamics (PD) of the drug product.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contraindicationsText rdf:type rdf:Property ;
    rdfs:label 'Contraindications Text' ;
    rdfs:comment 'Full text of the Contraindications section from the label, listing situations where the drug product should not be used due to risk of harm.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosageAdministrationText rdf:type rdf:Property ;
    rdfs:label 'Dosage Administration Text' ;
    rdfs:comment 'Full text of the Dosage and Administration section from the label, providing instructions on how to prescribe, prepare, and administer the drug product.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugInteractionsText rdf:type rdf:Property ;
    rdfs:label 'Drug Interactions Text' ;
    rdfs:comment 'Full text of the Drug Interactions section from the label, describing known interactions with other drugs, foods, or substances that may affect efficacy or safety.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedName rdf:type rdf:Property ;
    rdfs:label 'Established Name' ;
    rdfs:comment 'The non-proprietary or generic name of the drug product, typically the International Nonproprietary Name (INN) or United States Adopted Name (USAN).' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationsText rdf:type rdf:Property ;
    rdfs:label 'Indications Text' ;
    rdfs:comment 'Full text of the Indications and Usage section from the label, describing the approved therapeutic uses and patient populations for the drug product.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Label Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the label is written (e.g., en for English, es for Spanish, ja for Japanese).' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelStatus rdf:type rdf:Property ;
    rdfs:label 'Label Status' ;
    rdfs:comment 'Current lifecycle status of the label. Draft = under development, Submitted = filed with regulatory authority, Approved = authorized but not yet effective, Active = currently in use, Superseded = replaced by newer version, Withdrawn = removed from use.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelType rdf:type rdf:Property ;
    rdfs:label 'Label Type' ;
    rdfs:comment 'Type of product label document. USPI = US Prescribing Information, SmPC = Summary of Product Characteristics (EU), PIL = Patient Information Leaflet, IFU = Instructions for Use.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelVersion rdf:type rdf:Property ;
    rdfs:label 'Label Version' ;
    rdfs:comment 'Version number of the product label following semantic versioning (e.g., 1.0, 2.1). Incremented with each regulatory update or revision.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pregnancyCategory rdf:type rdf:Property ;
    rdfs:label 'Pregnancy Category' ;
    rdfs:comment 'Legacy FDA pregnancy category (A, B, C, D, X) for products approved before the Pregnancy and Lactation Labeling Rule (PLLR). Not Applicable for products approved after PLLR implementation.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxOtcStatus rdf:type rdf:Property ;
    rdfs:label 'Rx Otc Status' ;
    rdfs:comment 'Indicates whether the product requires a prescription (Rx), is available over-the-counter (OTC), or is behind-the-counter (BTC) requiring pharmacist consultation.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useInSpecificPopulationsText rdf:type rdf:Property ;
    rdfs:label 'Use In Specific Populations Text' ;
    rdfs:comment 'Full text of the Use in Specific Populations section from the label, providing information on use in pregnancy, lactation, pediatric, geriatric, and patients with renal or hepatic impairment.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningsPrecautionsText rdf:type rdf:Property ;
    rdfs:label 'Warnings Precautions Text' ;
    rdfs:comment 'Full text of the Warnings and Precautions section from the label, describing serious adverse reactions, potential safety hazards, and steps to prevent or manage them.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Id' ;
    rdfs:comment 'Unique identifier for the product lifecycle record. Primary key for tracking lifecycle stage transitions of a medicinal product from discovery through post-market discontinuation.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateCriteriaMet rdf:type rdf:Property ;
    rdfs:label 'Gate Criteria Met' ;
    rdfs:comment 'Boolean flag indicating whether all predefined gate criteria for the current lifecycle stage have been successfully met. Used in stage-gate governance processes to authorize progression to next stage.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gateDecision rdf:type rdf:Property ;
    rdfs:label 'Gate Decision' ;
    rdfs:comment 'Formal decision outcome from the gate review committee. \'Go\' authorizes progression, \'conditional_go\' requires specific actions, \'hold\' pauses development, \'kill\' terminates the program, \'recycle\' returns to previous stage for additional work.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Gate Review Date' ;
    rdfs:comment 'Date when the formal gate review was conducted to assess readiness for stage transition. Part of the governance process ensuring disciplined portfolio management.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investmentToDate rdf:type rdf:Property ;
    rdfs:label 'Investment To Date' ;
    rdfs:comment 'Cumulative investment amount (in USD) spent on the product from inception through the current lifecycle stage. Includes R&D costs, clinical trial expenses, regulatory submission costs, and manufacturing setup. Used for ROI analysis and portfolio valuation.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneEvent rdf:type rdf:Property ;
    rdfs:label 'Milestone Event' ;
    rdfs:comment 'Description of the key milestone event that triggered the current lifecycle stage transition (e.g., \'IND Submission Accepted\', \'Phase III Primary Endpoint Met\', \'FDA Approval Granted\', \'Commercial Launch Completed\'). Provides business context for stage changes.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPlannedStage rdf:type rdf:Property ;
    rdfs:label 'Next Planned Stage' ;
    rdfs:comment 'The anticipated next lifecycle stage based on current development plans. Used for forward-looking portfolio planning and resource forecasting. May be null for discontinued or terminated products. [ENUM-REF-CANDIDATE: discovery|preclinical|phase_i|phase_ii|phase_iii|nda_bla_submission|maa_submission|approved|launched|loe|discontinued — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStage rdf:type rdf:Property ;
    rdfs:label 'Previous Stage' ;
    rdfs:comment 'The immediately preceding lifecycle stage before the current stage. Enables tracking of stage transitions and identification of products that have been moved backward (e.g., from Phase III back to Phase II due to protocol amendments). [ENUM-REF-CANDIDATE: discovery|preclinical|phase_i|phase_ii|phase_iii|nda_bla_submission|maa_submission|approved|launched|loe|discontinued — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfSuccess rdf:type rdf:Property ;
    rdfs:label 'Probability Of Success' ;
    rdfs:comment 'Estimated probability (as percentage, 0.00 to 100.00) that the product will successfully progress through all remaining lifecycle stages to commercial launch. Based on historical success rates, clinical data, and competitive landscape. Used in risk-adjusted portfolio valuation (rNPV).' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedPeakSales rdf:type rdf:Property ;
    rdfs:label 'Projected Peak Sales' ;
    rdfs:comment 'Forecasted annual peak sales revenue (in USD) for the product at market maturity. Used for portfolio prioritization, resource allocation, and commercial planning. Updated as market intelligence and clinical data evolve.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'Name or identifier of the functional team or business unit responsible for managing the product during the current lifecycle stage (e.g., \'Discovery Biology\', \'Clinical Development Oncology\', \'Regulatory Affairs\', \'Commercial Launch Team\').' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage of the medicinal product in its development and commercial lifecycle. Tracks progression from early research through regulatory approval, market launch, loss of exclusivity (LOE), and eventual discontinuation. Critical for portfolio planning and resource allocation. [ENUM-REF-CANDIDATE: discovery|preclinical|phase_i|phase_ii|phase_iii|nda_bla_submission|maa_submission|approved|launched|loe|discontinued — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageEntryDate rdf:type rdf:Property ;
    rdfs:label 'Stage Entry Date' ;
    rdfs:comment 'Date when the product entered the current lifecycle stage. Used to calculate time-in-stage metrics and track development velocity against portfolio benchmarks.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageExitDate rdf:type rdf:Property ;
    rdfs:label 'Stage Exit Date' ;
    rdfs:comment 'Date when the product exited or is expected to exit the current lifecycle stage. Nullable for products still in active stage. Critical for forecasting and resource planning.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'Strategic importance ranking assigned by portfolio management based on alignment with corporate strategy, unmet medical need, commercial potential, and competitive positioning.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Target Launch Date' ;
    rdfs:comment 'Planned or forecasted commercial launch date for the product. Updated as development progresses and regulatory timelines become clearer. Critical for commercial planning and supply chain readiness.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productNdcCodeId rdf:type rdf:Property ;
    rdfs:label 'Product Ndc Code Id' ;
    rdfs:comment 'Unique identifier for the NDC registry record. Primary key for the product NDC code entity.' ;
    rdfs:domain ind:ProductNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelerLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Labeler Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: NDC labeler code must map to legal entity for FDA establishment registration, labeling compliance, product listing. Replaces denormalized labeler_name with FK for regulatory reporting (FDA SPL submiss' ;
    rdfs:domain ind:ProductNdcCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:activeIngredient rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient' ;
    rdfs:comment 'The substance or substances in the drug product responsible for the therapeutic effect. May list multiple active ingredients for combination products.' ;
    rdfs:domain ind:ProductNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingEndDate rdf:type rdf:Property ;
    rdfs:label 'Marketing End Date' ;
    rdfs:comment 'The date the drug product was withdrawn from the market or discontinued. Null for products still being marketed.' ;
    rdfs:domain ind:ProductNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingStartDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Start Date' ;
    rdfs:comment 'The date the drug product was first commercially marketed in the United States. This is the date the product became available for sale.' ;
    rdfs:domain ind:ProductNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonProprietaryName rdf:type rdf:Property ;
    rdfs:label 'Non Proprietary Name' ;
    rdfs:comment 'The established or generic name of the drug product, typically the active pharmaceutical ingredient (API) name. May be the INN (International Nonproprietary Name) or USAN (United States Adopted Name).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementCode rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Code' ;
    rdfs:comment 'The code used for insurance reimbursement and billing purposes, often the 11-digit NDC format required by CMS and payers.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryIdentifierId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Identifier Id' ;
    rdfs:comment 'Unique identifier for the regulatory identifier record. Primary key.' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakthroughTherapyDesignation rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy Designation' ;
    rdfs:comment 'Indicates whether the product has been granted breakthrough therapy designation by the regulatory authority for serious or life-threatening conditions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Expiration Date' ;
    rdfs:comment 'The date on which the regulatory exclusivity period expires, after which generic or biosimilar versions may be approved.' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fastTrackDesignation rdf:type rdf:Property ;
    rdfs:label 'Fast Track Designation' ;
    rdfs:comment 'Indicates whether the product has been granted fast track designation by the regulatory authority to expedite development and review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifierNumber rdf:type rdf:Property ;
    rdfs:label 'Identifier Number' ;
    rdfs:comment 'The actual regulatory identifier or listing code assigned by the health authority (e.g., NDA number, BLA number, MAA number, NDC code, JNDA number, PMDA approval number, NMPA registration number).' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'The type or category of regulatory identifier (e.g., NDA for New Drug Application, ANDA for Abbreviated New Drug Application, BLA for Biologics License Application, MAA for Marketing Authorization Application, NDC for National Drug Code). [ENUM-REF-CANDIDATE: NDA|ANDA|BLA|MAA|JNDA|PMDA Approval Number|NMPA Registration Number|NDC|EMA Product Number|Other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCategory rdf:type rdf:Property ;
    rdfs:label 'Marketing Category' ;
    rdfs:comment 'The marketing category or classification of the product as defined by the regulatory authority (e.g., NDA, ANDA, BLA, OTC Monograph).' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcLabelerCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Labeler Code' ;
    rdfs:comment 'The labeler segment of the 10-digit NDC code, identifying the manufacturer or distributor. Applicable for US FDA NDC identifiers.' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcPackageCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Package Code' ;
    rdfs:comment 'The package segment of the 10-digit NDC code, identifying the package size and type. Applicable for US FDA NDC identifiers.' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcProductCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Product Code' ;
    rdfs:comment 'The product segment of the 10-digit NDC code, identifying the specific strength, dosage form, and formulation. Applicable for US FDA NDC identifiers.' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityReviewDesignation rdf:type rdf:Property ;
    rdfs:label 'Priority Review Designation' ;
    rdfs:comment 'Indicates whether the product has been granted priority review designation by the regulatory authority to shorten the review timeline.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialStatus rdf:type rdf:Property ;
    rdfs:label 'Commercial Status' ;
    rdfs:comment 'Current lifecycle status of the SKU in the market. Active indicates commercially available; discontinued indicates no longer manufactured but may have remaining inventory; withdrawn indicates removed from market for safety or regulatory reasons.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genericName rdf:type rdf:Property ;
    rdfs:label 'Generic Name' ;
    rdfs:comment 'International Nonproprietary Name (INN) or United States Adopted Name (USAN) for the active pharmaceutical ingredient (API) in this SKU.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Manufacturer\'s suggested retail price or wholesale acquisition cost (WAC) for the SKU in the local currency. Used for pricing strategy, contracting, and financial planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remsProgram rdf:type rdf:Property ;
    rdfs:label 'Rems Program' ;
    rdfs:comment 'Name or identifier of the FDA-mandated REMS program if applicable. Null if no REMS required. REMS programs impose additional safety requirements for high-risk products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationRequired rdf:type rdf:Property ;
    rdfs:label 'Serialization Required' ;
    rdfs:comment 'Indicates whether the SKU is subject to serialization and track-and-trace requirements under DSCSA (US), FMD (EU), or other regional regulations. True if unique serial numbers must be applied at unit level.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Commercial brand name or trade name under which the SKU is marketed and sold. May differ by market or therapeutic indication.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySpecifiedDrugSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Primary Specified Drug Substance Id' ;
    rdfs:comment 'Reference to the global substance master record. Links this specified substance to the authoritative substance definition in the substance registry.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugSubstance .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'The quality grade or compendial standard of the substance. Examples include USP, EP, JP, BP, or in-house specification grade. Indicates the purity and quality standard applied.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idmpSubstanceCode rdf:type rdf:Property ;
    rdfs:label 'Idmp Substance Code' ;
    rdfs:comment 'The globally unique IDMP substance identifier assigned per ISO 11238 standards. Used for international regulatory submissions and substance harmonization across health authorities.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerSubstanceCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Substance Code' ;
    rdfs:comment 'The manufacturer-specific internal code or catalog number for this specified substance. Used for procurement, quality control, and supply chain traceability.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opticalActivity rdf:type rdf:Property ;
    rdfs:label 'Optical Activity' ;
    rdfs:comment 'The stereochemical configuration or optical activity of the substance. Indicates whether the substance is a specific enantiomer, racemate, or other stereoisomeric form (e.g., R, S, (+), (-), racemic).' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purityPercentage rdf:type rdf:Property ;
    rdfs:label 'Purity Percentage' ;
    rdfs:comment 'The minimum purity percentage of the specified substance as defined in the specification. Expressed as a percentage (e.g., 98.5 for 98.5% purity).' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceStrengthUnit rdf:type rdf:Property ;
    rdfs:label 'Reference Strength Unit' ;
    rdfs:comment 'The unit of measure for the reference strength value. Typically represents the base or active moiety unit when different from the administered substance unit.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceStrengthValue rdf:type rdf:Property ;
    rdfs:label 'Reference Strength Value' ;
    rdfs:comment 'The numeric quantity expressed as reference strength. Used when the active moiety differs from the administered form (e.g., salt vs base). Enables standardized strength comparison across different salt forms.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solvateType rdf:type rdf:Property ;
    rdfs:label 'Solvate Type' ;
    rdfs:comment 'The type of solvate if the substance exists as a solvate. Common examples include hydrate, ethanolate, or other solvent inclusion compounds.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationLevel rdf:type rdf:Property ;
    rdfs:label 'Specification Level' ;
    rdfs:comment 'The level of detail at which the substance is specified. Indicates whether the substance is defined at molecular, salt, solvate, hydrate, polymorphic form, or mixture level per IDMP hierarchy.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoichiometry rdf:type rdf:Property ;
    rdfs:label 'Stoichiometry' ;
    rdfs:comment 'The stoichiometric ratio of components in the specified substance. Relevant for salts, solvates, hydrates, and co-crystals (e.g., 1:1, 2:1, monohydrate, hemihydrate).' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceCode rdf:type rdf:Property ;
    rdfs:label 'Substance Code' ;
    rdfs:comment 'The standardized code identifying the substance. May be an UNII code, CAS number, or other globally recognized substance identifier used for regulatory submissions.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceName rdf:type rdf:Property ;
    rdfs:label 'Substance Name' ;
    rdfs:comment 'The official name of the substance at the specified level. May be INN, USAN, chemical name, or other standardized nomenclature depending on regulatory context.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceRole rdf:type rdf:Property ;
    rdfs:label 'Substance Role' ;
    rdfs:comment 'The functional role of the substance within the formulation. Indicates whether the substance is an active pharmaceutical ingredient (API), excipient, or other functional component per IDMP requirements.' ;
    rdfs:domain ind:SpecifiedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Head Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Therapeutic area head accountability for franchise strategy, portfolio prioritization, investment decisions, and commercial planning. Currently plain text; FK enables organizational reporting, span-of' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:responsibleOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Responsible Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: Therapeutic areas managed by specific organizational units (business units, franchises, therapeutic area heads) for portfolio management, resource allocation, budget planning, strategic decision-makin' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:acceleratedApprovalPathway rdf:type rdf:Property ;
    rdfs:label 'Accelerated Approval Pathway' ;
    rdfs:comment 'Indicates whether products in this therapeutic area are typically eligible for accelerated approval based on surrogate or intermediate clinical endpoints.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:areaDescription rdf:type rdf:Property ;
    rdfs:label 'Area Description' ;
    rdfs:comment 'Detailed description of the therapeutic area, including scope, disease categories, and clinical focus.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaName rdf:type rdf:Property ;
    rdfs:label 'Area Name' ;
    rdfs:comment 'Full name of the therapeutic area (e.g., Oncology, Immunology, Rare Diseases, Neuroscience, Cardiovascular).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel1Name rdf:type rdf:Property ;
    rdfs:label 'Atc Level 1 Name' ;
    rdfs:comment 'WHO ATC classification level 1 anatomical main group name (e.g., Alimentary Tract and Metabolism, Blood and Blood Forming Organs, Cardiovascular System).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakthroughTherapyEligible rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy Eligible' ;
    rdfs:comment 'Indicates whether products in this therapeutic area are typically eligible for breakthrough therapy designation due to serious or life-threatening conditions with unmet medical need.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessUnitOwner rdf:type rdf:Property ;
    rdfs:label 'Business Unit Owner' ;
    rdfs:comment 'Name of the business unit or division responsible for strategy, portfolio management, and commercial execution for this therapeutic area.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalTrialComplexityLevel rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Complexity Level' ;
    rdfs:comment 'Assessment of clinical trial design and execution complexity for this therapeutic area based on endpoint selection, patient recruitment challenges, and trial duration.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Commercial Priority Level' ;
    rdfs:comment 'Strategic priority level for commercial investment and market development in this therapeutic area.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstancePotential rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Potential' ;
    rdfs:comment 'Indicates whether products in this therapeutic area have potential for abuse or dependence requiring Drug Enforcement Administration (DEA) scheduling consideration.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diseaseCategory rdf:type rdf:Property ;
    rdfs:label 'Disease Category' ;
    rdfs:comment 'Primary disease category or pathology focus within the therapeutic area (e.g., Solid Tumors, Hematologic Malignancies, Autoimmune Disorders, Genetic Disorders).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastTrackEligible rdf:type rdf:Property ;
    rdfs:label 'Fast Track Eligible' ;
    rdfs:comment 'Indicates whether products in this therapeutic area are typically eligible for fast track designation to facilitate development and expedite review of drugs for serious conditions with unmet medical need.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalMarketSizeUsdMillions rdf:type rdf:Property ;
    rdfs:label 'Global Market Size Usd Millions' ;
    rdfs:comment 'Estimated global market size for this therapeutic area in millions of USD. Used for strategic planning and investment prioritization.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:icd10ChapterCode rdf:type rdf:Property ;
    rdfs:label 'Icd 10 Chapter Code' ;
    rdfs:comment 'ICD-10 chapter code representing the primary disease classification for this therapeutic area (e.g., C00-D49 for Neoplasms).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10ChapterName rdf:type rdf:Property ;
    rdfs:label 'Icd 10 Chapter Name' ;
    rdfs:comment 'ICD-10 chapter name describing the disease classification (e.g., Neoplasms, Diseases of the Circulatory System, Diseases of the Nervous System).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanismOfActionCategory rdf:type rdf:Property ;
    rdfs:label 'Mechanism Of Action Category' ;
    rdfs:comment 'High-level mechanism of action category for products in this therapeutic area (e.g., Targeted Therapy, Immunotherapy, Enzyme Replacement, Receptor Agonist).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDesignationEligible rdf:type rdf:Property ;
    rdfs:label 'Orphan Designation Eligible' ;
    rdfs:comment 'Indicates whether products in this therapeutic area are typically eligible for orphan drug designation due to rare disease prevalence (affecting fewer than 200,000 patients in the US or fewer than 5 in 10,000 in the EU).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientPopulationEstimate rdf:type rdf:Property ;
    rdfs:label 'Patient Population Estimate' ;
    rdfs:comment 'Estimated global patient population affected by diseases within this therapeutic area. Used for epidemiological analysis and market sizing.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pediatricFocus rdf:type rdf:Property ;
    rdfs:label 'Pediatric Focus' ;
    rdfs:comment 'Indicates whether this therapeutic area has a specific focus on pediatric populations, requiring pediatric investigation plans (PIP) or pediatric study plans (PSP).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectedCagrPercent rdf:type rdf:Property ;
    rdfs:label 'Projected Cagr Percent' ;
    rdfs:comment 'Projected compound annual growth rate (CAGR) for this therapeutic area market over the next 5 years, expressed as a percentage.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplexityLevel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Complexity Level' ;
    rdfs:comment 'Assessment of regulatory complexity for products in this therapeutic area based on approval pathway requirements, clinical endpoint challenges, and post-market obligations.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsTypicallyRequired rdf:type rdf:Property ;
    rdfs:label 'Rems Typically Required' ;
    rdfs:comment 'Indicates whether products in this therapeutic area typically require Risk Evaluation and Mitigation Strategies (REMS) due to serious safety concerns.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:researchPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Research Priority Level' ;
    rdfs:comment 'Strategic priority level for research and development investment in this therapeutic area.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicFranchise rdf:type rdf:Property ;
    rdfs:label 'Strategic Franchise' ;
    rdfs:comment 'Indicates whether this therapeutic area is designated as a strategic franchise with dedicated resources, leadership, and long-term investment commitment.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unmetMedicalNeedLevel rdf:type rdf:Property ;
    rdfs:label 'Unmet Medical Need Level' ;
    rdfs:comment 'Assessment of unmet medical need in this therapeutic area based on availability of effective treatments, disease burden, and patient outcomes.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Audited Investigator Id' ;
    rdfs:comment 'Foreign key linking to hcp.investigator. Business justification: Clinical investigator audits assess individual investigator GCP compliance, protocol adherence, and data integrity. Critical for clinical trial quality assurance, regulatory inspections, and investiga' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:findingOosInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Finding Oos Investigation Id' ;
    rdfs:comment 'Foreign key linking to quality.oos_investigation. Business justification: Audits can uncover OOS investigations that require review or follow-up. This FK links audit findings to specific OOS investigation records. Business case: regulatory inspections may review OOS investi' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosInvestigation .

ind:qmsDocumentId rdf:type rdf:Property ;
    rdfs:label 'Qms Document Id' ;
    rdfs:comment 'Document identifier in the Quality Management System (QMS) such as MasterControl or Veeva Vault QualityDocs where the audit record and associated documents are stored. Enables traceability to controlled quality documents.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QmsDocument .

ind:qualityDeviationId rdf:type rdf:Property ;
    rdfs:label 'Quality Deviation Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_deviation. Business justification: Audits frequently identify deviations from approved procedures. This FK captures the specific deviation record that was identified during an audit finding. Business case: regulatory inspections (FDA F' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityDeviation .

ind:agenda rdf:type rdf:Property ;
    rdfs:label 'Agenda' ;
    rdfs:comment 'Detailed agenda or schedule of audit activities including opening meeting, process walkthroughs, document reviews, interviews, sampling activities, and closing meeting. May reference specific Standard Operating Procedures (SOPs) or areas to be assessed.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Verification Status' ;
    rdfs:comment 'Status of verification activities to confirm that corrective actions have been effectively implemented and findings are resolved. Pending indicates awaiting verification; in verification indicates verification activities underway; verified indicates actions confirmed effective; closed indicates audit formally closed with all findings resolved.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteria rdf:type rdf:Property ;
    rdfs:label 'Criteria' ;
    rdfs:comment 'Set of policies, procedures, regulations, or standards against which the audit was conducted. May include specific FDA 21 CFR parts, ICH guidelines, ISO standards, internal SOPs (Standard Operating Procedures), or GMP (Good Manufacturing Practice) requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Methodology used to conduct the audit. On-site indicates physical presence at the facility; remote indicates virtual audit via video conference and electronic document review; hybrid combines on-site and remote elements; desktop review indicates document-only assessment without site visit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAuditDate rdf:type rdf:Property ;
    rdfs:label 'Planned Audit Date' ;
    rdfs:comment 'Originally scheduled date for the audit as defined in the annual audit plan or inspection schedule. Used for tracking schedule adherence and planning purposes.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preAuditPreparationStatus rdf:type rdf:Property ;
    rdfs:label 'Pre Audit Preparation Status' ;
    rdfs:comment 'Status of pre-audit preparation activities including document review, audit plan development, team briefing, and logistics coordination. Critical for audit readiness and effectiveness.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list or structured text of audit team members including subject matter experts, technical specialists, and observers participating in the audit.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningLetterIssued rdf:type rdf:Property ;
    rdfs:label 'Warning Letter Issued' ;
    rdfs:comment 'Boolean flag indicating whether a regulatory Warning Letter was issued following the inspection. Warning Letters are official FDA (Food and Drug Administration) correspondence notifying a company of serious violations requiring prompt corrective action.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchDispositionId rdf:type rdf:Property ;
    rdfs:label 'Batch Disposition Id' ;
    rdfs:comment 'Primary key for batch_disposition' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeringIcsrId rdf:type rdf:Property ;
    rdfs:label 'Triggering Icsr Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.icsr. Business justification: Batch disposition decisions (reject/recall/quarantine) are often triggered by adverse event reports linked to specific batches. Business process: when ICSRs identify batch-specific safety issues, disp' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Icsr .

ind:dispositionComments rdf:type rdf:Property ;
    rdfs:label 'Disposition Comments' ;
    rdfs:comment 'Additional comments, notes, or observations recorded by the quality unit or QP during the disposition review and approval process.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current workflow status of the disposition decision: pending review, approved by QP, rejected, on hold pending investigation closure, or completed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'The precise date and time when the disposition decision was finalized and recorded in the QMS.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionType rdf:type rdf:Property ;
    rdfs:label 'Disposition Type' ;
    rdfs:comment 'The formal quality unit decision on the batch: release for distribution, reject and destroy, reprocess, rework, retest, or hold in quarantine pending further investigation.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketApplicability rdf:type rdf:Property ;
    rdfs:label 'Market Applicability' ;
    rdfs:comment 'Comma-separated list of markets or regulatory jurisdictions for which this batch is approved for distribution (e.g., USA, EU, JPN, ROW). Reflects market-specific release requirements.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Open Deviation Count' ;
    rdfs:comment 'Number of open quality deviations associated with this batch that must be resolved or justified prior to release per 21 CFR 211.192.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openOosCount rdf:type rdf:Property ;
    rdfs:label 'Open Oos Count' ;
    rdfs:comment 'Number of open Out of Specification (OOS) investigations linked to this batch that must be closed before disposition can be finalized.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qpApproverName rdf:type rdf:Property ;
    rdfs:label 'Qp Approver Name' ;
    rdfs:comment 'Full name of the Qualified Person or quality unit approver who signed off on the disposition decision.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineLocation rdf:type rdf:Property ;
    rdfs:label 'Quarantine Location' ;
    rdfs:comment 'Physical warehouse location or storage area where the batch is held under quarantine pending final disposition.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Physical quarantine status of the batch: quarantined pending disposition, released from quarantine for distribution, or rejected and segregated for destruction.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether the batch is under regulatory hold pending resolution of compliance issues, regulatory inspection findings, or authority requests.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Explanation of the regulatory hold, including the authority imposing the hold, the compliance issue, and the resolution path.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'The quantity of the batch rejected and segregated for destruction or reprocessing due to non-conformance with specifications.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'The quantity of the batch approved for release and distribution, which may be less than the total batch size if partial rejection or rework occurred.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Coa Employee Id' ;
    rdfs:comment 'Reference to the Quality Assurance personnel who authorized and signed the CoA.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coaQaReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Coa Qa Reviewer Employee Id' ;
    rdfs:comment 'Reference to the Quality Assurance reviewer who performed the final review before CoA issuance.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Name of the Quality Assurance personnel who authorized and signed the CoA.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Number' ;
    rdfs:comment 'Business identifier for the certificate of analysis, typically following a site-specific numbering convention.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Name of the customer or recipient organization for whom this CoA is issued.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version number of this CoA document, incremented when reissued or revised.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Flag' ;
    rdfs:comment 'Indicates whether the batch was manufactured under current Good Manufacturing Practice (cGMP) conditions.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when this CoA was officially issued and made available to the recipient.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:issuingSiteName rdf:type rdf:Property ;
    rdfs:label 'Issuing Site Name' ;
    rdfs:comment 'Name of the manufacturing or testing site that issued this CoA.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Lims Reference Number' ;
    rdfs:comment 'Reference number or sample ID from the Laboratory Information Management System (LIMS) used for tracking test results.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaReviewerName rdf:type rdf:Property ;
    rdfs:label 'Qa Reviewer Name' ;
    rdfs:comment 'Name of the Quality Assurance reviewer who performed the final review before CoA issuance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarket rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market' ;
    rdfs:comment 'Target regulatory market or jurisdiction for which this CoA is applicable (e.g., USA, EU, Japan, China), using 3-letter country codes or regional identifiers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Overall quality decision for the batch: released for use/distribution, rejected, pending further testing, conditional release, or quarantine.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmInspectionLot rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Inspection Lot' ;
    rdfs:comment 'SAP QM inspection lot number associated with this CoA for integration with enterprise resource planning systems.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Test Completion Date' ;
    rdfs:comment 'Date when all quality control testing for this batch was completed.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Start Date' ;
    rdfs:comment 'Date when quality control testing for this batch commenced.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complaintId rdf:type rdf:Property ;
    rdfs:label 'Complaint Id' ;
    rdfs:comment 'Primary key for complaint' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintClosedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Complaint Closed By Employee Id' ;
    rdfs:comment 'Reference to the Quality Assurance professional who reviewed and approved the closure of the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complaintEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Complaint Employee Id' ;
    rdfs:comment 'Reference to the Quality Assurance professional or team member assigned as the primary owner of the complaint investigation.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:oosInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Oos Investigation Id' ;
    rdfs:comment 'Foreign key linking to quality.oos_investigation. Business justification: Product complaints about quality issues may trigger OOS investigations when retained samples are retested. This FK links the complaint to the resulting OOS investigation. Business case: complaint abou' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosInvestigation .

ind:patientAdverseEventId rdf:type rdf:Property ;
    rdfs:label 'Patient Adverse Event Id' ;
    rdfs:comment 'Foreign key linking to patient.adverse_event. Business justification: Regulatory requirement (FDA 21 CFR 314.80, EMA guidelines) to cross-reference product quality complaints with adverse events for integrated safety/quality signal detection. Real process: complaint int' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdverseEvent .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Primary classification of the complaint type based on the nature of the issue reported.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Business-facing unique complaint tracking number assigned by the Quality Management System (QMS). Format: CMP-YYYYNNNN.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSource rdf:type rdf:Property ;
    rdfs:label 'Complaint Source' ;
    rdfs:comment 'Origin of the complaint indicating who reported the product quality issue. HCP = Healthcare Professional.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskAssessment rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Assessment' ;
    rdfs:comment 'Preliminary risk classification assigned upon complaint receipt to prioritize investigation urgency and resource allocation.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationFindings rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings' ;
    rdfs:comment 'Summary of the investigation results, including laboratory testing, batch record review, and field investigation outcomes.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Market Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating the geographic market where the complaint originated (e.g., USA, GBR, JPN).' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Impact Flag' ;
    rdfs:comment 'Indicates whether the complaint involves actual or potential patient harm, safety concern, or adverse event requiring pharmacovigilance assessment.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Tracking number or case identifier assigned by the regulatory authority upon submission of the complaint report.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCommunication rdf:type rdf:Property ;
    rdfs:label 'Response Communication' ;
    rdfs:comment 'Summary of the response provided to the complainant, including explanation of findings and actions taken.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the complaint based on investigation findings, using structured root cause analysis methodology.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labTestResultId rdf:type rdf:Property ;
    rdfs:label 'Lab Test Result Id' ;
    rdfs:comment 'Unique identifier for the laboratory test result record. Primary key.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabTestResult .

ind:originalTestResultLabTestResultId rdf:type rdf:Property ;
    rdfs:label 'Original Test Result Lab Test Result Id' ;
    rdfs:comment 'Reference to the original test result if this is a retest. Links to another lab_test_result record.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabTestResult .

ind:primaryLabEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lab Employee Id' ;
    rdfs:comment 'Identifier for the laboratory analyst who performed the test. Links to employee or user master.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLabApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Lab Approved By Employee Id' ;
    rdfs:comment 'Identifier for the QA person who approved the test result. Links to employee or user master.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analystName rdf:type rdf:Property ;
    rdfs:label 'Analyst Name' ;
    rdfs:comment 'Full name of the laboratory analyst who performed the test.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Flag' ;
    rdfs:comment 'Boolean indicator that the test result has been approved by Quality Assurance (QA) for release or further processing.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Inclusion Flag' ;
    rdfs:comment 'Boolean indicator that this test result is included in the Certificate of Analysis issued for the batch.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Identifier for OOS or OOT investigation record if this result triggered an investigation. Links to investigation management system.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosInvestigation .

ind:oosFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Flag' ;
    rdfs:comment 'Boolean indicator that the result is out of specification and requires investigation per OOS procedures.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ootFlag rdf:type rdf:Property ;
    rdfs:label 'Oot Flag' ;
    rdfs:comment 'Boolean indicator that the result is within specification but outside expected trend limits, requiring investigation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Determination of whether the test result meets the specification limits. Current lifecycle status of the test result.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultText rdf:type rdf:Property ;
    rdfs:label 'Result Text' ;
    rdfs:comment 'Textual or qualitative result for tests that do not produce numeric values (e.g., Pass/Fail, Conforms, Positive/Negative).' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Boolean indicator that this test is a retest of a previous result. Used to track retesting activities.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedByName rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Name' ;
    rdfs:comment 'Full name of the person who reviewed the test result.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedDate rdf:type rdf:Property ;
    rdfs:label 'Reviewed Date' ;
    rdfs:comment 'Date and time when the test result was reviewed.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Reviewed Flag' ;
    rdfs:comment 'Boolean indicator that the test result has been reviewed by a qualified reviewer (e.g., QC supervisor).' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Classification of the sample being tested. Indicates the stage in the manufacturing or quality lifecycle. [ENUM-REF-CANDIDATE: raw_material|in_process|drug_substance|drug_product|stability|reference_standard|retained_sample — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityTimepoint rdf:type rdf:Property ;
    rdfs:label 'Stability Timepoint' ;
    rdfs:comment 'Timepoint in the stability study protocol (e.g., Initial, 3 months, 6 months, 12 months, 24 months).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the test execution was completed and result recorded.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testNumber rdf:type rdf:Property ;
    rdfs:label 'Test Number' ;
    rdfs:comment 'Business identifier for the test execution. Human-readable unique test number assigned by LIMS.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testParameter rdf:type rdf:Property ;
    rdfs:label 'Test Parameter' ;
    rdfs:comment 'Specific quality attribute or parameter being measured (e.g., Assay, Impurity A, pH, Dissolution at 30 min, Bioburden).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Start Timestamp' ;
    rdfs:comment 'Precise date and time when the test execution started. Used for audit trail and chronological sequencing.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:methodId rdf:type rdf:Property ;
    rdfs:label 'Method Id' ;
    rdfs:comment 'Reference to the analytical method being validated. Links to the analytical method master data.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalMethod .

ind:accuracyRecoveryPercentMean rdf:type rdf:Property ;
    rdfs:label 'Accuracy Recovery Percent Mean' ;
    rdfs:comment 'Mean recovery percentage from accuracy studies, typically expected to be 98-102% for assay methods.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyResult rdf:type rdf:Property ;
    rdfs:label 'Accuracy Result' ;
    rdfs:comment 'Outcome of the accuracy assessment. Pass indicates recovery within predefined acceptance criteria across the method range.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compendialMethodFlag rdf:type rdf:Property ;
    rdfs:label 'Compendial Method Flag' ;
    rdfs:comment 'Indicates whether the method is based on a pharmacopeial (compendial) method from USP, EP, JP, or other official compendia. True if compendial, False if proprietary or in-house developed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compendialReference rdf:type rdf:Property ;
    rdfs:label 'Compendial Reference' ;
    rdfs:comment 'Reference to the pharmacopeial monograph or general chapter if the method is compendial (e.g., USP <621>, EP 2.2.46, JP 17).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediatePrecisionRsdPercent rdf:type rdf:Property ;
    rdfs:label 'Intermediate Precision Rsd Percent' ;
    rdfs:comment 'Relative standard deviation (RSD) from intermediate precision studies (inter-assay precision, different days, analysts, equipment), typically expected to be ≤ 3% for assay methods.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearityCorrelationCoefficient rdf:type rdf:Property ;
    rdfs:label 'Linearity Correlation Coefficient' ;
    rdfs:comment 'Correlation coefficient (R) from the linearity study, typically expected to be ≥ 0.999 for assay methods.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearityRangeLower rdf:type rdf:Property ;
    rdfs:label 'Linearity Range Lower' ;
    rdfs:comment 'Lower limit of the concentration range over which linearity was demonstrated.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearityRangeUnit rdf:type rdf:Property ;
    rdfs:label 'Linearity Range Unit' ;
    rdfs:comment 'Unit of measure for the linearity range (e.g., mg/mL, µg/mL, percent label claim).' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linearityRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Linearity Range Upper' ;
    rdfs:comment 'Upper limit of the concentration range over which linearity was demonstrated.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearityResult rdf:type rdf:Property ;
    rdfs:label 'Linearity Result' ;
    rdfs:comment 'Outcome of the linearity assessment. Pass indicates acceptable correlation coefficient and residuals within acceptance criteria.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodUnit rdf:type rdf:Property ;
    rdfs:label 'Lod Unit' ;
    rdfs:comment 'Unit of measure for the limit of detection (e.g., µg/mL, ppm, percent).' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodValue rdf:type rdf:Property ;
    rdfs:label 'Lod Value' ;
    rdfs:comment 'Established limit of detection value for the method - the lowest amount of analyte that can be detected but not necessarily quantitated.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loqUnit rdf:type rdf:Property ;
    rdfs:label 'Loq Unit' ;
    rdfs:comment 'Unit of measure for the limit of quantitation (e.g., µg/mL, ppm, percent).' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loqValue rdf:type rdf:Property ;
    rdfs:label 'Loq Value' ;
    rdfs:comment 'Established limit of quantitation value for the method - the lowest amount of analyte that can be quantitatively determined with suitable precision and accuracy.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'Classification of the analytical method by its intended purpose (e.g., assay for potency, identification for substance confirmation, impurity for degradation products).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallValidationConclusion rdf:type rdf:Property ;
    rdfs:label 'Overall Validation Conclusion' ;
    rdfs:comment 'Final conclusion of the method validation study. Validated indicates the method is fit for its intended purpose; not validated indicates it failed to meet acceptance criteria; conditionally validated indicates it passed with specific limitations or conditions.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionResult rdf:type rdf:Property ;
    rdfs:label 'Precision Result' ;
    rdfs:comment 'Outcome of the precision assessment. Pass indicates RSD values within predefined acceptance criteria for repeatability and intermediate precision.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatabilityRsdPercent rdf:type rdf:Property ;
    rdfs:label 'Repeatability Rsd Percent' ;
    rdfs:comment 'Relative standard deviation (RSD) from repeatability studies (intra-assay precision), typically expected to be ≤ 2% for assay methods.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:robustnessResult rdf:type rdf:Property ;
    rdfs:label 'Robustness Result' ;
    rdfs:comment 'Outcome of the robustness assessment. Pass indicates the method is robust to deliberate variations in parameters such as pH, temperature, flow rate, or mobile phase composition.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificityResult rdf:type rdf:Property ;
    rdfs:label 'Specificity Result' ;
    rdfs:comment 'Outcome of the specificity assessment. Pass indicates the method can unequivocally assess the analyte in the presence of impurities, degradation products, and matrix components.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technique rdf:type rdf:Property ;
    rdfs:label 'Technique' ;
    rdfs:comment 'Analytical technique or instrumentation used (e.g., HPLC, GC, UV-Vis Spectroscopy, FTIR, Mass Spectrometry, Titration, Dissolution Apparatus).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Validation Protocol Number' ;
    rdfs:comment 'Unique protocol number assigned to the method validation study. Business identifier for the validation activity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStartDate rdf:type rdf:Property ;
    rdfs:label 'Validation Start Date' ;
    rdfs:comment 'Date when the method validation activities commenced.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: OOS investigations require documented initiator for regulatory compliance and accountability. Initiated_by is currently a plain name field; proper FK enables qualification verification, workload track' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignabilityDetermination rdf:type rdf:Property ;
    rdfs:label 'Assignability Determination' ;
    rdfs:comment 'Determination of whether the OOS result is assignable to a specific identifiable cause. Assignable means a definitive cause was found; unassignable means no cause could be conclusively determined.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchDisposition rdf:type rdf:Property ;
    rdfs:label 'Batch Disposition' ;
    rdfs:comment 'Final disposition decision for the affected batch based on investigation findings (released, rejected, reworked, quarantined, or pending further investigation).' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'Name or identifier of the quality professional who formally closed the OOS investigation.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionJustification rdf:type rdf:Property ;
    rdfs:label 'Disposition Justification' ;
    rdfs:comment 'Scientific and regulatory justification for the batch disposition decision, including consideration of patient safety and product quality.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationClosedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Closed Date' ;
    rdfs:comment 'Date when the OOS investigation was formally closed after all phases completed and disposition determined.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationConclusion rdf:type rdf:Property ;
    rdfs:label 'Investigation Conclusion' ;
    rdfs:comment 'Final conclusion summary of the OOS investigation, including determination of cause, impact assessment, and corrective actions taken.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Business identifier for the OOS investigation, typically assigned by the Quality Management System (QMS) or Laboratory Information Management System (LIMS).' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the OOS investigation. Phase I covers laboratory investigation; Phase II covers full-scale investigation if laboratory error is ruled out.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryErrorDescription rdf:type rdf:Property ;
    rdfs:label 'Laboratory Error Description' ;
    rdfs:comment 'Detailed description of the laboratory error identified, if applicable (e.g., instrument malfunction, calculation error, contamination).' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryErrorIdentified rdf:type rdf:Property ;
    rdfs:label 'Laboratory Error Identified' ;
    rdfs:comment 'Indicates whether a laboratory error was conclusively identified during Phase I investigation that explains the OOS result.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observedResult rdf:type rdf:Property ;
    rdfs:label 'Observed Result' ;
    rdfs:comment 'Actual test result value that fell outside the specification limit and triggered the OOS investigation.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseICompletionDate rdf:type rdf:Property ;
    rdfs:label 'Phase I Completion Date' ;
    rdfs:comment 'Date when Phase I laboratory investigation was completed.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseIFindings rdf:type rdf:Property ;
    rdfs:label 'Phase I Findings' ;
    rdfs:comment 'Summary of findings from the Phase I laboratory investigation, including any identified laboratory errors or anomalies.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseIStartDate rdf:type rdf:Property ;
    rdfs:label 'Phase I Start Date' ;
    rdfs:comment 'Date when Phase I laboratory investigation began to determine if the OOS result was due to laboratory error.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseIiCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Completion Date' ;
    rdfs:comment 'Date when Phase II full-scale investigation was completed.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseIiFindings rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Findings' ;
    rdfs:comment 'Summary of findings from Phase II investigation, including root cause analysis of manufacturing, material, or process issues.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseIiRequired rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Required' ;
    rdfs:comment 'Indicates whether Phase II full-scale investigation is required. Phase II is triggered when no laboratory error is found in Phase I.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phaseIiStartDate rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Start Date' ;
    rdfs:comment 'Date when Phase II full-scale investigation began to determine root cause in manufacturing, materials, or process.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaReviewDate rdf:type rdf:Property ;
    rdfs:label 'Qa Review Date' ;
    rdfs:comment 'Date when the Quality Assurance review and approval was completed.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaReviewer rdf:type rdf:Property ;
    rdfs:label 'Qa Reviewer' ;
    rdfs:comment 'Name or identifier of the Quality Assurance reviewer who approved the investigation findings and conclusions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether the OOS investigation findings require reporting to regulatory authorities (FDA, EMA, etc.) per applicable regulations.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestAuthorized rdf:type rdf:Property ;
    rdfs:label 'Retest Authorized' ;
    rdfs:comment 'Indicates whether retesting was authorized following Phase I investigation. Retesting is only appropriate when laboratory error is confirmed.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestJustification rdf:type rdf:Property ;
    rdfs:label 'Retest Justification' ;
    rdfs:comment 'Scientific justification for authorizing retesting, including explanation of the laboratory error that invalidates the original result.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestResult rdf:type rdf:Property ;
    rdfs:label 'Retest Result' ;
    rdfs:comment 'Result obtained from authorized retesting, if performed.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseIdentified rdf:type rdf:Property ;
    rdfs:label 'Root Cause Identified' ;
    rdfs:comment 'Indicates whether a definitive root cause was identified during Phase II investigation.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationLimit rdf:type rdf:Property ;
    rdfs:label 'Specification Limit' ;
    rdfs:comment 'Established acceptance criteria or specification limit that the test result failed to meet (e.g., 95.0-105.0%, NMT 0.5%).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Analytical test method or procedure used that produced the OOS result (e.g., HPLC, dissolution, assay).' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productQualityReviewId rdf:type rdf:Property ;
    rdfs:label 'Product Quality Review Id' ;
    rdfs:comment 'Unique identifier for the annual product quality review record. Primary key for the product quality review entity.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProductEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Product Employee Id' ;
    rdfs:comment 'Reference to the quality professional responsible for coordinating and authoring the product quality review. Typically a Quality Assurance manager or site quality head.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryProductManagementReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Product Management Reviewer Employee Id' ;
    rdfs:comment 'Reference to the senior management representative who reviewed the product quality review as part of management review process per ICH Q10.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionItems rdf:type rdf:Property ;
    rdfs:label 'Action Items' ;
    rdfs:comment 'List of approved action items and improvement initiatives resulting from the product quality review. May include process improvements, investigations, revalidations, or specification updates.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchRejectionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Batch Rejection Rate Percent' ;
    rdfs:comment 'Percentage of batches rejected relative to total batches manufactured during the review period. Critical quality performance indicator for process capability assessment.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capaCount rdf:type rdf:Property ;
    rdfs:label 'Capa Count' ;
    rdfs:comment 'Total number of CAPA records initiated for this product during the review period. Indicates the volume of quality improvement activities.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeControlCount rdf:type rdf:Property ;
    rdfs:label 'Change Control Count' ;
    rdfs:comment 'Total number of change control records implemented for this product during the review period. Tracks the volume of process, equipment, or specification changes.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintCount rdf:type rdf:Property ;
    rdfs:label 'Complaint Count' ;
    rdfs:comment 'Total number of product quality complaints received during the review period from customers, patients, or healthcare providers.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Critical Deviation Count' ;
    rdfs:comment 'Number of critical or major deviations that had significant impact on product quality or GMP compliance. Subset of total deviation count requiring heightened management attention.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementReviewDate rdf:type rdf:Property ;
    rdfs:label 'Management Review Date' ;
    rdfs:comment 'Date when senior management completed their review of the product quality review and approved action items and improvement initiatives.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementReviewerName rdf:type rdf:Property ;
    rdfs:label 'Management Reviewer Name' ;
    rdfs:comment 'Full name of the senior management representative who conducted management review. Typically site head, quality head, or operations director.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ootCount rdf:type rdf:Property ;
    rdfs:label 'Oot Count' ;
    rdfs:comment 'Total number of out-of-trend analytical results identified during the review period. OOT results indicate potential process drift requiring investigation.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processCapabilityCpk rdf:type rdf:Property ;
    rdfs:label 'Process Capability Cpk' ;
    rdfs:comment 'Process capability index (Cpk) for critical quality attributes during the review period. Cpk >= 1.33 indicates acceptable process capability; Cpk >= 1.67 indicates robust process.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallCount rdf:type rdf:Property ;
    rdfs:label 'Recall Count' ;
    rdfs:comment 'Number of product recalls initiated during the review period. Includes voluntary and regulatory-mandated recalls at all classification levels.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revalidationJustification rdf:type rdf:Property ;
    rdfs:label 'Revalidation Justification' ;
    rdfs:comment 'Business justification and rationale for revalidation requirement or decision to defer revalidation. Documents risk assessment and decision-making process.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revalidationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Revalidation Required Flag' ;
    rdfs:comment 'Indicates whether process revalidation or requalification is required based on review findings. True if quality trends, changes, or deviations necessitate revalidation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewConclusion rdf:type rdf:Property ;
    rdfs:label 'Review Conclusion' ;
    rdfs:comment 'Executive summary and overall conclusion of the product quality review. Synthesizes key findings, trends, and quality performance assessment for management decision-making.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Unique business identifier for the annual product quality review, typically following a standardized numbering convention including year and product code.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewOwnerName rdf:type rdf:Property ;
    rdfs:label 'Review Owner Name' ;
    rdfs:comment 'Full name of the quality professional responsible for the product quality review. Denormalized for reporting and audit trail purposes.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the time period covered by this product quality review. Typically the beginning of the calendar or fiscal year for annual reviews.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the product quality review type. Annual reviews are standard ICH Q10 requirement; interim reviews may be triggered by significant events; ad-hoc reviews address specific quality concerns.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityFailureCount rdf:type rdf:Property ;
    rdfs:label 'Stability Failure Count' ;
    rdfs:comment 'Number of stability failures or out-of-specification stability results observed during the review period. Critical indicator of product shelf-life integrity.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stabilityStudyCount rdf:type rdf:Property ;
    rdfs:label 'Stability Study Count' ;
    rdfs:comment 'Number of ongoing stability studies for this product during the review period. Includes registration, commercial, and supporting stability protocols.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBatchesManufactured rdf:type rdf:Property ;
    rdfs:label 'Total Batches Manufactured' ;
    rdfs:comment 'Total number of commercial batches manufactured during the review period. Provides denominator for calculating batch-level quality metrics and failure rates.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBatchesRejected rdf:type rdf:Property ;
    rdfs:label 'Total Batches Rejected' ;
    rdfs:comment 'Total number of batches rejected during the review period due to quality failures, out-of-specification results, or GMP deviations. Key indicator of manufacturing process capability.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBatchesReleased rdf:type rdf:Property ;
    rdfs:label 'Total Batches Released' ;
    rdfs:comment 'Total number of batches released for distribution during the review period. Indicates successful completion of quality control testing and Quality Person (QP) certification.' ;
    rdfs:domain ind:ProductQualityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingEventId rdf:type rdf:Property ;
    rdfs:label 'Originating Event Id' ;
    rdfs:comment 'Reference identifier of the originating QMS event (deviation number, OOS investigation number, audit finding ID, complaint number, etc.) that triggered this CAPA.' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityEvent .

ind:originatingMedicalInquiryId rdf:type rdf:Property ;
    rdfs:label 'Originating Medical Inquiry Id' ;
    rdfs:comment 'Foreign key linking to medical.medical_inquiry. Business justification: Medical inquiries reporting product quality concerns trigger CAPA investigations. Standard pharma process where medical affairs escalates safety/quality issues to QA for formal investigation and corre' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inquiry .

ind:primaryQualityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Quality Employee Id' ;
    rdfs:comment 'Identifier of the individual assigned as the owner responsible for managing and completing the CAPA.' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qualityChangeControlId rdf:type rdf:Property ;
    rdfs:label 'Quality Change Control Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_change_control. Business justification: CAPA records often trigger change controls as part of the corrective/preventive action implementation. One CAPA can trigger one change control (1:N relationship). This FK enables tracking which change' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityChangeControl .

ind:tertiaryQualityClosedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Quality Closed By Employee Id' ;
    rdfs:comment 'Identifier of the individual who approved and closed the CAPA record.' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:closedByName rdf:type rdf:Property ;
    rdfs:label 'Closed By Name' ;
    rdfs:comment 'Full name of the individual who approved and closed the CAPA record.' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureComments rdf:type rdf:Property ;
    rdfs:label 'Closure Comments' ;
    rdfs:comment 'Final comments and summary provided at CAPA closure, documenting the rationale for closure and any lessons learned.' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Additional contributing factors identified during root cause analysis that may have influenced the occurrence of the issue.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckComments rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Comments' ;
    rdfs:comment 'Detailed comments and findings from the effectiveness check evaluation.' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Required Flag' ;
    rdfs:comment 'Indicates whether an effectiveness check is required to verify that the CAPA actions successfully addressed the root cause and prevented recurrence.' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedByName rdf:type rdf:Property ;
    rdfs:label 'Initiated By Name' ;
    rdfs:comment 'Full name of the individual who initiated the CAPA record.' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingEventType rdf:type rdf:Property ;
    rdfs:label 'Originating Event Type' ;
    rdfs:comment 'Type of quality management system event that triggered the CAPA, such as deviation, Out of Specification (OOS), Out of Trend (OOT), audit finding, customer complaint, or change control. [ENUM-REF-CANDIDATE: deviation|oos|oot|audit_finding|complaint|change_control|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCapaDescription rdf:type rdf:Property ;
    rdfs:label 'Quality Capa Description' ;
    rdfs:comment 'Detailed description of the nonconformance, problem, or potential risk that the CAPA addresses, including background context and scope.' ;
    rdfs:domain ind:QualityCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Change control initiation requires documented personnel for accountability and regulatory traceability. Initiator_name is denormalized; proper FK enables department lookup, qualification verification,' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Actual date when the change was implemented in production or operational environment.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedProducts rdf:type rdf:Property ;
    rdfs:label 'Affected Products' ;
    rdfs:comment 'List or description of drug products (DP), drug substances (DS), or SKUs affected by this change, including product names, NDC codes, or internal product identifiers.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSopList rdf:type rdf:Property ;
    rdfs:label 'Affected Sop List' ;
    rdfs:comment 'List of SOP numbers or titles that are affected by the change and require revision or replacement.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the person or role who provided final approval for the change (typically QA Manager or Change Control Board Chair).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRationale rdf:type rdf:Property ;
    rdfs:label 'Change Rationale' ;
    rdfs:comment 'Business and technical justification for the proposed change, including drivers such as quality improvement, cost reduction, regulatory compliance, safety enhancement, or obsolescence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:comment 'Brief descriptive title summarizing the proposed change.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerified rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verified' ;
    rdfs:comment 'Indicates whether the change effectiveness has been verified through post-implementation review, confirming that the change achieved its intended purpose without adverse impact.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationPlan rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan' ;
    rdfs:comment 'Detailed plan describing how the change will be implemented, including steps, responsibilities, timelines, training requirements, and communication plan.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postImplementationReview rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review' ;
    rdfs:comment 'Summary of the post-implementation review conducted to verify that the change was implemented as planned, achieved intended objectives, and did not introduce unintended consequences. Includes effectiveness assessment.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Assessment' ;
    rdfs:comment 'Assessment of regulatory implications including whether the change requires prior approval, notification, or annual reporting to regulatory authorities (FDA, EMA, PMDA, etc.) and which markets are affected.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether regulatory notification or prior approval is required for this change based on regulatory impact assessment.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sopUpdatesRequired rdf:type rdf:Property ;
    rdfs:label 'Sop Updates Required' ;
    rdfs:comment 'Indicates whether existing SOPs need to be revised or new SOPs need to be created as part of the change implementation.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Target Implementation Date' ;
    rdfs:comment 'Planned or target date for implementing the approved change.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Validation Protocol Reference' ;
    rdfs:comment 'Reference to validation or qualification protocol document(s) required to support the change, including protocol numbers or document identifiers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRequired rdf:type rdf:Property ;
    rdfs:label 'Validation Required' ;
    rdfs:comment 'Indicates whether validation or qualification activities are required to demonstrate that the change does not adversely affect product quality, process performance, or system functionality.' ;
    rdfs:domain ind:QualityChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigation Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Deviation investigations require assigned ownership for accountability and regulatory traceability. Investigation_owner is currently a plain name field; proper FK enables workload tracking, qualificat' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sopId rdf:type rdf:Property ;
    rdfs:label 'Sop Id' ;
    rdfs:comment 'Foreign key linking to quality.sop. Business justification: Deviations reference the SOP that was violated. Currently stored as sop_reference (STRING). Normalizing to FK allows proper referential integrity and enables joining to get full SOP details (title, ve' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sop .

ind:auditFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Flag' ;
    rdfs:comment 'Indicates whether the deviation was identified during an internal audit, external audit, or regulatory inspection.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Flag' ;
    rdfs:comment 'Indicates whether the deviation was identified as a result of a customer complaint, linking quality issues to market feedback.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedBy rdf:type rdf:Property ;
    rdfs:label 'Detected By' ;
    rdfs:comment 'Name or identifier of the individual who discovered the deviation. Used for quality culture assessment and training needs analysis.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Disposition Recommendation' ;
    rdfs:comment 'Recommended disposition of the affected batch or material based on investigation findings and quality risk assessment. Subject to quality assurance approval.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Code identifying the manufacturing site, laboratory, or warehouse where the deviation occurred. Used for site-level quality trending and regulatory reporting.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'Approved final disposition of the affected batch or material after quality assurance review and approval.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Actual date when the deviation investigation was completed and documented, including root cause analysis and corrective action plan.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationDueDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Due Date' ;
    rdfs:comment 'Target date for completion of the deviation investigation, typically based on GMP impact classification and organizational quality standards.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Qa Approval Date' ;
    rdfs:comment 'Date when the quality assurance reviewer approved the deviation investigation and closure, authorizing final disposition.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Quality Deviation Description' ;
    rdfs:comment 'Detailed narrative description of the deviation event, including what was observed, what was expected, and the nature of the departure from approved procedures or specifications.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date when the deviation was reported to the relevant regulatory authority, if reportable. Null if not reportable or not yet reported.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Summary' ;
    rdfs:comment 'Summary of the root cause analysis findings, identifying the underlying reason(s) for the deviation occurrence. Populated after investigation completion.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalMethodId rdf:type rdf:Property ;
    rdfs:label 'Analytical Method Id' ;
    rdfs:comment 'Foreign key linking to quality.analytical_method. Business justification: Specifications define acceptance criteria and reference the analytical method used for testing. Currently stored as analytical_method_reference (STRING). Normalizing to FK allows proper referential in' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalMethod .

ind:authorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Author Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Specification authorship requires qualified personnel for GMP compliance and regulatory traceability. Author_name is denormalized; proper FK enables author qualification verification, workload trackin' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryApprovalId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Id' ;
    rdfs:comment 'Foreign key linking to regulatory.approval. Business justification: Quality specifications must link to regulatory approvals to track approved specifications for marketed products. This is critical for regulatory compliance and change control management. The specifica' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Approval .

ind:supersededBySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Specification Id' ;
    rdfs:comment 'Reference to the newer specification version that supersedes this one. Null if this is the current effective version.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:acceptanceCriterion rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criterion' ;
    rdfs:comment 'The acceptance limit or range for the test parameter, expressed as numeric limits (e.g., \'95.0% - 105.0%\', \'NMT 0.5%\', \'pH 6.0 - 8.0\') or qualitative criteria (e.g., \'Conforms\', \'White to off-white powder\').' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cppLinkage rdf:type rdf:Property ;
    rdfs:label 'Cpp Linkage' ;
    rdfs:comment 'Reference to the Critical Process Parameters (CPPs) that impact this CQA, establishing the QbD design space linkage.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cqaFlag rdf:type rdf:Property ;
    rdfs:label 'Cqa Flag' ;
    rdfs:comment 'Indicates whether this test parameter is designated as a Critical Quality Attribute (CQA) under Quality by Design (QbD) principles. True if CQA, False otherwise.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Limit' ;
    rdfs:comment 'Numeric lower acceptance limit for quantitative test parameters. Null for qualitative tests or tests with only upper limits.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketAuthorization rdf:type rdf:Property ;
    rdfs:label 'Market Authorization' ;
    rdfs:comment 'Geographic markets or countries where this specification is approved and in effect (e.g., \'USA\', \'EU\', \'JPN\', \'Global\'). Multiple markets may be comma-separated.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Business identifier for the specification document, typically following organizational numbering conventions (e.g., SPEC-DS-001, SPEC-DP-045).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of the specification: draft (being authored), under_review (in approval workflow), approved (approved but not yet effective), effective (currently in use), superseded (replaced by newer version), obsolete (no longer valid), or withdrawn (removed from use). [ENUM-REF-CANDIDATE: draft|under_review|approved|effective|superseded|obsolete|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of the specification based on its intended use: release (batch release testing), shelf-life (end of shelf-life criteria), in-process (during manufacturing), stability (stability study acceptance), reference_standard (for reference materials), or raw_material (incoming material testing).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'The frequency at which this test must be performed (e.g., \'Every batch\', \'Annual\', \'Quarterly\', \'Skip lot (1 in 3)\', \'On change\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Limit' ;
    rdfs:comment 'Numeric upper acceptance limit for quantitative test parameters. Null for qualitative tests or tests with only lower limits.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryStabilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stability Employee Id' ;
    rdfs:comment 'Reference to the quality or analytical scientist responsible for managing the stability study and ensuring protocol compliance. Links to employee master data.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryStabilityResponsiblePersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Stability Responsible Person Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryStabilityLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Stability Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the stability study record. Audit trail for accountability and compliance.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:containerClosureSystem rdf:type rdf:Property ;
    rdfs:label 'Container Closure System' ;
    rdfs:comment 'Description of the primary packaging configuration used in the stability study (e.g., HDPE bottle with child-resistant cap, blister pack PVC/PVDC/Aluminum, glass vial with rubber stopper). Critical for assessing packaging compatibility and shelf-life.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTimePointMonths rdf:type rdf:Property ;
    rdfs:label 'Current Time Point Months' ;
    rdfs:comment 'Most recent time point (in months from study start) for which testing has been completed. Used to track study progress.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallPassFailStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Pass Fail Status' ;
    rdfs:comment 'Aggregate pass/fail status for the most recent completed time point. Fail indicates one or more test parameters exceeded specification limits. Triggers Out of Specification (OOS) investigation if fail.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pullPointSchedule rdf:type rdf:Property ;
    rdfs:label 'Pull Point Schedule' ;
    rdfs:comment 'Comma-separated list of planned time points (in months) when samples will be pulled and tested (e.g., 0, 3, 6, 9, 12, 18, 24, 36). Defines the study sampling plan per ICH guidelines.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestDateMonths rdf:type rdf:Property ;
    rdfs:label 'Retest Date Months' ;
    rdfs:comment 'Retest period in months for drug substances (API) derived from stability data. Indicates the time period after which the material must be retested before use in manufacturing.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statisticalTrendAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Statistical Trend Analysis Method' ;
    rdfs:comment 'Statistical method applied to evaluate stability data trends and support shelf-life determination: linear regression, pooled regression across batches, bracketing design, matrixing design, or none if not yet analyzed.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyNotes rdf:type rdf:Property ;
    rdfs:label 'Study Notes' ;
    rdfs:comment 'Free-text field for capturing additional study-level observations, deviations from protocol, chamber malfunctions, sample handling issues, or other relevant comments that may impact data interpretation.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testParameters rdf:type rdf:Property ;
    rdfs:label 'Test Parameters' ;
    rdfs:comment 'Comma-separated list of analytical test parameters performed at each time point (e.g., assay, degradation products, dissolution, appearance, pH, viscosity, water content, particulate matter). Defines the analytical scope per study protocol.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Id' ;
    rdfs:comment 'Unique identifier for the supplier qualification record. Primary key for this entity.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupplierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Employee Id' ;
    rdfs:comment 'Reference to the user who initiated the supplier qualification record. Typically a Quality Assurance (QA) specialist, procurement specialist, or supplier quality engineer.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Status' ;
    rdfs:comment 'Current status of the supplier qualification approval workflow. Draft indicates initial creation; pending review indicates awaiting Quality Assurance (QA) review; QA review indicates under active review; QA approved indicates final approval granted; rejected indicates qualification denied.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedMaterialScope rdf:type rdf:Property ;
    rdfs:label 'Approved Material Scope' ;
    rdfs:comment 'Detailed description of the materials, drug substances, drug products, or components that the supplier is qualified to provide. Includes specific material codes, grades, and specifications covered under this qualification.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedServiceScope rdf:type rdf:Property ;
    rdfs:label 'Approved Service Scope' ;
    rdfs:comment 'Detailed description of the services that the supplier is qualified to perform. Includes manufacturing operations, testing services, validation activities, clinical trial services, or other contracted services covered under this qualification.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaCountLast12Months rdf:type rdf:Property ;
    rdfs:label 'Capa Count Last 12 Months' ;
    rdfs:comment 'Number of Corrective and Preventive Action (CAPA) records initiated for the supplier in the last 12 months. Indicates frequency of quality issues requiring formal corrective action.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationCountLast12Months rdf:type rdf:Property ;
    rdfs:label 'Deviation Count Last 12 Months' ;
    rdfs:comment 'Number of quality deviations reported by or attributed to the supplier in the last 12 months. Used as a key performance indicator for supplier quality oversight.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oosCountLast12Months rdf:type rdf:Property ;
    rdfs:label 'Oos Count Last 12 Months' ;
    rdfs:comment 'Number of Out of Specification (OOS) results reported for materials or services provided by the supplier in the last 12 months. Critical quality metric for supplier performance.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Quantitative performance rating of the supplier based on quality metrics including on-time delivery, Certificate of Analysis (CoA) accuracy, deviation rate, Out of Specification (OOS) incidents, and Corrective and Preventive Action (CAPA) closure timeliness. Typically scored on a scale of 0-100.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Effective Date' ;
    rdfs:comment 'Date on which the supplier qualification became effective and the supplier was approved for use under Good Manufacturing Practice (GMP) operations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityAgreementType rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Type' ;
    rdfs:comment 'Classification of the quality agreement. Master indicates overarching agreement covering multiple products or services; product-specific indicates agreement for a single drug product or drug substance; service-specific indicates agreement for defined services; site-specific indicates agreement tied to a particular manufacturing or testing site.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Authority' ;
    rdfs:comment 'Name of the regulatory authority that conducted the most recent inspection. Examples include U.S. Food and Drug Administration (FDA), European Medicines Agency (EMA), Medicines and Healthcare products Regulatory Agency (MHRA), Pharmaceuticals and Medical Devices Agency (PMDA).' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarketCoverage rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market Coverage' ;
    rdfs:comment 'List of regulatory markets and jurisdictions for which the supplier is qualified to provide materials or services. Includes U.S. Food and Drug Administration (FDA), European Medicines Agency (EMA), Pharmaceuticals and Medical Devices Agency (PMDA), and other regulatory authorities. Pipe-separated list of market codes.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier based on the materials or services provided. Contract Manufacturing Organization (CMO) manufactures drug product; Contract Development and Manufacturing Organization (CDMO) provides development and manufacturing; Contract Research Organization (CRO) conducts research and clinical trials; Active Pharmaceutical Ingredient (API) supplier provides drug substance; excipient supplier provides inactive ingredients; packaging supplier provides primary or secondary packaging materials; equipment supplier provides manufacturing equipment; service provider offers validation, testing, or consulting services. [ENUM-REF-CANDIDATE: cmo|cdmo|cro|api_supplier|excipient_supplier|packaging_supplier|equipment_supplier|service_provider — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationId rdf:type rdf:Property ;
    rdfs:label 'Validation Id' ;
    rdfs:comment 'Primary key for validation' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Validation .

ind:teamLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Team Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Validation team lead assignment requires qualified personnel for GMP compliance. Validation_team_lead is currently a plain name field; proper FK enables qualification verification, workload tracking, ' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deviationSummary rdf:type rdf:Property ;
    rdfs:label 'Deviation Summary' ;
    rdfs:comment 'Summary description of any deviations encountered during validation execution, including their impact assessment and resolution.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationsObserved rdf:type rdf:Property ;
    rdfs:label 'Deviations Observed' ;
    rdfs:comment 'Count of deviations or non-conformances observed during validation execution that required documentation and investigation.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRevalidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Revalidation Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic revalidation activity. Calculated based on revalidation frequency and last validation completion date.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Outcome' ;
    rdfs:comment 'Final outcome determination of the validation: pass (all acceptance criteria met), fail (critical criteria not met), conditional_pass (passed with minor observations requiring follow-up), or incomplete (execution not finished).' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Protocol Approved By' ;
    rdfs:comment 'Name and title of the Quality Assurance representative who approved the validation protocol for execution.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolAuthor rdf:type rdf:Property ;
    rdfs:label 'Protocol Author' ;
    rdfs:comment 'Name of the individual who authored or prepared the validation protocol document.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolObjective rdf:type rdf:Property ;
    rdfs:label 'Protocol Objective' ;
    rdfs:comment 'Detailed objective and scope statement describing what the validation protocol intends to demonstrate or verify.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolTitle rdf:type rdf:Property ;
    rdfs:label 'Protocol Title' ;
    rdfs:comment 'Descriptive title of the validation protocol, summarizing the scope and objective of the validation activity.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicates whether this validation has regulatory reporting implications or is subject to regulatory inspection (True/False).' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revalidationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Revalidation Frequency Months' ;
    rdfs:comment 'Frequency in months at which revalidation must be performed (e.g., 12, 24, 36 months). Applicable when revalidation_required_flag is True.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testRunsCompleted rdf:type rdf:Property ;
    rdfs:label 'Test Runs Completed' ;
    rdfs:comment 'Number of test runs or batches successfully completed during validation execution.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testRunsPlanned rdf:type rdf:Property ;
    rdfs:label 'Test Runs Planned' ;
    rdfs:comment 'Number of test runs or batches planned for execution as part of the validation protocol (e.g., 3 consecutive batches for process validation).' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testStepsFailed rdf:type rdf:Property ;
    rdfs:label 'Test Steps Failed' ;
    rdfs:comment 'Number of test steps that did not meet acceptance criteria and failed during validation execution.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testStepsPassed rdf:type rdf:Property ;
    rdfs:label 'Test Steps Passed' ;
    rdfs:comment 'Number of test steps that met acceptance criteria and passed during validation execution.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testStepsTotal rdf:type rdf:Property ;
    rdfs:label 'Test Steps Total' ;
    rdfs:comment 'Total number of individual test steps or test cases defined in the validation protocol.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationCategory rdf:type rdf:Property ;
    rdfs:label 'Validation Category' ;
    rdfs:comment 'High-level category of the validation activity: equipment, process, cleaning, computer system, analytical method, facility, or utility validation. [ENUM-REF-CANDIDATE: equipment|process|cleaning|computer_system|analytical_method|facility|utility — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Applications need a regulatory lead responsible for overall application strategy, submission coordination, and health authority engagement. Essential for regulatory affairs resource allocation, applic' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Application Number' ;
    rdfs:comment 'The official application number assigned by the health authority upon receipt of the submission (e.g., NDA 123456, BLA 761234, EMA/H/C/004321). This is the externally-known business identifier for the application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory application as tracked in the regulatory information management system. Drives workflow and reporting across regulatory affairs. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|refused|withdrawn|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakthroughTherapyFlag rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy Flag' ;
    rdfs:comment 'Indicates whether the FDA has granted Breakthrough Therapy Designation (BTD) for this application, enabling intensive FDA guidance and rolling review.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fastTrackFlag rdf:type rdf:Property ;
    rdfs:label 'Fast Track Flag' ;
    rdfs:comment 'Indicates whether the FDA has granted Fast Track Designation for this application, facilitating more frequent interactions with FDA and eligibility for rolling review.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadDivisionCode rdf:type rdf:Property ;
    rdfs:label 'Lead Division Code' ;
    rdfs:comment 'The FDA Office/Division or EMA Committee (e.g., CDER, CBER, CHMP, COMP) responsible for reviewing this application. Determines the review team and applicable guidance documents.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketExclusivityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Market Exclusivity Expiry Date' ;
    rdfs:comment 'The date on which market exclusivity (e.g., orphan drug exclusivity, pediatric exclusivity, or new indication exclusivity) expires for this application. Distinct from data exclusivity.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newMolecularEntityFlag rdf:type rdf:Property ;
    rdfs:label 'New Molecular Entity Flag' ;
    rdfs:comment 'Indicates whether the active ingredient in this application is a New Chemical Entity (NCE) or New Molecular Entity (NME) that has not previously been approved by the health authority, conferring 5-year data exclusivity in the US.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paiOutcome rdf:type rdf:Property ;
    rdfs:label 'Pai Outcome' ;
    rdfs:comment 'The outcome classification of the Pre-Approval Inspection (PAI) conducted at the manufacturing site. VAI = Voluntary Action Indicated; OAI = Official Action Indicated (may delay approval).' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paiRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pai Required Flag' ;
    rdfs:comment 'Indicates whether a Pre-Approval Inspection (PAI) of the manufacturing facility has been required or triggered as part of the review of this application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdufaActionDate rdf:type rdf:Property ;
    rdfs:label 'Pdufa Action Date' ;
    rdfs:comment 'The target action date committed by the FDA under the Prescription Drug User Fee Act (PDUFA), or equivalent agency action deadline (e.g., EMA opinion date, PMDA review deadline). Critical milestone for commercial planning.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postApprovalCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Post Approval Commitment Flag' ;
    rdfs:comment 'Indicates whether the approval of this application is subject to post-approval commitments or post-marketing requirements (PMRs/PMCs) imposed by the health authority.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Review Flag' ;
    rdfs:comment 'Indicates whether the application has been granted Priority Review designation by the health authority, entitling it to a shorter review clock (6 months for FDA vs. standard 10 months).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceProductName rdf:type rdf:Property ;
    rdfs:label 'Reference Product Name' ;
    rdfs:comment 'For ANDA (generic) or biosimilar applications, the name of the reference listed drug (RLD) or reference biological product against which the application is filed. Null for original NDA/BLA applications.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollingReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Rolling Review Flag' ;
    rdfs:comment 'Indicates whether the health authority has granted rolling review, allowing submission and review of completed dossier sections before the full application is submitted.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:therapeuticIndication rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Indication' ;
    rdfs:comment 'The approved or proposed clinical indication for which the drug product is being developed or has been approved (e.g., \'Treatment of relapsed/refractory multiple myeloma in adults\'). Aligns with label language.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Externally-known unique identifier assigned by the health authority for this approval (e.g., NDA 123456, EU/1/20/1234, PMDA approval number). This is the official regulatory reference number.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'Classification of the regulatory approval pathway or designation granted. Full approval indicates standard review; accelerated/conditional/provisional indicate expedited pathways with post-approval commitments. [ENUM-REF-CANDIDATE: full|accelerated|conditional|provisional|priority_review|breakthrough|orphan|fast_track — promote to reference product]' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDosageForm rdf:type rdf:Property ;
    rdfs:label 'Approved Dosage Form' ;
    rdfs:comment 'The pharmaceutical dosage form approved for marketing (e.g., tablet, capsule, injection, oral solution, transdermal patch). Corresponds to the Finished Dosage Form (FDF) as specified in the approved label.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedIndication rdf:type rdf:Property ;
    rdfs:label 'Approved Indication' ;
    rdfs:comment 'The specific disease, condition, or therapeutic use for which the drug product has been approved. Reflects the exact label language as approved by the health authority (e.g., \'treatment of adult patients with relapsed/refractory multiple myeloma\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedPatientPopulation rdf:type rdf:Property ;
    rdfs:label 'Approved Patient Population' ;
    rdfs:comment 'Description of the patient population for whom the drug is approved, including age group, disease stage, prior treatment requirements, and any biomarker or genetic criteria (e.g., \'adults ≥18 years with EGFR-mutated NSCLC\').' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedRouteOfAdministration rdf:type rdf:Property ;
    rdfs:label 'Approved Route Of Administration' ;
    rdfs:comment 'The approved route by which the drug product is administered to patients (e.g., oral, intravenous, subcutaneous, intramuscular, topical, inhalation). As specified in the approved product label.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedStrength rdf:type rdf:Property ;
    rdfs:label 'Approved Strength' ;
    rdfs:comment 'The approved dose strength(s) of the Active Pharmaceutical Ingredient (API) in the drug product (e.g., \'10 mg\', \'100 mg/5 mL\', \'0.5 mg/mL\'). Multiple strengths may be listed as a delimited string.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Reference' ;
    rdfs:comment 'Document reference number or identifier for the official approval certificate issued by the health authority. Used to locate the physical or electronic certificate in the regulatory document management system (e.g., Veeva Vault RIM).' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditions rdf:type rdf:Property ;
    rdfs:label 'Conditions' ;
    rdfs:comment 'Specific conditions, restrictions, or obligations attached to the approval by the health authority. Includes Risk Evaluation and Mitigation Strategy (REMS) requirements, restricted distribution programs, mandatory monitoring, or other conditions of use.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasRems rdf:type rdf:Property ;
    rdfs:label 'Has Rems' ;
    rdfs:comment 'Indicates whether a Risk Evaluation and Mitigation Strategy (REMS) program is required as a condition of this approval. True if REMS is mandated by FDA; False otherwise.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:letterDate rdf:type rdf:Property ;
    rdfs:label 'Letter Date' ;
    rdfs:comment 'Date of the official approval letter issued by the health authority. May differ from the approval_date in cases where the letter is issued after the formal approval decision.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paiRequired rdf:type rdf:Property ;
    rdfs:label 'Pai Required' ;
    rdfs:comment 'Indicates whether a Pre-Approval Inspection (PAI) of manufacturing facilities was required and conducted as part of the approval process. True if PAI was mandated; False otherwise.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postApprovalCommitmentCount rdf:type rdf:Property ;
    rdfs:label 'Post Approval Commitment Count' ;
    rdfs:comment 'Number of post-approval commitments (PACs) or post-marketing requirements (PMRs) imposed by the health authority as conditions of this approval. Drives tracking of outstanding regulatory obligations.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryExclusivityType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Exclusivity Type' ;
    rdfs:comment 'Type of regulatory exclusivity granted with this approval. NCE (New Chemical Entity) exclusivity, orphan exclusivity, pediatric exclusivity, or data/market exclusivity. Determines the period during which generic or biosimilar competition is blocked.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region' ;
    rdfs:comment 'Regulatory region or jurisdiction grouping for the approval. Used for regional reporting and portfolio management (US=FDA, EU=EMA, JP=PMDA, CN=NMPA, UK=MHRA, CA=Health Canada, AU=TGA, ROW=Rest of World). [ENUM-REF-CANDIDATE: US|EU|JP|CN|UK|CA|AU|ROW — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDivision rdf:type rdf:Property ;
    rdfs:label 'Review Division' ;
    rdfs:comment 'The specific review division or committee within the health authority responsible for evaluating and granting this approval (e.g., FDA CDER Division of Oncology Products, EMA CHMP, PMDA Review Division).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Holder Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: DMF holders are legal entities that own drug master files. Regulatory compliance requires tracking the legal entity for authorization letters, annual updates, and cross-referencing in NDAs/ANDAs. Hold' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:holderVendorId rdf:type rdf:Property ;
    rdfs:label 'Holder Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: DMFs are filed by API/excipient manufacturers who are procurement vendors. Pharma companies link DMF holders to vendor master for GMP qualification status, audit scheduling, supply chain risk assessme' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:manufacturingSiteCountryId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: DMF manufacturing site jurisdiction determines applicable GMP standards, inspection authority, and regulatory pathway. Critical for CMC assessment and supply chain risk management. Manufacturing_site_' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of amendments submitted to the health authority for this DMF since the original filing date. Reflects the change history and regulatory maintenance activity for the DMF.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedProductNames rdf:type rdf:Property ;
    rdfs:label 'Associated Product Names' ;
    rdfs:comment 'Comma-separated list of internal drug product names or development codes that reference this DMF in their NDA, BLA, or MAA submissions. Provides a quick cross-reference for CMC regulatory strategy without requiring a full join to the submission registry.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationLetterDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Letter Date' ;
    rdfs:comment 'Date on which the most recent Letter of Authorization (LoA) was issued by the DMF holder to the referencing applicant. Null if no authorization letter has been issued.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationLetterIssued rdf:type rdf:Property ;
    rdfs:label 'Authorization Letter Issued' ;
    rdfs:comment 'Indicates whether the DMF holder has issued a Letter of Authorization (LoA) to the referencing applicant, granting the health authority permission to review the confidential DMF contents in support of an NDA, BLA, or ANDA submission.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmcSection rdf:type rdf:Property ;
    rdfs:label 'Cmc Section' ;
    rdfs:comment 'Identifies the specific Chemistry, Manufacturing, and Controls (CMC) section of the eCTD/CTD dossier (Module 3) to which this DMF contributes. Used to map DMF content to the corresponding CTD section in NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityCommitment rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Commitment' ;
    rdfs:comment 'Indicates whether the DMF holder has provided a formal confidentiality commitment to the referencing company, ensuring that proprietary manufacturing information disclosed in the DMF will not be shared beyond the regulatory review context.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deficiencyLetterReceived rdf:type rdf:Property ;
    rdfs:label 'Deficiency Letter Received' ;
    rdfs:comment 'Indicates whether the health authority has issued a deficiency letter (also known as a Complete Response Letter or information request) identifying gaps or issues in the DMF that must be addressed before the referencing application can be approved.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deficiencyResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Deficiency Response Due Date' ;
    rdfs:comment 'Deadline by which the DMF holder must respond to a deficiency letter issued by the health authority. Null if no deficiency letter has been received. Critical for regulatory timeline management.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalOwner rdf:type rdf:Property ;
    rdfs:label 'Internal Owner' ;
    rdfs:comment 'Name or employee identifier of the internal regulatory affairs professional responsible for managing this DMF relationship, tracking updates, and coordinating authorization letters with the DMF holder.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAnnualUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Annual Update Date' ;
    rdfs:comment 'Date of the most recent annual update submitted to the health authority to confirm the DMF remains current and accurate. FDA requires annual updates under 21 CFR 314.420(c). Failure to update may result in DMF inactivation.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingSiteName rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Name' ;
    rdfs:comment 'Name of the manufacturing facility covered by or associated with the DMF. For Type I DMFs, this is the primary subject. For Type II DMFs, this identifies where the API or drug substance is manufactured. Confidential as it reveals supply chain details.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paiStatus rdf:type rdf:Property ;
    rdfs:label 'Pai Status' ;
    rdfs:comment 'Current status of the Pre-Approval Inspection (PAI) for the manufacturing site or process covered by this DMF. PAI is conducted by FDA or other health authorities prior to approval of an NDA/BLA referencing this DMF. [ENUM-REF-CANDIDATE: not_initiated|scheduled|completed|passed|failed|pending_response — promote to reference product]' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referencingApplicationCount rdf:type rdf:Property ;
    rdfs:label 'Referencing Application Count' ;
    rdfs:comment 'Number of regulatory applications (NDA, BLA, ANDA, MAA) that currently reference this DMF. Indicates the strategic importance of the DMF to the product portfolio and the breadth of supplier dependency.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Internal classification of the strategic importance of this DMF to the company\'s product portfolio and supply chain. Critical indicates sole-source supplier for a marketed product; high indicates key supplier for pipeline assets; medium/low for non-critical materials.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Detailed description of the subject matter covered by the DMF, such as the specific API, excipient, packaging component, or manufacturing site. Aligns with the \'Subject of DMF\' field in FDA eCTD submissions.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authoringVendorId rdf:type rdf:Property ;
    rdfs:label 'Authoring Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Regulatory dossier documents are frequently authored by CRO vendors (medical writing, CMC documentation, clinical study reports). Pharma companies track document authorship by vendor for quality contr' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:relatedDocumentDossierDocumentId rdf:type rdf:Property ;
    rdfs:label 'Related Document Dossier Document Id' ;
    rdfs:comment 'Reference to a related or predecessor document within the dossier (e.g., the document being replaced or superseded by this version). Supports document lineage and eCTD lifecycle traceability.' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DossierDocument .

ind:checksum rdf:type rdf:Property ;
    rdfs:label 'Checksum' ;
    rdfs:comment 'Cryptographic checksum (MD5 or SHA-256) of the document file, used to verify file integrity during dossier compilation, transmission, and health authority receipt validation.' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Checksum Algorithm' ;
    rdfs:comment 'The hashing algorithm used to generate the document checksum (e.g., MD5, SHA-256). Required to correctly validate file integrity during eCTD processing.' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdModule rdf:type rdf:Property ;
    rdfs:label 'Ctd Module' ;
    rdfs:comment 'The ICH CTD module (1–5) under which this document is classified. Module 1: Administrative; Module 2: Summaries; Module 3: Quality (CMC); Module 4: Nonclinical; Module 5: Clinical.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdSectionCode rdf:type rdf:Property ;
    rdfs:label 'Ctd Section Code' ;
    rdfs:comment 'Hierarchical section code within the ICH CTD structure (e.g., 3.2.P.2.1 for Drug Product Development). Drives dossier organization, completeness checks, and eCTD leaf placement.' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSubtype rdf:type rdf:Property ;
    rdfs:label 'Document Subtype' ;
    rdfs:comment 'Further granular classification within the document type (e.g., Phase 1 CSR, Phase 3 CSR, Pivotal Study, Supportive Study). Supports detailed dossier analytics and completeness gap analysis.' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdOperation rdf:type rdf:Property ;
    rdfs:label 'Ectd Operation' ;
    rdfs:comment 'The eCTD lifecycle operation applied to this document in the current sequence (new, replace, append, delete). Governs how the document is processed by health authority eCTD review tools.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'File format of the document (e.g., PDF, XML, SAS dataset, DOCX). PDF is the primary format for eCTD submissions; XML is used for structured data files and backbone.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'The actual file name of the document as stored in the eCTD dossier directory structure, including extension. Must comply with eCTD file naming conventions (lowercase, no spaces, max 64 characters).' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the document file in bytes. Used for dossier volume management, submission package size validation, and health authority file size compliance checks.' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Indicates whether the document contains commercially sensitive or trade secret information requiring restricted access controls and redaction before public disclosure.' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPlaceholder rdf:type rdf:Property ;
    rdfs:label 'Is Placeholder' ;
    rdfs:comment 'Indicates whether this record represents a placeholder for a document that is planned but not yet authored or available. Used during dossier gap analysis and submission readiness assessment.' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProprietary rdf:type rdf:Property ;
    rdfs:label 'Is Proprietary' ;
    rdfs:comment 'Indicates whether the document contains proprietary manufacturing, formulation, or IP information (e.g., DMF cross-references, trade secrets). Governs access restrictions and redaction requirements.' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storagePath rdf:type rdf:Property ;
    rdfs:label 'Storage Path' ;
    rdfs:comment 'The logical or physical storage path of the document file within the eCTD dossier directory structure or document management system (e.g., Veeva Vault, eCTD backbone path). Supports document retrieval and dossier assembly.' ;
    rdfs:domain ind:DossierDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haInteractionId rdf:type rdf:Property ;
    rdfs:label 'Ha Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each health authority interaction record in the silver layer lakehouse. Primary key for this data product. Entity role: TRANSACTION_HEADER — represents a discrete formal communication or meeting event with a health authority, with its own lifecycle, participants, and outcomes.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaInteraction .

ind:companyLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Company Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Health authority meetings and interactions require a company lead for meeting preparation, attendance, and follow-up action tracking. Critical for regulatory intelligence capture, meeting effectivenes' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyContactName rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Name' ;
    rdfs:comment 'Name of the primary health authority contact or reviewer assigned to this interaction (e.g., FDA project manager, EMA rapporteur, PMDA reviewer). Enables relationship management and continuity tracking across interactions.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Reference Number' ;
    rdfs:comment 'The official reference or tracking number assigned by the health authority to this specific interaction or correspondence (e.g., FDA meeting request confirmation number, EMA scientific advice case number, MHRA correspondence reference). Distinct from the company\'s internal interaction_reference_number.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreedOutcomesSummary rdf:type rdf:Property ;
    rdfs:label 'Agreed Outcomes Summary' ;
    rdfs:comment 'Summary of agreements, agency positions, commitments, and conclusions reached during or resulting from this health authority interaction. For meetings, captures agreed minutes content. For written correspondence, captures the agency\'s decision or position. Critical for regulatory strategy and post-meeting action tracking.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Briefing Document Reference' ;
    rdfs:comment 'Document reference number or Veeva Vault document ID for the briefing document, background package, or information package submitted to the health authority in preparation for or in response to this interaction. Links to the eTMF/RIM document management system.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates the direction of the communication: inbound (initiated by the health authority, e.g., information request, deficiency letter), outbound (initiated by the company, e.g., meeting request, response letter), or bilateral (mutual, e.g., formal meeting). Essential for tracking response obligations and deadlines.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discussionTopicsSummary rdf:type rdf:Property ;
    rdfs:label 'Discussion Topics Summary' ;
    rdfs:comment 'A structured summary of the key topics, questions, and agenda items discussed or addressed in this health authority interaction. For meetings, captures the agenda items. For written correspondence, summarizes the subject matter. Business-confidential as it contains regulatory strategy information.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions Required' ;
    rdfs:comment 'Indicates whether this interaction generated one or more follow-up action items that require tracking and completion (e.g., additional data requests, protocol amendments, label negotiations, post-approval commitments). Drives workflow routing in the regulatory affairs team.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthAuthorityDivision rdf:type rdf:Property ;
    rdfs:label 'Health Authority Division' ;
    rdfs:comment 'The specific division, office, or committee within the health authority responsible for this interaction (e.g., FDA CDER Office of Oncology Products, EMA Committee for Medicinal Products for Human Use (CHMP), PMDA Office of New Drug I). Enables granular tracking of agency relationships and division-specific regulatory strategies.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'The principal real-world date on which the interaction occurred — the meeting date for in-person/teleconference interactions, or the date a written communication was received or sent. Serves as the BUSINESS_EVENT_TIMESTAMP (date precision) for this transaction. For written correspondence, this is the document date on the letter or communication.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionFormat rdf:type rdf:Property ;
    rdfs:label 'Interaction Format' ;
    rdfs:comment 'The modality or format through which the health authority interaction took place. Distinguishes between in-person meetings, teleconferences, videoconferences, hybrid formats, and written-only communications. Critical for meeting management and regulatory strategy documentation.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Interaction Reference Number' ;
    rdfs:comment 'Externally-known tracking number or correspondence control number assigned to this interaction, either by the health authority (e.g., FDA meeting request number, EMA procedure number) or by the company\'s RIMS/Veeva Vault RIM system. Serves as the BUSINESS_IDENTIFIER for this transaction. Used for cross-referencing with agency correspondence and eCTD submissions.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle state of the health authority interaction record. Tracks the workflow from initial drafting through scheduling, execution, and closure. \'Overdue\' indicates a response deadline has been missed. Serves as the LIFECYCLE_STATUS for this transaction header. [ENUM-REF-CANDIDATE: draft|submitted|scheduled|in_progress|completed|cancelled|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingCategory rdf:type rdf:Property ;
    rdfs:label 'Meeting Category' ;
    rdfs:comment 'For meeting-type interactions, the formal FDA meeting category (Type A: dispute resolution/clinical hold; Type B: pre-IND, end-of-phase, pre-NDA/BLA; Type C: all others) or EMA scientific advice category. Drives PDUFA response timeline obligations. Set to \'not_applicable\' for written correspondence interactions.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Minutes Document Reference' ;
    rdfs:comment 'Document reference number or Veeva Vault document ID for the official meeting minutes or written record of the interaction outcome. For written correspondence, references the agency letter or response document. Null for interactions where minutes are not yet finalized.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paiRelated rdf:type rdf:Property ;
    rdfs:label 'Pai Related' ;
    rdfs:comment 'Indicates whether this interaction is associated with a Pre-Approval Inspection (PAI) by the health authority, including inspection scheduling, outcome discussions, or corrective action follow-up. Enables filtering of PAI-related regulatory communications.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of participants (combined company and agency attendees) in this interaction. Applicable primarily to meeting-type interactions. Used for meeting logistics and engagement analytics.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdufaClockImpact rdf:type rdf:Property ;
    rdfs:label 'Pdufa Clock Impact' ;
    rdfs:comment 'Indicates whether this interaction has an impact on the PDUFA review clock (e.g., a complete response letter resets the clock; an information request may pause it). True if the interaction affects the regulatory review timeline clock. Applicable to FDA interactions only; False or null for non-FDA interactions.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remsRelated rdf:type rdf:Property ;
    rdfs:label 'Rems Related' ;
    rdfs:comment 'Indicates whether this health authority interaction is related to a Risk Evaluation and Mitigation Strategy (REMS) program, including REMS design, modification, assessment, or compliance discussions. Enables filtering of REMS-specific regulatory communications.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimelineCompliant rdf:type rdf:Property ;
    rdfs:label 'Response Timeline Compliant' ;
    rdfs:comment 'Indicates whether the company\'s response to this health authority interaction was submitted within the required regulatory deadline (response_due_date). True if response_submitted_date is on or before response_due_date. Null if no response is required or if the response has not yet been submitted.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'The native record identifier from the source system of record (Veeva Vault RIM correspondence or meeting module document ID) from which this interaction record was ingested. Enables traceability back to the operational system for audit and reconciliation purposes.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptedDossierFormats rdf:type rdf:Property ;
    rdfs:label 'Accepted Dossier Formats' ;
    rdfs:comment 'Comma-separated list of submission dossier formats accepted by the health authority (e.g., \'eCTD\', \'NeeS\', \'paper\', \'eCTD v4.0\'). Drives submission preparation and formatting decisions in Veeva Vault RIM and RIMS.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acronym rdf:type rdf:Property ;
    rdfs:label 'Acronym' ;
    rdfs:comment 'Commonly used abbreviation or acronym for the health authority (e.g., \'FDA\', \'EMA\', \'PMDA\', \'MHRA\', \'NMPA\', \'WHO\'). Used in regulatory correspondence, submission tracking, and reporting.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Official full legal name of the health authority agency (e.g., \'U.S. Food and Drug Administration\', \'European Medicines Agency\'). Used as the primary identity label for the agency across all regulatory activities.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Status' ;
    rdfs:comment 'Current operational lifecycle status of the health authority record. \'active\' indicates the agency is currently operational and accepting submissions; \'inactive\' indicates it is no longer operational; \'merged\' indicates it has been absorbed into another agency; \'dissolved\' indicates it has been formally disbanded; \'under_review\' indicates the record is pending validation.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the health authority by its organizational scope and mandate. Distinguishes between national competent authorities (e.g., FDA, MHRA), supranational agencies (e.g., EMA), international organizations (e.g., WHO), regional authorities, and advisory bodies. [ENUM-REF-CANDIDATE: national_competent_authority|supranational_agency|international_organization|regional_authority|advisory_body — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Agency Website Url' ;
    rdfs:comment 'Official public website URL of the health authority (e.g., https://www.fda.gov, https://www.ema.europa.eu). Used for reference, guidance document retrieval, and regulatory intelligence.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blaAccepted rdf:type rdf:Property ;
    rdfs:label 'Bla Accepted' ;
    rdfs:comment 'Indicates whether the health authority accepts Biologics License Application (BLA) submissions or their local equivalent for marketing authorization of biological products, vaccines, and biosimilars.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakthroughDesignationProgram rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Designation Program' ;
    rdfs:comment 'Indicates whether the health authority offers a breakthrough therapy designation or equivalent expedited development program (e.g., FDA Breakthrough Therapy, EMA PRIME scheme, MHRA Innovative Licensing and Access Pathway). Drives early engagement strategy.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmfAccepted rdf:type rdf:Property ;
    rdfs:label 'Dmf Accepted' ;
    rdfs:comment 'Indicates whether the health authority accepts Drug Master File (DMF) submissions for confidential disclosure of manufacturing, processing, packaging, and storage information for drug substances and excipients.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ectdRequired rdf:type rdf:Property ;
    rdfs:label 'Ectd Required' ;
    rdfs:comment 'Indicates whether the health authority mandates submission in Electronic Common Technical Document (eCTD) format as per ICH M8 guideline. Drives submission formatting and Veeva Vault RIM configuration.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAgencyCode rdf:type rdf:Property ;
    rdfs:label 'External Agency Code' ;
    rdfs:comment 'Official external identifier assigned to the health authority by an industry body or cross-reference system (e.g., DUNS number, ISO organization code, or identifier from a regulatory intelligence database). Supports cross-system reconciliation.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichMember rdf:type rdf:Property ;
    rdfs:label 'Ich Member' ;
    rdfs:comment 'Indicates whether the health authority is a full member or observer of the International Council for Harmonisation (ICH). ICH membership signals alignment with harmonized technical guidelines for drug registration.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indAccepted rdf:type rdf:Property ;
    rdfs:label 'Ind Accepted' ;
    rdfs:comment 'Indicates whether the health authority accepts Investigational New Drug (IND) applications or their local equivalent for clinical trial authorization. Drives IND filing strategy for global clinical development programs.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Scope of regulatory jurisdiction exercised by the health authority — federal (e.g., FDA within the US), national (e.g., MHRA for UK), regional (e.g., state-level agencies), supranational (e.g., EMA for EU member states), or international (e.g., WHO).' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOfSubmission rdf:type rdf:Property ;
    rdfs:label 'Language Of Submission' ;
    rdfs:comment 'Official language(s) required for regulatory submissions to this health authority (e.g., \'English\' for FDA/EMA/MHRA, \'Japanese\' for PMDA, \'Chinese (Simplified)\' for NMPA). Drives translation and localization planning for global submissions.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localRepresentativeRequired rdf:type rdf:Property ;
    rdfs:label 'Local Representative Required' ;
    rdfs:comment 'Indicates whether the health authority requires a local regulatory representative, marketing authorization holder, or in-country agent to be designated for submissions and post-approval activities. Critical for market access planning in jurisdictions like Japan (PMDA) and China (NMPA).' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailingAddress rdf:type rdf:Property ;
    rdfs:label 'Mailing Address' ;
    rdfs:comment 'Full official mailing address of the health authority\'s headquarters or primary regulatory affairs office. Used for formal paper submissions and official correspondence.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mutualRecognitionAgreements rdf:type rdf:Property ;
    rdfs:label 'Mutual Recognition Agreements' ;
    rdfs:comment 'Comma-separated list of Mutual Recognition Agreements (MRA) or equivalence arrangements the health authority has with other regulatory bodies (e.g., \'FDA-EMA MRA\', \'PIC/S Member\'). Impacts GMP inspection reliance and submission strategy.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaAccepted rdf:type rdf:Property ;
    rdfs:label 'Nda Accepted' ;
    rdfs:comment 'Indicates whether the health authority accepts New Drug Application (NDA) submissions or their local equivalent (e.g., MAA for EMA, J-NDA for PMDA) for marketing authorization of small molecule drugs.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orphanDrugProgram rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Program' ;
    rdfs:comment 'Indicates whether the health authority operates an orphan drug designation program providing incentives (e.g., market exclusivity, fee waivers, protocol assistance) for rare disease treatments. Relevant for oncology and rare disease therapeutic areas.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paiConducted rdf:type rdf:Property ;
    rdfs:label 'Pai Conducted' ;
    rdfs:comment 'Indicates whether the health authority conducts Pre-Approval Inspections (PAI) of manufacturing facilities as part of the marketing authorization review process. Drives inspection readiness planning.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityReviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Priority Review Duration Days' ;
    rdfs:comment 'Expedited or priority review clock duration in calendar days for applications granted priority review designation at this health authority (e.g., 180 days for FDA Priority Review, 150 days for EMA accelerated assessment). Supports regulatory strategy for breakthrough therapies.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:psurRequired rdf:type rdf:Property ;
    rdfs:label 'Psur Required' ;
    rdfs:comment 'Indicates whether the health authority requires Periodic Safety Update Reports (PSUR) or Periodic Benefit-Risk Evaluation Reports (PBRER) as part of post-marketing pharmacovigilance obligations. Aligns with ICH E2C(R2) guideline.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardReviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Standard Review Duration Days' ;
    rdfs:comment 'Standard regulatory review clock duration in calendar days for a standard marketing authorization application at this health authority (e.g., 365 days for FDA standard NDA review, 210 days for EMA centralized procedure). Used for regulatory timeline planning.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Submission Portal Url' ;
    rdfs:comment 'Official URL of the health authority\'s electronic submission portal (e.g., FDA ESG gateway, EMA CESP portal, PMDA eCTD gateway). Used by regulatory affairs teams to route and track electronic submissions.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Agency Code' ;
    rdfs:comment 'Agency identifier code as configured in Veeva Vault Regulatory Information Management (RIM) system. Used to link this master record to submission tracking, dossier management, and regulatory correspondence workflows in Veeva Vault.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorVersionLabelId rdf:type rdf:Property ;
    rdfs:label 'Prior Version Label Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding label version that this record supersedes. Enables reconstruction of the complete label amendment history chain for a given product-market-language combination.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Label .

ind:affectedSections rdf:type rdf:Property ;
    rdfs:label 'Affected Sections' ;
    rdfs:comment 'Comma-separated list of label sections modified in this version (e.g., \'Warnings and Precautions, Adverse Reactions, Dosage and Administration\'). Enables targeted review of changes and supports regulatory correspondence tracking.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackBoxWarning rdf:type rdf:Property ;
    rdfs:label 'Black Box Warning' ;
    rdfs:comment 'Indicates whether this label version contains an FDA Boxed Warning (Black Box Warning) — the most serious warning required by the FDA for drugs with significant risk of serious or life-threatening adverse effects. True = boxed warning present; False = no boxed warning.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationDeadline rdf:type rdf:Property ;
    rdfs:label 'Implementation Deadline' ;
    rdfs:comment 'Regulatory or company-mandated deadline by which the new label version must be implemented on marketed product packaging. Critical for compliance tracking, especially for safety-driven label changes with mandatory implementation timelines.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Operational status of the label implementation across markets and packaging lines. Pending: implementation not yet started; In Progress: packaging/artwork updates underway; Implemented: new label in use on marketed product; Overdue: implementation deadline passed without completion; Not Applicable: label change does not require physical implementation.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indications rdf:type rdf:Property ;
    rdfs:label 'Indications' ;
    rdfs:comment 'Summary of the approved therapeutic indications as stated on this label version. Captures the disease/condition(s) for which the drug is approved, including any population restrictions (e.g., adult, pediatric). Full text stored in label content management system (Veeva Vault PromoMats).' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelNumber rdf:type rdf:Property ;
    rdfs:label 'Label Number' ;
    rdfs:comment 'Externally-known unique business identifier for the label document, typically assigned by the regulatory information management system (RIMS) or Veeva Vault RIM (e.g., LBL-2024-00123). Used for cross-system traceability.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Spl Document Reference' ;
    rdfs:comment 'FDA-assigned UUID for the Structured Product Labeling (SPL) document submitted to the FDA DailyMed system. Unique identifier for the SPL XML document in the FDA labeling repository. Applicable for US market labels only.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelChangeId rdf:type rdf:Property ;
    rdfs:label 'Label Change Id' ;
    rdfs:comment 'Unique surrogate identifier for each label change record in the regulatory labeling lifecycle management system.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelDocumentLabelId rdf:type rdf:Property ;
    rdfs:label 'Label Document Label Id' ;
    rdfs:comment 'Document management system identifier (e.g., Veeva Vault document ID) for the approved label document associated with this change, enabling direct retrieval of the label text from the document management system.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Label .

ind:regulatoryOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Label changes require a regulatory owner for change control execution, health authority correspondence, and implementation tracking. Essential for labeling change management, regulatory project tracki' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'Externally-known business identifier for the label change, used for cross-referencing with regulatory submissions, health authority correspondence, and internal change control systems. Format: LC-YYYY-NNNNNN.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceReference rdf:type rdf:Property ;
    rdfs:label 'Correspondence Reference' ;
    rdfs:comment 'Reference number or identifier for the health authority correspondence (e.g., FDA Complete Response Letter, EMA Day 120 List of Questions) that directed or acknowledged this label change.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Health Authority Reference' ;
    rdfs:comment 'The reference number or tracking number assigned by the health authority (e.g., FDA NDA/BLA supplement number, EMA procedure number) for the submission associated with this label change.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorType rdf:type rdf:Property ;
    rdfs:label 'Initiator Type' ;
    rdfs:comment 'Indicates whether the label change was initiated by the company (e.g., based on new clinical data or pharmacovigilance signal) or mandated by a health authority (e.g., FDA, EMA directive or post-approval commitment).' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlackBoxWarning rdf:type rdf:Property ;
    rdfs:label 'Is Black Box Warning' ;
    rdfs:comment 'Indicates whether this label change includes the addition, modification, or removal of a black box warning (boxed warning), which is the FDA\'s most serious warning for drug safety risks.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPvDriven rdf:type rdf:Property ;
    rdfs:label 'Is Pv Driven' ;
    rdfs:comment 'Indicates whether this label change was driven by a pharmacovigilance signal, safety review, or post-market surveillance finding, as opposed to a new clinical indication or administrative update.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemsRelated rdf:type rdf:Property ;
    rdfs:label 'Is Rems Related' ;
    rdfs:comment 'Indicates whether this label change is associated with a Risk Evaluation and Mitigation Strategy (REMS) program requirement, such as a new REMS, REMS modification, or REMS-driven labeling update.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorLabelVersion rdf:type rdf:Property ;
    rdfs:label 'Prior Label Version' ;
    rdfs:comment 'Version number of the product label that was in effect immediately before this change, enabling traceability of label evolution and comparison of changes.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'The date on which the internal cross-functional review of the label change was completed, including sign-off from Regulatory Affairs, Medical Affairs, Pharmacovigilance, and Legal.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sectionsModified rdf:type rdf:Property ;
    rdfs:label 'Sections Modified' ;
    rdfs:comment 'Comma-delimited list of label sections that were modified in this change (e.g., \'Warnings and Precautions, Dosage and Administration, Adverse Reactions\'). Aligned with the Physician Labeling Rule (PLR) section structure for US labels and SmPC sections for EU labels.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Classification of the urgency with which the label change must be processed and implemented, based on the severity of the safety signal or regulatory requirement. Urgent and immediate changes may require expedited health authority notification.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Pre-approval inspections require an internal coordinator to manage inspection readiness, site preparation, document room setup, and response coordination. Essential for inspection preparedness trackin' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalImpact rdf:type rdf:Property ;
    rdfs:label 'Approval Impact' ;
    rdfs:comment 'Assessment of the inspection outcome\'s impact on the associated regulatory application approval timeline. \'No Impact\' = NAI/VAI with minor observations; \'Delay Risk\' = VAI/OAI requiring agency review; \'Approval Blocked\' = OAI with Warning Letter or import alert.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentInspectionReportDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Inspection Report Date' ;
    rdfs:comment 'Date on which the FDA issued the Establishment Inspection Report (EIR), the official written record of the inspection findings. The EIR is the definitive agency document summarizing the inspection.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Facility Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the inspected facility is located. Used for geographic reporting and to determine applicable regulatory jurisdiction.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityFeiNumber rdf:type rdf:Property ;
    rdfs:label 'Facility Fei Number' ;
    rdfs:comment 'FDA-assigned Facility Establishment Identifier (FEI) number for the inspected manufacturing site. Used by FDA to uniquely identify registered drug establishments in the agency\'s database.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Legal or registered name of the manufacturing facility or establishment subject to the inspection. Captured directly on the inspection record for traceability independent of the site master data.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:form483IssueDate rdf:type rdf:Property ;
    rdfs:label 'Form 483 Issue Date' ;
    rdfs:comment 'Date on which the FDA Form 483 was formally issued to the company at the close-out meeting. Triggers the response timeline for the company\'s written response.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:form483ObservationCount rdf:type rdf:Property ;
    rdfs:label 'Form 483 Observation Count' ;
    rdfs:comment 'Total number of individual observations (483 items) cited on the FDA Form 483 issued at the conclusion of the inspection. A key metric for assessing inspection severity and approval risk.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:importAlertIssued rdf:type rdf:Property ;
    rdfs:label 'Import Alert Issued' ;
    rdfs:comment 'Indicates whether the FDA issued an Import Alert against the inspected facility following the inspection. An Import Alert results in detention without physical examination (DWPE) of products from the facility.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadInvestigatorBadge rdf:type rdf:Property ;
    rdfs:label 'Lead Investigator Badge' ;
    rdfs:comment 'Official badge or employee identification number of the lead health authority investigator. Used to uniquely identify the investigator in agency records and correspondence.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Lead Investigator Name' ;
    rdfs:comment 'Full name of the lead health authority investigator or inspector assigned to conduct the inspection. Used for correspondence tracking and relationship management with the agency.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preliminaryOutcome rdf:type rdf:Property ;
    rdfs:label 'Preliminary Outcome' ;
    rdfs:comment 'Preliminary classification communicated informally by the lead investigator at the close-out meeting before the official classification is issued. Used for early approval readiness assessment while awaiting final determination.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required' ;
    rdfs:comment 'Indicates whether the health authority has determined that a follow-up or reinspection of the facility is required before the associated application can be approved. Typically triggered by OAI classifications.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaVaultRecordReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Record Reference' ;
    rdfs:comment 'Unique record identifier from Veeva Vault RIM (Regulatory Information Management) system where the inspection record and associated documents are managed. Enables traceability to the source system of record.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningLetterDate rdf:type rdf:Property ;
    rdfs:label 'Warning Letter Date' ;
    rdfs:comment 'Date on which the health authority formally issued the Warning Letter to the company. Marks the start of the regulatory action timeline and triggers mandatory corrective action commitments.' ;
    rdfs:domain ind:Pai ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postApprovalCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Post Approval Commitment Id' ;
    rdfs:comment 'Unique system-generated identifier for each post-approval commitment record. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PostApprovalCommitment .

ind:clinicalSupplyOrderId rdf:type rdf:Property ;
    rdfs:label 'Clinical Supply Order Id' ;
    rdfs:comment 'Foreign key linking to supply.clinical_supply_order. Business justification: Post-approval commitments often include required clinical studies (pediatric, confirmatory trials). These studies require investigational product supply management; tracking PAC fulfillment requires l' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalSupplyOrder .

ind:commitmentOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Commitment Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Post-approval commitments require structured employee ownership for fulfillment tracking, escalation management, and performance evaluation. Critical for commitment compliance, workload planning, and ' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:executingVendorId rdf:type rdf:Property ;
    rdfs:label 'Executing Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Post-approval commitments (clinical studies, stability studies, manufacturing process validation) are often executed by CRO/CMO vendors. Pharma companies track which vendor is responsible for each com' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:agencyTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Tracking Number' ;
    rdfs:comment 'The unique identifier assigned by the health authority (FDA, EMA, PMDA, MHRA, NMPA) to track this specific post-approval commitment or post-marketing requirement. For FDA PMR/PMC, this is the agency-assigned PMR/PMC number (e.g., PMR 1234-1).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Report Due Date' ;
    rdfs:comment 'The due date for the next annual progress report to the health authority on the status of this post-approval commitment, as required under 21 CFR Part 314.81 for FDA and equivalent EMA reporting cycles.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalTrialRegistryNumber rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Registry Number' ;
    rdfs:comment 'Public registry identifier for the clinical study associated with this commitment (e.g., ClinicalTrials.gov NCT number, EudraCT number). Required for Phase IV and pediatric studies under FDAAA and EU CTR.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentCategory rdf:type rdf:Property ;
    rdfs:label 'Commitment Category' ;
    rdfs:comment 'Broad scientific or operational category of the commitment: Clinical (clinical studies), Non-Clinical (preclinical/toxicology), CMC (Chemistry Manufacturing and Controls), Pharmacovigilance, Labeling, or Risk Management. Used for portfolio analytics and resource planning.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the post-approval commitment as reported to the health authority. Aligns with FDA PMR/PMC status categories: Pending (not yet started), Ongoing (in progress), Submitted (deliverable submitted to agency), Fulfilled (agency confirmed completion), Released (agency released from requirement), Delayed, or Terminated. [ENUM-REF-CANDIDATE: Pending|Ongoing|Submitted|Fulfilled|Released|Delayed|Terminated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Classification of the commitment type: PMR (Post-Marketing Requirement — legally required under FDAAA), PMC (Post-Marketing Commitment — voluntarily agreed), Phase IV Study, Label Update, Stability Study, or Risk Management measure. [ENUM-REF-CANDIDATE: PMR|PMC|Phase IV Study|Label Update|Stability Study|Risk Management|REMS|Pediatric Study|Pharmacovigilance Study|Registry Study — promote to reference product]' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedMilestoneCount rdf:type rdf:Property ;
    rdfs:label 'Completed Milestone Count' ;
    rdfs:comment 'Number of individual action-level milestones or tasks that have been completed for this commitment. Used alongside milestone_count to calculate progress percentage for executive dashboards.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Narrative explanation for any delay in meeting the original or revised due date for this commitment. Required for agency reporting when a commitment is classified as Delayed. Supports regulatory correspondence and agency negotiations.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'The type of document or output required to fulfill this commitment: Protocol (study protocol submission), Interim Report, Final Study Report, Label Update, Annual Report, or Safety Update (e.g., PSUR/PBRER). [ENUM-REF-CANDIDATE: Protocol|Interim Report|Final Study Report|Label Update|Annual Report|Safety Update|Risk Management Plan|Registry Report|Pharmacovigilance Plan — promote to reference product]' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPediatricCommitment rdf:type rdf:Property ;
    rdfs:label 'Is Pediatric Commitment' ;
    rdfs:comment 'Indicates whether this commitment was issued under pediatric legislation (PREA in the US, PDCO/PIP in the EU). True if the commitment is a pediatric study or measure required under PREA or EU Pediatric Regulation.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAgency rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency' ;
    rdfs:comment 'The regulatory health authority that issued or mandated this post-approval commitment (e.g., FDA, EMA, PMDA, MHRA, NMPA). Determines the applicable regulatory framework and reporting obligations. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|NMPA|WHO|Health Canada|TGA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReportedStatusDate rdf:type rdf:Property ;
    rdfs:label 'Last Reported Status Date' ;
    rdfs:comment 'The date on which the most recent status update for this commitment was reported to the health authority (e.g., in an annual report or ad hoc correspondence). Used to track reporting currency and compliance.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalDueDate rdf:type rdf:Property ;
    rdfs:label 'Original Due Date' ;
    rdfs:comment 'The original due date for fulfillment of this post-approval commitment as specified in the approval letter or agency correspondence. Preserved for compliance tracking and variance analysis against revised due dates.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postApprovalCommitmentDescription rdf:type rdf:Property ;
    rdfs:label 'Post Approval Commitment Description' ;
    rdfs:comment 'Full narrative description of the post-approval commitment as stated in the approval letter, labeling, or agency correspondence. Captures the scope, objective, and specific deliverable required.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedDueDate rdf:type rdf:Property ;
    rdfs:label 'Revised Due Date' ;
    rdfs:comment 'The most current agreed-upon due date for fulfillment, reflecting any agency-approved extensions or renegotiations. Null if no revision has been made to the original due date.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Product Registration Id' ;
    rdfs:comment 'Unique surrogate identifier for each country-level product registration record. Primary key of the product_registration data product.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRegistration .

ind:firstCommercialDate rdf:type rdf:Property ;
    rdfs:label 'First Commercial Date' ;
    rdfs:comment 'Date on which the product was first commercially launched and placed on the market in this country following registration. Used to track sunset clause compliance and commercial launch timelines.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Label Version Number' ;
    rdfs:comment 'Version number of the currently approved product label or Summary of Product Characteristics (SmPC) associated with this registration. Used to track label currency and identify when label updates are required.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationHolder rdf:type rdf:Property ;
    rdfs:label 'Registration Holder' ;
    rdfs:comment 'Legal entity name of the Marketing Authorization Holder (MAH) or registration holder responsible for maintaining this registration in the country. May differ from the parent company in cases of local affiliates or licensing partners.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Approval Date' ;
    rdfs:comment 'Date on which the health authority granted approval of the renewal application, extending the validity of the marketing authorization.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Calendar date by which the renewal application must be submitted to the health authority to prevent registration lapse. Critical for renewal calendar management and commercial continuity planning.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Amount' ;
    rdfs:comment 'Monetary amount of the regulatory renewal fee payable to the health authority for this registration renewal. Expressed in the local currency of the health authority jurisdiction.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the renewal fee amount (e.g., USD, EUR, GBP, JPY, CNY).' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFeeStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Status' ;
    rdfs:comment 'Payment status of the regulatory renewal fee due to the health authority for this registration renewal cycle. Unpaid or overdue fees can result in registration lapse.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOutcome rdf:type rdf:Property ;
    rdfs:label 'Renewal Outcome' ;
    rdfs:comment 'Outcome of the most recent renewal application for this registration. Approved = renewal granted; Refused = health authority denied renewal; Withdrawn by Holder = MAH withdrew the renewal application; Pending = renewal submitted and under review; Not Submitted = renewal not yet submitted.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Submission Date' ;
    rdfs:comment 'Actual date on which the renewal application dossier was submitted to the health authority. Used to confirm timely submission and calculate submission lead time against the renewal due date.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Type of renewal cycle applicable to this registration as defined by the health authority. Five-year = standard EU/ICH 5-year renewal; Annual = annual renewal required (e.g., certain PMDA registrations); Sunset Clause = registration lapses if product not marketed within defined period; Indefinite = no renewal required after initial grant; Not Applicable = renewal not applicable in this jurisdiction.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunsetClauseDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Clause Date' ;
    rdfs:comment 'Date by which the product must be placed on the market in the registered country to avoid automatic lapse of the registration under the sunset clause provision. Applicable in EU and certain other jurisdictions where a registration lapses if the product is not marketed within 3 years of grant.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentActionId rdf:type rdf:Property ;
    rdfs:label 'Commitment Action Id' ;
    rdfs:comment 'Unique surrogate identifier for each granular action record within a post-approval regulatory commitment. Serves as the primary key for this entity.' ;
    rdfs:domain ind:CommitmentAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyImposedDate rdf:type rdf:Property ;
    rdfs:label 'Agency Imposed Date' ;
    rdfs:comment 'The date on which the health authority formally imposed or agreed to this commitment action, typically the approval date or the date of the commitment letter. Serves as the BUSINESS_EVENT_TIMESTAMP for this transaction.' ;
    rdfs:domain ind:CommitmentAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes documenting the outcome, findings, or any relevant context upon completion of this commitment action. May include summary of study results, reasons for delay, or agency feedback received.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableTitle rdf:type rdf:Property ;
    rdfs:label 'Deliverable Title' ;
    rdfs:comment 'The formal title of the document or deliverable produced to fulfill this action (e.g., \'Phase 4 Pediatric Safety Study Final Report\', \'Updated Prescribing Information\'). Used for document management and health authority correspondence.' ;
    rdfs:domain ind:CommitmentAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Current escalation level for this action, reflecting how far up the organization or to the health authority the delay or risk has been escalated. Supports governance and risk management reporting.' ;
    rdfs:domain ind:CommitmentAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOverdue rdf:type rdf:Property ;
    rdfs:label 'Is Overdue' ;
    rdfs:comment 'Flag indicating whether this commitment action has passed its due date without completion or submission. Drives escalation workflows and health authority notification processes.' ;
    rdfs:domain ind:CommitmentAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionReference rdf:type rdf:Property ;
    rdfs:label 'Submission Reference' ;
    rdfs:comment 'The formal submission reference number or dossier identifier associated with the deliverable filed for this action (e.g., NDA supplement number, variation number, eCTD submission ID). Enables cross-referencing with the submission tracking system.' ;
    rdfs:domain ind:CommitmentAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Documented justification for waiving this commitment action, applicable when the health authority has agreed that the action is no longer necessary (e.g., due to new scientific evidence or product withdrawal). Required for audit trail.' ;
    rdfs:domain ind:CommitmentAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceId rdf:type rdf:Property ;
    rdfs:label 'Correspondence Id' ;
    rdfs:comment 'Unique surrogate identifier for each regulatory correspondence record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyDivision rdf:type rdf:Property ;
    rdfs:label 'Agency Division' ;
    rdfs:comment 'Specific division, office, or directorate within the health authority handling the correspondence (e.g., FDA Office of New Drugs, CDER Division of Oncology Products, EMA Committee for Medicinal Products for Human Use (CHMP)). Enables precise routing and tracking of agency interactions.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyLetterDate rdf:type rdf:Property ;
    rdfs:label 'Agency Letter Date' ;
    rdfs:comment 'Official date printed on the health authority correspondence letter, which may differ from the received_date. Used for formal regulatory record-keeping and timeline calculations per agency procedural rules.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Flag' ;
    rdfs:comment 'Indicates whether the correspondence contains commercially sensitive or confidential information subject to restricted access controls (e.g., trade secrets, proprietary manufacturing data). True = confidential; False = standard access.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correspondenceNumber rdf:type rdf:Property ;
    rdfs:label 'Correspondence Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the correspondence, either by the health authority (e.g., FDA tracking number, EMA reference) or internally by the regulatory affairs team. Used for cross-referencing in Veeva Vault RIM and RIMS.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceStatus rdf:type rdf:Property ;
    rdfs:label 'Correspondence Status' ;
    rdfs:comment 'Current lifecycle status of the correspondence record. Tracks workflow from initial drafting through final closure, enabling compliance monitoring against agency deadlines. [ENUM-REF-CANDIDATE: draft|sent|received|under_review|responded|closed|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceType rdf:type rdf:Property ;
    rdfs:label 'Correspondence Type' ;
    rdfs:comment 'Classification of the formal correspondence type exchanged with the health authority. Key types include: information_request (IR) — agency requests additional data; complete_response_letter (CRL) — FDA response to NDA/BLA; deficiency_letter — EMA/MHRA list of outstanding issues; acknowledgment_letter — agency confirms receipt; approval_letter — formal marketing authorization; agency_query — general regulatory inquiry. [ENUM-REF-CANDIDATE: information_request|complete_response_letter|deficiency_letter|acknowledgment_letter|approval_letter|agency_query|meeting_request|meeting_minutes|advisory_committee_briefing|label_negotiation|post_approval_commitment|rems_correspondence — promote to reference product]' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'Revised response deadline granted by the health authority following an approved extension request. Replaces the original response_due_date for compliance monitoring when an extension has been granted.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paiFlag rdf:type rdf:Property ;
    rdfs:label 'Pai Flag' ;
    rdfs:comment 'Indicates whether this correspondence is associated with a Pre-Approval Inspection (PAI) conducted by the health authority at manufacturing or clinical sites. True = PAI-related; False = not PAI-related.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Flag' ;
    rdfs:comment 'Indicates whether this correspondence has been flagged as high priority, requiring expedited handling or escalation (e.g., Complete Response Letters, SUSAR-related queries, or time-sensitive agency requests). True = priority; False = standard.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseExtensionRequested rdf:type rdf:Property ;
    rdfs:label 'Response Extension Requested' ;
    rdfs:comment 'Indicates whether the company has formally requested an extension to the response deadline from the health authority. True = extension requested; False = no extension requested. Supports compliance tracking and agency negotiation records.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePerson rdf:type rdf:Property ;
    rdfs:label 'Responsible Person' ;
    rdfs:comment 'Name or identifier of the regulatory affairs professional responsible for managing and responding to this correspondence. Serves as the primary point of contact for the correspondence lifecycle within the organization.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentDate rdf:type rdf:Property ;
    rdfs:label 'Sent Date' ;
    rdfs:comment 'Date the outbound correspondence was officially transmitted to the health authority. For inbound correspondence, this field is null. Captured for audit trail and submission timeline tracking.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectMatterCategory rdf:type rdf:Property ;
    rdfs:label 'Subject Matter Category' ;
    rdfs:comment 'High-level categorization of the subject matter area addressed in the correspondence, aligned with eCTD module structure. Supports analytics on correspondence volume by technical domain. [ENUM-REF-CANDIDATE: clinical|nonclinical|cmc|regulatory_strategy|labeling|safety|pharmacovigilance|rems|post_approval|manufacturing|quality|intellectual_property — promote to reference product]' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Agency Meeting Date' ;
    rdfs:comment 'Date of the most recent or scheduled health authority meeting (e.g., Type B meeting with FDA, PRIME scientific advice meeting with EMA) related to this designation.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefits rdf:type rdf:Property ;
    rdfs:label 'Benefits' ;
    rdfs:comment 'Free-text summary of the regulatory and commercial benefits conferred by this designation (e.g., rolling review, priority review voucher, tax credits, market exclusivity, fee waivers, intensive FDA guidance).' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmatoryTrialRequired rdf:type rdf:Property ;
    rdfs:label 'Confirmatory Trial Required' ;
    rdfs:comment 'Indicates whether a post-approval confirmatory clinical trial is required as a condition of the designation or associated approval pathway (e.g., Accelerated Approval post-market requirement).' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designationNumber rdf:type rdf:Property ;
    rdfs:label 'Designation Number' ;
    rdfs:comment 'Official reference number assigned by the health authority upon granting the designation (e.g., FDA Orphan Drug Designation number, Breakthrough Therapy designation reference). Serves as the externally-known business identifier for this designation.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationStatus rdf:type rdf:Property ;
    rdfs:label 'Designation Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory designation, tracking progression from initial request through grant, potential withdrawal, revocation, or expiry.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationType rdf:type rdf:Property ;
    rdfs:label 'Designation Type' ;
    rdfs:comment 'Category of the special regulatory designation or expedited program. Covers FDA and international agency programs. [ENUM-REF-CANDIDATE: Breakthrough Therapy|Fast Track|Accelerated Approval|Priority Review|Orphan Drug Designation|Rare Pediatric Disease|Qualified Infectious Disease Product|EMA PRIME|PMDA Sakigake|Conditional Marketing Authorization|Exceptional Circumstances — promote to reference product]' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Period Years' ;
    rdfs:comment 'Duration in years of market exclusivity conferred by the designation upon approval (e.g., 7 years for FDA Orphan Drug, 10 years for EMA Orphan). Null if no exclusivity is associated with this designation type.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obligations rdf:type rdf:Property ;
    rdfs:label 'Obligations' ;
    rdfs:comment 'Free-text summary of post-grant obligations and commitments associated with the designation (e.g., pediatric study requirements, annual prevalence reporting for orphan drugs, post-market confirmatory trials for accelerated approval).' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDiseasePrevalence rdf:type rdf:Property ;
    rdfs:label 'Orphan Disease Prevalence' ;
    rdfs:comment 'Reported prevalence of the orphan condition per 10,000 population as submitted in the Orphan Drug Designation (ODD) request. Applicable only when designation_type is Orphan Drug Designation or Rare Pediatric Disease.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityReviewVoucherEligible rdf:type rdf:Property ;
    rdfs:label 'Priority Review Voucher Eligible' ;
    rdfs:comment 'Indicates whether this designation confers eligibility for a Priority Review Voucher (PRV) upon approval (applicable to Rare Pediatric Disease and Tropical Disease designations under FDA).' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollingReviewEnabled rdf:type rdf:Property ;
    rdfs:label 'Rolling Review Enabled' ;
    rdfs:comment 'Indicates whether the designation enables rolling review of the marketing application (i.e., submission of completed dossier modules before the full application is ready), as applicable for Fast Track and EMA PRIME designations.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voucherRedeemed rdf:type rdf:Property ;
    rdfs:label 'Voucher Redeemed' ;
    rdfs:comment 'Indicates whether the Priority Review Voucher (PRV) associated with this designation has been redeemed or sold. Applicable only when priority_review_voucher_eligible is True.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Unique system-generated identifier for each regulatory milestone record. Primary key for the regulatory_milestone data product.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crlReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Crl Receipt Date' ;
    rdfs:comment 'Date on which a Complete Response Letter (CRL) was received from the FDA, indicating the agency cannot approve the application in its current form. Null if no CRL has been issued. Critical for tracking resubmission timelines.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'Classification of the health authority meeting associated with this milestone. FDA meeting types: Type A (dispute resolution/clinical hold), Type B (pre-IND, EOP1, EOP2, pre-NDA/BLA), Type C (other). ADCOM = Advisory Committee Meeting. [ENUM-REF-CANDIDATE: Type_A|Type_B|Type_C|ADCOM|pre_IND|EOP1|EOP2|pre_NDA|pre_BLA|scientific_advice|other — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paiDate rdf:type rdf:Property ;
    rdfs:label 'Pai Date' ;
    rdfs:comment 'Date of the Pre-Approval Inspection (PAI) conducted by the health authority at the manufacturing facility prior to granting marketing approval. Applicable for PAI-type milestones. Null for non-inspection milestones.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pdufaDate rdf:type rdf:Property ;
    rdfs:label 'Pdufa Date' ;
    rdfs:comment 'The FDA-assigned Prescription Drug User Fee Act (PDUFA) action date by which the FDA commits to completing its review of an NDA or BLA. Applicable only to FDA submissions. Null for non-FDA applications or non-applicable milestone types.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postApprovalCommitmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Post Approval Commitment Due Date' ;
    rdfs:comment 'Due date for fulfilling a post-approval commitment or post-marketing requirement imposed by the health authority as a condition of approval (e.g., post-marketing study, label update, REMS implementation). Applicable for commitment-type milestones.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleOwner rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner' ;
    rdfs:comment 'Name or identifier of the regulatory affairs professional or team lead responsible for managing and delivering this milestone. Used for accountability tracking and workload management in regulatory project plans.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedTargetDate rdf:type rdf:Property ;
    rdfs:label 'Revised Target Date' ;
    rdfs:comment 'Most recently revised target date for the milestone, updated when the original planned date changes due to program delays, strategy shifts, or health authority feedback. Distinct from planned_date (baseline) to enable schedule variance tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Number of calendar days between the planned_date and actual_date (or current date if not yet completed). Positive value indicates delay; negative value indicates early completion. Supports regulatory timeline performance reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategyId rdf:type rdf:Property ;
    rdfs:label 'Strategy Id' ;
    rdfs:comment 'Unique surrogate identifier for the regulatory strategy record within the Pharmaceuticals data lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadHealthAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Lead Health Authority Id' ;
    rdfs:comment 'Foreign key linking to regulatory.health_authority. Business justification: Regulatory strategy identifies the lead health authority for the global filing sequence (e.g., FDA for US-first strategy, EMA for EU-first). The lead_agency STRING should be replaced with a FK to heal' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthAuthority .

ind:agencyEngagementPlan rdf:type rdf:Property ;
    rdfs:label 'Agency Engagement Plan' ;
    rdfs:comment 'Summary of planned formal and informal interactions with health authorities (e.g., Pre-IND meetings, Type B meetings with FDA, Scientific Advice with EMA, PMDA consultations). Defines the cadence and objectives of regulatory agency engagement.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveLandscapeNotes rdf:type rdf:Property ;
    rdfs:label 'Competitive Landscape Notes' ;
    rdfs:comment 'Summary of the competitive regulatory landscape including approved products in the same indication, precedent-setting approvals, and competitor pipeline programs that may influence the regulatory strategy or review standards.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalFilingSequence rdf:type rdf:Property ;
    rdfs:label 'Global Filing Sequence' ;
    rdfs:comment 'Ordered sequence of regulatory agency submissions planned globally, describing the order in which dossiers will be filed across jurisdictions (e.g., FDA first, then EMA, then PMDA). Supports launch sequencing and resource planning.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRegulatoryRisks rdf:type rdf:Property ;
    rdfs:label 'Key Regulatory Risks' ;
    rdfs:comment 'Narrative description of the principal regulatory risks identified for this program, including data gaps, safety signals, manufacturing concerns, or precedent-setting issues that could delay or prevent approval.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primeDesignation rdf:type rdf:Property ;
    rdfs:label 'Prime Designation' ;
    rdfs:comment 'Indicates whether EMA PRIority MEdicines (PRIME) designation is being pursued or has been granted. PRIME provides enhanced EMA support for medicines that offer a major therapeutic advantage over existing treatments.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityMarkets rdf:type rdf:Property ;
    rdfs:label 'Priority Markets' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the priority markets targeted for initial regulatory submissions (e.g., USA, GBR, DEU, JPN). Drives global filing sequence planning.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPathwayType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pathway Type' ;
    rdfs:comment 'The planned regulatory approval pathway for the drug program (e.g., NDA 505(b)(1), NDA 505(b)(2), BLA, MAA, Abbreviated NDA, 510(k)). Determines the submission type and data package requirements. [ENUM-REF-CANDIDATE: NDA_505b1|NDA_505b2|ANDA|BLA|MAA|NDS|JNDA|sNDA|sBLA|sMAA — promote to reference product]' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sakigakeDesignation rdf:type rdf:Property ;
    rdfs:label 'Sakigake Designation' ;
    rdfs:comment 'Indicates whether PMDA Sakigake designation is being pursued for this program in Japan. Sakigake provides priority review and early consultation for innovative drugs addressing serious diseases.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicRationale rdf:type rdf:Property ;
    rdfs:label 'Strategic Rationale' ;
    rdfs:comment 'Narrative explanation of the strategic reasoning behind the chosen regulatory pathway, filing sequence, and expedited program designations. Documents the decision-making basis for regulatory governance review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyNumber rdf:type rdf:Property ;
    rdfs:label 'Strategy Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the regulatory strategy document as assigned in Veeva Vault RIM. Used for cross-functional referencing and regulatory correspondence tracking.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyStatus rdf:type rdf:Property ;
    rdfs:label 'Strategy Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory strategy document within Veeva Vault RIM. Drives workflow routing and version control. [ENUM-REF-CANDIDATE: draft|under_review|approved|active|superseded|retired — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Target Approval Date' ;
    rdfs:comment 'Anticipated date of regulatory approval from the lead agency based on standard or priority review timelines. Drives commercial launch planning and supply chain readiness.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Target Submission Date' ;
    rdfs:comment 'Planned date for the primary regulatory submission (e.g., NDA, BLA, MAA) to the lead agency. Used for milestone tracking and commercial launch timeline planning.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tppSummary rdf:type rdf:Property ;
    rdfs:label 'Tpp Summary' ;
    rdfs:comment 'Narrative summary of the Target Product Profile (TPP) describing the desired label claims, patient population, dosing regimen, safety profile, and differentiation from existing therapies. Anchors the regulatory strategy to commercial objectives.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsId rdf:type rdf:Property ;
    rdfs:label 'Rems Id' ;
    rdfs:comment 'Unique surrogate identifier for the REMS program master record in the Pharmaceuticals data lakehouse.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: REMS programs require an internal program owner for assessment coordination, modification management, and FDA correspondence. Critical for REMS compliance tracking, program oversight, and regulatory a' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentSchedule rdf:type rdf:Property ;
    rdfs:label 'Assessment Schedule' ;
    rdfs:comment 'FDA-mandated schedule for submitting REMS assessments (e.g., \'18 months, 3 years, and 7 years after approval\', or \'annually\'). Defines the cadence of program effectiveness reporting obligations.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecmSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Ecm Submission Reference' ;
    rdfs:comment 'eCTD sequence number or submission reference in Veeva Vault RIM corresponding to the most recent REMS submission or modification filed with FDA. Enables traceability to the regulatory dossier.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etasuElements rdf:type rdf:Property ;
    rdfs:label 'Etasu Elements' ;
    rdfs:comment 'Narrative description of the specific ETASU elements required under this REMS program (e.g., certified prescriber requirement, certified pharmacy requirement, patient enrollment registry, laboratory monitoring, patient agreement form). [ENUM-REF-CANDIDATE: certified_prescriber|certified_pharmacy|patient_registry|lab_monitoring|patient_agreement|safe_use_condition — promote to reference product]' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaContactName rdf:type rdf:Property ;
    rdfs:label 'Fda Contact Name' ;
    rdfs:comment 'Name of the FDA project manager or reviewer assigned to this REMS program. Used for official regulatory correspondence and health authority interactions.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalStatement rdf:type rdf:Property ;
    rdfs:label 'Goal Statement' ;
    rdfs:comment 'Official FDA-approved goal statement for the REMS program describing the specific safety outcome the program is designed to achieve (e.g., \'Mitigate the risk of fetal exposure to isotretinoin\').' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasCommunicationPlan rdf:type rdf:Property ;
    rdfs:label 'Has Communication Plan' ;
    rdfs:comment 'Indicates whether the REMS program includes a Communication Plan element targeting healthcare professionals (HCPs) about serious risks associated with the drug.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasEtasu rdf:type rdf:Property ;
    rdfs:label 'Has Etasu' ;
    rdfs:comment 'Indicates whether the REMS program includes Elements to Assure Safe Use (ETASU), which are the most restrictive REMS requirements such as certified prescriber/pharmacy networks, patient registries, or laboratory testing requirements.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasMedicationGuide rdf:type rdf:Property ;
    rdfs:label 'Has Medication Guide' ;
    rdfs:comment 'Indicates whether the REMS program includes a Medication Guide as a required REMS element to be dispensed to patients at each prescription fill.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Outcome' ;
    rdfs:comment 'FDA\'s determination following review of the most recently submitted REMS assessment report. Indicates whether the program is meeting its goals or requires modification.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessmentSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Submission Date' ;
    rdfs:comment 'Date on which the most recent REMS assessment report was submitted to FDA via eCTD. Used to verify compliance with the assessment schedule.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'Date of the most recent FDA-approved modification to the REMS program. Used to track program currency and trigger downstream label and communication updates.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModificationType rdf:type rdf:Property ;
    rdfs:label 'Last Modification Type' ;
    rdfs:comment 'Classification of the most recent REMS modification as major (substantive change to ETASU or goals), minor (non-substantive change), or administrative (formatting/contact updates).' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationCount rdf:type rdf:Property ;
    rdfs:label 'Modification Count' ;
    rdfs:comment 'Total number of FDA-approved modifications made to the REMS program since initial approval. Tracks program evolution and regulatory change history.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Date by which the next REMS assessment report must be submitted to FDA per the approved assessment schedule. Critical for regulatory compliance tracking.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programAdministrator rdf:type rdf:Property ;
    rdfs:label 'Program Administrator' ;
    rdfs:comment 'Name of the organization or vendor contracted to administer the REMS program operations (e.g., patient enrollment, prescriber certification, pharmacy certification, call center). May be an internal team or a third-party REMS administrator.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programVersion rdf:type rdf:Property ;
    rdfs:label 'Program Version' ;
    rdfs:comment 'Version identifier of the current approved REMS program document, incremented with each FDA-approved modification (e.g., v1.0, v2.3). Aligns with eCTD submission versioning in Veeva Vault RIM.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsNumber rdf:type rdf:Property ;
    rdfs:label 'Rems Number' ;
    rdfs:comment 'FDA-assigned unique program identifier for the REMS, used for official correspondence and regulatory submissions. Serves as the externally-known business identifier.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCertifiedPharmacy rdf:type rdf:Property ;
    rdfs:label 'Requires Certified Pharmacy' ;
    rdfs:comment 'Indicates whether pharmacies must be certified or enrolled in the REMS program before they are authorized to dispense the drug. Restricts dispensing to a controlled pharmacy network.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCertifiedPrescriber rdf:type rdf:Property ;
    rdfs:label 'Requires Certified Prescriber' ;
    rdfs:comment 'Indicates whether prescribers must be certified or enrolled in the REMS program before they are authorized to prescribe the drug. A key ETASU element for high-risk products.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresLabMonitoring rdf:type rdf:Property ;
    rdfs:label 'Requires Lab Monitoring' ;
    rdfs:comment 'Indicates whether the REMS program mandates specific laboratory tests (e.g., pregnancy tests, liver function tests, blood counts) as a condition of prescribing or dispensing the drug.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPatientEnrollment rdf:type rdf:Property ;
    rdfs:label 'Requires Patient Enrollment' ;
    rdfs:comment 'Indicates whether patients must be enrolled in the REMS program (e.g., patient registry or patient agreement) before receiving the drug. Enables tracking of patient exposure and outcomes.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharedRemsIndicator rdf:type rdf:Property ;
    rdfs:label 'Shared Rems Indicator' ;
    rdfs:comment 'Indicates whether this is a shared REMS program administered jointly by multiple sponsors (e.g., brand and generic manufacturers) under a single FDA-approved REMS. Relevant for interoperability with generic entrants.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalId rdf:type rdf:Property ;
    rdfs:label 'Renewal Id' ;
    rdfs:comment 'Unique surrogate identifier for the marketing authorization renewal record. Primary key for the renewal data product.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'The date on which the current marketing authorization expires if not renewed. This is the critical deadline driving the renewal calendar and supply chain continuity planning.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the renewal fee amount (e.g., USD, EUR, GBP, JPY, CNY).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Date' ;
    rdfs:comment 'The date on which the renewal fee was paid to the health authority. Confirms financial compliance with the renewal application requirements.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Status' ;
    rdfs:comment 'Current payment status of the regulatory renewal fee. Unpaid fees can result in rejection of the renewal application by the health authority, making this a critical compliance tracking field.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeWaiverFlag rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Flag' ;
    rdfs:comment 'Indicates whether the health authority has granted a fee waiver for this renewal (e.g., for orphan drug designations, small and medium enterprises, or public health emergencies).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelUpdateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Label Update Required Flag' ;
    rdfs:comment 'Indicates whether the renewal approval requires an update to the product label (SmPC, PIL, or USPI) as a condition of the renewed authorization, triggering a label change workflow.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newExpiryDate rdf:type rdf:Property ;
    rdfs:label 'New Expiry Date' ;
    rdfs:comment 'The updated expiry date of the marketing authorization following successful renewal. For EMA five-year renewals, the authorization becomes unlimited unless the authority decides otherwise. Null if renewal is not yet approved.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remsUpdateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Update Required Flag' ;
    rdfs:comment 'Indicates whether the renewal requires an update to the Risk Evaluation and Mitigation Strategy (REMS) program as part of the renewal conditions or health authority requirements.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Number' ;
    rdfs:comment 'Externally-known business identifier for the renewal activity, typically assigned by the regulatory affairs team or the health authority (e.g., REN-2024-00123). Used for cross-referencing in Veeva Vault RIM and regulatory correspondence.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current lifecycle state of the renewal activity. Tracks progression from planning through submission to health authority decision. Lapsed indicates the registration has expired without successful renewal. [ENUM-REF-CANDIDATE: planned|in_preparation|submitted|under_review|approved|rejected|withdrawn|lapsed — promote to reference product]' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunsetClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Sunset Clause Flag' ;
    rdfs:comment 'Indicates whether this renewal is triggered by the sunset clause provision, which requires evidence that the product has been placed on the market within three years of initial authorization to prevent automatic lapse.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unlimitedAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Unlimited Authorization Flag' ;
    rdfs:comment 'Indicates whether the marketing authorization has been converted to unlimited validity following a successful renewal (standard EMA outcome after first five-year renewal with satisfactory benefit-risk profile).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:croBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Cro Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: CROs are contracted business partners providing regulatory submission preparation and filing services. Tracking the CRO entity is essential for vendor management, quality oversight, and regulatory ins' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:actualDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Decision Date' ;
    rdfs:comment 'Calendar date on which the health authority issued its formal regulatory decision (approval, complete response, refusal, withdrawal). Used to measure review cycle time against PDUFA/EMA target dates and track regulatory performance.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverLetterTitle rdf:type rdf:Property ;
    rdfs:label 'Cover Letter Title' ;
    rdfs:comment 'Title or subject line of the cover letter accompanying this submission, summarizing the purpose and scope of the filing. Provides a human-readable description of the submission intent for regulatory affairs tracking and correspondence management.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdModulesIncluded rdf:type rdf:Property ;
    rdfs:label 'Ctd Modules Included' ;
    rdfs:comment 'Comma-separated list of ICH CTD modules included in this submission (e.g., \'1,2,3,4,5\' for a full NDA; \'1,2\' for an administrative amendment). Modules: 1=Administrative/Regional; 2=Summaries; 3=Quality (CMC); 4=Nonclinical; 5=Clinical. Supports dossier completeness assessment.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of individual documents included in this submission sequence. Used for dossier completeness assessment, submission quality metrics, and workload estimation for health authority reviewers.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dossierFormat rdf:type rdf:Property ;
    rdfs:label 'Dossier Format' ;
    rdfs:comment 'Technical format of the regulatory dossier submitted to the health authority. eCTD (Electronic Common Technical Document) is the current standard; NeeS (Non-eCTD Electronic Submission) and paper are legacy formats. Determines validation and processing requirements.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeUsd rdf:type rdf:Property ;
    rdfs:label 'Fee Usd' ;
    rdfs:comment 'Regulatory user fee paid to the health authority for processing this submission, denominated in US Dollars. For FDA submissions, this is the PDUFA application fee. Tracked for financial planning, budget management, and fee waiver/exemption monitoring.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeWaiverGranted rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Granted' ;
    rdfs:comment 'Indicates whether a regulatory user fee waiver or exemption has been granted for this submission (e.g., orphan drug fee waiver, small business waiver, public health waiver). True = fee waiver approved by the health authority.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medium rdf:type rdf:Property ;
    rdfs:label 'Medium' ;
    rdfs:comment 'Physical or electronic channel used to transmit the submission to the health authority. Electronic Gateway (e.g., FDA ESG, EMA eSubmission Gateway) is the standard; physical media (CD/DVD/USB) and portal submissions are also tracked.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityDesignation rdf:type rdf:Property ;
    rdfs:label 'Priority Designation' ;
    rdfs:comment 'Special regulatory designation granted to the submission or parent application that confers expedited review or development benefits. Includes FDA Breakthrough Therapy, Fast Track, Priority Review, Accelerated Approval, Orphan Drug designation. Multiple designations may apply; primary designation recorded here.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Further classification of the submission type providing regulatory granularity (e.g., Prior Approval Supplement, Changes Being Effected Supplement, Type IA Variation, Type IB Variation, Type II Variation). Jurisdiction-specific categorization used for review timeline determination. [ENUM-REF-CANDIDATE: promote to reference product]' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetActionDate rdf:type rdf:Property ;
    rdfs:label 'Target Action Date' ;
    rdfs:comment 'Regulatory target date by which the health authority is committed to completing its review and issuing a decision. For FDA submissions, this is the Prescription Drug User Fee Act (PDUFA) goal date. For EMA, this is the Day 210 opinion date. Critical milestone for commercial planning.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationErrorCount rdf:type rdf:Property ;
    rdfs:label 'Validation Error Count' ;
    rdfs:comment 'Number of technical validation errors identified during eCTD dossier validation. Zero indicates a clean submission. Used to assess submission quality and track remediation effort prior to resubmission.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionSequenceId rdf:type rdf:Property ;
    rdfs:label 'Submission Sequence Id' ;
    rdfs:comment 'Unique surrogate identifier for each eCTD submission sequence record within the regulatory application lifecycle.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rimsSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Rims Submission Id' ;
    rdfs:comment 'The native submission record identifier from the source Regulatory Information Management System (RIMS), specifically Veeva Vault RIM, used for cross-system traceability and reconciliation.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:croCmoInvolvement rdf:type rdf:Property ;
    rdfs:label 'Cro Cmo Involvement' ;
    rdfs:comment 'Indicates whether a Contract Research Organization (CRO) or Contract Manufacturing Organization (CMO) contributed data or documents to this submission sequence. Relevant for supply chain transparency and regulatory accountability.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecdtLifecycleOperation rdf:type rdf:Property ;
    rdfs:label 'Ecdt Lifecycle Operation' ;
    rdfs:comment 'The eCTD document lifecycle operation applied in this sequence, indicating how the submitted documents relate to prior sequences. Values: new (first submission of a document), replace (supersedes a prior document), append (adds to a prior document), delete (removes a prior document). Aligns with ICH M8 eCTD lifecycle attribute.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecdtVersion rdf:type rdf:Property ;
    rdfs:label 'Ecdt Version' ;
    rdfs:comment 'The version of the Electronic Common Technical Document (eCTD) specification used to structure and validate this submission sequence (e.g., 3.2.2 for legacy, 4.0 for ICH M8 compliant submissions).' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Gateway Tracking Number' ;
    rdfs:comment 'Unique tracking or acknowledgement number assigned by the health authority\'s electronic submission gateway (e.g., FDA ESG acknowledgement number, EMA CESP submission ID) upon receipt of the eCTD package. Used for submission traceability and correspondence.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informationRequestRef rdf:type rdf:Property ;
    rdfs:label 'Information Request Ref' ;
    rdfs:comment 'Reference identifier for the health authority information request, deficiency letter, or complete response letter (CRL) that this submission sequence is responding to. Null if not a response submission.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isResubmission rdf:type rdf:Property ;
    rdfs:label 'Is Resubmission' ;
    rdfs:comment 'Indicates whether this submission sequence is a formal resubmission following a Complete Response Letter (CRL) or refusal, as opposed to an original or routine amendment filing.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageSizeMb rdf:type rdf:Property ;
    rdfs:label 'Package Size Mb' ;
    rdfs:comment 'Total file size of the eCTD submission package in megabytes. Used for submission logistics planning, gateway transmission monitoring, and compliance with health authority file size limits.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdufaGoalDate rdf:type rdf:Property ;
    rdfs:label 'Pdufa Goal Date' ;
    rdfs:comment 'The target action date committed by the FDA under the Prescription Drug User Fee Act (PDUFA) for completing review of this submission. Applicable to NDA/BLA submissions filed with the FDA. Null for non-FDA or non-PDUFA submissions.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryActionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Date' ;
    rdfs:comment 'The date on which the health authority issued a formal regulatory action (approval, complete response letter, refusal, approvable letter) in response to this submission sequence.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryProcedureType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Procedure Type' ;
    rdfs:comment 'The regulatory procedure under which this submission is filed, particularly relevant for EMA submissions. Centralized = EMA centralized procedure; Decentralized = DCP across multiple EU member states; Mutual Recognition = MRP; National = single country national procedure. Null for FDA submissions.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Related Sequence Number' ;
    rdfs:comment 'The eCTD sequence number of a prior submission sequence to which this sequence is directly related (e.g., the original sequence number of a complete response letter being responded to, or the sequence being replaced/amended). Supports submission lineage tracing.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewClockStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Clock Start Date' ;
    rdfs:comment 'The date on which the regulatory review clock officially begins for this submission sequence, as determined by the health authority. May differ from acknowledgement_date for submissions requiring filing review or completeness assessment.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDescription rdf:type rdf:Property ;
    rdfs:label 'Submission Description' ;
    rdfs:comment 'Free-text narrative description of the purpose and content of this submission sequence, summarizing the regulatory objective (e.g., \'Response to FDA Complete Response Letter dated 2024-03-15 addressing CMC deficiencies in Module 3\').' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionUnitCount rdf:type rdf:Property ;
    rdfs:label 'Submission Unit Count' ;
    rdfs:comment 'Number of submission units (eCTD submission unit packages) included in this sequence. In eCTD v4.0, a sequence may contain multiple submission units each addressing different regulatory activities.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplementCategory rdf:type rdf:Property ;
    rdfs:label 'Supplement Category' ;
    rdfs:comment 'Regulatory category of a supplement submission indicating the level of change and required review pathway. PAS = Prior Approval Supplement; CBE-30 = Changes Being Effected in 30 Days; CBE-0 = Changes Being Effected immediately; Class I/II per EMA variation classification. Null for non-supplement submissions.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationId rdf:type rdf:Property ;
    rdfs:label 'Variation Id' ;
    rdfs:comment 'Unique surrogate identifier for the post-approval variation or supplement record in the Databricks Silver Layer.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedCtdSections rdf:type rdf:Property ;
    rdfs:label 'Affected Ctd Sections' ;
    rdfs:comment 'Comma-separated list of eCTD Common Technical Document (CTD) module and section references impacted by this variation (e.g., 3.2.S.2.2, 3.2.P.3.3, 2.7.1). Sourced from Veeva Vault RIM dossier mapping.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockStopDays rdf:type rdf:Property ;
    rdfs:label 'Clock Stop Days' ;
    rdfs:comment 'Total number of days the regulatory review clock was stopped due to requests for supplementary information (List of Questions / List of Outstanding Issues) from the health authority, used for accurate timeline tracking.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Group Reference Number' ;
    rdfs:comment 'Reference identifier linking this variation to a grouped variation package when multiple changes are submitted together under EMA grouping or FDA bundling provisions.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGrouped rdf:type rdf:Property ;
    rdfs:label 'Is Grouped' ;
    rdfs:comment 'Indicates whether this variation is submitted as part of a grouped variation package (multiple changes submitted together in a single application under EMA grouping rules).' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLabelingChange rdf:type rdf:Property ;
    rdfs:label 'Is Labeling Change' ;
    rdfs:comment 'Indicates whether this variation includes a change to the approved product labeling (SmPC, PIL, or US prescribing information), triggering label management workflows.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyDriven rdf:type rdf:Property ;
    rdfs:label 'Is Safety Driven' ;
    rdfs:comment 'Indicates whether this variation was initiated as a result of a pharmacovigilance signal, safety review, or post-market safety commitment, triggering expedited regulatory processing.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:questionsReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Questions Received Date' ;
    rdfs:comment 'Date on which the health authority issued a List of Questions (LoQ) or Request for Information (RFI) during the review of this variation, initiating a clock stop.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:variationNumber rdf:type rdf:Property ;
    rdfs:label 'Variation Number' ;
    rdfs:comment 'Externally-known unique identifier assigned to the variation or supplement by the health authority or internal regulatory tracking system (e.g., EMA variation number, FDA supplement number, or internal RIMS reference).' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationStatus rdf:type rdf:Property ;
    rdfs:label 'Variation Status' ;
    rdfs:comment 'Current lifecycle status of the variation or supplement from initial drafting through health authority decision and implementation. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|refused|withdrawn|implemented — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationType rdf:type rdf:Property ;
    rdfs:label 'Variation Type' ;
    rdfs:comment 'Regulatory classification of the variation or supplement. EMA categories include Type IA (minor, immediate notification), Type IAIN (immediate notification), Type IB (minor, 30-day review), and Type II (major). FDA categories include CBE-0 (Changes Being Effected immediately), CBE-30 (Changes Being Effected in 30 days), and PAS (Prior Approval Supplement). [ENUM-REF-CANDIDATE: Type_IA|Type_IAIN|Type_IB|Type_II|CBE_0|CBE_30|PAS|Minor|Major — promote to reference product]' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'The quantity of IMP or ancillary supply formally approved for fulfilment after clinical supply review. May differ from ordered_quantity due to stock availability, protocol amendments, or QP release constraints.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courierName rdf:type rdf:Property ;
    rdfs:label 'Courier Name' ;
    rdfs:comment 'Name of the third-party logistics (3PL) provider or courier responsible for transporting the clinical supply from the depot to the investigational site. Used for GDP audit trail and shipment tracking.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the investigational site receiving the supply is located. Drives import permit requirements, customs clearance, and cold-chain logistics planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingUnit rdf:type rdf:Property ;
    rdfs:label 'Dispensing Unit' ;
    rdfs:comment 'Description of the dispensing unit configuration for the IMP as packaged for clinical trial use (e.g., \'Blinded kit of 28 tablets\', \'1 vial 10mg/mL\'). Supports site pharmacist dispensing and accountability records.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Export Permit Number' ;
    rdfs:comment 'Reference number of the export permit or authorisation issued by the originating country\'s regulatory authority for the shipment of IMP across international borders for clinical trial purposes.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Import Permit Number' ;
    rdfs:comment 'Reference number of the import permit issued by the relevant national regulatory authority (e.g., FDA, EMA member state, PMDA) authorising the importation of the IMP into the destination country for clinical trial use.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indCtaNumber rdf:type rdf:Property ;
    rdfs:label 'Ind Cta Number' ;
    rdfs:comment 'The regulatory filing reference number (IND number in the US per 21 CFR Part 312, or CTA number in the EU per Regulation 536/2014) under which this clinical supply order is authorised. Required for import/export permit applications and regulatory compliance.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtSystemReference rdf:type rdf:Property ;
    rdfs:label 'Irt System Reference' ;
    rdfs:comment 'Reference number or transaction ID from the Interactive Response Technology (IRT) / Interactive Web Response System (IWRS) that triggered or confirmed this supply order. Links the supply event to the randomization and drug management system.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The calendar date on which the clinical supply order was formally placed or submitted by the clinical supply team. This is the principal business event date for the order.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qpReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Qp Release Date' ;
    rdfs:comment 'The date on which the Qualified Person (QP) formally certified and released the IMP batch for clinical use. Required for EU GMP Annex 13 compliance and batch disposition records.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifiedPersonRelease rdf:type rdf:Property ;
    rdfs:label 'Qualified Person Release' ;
    rdfs:comment 'Indicates whether the IMP batch included in this order has been certified and released by a Qualified Person (QP) as required by EU GMP Annex 13 and Directive 2001/20/EC before dispatch to the clinical site.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'The unit of measure in which the ordered quantity is expressed, aligned with the IMP material master in SAP MM. Ensures unambiguous interpretation of quantity across manufacturing, QC, and site dispensing. [ENUM-REF-CANDIDATE: Vial|Tablet|Capsule|Kit|Syringe|Ampoule|Bottle|Sachet|Patch|Unit — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationKitNumber rdf:type rdf:Property ;
    rdfs:label 'Randomization Kit Number' ;
    rdfs:comment 'The unique kit number assigned by the Interactive Response Technology (IRT) or randomization system to the blinded supply kit. Links the physical supply to the randomization schedule and subject assignment. Critical for blinded trial integrity.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'The actual quantity of IMP or ancillary supply physically dispatched from the manufacturing site or depot. May differ from approved_quantity due to last-minute stock adjustments or partial shipments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyDepotCode rdf:type rdf:Property ;
    rdfs:label 'Supply Depot Code' ;
    rdfs:comment 'Code identifying the clinical supply depot, distribution centre, or CMO/CDMO warehouse from which this order is fulfilled. Used for inventory allocation, GDP compliance, and 3PL coordination.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRecordId rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Record Id' ;
    rdfs:comment 'Unique identifier for the cold chain monitoring record. Primary key for the cold_chain_record product.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsiblePersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Temperature excursions require documented responsible person for GDP compliance, disposition decisions, and regulatory reporting. New attribute needed; removes denormalized responsible_person text fie' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaReference rdf:type rdf:Property ;
    rdfs:label 'Capa Reference' ;
    rdfs:comment 'The reference number of the CAPA investigation initiated in response to the temperature excursion, if applicable.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationReference rdf:type rdf:Property ;
    rdfs:label 'Deviation Reference' ;
    rdfs:comment 'The reference number of the quality deviation or non-conformance record associated with the temperature excursion event.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision Date' ;
    rdfs:comment 'The date when the quality disposition decision was made following excursion investigation and impact assessment.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:excursionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Excursion Duration Minutes' ;
    rdfs:comment 'The total duration in minutes that the temperature or humidity remained outside the acceptable range during the excursion event.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Excursion End Timestamp' ;
    rdfs:comment 'The date and time when the temperature or humidity returned to within the acceptable range, marking the end of the excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excursionFlag rdf:type rdf:Property ;
    rdfs:label 'Excursion Flag' ;
    rdfs:comment 'Boolean indicator whether this reading represents a temperature or humidity excursion outside the acceptable range. True indicates an excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excursionSeverity rdf:type rdf:Property ;
    rdfs:label 'Excursion Severity' ;
    rdfs:comment 'The severity classification of the temperature excursion based on the magnitude and duration of the deviation from acceptable range.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Excursion Start Timestamp' ;
    rdfs:comment 'The date and time when the temperature or humidity first exceeded the acceptable threshold, marking the beginning of the excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gdp Compliance Status' ;
    rdfs:comment 'The assessment of whether the cold chain monitoring and handling met GDP requirements and regulatory standards.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityReadingPct rdf:type rdf:Property ;
    rdfs:label 'Humidity Reading Pct' ;
    rdfs:comment 'The relative humidity percentage recorded by the monitoring device, if humidity monitoring is required for the product.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'The category of location where the temperature monitoring occurred, indicating the supply chain segment.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Device Code' ;
    rdfs:comment 'Unique identifier of the temperature monitoring device or data logger used to capture the reading. Required for device calibration traceability.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringEventCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Event Code' ;
    rdfs:comment 'Business identifier for the temperature monitoring event or data collection session. Used for traceability and audit purposes.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'The precise date and time when the temperature or humidity reading was captured by the monitoring device. Critical for excursion analysis.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Boolean indicator whether the temperature excursion event requires reporting to regulatory authorities such as FDA, EMA, or other health agencies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageConditionRequired rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Required' ;
    rdfs:comment 'The required storage condition classification for the pharmaceutical product as defined in the product specification and regulatory approval.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'The specific storage zone, room, or area within the facility where the product was located during monitoring.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainSegment rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Segment' ;
    rdfs:comment 'The segment of the pharmaceutical supply chain where the temperature monitoring occurred, enabling segment-specific analysis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxThresholdC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Threshold C' ;
    rdfs:comment 'The maximum acceptable temperature in degrees Celsius for the product storage condition. Readings above this trigger an excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinThresholdC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Threshold C' ;
    rdfs:comment 'The minimum acceptable temperature in degrees Celsius for the product storage condition. Readings below this trigger an excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureReadingC rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading C' ;
    rdfs:comment 'The actual temperature measurement in degrees Celsius recorded by the monitoring device at the reading timestamp.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialContractAccountId rdf:type rdf:Property ;
    rdfs:label 'Commercial Contract Account Id' ;
    rdfs:comment 'Foreign key linking to commercial.contract_account. Business justification: Supply delivery orders should link to commercial contract accounts for customer shipments and order fulfillment. This enables integrated order-to-cash process and customer account management across co' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAccount .

ind:pickerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Picker Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Warehouse picking operations require documented personnel for FEFO compliance, lot traceability, and inventory accuracy accountability. New attribute needed for operational quality control.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Reference to the commercial sales order or stock transfer order that triggered this delivery. Links the delivery to the originating demand document in SAP SD.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:actualGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Actual Goods Issue Date' ;
    rdfs:comment 'The actual date on which goods issue was posted in SAP, representing the physical departure of pharmaceutical goods from the warehouse. Critical for lot traceability and GDP compliance.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalSupplyFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Supply Flag' ;
    rdfs:comment 'Indicates whether this delivery is for clinical trial investigational product (IP) supply rather than commercial distribution. Clinical supply deliveries require additional chain-of-custody and IND compliance documentation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Externally-known SAP outbound delivery document number (e.g., 80XXXXXXXX) generated by SAP SD VL01N. Used as the primary business reference across warehouse, logistics, and customer-facing communications.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPriority rdf:type rdf:Property ;
    rdfs:label 'Delivery Priority' ;
    rdfs:comment 'Priority classification for warehouse and logistics execution of this delivery. Emergency and clinical priorities trigger expedited picking, packing, and carrier assignment for patient safety or clinical trial continuity.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivery Quantity' ;
    rdfs:comment 'Quantity of pharmaceutical product to be delivered as specified in the delivery order. Expressed in the base unit of measure (e.g., EA for each, BT for bottle, VL for vial).' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the delivery order reflecting warehouse execution progress. Progresses from created through picking, packing, and goods issue posting. [ENUM-REF-CANDIDATE: created|picking_in_progress|picked|packing_in_progress|packed|goods_issue_posted|cancelled — promote to reference product]' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery document indicating the nature of the movement: outbound (commercial sale), returns (reverse logistics), stock_transfer (inter-site or inter-DC), clinical_supply (investigational product for clinical trials), or sample (promotional/medical samples). Aligns with SAP delivery type (LF, LR, NL, etc.).' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoCompliant rdf:type rdf:Property ;
    rdfs:label 'Fefo Compliant' ;
    rdfs:comment 'Indicates whether the batch/lot selected for this delivery complies with FEFO (First Expiry First Out) inventory rotation policy, ensuring the earliest-expiring stock is shipped first. Mandatory for pharmaceutical GDP compliance.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsIssueQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Quantity' ;
    rdfs:comment 'Actual quantity for which goods issue has been posted in SAP, representing the confirmed shipped quantity. Used for inventory reconciliation and revenue recognition.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Status' ;
    rdfs:comment 'Status of the SAP goods issue (GI) posting for this delivery, which triggers inventory reduction and revenue recognition. Fully posted indicates stock has been legally transferred to the customer.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Timestamp' ;
    rdfs:comment 'Precise date and time when goods issue was posted in SAP SD, capturing the exact moment of inventory transfer. Required for cold-chain time-in-transit calculations and GDP audit trails.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the delivery in kilograms, including product, primary packaging, secondary packaging, and pallet. Required for freight booking, dangerous goods documentation, and carrier compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingUnitCount rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Count' ;
    rdfs:comment 'Number of handling units (pallets, cartons, shipper boxes) packed for this delivery. Used for freight cost calculation, carrier booking, and GDP packing documentation.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packingStatus rdf:type rdf:Property ;
    rdfs:label 'Packing Status' ;
    rdfs:comment 'Packing execution status indicating whether the picked pharmaceutical goods have been packed into shipping units (cartons, pallets, shipper boxes) for this delivery.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'Actual quantity of pharmaceutical product physically picked from warehouse storage bins. May differ from delivery quantity in cases of partial picks or stock discrepancies.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickingStatus rdf:type rdf:Property ;
    rdfs:label 'Picking Status' ;
    rdfs:comment 'Warehouse picking execution status indicating whether stock has been physically selected from storage bins for this delivery. Corresponds to SAP WM transfer order status.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'The scheduled date on which the pharmaceutical goods are planned to be delivered to the ship-to party. Used for supply chain planning and customer service level monitoring.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'SAP shipment document number (VT01N) associated with this delivery, representing the physical transport leg after goods issue. A single shipment may consolidate multiple delivery orders. Distinct from the delivery order which is the warehouse execution instruction.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume M3' ;
    rdfs:comment 'Total volume of the delivery in cubic metres. Used for freight capacity planning, cold-chain container sizing, and carrier booking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Planning Department Id' ;
    rdfs:comment 'Foreign key linking to workforce.department. Business justification: Demand planning is organized by therapeutic area departments for resource allocation, budget tracking, and capacity planning. New attribute needed for organizational hierarchy reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:adjustedForecastQty rdf:type rdf:Property ;
    rdfs:label 'Adjusted Forecast Qty' ;
    rdfs:comment 'Demand quantity after commercial, medical affairs, or supply chain planner adjustments to the statistical baseline. Reflects market intelligence, launch events, tender wins, or clinical trial enrollment changes applied on top of the baseline.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineForecastQty rdf:type rdf:Property ;
    rdfs:label 'Baseline Forecast Qty' ;
    rdfs:comment 'Statistically generated baseline demand quantity for the SKU in the forecast period, produced by the statistical forecasting engine (Kinaxis/Blue Yonder) using historical sales, shipment, or consumption data without manual override.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consensus Approved Timestamp' ;
    rdfs:comment 'Date and time when the demand plan was formally approved through the S&OP consensus process. Marks the transition to frozen/authoritative demand signal for supply execution. Compliant with 21 CFR Part 11 electronic record requirements.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consensusForecastQty rdf:type rdf:Property ;
    rdfs:label 'Consensus Forecast Qty' ;
    rdfs:comment 'Final consensus-approved demand quantity agreed upon during the S&OP/IBP consensus meeting, representing the authoritative demand signal used for supply planning and inventory positioning. Populated only after plan_status reaches consensus_approved.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandClassification rdf:type rdf:Property ;
    rdfs:label 'Demand Classification' ;
    rdfs:comment 'Classification of the demand signal by supply chain purpose: commercial (market sales), clinical (investigational product for trials), compassionate use (expanded access programs), sample (promotional/medical samples), or launch (pre-launch inventory build). Drives planning rules and inventory segmentation.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSignalSource rdf:type rdf:Property ;
    rdfs:label 'Demand Signal Source' ;
    rdfs:comment 'Origin of the primary demand signal used to generate or adjust this forecast (e.g., Kinaxis RapidResponse statistical engine, Blue Yonder, SAP APO, manual planner input, CRM pipeline, market research, or tender/contract data). [ENUM-REF-CANDIDATE: kinaxis|blue_yonder|sap_apo|manual|crm|market_research|tender — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Pct' ;
    rdfs:comment 'Measured forecast accuracy for the prior equivalent period, expressed as a percentage (0–100). Calculated as 1 minus the Mean Absolute Percentage Error (MAPE) for the SKU-period. Used to assess planning reliability and trigger model recalibration.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastBias rdf:type rdf:Property ;
    rdfs:label 'Forecast Bias' ;
    rdfs:comment 'Systematic directional error in the forecast for the prior equivalent period, measured as actual minus forecast quantity. Positive bias indicates under-forecasting; negative bias indicates over-forecasting. Used for continuous improvement of demand planning accuracy.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastGranularity rdf:type rdf:Property ;
    rdfs:label 'Forecast Granularity' ;
    rdfs:comment 'The time granularity at which the demand forecast quantities are expressed (weekly, monthly, or quarterly buckets). Determines how forecast_period_date is interpreted.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Date' ;
    rdfs:comment 'The specific time bucket (month, week, or quarter start date) to which the demand quantities in this record apply. Each row represents one SKU-period combination within the planning horizon.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizeQty rdf:type rdf:Property ;
    rdfs:label 'Lot Size Qty' ;
    rdfs:comment 'Standard manufacturing lot or batch size quantity for the SKU, used to convert demand quantities into production orders and assess capacity requirements. Expressed in the same UOM as forecast quantities.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the adjusted forecast deviates from the statistical baseline (e.g., new tender win, product launch, competitor entry, clinical trial enrollment change, market withdrawal). Required when adjusted_forecast_qty differs from baseline_forecast_qty. [ENUM-REF-CANDIDATE: tender_win|product_launch|competitor_entry|clinical_enrollment|market_withdrawal|promotional_event|regulatory_change — promote to reference product]' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Created Timestamp' ;
    rdfs:comment 'Timestamp when this demand plan record was first created in the system, providing the audit trail start point for the planning record lifecycle.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this demand plan record, supporting audit trail requirements and change management tracking per 21 CFR Part 11 and ICH Q10.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known business identifier for the demand plan, used for cross-system reference in Kinaxis RapidResponse, Blue Yonder, and SAP S/4HANA. Follows the enterprise demand plan numbering convention.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the demand plan, enabling tracking of iterative revisions within a planning cycle (e.g., v1.0, v2.1). Supports version-controlled consensus planning workflows.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text notes entered by the demand planner documenting assumptions, market intelligence, adjustment rationale, or risk factors influencing the forecast. Supports S&OP review and audit trail documentation.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'The cadence of the demand planning cycle in which this plan was generated (e.g., monthly S&OP cycle, quarterly business review, weekly rolling horizon). Determines the review and approval schedule.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'The last date of the demand planning horizon covered by this plan. Defines the end of the forecast period, typically 12–24 months for pharmaceutical commercial planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'The first date of the demand planning horizon covered by this plan. Defines the start of the forecast period for supply planning and inventory positioning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Inventory level at which a replenishment order should be triggered for this SKU, calculated from lead time demand plus safety stock. Used in SAP S/4HANA MRP and Kinaxis supply planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Minimum buffer inventory quantity maintained to protect against demand variability and supply disruptions for this SKU in the planning period. Expressed in the same UOM as forecast quantities. Sourced from SAP S/4HANA MM or Kinaxis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalModelType rdf:type rdf:Property ;
    rdfs:label 'Statistical Model Type' ;
    rdfs:comment 'The statistical forecasting algorithm applied to generate the baseline forecast (e.g., exponential smoothing, ARIMA, Croston, moving average, machine learning ensemble). Sourced from Kinaxis RapidResponse or Blue Yonder model configuration. [ENUM-REF-CANDIDATE: exponential_smoothing|arima|croston|moving_average|holt_winters|ml_ensemble — promote to reference product]' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainTier rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Tier' ;
    rdfs:comment 'Identifies the supply chain tier to which this demand plan applies: Drug Substance (DS/API), Drug Product (DP/FDF), Finished Goods (packaged product), or Packaging Components. Enables multi-tier demand disaggregation from finished goods back to API and raw materials.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Unit of measure in which demand quantities (baseline, adjusted, consensus) are expressed. Common pharmaceutical UOMs include EA (each), CS (case), BT (bottle), VL (vial), KG (kilogram), L (litre), TAB (tablet), CAP (capsule). Aligns with SAP S/4HANA UOM configuration. [ENUM-REF-CANDIDATE: EA|CS|BT|VL|KG|L|TAB|CAP|VIAL|SYRINGE — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Site Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Distribution nodes require named site managers for GDP accountability, regulatory inspections, and operational escalations. New attribute needed; removes denormalized operator_name text field.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:address rdf:type rdf:Property ;
    rdfs:label 'Address' ;
    rdfs:comment 'Full physical street address of the distribution network node. Required for GDP authorization documentation, carrier routing, and regulatory inspection records.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalSupplyCapable rdf:type rdf:Property ;
    rdfs:label 'Clinical Supply Capable' ;
    rdfs:comment 'Indicates whether the node is qualified and authorized to handle clinical trial investigational medicinal products (IMPs) in addition to commercial supply. Clinical supply nodes must comply with GCP and GMP requirements.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainCertified rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Certified' ;
    rdfs:comment 'Indicates whether the node holds a valid cold chain certification from a recognized body (e.g., IATA CEIV Pharma, GDP cold chain qualification). Required for handling temperature-sensitive biologics, vaccines, and specialty medicines.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlledSubstanceAuthorized rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Authorized' ;
    rdfs:comment 'Indicates whether the node is authorized by the DEA (or equivalent national authority) to store and distribute controlled substances. Nodes without this authorization cannot be assigned to controlled substance distribution lanes.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdpAuthorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gdp Authorization Expiry Date' ;
    rdfs:comment 'Date on which the GDP wholesale distribution authorization expires. Supply planning systems must alert when expiry is approaching to prevent distribution through unauthorized nodes.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdpAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Gdp Authorization Number' ;
    rdfs:comment 'Official GDP wholesale distribution authorization number issued by the competent regulatory authority (e.g., MHRA, national competent authority). Required for regulatory traceability and audit purposes.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Gdp Authorization Status' ;
    rdfs:comment 'Current GDP authorization status of the node as required by EU GDP Guidelines (2013/C 343/01) and equivalent national regulations. Authorized nodes are eligible to handle medicinal products. Expired or suspended nodes must be excluded from active distribution lanes.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Handling Time Days' ;
    rdfs:comment 'Number of calendar days required for internal processing activities at the node (receiving, quality inspection, pick/pack, dispatch preparation). Added to lead times in supply planning calculations.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatCapable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Capable' ;
    rdfs:comment 'Indicates whether the node is certified to store and handle hazardous materials including cytotoxic compounds, flammable solvents, and other regulated substances. Relevant for oncology API and certain excipient handling.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inboundLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Inbound Lead Time Days' ;
    rdfs:comment 'Standard number of calendar days required for inbound shipments to arrive at this node from its upstream supply source. Used as a planning parameter in Kinaxis RapidResponse and SAP APO/IBP for replenishment scheduling.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiTemperatureCapable rdf:type rdf:Property ;
    rdfs:label 'Multi Temperature Capable' ;
    rdfs:comment 'Indicates whether the node can simultaneously handle multiple temperature zones (e.g., both ambient and refrigerated storage). Enables assignment of mixed-temperature product portfolios to a single node in supply network planning.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkTier rdf:type rdf:Property ;
    rdfs:label 'Network Tier' ;
    rdfs:comment 'Hierarchical tier classification of the node within the distribution network topology. Tier 1 = primary manufacturing/central DC; Tier 2 = regional DC; Tier 3 = local/last-mile node. Drives network optimization and replenishment hierarchy in supply planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this distribution network node across supply chain planning systems (Kinaxis RapidResponse, Blue Yonder, SAP APO/IBP). Used as the business key for cross-system integration and network lane definitions.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name of the distribution network node (e.g., \'Frankfurt Regional DC\', \'Chicago 3PL Hub\', \'Singapore Manufacturing Site\'). Used in supply chain planning dashboards and network topology reports.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of the distribution network node. Inactive or suspended nodes are excluded from supply planning runs. Nodes under qualification are pending GDP or regulatory authorization review.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the network node by its functional role in the pharmaceutical supply chain. Drives planning logic, GDP compliance requirements, and lane eligibility in Kinaxis RapidResponse and SAP APO/IBP. [ENUM-REF-CANDIDATE: manufacturing_site|distribution_center|3pl_node|wholesaler|direct_to_pharmacy|clinical_depot|hospital_pharmacy|specialty_pharmacy — promote to reference product]' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorType rdf:type rdf:Property ;
    rdfs:label 'Operator Type' ;
    rdfs:comment 'Classification of the entity operating the distribution node. Distinguishes between internally operated sites and third-party operators such as 3PL (Third-Party Logistics), CMO (Contract Manufacturing Organization), CDMO (Contract Development and Manufacturing Organization), or wholesalers.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Outbound Lead Time Days' ;
    rdfs:comment 'Standard number of calendar days required for outbound shipments to depart this node and reach the next downstream node or customer. Used for delivery commitment and supply planning in Kinaxis RapidResponse.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:palletCapacity rdf:type rdf:Property ;
    rdfs:label 'Pallet Capacity' ;
    rdfs:comment 'Maximum number of standard pallets (EUR/ISO pallet) the node can accommodate simultaneously. Used for operational capacity planning and inbound/outbound throughput modeling in supply network planning tools.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quarantineZoneAvailable rdf:type rdf:Property ;
    rdfs:label 'Quarantine Zone Available' ;
    rdfs:comment 'Indicates whether the node has a dedicated physical quarantine zone for holding materials pending quality release, investigation, or returns processing. Required for GDP-compliant nodes handling pharmaceutical products.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapStorageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Sap Storage Location Code' ;
    rdfs:comment 'SAP storage location code within the plant, representing the primary storage location for this node in SAP S/4HANA WM. Used for inventory posting, goods receipt, and goods issue transactions.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity M3' ;
    rdfs:comment 'Total physical storage capacity of the node measured in cubic meters. Used for capacity planning, network optimization, and inventory allocation decisions in Kinaxis RapidResponse and SAP WM.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Primary temperature storage zone capability of the node. Defines the cold-chain handling classification: ambient (15–25°C), CRT (Controlled Room Temperature, 15–30°C), refrigerated (2–8°C), frozen (-20°C), or ultra-low temperature (-80°C). Critical for product-to-node assignment in supply planning.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseZoneCount rdf:type rdf:Property ;
    rdfs:label 'Warehouse Zone Count' ;
    rdfs:comment 'Number of distinct storage zones configured within the node (e.g., quarantine zone, approved stock zone, returns zone, controlled substance vault). Reflects the physical warehouse layout complexity in SAP WM.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentEventId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Event Id' ;
    rdfs:comment 'Primary key for fulfillment_event' ;
    rdfs:domain ind:FulfillmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reported By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Supply chain excursions require documented reporter for CAPA assignment, deviation management, and regulatory reportability assessment. New attribute needed; removes denormalized reported_by text fiel' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity' ;
    rdfs:comment 'The quantity of pharmaceutical material directly affected by this supply chain event (e.g., quantity of product in a temperature-excursed shipment, quantity subject to a supply disruption, quantity reallocated in an allocation change event).' ;
    rdfs:domain ind:FulfillmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Event Location Description' ;
    rdfs:comment 'Human-readable description of the location where the event occurred, including site name, warehouse zone, or transit leg description. Complements the location ID for operational reporting and GDP deviation documentation.' ;
    rdfs:domain ind:FulfillmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'The operational system of record that originated or captured this supply chain event. Enables data lineage tracing and source system reconciliation across SAP S/4HANA, Kinaxis RapidResponse, Blue Yonder, IoT monitoring devices, courier portals, LIMS, and MES platforms. [ENUM-REF-CANDIDATE: SAP_S4HANA|Kinaxis_RapidResponse|Blue_Yonder|manual_entry|IoT_sensor|courier_portal|LIMS|MES — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSubtype rdf:type rdf:Property ;
    rdfs:label 'Event Subtype' ;
    rdfs:comment 'Granular classification within the event type. Examples: for shipment_milestone — departed, in_transit, arrived, delivered, customs_hold; for temperature_excursion — cold_chain_breach, freeze_event, heat_event; for gdp_deviation — documentation_gap, unauthorized_access, pest_control, vehicle_hygiene. [ENUM-REF-CANDIDATE: departed|in_transit|arrived|delivered|customs_hold|cold_chain_breach|freeze_event|heat_event|documentation_gap|unauthorized_access|pest_control|vehicle_hygiene — promote to reference product]' ;
    rdfs:domain ind:FulfillmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time at which the supply chain event occurred in the real world (e.g., when a shipment departed, when a temperature excursion was detected, when a GDP deviation was identified). Distinct from record audit timestamps. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdpGuidelineReference rdf:type rdf:Property ;
    rdfs:label 'Gdp Guideline Reference' ;
    rdfs:comment 'The specific GDP guideline clause or section number that is relevant to this event or deviation. Examples: EU GDP 2013/C 343/01 Chapter 6.3 (Temperature Control), WHO GDP TRS 957 Annex 5 Section 8. Supports regulatory inspection readiness and deviation documentation.' ;
    rdfs:domain ind:FulfillmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productQuarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Product Quarantine Flag' ;
    rdfs:comment 'Indicates whether the affected pharmaceutical material has been placed in quarantine status as a result of this event. When True, the material is blocked from further distribution pending quality investigation and disposition decision.' ;
    rdfs:domain ind:FulfillmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Free-text description of the actions taken to resolve this supply chain event, including corrective measures, product disposition decisions, and process improvements implemented. Populated when event_status transitions to resolved or closed.' ;
    rdfs:domain ind:FulfillmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'The date and time at which the supply chain event was formally resolved and closed in the QMS or supply chain system. Used to calculate event resolution cycle time for GDP KPI reporting.' ;
    rdfs:domain ind:FulfillmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'The Stock Keeping Unit code identifying the specific commercial or clinical product variant affected by this event, including pack size and configuration. Used for inventory management and commercial distribution tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'The native identifier of this event in the originating source system (e.g., SAP delivery document number, Kinaxis event ID, IoT platform alert ID). Supports cross-system traceability and deduplication during ETL processing.' ;
    rdfs:domain ind:FulfillmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalTrialNumber rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Number' ;
    rdfs:comment 'The clinical trial protocol number (IND/CTA reference) associated with the goods issue when material is issued as investigational product (IP) for clinical trial supply. Links the material consumption to the specific clinical study for GCP compliance, IND/CTA regulatory reporting, and clinical supply chain reconciliation. Populated only for clinical supply goods issues.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Destruction Certificate Number' ;
    rdfs:comment 'The certificate of destruction document number issued by a licensed waste disposal or pharmaceutical destruction contractor when materials are scrapped or destroyed (movement type 551/552). Required for GMP compliance, DEA controlled substance destruction reporting, and environmental regulatory compliance. Populated only for destruction goods issues.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gi Document Number' ;
    rdfs:comment 'The externally-known SAP material document number assigned to the goods issue posting (e.g., 4900012345). This is the primary business identifier referenced in GMP batch records, cost accounting entries, and supply chain traceability. Corresponds to MBLNR in SAP MSEG/MKPF tables.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Gi Document Year' ;
    rdfs:comment 'The fiscal year in which the goods issue material document was posted in SAP (MJAHR). Required in combination with gi_document_number to uniquely identify a material document in SAP MM.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:giStatus rdf:type rdf:Property ;
    rdfs:label 'Gi Status' ;
    rdfs:comment 'Current lifecycle status of the goods issue document. \'posted\' indicates the GI is active and inventory has been reduced; \'reversed\' indicates a reversal document has been posted (movement type 262/552/602); \'blocked\' indicates the document is on quality hold; \'cancelled\' indicates the document was voided prior to posting.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlledSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Substance' ;
    rdfs:comment 'Indicates whether the issued material is a DEA-scheduled controlled substance requiring additional regulatory documentation, DEA Form 222 or CSOS electronic ordering, and controlled substance inventory reconciliation. When True, the goods issue must comply with DEA 21 CFR Part 1304 record-keeping requirements.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGmpRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Relevant' ;
    rdfs:comment 'Indicates whether this goods issue is subject to Good Manufacturing Practice (GMP) documentation and traceability requirements. True for materials used in GMP-regulated manufacturing, clinical trial supply, or quality testing. False for non-GMP materials such as office supplies, maintenance items, or non-regulated consumables. Drives GMP batch record inclusion and regulatory audit scope.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedQuantity rdf:type rdf:Property ;
    rdfs:label 'Issued Quantity' ;
    rdfs:comment 'The quantity of material issued in the base unit of measure (ERFMG in SAP MSEG). Represents the actual amount consumed, shipped, scrapped, or transferred. Drives inventory reduction, cost accounting entries, and GMP batch record material consumption documentation. Must reconcile with production order component requirements or delivery quantities.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Issuing Storage Location' ;
    rdfs:comment 'The SAP storage location (LGORT) from which the material is physically withdrawn. Identifies the specific warehouse area, cold-chain storage zone, quarantine area, or dispensing room within the plant. Critical for GMP material flow documentation, cold-chain compliance, and GDP storage condition traceability.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Movement Type Description' ;
    rdfs:comment 'Human-readable description of the SAP movement type (e.g., \'Goods Issue to Production Order\', \'Goods Issue for Delivery\', \'Scrapping\', \'Sample Withdrawal\', \'Transfer Posting\'). Supports business reporting and GMP batch record documentation without requiring SAP configuration knowledge.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Order Reference Number' ;
    rdfs:comment 'The reference number of the consuming or receiving order associated with the goods issue. For production consumption (movement type 261), this is the SAP production order number (AUFNR). For clinical supply, this is the clinical trial supply order number. For customer delivery, this is the SAP sales order number (VBELN). Central to GMP batch record traceability and cost allocation.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'The SAP reason code (GRUND) providing additional classification for the goods issue movement, particularly for scrapping, destruction, or non-standard consumption. Examples include: expired material destruction, quality rejection scrap, clinical trial sample, regulatory submission sample, stability testing sample. Supports GMP deviation tracking and regulatory reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location' ;
    rdfs:comment 'For intra-plant transfer postings (movement type 311), the destination storage location within the same plant. Tracks material movement between warehouse zones, e.g., from quarantine to released stock, from bulk storage to dispensing area, or from cold-chain to ambient staging.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'SAP special stock indicator (SOBKZ) identifying whether the issued material belongs to a special stock category. Key values: E=Sales order stock (customer-specific), Q=Project stock, K=Consignment stock at customer, W=Vendor consignment stock. Empty value indicates standard own stock. Critical for clinical trial supply (project stock) and consignment management.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'The inventory valuation method applied to the goods issue for cost accounting purposes (BWTAR in SAP). Determines how the material consumption cost is calculated: standard cost (standard price from material master), moving average price (MAP), or actual cost. Impacts COGS calculation and financial reporting accuracy.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionAuthorityPositionId rdf:type rdf:Property ;
    rdfs:label 'Disposition Authority Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Lot disposition decisions require documented QA release authority position for GMP compliance and regulatory inspection readiness. Position-based rather than individual for role continuity.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:coldChainBreakDate rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Break Date' ;
    rdfs:comment 'Date on which a cold chain break or temperature excursion was first detected for this lot. Populated only when temperature_excursion_flag is True. Used to initiate quality impact assessment and determine lot disposition.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysUntilExpiry rdf:type rdf:Property ;
    rdfs:label 'Days Until Expiry' ;
    rdfs:comment 'Number of days remaining until the lot\'s expiry date, calculated at the time of data extraction. Used for near-expiry inventory alerts, FEFO prioritization, and supply chain risk management. Negative values indicate expired lots.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isClinicalSupply rdf:type rdf:Property ;
    rdfs:label 'Is Clinical Supply' ;
    rdfs:comment 'Flag indicating whether this lot is designated for use in clinical trials (investigational product supply) rather than commercial distribution. Clinical supply lots are subject to additional regulatory controls under GCP and IND/CTA requirements.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGdpCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Gdp Compliant' ;
    rdfs:comment 'Flag indicating whether this lot\'s storage and handling at the current location is confirmed compliant with Good Distribution Practice (GDP) requirements, including temperature monitoring, security, and documentation standards.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date of the most recent inventory movement (goods receipt, goods issue, transfer posting, or stock transfer) recorded for this lot in SAP. Used for slow-moving inventory analysis and supply chain performance monitoring.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current quality and disposition status of the lot in the inventory management system. Drives whether the lot is available for use, shipment, or must be held pending quality review. Maps to SAP batch status (unrestricted-use, quality inspection, blocked). [ENUM-REF-CANDIDATE: unrestricted|quality_hold|quarantine|rejected|released|destroyed — promote to reference product]' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Net quantity of the lot available for new allocations, calculated as quantity_on_hand minus quantity_reserved minus quantity_on_quality_hold. Represents the actionable inventory for supply planning and order fulfillment.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnQualityHold rdf:type rdf:Property ;
    rdfs:label 'Quantity On Quality Hold' ;
    rdfs:comment 'Quantity of the lot currently blocked due to quality inspection, Out-of-Specification (OOS) investigation, or quality hold pending Corrective and Preventive Action (CAPA) resolution. Not available for use or shipment.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity of the lot that has been reserved for specific production orders, sales orders, or clinical trial supply requests but not yet physically consumed or shipped. Reduces available quantity for new allocations.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineReason rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason' ;
    rdfs:comment 'Free-text description of the reason this lot has been placed in quarantine or quality hold status. Documents the triggering event (e.g., OOS result, customer complaint, supplier deviation, temperature excursion) for CAPA and regulatory traceability.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'Original lot or batch number assigned by the external supplier, Contract Manufacturing Organization (CMO), or Contract Development and Manufacturing Organization (CDMO). Enables traceability back to the supplier\'s manufacturing records and Certificate of Analysis (CoA).' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard or moving average cost per unit of measure for this lot as recorded in SAP. Used for inventory valuation, COGS calculation, and financial reporting. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotTraceabilityId rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Id' ;
    rdfs:comment 'Unique surrogate identifier for each lot/batch traceability linkage record in the pharmaceutical supply chain. Primary key for this entity.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Manufacturing transformations require documented operator for batch record traceability, GMP compliance, and deviation investigation. New attribute needed for regulatory audit trail.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentInventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Parent Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: lot_traceability tracks parent-child lot genealogy. The parent_lot_number (STRING) should be replaced with parent_inventory_lot_id FK to inventory_lot.inventory_lot_id. This enables proper referential' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:childLotNumber rdf:type rdf:Property ;
    rdfs:label 'Child Lot Number' ;
    rdfs:comment 'The lot or batch number of the output/produced material resulting from the transformation step. Represents the downstream node in the traceability chain (e.g., drug product lot, finished goods lot). Aligns with SAP MM batch number of the output material.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Reference Number' ;
    rdfs:comment 'Reference number of any GMP deviation, OOS (Out of Specification), or OOT (Out of Trend) investigation associated with this lot or transformation step. Links to the Quality Management System (MasterControl/TrackWise) for CAPA tracking.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gdp Compliance Flag' ;
    rdfs:comment 'Indicates whether the transformation and handling of this lot was performed in compliance with Good Distribution Practice (GDP) guidelines. FALSE triggers a quality investigation. Required for EU distribution authorization and WHO prequalification.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Process Order Number' ;
    rdfs:comment 'SAP PP process order number or manufacturing work order number that authorized and tracked the transformation operation. Provides the operational link between the traceability record and the ERP production execution.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qpReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Qp Release Status' ;
    rdfs:comment 'The Qualified Person (QP) or Authorized Person (AP) release status of the child lot. \'released\' indicates the lot has been certified by a QP for distribution per EU GMP Annex 16. \'rejected\' indicates the lot failed QP review. Required for EU market distribution and clinical supply.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityIn rdf:type rdf:Property ;
    rdfs:label 'Quantity In' ;
    rdfs:comment 'The quantity of the parent lot material consumed or input into the transformation step. Expressed in the unit of measure defined by quantity_uom. Used for yield calculation and GMP batch record reconciliation.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOut rdf:type rdf:Property ;
    rdfs:label 'Quantity Out' ;
    rdfs:comment 'The quantity of the child lot material produced or output from the transformation step. Expressed in the unit of measure defined by quantity_uom. Used for yield calculation and GMP batch record reconciliation.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Boolean flag indicating whether this lot is subject to an active product recall. Set to TRUE when a recall action is initiated by the company or regulatory authority. Enables rapid identification of affected lots across the traceability chain for recall scope determination.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Reference Number' ;
    rdfs:comment 'The regulatory or internal recall reference number associated with this lot when recall_flag is TRUE. Links the traceability record to the formal recall action for scope tracking, regulatory reporting, and pharmacovigilance investigation.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoreticalYield rdf:type rdf:Property ;
    rdfs:label 'Theoretical Yield' ;
    rdfs:comment 'The maximum expected quantity of output material based on the bill of materials and batch formula, expressed in quantity_uom. Used to calculate actual vs. theoretical yield variance for GMP batch record review and OOS/OOT investigations.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:traceabilityChainLevel rdf:type rdf:Property ;
    rdfs:label 'Traceability Chain Level' ;
    rdfs:comment 'Numeric level in the lot genealogy hierarchy, where level 1 represents the raw material/API input and higher levels represent downstream transformation steps (e.g., level 2 = drug substance, level 3 = drug product, level 4 = finished goods). Enables hierarchical traceability chain traversal for recall scope and genealogy reporting.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:traceabilityChainStatus rdf:type rdf:Property ;
    rdfs:label 'Traceability Chain Status' ;
    rdfs:comment 'Current lifecycle status of this traceability linkage record. \'active\' indicates a valid, in-use chain link; \'recalled\' flags lots subject to a market recall; \'under_investigation\' indicates a pharmacovigilance or quality investigation is open; \'invalidated\' marks records superseded by corrections.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Traceability Record Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for this traceability linkage record. Used in regulatory submissions, recall investigations, and GMP batch record cross-references. Typically sourced from SAP MM/WM or MES batch record systems.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationDate rdf:type rdf:Property ;
    rdfs:label 'Transformation Date' ;
    rdfs:comment 'The calendar date on which the manufacturing, packaging, or supply chain transformation operation was performed, converting the parent lot into the child lot. Principal business event date for this traceability record.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transformationType rdf:type rdf:Property ;
    rdfs:label 'Transformation Type' ;
    rdfs:comment 'Classification of the manufacturing or supply chain operation that converted the parent lot into the child lot. Drives traceability chain logic and GMP batch record linkage. [ENUM-REF-CANDIDATE: manufacturing|packaging|repackaging|blending|filling|labelling|sampling|testing|transfer — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPct rdf:type rdf:Property ;
    rdfs:label 'Yield Pct' ;
    rdfs:comment 'The process yield expressed as a percentage, calculated as (quantity_out / quantity_in) × 100. Stored as a business-critical GMP metric for batch record review, deviation investigation, and process performance trending. Out-of-specification yield triggers CAPA.' ;
    rdfs:domain ind:LotTraceability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managingDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Managing Department Id' ;
    rdfs:comment 'Foreign key linking to workforce.department. Business justification: Recalls are managed by quality departments for organizational accountability, resource allocation, and regulatory reporting. New attribute needed for departmental workload tracking.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'The date on which direct customers (wholesalers, distributors, hospitals, pharmacies) were formally notified of the recall via recall notification letters or electronic communications.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Status' ;
    rdfs:comment 'Current status of the customer notification process indicating whether recall notification letters have been sent to all affected customers in the distribution chain.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionLevel rdf:type rdf:Property ;
    rdfs:label 'Distribution Level' ;
    rdfs:comment 'The level in the distribution chain to which the recall extends. Consumer: product reached end patients/consumers; Retail: product at retail pharmacy level; Wholesale: product at wholesale distributor level; Hospital: product at hospital/clinic level; User: product at healthcare professional level.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckLevel rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Level' ;
    rdfs:comment 'FDA-defined effectiveness check level indicating the depth and percentage of consignees to be audited to verify recall notification receipt and product return. Level A: 100% of consignees; Level B: some percentage; Level C: 10% of consignees; Level D: 2% of consignees; Not Required: for certain recall types.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDateRange rdf:type rdf:Property ;
    rdfs:label 'Expiration Date Range' ;
    rdfs:comment 'The expiration date range (e.g., \'2024-01 to 2025-06\') covering all affected lot numbers included in the recall. Assists customers and distributors in identifying recalled product on shelves and in inventory.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthHazardAssessment rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Assessment' ;
    rdfs:comment 'Summary of the health hazard evaluation conducted by the company\'s medical and regulatory teams to assess the risk to patients from the defective product. Supports recall classification and regulatory submission under 21 CFR Part 7.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingAgency rdf:type rdf:Property ;
    rdfs:label 'Initiating Agency' ;
    rdfs:comment 'The regulatory authority or company entity that initiated or mandated the recall. Identifies whether the recall was company-initiated (voluntary) or directed by a specific regulatory body such as FDA, EMA, MHRA, PMDA, or NMPA. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|Company — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Press Release Date' ;
    rdfs:comment 'The date on which the company issued a public press release or public notification regarding the recall. Required for Class I and certain Class II recalls to inform consumers and healthcare professionals.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityDistributed rdf:type rdf:Property ;
    rdfs:label 'Quantity Distributed' ;
    rdfs:comment 'Total quantity of the affected product that was distributed to the market prior to the recall initiation, expressed in the standard unit of measure (e.g., units, bottles, vials). Used to calculate recall effectiveness and track recovery progress.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRecovered rdf:type rdf:Property ;
    rdfs:label 'Quantity Recovered' ;
    rdfs:comment 'Total quantity of the recalled product that has been physically returned, destroyed, or otherwise accounted for as of the last update. Used to calculate recall effectiveness percentage and support regulatory reporting.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallClass rdf:type rdf:Property ;
    rdfs:label 'Recall Class' ;
    rdfs:comment 'FDA-defined classification indicating the severity of the health hazard associated with the recalled product. Class I: serious adverse health consequences or death; Class II: temporary or medically reversible adverse health consequences; Class III: unlikely to cause adverse health consequences.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClosureDate rdf:type rdf:Property ;
    rdfs:label 'Recall Closure Date' ;
    rdfs:comment 'The date on which the recall was formally closed or terminated by the regulatory authority or the company after all recall activities, effectiveness checks, and documentation requirements were completed.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallEffectivenessPct rdf:type rdf:Property ;
    rdfs:label 'Recall Effectiveness Pct' ;
    rdfs:comment 'Percentage of distributed product that has been successfully recovered or accounted for, calculated as (quantity_recovered / quantity_distributed) * 100. Key metric for FDA recall effectiveness checks and regulatory reporting under 21 CFR Part 7.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated Date' ;
    rdfs:comment 'The date on which the recall was formally initiated by the company or ordered by the regulatory authority. Represents the principal business event timestamp for the recall lifecycle.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallNotes rdf:type rdf:Property ;
    rdfs:label 'Recall Notes' ;
    rdfs:comment 'Free-text field for additional operational notes, regulatory correspondence summaries, or contextual information relevant to the recall event that is not captured in structured fields.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'Externally-assigned recall identification number issued by the regulatory authority (e.g., FDA recall number) or internally assigned by the company for voluntary recalls. Serves as the primary business identifier for tracking and referencing the recall event across regulatory submissions and communications.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallReasonCode rdf:type rdf:Property ;
    rdfs:label 'Recall Reason Code' ;
    rdfs:comment 'Standardized code categorizing the root cause or reason for the recall (e.g., contamination, labeling error, sub-potency, sterility failure, foreign particulate). Aligns with FDA recall reason taxonomy for regulatory reporting and trend analysis. [ENUM-REF-CANDIDATE: Contamination|Labeling Error|Sub-Potency|Super-Potency|Sterility Failure|Foreign Particulate|Stability Failure|Packaging Defect|Microbial Contamination|Other — promote to reference product]' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Recall Reason Description' ;
    rdfs:comment 'Detailed narrative description of the specific defect, violation, or safety concern that triggered the recall. Provides the full technical and regulatory context beyond the recall reason code, including root cause findings from CAPA investigations.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScope rdf:type rdf:Property ;
    rdfs:label 'Recall Scope' ;
    rdfs:comment 'Geographic scope of the recall indicating whether the recall covers the entire national market, specific regions, international markets, or is limited to a specific manufacturing or distribution site.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Status' ;
    rdfs:comment 'Current lifecycle status of the recall event. Pending: recall initiated but not yet active; Active: recall in progress with field corrections underway; Monitoring: recall effectiveness checks ongoing; Terminated: FDA has terminated the recall; Closed: all recall activities completed and documented.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStrategy rdf:type rdf:Property ;
    rdfs:label 'Recall Strategy' ;
    rdfs:comment 'Description of the recall strategy approved by the regulatory authority or company, including the depth of recall, communication methods, effectiveness check methodology, and disposition instructions for recovered product.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallType rdf:type rdf:Property ;
    rdfs:label 'Recall Type' ;
    rdfs:comment 'Categorization of the recall initiation type. Voluntary recalls are company-initiated; Mandatory recalls are ordered by a regulatory authority; Market Withdrawal involves minor violations not subject to legal action; Stock Recovery involves products not yet distributed to the market.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationRecordId rdf:type rdf:Property ;
    rdfs:label 'Serialization Record Id' ;
    rdfs:comment 'Primary key for serialization_record' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Commissioned By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Serialization commissioning events require documented operator for regulatory compliance, DSCSA traceability, and falsified medicines directive audit trail. New attribute needed.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:commissioningPlantId rdf:type rdf:Property ;
    rdfs:label 'Commissioning Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Serialization commissioning occurs at plants; plant master data provides GMP certification, FDA establishment identifier, regulatory market authorization. Distinct from manufacturing_site_id (manufact' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:primarySerializationCommissioningSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Serialization Commissioning Site Id' ;
    rdfs:comment 'Reference to the manufacturing or packaging site where the serial number was commissioned. Used for GDP compliance, site-level traceability, and regulatory reporting to FDA/EMA.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:commissioningEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Commissioning Event Timestamp' ;
    rdfs:comment 'Date and time when the serial number was commissioned (activated and associated with a physical product unit) at the manufacturing or packaging site. Marks the start of the serialized unit\'s lifecycle. Required for DSCSA and EU FMD event reporting.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decommissioningReason rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Reason' ;
    rdfs:comment 'Reason code for decommissioning the serialized unit. Required for EU FMD decommissioning event reporting to the European Medicines Verification System (EMVS). Supports pharmacovigilance and recall management workflows. [ENUM-REF-CANDIDATE: recall|destruction|sample|theft|damage|dispensed|exported|other — promote to reference product]' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissioningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Timestamp' ;
    rdfs:comment 'Date and time when the serialized unit was decommissioned (removed from the active supply chain). Populated when serialization_status transitions to \'decommissioned\' or \'destroyed\'. Required for EU FMD and DSCSA event reporting.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epcisEventCode rdf:type rdf:Property ;
    rdfs:label 'Epcis Event Code' ;
    rdfs:comment 'Unique identifier of the most recent GS1 EPCIS event associated with this serialized unit. Links to the EPCIS event repository for full event history (ObjectEvent, AggregationEvent, TransactionEvent). Used for DSCSA and EU FMD interoperability.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verification Timestamp' ;
    rdfs:comment 'Date and time of the most recent verification event performed against the medicines verification system (NMVS/EMVS). Used to track verification frequency and identify units that have not been recently verified.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingLevel rdf:type rdf:Property ;
    rdfs:label 'Packaging Level' ;
    rdfs:comment 'Level of the packaging hierarchy this serialization record represents. \'unit\' is the individual saleable unit (SGTIN); \'bundle\' is a multi-pack; \'case\' is a shipping case (SSCC); \'pallet\' is a pallet-level aggregation (SSCC). Drives aggregation hierarchy logic.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Serial Number' ;
    rdfs:comment 'Serial number of the immediate parent container in the aggregation hierarchy (e.g., the case serial number for a unit, or the pallet serial number for a case). Enables reconstruction of the full unit→case→pallet aggregation tree for DSCSA and EU FMD compliance.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarketCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market Code' ;
    rdfs:comment 'Regulatory market authorization code or product registration number applicable to the market country. Links the serialized unit to the specific marketing authorization (NDA/BLA/MAA) under which it was released for that market.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleableReturnFlag rdf:type rdf:Property ;
    rdfs:label 'Saleable Return Flag' ;
    rdfs:comment 'Indicates whether this serialized unit has been returned from the market and assessed as eligible for re-entry into the saleable supply chain. Requires verification against the NMVS/EMVS and GDP assessment before re-release.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serializationStatus rdf:type rdf:Property ;
    rdfs:label 'Serialization Status' ;
    rdfs:comment 'Current lifecycle status of the serialized unit within the track-and-trace system. \'commissioned\' = activated at manufacturing; \'active\' = in supply chain; \'shipped\' = dispatched to trading partner; \'returned\' = returned from market; \'decommissioned\' = intentionally removed; \'destroyed\' = physically destroyed.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainType rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Type' ;
    rdfs:comment 'Indicates whether the serialized unit belongs to the commercial supply chain or the clinical trial supply chain. Clinical trial units require additional IND/CTA traceability. Compassionate use units require special regulatory tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatementFlag rdf:type rdf:Property ;
    rdfs:label 'Transaction Statement Flag' ;
    rdfs:comment 'Indicates whether a valid DSCSA Transaction Statement has been received and verified for this serialized unit from the upstream trading partner. Required under DSCSA Section 582 for each change of ownership in the pharmaceutical supply chain.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryServiceBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Business Partner Id' ;
    rdfs:comment 'Reference to the external organisation (CMO, CDMO, or 3PL) that is the contracting counterparty for this supply agreement. Links to the supplier/vendor master.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:agreementVersion rdf:type rdf:Property ;
    rdfs:label 'Agreement Version' ;
    rdfs:comment 'Version or revision identifier of the agreement document (e.g., v1.0, v2.3-AMEND). Tracks amendments and renegotiations over the agreement lifecycle.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedAnnualVolume rdf:type rdf:Property ;
    rdfs:label 'Contracted Annual Volume' ;
    rdfs:comment 'Total contracted volume of product or service units per agreement year (e.g., batches, kg of API, units of FDF). Represents the committed or target volume used for capacity planning and take-or-pay calculations.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Contracted Unit Price' ;
    rdfs:comment 'Agreed price per unit of measure (volume_uom) for the contracted service or product under this agreement. Used for COGS calculation, budget planning, and purchase order valuation in SAP MM.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expediteLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Expedite Lead Time Days' ;
    rdfs:comment 'Contractually agreed expedited or rush lead time in calendar days available at a premium cost. Used in supply planning exception scenarios and shortage mitigation.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Indicates whether the agreement contains a force majeure clause that excuses performance obligations under extraordinary circumstances (e.g., pandemic, natural disaster, regulatory action). True = force majeure clause is present.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumOrderQty rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Qty' ;
    rdfs:comment 'Minimum quantity per purchase order or manufacturing run that the counterparty will accept under this agreement. Expressed in volume_uom. Used in supply planning to avoid sub-MOQ orders.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Ref' ;
    rdfs:comment 'Reference number or document identifier of the associated Quality Agreement (QA) that governs GMP responsibilities, batch release criteria, and quality obligations between the parties. Distinct from the commercial supply agreement.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:takeOrPayFlag rdf:type rdf:Property ;
    rdfs:label 'Take Or Pay Flag' ;
    rdfs:comment 'Indicates whether the agreement contains a take-or-pay clause obligating the company to purchase or pay for a minimum contracted volume regardless of actual demand. True = take-or-pay applies.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:takeOrPayMinPct rdf:type rdf:Property ;
    rdfs:label 'Take Or Pay Min Pct' ;
    rdfs:comment 'Minimum percentage of contracted_annual_volume that must be purchased or paid for under the take-or-pay clause (e.g., 80.00 = 80%). Null if take_or_pay_flag is False.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure applicable to contracted_annual_volume and minimum_order_qty fields (e.g., KG for API, BATCH for manufacturing runs, UNIT for finished dosage forms). Aligned with SAP UOM configuration. [ENUM-REF-CANDIDATE: KG|L|BATCH|UNIT|VIAL|TABLET|CAPSULE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originDistributionNetworkId rdf:type rdf:Property ;
    rdfs:label 'Origin Distribution Network Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_network. Business justification: Shipments originate from distribution network nodes (plants, warehouses, DCs). The origin_location_code (STRING) should be replaced with origin_distribution_network_id FK to distribution_network.distr' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionNetwork .

ind:releasedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Released By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GDP requires documented personnel for shipment release authorization, especially for cold chain and controlled substances. New attribute needed for regulatory compliance.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Official customs entry or export declaration number assigned by the customs authority for cross-border shipments. Required for import/export compliance tracking and regulatory audit trails. Null for domestic shipments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Required' ;
    rdfs:comment 'Indicates whether this shipment crosses international borders and requires customs import/export documentation (commercial invoice, packing list, import license, health certificate). True for cross-border shipments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Business identifier (SAP Plant code, DC code, customer account, or clinical site number) of the destination receiving the shipment. Used for delivery confirmation and traceability.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationType rdf:type rdf:Property ;
    rdfs:label 'Destination Location Type' ;
    rdfs:comment 'Classifies the type of destination receiving the shipment. Drives GDP compliance requirements, cold-chain monitoring thresholds, and customs documentation needs. [ENUM-REF-CANDIDATE: plant|distribution_center|3pl_warehouse|distributor|wholesaler|hospital|pharmacy|clinical_trial_site — promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Planned or carrier-confirmed estimated date of arrival at the destination. Used for supply chain planning, cold-chain monitoring window calculations, and customer service commitments. Corresponds to SAP planned delivery date (LFDAT).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazardousGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Goods Flag' ;
    rdfs:comment 'Indicates whether the shipment contains dangerous goods (e.g., flammable solvents, cytotoxic agents, radioactive materials) subject to IATA Dangerous Goods Regulations (DGR) or IMDG Code. Triggers mandatory DG documentation and packaging requirements.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country from which the shipment originates. Used for customs documentation, import/export compliance, and GDP lane qualification.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationType rdf:type rdf:Property ;
    rdfs:label 'Origin Location Type' ;
    rdfs:comment 'Classifies the type of origin location from which the shipment departs. Supports routing logic and GDP compliance tracking across the pharmaceutical distribution network.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned Progressive (PRO) number or airway bill number (AWB) / bill of lading (BOL) number used to track the shipment within the carrier\'s system. Primary reference for carrier communication and proof-of-delivery retrieval.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationVerified rdf:type rdf:Property ;
    rdfs:label 'Serialization Verified' ;
    rdfs:comment 'Indicates whether the drug product serialization data (2D DataMatrix barcodes at unit/case level) has been verified and reported to the applicable track-and-trace system (DSCSA in US, FMD in EU) prior to shipment. Required for commercial pharmaceutical distribution.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment. \'planned\' = shipment created but not yet dispatched; \'in_transit\' = goods picked up by carrier; \'delivered\' = confirmed receipt at destination; \'cancelled\' = shipment voided; \'on_hold\' = blocked pending resolution (e.g., GDP deviation, customs hold); \'returned\' = goods returned to origin.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum acceptable storage and transit temperature in degrees Celsius for this shipment. Defined by the drug product\'s approved storage conditions (e.g., 8°C for refrigerated, 25°C for controlled room temperature). Exceedances trigger GDP deviation investigations.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum acceptable storage and transit temperature in degrees Celsius for this shipment. Defined by the drug product\'s approved storage conditions (e.g., 2°C for refrigerated products, -20°C for frozen biologics). Used to configure temperature monitoring device alarms.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMonitorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitor Device Code' ;
    rdfs:comment 'Unique identifier of the temperature data logger or monitoring device (e.g., Sensitech TempTale, Berlinger ELPRO) placed within the shipment packaging. Used to retrieve temperature excursion data post-delivery for GDP compliance review.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Primary mode of transport used for this shipment. Drives cold-chain packaging requirements, transit time expectations, and customs documentation. \'air\' = air freight; \'road\' = truck/van; \'sea\' = ocean freight; \'rail\' = rail freight; \'courier\' = express parcel; \'multimodal\' = combination of modes.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'United Nations (UN) four-digit number identifying the hazardous substance or article being shipped (e.g., UN3373 for Biological Substance Category B, UN1170 for ethanol). Required on dangerous goods declarations when hazardous_goods_flag is True.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingDistributionNetworkId rdf:type rdf:Property ;
    rdfs:label 'Sending Distribution Network Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_network. Business justification: Stock transfer orders move materials between distribution network nodes. The sending_plant_code (STRING) should be replaced with sending_distribution_network_id FK to distribution_network.distribution' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionNetwork .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'SAP outbound delivery document number (transaction VL10) created from the stock transfer order for goods issue processing. Links the STO to the physical shipment execution in SAP WM/SD.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdp Compliant' ;
    rdfs:comment 'Indicates whether the stock transfer order has been executed in full compliance with Good Distribution Practice (GDP) requirements, including qualified carrier use, temperature monitoring, chain of custody documentation, and deviation management.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Date' ;
    rdfs:comment 'Actual date on which goods issue was posted at the sending plant, marking the departure of materials from the source location. Triggers inventory reduction at the sending plant and initiates in-transit stock.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'Actual date on which goods receipt was posted at the receiving plant, confirming arrival and acceptance of the transferred materials. Triggers inventory increase at the receiving plant and closes the in-transit stock.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sendingStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Sending Storage Location' ;
    rdfs:comment 'SAP storage location code within the sending plant from which the materials are issued. Identifies the specific warehouse area, cold-room, quarantine zone, or controlled substance vault at the source site.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCondition rdf:type rdf:Property ;
    rdfs:label 'Shipping Condition' ;
    rdfs:comment 'Shipping service level or condition required for the transfer. Determines carrier selection, transit time expectations, and special handling requirements. Corresponds to SAP SD shipping condition configuration.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sto Creation Timestamp' ;
    rdfs:comment 'Date and time when the stock transfer order was created in the source system (SAP MM). Represents the business event timestamp of order initiation. Used for lead time analysis and supply chain performance reporting.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stoNumber rdf:type rdf:Property ;
    rdfs:label 'Sto Number' ;
    rdfs:comment 'Externally-known business document number assigned by SAP MM for the inter-plant or inter-site stock transfer order. Corresponds to the SAP Purchase Order number used for STO processing (document type UB or NB).' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferCategory rdf:type rdf:Property ;
    rdfs:label 'Transfer Category' ;
    rdfs:comment 'Classifies the nature of the transfer based on the sending and receiving location types: plant-to-plant, distribution center to plant, plant to distribution center, DC-to-DC, or involving a third-party logistics (3PL) provider. Supports network-level supply chain analytics.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'Quantity of the pharmaceutical material ordered for transfer in the base unit of measure. Represents the planned transfer quantity as specified in the STO line item.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationId rdf:type rdf:Property ;
    rdfs:label 'Allocation Id' ;
    rdfs:comment 'Unique identifier for the supply allocation record. Primary key for the supply allocation entity.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedChannel rdf:type rdf:Property ;
    rdfs:label 'Allocated Channel' ;
    rdfs:comment 'Distribution channel or market segment receiving the allocation. Critical for specialty pharma and biologics with restricted distribution networks. [ENUM-REF-CANDIDATE: retail|hospital|specialty_pharmacy|government|clinical_trial|compassionate_use|direct_to_patient — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity of product allocated to the customer, channel, or market under this allocation decision. Represents the Available-to-Promise (ATP) commitment.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Business-facing unique identifier for the allocation decision. Used for tracking and reference in supply chain communications and regulatory documentation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the allocation decision. Tracks progression from draft through approval to fulfillment or cancellation. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|fulfilled|cancelled|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the allocation methodology applied. Determines the business rules and priority logic used for constrained product distribution. [ENUM-REF-CANDIDATE: fair_share|priority_based|contractual|government_contract|compassionate_use|clinical_trial|launch_sequencing — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintDescription rdf:type rdf:Property ;
    rdfs:label 'Constraint Description' ;
    rdfs:comment 'Detailed explanation of the supply constraint situation. Provides business context for allocation decisions and supports regulatory documentation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintReasonCode rdf:type rdf:Property ;
    rdfs:label 'Constraint Reason Code' ;
    rdfs:comment 'Primary reason for supply constraint requiring allocation. Documents the root cause driving the need for allocation decision and ATP limitation. [ENUM-REF-CANDIDATE: capacity|raw_material_shortage|api_shortage|regulatory_hold|quality_hold|launch_phase|demand_surge|supply_disruption — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfilledQuantity rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Quantity' ;
    rdfs:comment 'Actual quantity fulfilled against this allocation to date. Tracks allocation consumption and remaining Available-to-Promise (ATP) balance.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governmentContractFlag rdf:type rdf:Property ;
    rdfs:label 'Government Contract Flag' ;
    rdfs:comment 'Indicates whether this allocation fulfills a government contract obligation such as 340B Drug Pricing Program, Veterans Affairs (VA), or Department of Defense (DoD) contracts.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governmentContractNumber rdf:type rdf:Property ;
    rdfs:label 'Government Contract Number' ;
    rdfs:comment 'Reference number for government contract being fulfilled by this allocation. Required for 340B, VA, DoD, and other federal program compliance.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityScore rdf:type rdf:Property ;
    rdfs:label 'Priority Score' ;
    rdfs:comment 'Numeric priority score used for allocation ranking within priority tiers. Higher scores receive allocation preference in constrained scenarios.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'Remaining unfulfilled quantity available under this allocation. Calculated as allocated_quantity minus fulfilled_quantity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Reference to the allocation rule or algorithm applied to generate this allocation decision. Links to allocation policy configuration in planning systems.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planSiteId rdf:type rdf:Property ;
    rdfs:label 'Plan Site Id' ;
    rdfs:comment 'Reference to the manufacturing site (internal or CMO/CDMO) responsible for producing the planned quantity. Links to the site master data record. Supports GDP compliance and site-level capacity planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:capacityConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Capacity Constraint Flag' ;
    rdfs:comment 'Indicates whether this supply plan record is constrained by manufacturing capacity limitations (True) or represents an unconstrained theoretical plan (False). Distinguishes constrained from unconstrained plan scenarios.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Pct' ;
    rdfs:comment 'Percentage of available manufacturing capacity consumed by this supply plan at the designated manufacturing site. Used for capacity management, bottleneck identification, and CMO contract utilization tracking.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfBatches rdf:type rdf:Property ;
    rdfs:label 'Number Of Batches' ;
    rdfs:comment 'Total number of manufacturing batches planned within the planning horizon for this supply plan record. Used for capacity loading, CMO scheduling, and GMP batch record planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedProductionQty rdf:type rdf:Property ;
    rdfs:label 'Planned Production Qty' ;
    rdfs:comment 'Total planned production or procurement quantity for the material within the planning horizon, expressed in the base unit of measure (e.g., kg for DS/API, units for FDF/DP). Core quantitative output of the supply plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Production Start Date' ;
    rdfs:comment 'The scheduled start date for the manufacturing or procurement activity. Used for capacity planning, CMO scheduling, and lead time management. Derived from planned receipt date minus production lead time.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'The date on which the planned quantity is expected to be received at the destination site or made available in inventory. Used for inventory availability calculations and demand fulfillment scheduling.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scenario rdf:type rdf:Property ;
    rdfs:label 'Scenario' ;
    rdfs:comment 'Scenario classification for the supply plan, supporting what-if analysis and risk planning. Base is the primary plan; optimistic and pessimistic reflect demand upside/downside; risk_adjusted incorporates supply risk mitigations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyType rdf:type rdf:Property ;
    rdfs:label 'Supply Type' ;
    rdfs:comment 'Indicates the sourcing strategy for the planned supply: make (internal manufacturing), buy (external procurement from CMO/CDMO), or transfer (inter-site or inter-company stock transfer). Drives MRP logic in SAP PP and Kinaxis.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Timestamp' ;
    rdfs:comment 'The actual date and time the physical materials arrived at the receiving dock or facility. Distinct from the SAP posting date; captures the real-world event time for GDP compliance, cold-chain monitoring, and traceability. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'The carrier\'s bill of lading number for the inbound shipment. Provides the legal transport document reference linking the receipt to the logistics carrier record. Used for freight claims, GDP transport documentation, and supply chain traceability.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReference rdf:type rdf:Property ;
    rdfs:label 'Coa Reference' ;
    rdfs:comment 'The document reference number or identifier for the vendor\'s Certificate of Analysis (CoA) accompanying the shipment. The CoA confirms the material meets specification. Required for GMP compliance and regulatory traceability. Stored in Veeva Vault or LIMS document management.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cocReference rdf:type rdf:Property ;
    rdfs:label 'Coc Reference' ;
    rdfs:comment 'The document reference number for the vendor\'s Certificate of Compliance (CoC), confirming the material was manufactured in accordance with GMP and applicable regulatory requirements. Distinct from the CoA which covers analytical test results.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The SAP Material Document number generated upon posting the goods receipt in SAP S/4HANA MIGO (transaction MIGO/MB01). Serves as the primary business identifier linking this receipt to the source ERP transaction. Format follows SAP material document numbering (e.g., 5000012345).' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Gr Document Year' ;
    rdfs:comment 'The fiscal year associated with the SAP GR material document number. Required because SAP material document numbers are unique only within a fiscal year. Combined with gr_document_number to form the unique SAP key.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundDeliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Inbound Delivery Number' ;
    rdfs:comment 'SAP inbound delivery document number (transaction VL31N/VL32N) associated with this goods receipt, if applicable. Used when the receipt is triggered by an advance shipping notice (ASN) from the vendor. May be null for direct PO-based receipts.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poLineItem rdf:type rdf:Property ;
    rdfs:label 'Po Line Item' ;
    rdfs:comment 'The specific line item number within the purchase order against which this goods receipt is posted. A single PO may have multiple line items for different materials or delivery schedules.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poQuantity rdf:type rdf:Property ;
    rdfs:label 'Po Quantity' ;
    rdfs:comment 'The ordered quantity as specified in the purchase order line item. Used to calculate receipt variance (received vs. ordered) and to identify over/under deliveries requiring vendor notification or tolerance check.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the received material has been placed in quarantine status pending quality inspection or investigation. True = material is quarantined and not available for use; False = material is not in quarantine. Triggers quality inspection workflow in LIMS and QMS.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the warehouse receipt. \'posted\' = GR document successfully posted in SAP; \'reversed\' = GR has been reversed/cancelled; \'blocked\' = receipt blocked pending resolution; \'under_inspection\' = quality inspection in progress; \'released\' = inspection complete and stock released for use.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record. Primary key for the benefit enrollment transaction.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Unique identifier of the benefit plan in which the employee is enrolling. References the benefit plan master data.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:primaryBenefitEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Benefit Employee Id' ;
    rdfs:comment 'Unique identifier of the employee enrolling in the benefit program. Links to the employee master record in SAP HCM.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualElectionAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Election Amount' ;
    rdfs:comment 'Total annual amount elected by employee for FSA, HSA, or 401k contributions. Used for payroll deduction calculation and IRS compliance reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryDesignation rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Designation' ;
    rdfs:comment 'Name(s) of designated beneficiaries for life insurance or pension benefits. Confidential information used for claims processing. Nullable for non-applicable benefit types.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Member Number' ;
    rdfs:comment 'Unique member identifier assigned by the insurance carrier to the employee. Used on insurance cards and for claims processing. Restricted PII.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'Insurance carrier\'s policy or certificate number assigned to this enrollment. Used for claims processing and carrier reconciliation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraContinuationFlag rdf:type rdf:Property ;
    rdfs:label 'Cobra Continuation Flag' ;
    rdfs:comment 'Indicates whether this enrollment is a COBRA continuation coverage following termination of employment. True for COBRA enrollments, False for active employee enrollments.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contribution Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for employee and employer contribution amounts. Supports multi-country payroll operations.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Frequency at which employee and employer contributions are deducted or paid: weekly, biweekly, semi-monthly, monthly, or annual.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage elected by the employee: employee only, employee plus spouse, employee plus children, or full family coverage. Determines premium rates and contribution amounts.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csvScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Csv Scope Flag' ;
    rdfs:comment 'Indicates whether this enrollment record is within the scope of computer system validation per 21 CFR Part 11. True for GxP-regulated personnel benefit records requiring validation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Number of dependents covered under this enrollment. Used for premium calculation and compliance reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'Amount deducted from employee paycheck per pay period for this benefit. Represents the employee\'s share of the premium or contribution.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'Amount contributed by the employer per pay period for this benefit. Represents the employer\'s share of the premium or contribution for financial and compliance reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentEventType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Event Type' ;
    rdfs:comment 'Type of qualifying event that triggered the enrollment: new hire enrollment, annual open enrollment period, qualifying life event (marriage, birth, etc.), COBRA continuation, or rehire enrollment.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingLifeEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Date' ;
    rdfs:comment 'Date of the qualifying life event (marriage, birth, adoption, divorce, etc.) that allowed mid-year enrollment change. Nullable if not applicable.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Termination Timestamp' ;
    rdfs:comment 'Date and time when the benefit enrollment was terminated in the system. Nullable if enrollment is active.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Indicates whether the employee actively waived this benefit coverage. True if waived, False if enrolled.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:candidateId rdf:type rdf:Property ;
    rdfs:label 'Candidate Id' ;
    rdfs:comment 'Unique identifier for the candidate record in the talent acquisition system. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Candidate .

ind:candidateRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Recruiter Employee Id' ;
    rdfs:comment 'Employee ID of the internal recruiter or talent acquisition specialist assigned to manage this candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:candidateReferralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Referral Employee Id' ;
    rdfs:comment 'Employee ID of the internal employee who referred this candidate, if applicable.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backgroundCheckCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Completion Date' ;
    rdfs:comment 'Date on which the candidates background check was completed.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Current status of the candidates pre-employment background verification process.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateNumber rdf:type rdf:Property ;
    rdfs:label 'Candidate Number' ;
    rdfs:comment 'Human-readable business identifier for the candidate, typically system-generated and used in communications and reporting.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateStatus rdf:type rdf:Property ;
    rdfs:label 'Candidate Status' ;
    rdfs:comment 'Current overall status of the candidate in the talent acquisition pipeline across all applications.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'Name of the candidates current employer organization, if disclosed.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'Candidates current job title or role at their present employer.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeField rdf:type rdf:Property ;
    rdfs:label 'Degree Field' ;
    rdfs:comment 'Primary field of study or major for the candidates highest degree (e.g., Chemistry, Pharmacology, Biochemistry, Engineering).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversitySelfIdentification rdf:type rdf:Property ;
    rdfs:label 'Diversity Self Identification' ;
    rdfs:comment 'Candidates voluntary self-identification for diversity and inclusion tracking purposes, collected in compliance with equal employment opportunity regulations.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Salary Amount' ;
    rdfs:comment 'Candidates expected or desired annual salary amount.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedSalaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Expected Salary Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the candidates expected salary amount.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the candidate has provided explicit consent for processing of personal data under GDPR. True if consent given, False otherwise.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpExperienceFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Experience Flag' ;
    rdfs:comment 'Indicates whether the candidate has prior experience working in GxP-regulated environments (GMP, GLP, GCP, GDP). True if candidate has GxP experience, False otherwise.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Gxp Experience Years' ;
    rdfs:comment 'Number of years the candidate has worked in GxP-regulated roles or environments.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'Highest level of formal education attained by the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialContactDate rdf:type rdf:Property ;
    rdfs:label 'Initial Contact Date' ;
    rdfs:comment 'Date on which the candidate was first contacted or entered the talent acquisition system.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL to the candidates LinkedIn professional profile, if provided.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Status' ;
    rdfs:comment 'Status of pre-employment medical clearance for candidates being hired into GxP-regulated or safety-critical roles.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days of notice the candidate must provide to their current employer before resignation, if applicable.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredLocations rdf:type rdf:Property ;
    rdfs:label 'Preferred Locations' ;
    rdfs:comment 'Candidates preferred geographic locations for employment, pipe-delimited if multiple.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resumeFilePath rdf:type rdf:Property ;
    rdfs:label 'Resume File Path' ;
    rdfs:comment 'File system or cloud storage path to the candidates uploaded resume or curriculum vitae document.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Primary channel through which the candidate was sourced or entered the talent acquisition pipeline.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDetail rdf:type rdf:Property ;
    rdfs:label 'Source Detail' ;
    rdfs:comment 'Detailed source information such as specific job board name, referrer employee ID, agency name, or university name.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Total Years Experience' ;
    rdfs:comment 'Total number of years of relevant professional work experience as declared by the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veteranStatus rdf:type rdf:Property ;
    rdfs:label 'Veteran Status' ;
    rdfs:comment 'Candidates veteran status, voluntarily disclosed for compliance with veteran employment regulations.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willingToRelocateFlag rdf:type rdf:Property ;
    rdfs:label 'Willing To Relocate Flag' ;
    rdfs:comment 'Indicates whether the candidate is willing to relocate for employment opportunities. True if willing, False otherwise.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'Current work authorization status of the candidate for the target country of employment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_profile. Business justification: Compensation plans are designed for job profiles/families, not individual positions. The compensation_plan currently has job_grade_band as a STRING, but should also link to job_profile for systematic ' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:baseSalaryMaximum rdf:type rdf:Property ;
    rdfs:label 'Base Salary Maximum' ;
    rdfs:comment 'Maximum base salary amount for the applicable job grade band within this compensation plan. Defines upper limit for salary progression.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseSalaryMidpoint rdf:type rdf:Property ;
    rdfs:label 'Base Salary Midpoint' ;
    rdfs:comment 'Target or midpoint base salary amount for the applicable job grade band. Represents market-competitive pay level.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseSalaryMinimum rdf:type rdf:Property ;
    rdfs:label 'Base Salary Minimum' ;
    rdfs:comment 'Minimum base salary amount for the applicable job grade band within this compensation plan. Used for pay equity analysis and salary range management.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitPackageCode rdf:type rdf:Property ;
    rdfs:label 'Benefit Package Code' ;
    rdfs:comment 'Identifier for the standard benefit package associated with this compensation plan (e.g., health, dental, vision, life insurance, pension/401k, FSA, EAP).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Bonus Target Percentage' ;
    rdfs:comment 'Target annual bonus as a percentage of base salary for employees enrolled in this plan. Used for total compensation calculations.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Flag' ;
    rdfs:comment 'Indicates whether this compensation plan has undergone compliance review for pay equity, regulatory requirements, and internal policy adherence.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthInsuranceEmployerContribution rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Employer Contribution' ;
    rdfs:comment 'Standard employer contribution amount toward health insurance premiums for employees enrolled in this plan. May vary by coverage tier.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobGradeBand rdf:type rdf:Property ;
    rdfs:label 'Job Grade Band' ;
    rdfs:comment 'Job grade or band range applicable to this compensation plan (e.g., \'Grade 10-12\', \'Executive Band\'). Links to organizational job architecture.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltiEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Lti Eligibility Flag' ;
    rdfs:comment 'Indicates whether employees in this compensation plan are eligible for long-term incentive programs (e.g., stock options, restricted stock units, performance shares).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltiTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Lti Target Percentage' ;
    rdfs:comment 'Target long-term incentive award as a percentage of base salary. Applicable only when LTI eligibility flag is true.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meritIncreaseBudgetPercentage rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Budget Percentage' ;
    rdfs:comment 'Annual merit increase budget as a percentage of current base salary for this compensation plan. Used during annual compensation review cycles.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openEnrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment End Date' ;
    rdfs:comment 'End date of the annual open enrollment period. Benefit elections must be completed by this date.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openEnrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Start Date' ;
    rdfs:comment 'Start date of the annual open enrollment period when employees can enroll or modify their benefit elections for this compensation plan.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payEquityAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Pay Equity Analysis Flag' ;
    rdfs:comment 'Indicates whether this compensation plan has been analyzed for pay equity across gender, ethnicity, and other protected classes.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planAdministratorEmail rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Email' ;
    rdfs:comment 'Email address of the plan administrator for employee inquiries and escalations.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAdministratorName rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Name' ;
    rdfs:comment 'Name of the HR or compensation team member responsible for administering this compensation plan. Used for audit and governance purposes.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the compensation plan including eligibility criteria, calculation methodology, and key terms. Used for employee communication and HR reference.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementPlanEmployerMatchPercentage rdf:type rdf:Property ;
    rdfs:label 'Retirement Plan Employer Match Percentage' ;
    rdfs:comment 'Employer matching contribution percentage for retirement plans (401k, pension) associated with this compensation plan.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departmentId rdf:type rdf:Property ;
    rdfs:label 'Department Id' ;
    rdfs:comment 'Unique identifier for the department. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:parentDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Department Id' ;
    rdfs:comment 'Reference to the parent department in the organizational hierarchy. Enables multi-level organizational structure representation.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:budgetAmountAnnual rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Annual' ;
    rdfs:comment 'Total annual operating budget allocated to the department in the company\'s reporting currency. Includes personnel, operational, and capital expenses.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departmentDescription rdf:type rdf:Property ;
    rdfs:label 'Department Description' ;
    rdfs:comment 'Detailed description of the department\'s purpose, responsibilities, and scope of work. Provides business context for organizational understanding.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentStatus rdf:type rdf:Property ;
    rdfs:label 'Department Status' ;
    rdfs:comment 'Current operational status of the department. Tracks lifecycle from planning through active operation to closure.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentType rdf:type rdf:Property ;
    rdfs:label 'Department Type' ;
    rdfs:comment 'Classification of the organizational unit type. Distinguishes between departments, divisions, functional groups, sites, cost centers, and business units.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountActual rdf:type rdf:Property ;
    rdfs:label 'Headcount Actual' ;
    rdfs:comment 'Current actual number of full-time equivalent (FTE) employees assigned to the department. Updated as employees join or leave.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountPlanned rdf:type rdf:Property ;
    rdfs:label 'Headcount Planned' ;
    rdfs:comment 'Planned or budgeted number of full-time equivalent (FTE) employees for the department. Used for workforce planning and budget allocation.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteLocationCode rdf:type rdf:Property ;
    rdfs:label 'Site Location Code' ;
    rdfs:comment 'Code identifying the physical site or facility where the department is located. Supports multi-site organizational structures.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Flag' ;
    rdfs:comment 'Indicates whether the department is in scope for Sarbanes-Oxley Act compliance and internal controls over financial reporting. Drives audit and control testing requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'User identifier of the person or system that created this employee record. Required for complete audit trail per 21 CFR Part 11 and GDPR accountability principle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:employingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Employing Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Employment contracts are with specific legal entities - required for tax reporting, statutory compliance, labor law jurisdiction, and corporate structure reporting. Creates new FK as no existing colum' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Reference to the employee record of the direct manager or supervisor. Establishes reporting hierarchy for approval workflows, performance management, and training assignment escalation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date of the most recent background check completion. Used to determine when periodic re-screening is due per company policy and regulatory requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:citizenshipCountryCode rdf:type rdf:Property ;
    rdfs:label 'Citizenship Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the employee\'s citizenship. Used for work authorization verification, export control compliance (ITAR, EAR), and visa/immigration tracking for international assignments.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'Human-readable business identifier assigned to the employee by HR systems. Used for payroll, timekeeping, and external reporting. Typically sourced from SAP HR Personnel Number field.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of employment arrangement. CRO-seconded staff are Contract Research Organization personnel working on-site who require GCP training and system access but remain employed by the CRO. Critical for determining training requirements, access levels, and regulatory accountability.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGcpQualified rdf:type rdf:Property ;
    rdfs:label 'Is Gcp Qualified' ;
    rdfs:comment 'Indicates whether the employee is currently qualified to perform GCP-regulated clinical trial activities per ICH E6(R2) guidelines. True if all required GCP training is current and documented. Used to control access to clinical trial systems (CTMS, EDC, eTMF) and determine eligibility for clinical roles.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGlpQualified rdf:type rdf:Property ;
    rdfs:label 'Is Glp Qualified' ;
    rdfs:comment 'Indicates whether the employee is currently qualified to perform GLP-regulated nonclinical laboratory studies per FDA 21 CFR Part 58 and OECD GLP principles. True if all required GLP training is current. Used to determine eligibility for preclinical study roles and LIMS access.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGmpQualified rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Qualified' ;
    rdfs:comment 'Indicates whether the employee is currently qualified to perform GMP-regulated manufacturing and quality activities per 21 CFR Parts 210/211 and EU GMP Annex 11. True if all required cGMP training is current. Controls access to manufacturing execution systems (MES), batch records, and quality systems.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPeopleManager rdf:type rdf:Property ;
    rdfs:label 'Is People Manager' ;
    rdfs:comment 'Indicates whether the employee has direct reports and managerial responsibilities. True if the employee manages one or more subordinates. Used to determine eligibility for management training programs and approval authority levels.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQualityCriticalRole rdf:type rdf:Property ;
    rdfs:label 'Is Quality Critical Role' ;
    rdfs:comment 'Indicates whether the employee holds a quality-critical function requiring enhanced training documentation, competency assessment, and audit readiness per ICH Q10 and ISO 9001. Includes QA/QC personnel, Qualified Persons, and individuals with batch release authority.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Standardized job classification code from HR system. Maps to compensation bands, competency frameworks, and training matrices. Typically sourced from SAP Organizational Management job catalog.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broad occupational category grouping similar roles (e.g., Research & Development, Quality Assurance, Manufacturing Operations, Clinical Operations, Regulatory Affairs). Used for workforce planning and skills gap analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPromotionDate rdf:type rdf:Property ;
    rdfs:label 'Last Promotion Date' ;
    rdfs:comment 'Date of the employee\'s most recent promotion or job grade increase. Used for career progression analytics, retention risk modeling, and compensation planning.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransferDate rdf:type rdf:Property ;
    rdfs:label 'Last Transfer Date' ;
    rdfs:comment 'Date of the employee\'s most recent lateral transfer to a different department, site, or role. Used to track internal mobility and trigger site-specific training reassessments.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobilePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone Number' ;
    rdfs:comment 'Personal or corporate mobile phone number. Used for emergency notifications, on-call schedules, and multi-factor authentication for system access.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number (e.g., Social Security Number in US, National Insurance Number in UK). Used for tax reporting, benefits administration, and background checks. Highly restricted access per data privacy regulations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Name the employee prefers to be called in day-to-day business interactions. Used for internal communications, badges, and non-regulatory systems.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Role Flag' ;
    rdfs:comment 'Identifies employees holding specific regulatory-defined roles with legal accountability. Qualified Person (EU) and Authorized Person (US) have batch release authority. Study Director oversees GLP studies. Principal Investigator leads clinical trials. Used for regulatory submissions and inspection readiness.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'Highest level of security clearance granted to the employee for access to classified or highly sensitive information. Relevant for employees working on government contracts, controlled substances (DEA schedules), or proprietary research with national security implications.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for employment termination. Used for workforce analytics, turnover reporting, and compliance with labor regulations. Null for active employees.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Expiry Date' ;
    rdfs:comment 'Date when the employee\'s work authorization (visa, permit) expires. Null for citizens and permanent residents. Used to trigger renewal workflows and prevent unauthorized work.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workCountryCode rdf:type rdf:Property ;
    rdfs:label 'Work Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the employee primarily works. Determines applicable labor laws, tax jurisdictions, and regulatory training requirements (FDA vs EMA vs PMDA). Used for global workforce reporting and compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Work Phone Number' ;
    rdfs:comment 'Primary business telephone number for the employee. Used for internal directory, emergency contact during business hours, and audit communication.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeMovementId rdf:type rdf:Property ;
    rdfs:label 'Employee Movement Id' ;
    rdfs:comment 'Unique identifier for the employee movement transaction record. Primary key for the employee movement entity.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newSiteId rdf:type rdf:Property ;
    rdfs:label 'New Site Id' ;
    rdfs:comment 'Identifier of the physical site or location where the employee will be based after the movement. Important for GxP training and facility access.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:primaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Employee Id' ;
    rdfs:comment 'Unique identifier of the employee undergoing the movement. Links to the employee master record.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryEmployeePreviousDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Employee Previous Department Id' ;
    rdfs:comment 'Identifier of the organizational department the employee was assigned to before the movement.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:primaryEmployeePreviousPositionId rdf:type rdf:Property ;
    rdfs:label 'Primary Employee Previous Position Id' ;
    rdfs:comment 'Identifier of the position the employee held before the movement. Provides historical context for the transition.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:tertiaryNewManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary New Manager Employee Id' ;
    rdfs:comment 'Identifier of the manager or supervisor the employee will report to after the movement. Establishes new reporting relationship.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryQuinaryApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Quinary Approved By Employee Id' ;
    rdfs:comment 'Identifier of the manager, HR business partner, or executive who approved the movement. Required for audit trail and compliance.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:movementNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Number' ;
    rdfs:comment 'Business-facing unique transaction number for the employee movement event, used for tracking and audit purposes.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the movement (e.g., performance, business need, employee request, restructuring, succession planning).' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Description' ;
    rdfs:comment 'Detailed textual explanation of the reason for the employee movement, providing context beyond the reason code.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the movement transaction. Tracks the approval and execution workflow state. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_progress|completed|cancelled|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'New Cost Center Code' ;
    rdfs:comment 'The cost center code to which the employees costs will be allocated after the movement. Impacts financial planning and variance analysis.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newGradeBand rdf:type rdf:Property ;
    rdfs:label 'New Grade Band' ;
    rdfs:comment 'The salary grade or job level the employee will hold after the movement. Impacts compensation, benefits eligibility, and organizational hierarchy.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newJobFamily rdf:type rdf:Property ;
    rdfs:label 'New Job Family' ;
    rdfs:comment 'The job family or functional area the employee is moving into. Critical for skills assessment and training requirements.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Previous Cost Center Code' ;
    rdfs:comment 'The cost center code to which the employees costs were allocated before the movement. Used for financial reporting and budget tracking.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousGradeBand rdf:type rdf:Property ;
    rdfs:label 'Previous Grade Band' ;
    rdfs:comment 'The salary grade or job level the employee held before the movement. Used for compensation analysis and career progression tracking.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousJobFamily rdf:type rdf:Property ;
    rdfs:label 'Previous Job Family' ;
    rdfs:comment 'The job family or functional area the employee belonged to before the movement (e.g., Research, Manufacturing, Quality, Regulatory).' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Critical Flag' ;
    rdfs:comment 'Indicates whether the new position performs quality-critical functions requiring enhanced training, qualification, and audit trail documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Secondment End Date' ;
    rdfs:comment 'The planned or actual date on which a secondment assignment ends and the employee returns to the home organization.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondmentOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Secondment Organization Name' ;
    rdfs:comment 'Name of the external organization (CRO, CMO, CDMO, partner company) to which the employee is being seconded, if applicable. Null for internal movements.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Secondment Start Date' ;
    rdfs:comment 'The date on which a secondment assignment begins. Applicable only for secondment movement types.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequalificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Requalification Required Flag' ;
    rdfs:comment 'Indicates whether the movement triggers mandatory requalification or new training requirements due to role change, site change, or regulatory scope change.' ;
    rdfs:domain ind:EmployeeMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employmentContractId rdf:type rdf:Property ;
    rdfs:label 'Employment Contract Id' ;
    rdfs:comment 'Unique identifier for the employment contract record. Primary key for the employment contract entity.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Contracting Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Contracts are executed by specific legal entities - essential for legal validity, governing jurisdiction determination, and contract enforceability. Creates new FK to establish which legal entity is t' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Employment contracts are typically written for a specific authorized position slot. The contract currently has job_title and job_family as strings, but these should reference the position master for c' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:baseSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Base Salary Amount' ;
    rdfs:comment 'Annual base salary amount in the contract currency. Excludes bonuses, allowances, and benefits. Used for payroll processing, compensation analysis, and financial planning.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the signed employment contract document stored in the document management system (e.g., Veeva Vault, SharePoint). Used for audit readiness, regulatory inspections, and legal documentation retrieval.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fte rdf:type rdf:Property ;
    rdfs:label 'Fte' ;
    rdfs:comment 'Full-time equivalency ratio representing the proportion of a full-time workload. 1.000 indicates full-time; 0.500 indicates half-time. Used for headcount reporting, budget planning, and resource allocation.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the legal jurisdiction under which the employment contract is governed. Determines applicable labor laws, tax regulations, and dispute resolution mechanisms. Examples: USA, GBR, DEU, JPN, CHE.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Role Flag' ;
    rdfs:comment 'Indicates whether the employee holds a quality-critical role requiring Good Clinical Practice (GCP), Good Manufacturing Practice (GMP), or Good Laboratory Practice (GLP) training and certification. True for roles subject to FDA/EMA inspection and audit requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpTrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Gxp Training Required' ;
    rdfs:comment 'Specifies which Good Practice training certifications are mandatory for this role. GCP (Good Clinical Practice) for clinical trial personnel; GMP (Good Manufacturing Practice) for manufacturing and quality personnel; GLP (Good Laboratory Practice) for laboratory and preclinical personnel. Combinations indicate multi-domain roles. [ENUM-REF-CANDIDATE: gcp|gmp|glp|gcp_gmp|gcp_glp|gmp_glp|gcp_gmp_glp|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAssignmentClause rdf:type rdf:Property ;
    rdfs:label 'Ip Assignment Clause' ;
    rdfs:comment 'Indicates whether the employment contract includes an intellectual property assignment clause transferring ownership of employee-created inventions, patents, and discoveries to Pharmaceuticals. True if IP assignment is contractually binding; False otherwise. Critical for patent filing and drug development.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonCompeteClause rdf:type rdf:Property ;
    rdfs:label 'Non Compete Clause' ;
    rdfs:comment 'Indicates whether the employment contract includes a non-compete or restrictive covenant clause limiting the employee\'s ability to work for competitors after termination. True if non-compete obligations exist; False otherwise. Subject to jurisdiction-specific enforceability.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:probationEndDate rdf:type rdf:Property ;
    rdfs:label 'Probation End Date' ;
    rdfs:comment 'The calculated or actual date on which the probationary period concludes. Used for HR workflow triggers and performance review scheduling.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:probationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Probation Period Days' ;
    rdfs:comment 'Duration of the probationary period in days during which the employee\'s performance is evaluated before full employment confirmation. Typically ranges from 30 to 180 days depending on role and jurisdiction.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rehireEligible rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for rehire by Pharmaceuticals after contract termination. True if eligible; False if ineligible due to performance, conduct, or policy violations. Used for talent acquisition and background screening.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteWorkEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for remote or hybrid work arrangements under this contract. True if remote work is permitted; False if on-site presence is required. Relevant for post-pandemic workforce policies.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Salary Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the base salary amount. Examples: USD, EUR, GBP, JPY, CHF. Required for multi-currency payroll processing and financial consolidation.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryGrade rdf:type rdf:Property ;
    rdfs:label 'Salary Grade' ;
    rdfs:comment 'Compensation band or grade assigned to the employee within the organization\'s salary structure. Used for pay equity analysis, compensation planning, and internal benchmarking. Format typically alphanumeric (e.g., E5, M3, S12).' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'The date on which the employment contract was signed by both parties. Used for legal documentation, audit trails, and contract lifecycle tracking.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workLocation rdf:type rdf:Property ;
    rdfs:label 'Work Location' ;
    rdfs:comment 'Primary work location or site where the employee is based. May reference a facility, office, or indicate remote work. Used for workforce planning, compliance with local labor laws, and emergency response.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Working Hours Per Week' ;
    rdfs:comment 'Standard number of working hours per week as defined in the employment contract. Used for full-time equivalency (FTE) calculations, payroll processing, and compliance with labor regulations. Typical values: 40.00 for full-time, 20.00 for part-time.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gxpTrainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Gxp Training Record Id' ;
    rdfs:comment 'Unique identifier for the GxP training record. Primary key for the training record entity.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alt5GxpApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Gxp Approved By Employee Id' ;
    rdfs:comment 'Reference to the quality assurance officer or authorized personnel who approved and verified this training record for regulatory compliance. Null if not yet approved.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryGxpEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Gxp Employee Id' ;
    rdfs:comment 'Reference to the employee who is assigned or has completed this training. Links to the employee master data.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryGxpCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Gxp Created By Employee Id' ;
    rdfs:comment 'Reference to the employee who created this training record in the system. Part of the audit trail required by 21 CFR Part 11.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryGxpLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Gxp Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who last modified this training record. Part of the audit trail required by 21 CFR Part 11.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryGxpTrainerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Gxp Trainer Employee Id' ;
    rdfs:comment 'Reference to the employee who conducted or facilitated the training session. Null for self-paced e-learning.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Reference to the training course or curriculum that this record tracks. Links to the training course master data.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Outcome of the training assessment: pass (met or exceeded threshold), fail (did not meet threshold), waived (assessment requirement waived by authorized personnel), or not applicable (no assessment required).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numeric score achieved by the employee on the training assessment or examination, typically expressed as a percentage (0.00 to 100.00). Null if no assessment was required.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when the training was assigned to the employee.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Business reason for assigning this training: new hire onboarding, role change, SOP update, periodic requalification, Corrective and Preventive Action (CAPA), audit finding, regulatory requirement, or identified competency gap. [ENUM-REF-CANDIDATE: new_hire|role_change|sop_update|periodic_requalification|capa|audit_finding|regulatory_requirement|competency_gap — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendanceStatus rdf:type rdf:Property ;
    rdfs:label 'Attendance Status' ;
    rdfs:comment 'Attendance status for scheduled training sessions: attended (full participation), absent (did not attend), partially attended (incomplete participation), or excused (authorized absence).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Date' ;
    rdfs:comment 'Date when the training certificate was issued to the employee. Null if no certificate was issued.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate number issued upon successful completion of the training. Used for audit and verification purposes. Null if no certificate was issued.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment, typically expressed as a percentage (0.00 to 100.00). Null if no assessment was required.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryInspectionReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Ready Flag' ;
    rdfs:comment 'Indicates whether this training record is complete, verified, and ready for presentation during FDA, EMA, or other regulatory inspections. True if inspection-ready, False otherwise.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requalificationIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Requalification Interval Months' ;
    rdfs:comment 'Number of months between required requalification training cycles. Null if requalification is not periodic.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sopVersion rdf:type rdf:Property ;
    rdfs:label 'Sop Version' ;
    rdfs:comment 'Version number or identifier of the SOP that was covered in this training. Critical for change control and audit trail. Null if training is not SOP-specific.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total duration of the training session in hours, including instruction, assessment, and practical exercises.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical or virtual location where the training was conducted (e.g., site name, building, room number, or online platform).' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingMaterialVersion rdf:type rdf:Property ;
    rdfs:label 'Training Material Version' ;
    rdfs:comment 'Version number or identifier of the training materials (slides, videos, documents) used for this training session. Ensures traceability and compliance with 21 CFR Part 11.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Training Record Number' ;
    rdfs:comment 'Business-facing unique identifier for the training record, often used in audit trails and regulatory submissions.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Classification of the training event: initial (new hire or new role), refresher (periodic update), requalification (competency renewal), ad hoc (unscheduled), remedial (corrective), or change control (triggered by SOP revision).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Id' ;
    rdfs:comment 'Primary key for headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHeadcountIncumbentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Headcount Incumbent Employee Id' ;
    rdfs:comment 'Reference to the current employee holding the target position for succession planning. Links to employee master data.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryHeadcountCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Headcount Created By Employee Id' ;
    rdfs:comment 'Reference to the employee who created this headcount plan record. Used for audit trail and accountability.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryHeadcountLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Headcount Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who most recently modified this headcount plan record. Used for audit trail and accountability.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryHeadcountApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Headcount Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved this headcount plan. Typically a senior leader or HR executive with workforce planning authority.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedFteCount rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Count' ;
    rdfs:comment 'Authorized full-time equivalent headcount for the planning period. Represents the approved workforce capacity including full-time and part-time employees normalized to FTE basis.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attritionAssumptionRate rdf:type rdf:Property ;
    rdfs:label 'Attrition Assumption Rate' ;
    rdfs:comment 'Assumed attrition rate (as percentage) used in workforce planning calculations. Represents expected voluntary and involuntary turnover during the planning period.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessContinuityPriority rdf:type rdf:Property ;
    rdfs:label 'Business Continuity Priority' ;
    rdfs:comment 'Priority level for business continuity planning: critical (role essential for regulatory compliance or patient safety), high (significant business impact if vacant), medium (moderate impact), low (minimal immediate impact).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentFteCount rdf:type rdf:Property ;
    rdfs:label 'Current Fte Count' ;
    rdfs:comment 'Current actual full-time equivalent headcount as of the plan snapshot date. Used to calculate the gap between current state and approved target.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentGapAssessment rdf:type rdf:Property ;
    rdfs:label 'Development Gap Assessment' ;
    rdfs:comment 'Detailed assessment of competency gaps and development needs for the successor candidate to be fully prepared for the target position. Includes technical skills, leadership capabilities, and regulatory qualifications.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedAttritionCount rdf:type rdf:Property ;
    rdfs:label 'Expected Attrition Count' ;
    rdfs:comment 'Projected number of employee departures during the planning period based on attrition assumptions. Used to calculate replacement hiring needs.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gxpQualificationReadiness rdf:type rdf:Property ;
    rdfs:label 'Gxp Qualification Readiness' ;
    rdfs:comment 'Status of GxP (GMP/GLP/GCP) qualification readiness for the successor candidate: qualified (meets all regulatory requirements), in_progress (undergoing qualification training), not_started (qualification not yet initiated), not_applicable (role does not require GxP qualification).' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openPositionsCount rdf:type rdf:Property ;
    rdfs:label 'Open Positions Count' ;
    rdfs:comment 'Number of approved but unfilled positions included in this headcount plan. Represents active recruitment needs.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planReviewDate rdf:type rdf:Property ;
    rdfs:label 'Plan Review Date' ;
    rdfs:comment 'Date when this headcount or succession plan was last reviewed and validated. Used to ensure plans remain current and aligned with business needs.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedHiresCount rdf:type rdf:Property ;
    rdfs:label 'Planned Hires Count' ;
    rdfs:comment 'Number of new hires planned during the planning period to meet approved headcount targets, including backfills and net new positions.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryContinuityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Continuity Required Flag' ;
    rdfs:comment 'Indicates whether this position requires regulatory continuity planning due to FDA/EMA inspection readiness or GxP compliance requirements (True/False). True for Qualified Persons, Responsible Pharmacists, and other regulatory-critical roles.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionRiskRating rdf:type rdf:Property ;
    rdfs:label 'Retention Risk Rating' ;
    rdfs:comment 'Assessment of flight risk for the incumbent or successor: low (stable, unlikely to leave), medium (some risk factors present), high (significant risk of departure), critical (imminent departure risk or key person dependency).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Name of the planning scenario for what-if modeling (e.g., \'Base Case\', \'Aggressive Growth\', \'Cost Optimization\', \'Clinical Trial Scale-Up\'). Supports multiple scenario planning for strategic workforce decisions.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioProbability rdf:type rdf:Property ;
    rdfs:label 'Scenario Probability' ;
    rdfs:comment 'Estimated probability (as percentage) that this planning scenario will materialize. Used in probabilistic workforce planning and risk assessment.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successionPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Flag' ;
    rdfs:comment 'Indicates whether this headcount plan includes succession planning elements for critical or regulated roles (True/False). When True, succession-specific attributes are populated.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successorReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Successor Readiness Level' ;
    rdfs:comment 'Assessment of the successor candidate\'s readiness to assume the target position: ready_now (can assume role immediately), 1_2_years (ready within 1-2 years with development), 3_5_years (ready within 3-5 years with development), not_ready (significant development required).' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaCriticality rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Criticality' ;
    rdfs:comment 'Primary therapeutic area for which this succession plan is critical, reflecting specialized expertise requirements in pharmaceutical development and commercialization.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobApplicationId rdf:type rdf:Property ;
    rdfs:label 'Job Application Id' ;
    rdfs:comment 'Unique identifier for the job application record. Primary key for the job application entity.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJobRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Job Recruiter Employee Id' ;
    rdfs:comment 'Reference to the recruiter or talent acquisition specialist managing this application. Links to the employee master record.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recruitmentRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Recruitment Requisition Id' ;
    rdfs:comment 'Reference to the recruitment requisition for which this application was submitted. Links to the job requisition master record.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecruitmentRequisition .

ind:tertiaryJobReferralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Job Referral Employee Id' ;
    rdfs:comment 'Reference to the employee who referred this candidate, if the application source is employee referral. Links to the employee master record.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationSource rdf:type rdf:Property ;
    rdfs:label 'Application Source' ;
    rdfs:comment 'Channel or source through which the candidate submitted the application (e.g., career site, employee referral, recruitment agency, job board). [ENUM-REF-CANDIDATE: career_site|employee_referral|recruitment_agency|job_board|social_media|campus_recruitment|internal_posting|direct_application|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedStartDate rdf:type rdf:Property ;
    rdfs:label 'Expected Start Date' ;
    rdfs:comment 'Expected or proposed start date for the candidate if hired. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hiringDecision rdf:type rdf:Property ;
    rdfs:label 'Hiring Decision' ;
    rdfs:comment 'Final hiring decision for this application (e.g., pending, hire, no hire).' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hiringDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Hiring Decision Date' ;
    rdfs:comment 'Date when the final hiring decision was made for this application. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'Date of the most recent or scheduled interview for this application. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewStage rdf:type rdf:Property ;
    rdfs:label 'Interview Stage' ;
    rdfs:comment 'Current interview stage for the application (e.g., not scheduled, phone screen, first round, second round, panel interview, final round, completed). [ENUM-REF-CANDIDATE: not_scheduled|phone_screen|first_round|second_round|panel_interview|final_round|completed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Date' ;
    rdfs:comment 'Date when pre-employment medical clearance was obtained. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Offer Acceptance Date' ;
    rdfs:comment 'Date when the candidate accepted the job offer. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'Date when the job offer was extended to the candidate. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Status of the job offer for this application (e.g., not extended, pending, accepted, declined, withdrawn, expired).' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralBonusEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Bonus Eligible Flag' ;
    rdfs:comment 'Indicates whether the referring employee is eligible for a referral bonus if this candidate is hired. True if eligible per company referral program rules.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Competency Framework Id' ;
    rdfs:comment 'Reference to the competency framework defining the skills, behaviors, and knowledge areas required for this role. Used in performance evaluation, training needs analysis, and talent development.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetencyFramework .

ind:jobFamilyId rdf:type rdf:Property ;
    rdfs:label 'Job Family Id' ;
    rdfs:comment 'Reference to the job family grouping that this profile belongs to (e.g., Research & Development, Quality Assurance, Manufacturing Operations, Clinical Development). Used for workforce planning and career pathing.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobFamily .

ind:primaryJobEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Job Employee Id' ;
    rdfs:comment 'Reference to the user (typically HR Director or Quality Head) who approved this job profile. Required for audit trail and accountability per 21 CFR Part 11 and ICH Q10.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:compensationGrade rdf:type rdf:Property ;
    rdfs:label 'Compensation Grade' ;
    rdfs:comment 'Compensation grade or band assigned to this role, defining the salary range and bonus eligibility. Used in budgeting, offer generation, and pay equity analysis. Confidential business data.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'Classification under the U.S. Fair Labor Standards Act indicating whether the role is exempt or non-exempt from overtime pay requirements. Drives payroll processing and labor cost planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpTrainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Required Flag' ;
    rdfs:comment 'Indicates whether this role requires mandatory Good Clinical Practice training per ICH E6 guidelines. True for clinical trial personnel (CRAs, clinical monitors, data managers). Drives training assignment and audit readiness.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glpTrainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Glp Training Required Flag' ;
    rdfs:comment 'Indicates whether this role requires mandatory Good Laboratory Practice training per FDA GLP regulations. True for preclinical research and toxicology study personnel. Drives GLP curriculum assignment and regulatory compliance.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpTrainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Training Required Flag' ;
    rdfs:comment 'Indicates whether this role requires mandatory Good Manufacturing Practice training per 21 CFR Part 211. True for manufacturing, quality control, and quality assurance personnel. Drives cGMP curriculum assignment and FDA inspection readiness.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Hierarchical level of the role within the organization, used for compensation banding, career progression, and span-of-control analysis. [ENUM-REF-CANDIDATE: entry|intermediate|senior|lead|principal|director|executive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum formal education credential required for this role (e.g., Bachelor of Science in Chemistry for QC Analyst, Doctorate in Pharmacy for Medical Affairs). Used in candidate screening and qualification verification.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for this role. Used in candidate screening, internal mobility decisions, and compensation benchmarking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalRequirements rdf:type rdf:Property ;
    rdfs:label 'Physical Requirements' ;
    rdfs:comment 'Description of physical demands and working conditions for this role (e.g., standing for extended periods, lifting up to 50 lbs, cleanroom environment, laboratory safety protocols). Used for ADA compliance and workplace safety planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredEducationField rdf:type rdf:Property ;
    rdfs:label 'Preferred Education Field' ;
    rdfs:comment 'Preferred academic discipline or field of study for this role (e.g., Chemistry, Biochemistry, Pharmacology, Life Sciences, Engineering). Used in talent acquisition and succession planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileDescription rdf:type rdf:Property ;
    rdfs:label 'Profile Description' ;
    rdfs:comment 'Comprehensive narrative describing the purpose, scope, and key responsibilities of the role. Includes regulatory context for GxP-critical roles and quality-critical functions.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileTitle rdf:type rdf:Property ;
    rdfs:label 'Profile Title' ;
    rdfs:comment 'Official title of the job profile as it appears in organizational charts, position postings, and regulatory documentation (e.g., Senior Quality Control Analyst, Clinical Research Associate II, Manufacturing Technician III).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRoleClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Role Classification' ;
    rdfs:comment 'Classification indicating whether the role performs GxP-critical activities (GCP, GMP, GLP), quality-critical functions requiring heightened training and qualification, or non-regulated administrative functions. Drives training curriculum and audit scope.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible Flag' ;
    rdfs:comment 'Indicates whether this role is eligible for remote or hybrid work arrangements. False for roles requiring on-site presence (manufacturing, laboratory, clinical site personnel). Used in workforce flexibility planning and talent attraction.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of mandatory professional certifications or licenses required for this role (e.g., Certified Quality Auditor, Registered Pharmacist, Project Management Professional). Drives qualification tracking and audit compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleBasedAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Role Based Access Level' ;
    rdfs:comment 'Default system access level assigned to this role for regulated systems (LIMS, MES, QMS, CTMS). Drives 21 CFR Part 11 compliance for electronic records and signatures, and supports least-privilege access control.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyTrainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Training Required Flag' ;
    rdfs:comment 'Indicates whether this role requires mandatory occupational health and safety training (e.g., hazardous materials handling, biosafety, radiation safety, ergonomics). True for laboratory, manufacturing, and clinical roles. Drives OSHA compliance.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sopList rdf:type rdf:Property ;
    rdfs:label 'Sop List' ;
    rdfs:comment 'Comma-separated list of SOP identifiers that personnel in this role must be trained on and qualified to execute. Critical for GxP roles and quality-critical functions. Drives training curriculum and audit trail.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanningTier rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Tier' ;
    rdfs:comment 'Priority tier for succession planning and talent pipeline development. Critical for roles with high business impact, specialized expertise, or regulatory accountability (e.g., Qualified Person, Head of Quality). Used in talent review and development planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisory Flag' ;
    rdfs:comment 'Indicates whether this role has direct supervisory or managerial responsibilities over other employees. Used in organizational structure modeling, span-of-control analysis, and leadership development planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Expected percentage of work time requiring business travel (0-100). Used in candidate screening, expense budgeting, and work-life balance planning. High for field-based roles (CRAs, sales reps, auditors).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalSpanOfControl rdf:type rdf:Property ;
    rdfs:label 'Typical Span Of Control' ;
    rdfs:comment 'Typical number of direct reports for supervisory roles. Used in organizational design, workforce planning, and management capacity analysis. Null for non-supervisory roles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique identifier for the leave request transaction. Primary key for the leave request record.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLeaveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Employee Id' ;
    rdfs:comment 'Identifier of the employee submitting the leave request. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLeaveUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Leave Updated By User Employee Id' ;
    rdfs:comment 'System user identifier of the person who last modified the leave request record. Used for audit trail and compliance with 21 CFR Part 11 electronic records requirements.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Free-text comments provided by the approver during the approval or rejection decision. May include conditions, alternative arrangements, or reasons for rejection.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of supporting documents attached to the leave request (e.g., medical certificates, travel itineraries, legal notices). Used for compliance verification and audit readiness.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:balanceAfter rdf:type rdf:Property ;
    rdfs:label 'Balance After' ;
    rdfs:comment 'Employee leave balance in days for the applicable leave type after this request was approved and deducted. Calculated as balance_before minus duration_days. Used for entitlement tracking and compliance.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceBefore rdf:type rdf:Property ;
    rdfs:label 'Balance Before' ;
    rdfs:comment 'Employee leave balance in days for the applicable leave type immediately before this request was approved. Snapshot value for audit trail and balance reconciliation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total number of working hours requested for leave. Calculated based on employee work schedule and used for hourly leave tracking and payroll deduction calculations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyContactNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Notified Flag' ;
    rdfs:comment 'Indicates whether the employees emergency contact was notified about the leave (True) or not (False). Typically True for extended medical or emergency leave situations.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpCriticalRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Critical Role Flag' ;
    rdfs:comment 'Indicates whether the employee holds a GxP-critical role (GMP, GCP, GLP) requiring special absence management and substitute qualification verification (True) or not (False). Used for regulatory compliance and audit readiness for FDA/EMA inspections.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:halfDayFlag rdf:type rdf:Property ;
    rdfs:label 'Half Day Flag' ;
    rdfs:comment 'Indicates whether the leave request is for a half-day absence (True) or full-day absence (False). Used for precise leave balance calculation and workforce scheduling.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:halfDayPeriod rdf:type rdf:Property ;
    rdfs:label 'Half Day Period' ;
    rdfs:comment 'Specifies which half of the day is requested for leave when half_day_flag is True. AM=morning absence, PM=afternoon absence. Null for full-day leave requests.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Handover Completed Flag' ;
    rdfs:comment 'Indicates whether the employee has completed the work handover process to the substitute or team before starting leave (True) or not (False). Used for operational readiness tracking in GxP-regulated functions.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveTypeCode rdf:type rdf:Property ;
    rdfs:label 'Leave Type Code' ;
    rdfs:comment 'Classification of the leave request type. Determines entitlement rules, approval workflows, and payroll treatment. ANNUAL=paid annual vacation, SICK=illness absence, PARENTAL=family care leave, MATERNITY=maternity leave, PATERNITY=paternity leave, STUDY=educational leave, BEREAVEMENT=compassionate leave, UNPAID=unpaid time off, SABBATICAL=extended career break, JURY_DUTY=civic duty, MILITARY=military service. [ENUM-REF-CANDIDATE: ANNUAL|SICK|PARENTAL|MATERNITY|PATERNITY|STUDY|BEREAVEMENT|UNPAID|SABBATICAL|JURY_DUTY|MILITARY — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificateReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Received Flag' ;
    rdfs:comment 'Indicates whether the required medical certificate has been received and verified (True) or is still outstanding (False). Null if medical certificate is not required for this request.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Required Flag' ;
    rdfs:comment 'Indicates whether a medical certificate or doctors note is required for this leave request (True) or not (False). Typically True for sick leave exceeding a threshold duration as per company policy or local labor law.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paidFlag rdf:type rdf:Property ;
    rdfs:label 'Paid Flag' ;
    rdfs:comment 'Indicates whether the leave period is paid (True) or unpaid (False). Determines payroll treatment and salary deduction requirements. Derived from leave type and employee entitlement rules.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollPeriod rdf:type rdf:Property ;
    rdfs:label 'Payroll Period' ;
    rdfs:comment 'Payroll period (YYYY-MM format) in which the leave impact was processed for salary calculation. Used for payroll reconciliation and financial reporting.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed Flag' ;
    rdfs:comment 'Indicates whether the leave request has been processed in the payroll system for salary adjustment or deduction (True) or is pending payroll processing (False). Used for payroll reconciliation and audit trail.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text explanation provided by the employee describing the reason for the leave request. Optional field for additional context beyond the standardized reason code.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnToWorkConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Return To Work Confirmed Flag' ;
    rdfs:comment 'Indicates whether the employees return to work has been confirmed by the manager or HR (True) or is pending confirmation (False). Used for attendance tracking and workforce availability updates.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Actual date when the employee returned to work after the leave period. May differ from the planned end_date if leave was extended or curtailed. Used for attendance reconciliation and workforce planning accuracy.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Unique identifier for the payroll processing cycle. Primary key for the payroll run entity.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:payrollPeriodId rdf:type rdf:Property ;
    rdfs:label 'Payroll Period Id' ;
    rdfs:comment 'Foreign key linking to workforce.payroll_period. Business justification: Payroll runs occur within defined payroll periods. Currently payroll_run has period dates as attributes but no FK to the payroll_period master table. The start and end dates can be derived from payrol' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollPeriod .

ind:primaryPayrollEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payroll Employee Id' ;
    rdfs:comment 'Employee identifier of the payroll specialist or HR administrator who executed this payroll run. Used for audit trail and accountability per SOX (Sarbanes-Oxley Act) compliance requirements.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Fiscal period to which this payroll run is posted in SAP FI (format: YYYY-MM, e.g., 2024-01). Used for general ledger reconciliation and financial statement preparation.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDefault rdf:type rdf:Property ;
    rdfs:label 'Cost Center Default' ;
    rdfs:comment 'Default cost center for payroll cost allocation when employee-specific cost centers are not provided. Used for SAP CO (Controlling) module integration and departmental expense tracking.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Fi Document Number' ;
    rdfs:comment 'SAP FI document number generated when payroll costs are posted to the general ledger. Provides audit trail linking payroll transactions to financial statements. Ten-digit numeric identifier.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollArea rdf:type rdf:Property ;
    rdfs:label 'Payroll Area' ;
    rdfs:comment 'Organizational unit representing the country, legal entity, or payroll processing group (e.g., US01, UK01, DE01). Determines payroll calendar, payment frequency, and regulatory jurisdiction. Maps to SAP Payroll Area configuration.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollFrequency rdf:type rdf:Property ;
    rdfs:label 'Payroll Frequency' ;
    rdfs:comment 'Frequency of payroll processing for this run (monthly, semi-monthly, bi-weekly, weekly, quarterly, annual). Determines the cadence of payroll cycles and employee payment schedules.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunNumber rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Number' ;
    rdfs:comment 'Business identifier for the payroll run, typically formatted as a human-readable code used in SAP S/4HANA HCM Payroll module for tracking and reconciliation purposes.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollSchema rdf:type rdf:Property ;
    rdfs:label 'Payroll Schema' ;
    rdfs:comment 'Technical identifier for the payroll calculation logic and rules applied in this run (e.g., US01, UK01). Defines wage types, tax rules, and deduction sequences per jurisdiction in SAP HCM.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDefault rdf:type rdf:Property ;
    rdfs:label 'Profit Center Default' ;
    rdfs:comment 'Default profit center for payroll cost allocation when employee-specific profit centers are not provided. Used for SAP CO profitability analysis and segment reporting.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Free-text explanation for why this payroll run was reversed or cancelled. Required for audit documentation and root cause analysis of payroll errors. Null if run was not reversed.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when the payroll run was reversed. Null if run was not reversed. Used for audit trail and financial reconciliation.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the payroll run. Draft = initial creation; Simulated = test run for validation; Released = approved for processing; Posted = finalized and integrated to FI; Reversed = corrected/voided; Cancelled = aborted before completion.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payroll run purpose. Regular = standard periodic payroll; Off-cycle = unscheduled payment (e.g., new hire, termination); Correction = adjustment to prior run; Bonus = incentive/commission payment; Final = termination settlement; Advance = early payment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEmployeesProcessed rdf:type rdf:Property ;
    rdfs:label 'Total Employees Processed' ;
    rdfs:comment 'Count of employees included in this payroll run. Used for reconciliation and audit purposes to ensure all eligible employees received payslips.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalGrossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Total Gross Pay Amount' ;
    rdfs:comment 'Aggregate gross pay across all employees in this run before any deductions (base salary + overtime + bonuses + allowances). Used for financial reconciliation with SAP FI Cost of Goods Sold (COGS) and Profit and Loss (P&L) reporting.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetPayAmount rdf:type rdf:Property ;
    rdfs:label 'Total Net Pay Amount' ;
    rdfs:comment 'Aggregate net pay across all employees in this run after all deductions (gross pay - taxes - social security - pension - other deductions). Represents the total cash disbursement required for this payroll cycle.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOtherDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Other Deductions Amount' ;
    rdfs:comment 'Aggregate of all other deductions not classified as tax, social security, or pension (e.g., health insurance premiums, union dues, garnishments, loan repayments). Used for detailed payroll reconciliation.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPensionContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Pension Contribution Amount' ;
    rdfs:comment 'Aggregate retirement plan contributions (employee + employer portions) for this run. Includes 401(k), pension schemes, or equivalent per jurisdiction. Must be remitted to pension administrators.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSocialSecurityAmount rdf:type rdf:Property ;
    rdfs:label 'Total Social Security Amount' ;
    rdfs:comment 'Aggregate social security contributions (employee + employer portions) for this run. Includes FICA (US), National Insurance (UK), or equivalent per jurisdiction. Must be remitted to government agencies.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Withheld Amount' ;
    rdfs:comment 'Aggregate income tax withheld from all employees in this run (federal, state, local). Must be remitted to tax authorities per statutory deadlines. Critical for compliance with IRS, HMRC, and other tax agencies.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payslipId rdf:type rdf:Property ;
    rdfs:label 'Payslip Id' ;
    rdfs:comment 'Unique identifier for the payslip record. Primary key for the payslip entity.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Finance Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Workforce payslips should link to finance journal entries for payroll accounting and financial reporting. This enables integrated payroll processing with proper financial controls and GL posting.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:payslipApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Payslip Approved By User Employee Id' ;
    rdfs:comment 'User identifier of the payroll administrator or manager who approved this payslip for payment. Required for SOX compliance and audit trail.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:payslipEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Payslip Employee Id' ;
    rdfs:comment 'Reference to the employee who received this payslip. Links to the employee master data record.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allowances rdf:type rdf:Property ;
    rdfs:label 'Allowances' ;
    rdfs:comment 'Sum of all allowances paid in this period, including housing, transportation, meal, shift, and other statutory or contractual allowances.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution where the employee bank account is held, used for payment reconciliation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseSalary rdf:type rdf:Property ;
    rdfs:label 'Base Salary' ;
    rdfs:comment 'The regular base salary amount for the payroll period, excluding overtime, bonuses, and allowances.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusPayment rdf:type rdf:Property ;
    rdfs:label 'Bonus Payment' ;
    rdfs:comment 'Discretionary or performance-based bonus payments included in this payslip, such as annual bonuses, spot awards, or incentive payments.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generated Timestamp' ;
    rdfs:comment 'The date and time when this payslip record was generated by the payroll system. Represents the payroll calculation event timestamp.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossPay rdf:type rdf:Property ;
    rdfs:label 'Gross Pay' ;
    rdfs:comment 'Total gross earnings before any deductions. Sum of base salary, overtime, bonuses, and allowances.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Deduction' ;
    rdfs:comment 'Employee portion of health insurance premiums deducted from gross pay for medical, dental, and vision coverage.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total number of regular hours worked during the payroll period, excluding overtime hours. Used for hourly wage calculations.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveBalance rdf:type rdf:Property ;
    rdfs:label 'Leave Balance' ;
    rdfs:comment 'Remaining leave balance available to the employee as of the end of this payroll period, expressed in days.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveDaysTaken rdf:type rdf:Property ;
    rdfs:label 'Leave Days Taken' ;
    rdfs:comment 'Number of paid leave days taken during the payroll period, including vacation, sick leave, and other paid time off.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPay rdf:type rdf:Property ;
    rdfs:label 'Net Pay' ;
    rdfs:comment 'Final take-home pay amount after all deductions. Calculated as gross pay minus total deductions. This is the amount disbursed to the employee.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductions rdf:type rdf:Property ;
    rdfs:label 'Other Deductions' ;
    rdfs:comment 'Sum of all other deductions not categorized above, including union dues, garnishments, loan repayments, and voluntary deductions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Total number of overtime hours worked during the payroll period, including regular overtime and premium overtime.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePay rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay' ;
    rdfs:comment 'Total overtime compensation for the payroll period, including regular overtime and premium overtime rates.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payslipNumber rdf:type rdf:Property ;
    rdfs:label 'Payslip Number' ;
    rdfs:comment 'Externally visible unique payslip document number assigned by the payroll system. Used for employee self-service and audit trail.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipStatus rdf:type rdf:Property ;
    rdfs:label 'Payslip Status' ;
    rdfs:comment 'Current lifecycle status of the payslip record. Tracks progression from draft through approval, payment, and any subsequent corrections or voids.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionContribution rdf:type rdf:Property ;
    rdfs:label 'Pension Contribution' ;
    rdfs:comment 'Employee pension or retirement plan contributions deducted from gross pay, including mandatory and voluntary contributions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityContribution rdf:type rdf:Property ;
    rdfs:label 'Social Security Contribution' ;
    rdfs:comment 'Employee portion of social security or national insurance contributions deducted from gross pay, as required by jurisdiction.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxDeduction rdf:type rdf:Property ;
    rdfs:label 'Tax Deduction' ;
    rdfs:comment 'Total income tax withheld from gross pay for the payroll period, including federal, state, and local taxes as applicable by jurisdiction.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Deductions' ;
    rdfs:comment 'Sum of all deductions from gross pay, including tax, social security, pension, health insurance, and other deductions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateGross rdf:type rdf:Property ;
    rdfs:label 'Year To Date Gross' ;
    rdfs:comment 'Cumulative gross pay from the beginning of the calendar or fiscal year through the end of this payroll period. Used for tax reporting and compliance.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateNet rdf:type rdf:Property ;
    rdfs:label 'Year To Date Net' ;
    rdfs:comment 'Cumulative net pay from the beginning of the calendar or fiscal year through the end of this payroll period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateTax rdf:type rdf:Property ;
    rdfs:label 'Year To Date Tax' ;
    rdfs:comment 'Cumulative income tax withheld from the beginning of the calendar or fiscal year through the end of this payroll period. Used for tax reporting and W-2/T4 preparation.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed. Links to the employee master record.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calibrationSessionDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Session Date' ;
    rdfs:comment 'Date when the review was discussed and calibrated in a management calibration session to ensure consistency across the organization.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Impact Flag' ;
    rdfs:comment 'Indicates whether this review will impact compensation decisions such as merit increases or bonuses (True/False).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyCollaborationRating rdf:type rdf:Property ;
    rdfs:label 'Competency Collaboration Rating' ;
    rdfs:comment 'Rating for teamwork, cross-functional collaboration, and communication competencies.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Competency Compliance Rating' ;
    rdfs:comment 'Rating for adherence to Good Clinical Practice (GCP), Good Manufacturing Practice (GMP), Good Laboratory Practice (GLP), and other regulatory compliance standards.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyLeadershipRating rdf:type rdf:Property ;
    rdfs:label 'Competency Leadership Rating' ;
    rdfs:comment 'Rating for leadership and people management competencies.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyTechnicalRating rdf:type rdf:Property ;
    rdfs:label 'Competency Technical Rating' ;
    rdfs:comment 'Rating for technical competencies specific to the employee\'s role (e.g., GMP knowledge, laboratory techniques, regulatory expertise).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentAreasSummary rdf:type rdf:Property ;
    rdfs:label 'Development Areas Summary' ;
    rdfs:comment 'Narrative summary of areas where the employee needs improvement or further development.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlan rdf:type rdf:Property ;
    rdfs:label 'Development Plan' ;
    rdfs:comment 'Detailed development plan outlining specific actions, training, or experiences to support the employee\'s growth and address development areas.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Date' ;
    rdfs:comment 'Date when the employee acknowledged the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Flag' ;
    rdfs:comment 'Indicates whether the employee has acknowledged receipt and review of their performance evaluation (True/False).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment' ;
    rdfs:comment 'Employee\'s self-assessment narrative reflecting on their own performance, achievements, and development needs.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Score' ;
    rdfs:comment 'Weighted average score of all individual and team goals achieved during the review period (typically 0-100 or 0-5 scale).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gxpTrainingComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Training Compliance Flag' ;
    rdfs:comment 'Indicates whether the employee maintained compliance with required Good Clinical Practice (GCP), Good Manufacturing Practice (GMP), and Good Laboratory Practice (GLP) training during the review period (True/False). Critical for FDA and EMA audit readiness.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:individualGoalsCount rdf:type rdf:Property ;
    rdfs:label 'Individual Goals Count' ;
    rdfs:comment 'Number of individual goals defined for the employee during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meritIncreaseEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Eligibility Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for a merit-based salary increase based on this review (True/False).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'The overall performance rating assigned to the employee for the review period. [ENUM-REF-CANDIDATE: exceeds_expectations|meets_expectations|needs_improvement|unsatisfactory|outstanding|developing|not_rated — promote to reference product]' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score representing the overall performance rating (e.g., 1.0 to 5.0 scale). Used for quantitative analysis and compensation planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceImprovementPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Improvement Plan Flag' ;
    rdfs:comment 'Indicates whether the employee has been placed on a Performance Improvement Plan (PIP) as a result of this review (True/False).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Readiness Flag' ;
    rdfs:comment 'Indicates whether the employee is considered ready for promotion based on this review (True/False).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the performance review process was fully completed, including all approvals and employee acknowledgement.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCycleType rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Type' ;
    rdfs:comment 'The type of review cycle (annual, mid-year, probationary, project-based, quarterly, or ad-hoc).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Detailed comments and feedback provided by the reviewer regarding the employee\'s performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Narrative summary of the employee\'s key strengths and positive contributions during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionCandidateFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Candidate Flag' ;
    rdfs:comment 'Indicates whether the employee is identified as a succession candidate for critical roles (True/False).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teamGoalsCount rdf:type rdf:Property ;
    rdfs:label 'Team Goals Count' ;
    rdfs:comment 'Number of team or departmental goals assigned to the employee during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Reference to the supervisory position to which this position reports. Defines the reporting line in the organizational hierarchy. Nullable for top-level executive positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:applicableSopList rdf:type rdf:Property ;
    rdfs:label 'Applicable Sop List' ;
    rdfs:comment 'Comma-separated list of Standard Operating Procedure (SOP) document numbers or identifiers applicable to the position. Defines the controlled procedures the position holder must be trained on and follow. Critical for quality-critical and regulated roles subject to audit.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Full-time equivalent allocation for the position. 1.00 represents full-time; 0.50 represents half-time. Used for headcount planning and budget calculations. Supports fractional positions and job-sharing arrangements.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeBand rdf:type rdf:Property ;
    rdfs:label 'Grade Band' ;
    rdfs:comment 'Compensation grade or pay band assigned to the position, determining salary range and benefits eligibility. Business-confidential classification used for compensation planning and budgeting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGcpRegulated rdf:type rdf:Property ;
    rdfs:label 'Is Gcp Regulated' ;
    rdfs:comment 'Indicates whether the position performs Good Clinical Practice (GCP)-regulated activities requiring International Council for Harmonisation (ICH) GCP training and compliance per ICH E6(R2). True for clinical research, clinical operations, and medical affairs roles.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGlpRegulated rdf:type rdf:Property ;
    rdfs:label 'Is Glp Regulated' ;
    rdfs:comment 'Indicates whether the position performs Good Laboratory Practice (GLP)-regulated activities requiring GLP training and compliance per 21 CFR Part 58. True for preclinical research and toxicology roles.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGmpRegulated rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Regulated' ;
    rdfs:comment 'Indicates whether the position performs GMP-regulated activities requiring Current Good Manufacturing Practice (cGMP) training, qualification, and audit trail documentation per 21 CFR Part 211. True for manufacturing, quality control, and quality assurance roles.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQualityCritical rdf:type rdf:Property ;
    rdfs:label 'Is Quality Critical' ;
    rdfs:comment 'Indicates whether the position is designated as quality-critical, requiring enhanced qualification, training documentation, and role-based access controls per Quality Management System (QMS) requirements. Subject to stricter audit scrutiny by Food and Drug Administration (FDA) and European Medicines Agency (EMA).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryTrainingCurricula rdf:type rdf:Property ;
    rdfs:label 'Mandatory Training Curricula' ;
    rdfs:comment 'Comma-separated list of mandatory training course codes or curricula identifiers required for the position. Includes GMP, GCP, GLP, safety, compliance, and role-specific technical training. Used to auto-assign training upon position assignment and track compliance for FDA/EMA inspections.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Externally-known unique business identifier for the position, used in requisitions, organizational charts, and Human Resources Information System (HRIS) integrations. Typically alphanumeric code assigned by HR.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed narrative description of the position\'s purpose, key responsibilities, and scope of work. Used for recruitment job postings, performance management, and organizational documentation.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle state of the position. Active indicates the position is approved and available; vacant means unfilled; filled means occupied by an employee; frozen means temporarily unavailable for hiring; closed means permanently eliminated; pending_approval means awaiting budget or organizational approval.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Classification of the position by employment arrangement. Permanent indicates regular full-time or part-time employment; temporary indicates fixed-term employment; contract indicates external contractor; intern indicates trainee or student; consultant indicates professional services engagement.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCompetencies rdf:type rdf:Property ;
    rdfs:label 'Required Competencies' ;
    rdfs:comment 'Comma-separated list of competency codes or descriptors defining the skills, knowledge, and behaviors required for successful performance in the position. Used for talent assessment, development planning, and succession planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Required Education Level' ;
    rdfs:comment 'Minimum educational qualification required for the position. Used for recruitment screening and competency verification. Critical for roles requiring scientific or technical expertise in pharmaceutical development and manufacturing.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Required Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for the position. Used for recruitment qualification and career progression planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresCsvTraining rdf:type rdf:Property ;
    rdfs:label 'Requires Csv Training' ;
    rdfs:comment 'Indicates whether the position requires Computer System Validation (CSV) training per 21 CFR Part 11 for roles that create, modify, or approve electronic records in validated systems. True for IT, quality, and regulated system users.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDataIntegrityTraining rdf:type rdf:Property ;
    rdfs:label 'Requires Data Integrity Training' ;
    rdfs:comment 'Indicates whether the position requires data integrity training covering ALCOA+ principles (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available) per FDA and EMA data integrity guidance. Critical for laboratory, manufacturing, and quality roles.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workSchedule rdf:type rdf:Property ;
    rdfs:label 'Work Schedule' ;
    rdfs:comment 'Standard work schedule pattern for the position. Standard indicates regular business hours; shift indicates rotating or fixed shift work (common in manufacturing); flexible indicates flexible hours; remote indicates fully remote work; hybrid indicates combination of on-site and remote.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Id' ;
    rdfs:comment 'Unique identifier for the qualification record. Primary key for the qualification entity.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qualification Employee Id' ;
    rdfs:comment 'Identifier of the employee who holds this qualification. Links to the employee master record.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Level of access or permission granted within the system. Read-only allows viewing; read-write allows data entry; approve allows electronic signature and approval; admin allows configuration; super-user allows full control.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Flag' ;
    rdfs:comment 'Indicates whether this qualification record is subject to electronic audit trail requirements under 21 CFR Part 11. True if audit trail is required; false otherwise.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Detailed explanation of why the qualification or system access is required for the employee\'s role. Supports audit trails and access review processes for SOX and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyArea rdf:type rdf:Property ;
    rdfs:label 'Competency Area' ;
    rdfs:comment 'Functional or technical area of competency covered by this qualification (e.g., \'Aseptic Processing\', \'Clinical Monitoring\', \'Analytical Chemistry\', \'Quality Auditing\', \'Controlled Substance Handling\'). Supports skills matrix and workforce planning.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the organization, regulatory authority, or internal department that issued or granted the qualification. Examples: \'FDA\', \'EMA\', \'Internal Quality Assurance\', \'Society of Clinical Research Associates\', \'DEA\'.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Access Review Date' ;
    rdfs:comment 'Date of the most recent periodic access review for system access qualifications. Supports SOX compliance and segregation of duties controls.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationCode rdf:type rdf:Property ;
    rdfs:label 'Qualification Code' ;
    rdfs:comment 'Short alphanumeric code or identifier for the qualification used in internal systems and training records. Enables quick lookup and reporting.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationName rdf:type rdf:Property ;
    rdfs:label 'Qualification Name' ;
    rdfs:comment 'Full descriptive name of the qualification, certification, or authorization. Examples: \'GMP Aseptic Processing Qualification\', \'ICH-GCP Clinical Monitor Certification\', \'HPLC Method Qualification for Product X\'.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this qualification is mandated by regulatory authorities (FDA, EMA, DEA) or industry standards (GMP, GCP, GLP). True if regulatory-required; false if voluntary or internal.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date on which the qualification or system access was revoked or withdrawn. Null if the qualification has never been revoked.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation of why the qualification or system access was revoked (e.g., \'Employee termination\', \'Role change\', \'Compliance violation\', \'Failed re-certification\'). Supports audit trails and access control reviews.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the supporting documentation for this qualification (e.g., certificate scan, training transcript, approval memo). Enables retrieval of evidence for audits and inspections.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemRoleName rdf:type rdf:Property ;
    rdfs:label 'System Role Name' ;
    rdfs:comment 'Name of the role or permission set assigned to the employee within the system (e.g., \'QC Analyst\', \'Manufacturing Operator\', \'Clinical Data Manager\', \'Quality Reviewer\'). Defines the scope of system access.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHours rdf:type rdf:Property ;
    rdfs:label 'Training Hours' ;
    rdfs:comment 'Total number of training hours completed by the employee to achieve this qualification. Tracks continuing education and professional development requirements.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryRecruitmentHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Recruitment Hiring Manager Employee Id' ;
    rdfs:comment 'Employee identifier of the hiring manager responsible for the requisition approval, candidate selection, and final hiring decision.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRecruitmentRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Recruitment Recruiter Employee Id' ;
    rdfs:comment 'Employee identifier of the talent acquisition specialist or recruiter assigned to manage the recruitment process for this requisition.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRecruitmentApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Recruitment Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the approver who authorized the requisition (typically HR Director, Finance Controller, or senior executive with budget authority).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedSalaryRangeMax rdf:type rdf:Property ;
    rdfs:label 'Approved Salary Range Max' ;
    rdfs:comment 'Maximum approved annual salary or hourly rate for the position, as authorized by compensation and budget approval process.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedSalaryRangeMin rdf:type rdf:Property ;
    rdfs:label 'Approved Salary Range Min' ;
    rdfs:comment 'Minimum approved annual salary or hourly rate for the position, as authorized by compensation and budget approval process.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the budget approval document or internal order authorizing the headcount and associated compensation costs.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountQuantity rdf:type rdf:Property ;
    rdfs:label 'Headcount Quantity' ;
    rdfs:comment 'Number of positions to be filled under this requisition. Typically 1 for individual roles, may be greater for bulk hiring initiatives.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Comprehensive description of the role responsibilities, key accountabilities, reporting relationships, and success criteria. Used in job postings and candidate communications.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPostingTitle rdf:type rdf:Property ;
    rdfs:label 'Job Posting Title' ;
    rdfs:comment 'External-facing job title used in job postings and advertisements. May differ from internal position title for market competitiveness and candidate attraction.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredQualifications rdf:type rdf:Property ;
    rdfs:label 'Preferred Qualifications' ;
    rdfs:comment 'Desired but not mandatory qualifications, skills, and experience that would make a candidate more competitive (e.g., experience with Veeva Vault, knowledge of ICH guidelines).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredQualifications rdf:type rdf:Property ;
    rdfs:label 'Required Qualifications' ;
    rdfs:comment 'Detailed description of mandatory educational qualifications, certifications, licenses, and professional credentials required for the position (e.g., PhD in Chemistry, PharmD license, CQA certification).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionCloseDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Close Date' ;
    rdfs:comment 'Date when the requisition was closed, either due to successful fill, cancellation, or other closure reason.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionOpenDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Open Date' ;
    rdfs:comment 'Date when the requisition was approved and opened for active recruitment, marking the start of the talent acquisition process.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the approved salary range (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingChannel rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channel' ;
    rdfs:comment 'Primary recruitment sourcing strategy for this requisition: internal mobility, external job boards, employee referral program, recruitment agency, campus recruiting, LinkedIn, or other job posting platforms. [ENUM-REF-CANDIDATE: internal|external|referral|agency|campus|linkedin|job_board — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired date by which the hired candidate should commence employment. Used for workforce planning and recruitment timeline management.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:successionPlanId rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Id' ;
    rdfs:comment 'Unique identifier for the succession plan record. Primary key for the succession plan entity.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySuccessionIncumbentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Succession Incumbent Employee Id' ;
    rdfs:comment 'Reference to the current employee holding the target position. May be null if position is vacant. Links to employee master data.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternarySuccessionCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Succession Created By Employee Id' ;
    rdfs:comment 'Reference to the employee who created this succession plan record. Links to employee master data. Used for audit trails and accountability.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinarySuccessionLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Succession Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who last modified this succession plan record. Links to employee master data. Used for audit trails and accountability.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetPositionId rdf:type rdf:Property ;
    rdfs:label 'Target Position Id' ;
    rdfs:comment 'Reference to the critical position for which succession planning is being performed. Links to the position master record.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:tertiarySuccessionApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Succession Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved this succession plan. Typically senior leadership or executive responsible for talent management. Links to employee master data. Null if plan not yet approved.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualTransitionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Transition Date' ;
    rdfs:comment 'Actual date when the successor assumed the target position. Null if transition has not yet occurred. Used to measure succession planning effectiveness and close out completed plans.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:developmentGapSummary rdf:type rdf:Property ;
    rdfs:label 'Development Gap Summary' ;
    rdfs:comment 'Narrative summary of the competency, experience, and qualification gaps that must be addressed before the successor is ready to assume the target position. Informs individual development plan creation.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTransitionDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Transition Date' ;
    rdfs:comment 'Projected date when the successor is expected to assume the target position. May be based on incumbent retirement date, readiness timeline, or business planning. Null if transition timing is uncertain.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gxpQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Gxp Qualification Date' ;
    rdfs:comment 'Date when the successor achieved full GxP qualification for the target position. Null if qualification is not yet complete. Used for regulatory audit trails and requalification scheduling.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gxpQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gxp Qualification Status' ;
    rdfs:comment 'Status of the successors qualification for Good Manufacturing Practice (GMP), Good Clinical Practice (GCP), or Good Laboratory Practice (GLP) requirements applicable to the target position. Qualified indicates all required GxP training and assessments are current; In Progress indicates qualification activities underway; Not Started indicates qualification not yet initiated; Expired indicates requalification required; Waived indicates regulatory exemption granted.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpRequalificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Gxp Requalification Due Date' ;
    rdfs:comment 'Date by which the successor must complete GxP requalification activities to maintain qualification status for the target position. Null if initial qualification not yet achieved or if position does not require periodic requalification.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifiedPersonFlag rdf:type rdf:Property ;
    rdfs:label 'Qualified Person Flag' ;
    rdfs:comment 'Indicates whether the target position is a Qualified Person role as defined by EU GMP regulations. True if position requires QP designation; False otherwise. QP roles have heightened succession planning requirements due to regulatory mandate for batch release authority.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:readinessLevel rdf:type rdf:Property ;
    rdfs:label 'Readiness Level' ;
    rdfs:comment 'Assessment of the successors readiness to assume the target position. Ready Now indicates candidate can assume role immediately; 1-2 Years indicates near-term readiness with minor development; 3-5 Years indicates longer-term development required; Not Ready indicates significant gaps exist.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePharmacistFlag rdf:type rdf:Property ;
    rdfs:label 'Responsible Pharmacist Flag' ;
    rdfs:comment 'Indicates whether the target position is a Responsible Pharmacist role as defined by regulatory authorities. True if position requires Responsible Pharmacist designation; False otherwise. These roles have specific succession planning requirements for pharmacy operations continuity.' ;
    rdfs:domain ind:SuccessionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemAccessId rdf:type rdf:Property ;
    rdfs:label 'System Access Id' ;
    rdfs:comment 'Primary key for system_access' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySystemEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary System Employee Id' ;
    rdfs:comment 'Unique identifier of the employee to whom the system access is assigned. Links to the employee master data in the workforce domain.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternarySystemReviewedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary System Reviewed By Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who performed the most recent periodic access review, typically a manager or compliance officer.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinarySystemRevokedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary System Revoked By Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who revoked the access, typically a manager, compliance officer, or IT administrator.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySystemProvisionedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary System Provisioned By Employee Id' ;
    rdfs:comment 'Unique identifier of the IT or system administrator who provisioned the access in the target system. Supports segregation of duties between approval and execution.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Business-readable unique identifier for the access assignment, typically used for audit trail and reference purposes in access review documentation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the access assignment. Tracks whether the access is pending approval, active, suspended, revoked, expired, or under periodic review.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Access Flag' ;
    rdfs:comment 'Indicates whether this is an emergency or temporary access assignment granted outside normal approval workflows. Requires enhanced monitoring and post-event review.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegedAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Privileged Access Flag' ;
    rdfs:comment 'Indicates whether this access assignment includes privileged or administrative rights. True for super user, admin, or elevated access requiring enhanced controls and monitoring.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:provisioningDate rdf:type rdf:Property ;
    rdfs:label 'Provisioning Date' ;
    rdfs:comment 'Date on which the access was actually provisioned in the target system. May differ from approval date due to processing time or scheduled activation.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roleCode rdf:type rdf:Property ;
    rdfs:label 'Role Code' ;
    rdfs:comment 'System-specific technical code or identifier for the role. Used for system integration and automated provisioning workflows.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleName rdf:type rdf:Property ;
    rdfs:label 'Role Name' ;
    rdfs:comment 'Name of the system role or permission set assigned to the employee. Examples include Quality Manager, Manufacturing Operator, Clinical Data Manager, Regulatory Affairs Specialist.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationOfDutiesFlag rdf:type rdf:Property ;
    rdfs:label 'Segregation Of Duties Flag' ;
    rdfs:comment 'Indicates whether this access assignment has been evaluated for segregation of duties conflicts. True if SOD analysis has been performed and no conflicts exist.' ;
    rdfs:domain ind:SystemAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeAttendanceId rdf:type rdf:Property ;
    rdfs:label 'Time Attendance Id' ;
    rdfs:comment 'Unique identifier for the time and attendance record. Primary key for the time_attendance product.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Identifier of the employee for whom this time and attendance record is captured. Links to the employee master data.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceCode rdf:type rdf:Property ;
    rdfs:label 'Absence Code' ;
    rdfs:comment 'Code indicating the type of absence if the employee did not work (e.g., SICK, VAC, PTO, FMLA, UNPAID). Used for leave balance tracking and payroll processing.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceReason rdf:type rdf:Property ;
    rdfs:label 'Absence Reason' ;
    rdfs:comment 'Descriptive explanation of the absence reason. Provides additional context for HR and compliance reporting.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Worked' ;
    rdfs:comment 'The actual number of hours the employee worked, calculated from clock-in and clock-out timestamps minus break periods. Used for payroll processing and labor cost allocation.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attendanceDate rdf:type rdf:Property ;
    rdfs:label 'Attendance Date' ;
    rdfs:comment 'The calendar date on which the employee\'s time and attendance was recorded. Principal business event date for this transaction.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attendanceRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Attendance Record Number' ;
    rdfs:comment 'Externally-known unique business identifier for this time and attendance record, used for audit trails and payroll reconciliation.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total duration of break periods taken during the shift, measured in minutes. Deducted from gross time to calculate actual hours worked.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'The exact date and time when the employee clocked in or started their shift. Critical for GMP batch production documentation where personnel presence must be timestamped.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock Out Timestamp' ;
    rdfs:comment 'The exact date and time when the employee clocked out or ended their shift. Used to calculate actual hours worked and for GMP compliance documentation.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:earlyDepartureMinutes rdf:type rdf:Property ;
    rdfs:label 'Early Departure Minutes' ;
    rdfs:comment 'Number of minutes the employee left early compared to their scheduled end time. Used for attendance policy enforcement and performance tracking.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lateArrivalMinutes rdf:type rdf:Property ;
    rdfs:label 'Late Arrival Minutes' ;
    rdfs:comment 'Number of minutes the employee arrived late compared to their scheduled start time. Used for attendance policy enforcement and performance tracking.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Overtime Category' ;
    rdfs:comment 'Classification of overtime hours by compensation rate (e.g., time and half, double time, holiday premium). Determines the overtime multiplier for payroll. [ENUM-REF-CANDIDATE: standard|time_and_half|double_time|holiday|weekend|night_differential|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidBreakMinutes rdf:type rdf:Property ;
    rdfs:label 'Paid Break Minutes' ;
    rdfs:comment 'The portion of break time that is compensated according to company policy or labor agreements. Included in payroll calculations.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'Production order number to which the employee\'s time is allocated for GMP batch manufacturing. Links labor hours to specific batch production for cost accounting and compliance documentation.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'The portion of actual hours worked that are classified as regular hours (non-overtime). Used for standard payroll calculations.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours' ;
    rdfs:comment 'The number of hours the employee was scheduled to work on this date according to their shift assignment. Used for variance analysis and labor planning.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Code identifying the shift pattern assigned to the employee for this attendance record (e.g., DAY, NIGHT, SWING, ROTATING). Used for shift differential calculations and manufacturing scheduling.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeClockDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Time Clock Device Code' ;
    rdfs:comment 'Identifier of the physical time clock or biometric device used to capture the attendance record. Used for device audit trails and validation.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryMethod rdf:type rdf:Property ;
    rdfs:label 'Time Entry Method' ;
    rdfs:comment 'Method by which the time and attendance data was captured (e.g., biometric scanner, badge swipe, manual entry). Important for audit trails and data quality assessment. [ENUM-REF-CANDIDATE: biometric|badge_swipe|manual|mobile_app|web_portal|supervisor_entry|system_generated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unpaidBreakMinutes rdf:type rdf:Property ;
    rdfs:label 'Unpaid Break Minutes' ;
    rdfs:comment 'The portion of break time that is not compensated (e.g., meal breaks). Excluded from payroll calculations.' ;
    rdfs:domain ind:TimeAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Training Assignment Id' ;
    rdfs:comment 'Unique identifier for the training assignment record. Primary key for the training assignment entity.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTrainingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Employee Id' ;
    rdfs:comment 'Unique identifier of the employee to whom the training is assigned. Links to the employee master record.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryTrainingWaiverApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Training Waiver Approved By Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who approved the training waiver. Typically a quality assurance manager or training director. Null if no waiver was granted.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTrainingApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Training Approved By Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who approved or verified the training completion. Required for GxP-regulated training records. Null if approval is not yet completed.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the training assignment indicating whether it is mandatory (required for role or compliance), elective (optional for development), or recommended (suggested but not required).' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attemptsCount rdf:type rdf:Property ;
    rdfs:label 'Attempts Count' ;
    rdfs:comment 'The number of times the employee has attempted to complete the training. Tracks retakes and supports analysis of training effectiveness.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionScore rdf:type rdf:Property ;
    rdfs:label 'Completion Score' ;
    rdfs:comment 'The score or grade achieved by the employee upon completion of the training, expressed as a percentage (0.00 to 100.00). Null if training does not include assessment or is not yet completed.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxAttemptsAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Attempts Allowed' ;
    rdfs:comment 'The maximum number of attempts permitted for this training assignment. Null if unlimited attempts are allowed.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScoreRequired rdf:type rdf:Property ;
    rdfs:label 'Passing Score Required' ;
    rdfs:comment 'The minimum score required to pass the training, expressed as a percentage (0.00 to 100.00). Used to determine if completion_status should be marked as completed or failed.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requalificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Requalification Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) that the training requires periodic requalification. Drives automated reassignment workflows when expiration_date is reached.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCost rdf:type rdf:Property ;
    rdfs:label 'Training Cost' ;
    rdfs:comment 'The cost incurred for this training assignment, including course fees, materials, instructor costs, and employee time. Used for training budget analysis and ROI calculations. Expressed in the organization\'s reporting currency.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Method' ;
    rdfs:comment 'The method by which the training is delivered to the employee. Supports analysis of training effectiveness by delivery channel.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'The name of the organization or vendor that provided the training. May be internal (company name) or external (Contract Research Organization, training vendor). Supports vendor management and training quality analysis.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'The date on which the training waiver was approved. Null if no waiver was granted.' ;
    rdfs:domain ind:TrainingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:owningDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Owning Department Id' ;
    rdfs:comment 'Identifier of the department responsible for maintaining and updating the training course content (e.g., Quality Assurance, Clinical Operations, Manufacturing, Human Resources).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:assessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Required Flag' ;
    rdfs:comment 'Indicates whether a formal assessment (test, quiz, practical demonstration) is required to complete the training course. True if assessment is mandatory, False if completion is based on attendance only.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether a formal certification or certificate of completion is issued upon successful completion of the training course. True if certification is issued, False otherwise.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceuCredits rdf:type rdf:Property ;
    rdfs:label 'Ceu Credits' ;
    rdfs:comment 'Number of Continuing Education Unit credits awarded upon successful completion of the training course. Used for professional development tracking and external certification maintenance. Null if no CEU credits are awarded.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentOwnerName rdf:type rdf:Property ;
    rdfs:label 'Content Owner Name' ;
    rdfs:comment 'Name of the individual or role responsible for the accuracy and currency of the training course content (e.g., \'Quality Assurance Manager\', \'Clinical Training Lead\'). Point of contact for content-related questions.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique alphanumeric business identifier for the training course used across systems (e.g., GMP-101, GCP-ADV-205). Externally-known code used in training records and compliance documentation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Detailed description of the training course content, learning objectives, target audience, and prerequisites. Provides comprehensive information for employees and managers to understand course scope and applicability.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseLanguage rdf:type rdf:Property ;
    rdfs:label 'Course Language' ;
    rdfs:comment 'Primary language in which the training course content is delivered, using ISO 639-2 three-letter language codes (e.g., ENG for English, SPA for Spanish, DEU for German). Critical for global workforce training management.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseStatus rdf:type rdf:Property ;
    rdfs:label 'Course Status' ;
    rdfs:comment 'Current lifecycle status of the training course: draft (under development), active (available for enrollment), under_review (being updated or reviewed), retired (no longer offered but historical records maintained), or archived (historical record only).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseTitle rdf:type rdf:Property ;
    rdfs:label 'Course Title' ;
    rdfs:comment 'Full descriptive title of the training course as displayed to employees and in training catalogs (e.g., \'Good Manufacturing Practice Fundamentals\', \'Clinical Trial Protocol Design\').' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'Classification of the training course by requirement type: mandatory (required for all), elective (optional), role_based (required for specific roles), compliance (regulatory requirement), technical (job-specific skills), leadership (management development), or safety (workplace safety). [ENUM-REF-CANDIDATE: mandatory|elective|role_based|compliance|technical|leadership|safety — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseVersion rdf:type rdf:Property ;
    rdfs:label 'Course Version' ;
    rdfs:comment 'Version number of the training course content following semantic versioning (e.g., 1.0, 2.1, 3.5). Incremented when course content is updated. Essential for tracking which version employees completed for audit purposes.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Content Review Date' ;
    rdfs:comment 'Date when the training course content was last reviewed for accuracy, currency, and regulatory compliance. Used to ensure training materials remain current and compliant.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:learningObjectives rdf:type rdf:Property ;
    rdfs:label 'Learning Objectives' ;
    rdfs:comment 'Specific, measurable learning outcomes that participants will achieve upon successful completion of the training course. Defines competencies and knowledge gained.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxEnrollmentCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Enrollment Capacity' ;
    rdfs:comment 'Maximum number of participants that can enroll in a single session of the training course. Null if no capacity limit exists (e.g., for self-paced eLearning courses).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Review Date' ;
    rdfs:comment 'Date when the training course content is scheduled for its next periodic review. Ensures proactive maintenance of training materials and compliance with quality management system requirements.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prerequisites rdf:type rdf:Property ;
    rdfs:label 'Prerequisites' ;
    rdfs:comment 'List of prerequisite courses, certifications, or qualifications that must be completed before enrolling in this training course. Null if no prerequisites exist.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Approval Required Flag' ;
    rdfs:comment 'Indicates whether the training course content or curriculum requires approval or review by regulatory authorities (FDA, EMA, etc.) before deployment. True if regulatory approval is required, False otherwise.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory framework classification indicating whether the course is GxP-related (Good Practice): gxp (general Good Practice), gmp (Good Manufacturing Practice), gcp (Good Clinical Practice), glp (Good Laboratory Practice), gdp (Good Distribution Practice), or non_gxp (non-regulated training). Critical for audit trail and compliance reporting to FDA/EMA.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopReferenceNumbers rdf:type rdf:Property ;
    rdfs:label 'Sop Reference Numbers' ;
    rdfs:comment 'Comma-separated list of SOP document numbers that this training course covers or is based upon (e.g., \'SOP-QA-001, SOP-MFG-045\'). Links training to controlled documentation for audit trail purposes.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Id' ;
    rdfs:comment 'Primary key uniquely identifying each supply agreement record between a business partner and a material' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier is the preferred source for this material based on quality, reliability, cost, and strategic relationship. Used in automated source determination during procurement.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Status' ;
    rdfs:comment 'Current lifecycle status of this supply agreement. Active = currently valid for procurement, Inactive = not available for new orders, Pending = under negotiation, Expired = past valid_to_date.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Entity Registration Id' ;
    rdfs:comment 'Unique identifier for this legal entity country registration record. Primary key.' ;
    rdfs:domain ind:EntityRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:branchType rdf:type rdf:Property ;
    rdfs:label 'Branch Type' ;
    rdfs:comment 'Classification of the type of presence or establishment the legal entity maintains in this country' ;
    rdfs:domain ind:EntityRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Establishment Identifier' ;
    rdfs:comment 'Country-specific establishment identifier assigned by the regulatory authority for pharmaceutical operations in this jurisdiction' ;
    rdfs:domain ind:EntityRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialPlantDataId rdf:type rdf:Property ;
    rdfs:label 'Material Plant Data Id' ;
    rdfs:comment 'Unique identifier for the material plant data record. Primary key.' ;
    rdfs:domain ind:MaterialPlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Lot-sizing procedure that determines how order quantities are calculated during MRP runs. EX=Lot-for-lot, FX=Fixed lot size, HB=Replenishment to maximum stock, LZ=Economic order quantity, WB=Weekly lot size.' ;
    rdfs:domain ind:MaterialPlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'Material Requirements Planning procedure type that determines how the material is planned at this plant. PD=MRP, VB=Manual reorder point, VM=Forecast-based, VV=Reorder point planning, ND=No planning.' ;
    rdfs:domain ind:MaterialPlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantSpecificMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Plant Specific Material Number' ;
    rdfs:comment 'Plant-specific material identifier that may differ from the enterprise material number, used for local operations and legacy system integration.' ;
    rdfs:domain ind:MaterialPlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionScheduler rdf:type rdf:Property ;
    rdfs:label 'Production Scheduler' ;
    rdfs:comment 'Identifier or name of the production scheduler or planner responsible for this material at this plant, used for MRP exception management and planning coordination.' ;
    rdfs:domain ind:MaterialPlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionGroup rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Group' ;
    rdfs:comment 'Quality management inspection group code that defines which QC laboratory team is responsible for testing this material at this plant, linking to quality inspection procedures.' ;
    rdfs:domain ind:MaterialPlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory level at which a procurement or production order should be triggered for this material at this plant, expressed in the material base unit of measure.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocationDefault rdf:type rdf:Property ;
    rdfs:label 'Storage Location Default' ;
    rdfs:comment 'Default storage location code within the plant where this material is typically stored, used for automatic goods receipt and inventory management.' ;
    rdfs:domain ind:MaterialPlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStorageLocationDataId rdf:type rdf:Property ;
    rdfs:label 'Material Storage Location Data Id' ;
    rdfs:comment 'Unique identifier for this material-storage location configuration record. Primary key.' ;
    rdfs:domain ind:MaterialStorageLocationData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Batch Management Indicator' ;
    rdfs:comment 'Flag indicating whether batch-level tracking is required for this material at this storage location. May differ from material master if location-specific requirements apply.' ;
    rdfs:domain ind:MaterialStorageLocationData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin or shelf location within the storage location where this material is stored. Used for picking and putaway operations.' ;
    rdfs:domain ind:MaterialStorageLocationData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Quantity' ;
    rdfs:comment 'Minimum inventory level to maintain for this material at this storage location. Safety stock requirement.' ;
    rdfs:domain ind:MaterialStorageLocationData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickingArea rdf:type rdf:Property ;
    rdfs:label 'Picking Area' ;
    rdfs:comment 'Designated picking zone within the storage location for this material. Optimizes warehouse operations and order fulfillment.' ;
    rdfs:domain ind:MaterialStorageLocationData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'Warehouse management strategy for placing incoming goods of this material into this storage location. Examples: FIFO, FEFO, fixed bin, bulk storage.' ;
    rdfs:domain ind:MaterialStorageLocationData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBinType rdf:type rdf:Property ;
    rdfs:label 'Storage Bin Type' ;
    rdfs:comment 'Classification of the bin type used for this material at this storage location. Examples: pallet rack, shelf, bulk bin, cold storage bin.' ;
    rdfs:domain ind:MaterialStorageLocationData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitoring Required' ;
    rdfs:comment 'Flag indicating whether continuous temperature monitoring is required for this material at this storage location. Critical for cold-chain integrity and regulatory compliance.' ;
    rdfs:domain ind:MaterialStorageLocationData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pvAgreementProductScopeId rdf:type rdf:Property ;
    rdfs:label 'Pv Agreement Product Scope Id' ;
    rdfs:comment 'Unique surrogate identifier for this agreement-product coverage record. Primary key.' ;
    rdfs:domain ind:PvAgreementProductScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentReference rdf:type rdf:Property ;
    rdfs:label 'Amendment Reference' ;
    rdfs:comment 'Reference to the specific agreement amendment that added, modified, or removed this product from scope. Supports audit trail and compliance verification.' ;
    rdfs:domain ind:PvAgreementProductScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productInclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Product Inclusion Status' ;
    rdfs:comment 'Current lifecycle status of this product\'s inclusion in the agreement scope. ACTIVE = currently covered, PENDING = negotiated but not yet effective, SUSPENDED = temporarily out of scope, TERMINATED = permanently removed from scope.' ;
    rdfs:domain ind:PvAgreementProductScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialFormularyPositionId rdf:type rdf:Property ;
    rdfs:label 'Commercial Formulary Position Id' ;
    rdfs:comment 'Primary key for commercial_formulary_position' ;
    rdfs:domain ind:CommercialFormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formularyPositionId rdf:type rdf:Property ;
    rdfs:label 'Formulary Position Id' ;
    rdfs:comment 'Unique surrogate identifier for this formulary position record' ;
    rdfs:domain ind:CommercialFormularyPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'The contract or agreement reference number governing the commercial terms of this formulary position.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptCommitteeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Pt Committee Approval Date' ;
    rdfs:comment 'The date on which the payer\'s Pharmacy and Therapeutics committee approved this formulary position for this brand.' ;
    rdfs:domain ind:CommercialFormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impAdministrationId rdf:type rdf:Property ;
    rdfs:label 'Imp Administration Id' ;
    rdfs:comment 'Unique surrogate identifier for each IMP administration event record' ;
    rdfs:domain ind:ImpAdministration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:administeredByInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Administered By Investigator Id' ;
    rdfs:comment 'Reference to the investigator or qualified designee who administered or supervised the IMP administration' ;
    rdfs:domain ind:ImpAdministration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:accountabilityLogEntry rdf:type rdf:Property ;
    rdfs:label 'Accountability Log Entry' ;
    rdfs:comment 'Reference to the corresponding entry in the IMP accountability log maintained at the investigational site' ;
    rdfs:domain ind:ImpAdministration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrationDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Administration Deviation Flag' ;
    rdfs:comment 'Indicates whether a protocol deviation occurred during this IMP administration (wrong dose, wrong time, wrong route, etc.)' ;
    rdfs:domain ind:ImpAdministration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:administrationStatus rdf:type rdf:Property ;
    rdfs:label 'Administration Status' ;
    rdfs:comment 'Status of this administration event: administered (full dose given), partially_administered, not_administered (subject refused or clinically contraindicated), returned (subject returned unused IMP), destroyed (IMP disposed per protocol)' ;
    rdfs:domain ind:ImpAdministration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Administration Timestamp' ;
    rdfs:comment 'Date and time when the investigational product was administered to the subject, as recorded in source documents and EDC' ;
    rdfs:domain ind:ImpAdministration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviationReason rdf:type rdf:Property ;
    rdfs:label 'Deviation Reason' ;
    rdfs:comment 'Free-text description of the protocol deviation related to this IMP administration, if deviation_flag is true' ;
    rdfs:domain ind:ImpAdministration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseNumber rdf:type rdf:Property ;
    rdfs:label 'Dose Number' ;
    rdfs:comment 'The sequential dose number administered to the subject at this visit, as recorded in the EDC (Medidata Rave). Null for non-dosing visits. Supports cumulative exposure and dose-response analysis. [Moved from visit: The dose_number attribute in visit represents the sequential dose count for the subject, which is actually a property of the administration event (the relationship between IMP and visit), not an intrinsic property of the visit itself. Multiple IMPs could be administered at a single visit, each with its own dose sequence.]' ;
    rdfs:domain ind:ImpAdministration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyDrugAdministeredFlag rdf:type rdf:Property ;
    rdfs:label 'Study Drug Administered Flag' ;
    rdfs:comment 'Indicates whether the investigational medicinal product (IMP) or study drug was administered to the subject at this visit (True) or not (False). Supports exposure analysis and Intent-to-Treat (ITT) population derivation. [Moved from visit: This boolean flag in visit is a summary indicator that becomes redundant once the detailed imp_administration association exists. The flag can be derived by checking if any imp_administration records exist for the visit. The detailed administration records in the association provide the complete regulatory-required documentation.]' ;
    rdfs:domain ind:ImpAdministration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compoundSupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Compound Supply Agreement Id' ;
    rdfs:comment 'Unique system-generated surrogate key for each compound-vendor supply agreement record' ;
    rdfs:domain ind:CompoundSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Effective Date' ;
    rdfs:comment 'Date when the supply agreement for this compound-vendor combination became effective' ;
    rdfs:domain ind:CompoundSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Expiry Date' ;
    rdfs:comment 'Date when the supply agreement for this compound-vendor combination expires and requires renewal or renegotiation' ;
    rdfs:domain ind:CompoundSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:catalogNumber rdf:type rdf:Property ;
    rdfs:label 'Catalog Number' ;
    rdfs:comment 'Vendor-specific catalog number or SKU for this compound in the vendor\'s product catalog. Used for purchase order line item specification.' ;
    rdfs:domain ind:CompoundSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the most recent purchase order placed for this compound from this vendor. Used to track active supply relationships and vendor performance history.' ;
    rdfs:domain ind:CompoundSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastQualityIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Quality Issue Date' ;
    rdfs:comment 'Date of the most recent quality issue reported for this compound from this vendor' ;
    rdfs:domain ind:CompoundSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumOrderQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Uom' ;
    rdfs:comment 'Unit of measure for the minimum order quantity (gram, milligram, kilogram, vial, unit)' ;
    rdfs:domain ind:CompoundSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:puritySpecification rdf:type rdf:Property ;
    rdfs:label 'Purity Specification' ;
    rdfs:comment 'Contractually agreed minimum purity specification for this compound from this vendor (e.g., ≥95%, ≥98%, ≥99.5%). Purity requirements may vary by vendor capability and intended use.' ;
    rdfs:domain ind:CompoundSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityIssueCount rdf:type rdf:Property ;
    rdfs:label 'Quality Issue Count' ;
    rdfs:comment 'Number of quality issues (out-of-specification results, failed CoA, contamination) reported for this compound from this vendor. Used for vendor performance tracking and sourcing decisions.' ;
    rdfs:domain ind:CompoundSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescriptionId rdf:type rdf:Property ;
    rdfs:label 'Prescription Id' ;
    rdfs:comment 'Unique identifier for this prescription record. Primary key for the prescription association.' ;
    rdfs:domain ind:Prescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adherenceScore rdf:type rdf:Property ;
    rdfs:label 'Adherence Score' ;
    rdfs:comment 'Calculated adherence metric for this prescription (e.g., proportion of days covered, medication possession ratio). Used for patient support program interventions and real-world evidence studies.' ;
    rdfs:domain ind:Prescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dosageInstructions rdf:type rdf:Property ;
    rdfs:label 'Dosage Instructions' ;
    rdfs:comment 'Free-text or structured dosage instructions specific to this prescription (e.g., \'10mg twice daily with food\'). Varies by patient based on indication, weight, comorbidities.' ;
    rdfs:domain ind:Prescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionDate rdf:type rdf:Property ;
    rdfs:label 'Prescription Date' ;
    rdfs:comment 'The date when the prescription was written by the prescribing physician. Critical for therapy timeline tracking and regulatory reporting.' ;
    rdfs:domain ind:Prescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refillCount rdf:type rdf:Property ;
    rdfs:label 'Refill Count' ;
    rdfs:comment 'Number of refills dispensed for this prescription. Used for adherence monitoring and patient support program engagement tracking.' ;
    rdfs:domain ind:Prescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialtyPharmacyFlag rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Flag' ;
    rdfs:comment 'Indicates whether this prescription was dispensed through a specialty pharmacy channel. Relevant for high-cost biologics, oncology products, and products requiring special handling.' ;
    rdfs:domain ind:Prescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:therapyEndDate rdf:type rdf:Property ;
    rdfs:label 'Therapy End Date' ;
    rdfs:comment 'The date when the patient stopped taking the medicinal product. Used to calculate treatment duration and time-to-discontinuation for real-world evidence studies.' ;
    rdfs:domain ind:Prescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:therapyStartDate rdf:type rdf:Property ;
    rdfs:label 'Therapy Start Date' ;
    rdfs:comment 'The date when the patient actually started taking the medicinal product. May differ from prescription_date due to prior authorization delays or patient decision timing.' ;
    rdfs:domain ind:Prescription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedVendorMaterialId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Material Id' ;
    rdfs:comment 'Unique identifier for this vendor-material approval record. Primary key.' ;
    rdfs:domain ind:ApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the unit_price (e.g., USD, EUR, GBP, JPY, CHF).' ;
    rdfs:domain ind:ApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolEngagementPlanId rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Plan Id' ;
    rdfs:comment 'Unique system-generated identifier for the KOL engagement plan record. Primary key for the association.' ;
    rdfs:domain ind:KolEngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualActivityCount rdf:type rdf:Property ;
    rdfs:label 'Actual Activity Count' ;
    rdfs:comment 'Actual number of completed engagement activities for this KOL within this access strategy. Used to track execution against plan and calculate engagement effectiveness.' ;
    rdfs:domain ind:KolEngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Actual amount spent on this KOL engagement within this access strategy. Used to track budget utilization and ROI.' ;
    rdfs:domain ind:KolEngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Budget amount allocated for this specific KOL engagement within this access strategy. Covers honoraria, travel, publication support, and other engagement-related expenses.' ;
    rdfs:domain ind:KolEngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectivenessScore rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Score' ;
    rdfs:comment 'Quantitative assessment of the effectiveness of this KOL\'s engagement within this specific access strategy, measured on a scale (e.g., 0-100). Based on activity completion, impact on access outcomes, and strategic objective achievement.' ;
    rdfs:domain ind:KolEngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementTier rdf:type rdf:Property ;
    rdfs:label 'Engagement Tier' ;
    rdfs:comment 'Strategic priority level for this specific KOL engagement within the context of this access strategy. Tier 1 represents highest strategic importance with dedicated resources and frequent touchpoints.' ;
    rdfs:domain ind:KolEngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolEngagementPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Plan Status' ;
    rdfs:comment 'Current lifecycle status of this KOL engagement plan. Tracks whether the engagement is in planning, actively executing, paused, successfully completed, or prematurely terminated.' ;
    rdfs:domain ind:KolEngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolRoleInStrategy rdf:type rdf:Property ;
    rdfs:label 'Kol Role In Strategy' ;
    rdfs:comment 'The specific role or function the KOL is expected to fulfill within this access strategy. Defines the nature of the engagement and the type of activities planned.' ;
    rdfs:domain ind:KolEngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetActivityCount rdf:type rdf:Property ;
    rdfs:label 'Target Activity Count' ;
    rdfs:comment 'Planned number of engagement activities (advisory boards, speaking engagements, publications, etc.) for this KOL within this access strategy during the planning period.' ;
    rdfs:domain ind:KolEngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationIndicationId rdf:type rdf:Property ;
    rdfs:label 'Application Indication Id' ;
    rdfs:comment 'Primary key for the application_indication association' ;
    rdfs:domain ind:ApplicationIndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceleratedApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Accelerated Approval Flag' ;
    rdfs:comment 'Boolean indicator of whether this product-indication received accelerated approval based on surrogate or intermediate clinical endpoints, with requirement for post-marketing confirmatory trials. True indicates accelerated approval pathway used; False indicates standard approval. [Moved from product_indication: Accelerated approval is granted per application-indication pair. The same indication may receive accelerated approval in one application but standard approval in another.]' ;
    rdfs:domain ind:ApplicationIndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Approval Jurisdiction' ;
    rdfs:comment 'The regulatory jurisdiction or health authority that granted approval for this application-indication combination (e.g., FDA, EMA, PMDA).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Flag' ;
    rdfs:comment 'Boolean indicator of whether this product-indication received conditional marketing authorization (EMA pathway) based on less comprehensive data than normally required, with obligations to provide additional data post-approval. True indicates conditional approval; False indicates standard authorization. [Moved from product_indication: Conditional approval (EMA) is granted per application-indication pair. This is application-specific regulatory status.]' ;
    rdfs:domain ind:ApplicationIndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fastTrackDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Fast Track Designation Flag' ;
    rdfs:comment 'Boolean indicator of whether this product-indication combination has received FDA Fast Track designation to facilitate development and expedite review of drugs treating serious conditions and filling unmet medical needs. True indicates fast track designation granted; False indicates not designated. [Moved from product_indication: Fast track designation is granted per application-indication pair by the FDA. This is application-specific, not indication-specific.]' ;
    rdfs:domain ind:ApplicationIndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indicationAddedDate rdf:type rdf:Property ;
    rdfs:label 'Indication Added Date' ;
    rdfs:comment 'Date on which this indication was first added to this application (original submission or supplemental application date).' ;
    rdfs:domain ind:ApplicationIndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Sequence Number' ;
    rdfs:comment 'The eCTD sequence number or supplemental application number for the submission that added or modified this indication within the application lifecycle.' ;
    rdfs:domain ind:ApplicationIndication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programObligationScopeId rdf:type rdf:Property ;
    rdfs:label 'Program Obligation Scope Id' ;
    rdfs:comment 'Unique identifier for this program-obligation scope assignment. Primary key.' ;
    rdfs:domain ind:ProgramObligationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceProgramId rdf:type rdf:Property ;
    rdfs:label 'Compliance Program Id' ;
    rdfs:comment 'Foreign key to compliance_program' ;
    rdfs:domain ind:ProgramObligationScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:assignedBy rdf:type rdf:Property ;
    rdfs:label 'Assigned By' ;
    rdfs:comment 'Role or individual who assigned this obligation to this program, typically a compliance manager or program owner.' ;
    rdfs:domain ind:ProgramObligationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Coverage Percentage' ;
    rdfs:comment 'Percentage of the obligation\'s full scope that is covered by this program (0-100). Useful when an obligation spans multiple programs and each program covers a portion.' ;
    rdfs:domain ind:ProgramObligationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programScopeNotes rdf:type rdf:Property ;
    rdfs:label 'Program Scope Notes' ;
    rdfs:comment 'Free-text notes describing how this obligation is scoped within this program, including any program-specific interpretations, exclusions, or implementation details. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ProgramObligationScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speakerProgramPresentationId rdf:type rdf:Property ;
    rdfs:label 'Speaker Program Presentation Id' ;
    rdfs:comment 'Unique identifier for this speaker program presentation record. Primary key.' ;
    rdfs:domain ind:SpeakerProgramPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedProductList rdf:type rdf:Property ;
    rdfs:label 'Approved Product List' ;
    rdfs:comment 'Comma-separated list of drug products the speaker is certified and approved to present on. Must align with training completion and medical expertise. [Moved from hcp_speaker_program: This comma-separated list should be decomposed into individual speaker-product relationships. Each approved product becomes a record in the association, eliminating the need for a denormalized list in the speaker program entity.]' ;
    rdfs:domain ind:SpeakerProgramPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceType rdf:type rdf:Property ;
    rdfs:label 'Audience Type' ;
    rdfs:comment 'Classification of the audience composition. Examples include physicians, pharmacists, nurses, or mixed healthcare professionals. [Moved from hcp_speaker_program: Audience type is specific to each speaker-product presentation event.]' ;
    rdfs:domain ind:SpeakerProgramPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTime rdf:type rdf:Property ;
    rdfs:label 'Event End Time' ;
    rdfs:comment 'Timestamp when the speaker program event concluded. Used for calculating event duration and compliance reporting. [Moved from hcp_speaker_program: End time is specific to each individual product presentation, not the overall speaker program enrollment.]' ;
    rdfs:domain ind:SpeakerProgramPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventFormat rdf:type rdf:Property ;
    rdfs:label 'Event Format' ;
    rdfs:comment 'Format of the speaker program event delivery. Determines logistics, compliance requirements, and audience engagement tracking. [Moved from hcp_speaker_program: Event format (in-person, virtual, hybrid) is specific to each speaker-product presentation.]' ;
    rdfs:domain ind:SpeakerProgramPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartTime rdf:type rdf:Property ;
    rdfs:label 'Event Start Time' ;
    rdfs:comment 'Timestamp when the speaker program event started. Used for detailed event tracking and compliance documentation. [Moved from hcp_speaker_program: Start time is specific to each individual product presentation, not the overall speaker program enrollment.]' ;
    rdfs:domain ind:SpeakerProgramPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:honorariumPaid rdf:type rdf:Property ;
    rdfs:label 'Honorarium Paid' ;
    rdfs:comment 'Actual honorarium payment amount for this specific product presentation. Required for Sunshine Act transfer of value reporting.' ;
    rdfs:domain ind:SpeakerProgramPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:presentationDate rdf:type rdf:Property ;
    rdfs:label 'Presentation Date' ;
    rdfs:comment 'Date when the speaker presented on this specific medicinal product. Principal business event date for this presentation.' ;
    rdfs:domain ind:SpeakerProgramPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:venue rdf:type rdf:Property ;
    rdfs:label 'Venue' ;
    rdfs:comment 'Location or facility where this specific product presentation was delivered. Includes venue name and address details.' ;
    rdfs:domain ind:SpeakerProgramPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueAddress rdf:type rdf:Property ;
    rdfs:label 'Venue Address' ;
    rdfs:comment 'Full street address of the venue where the speaker program event was held. Required for Sunshine Act geographic reporting. [Moved from hcp_speaker_program: Venue address is specific to each speaker-product presentation event.]' ;
    rdfs:domain ind:SpeakerProgramPresentation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugDispensationId rdf:type rdf:Property ;
    rdfs:label 'Drug Dispensation Id' ;
    rdfs:comment 'Unique surrogate identifier for each drug dispensation record linking a lot to a patient' ;
    rdfs:domain ind:DrugDispensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispenseDate rdf:type rdf:Property ;
    rdfs:label 'Dispense Date' ;
    rdfs:comment 'Date on which the drug was dispensed from the inventory lot to the patient at the clinical site' ;
    rdfs:domain ind:DrugDispensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispenseLocation rdf:type rdf:Property ;
    rdfs:label 'Dispense Location' ;
    rdfs:comment 'Clinical site code or pharmacy location where the dispensation occurred' ;
    rdfs:domain ind:DrugDispensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispenseQuantity rdf:type rdf:Property ;
    rdfs:label 'Dispense Quantity' ;
    rdfs:comment 'Quantity of drug dispensed from the lot to the patient, measured in the lot\'s unit of measure' ;
    rdfs:domain ind:DrugDispensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispenseStatus rdf:type rdf:Property ;
    rdfs:label 'Dispense Status' ;
    rdfs:comment 'Current status of the dispensation record for drug accountability tracking' ;
    rdfs:domain ind:DrugDispensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date on which unused drug from this dispensation was returned to the site pharmacy or destroyed' ;
    rdfs:domain ind:DrugDispensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Quantity of drug returned from the patient, used for drug accountability reconciliation' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnReason rdf:type rdf:Property ;
    rdfs:label 'Return Reason' ;
    rdfs:comment 'Reason code or free-text explanation for why drug was returned (e.g., patient discontinuation, dose adjustment, study completion)' ;
    rdfs:domain ind:DrugDispensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtDispense rdf:type rdf:Property ;
    rdfs:label 'Temperature At Dispense' ;
    rdfs:comment 'Recorded storage temperature at time of dispensation for cold chain compliance verification' ;
    rdfs:domain ind:DrugDispensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteImpAccountabilityId rdf:type rdf:Property ;
    rdfs:label 'Site Imp Accountability Id' ;
    rdfs:comment 'Unique surrogate identifier for each site-lot accountability record' ;
    rdfs:domain ind:SiteImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Accountability Status' ;
    rdfs:comment 'Current lifecycle status of the IMP lot at this site for accountability tracking purposes' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionDate rdf:type rdf:Property ;
    rdfs:label 'Destruction Date' ;
    rdfs:comment 'Date on which unused or expired IMP from this lot was destroyed at the site or returned for destruction, with destruction certificate reference' ;
    rdfs:domain ind:SiteImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether an accountability discrepancy has been identified for this site-lot combination, requiring CAPA and regulatory reporting' ;
    rdfs:domain ind:SiteImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text description of any accountability discrepancy, investigation findings, and corrective actions taken' ;
    rdfs:domain ind:SiteImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensedQuantity rdf:type rdf:Property ;
    rdfs:label 'Dispensed Quantity' ;
    rdfs:comment 'Cumulative quantity of the IMP lot dispensed to subjects enrolled at this site, tracked per subject dispensation record' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date of the most recent IMP accountability reconciliation performed by the CRA during a site monitoring visit, confirming physical inventory matches accountability records' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineQuantity rdf:type rdf:Property ;
    rdfs:label 'Quarantine Quantity' ;
    rdfs:comment 'Quantity of the IMP lot placed in quarantine at the site due to temperature excursion, packaging damage, or quality hold pending investigation' ;
    rdfs:domain ind:SiteImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of the IMP lot returned by subjects or returned to the sponsor/depot at site closure or lot expiry' ;
    rdfs:domain ind:SiteImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteAffiliationId rdf:type rdf:Property ;
    rdfs:label 'Site Affiliation Id' ;
    rdfs:comment 'Primary key for the site_affiliation association' ;
    rdfs:domain ind:SiteAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affiliationEndDate rdf:type rdf:Property ;
    rdfs:label 'Affiliation End Date' ;
    rdfs:comment 'Date when the HCP\'s affiliation with this investigational site ended or is planned to end. Used to track investigator turnover, site capacity changes, and delegation of authority updates.' ;
    rdfs:domain ind:SiteAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affiliationStartDate rdf:type rdf:Property ;
    rdfs:label 'Affiliation Start Date' ;
    rdfs:comment 'Date when the HCP\'s affiliation with this investigational site became active for clinical trial purposes. May differ from employment start date; represents trial-specific credentialing completion.' ;
    rdfs:domain ind:SiteAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Completion Date' ;
    rdfs:comment 'Date when the site credentialing process was completed and the HCP was approved to perform protocol activities at this site. Required for regulatory inspection readiness.' ;
    rdfs:domain ind:SiteAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Enrollment Authority Flag' ;
    rdfs:comment 'Indicates whether the HCP is authorized to enroll and randomize subjects at this site. Derived from delegation of authority log and protocol-specific training completion.' ;
    rdfs:domain ind:SiteAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimarySite rdf:type rdf:Property ;
    rdfs:label 'Is Primary Site' ;
    rdfs:comment 'Indicates whether this is the HCP\'s primary investigational site affiliation for enrollment and patient care. Used when HCP has privileges at multiple sites to determine primary contact point.' ;
    rdfs:domain ind:SiteAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trialInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Trial Investigator Id' ;
    rdfs:comment 'Unique surrogate identifier for each trial-investigator assignment record. Primary key for the association.' ;
    rdfs:domain ind:TrialInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when this HCP\'s investigator assignment on this trial ended (site closure, investigator departure, trial completion). Null for active assignments. Used for historical investigator portfolio tracking and conflict-of-interest screening.' ;
    rdfs:domain ind:TrialInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when this HCP was assigned to this trial as an investigator. Typically corresponds to site activation date or investigator onboarding completion. Used for investigator tenure tracking and workload analysis.' ;
    rdfs:domain ind:TrialInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cvOnFileDate rdf:type rdf:Property ;
    rdfs:label 'Cv On File Date' ;
    rdfs:comment 'Date when the investigator\'s current CV was received and filed in the eTMF for this trial. Required regulatory document per ICH-GCP. Must be updated if investigator credentials change during trial.' ;
    rdfs:domain ind:TrialInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentResponsibility rdf:type rdf:Property ;
    rdfs:label 'Enrollment Responsibility' ;
    rdfs:comment 'Boolean flag indicating whether this investigator has patient enrollment responsibilities for this trial. Principal Investigators typically have enrollment responsibility; some Sub-Investigators and Coordinators may not. Drives enrollment tracking and site performance metrics.' ;
    rdfs:domain ind:TrialInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialDisclosureSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Financial Disclosure Submission Date' ;
    rdfs:comment 'Date when the investigator submitted financial disclosure documentation for this trial. Required for regulatory submission timelines.' ;
    rdfs:domain ind:TrialInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalLicenseVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Medical License Verified Date' ;
    rdfs:comment 'Date when the sponsor or CRO verified the investigator\'s medical license status for this trial. Required before site activation. Typically re-verified annually during trial conduct.' ;
    rdfs:domain ind:TrialInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientsEnrolledCount rdf:type rdf:Property ;
    rdfs:label 'Patients Enrolled Count' ;
    rdfs:comment 'Count of patients enrolled by this investigator on this trial. Used for site performance tracking, investigator workload analysis, and enrollment forecasting. Updated as patients are consented and randomized.' ;
    rdfs:domain ind:TrialInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteAssignment rdf:type rdf:Property ;
    rdfs:label 'Site Assignment' ;
    rdfs:comment 'Site identifier or site name where this investigator is assigned for this trial. Links to the clinical site/investigator site record. An HCP may serve as investigator at multiple sites for the same trial (multi-site PI scenarios).' ;
    rdfs:domain ind:TrialInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditSiteInspectionId rdf:type rdf:Property ;
    rdfs:label 'Audit Site Inspection Id' ;
    rdfs:comment 'Primary key for the audit_site_inspection association' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteCapaId rdf:type rdf:Property ;
    rdfs:label 'Site Capa Id' ;
    rdfs:comment 'Foreign key reference to the CAPA record specific to this vendor site inspection' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityCapa .

ind:auditorAssigned rdf:type rdf:Property ;
    rdfs:label 'Auditor Assigned' ;
    rdfs:comment 'Lead auditor or audit team members assigned to this specific vendor site inspection' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date when this specific vendor site was inspected as part of the audit program. Corresponds to audit_date from detection data.' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextSiteAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Site Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next audit of this vendor site based on risk assessment and audit outcome. Corresponds to next_audit_due_date from detection data.' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteAuditOutcome rdf:type rdf:Property ;
    rdfs:label 'Site Audit Outcome' ;
    rdfs:comment 'Summary conclusion of the audit for this specific vendor site. Corresponds to audit_outcome from detection data.' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAuditScope rdf:type rdf:Property ;
    rdfs:label 'Site Audit Scope' ;
    rdfs:comment 'Specific scope of audit activities conducted at this vendor site, including functional areas, processes, and systems reviewed. Corresponds to audit_scope from detection data.' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCapaRequired rdf:type rdf:Property ;
    rdfs:label 'Site Capa Required' ;
    rdfs:comment 'Indicates whether formal Corrective and Preventive Action is required for findings at this vendor site. Corresponds to capa_required from detection data.' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteCriticalFindings rdf:type rdf:Property ;
    rdfs:label 'Site Critical Findings' ;
    rdfs:comment 'Number of critical findings identified at this vendor site' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteFacilityAudited rdf:type rdf:Property ;
    rdfs:label 'Site Facility Audited' ;
    rdfs:comment 'Name and location of the site, facility, manufacturing plant, warehouse, or supplier location that is the subject of the audit. May include facility code or site identifier. [Moved from audit: This attribute describes the specific site being audited and should be replaced by the FK relationship to vendor_site. The vendor_site product already contains site_name and location details.]' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Site Findings Count' ;
    rdfs:comment 'Total number of findings identified at this specific vendor site during the audit. Corresponds to findings_count from detection data.' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteMajorFindings rdf:type rdf:Property ;
    rdfs:label 'Site Major Findings' ;
    rdfs:comment 'Number of major findings identified at this vendor site' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteMinorFindings rdf:type rdf:Property ;
    rdfs:label 'Site Minor Findings' ;
    rdfs:comment 'Number of minor findings identified at this vendor site' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteQualificationImpact rdf:type rdf:Property ;
    rdfs:label 'Site Qualification Impact' ;
    rdfs:comment 'Impact of the audit outcome on the vendor site\'s qualification status for supplying materials or services' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Site Response Due Date' ;
    rdfs:comment 'Date by which the vendor site must submit formal responses to audit findings' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteResponseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Site Response Submitted Date' ;
    rdfs:comment 'Actual date when the vendor site submitted formal responses to audit findings' ;
    rdfs:domain ind:AuditSiteInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compoundExposureId rdf:type rdf:Property ;
    rdfs:label 'Compound Exposure Id' ;
    rdfs:comment 'Primary key for compound_exposure' ;
    rdfs:domain ind:CompoundExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doseLevel rdf:type rdf:Property ;
    rdfs:label 'Dose Level' ;
    rdfs:comment 'Dose level or dosing regimen administered to the patient (e.g., \'100mg QD\', \'5mg/kg Q2W\'). Captures the specific dosing schedule for this compound-patient exposure.' ;
    rdfs:domain ind:CompoundExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureStatus rdf:type rdf:Property ;
    rdfs:label 'Exposure Status' ;
    rdfs:comment 'Current lifecycle status of this compound exposure record (active, completed, discontinued, withdrawn). Tracks whether the patient is currently receiving treatment.' ;
    rdfs:domain ind:CompoundExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDurationDays rdf:type rdf:Property ;
    rdfs:label 'Treatment Duration Days' ;
    rdfs:comment 'Total duration of compound exposure expressed in days. Used for exposure-response analysis, safety signal detection, and pharmacovigilance reporting.' ;
    rdfs:domain ind:CompoundExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Distribution Service Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for each distribution service agreement record linking a distribution node to a payer account' ;
    rdfs:domain ind:DistributionServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coldChainCapability rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capability' ;
    rdfs:comment 'Temperature control capability required and committed for shipments from this distribution node to this payer account. Must match or exceed product temperature requirements.' ;
    rdfs:domain ind:DistributionServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Code' ;
    rdfs:comment 'Internal accounting code used to allocate distribution costs for shipments under this agreement. Links to cost center or GL account for financial reporting.' ;
    rdfs:domain ind:DistributionServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Contractual number of calendar days from order placement to delivery for shipments from this distribution node to this payer account. Used for supply planning and order promising.' ;
    rdfs:domain ind:DistributionServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:directDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Delivery Flag' ;
    rdfs:comment 'Indicates whether shipments under this agreement are delivered directly from the distribution node to the payer\'s designated location (True) or routed through intermediary wholesalers/distributors (False).' ;
    rdfs:domain ind:DistributionServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCarrier rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier' ;
    rdfs:comment 'Name of the logistics carrier designated for shipments under this distribution service agreement (e.g., FedEx, UPS, DHL, specialty pharma courier). May be mandated by payer or selected by supply chain.' ;
    rdfs:domain ind:DistributionServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Serialization Verification Required' ;
    rdfs:comment 'Indicates whether this payer account requires serialization verification at the distribution node level for DSCSA compliance or payer-specific track-and-trace requirements.' ;
    rdfs:domain ind:DistributionServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Classification of the service level commitment governing this distribution relationship (Standard, Expedited, Critical, Custom). Determines delivery speed, handling priority, and cost structure.' ;
    rdfs:domain ind:DistributionServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingSource rdf:type rdf:Property ;
    rdfs:label 'Listing Source' ;
    rdfs:comment 'The source or mechanism through which this drug product was added to the payer\'s formulary.' ;
    rdfs:domain ind:FormularyListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Medical Policy Reference' ;
    rdfs:comment 'Reference to the payer\'s medical policy or coverage criteria document that governs this drug product\'s coverage.' ;
    rdfs:domain ind:FormularyListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimit rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit' ;
    rdfs:comment 'Any quantity limits or dispensing restrictions imposed by the payer for this drug product (e.g., \'30 tablets per 30 days\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Id' ;
    rdfs:comment 'Primary key for the approved_vendor association' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inactivationDate rdf:type rdf:Property ;
    rdfs:label 'Inactivation Date' ;
    rdfs:comment 'Date when this vendor approval was inactivated, if applicable. Inactivation may occur due to vendor disqualification, quality issues, business decisions, or vendor exit.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inactivationReason rdf:type rdf:Property ;
    rdfs:label 'Inactivation Reason' ;
    rdfs:comment 'Business reason for inactivating this vendor approval (e.g., Quality Issues, Vendor Exit, Cost, Strategic Sourcing Decision, Regulatory Non-Compliance).' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Unit Price' ;
    rdfs:comment 'Current standard unit price for this excipient from this vendor in the agreed currency. Price is vendor-specific and material-specific.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyDataSourcingId rdf:type rdf:Property ;
    rdfs:label 'Study Data Sourcing Id' ;
    rdfs:comment 'Unique surrogate identifier for this study-dataset sourcing relationship record' ;
    rdfs:domain ind:StudyDataSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Employee Id' ;
    rdfs:comment 'Employee identifier of the person who last modified this sourcing relationship record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dataContributionType rdf:type rdf:Property ;
    rdfs:label 'Data Contribution Type' ;
    rdfs:comment 'The type of evidence or data element this dataset contributes to the study (efficacy outcomes, safety data, cost inputs, healthcare utilization patterns, quality of life measures, or epidemiological parameters). Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:StudyDataSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExtractionDate rdf:type rdf:Property ;
    rdfs:label 'Data Extraction Date' ;
    rdfs:comment 'Date on which data was extracted from this RWE dataset for use in the study. Important for regulatory documentation and understanding which data refresh was used.' ;
    rdfs:domain ind:StudyDataSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataVintageUsed rdf:type rdf:Property ;
    rdfs:label 'Data Vintage Used' ;
    rdfs:comment 'The specific data vintage or version of the RWE dataset that was used in this study (e.g., \'2022Q4\', \'v3.2\'). Critical for model reproducibility and regulatory compliance, as dataset content changes over time. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:StudyDataSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion Date' ;
    rdfs:comment 'Date on which this RWE dataset was formally incorporated into the HEOR study protocol or model. Used for audit trail and model version control. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientCountContributed rdf:type rdf:Property ;
    rdfs:label 'Patient Count Contributed' ;
    rdfs:comment 'Number of patients from this dataset that were included in the study analysis after applying study-specific inclusion/exclusion criteria. May differ from the total patient count in the dataset. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:StudyDataSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDatasetFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Dataset Flag' ;
    rdfs:comment 'Indicates whether this is the primary/main dataset for the study (true) or a supplementary/supporting dataset (false). Each study typically has one primary dataset. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:StudyDataSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourcingStatus rdf:type rdf:Property ;
    rdfs:label 'Sourcing Status' ;
    rdfs:comment 'Current status of this dataset sourcing relationship in the study lifecycle (planned for use, data extraction in progress, completed and incorporated, excluded from final analysis, or replaced by alternative dataset).' ;
    rdfs:domain ind:StudyDataSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyRole rdf:type rdf:Property ;
    rdfs:label 'Study Role' ;
    rdfs:comment 'The role this dataset plays in the HEOR study (primary data source, secondary/supplementary source, validation dataset, sensitivity analysis input, or comparator arm data). Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:StudyDataSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractFulfillmentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Contract Fulfillment Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each lot-to-contract allocation record.' ;
    rdfs:domain ind:ContractFulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'The actual date on which this allocated lot quantity was shipped. Populated upon shipment execution. Used for rebate accrual timing and contract performance measurement.' ;
    rdfs:domain ind:ContractFulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The date on which this inventory lot was allocated to this payer contract in the supply chain planning or inventory management system. Establishes the temporal relationship for allocation tracking.' ;
    rdfs:domain ind:ContractFulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationReason rdf:type rdf:Property ;
    rdfs:label 'Allocation Reason' ;
    rdfs:comment 'Business reason or driver for this specific lot-to-contract allocation. Examples: \'Formulary commitment fulfillment\', \'Shortage mitigation - split allocation\', \'Expiry date optimization\', \'GPO volume commitment\', \'Performance rebate tier achievement\'.' ;
    rdfs:domain ind:ContractFulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractPeriod rdf:type rdf:Property ;
    rdfs:label 'Contract Period' ;
    rdfs:comment 'The specific contract performance period (e.g., \'Q1 2024\', \'2024-03\', \'2024\') during which this lot allocation applies. Critical for aligning lot-level shipments with contract rebate periods and performance metric calculations.' ;
    rdfs:domain ind:ContractFulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedQuantity rdf:type rdf:Property ;
    rdfs:label 'Contracted Quantity' ;
    rdfs:comment 'The quantity from this specific lot that has been contractually committed to this payer contract. Represents the planned allocation amount based on contract terms and demand forecasts.' ;
    rdfs:domain ind:ContractFulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedShipDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ship Date' ;
    rdfs:comment 'The planned or forecasted date by which this allocated lot quantity is expected to ship to fulfill the payer contract. Used for supply chain planning and contract performance monitoring.' ;
    rdfs:domain ind:ContractFulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentPriority rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Priority' ;
    rdfs:comment 'The business priority assigned to this lot-contract allocation, determining fulfillment sequencing during inventory shortages or competing contract demands. Values: CRITICAL (formulary-critical contracts, shortage risk), HIGH (tier 1 payer contracts), MEDIUM (standard contracts), LOW (opportunistic allocations).' ;
    rdfs:domain ind:ContractFulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteProtocolActivationId rdf:type rdf:Property ;
    rdfs:label 'Site Protocol Activation Id' ;
    rdfs:comment 'Primary key for the site_protocol_activation association' ;
    rdfs:domain ind:SiteProtocolActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteProtocolActivationStatus rdf:type rdf:Property ;
    rdfs:label 'Site Protocol Activation Status' ;
    rdfs:comment 'Current operational status of this protocol version at this site. Tracks lifecycle from activation through closure. Corresponds to site_protocol_version_status from detection data. Distinct from the site\'s overall status and the protocol\'s overall status.' ;
    rdfs:domain ind:SiteProtocolActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationalProductSupplyId rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Supply Id' ;
    rdfs:comment 'Unique identifier for this investigational product supply allocation record. Primary key.' ;
    rdfs:domain ind:InvestigationalProductSupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyAllocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Supply Allocation Quantity' ;
    rdfs:comment 'The quantity of investigational product (manufactured per this MBR) allocated to this investigator for this trial. Measured in units consistent with the MBR batch size UOM.' ;
    rdfs:domain ind:InvestigationalProductSupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyEndDate rdf:type rdf:Property ;
    rdfs:label 'Supply End Date' ;
    rdfs:comment 'The date when investigational product supply from this MBR to this investigator ended or is planned to end. Used for supply chain planning and batch reconciliation.' ;
    rdfs:domain ind:InvestigationalProductSupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyStartDate rdf:type rdf:Property ;
    rdfs:label 'Supply Start Date' ;
    rdfs:comment 'The date when investigational product supply from this MBR to this investigator began. Critical for regulatory traceability and shelf-life management.' ;
    rdfs:domain ind:InvestigationalProductSupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalAdvisoryBoardMembershipId rdf:type rdf:Property ;
    rdfs:label 'Medical Advisory Board Membership Id' ;
    rdfs:comment 'Primary key for medical_advisory_board_membership' ;
    rdfs:domain ind:MedicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advisoryBoardMembershipCode rdf:type rdf:Property ;
    rdfs:label 'Advisory Board Membership Code' ;
    rdfs:comment 'Unique system-generated identifier for this specific membership relationship record' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Date' ;
    rdfs:comment 'Date on which the KOL was formally appointed to this advisory board, which may precede the membership start date if there was a nomination and approval process' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coiDisclosureOnFile rdf:type rdf:Property ;
    rdfs:label 'Coi Disclosure On File' ;
    rdfs:comment 'Indicates whether a conflict-of-interest disclosure specific to this advisory board membership has been collected and is on file for compliance purposes' ;
    rdfs:domain ind:MedicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAttendanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Attendance Date' ;
    rdfs:comment 'Date of the most recent advisory board meeting attended by this KOL, used for engagement recency tracking' ;
    rdfs:domain ind:MedicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingAttendanceCount rdf:type rdf:Property ;
    rdfs:label 'Meeting Attendance Count' ;
    rdfs:comment 'Cumulative number of advisory board meetings attended by this KOL for this specific board, used for engagement quality assessment and honorarium calculation validation' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberRole rdf:type rdf:Property ;
    rdfs:label 'Member Role' ;
    rdfs:comment 'Specific role or designation held by the KOL within this advisory board (e.g., Chair, Vice Chair, Member), determining responsibilities and governance authority' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Membership End Date' ;
    rdfs:comment 'Date on which the KOL membership term concluded or is scheduled to conclude, either through term expiration, resignation, or board dissolution' ;
    rdfs:domain ind:MedicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Membership Start Date' ;
    rdfs:comment 'Date on which the KOL formally commenced their membership term on this advisory board, as documented in the engagement contract' ;
    rdfs:domain ind:MedicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nominationSource rdf:type rdf:Property ;
    rdfs:label 'Nomination Source' ;
    rdfs:comment 'Source or function that nominated this KOL for membership on this advisory board (e.g., Medical Affairs, Clinical Development, specific MSL territory)' ;
    rdfs:domain ind:MedicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transparencyReported rdf:type rdf:Property ;
    rdfs:label 'Transparency Reported' ;
    rdfs:comment 'Indicates whether transfers of value associated with this specific membership have been reported to applicable transparency registries (Sunshine Act, EFPIA disclosure)' ;
    rdfs:domain ind:MedicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productPayerContractId rdf:type rdf:Property ;
    rdfs:label 'Product Payer Contract Id' ;
    rdfs:comment 'Primary key for product_payer_contract' ;
    rdfs:domain ind:ProductPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Identifier of the internal market access manager or account director responsible for managing this payer contract relationship.' ;
    rdfs:domain ind:ProductPayerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:payerContractId rdf:type rdf:Property ;
    rdfs:label 'Payer Contract Id' ;
    rdfs:comment 'Unique surrogate identifier for this payer contract record. Primary key.' ;
    rdfs:domain ind:ProductPayerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:outcomesMetric rdf:type rdf:Property ;
    rdfs:label 'Outcomes Metric' ;
    rdfs:comment 'The clinical or economic outcome metric used to measure performance for outcomes-based or value-based contracts (e.g., HbA1c reduction, hospitalization rate, adherence rate). Null for non-outcomes-based contracts.' ;
    rdfs:domain ind:ProductPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRebatePct rdf:type rdf:Property ;
    rdfs:label 'Performance Rebate Pct' ;
    rdfs:comment 'Additional rebate percentage contingent on achievement of formulary placement, utilization targets, or outcomes metrics. Null if contract does not include performance-based terms.' ;
    rdfs:domain ind:ProductPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationTarget rdf:type rdf:Property ;
    rdfs:label 'Utilization Target' ;
    rdfs:comment 'Target number of prescriptions, patients, or units for this medicinal product under this contract, used for performance-based rebate calculations. Null if not applicable.' ;
    rdfs:domain ind:ProductPayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registryEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Registry Enrollment Id' ;
    rdfs:comment 'Unique identifier for this registry enrollment record. Primary key.' ;
    rdfs:domain ind:RegistryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Commitment Id' ;
    rdfs:comment 'Reference to the specific post-marketing requirement (PMR) or post-marketing commitment (PMC) that mandates this product\'s enrollment in this registry, if applicable.' ;
    rdfs:domain ind:RegistryEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PostApprovalCommitment .

ind:currentPatientCount rdf:type rdf:Property ;
    rdfs:label 'Current Patient Count' ;
    rdfs:comment 'Current number of patients enrolled for this specific medicinal product within this registry.' ;
    rdfs:domain ind:RegistryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'Date when enrollment of this medicinal product in this registry was completed or terminated. Null if enrollment is still active.' ;
    rdfs:domain ind:RegistryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeStatus rdf:type rdf:Property ;
    rdfs:label 'Outcome Status' ;
    rdfs:comment 'Summary status of clinical or safety outcomes observed for this product within this registry. Tracks aggregate outcome data at the product-registry level. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:RegistryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryIndication rdf:type rdf:Property ;
    rdfs:label 'Primary Indication' ;
    rdfs:comment 'The specific disease indication or therapeutic use for which this medicinal product is being monitored within this registry. A product may be enrolled for different indications across multiple registries. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:RegistryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolAmendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Protocol Amendment Number' ;
    rdfs:comment 'Specific protocol amendment number under which this product was enrolled, if the enrollment occurred after the initial protocol version.' ;
    rdfs:domain ind:RegistryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPatientCount rdf:type rdf:Property ;
    rdfs:label 'Target Patient Count' ;
    rdfs:comment 'Target number of patients to be enrolled for this specific medicinal product within this registry, as specified in the protocol or regulatory commitment.' ;
    rdfs:domain ind:RegistryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentLine rdf:type rdf:Property ;
    rdfs:label 'Treatment Line' ;
    rdfs:comment 'The line of therapy context in which this medicinal product is being used and monitored within the registry (e.g., first-line, second-line, maintenance therapy). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:RegistryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolProductEngagementId rdf:type rdf:Property ;
    rdfs:label 'Kol Product Engagement Id' ;
    rdfs:comment 'Unique surrogate identifier for this KOL-product engagement record. Primary key for the association.' ;
    rdfs:domain ind:KolProductEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advisoryRole rdf:type rdf:Property ;
    rdfs:label 'Advisory Role' ;
    rdfs:comment 'The specific advisory role held by the KOL for this product engagement (e.g., Advisory Board Chair, Steering Committee Member, DSMB Member). Sourced from detection phase.' ;
    rdfs:domain ind:KolProductEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalTrialRole rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Role' ;
    rdfs:comment 'The specific role held by the KOL in clinical trials for this medicinal product, if applicable.' ;
    rdfs:domain ind:KolProductEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryIndicationFocus rdf:type rdf:Property ;
    rdfs:label 'Primary Indication Focus' ;
    rdfs:comment 'The specific disease indication or therapeutic sub-area within the medicinal product\'s therapeutic area that is the focus of this KOL engagement (e.g., metastatic breast cancer, relapsing-remitting MS). Sourced from detection phase.' ;
    rdfs:domain ind:KolProductEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speakerBureauStatus rdf:type rdf:Property ;
    rdfs:label 'Speaker Bureau Status' ;
    rdfs:comment 'Current status of the KOL\'s participation in the speaker bureau for this specific medicinal product. Sourced from detection phase.' ;
    rdfs:domain ind:KolProductEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Total Engagement Count' ;
    rdfs:comment 'Cumulative count of discrete engagement activities (advisory board meetings, speaking engagements, publication planning sessions) between this KOL and this product. Sourced from detection phase.' ;
    rdfs:domain ind:KolProductEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTovAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tov Amount' ;
    rdfs:comment 'Cumulative total of all transfers of value (honoraria, consulting fees, travel reimbursements) associated with this specific KOL-product engagement, for Sunshine Act and EFPIA transparency reporting.' ;
    rdfs:domain ind:KolProductEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractPricingId rdf:type rdf:Property ;
    rdfs:label 'Contract Pricing Id' ;
    rdfs:comment 'Unique identifier for this contract pricing agreement record. Primary key.' ;
    rdfs:domain ind:ContractPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Commitment' ;
    rdfs:comment 'The total annual volume (in units) that the contract account has committed to purchase for this medicinal product. Used for rebate tier calculation and contract performance tracking.' ;
    rdfs:domain ind:ContractPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractPrice rdf:type rdf:Property ;
    rdfs:label 'Contract Price' ;
    rdfs:comment 'The negotiated unit price for this medicinal product under this contract account. This price is specific to the product-account combination and represents the contracted rate that overrides standard list pricing.' ;
    rdfs:domain ind:ContractPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier rdf:type rdf:Property ;
    rdfs:label 'Volume Tier' ;
    rdfs:comment 'The volume commitment tier that this contract account has committed to for this medicinal product. Higher tiers typically correspond to larger volume commitments and more favorable pricing or rebate terms.' ;
    rdfs:domain ind:ContractPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressAttendanceId rdf:type rdf:Property ;
    rdfs:label 'Congress Attendance Id' ;
    rdfs:comment 'Unique surrogate identifier for the congress attendance record' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendanceEndDate rdf:type rdf:Property ;
    rdfs:label 'Attendance End Date' ;
    rdfs:comment 'The date the MSL concluded attendance at the congress. May differ from congress end_date if MSL attended only partial days. Used for travel planning and expense reconciliation. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attendanceRole rdf:type rdf:Property ;
    rdfs:label 'Attendance Role' ;
    rdfs:comment 'The functional role the MSL performed at this congress (e.g., Attendee, Presenter, Booth Staff, Satellite Speaker). Determines activity expectations and post-congress reporting requirements. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendanceStartDate rdf:type rdf:Property ;
    rdfs:label 'Attendance Start Date' ;
    rdfs:comment 'The date the MSL began attending the congress. May differ from congress start_date if MSL attended only partial days. Used for travel planning and expense reconciliation. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boothDutyAssigned rdf:type rdf:Property ;
    rdfs:label 'Booth Duty Assigned' ;
    rdfs:comment 'Indicates whether the MSL was assigned booth duty shifts during the congress. Drives scheduling and resource allocation. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Estimated total cost for this MSL\'s congress attendance including registration, travel, accommodation, and per diem. Used for budget planning and ROI analysis.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insightsSubmitted rdf:type rdf:Property ;
    rdfs:label 'Insights Submitted' ;
    rdfs:comment 'Indicates whether the MSL submitted post-congress insights and competitive intelligence reports. Used for compliance and knowledge capture tracking.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kolMeetingsConducted rdf:type rdf:Property ;
    rdfs:label 'Kol Meetings Conducted' ;
    rdfs:comment 'Number of Key Opinion Leader (KOL) meetings or engagements the MSL conducted during this congress attendance. Core metric for congress ROI assessment. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mslAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Msl Attendee Count' ;
    rdfs:comment 'Number of Medical Science Liaisons (MSLs) deployed to attend and engage at the congress. Used for resource allocation planning and MSL activity reporting. [Moved from congress_event: This is an aggregate count that should be derived from the congress_attendance association table, not stored redundantly on congress_event. The source of truth for MSL attendance is the association records.]' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postCongressReportDate rdf:type rdf:Property ;
    rdfs:label 'Post Congress Report Date' ;
    rdfs:comment 'Date the MSL submitted their post-congress activity report and insights. Used for compliance tracking and timely knowledge capture.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:presentationDelivered rdf:type rdf:Property ;
    rdfs:label 'Presentation Delivered' ;
    rdfs:comment 'Indicates whether the MSL delivered an oral or poster presentation at this congress. Used for performance tracking and scientific output measurement. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Registration Fee Amount' ;
    rdfs:comment 'Total registration fee paid for this MSL\'s congress attendance. Used for budget tracking and congress cost analysis.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelApproved rdf:type rdf:Property ;
    rdfs:label 'Travel Approved' ;
    rdfs:comment 'Indicates whether travel and accommodation for this attendance has been approved by management. Gates logistics booking.' ;
    rdfs:domain ind:CongressAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentLicenseId rdf:type rdf:Property ;
    rdfs:label 'Patent License Id' ;
    rdfs:comment 'Unique surrogate identifier for each patent-licensing agreement pairing. Primary key for the association.' ;
    rdfs:domain ind:PatentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementRights rdf:type rdf:Property ;
    rdfs:label 'Enforcement Rights' ;
    rdfs:comment 'Identifies which party has the right to enforce this patent against third-party infringers during the license term. Licensor: licensor retains enforcement rights. Licensee: licensee has enforcement rights (common in exclusive licenses). Joint: both parties must agree. Licensee-First-Right: licensee has first right to enforce; licensor may enforce if licensee declines. May vary by patent within the same agreement.' ;
    rdfs:domain ind:PatentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Date' ;
    rdfs:comment 'Date on which this patent was removed from the licensing agreement, if applicable. May occur due to patent expiry, invalidation, amendment, or strategic decision to narrow the licensed portfolio. Null if the patent remains actively licensed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseScope rdf:type rdf:Property ;
    rdfs:label 'License Scope' ;
    rdfs:comment 'Defines the breadth of rights granted for this specific patent within the agreement. Full grants all rights; Limited restricts to specific claims or applications; Research-Only excludes commercial use; Commercial-Only excludes research use; Diagnostic-Only restricts to diagnostic applications. Scope may vary by patent within the same agreement.' ;
    rdfs:domain ind:PatentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceFeeResponsibility rdf:type rdf:Property ;
    rdfs:label 'Maintenance Fee Responsibility' ;
    rdfs:comment 'Identifies which party is responsible for paying patent maintenance fees (annuities) for this specific patent during the license term. Licensor: licensor pays. Licensee: licensee reimburses or pays directly. Shared: costs split per agreement terms. May vary by patent within the same agreement.' ;
    rdfs:domain ind:PatentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentSpecificMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Patent Specific Milestone Value' ;
    rdfs:comment 'Aggregate value of milestone payments specifically tied to this patent (e.g., regulatory approval milestone triggered only if this patent covers the approved product). Null if no patent-specific milestones exist. Complements agreement-level milestone tracking.' ;
    rdfs:domain ind:PatentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patentSpecificUpfrontPayment rdf:type rdf:Property ;
    rdfs:label 'Patent Specific Upfront Payment' ;
    rdfs:comment 'One-time upfront payment allocated to this specific patent, if the agreement structure assigns value to individual patents (common in patent portfolio acquisitions or carve-out deals). Null if upfront payment is agreement-level only.' ;
    rdfs:domain ind:PatentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prosecutionControl rdf:type rdf:Property ;
    rdfs:label 'Prosecution Control' ;
    rdfs:comment 'Identifies which party controls patent prosecution (filing, amendments, responses to office actions) for this specific patent during the license term. Licensor: licensor retains control. Licensee: licensee assumes control (common in exclusive licenses). Joint: both parties must agree. May vary by patent within the same agreement.' ;
    rdfs:domain ind:PatentLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingPatentAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Blocking Patent Assessment Id' ;
    rdfs:comment 'Unique surrogate identifier for each blocking patent assessment record.' ;
    rdfs:domain ind:BlockingPatentAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessingAttorney rdf:type rdf:Property ;
    rdfs:label 'Assessing Attorney' ;
    rdfs:comment 'Name of the patent attorney or IP counsel who conducted the assessment of this specific patent within the FTO analysis. May differ from the overall conducting attorney if multiple attorneys divided the patent review workload.' ;
    rdfs:domain ind:BlockingPatentAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingPatentCount rdf:type rdf:Property ;
    rdfs:label 'Blocking Patent Count' ;
    rdfs:comment 'Total number of third-party patents identified during the FTO analysis as potentially blocking or relevant to the commercialization of the assessed product or technology. Key metric for risk quantification. [Moved from fto_analysis: This is an aggregate count that should be derived from the blocking_patent_assessment association table via COUNT() rather than stored redundantly in fto_analysis. Moving it eliminates data synchronization risk.]' ;
    rdfs:domain ind:BlockingPatentAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockingPatentNumbers rdf:type rdf:Property ;
    rdfs:label 'Blocking Patent Numbers' ;
    rdfs:comment 'Comma-separated list of patent publication or grant numbers (e.g., US10123456B2, EP3456789A1) identified as potentially blocking in the FTO analysis. Enables direct cross-referencing with patent databases and IP watch systems. [Moved from fto_analysis: This comma-separated list is a denormalized representation of the M:N relationship. The patent numbers should be retrieved via JOIN to the blocking_patent_assessment association and then to the patent table, eliminating redundancy and ensuring data consistency.]' ;
    rdfs:domain ind:BlockingPatentAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimMapping rdf:type rdf:Property ;
    rdfs:label 'Claim Mapping' ;
    rdfs:comment 'Detailed mapping of specific patent claims (e.g., claims 1, 3, 7-12) to the company\'s product features, formulation elements, or process steps that may infringe. This is relationship-specific because it describes how THIS patent\'s claims read on THIS product/technology under analysis.' ;
    rdfs:domain ind:BlockingPatentAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designAroundStrategy rdf:type rdf:Property ;
    rdfs:label 'Design Around Strategy' ;
    rdfs:comment 'Narrative description of the proposed design-around approach to avoid infringement of this specific patent, such as alternative formulation, different synthesis route, modified dosing regimen, or alternative excipients. This is relationship-specific because the design-around is tailored to both the patent claims and the product under analysis.' ;
    rdfs:domain ind:BlockingPatentAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invalidityAssessment rdf:type rdf:Property ;
    rdfs:label 'Invalidity Assessment' ;
    rdfs:comment 'IP counsel\'s assessment of potential grounds for challenging the validity of this patent (e.g., prior art references, obviousness arguments, enablement deficiencies). This is relationship-specific because invalidity strategy is developed in the context of the specific FTO analysis and product development timeline.' ;
    rdfs:domain ind:BlockingPatentAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingRecommendation rdf:type rdf:Property ;
    rdfs:label 'Licensing Recommendation' ;
    rdfs:comment 'IP counsel\'s recommendation on whether a license should be pursued for this patent in the context of this FTO analysis. Values: required (license necessary to proceed), recommended (license advisable to mitigate risk), optional (license could reduce risk but not essential), not_required (no license needed). This is relationship-specific because licensing need depends on both the patent scope and the specific product/technology.' ;
    rdfs:domain ind:BlockingPatentAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonInfringementRationale rdf:type rdf:Property ;
    rdfs:label 'Non Infringement Rationale' ;
    rdfs:comment 'Legal rationale explaining why the company\'s product or technology does not infringe this patent, citing specific claim limitations, product specifications, or process differences. This is relationship-specific because the non-infringement argument is tailored to both the patent claims and the product under analysis.' ;
    rdfs:domain ind:BlockingPatentAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevelPerPatent rdf:type rdf:Property ;
    rdfs:label 'Risk Level Per Patent' ;
    rdfs:comment 'IP infringement risk level assigned specifically to this patent within the context of this FTO analysis. Values: critical (immediate blocking threat), high (significant infringement risk), medium (moderate risk requiring monitoring), low (minimal risk), negligible (no material risk). This is relationship-specific because the same patent may pose different risk levels to different products or technologies.' ;
    rdfs:domain ind:BlockingPatentAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalAdvisoryBoardMembershipId rdf:type rdf:Property ;
    rdfs:label 'Clinical Advisory Board Membership Id' ;
    rdfs:comment 'Primary key for clinical_advisory_board_membership' ;
    rdfs:domain ind:ClinicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coiDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Coi Document Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the stored conflict of interest disclosure document in the document management system (e.g., Veeva Vault).' ;
    rdfs:domain ind:ClinicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference identifier to the consulting or advisory services contract governing this membership, stored in the contract management system.' ;
    rdfs:domain ind:ClinicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitationAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Invitation Accepted Date' ;
    rdfs:comment 'Date on which the principal investigator accepted the invitation to serve on this advisory board. Precedes the formal appointment_date.' ;
    rdfs:domain ind:ClinicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invitationDate rdf:type rdf:Property ;
    rdfs:label 'Invitation Date' ;
    rdfs:comment 'Date on which the principal investigator was formally invited to join this advisory board. Used to track recruitment timeline and response time.' ;
    rdfs:domain ind:ClinicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of this membership. Active indicates the PI is currently serving; Inactive, Resigned, or Term Expired indicate the membership has ended.' ;
    rdfs:domain ind:ClinicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termEndDate rdf:type rdf:Property ;
    rdfs:label 'Term End Date' ;
    rdfs:comment 'Date on which the principal investigator\'s term on this advisory board expires or ended. Null indicates an ongoing appointment. Used for governance and succession planning.' ;
    rdfs:domain ind:ClinicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalMeetingsHeld rdf:type rdf:Property ;
    rdfs:label 'Total Meetings Held' ;
    rdfs:comment 'Total number of advisory board meetings held during this PI\'s membership term. Used to calculate attendance rate and assess member engagement.' ;
    rdfs:domain ind:ClinicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transparencyReportingDate rdf:type rdf:Property ;
    rdfs:label 'Transparency Reporting Date' ;
    rdfs:comment 'Date on which this membership was reported to transparency reporting authorities. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:ClinicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transparencyReportingSubmitted rdf:type rdf:Property ;
    rdfs:label 'Transparency Reporting Submitted' ;
    rdfs:comment 'Indicates whether this membership and associated honoraria have been submitted to applicable transparency reporting systems (e.g., CMS Open Payments, EFPIA Disclosure Code).' ;
    rdfs:domain ind:ClinicalAdvisoryBoardMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productListednessId rdf:type rdf:Property ;
    rdfs:label 'Product Listedness Id' ;
    rdfs:comment 'Unique surrogate identifier for the product-indication listedness record. Primary key.' ;
    rdfs:domain ind:ProductListedness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:psurInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Psur Inclusion Flag' ;
    rdfs:comment 'Boolean flag indicating whether adverse events for this product-indication combination should be included in Periodic Safety Update Report (PSUR) / Periodic Benefit-Risk Evaluation Report (PBRER) analysis for this jurisdiction.' ;
    rdfs:domain ind:ProductListedness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rmpSectionReference rdf:type rdf:Property ;
    rdfs:label 'Rmp Section Reference' ;
    rdfs:comment 'Reference to the specific section of the Risk Management Plan (RMP) that addresses this product-indication combination, if applicable. Used for safety specification and risk minimization activities.' ;
    rdfs:domain ind:ProductListedness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmpReviewId rdf:type rdf:Property ;
    rdfs:label 'Rmp Review Id' ;
    rdfs:comment 'Unique identifier for this RMP review record. Primary key for the association.' ;
    rdfs:domain ind:RmpReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commentsProvided rdf:type rdf:Property ;
    rdfs:label 'Comments Provided' ;
    rdfs:comment 'Textual comments, findings, or recommendations provided by the HCP reviewer regarding the RMP content, scientific accuracy, or regulatory compliance. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:RmpReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expertSpecialty rdf:type rdf:Property ;
    rdfs:label 'Expert Specialty' ;
    rdfs:comment 'The therapeutic area or medical specialty expertise that qualified this HCP to review this RMP (e.g., Oncology, Immunology, Rare Diseases). Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:RmpReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryReviewer rdf:type rdf:Property ;
    rdfs:label 'Is Primary Reviewer' ;
    rdfs:comment 'Indicates whether this HCP is the primary/lead reviewer for this RMP (true) or a secondary/supporting reviewer (false).' ;
    rdfs:domain ind:RmpReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewHours rdf:type rdf:Property ;
    rdfs:label 'Review Hours' ;
    rdfs:comment 'Number of hours spent by the HCP on reviewing this RMP, used for workload tracking and external consultant billing.' ;
    rdfs:domain ind:RmpReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when the RMP review was assigned to this HCP, marking the start of the review period.' ;
    rdfs:domain ind:RmpReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerRole rdf:type rdf:Property ;
    rdfs:label 'Reviewer Role' ;
    rdfs:comment 'The functional role in which the HCP reviewed this RMP (e.g., Medical Reviewer, Therapeutic Area Specialist, External Consultant). Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:RmpReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionReviewed rdf:type rdf:Property ;
    rdfs:label 'Section Reviewed' ;
    rdfs:comment 'Specific section(s) of the RMP document reviewed by this HCP (e.g., Safety Specification, Pharmacovigilance Plan, Risk Minimization Measures, PASS Commitments). Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:RmpReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalIndicationAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Signal Indication Assessment Id' ;
    rdfs:comment 'Unique surrogate identifier for the signal-indication assessment record. Primary key for the association.' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Name or identifier of the pharmacovigilance professional who performed the indication-specific signal assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCountForIndication rdf:type rdf:Property ;
    rdfs:label 'Case Count For Indication' ;
    rdfs:comment 'Number of Individual Case Safety Reports (ICSRs) contributing to this safety signal that are specifically associated with this product indication. Subset of the total signal case count stratified by indication.' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contraindicationRecommendation rdf:type rdf:Property ;
    rdfs:label 'Contraindication Recommendation' ;
    rdfs:comment 'Specific recommendation for adding or modifying contraindications for this indication based on the signal assessment, including patient populations, comorbidities, or concomitant medications that should be contraindicated.' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatalCaseCountForIndication rdf:type rdf:Property ;
    rdfs:label 'Fatal Case Count For Indication' ;
    rdfs:comment 'Number of fatal outcome cases among the indication-specific cases contributing to this signal assessment.' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indicationRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Indication Restriction Flag' ;
    rdfs:comment 'Boolean indicator of whether the signal assessment recommends restricting or narrowing the approved indication (e.g., limiting to specific patient subpopulations, adding biomarker requirements, restricting line of therapy).' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelChangeRecommendation rdf:type rdf:Property ;
    rdfs:label 'Label Change Recommendation' ;
    rdfs:comment 'Specific recommendation for product label modification for this indication, including proposed section (warnings, precautions, adverse reactions, dosage and administration) and verbatim text recommendation.' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pracNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Prac Notification Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this indication-specific signal assessment requires notification to the PRAC rapporteur per EMA pharmacovigilance requirements.' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prrValueForIndication rdf:type rdf:Property ;
    rdfs:label 'Prr Value For Indication' ;
    rdfs:comment 'Proportional Reporting Ratio (PRR) calculated specifically for this signal-indication combination using indication-stratified case data.' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rorValueForIndication rdf:type rdf:Property ;
    rdfs:label 'Ror Value For Indication' ;
    rdfs:comment 'Reporting Odds Ratio (ROR) calculated specifically for this signal-indication combination using indication-stratified case data.' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seriousCaseCountForIndication rdf:type rdf:Property ;
    rdfs:label 'Serious Case Count For Indication' ;
    rdfs:comment 'Number of Serious Adverse Event (SAE) cases among the indication-specific cases contributing to this signal assessment.' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalStrengthForIndication rdf:type rdf:Property ;
    rdfs:label 'Signal Strength For Indication' ;
    rdfs:comment 'Qualitative assessment of the signal strength specifically for this indication, based on indication-stratified disproportionality analysis, case characteristics, and clinical plausibility. Values: strong, moderate, weak, insufficient.' ;
    rdfs:domain ind:SignalIndicationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalExpertConsultationId rdf:type rdf:Property ;
    rdfs:label 'Signal Expert Consultation Id' ;
    rdfs:comment 'Primary key for signal_expert_consultation' ;
    rdfs:domain ind:SignalExpertConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:causalityOpinion rdf:type rdf:Property ;
    rdfs:label 'Causality Opinion' ;
    rdfs:comment 'Expert assessment of causal relationship between the medicinal product and the adverse event. Typically structured as: certain, probable/likely, possible, unlikely, conditional/unclassified, unassessable/unclassifiable per WHO-UMC causality categories.' ;
    rdfs:domain ind:SignalExpertConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationDate rdf:type rdf:Property ;
    rdfs:label 'Consultation Date' ;
    rdfs:comment 'Date when the expert consultation occurred or expert opinion was provided. Critical for regulatory timeline documentation and transparency reporting.' ;
    rdfs:domain ind:SignalExpertConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consultationNumber rdf:type rdf:Property ;
    rdfs:label 'Consultation Number' ;
    rdfs:comment 'Unique identifier for the expert consultation engagement record. Primary key for the association.' ;
    rdfs:domain ind:SignalExpertConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consultationRequestDate rdf:type rdf:Property ;
    rdfs:label 'Consultation Request Date' ;
    rdfs:comment 'Date when the expert consultation was formally requested by the pharmacovigilance team. Supports SLA tracking for signal evaluation timelines.' ;
    rdfs:domain ind:SignalExpertConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consultationStatus rdf:type rdf:Property ;
    rdfs:label 'Consultation Status' ;
    rdfs:comment 'Current status of the expert consultation engagement. Values: requested, scheduled, completed, opinion_received, incorporated_in_assessment, cancelled.' ;
    rdfs:domain ind:SignalExpertConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expertOpinionText rdf:type rdf:Property ;
    rdfs:label 'Expert Opinion Text' ;
    rdfs:comment 'Detailed narrative opinion provided by the HCP expert regarding the safety signal, including clinical interpretation, mechanism plausibility, and recommendations. Supports regulatory submissions and signal assessment documentation.' ;
    rdfs:domain ind:SignalExpertConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expertRole rdf:type rdf:Property ;
    rdfs:label 'Expert Role' ;
    rdfs:comment 'Role or capacity in which the HCP expert is consulting on this signal. Examples: advisory board member, external consultant, KOL reviewer, therapeutic area expert, PRAC rapporteur consultant.' ;
    rdfs:domain ind:SignalExpertConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentContribution rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Contribution' ;
    rdfs:comment 'Expert contribution to benefit-risk assessment for the signal, including impact on product risk profile, patient population considerations, and risk mitigation recommendations.' ;
    rdfs:domain ind:SignalExpertConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyAllocationId rdf:type rdf:Property ;
    rdfs:label 'Supply Allocation Id' ;
    rdfs:comment 'Unique identifier for the supply allocation record. Primary key for the association product.' ;
    rdfs:domain ind:SupplyAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of total SKU demand allocated to this plant in the supply network. Used for demand planning and ATP calculations. Sum of allocation percentages across all plants for a given SKU should equal 100% for active allocations. Null if allocation is based on absolute capacity rather than percentage.' ;
    rdfs:domain ind:SupplyAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Maximum Capacity Units' ;
    rdfs:comment 'Maximum production or packaging capacity for this SKU at this plant, expressed in SKU units (e.g., bottles, cartons). Used for capacity planning, demand allocation, and ATP calculations. Null if capacity is managed at aggregate plant level rather than SKU level.' ;
    rdfs:domain ind:SupplyAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primarySupplyFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Supply Flag' ;
    rdfs:comment 'Indicates whether this plant is designated as the primary supply source for this SKU. True for primary plant, false for secondary/backup plants. Only one plant should be marked as primary for a given SKU at any point in time. Used for supply chain routing and prioritization decisions.' ;
    rdfs:domain ind:SupplyAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyPriority rdf:type rdf:Property ;
    rdfs:label 'Supply Priority' ;
    rdfs:comment 'Numeric priority ranking for this plant in the supply network for this SKU. Lower numbers indicate higher priority (1 = highest priority). Used during supply allocation decisions when demand exceeds capacity or when plants experience disruptions. Enables cascading supply logic in ATP and order promising systems.' ;
    rdfs:domain ind:SupplyAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impAccountabilityId rdf:type rdf:Property ;
    rdfs:label 'Imp Accountability Id' ;
    rdfs:comment 'Primary key for the imp_accountability association' ;
    rdfs:domain ind:ImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destructionQuantity rdf:type rdf:Property ;
    rdfs:label 'Destruction Quantity' ;
    rdfs:comment 'Quantity of this lot destroyed at the site per protocol (expired, damaged, or end-of-study destruction). Requires destruction certificate for regulatory compliance.' ;
    rdfs:domain ind:ImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyReason rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason' ;
    rdfs:comment 'Free-text explanation of any accountability discrepancy (quantity variance, missing documentation, temperature excursion during shipment). Triggers CAPA if material.' ;
    rdfs:domain ind:ImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensedDate rdf:type rdf:Property ;
    rdfs:label 'Dispensed Date' ;
    rdfs:comment 'Date on which this lot was first dispensed to a patient in this trial at this site. Critical for expiry compliance verification and audit trail.' ;
    rdfs:domain ind:ImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippedDate rdf:type rdf:Property ;
    rdfs:label 'Shipped Date' ;
    rdfs:comment 'Date on which this lot was shipped from the depot to the clinical site for use in this trial. Start of the accountability timeline.' ;
    rdfs:domain ind:ImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temperatureMonitoringCompliant rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitoring Compliant' ;
    rdfs:comment 'Flag indicating whether this lot maintained required storage conditions throughout its lifecycle at the site for this trial. False triggers deviation investigation.' ;
    rdfs:domain ind:ImpAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trialVendorEngagementId rdf:type rdf:Property ;
    rdfs:label 'Trial Vendor Engagement Id' ;
    rdfs:comment 'Primary key for the trial_vendor_engagement association' ;
    rdfs:domain ind:TrialVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliverableDate rdf:type rdf:Property ;
    rdfs:label 'Actual Deliverable Date' ;
    rdfs:comment 'Actual date when the primary deliverable was received from the vendor. Used to calculate delivery variance and assess on-time performance.' ;
    rdfs:domain ind:TrialVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contract Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value (e.g., USD, EUR, GBP). Required for multi-currency trial budget consolidation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableDueDate rdf:type rdf:Property ;
    rdfs:label 'Deliverable Due Date' ;
    rdfs:comment 'Date when the primary deliverable from the vendor is due (e.g., CSR for medical writing vendor, database lock for data management vendor, final lab report for central lab). Used for milestone tracking and performance monitoring.' ;
    rdfs:domain ind:TrialVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeOfWork rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Detailed description of the specific services, deliverables, and responsibilities assigned to the vendor for this trial. May reference contract exhibits, SOWs, or protocol sections. Critical for defining vendor accountability and managing scope changes.' ;
    rdfs:domain ind:TrialVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the service or material provided by the vendor for this trial. Determines operational workflows, deliverable expectations, and performance metrics. Examples: CRO Full Service (end-to-end trial management), Central Laboratory (sample analysis), IMP Manufacturing (investigational medicinal product production), SMO (site management organization for patient recruitment).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorGxpQualificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Gxp Qualification Id' ;
    rdfs:comment 'Unique identifier for this vendor-GxP obligation qualification record. Primary key.' ;
    rdfs:domain ind:VendorGxpQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Evidence Reference' ;
    rdfs:comment 'Reference identifier or document path to the compliance evidence package supporting this vendor\'s qualification for this obligation. May include audit reports, certificates, test results, quality agreements, and correspondence with regulatory authorities.' ;
    rdfs:domain ind:VendorGxpQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationAuthority rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Authority' ;
    rdfs:comment 'Name of the regulatory authority or certification body that issued the GMP certification (e.g., FDA, EMA, MHRA, PMDA, WHO PQ). [Moved from vendor: Similar to above - this is vendor-level general GMP certification metadata. The association tracks obligation-specific qualification, not general certifications. This should remain on vendor. Removing this entry.]' ;
    rdfs:domain ind:VendorGxpQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Expiry Date' ;
    rdfs:comment 'Date when the current GMP certification expires. Vendors must renew certification before this date to maintain qualified supplier status. [Moved from vendor: This is the vendor\'s general GMP certificate expiry. The association has qualification_expiry_date which is obligation-specific and may differ. Both are needed. Removing this entry.]' ;
    rdfs:domain ind:VendorGxpQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Timestamp when this vendor-GxP obligation qualification record was last modified.' ;
    rdfs:domain ind:VendorGxpQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualificationOwner rdf:type rdf:Property ;
    rdfs:label 'Qualification Owner' ;
    rdfs:comment 'The role, department, or individual responsible for managing this specific vendor-obligation qualification. May differ from the general obligation owner based on vendor category or material type.' ;
    rdfs:domain ind:VendorGxpQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last updated this qualification record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSiteAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Application Site Authorization Id' ;
    rdfs:comment 'Primary key for the application_site_authorization association' ;
    rdfs:domain ind:ApplicationSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityAllocation rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation' ;
    rdfs:comment 'The percentage or amount of site capacity allocated to this specific application. Enables capacity planning and tracking when a site supports multiple applications. May be expressed as percentage of total site capacity or absolute units.' ;
    rdfs:domain ind:ApplicationSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Inspection Required Flag' ;
    rdfs:comment 'Indicates whether a health authority GMP inspection of this site is required as part of the approval process for this application. Inspection requirements vary by application type, site history, and regulatory pathway.' ;
    rdfs:domain ind:ApplicationSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDateForApplication rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date For Application' ;
    rdfs:comment 'The date of the most recent health authority inspection of this site specifically in the context of this application. Different from the site\'s general last inspection date, as inspections may be application-triggered.' ;
    rdfs:domain ind:ApplicationSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingStep rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Step' ;
    rdfs:comment 'The specific manufacturing step or process stage assigned to this site for this application (e.g., API synthesis, formulation, sterile filling, lyophilization, primary packaging). Enables tracking of the manufacturing chain across multiple sites.' ;
    rdfs:domain ind:ApplicationSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySiteFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Site Flag' ;
    rdfs:comment 'Indicates whether this is the primary manufacturing site for this application for this manufacturing step. An application may have multiple sites for the same step (backup capacity), but typically designates one as primary.' ;
    rdfs:domain ind:ApplicationSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteMasterFileReference rdf:type rdf:Property ;
    rdfs:label 'Site Master File Reference' ;
    rdfs:comment 'Reference to the Site Master File (SMF) or Drug Master File (DMF) submitted to the health authority for this site in support of this application. SMF references are application-specific.' ;
    rdfs:domain ind:ApplicationSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteRole rdf:type rdf:Property ;
    rdfs:label 'Site Role' ;
    rdfs:comment 'The specific manufacturing or testing role that this site performs for this application. A site may have different roles for different applications.' ;
    rdfs:domain ind:ApplicationSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEngagementId rdf:type rdf:Property ;
    rdfs:label 'Service Engagement Id' ;
    rdfs:comment 'Primary key for the regulatory_service_engagement association' ;
    rdfs:domain ind:ServiceEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverableStatus rdf:type rdf:Property ;
    rdfs:label 'Deliverable Status' ;
    rdfs:comment 'Current status of the deliverables expected from this vendor for this application. Tracks progress of vendor obligations and service completion.' ;
    rdfs:domain ind:ServiceEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerCoverageId rdf:type rdf:Property ;
    rdfs:label 'Payer Coverage Id' ;
    rdfs:comment 'Unique surrogate identifier for this payer coverage agreement record. Primary key.' ;
    rdfs:domain ind:PayerCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiation Owner Employee Id' ;
    rdfs:comment 'Identifier of the market access account manager or payer relations director responsible for negotiating and maintaining this specific payer coverage agreement.' ;
    rdfs:domain ind:PayerCoverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:drugProductAssaySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Drug Product Assay Specification Id' ;
    rdfs:comment 'Primary key for the drug_product_assay_specification association' ;
    rdfs:domain ind:DrugProductAssaySpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testingSiteId rdf:type rdf:Property ;
    rdfs:label 'Testing Site Id' ;
    rdfs:comment 'Reference to the QC laboratory or contract testing organization authorized to perform this assay for this product. May differ by product even for the same assay.' ;
    rdfs:domain ind:DrugProductAssaySpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:assayPurpose rdf:type rdf:Property ;
    rdfs:label 'Assay Purpose' ;
    rdfs:comment 'The regulatory and operational purpose for which this assay is applied to this drug product. Determines when and how the assay is executed in the product lifecycle.' ;
    rdfs:domain ind:DrugProductAssaySpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfSpecificationProcedure rdf:type rdf:Property ;
    rdfs:label 'Out Of Specification Procedure' ;
    rdfs:comment 'Reference to the OOS investigation procedure or escalation path specific to this product-assay combination, which may vary by product criticality or regulatory risk.' ;
    rdfs:domain ind:DrugProductAssaySpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportableToRegulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Reportable To Regulatory Authority' ;
    rdfs:comment 'Indicates whether results from this assay for this product must be included in annual reports, stability reports, or other regulatory submissions.' ;
    rdfs:domain ind:DrugProductAssaySpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Specification Effective Date' ;
    rdfs:comment 'The date from which this specification became effective for batch release or stability testing. Critical for traceability when specifications change over product lifecycle.' ;
    rdfs:domain ind:DrugProductAssaySpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Specification Expiry Date' ;
    rdfs:comment 'The date on which this specification was superseded or retired. Null if currently active.' ;
    rdfs:domain ind:DrugProductAssaySpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:brandSupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Brand Supply Agreement Id' ;
    rdfs:comment 'Unique identifier for the brand-vendor supply agreement record' ;
    rdfs:domain ind:BrandSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualSpendAllocation rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Allocation' ;
    rdfs:comment 'Planned or actual annual procurement spend allocated to this vendor for this brand in USD. Used for spend analysis, vendor performance tracking, and multi-sourcing strategy optimization.' ;
    rdfs:domain ind:BrandSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedMaterialCategory rdf:type rdf:Property ;
    rdfs:label 'Approved Material Category' ;
    rdfs:comment 'The category of materials or services this vendor is qualified to supply for this specific brand (e.g., API, excipient, packaging material). A vendor may supply different material categories for different brands based on qualification scope.' ;
    rdfs:domain ind:BrandSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastQualityReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Quality Review Date' ;
    rdfs:comment 'Date of the most recent quality review conducted for this vendor in the context of supplying this specific brand' ;
    rdfs:domain ind:BrandSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextQualityReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Quality Review Due Date' ;
    rdfs:comment 'Scheduled date for the next quality review of this vendor for this brand' ;
    rdfs:domain ind:BrandSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primarySupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Flag' ;
    rdfs:comment 'Indicates whether this vendor is designated as the primary supplier for the approved material category for this brand. Brands typically have one primary and multiple secondary suppliers per material category for supply continuity.' ;
    rdfs:domain ind:BrandSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyAgreementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Effective Date' ;
    rdfs:comment 'Date when the supply agreement for this brand-vendor relationship became effective' ;
    rdfs:domain ind:BrandSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyAgreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Expiry Date' ;
    rdfs:comment 'Date when the supply agreement for this brand-vendor relationship expires and requires renewal' ;
    rdfs:domain ind:BrandSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientEnrollment2Id rdf:type rdf:Property ;
    rdfs:label 'Patient Enrollment2 Id' ;
    rdfs:comment 'Primary key for patient_enrollment2' ;
    rdfs:domain ind:PatientEnrollment2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Date' ;
    rdfs:comment 'Date when the biobank received its current accreditation.' ;
    rdfs:domain ind:Biobank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date when the current accreditation expires and requires renewal.' ;
