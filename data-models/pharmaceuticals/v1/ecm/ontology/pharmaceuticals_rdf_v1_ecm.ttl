# --- Attribute Properties ---
ind:biospecimenId rdf:type rdf:Property ;
    rdfs:label 'Biospecimen Id' ;
    rdfs:comment 'Unique identifier for the biospecimen record. Primary key for the biospecimen transactional entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Biospecimen .

ind:accountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: Biospecimen processing and storage generate vendor invoices from central labs, biobanks, and specialty testing facilities. Required for trial cost tracking, vendor payment processing, and per-protocol' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:biobankId rdf:type rdf:Property ;
    rdfs:label 'Biobank Id' ;
    rdfs:comment 'The identifier assigned by the biobank or central repository where the specimen is stored. Used for long-term tracking and retrieval.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Biobank .

ind:clinicalEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Clinical Enrollment Id' ;
    rdfs:comment 'Foreign key linking to clinical.enrollment. Business justification: Biospecimens are collected from enrolled subjects and may be analyzed by treatment arm for exploratory biomarker endpoints. Linking biospecimen to enrollment enables treatment arm stratification of bi' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalEnrollment .

ind:collectedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collected By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Biospecimen collection by site staff requires documented collector identity for chain of custody, GxP compliance, and training verification. Essential for regulatory inspections and biobank quality ma' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:crfFormId rdf:type rdf:Property ;
    rdfs:label 'Crf Form Id' ;
    rdfs:comment 'Foreign key linking to clinical.crf_form. Business justification: Biospecimen collection is documented via CRF forms (biospecimen collection CRF) in the EDC system. Linking biospecimen to crf_form enables traceability to the data collection instrument and supports s' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrfForm .

ind:dmfId rdf:type rdf:Property ;
    rdfs:label 'Dmf Id' ;
    rdfs:comment 'Foreign key linking to regulatory.dmf. Business justification: Bioanalytical methods, reference standards, and assay validation for biospecimens are documented in Drug Master Files (Type II or III). CMC regulatory teams must reference the appropriate DMF when bio' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dmf .

ind:investigationalSiteId rdf:type rdf:Property ;
    rdfs:label 'Investigational Site Id' ;
    rdfs:comment 'Reference to the investigational site where the biospecimen was collected. Links to the site master record in the Clinical Trial Management System (CTMS).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestigationalSite .

ind:medicinalProductId rdf:type rdf:Property ;
    rdfs:label 'Medicinal Product Id' ;
    rdfs:comment 'Foreign key linking to product.medicinal_product. Business justification: Biomarker studies, PK/PD analysis, and translational research require linking specimens to the product being tested. Essential for dose-response modeling, bioequivalence studies, and supporting produc' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicinalProduct .

ind:patientId rdf:type rdf:Property ;
    rdfs:label 'Patient Id' ;
    rdfs:comment 'Reference to the clinical trial subject from whom this biospecimen was collected. Links to the subject master record in the clinical trial management system.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patient .

ind:privacyImpactAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Privacy Impact Assessment Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_impact_assessment. Business justification: Biospecimen collection involves processing personal data (genetic, health) requiring DPIA under GDPR. Links biobanking activities to privacy compliance assessments for consent, data transfer, and rete' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyImpactAssessment .

ind:processingVendorId rdf:type rdf:Property ;
    rdfs:label 'Processing Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Central labs and bioanalytical vendors process trial specimens. Business process: specimen shipment tracking, lab vendor qualification, Certificate of Analysis receipt, result reconciliation, and vend' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:protocolId rdf:type rdf:Property ;
    rdfs:label 'Protocol Id' ;
    rdfs:comment 'Foreign key linking to clinical.protocol. Business justification: Biospecimen collection procedures, timing, and handling are defined in the protocol. Linking biospecimen to protocol version enables verification that collection followed the protocol-specified proced' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Protocol .

ind:reagentInventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Reagent Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: Biospecimen processing uses reagent/consumable lots; GCP compliance (ICH E6) requires lot traceability for data integrity and result reproducibility. Role prefix distinguishes reagent lots from clinic' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:rweDatasetId rdf:type rdf:Property ;
    rdfs:label 'Rwe Dataset Id' ;
    rdfs:comment 'Foreign key linking to market.rwe_dataset. Business justification: Trial biospecimens may be analyzed for RWE generation (biomarker studies, pharmacogenomics, translational research). RWE datasets reference trial biospecimen collections for real-world evidence suppor' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RweDataset .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to masterdata.storage_location. Business justification: Biospecimens are stored at specific controlled locations (central labs, biobanks, -80°C freezers). Required for sample tracking, chain of custody, retrieval for analysis, temperature excursion monitor' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:trialId rdf:type rdf:Property ;
    rdfs:label 'Trial Id' ;
    rdfs:comment 'Reference to the clinical trial under which this biospecimen was collected. Links to the trial master record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trial .

ind:unitOfMeasureId rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure Id' ;
    rdfs:comment 'Foreign key linking to masterdata.unit_of_measure. Business justification: Specimen volume uses standardized units (mL, µL). Required for lab processing (sufficient volume checks), aliquot planning, inventory management, and CDISC SDTM LB domain mapping. Essential for specim' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitOfMeasure .

ind:visitId rdf:type rdf:Property ;
    rdfs:label 'Visit Id' ;
    rdfs:comment 'Reference to the protocol-defined visit during which this biospecimen was collected. Links to the visit schedule in the Electronic Data Capture (EDC) system.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Visit .

ind:anatomicalSite rdf:type rdf:Property ;
    rdfs:label 'Anatomical Site' ;
    rdfs:comment 'The anatomical location from which the specimen was collected, such as left arm, liver, or lung. Particularly important for tissue biopsies and tumor samples.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayPlanned rdf:type rdf:Property ;
    rdfs:label 'Assay Planned' ;
    rdfs:comment 'The name or code of the assay or test planned to be performed on this specimen, such as pharmacokinetic (PK) analysis, biomarker assay, or genomic sequencing. Supports laboratory planning and resource allocation.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyVerified rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Verified' ;
    rdfs:comment 'Indicates whether the chain of custody for the specimen has been verified and documented. True if verified, False otherwise. Critical for regulatory compliance and data integrity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'The date on which the biospecimen was collected from the trial subject. Critical for protocol compliance and time-to-event analysis.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'The method or procedure used to collect the specimen, such as venipuncture, biopsy, or catheterization. Ensures protocol compliance and reproducibility.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'The precise date and time when the biospecimen was collected. Required for pharmacokinetic (PK) and pharmacodynamic (PD) studies where timing is critical.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collectionVisitName rdf:type rdf:Property ;
    rdfs:label 'Collection Visit Name' ;
    rdfs:comment 'The protocol-defined name of the visit during which the specimen was collected, such as Baseline, Week 4, End of Treatment. Aligns with the visit schedule in the Case Report Form (CRF).' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentBiobankFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Biobank Flag' ;
    rdfs:comment 'Indicates whether the subject provided optional consent for long-term biobanking and future research use of this specimen. True if consent was provided, False otherwise.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentGeneticTestingFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Genetic Testing Flag' ;
    rdfs:comment 'Indicates whether the subject provided optional consent for genetic or pharmacogenomic testing on this specimen. True if consent was provided, False otherwise.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'The type of tube or container used for specimen collection, such as EDTA tube, serum separator tube, cryovial. Critical for ensuring proper specimen handling and assay validity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The date and time when this biospecimen record was first created in the system. Supports audit trail and data lineage tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Detailed description of any protocol deviation that occurred during specimen collection, processing, or handling. Required for regulatory documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastingStatus rdf:type rdf:Property ;
    rdfs:label 'Fasting Status' ;
    rdfs:comment 'Indicates whether the subject was fasting at the time of specimen collection. Critical for certain laboratory tests such as glucose and lipid panels.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loincCode rdf:type rdf:Property ;
    rdfs:label 'Loinc Code' ;
    rdfs:comment 'The standardized LOINC code representing the specimen type and associated test. Enables interoperability with laboratory information systems and regulatory submissions.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDate rdf:type rdf:Property ;
    rdfs:label 'Processing Date' ;
    rdfs:comment 'The date on which the specimen was processed in the laboratory. Used to track time from collection to processing for quality control.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processingMethod rdf:type rdf:Property ;
    rdfs:label 'Processing Method' ;
    rdfs:comment 'The method used to process the specimen after collection, such as centrifugation, aliquoting, or fixation. Ensures traceability of specimen handling procedures.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Flag' ;
    rdfs:comment 'Indicates whether the specimen collection deviated from the protocol-defined procedures. True if a deviation occurred, False otherwise.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The date on which the specimen was received at the central laboratory or biobank. Used to verify shipment integrity and processing timelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'The date on which the specimen was shipped to the central laboratory or biobank. Used to track transit time and ensure cold chain compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Number' ;
    rdfs:comment 'The tracking number assigned to the shipment when the specimen was sent to a central laboratory or biobank. Supports chain-of-custody documentation.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snomedCode rdf:type rdf:Property ;
    rdfs:label 'Snomed Code' ;
    rdfs:comment 'The standardized SNOMED CT code representing the specimen type or anatomical source. Supports clinical terminology standardization and regulatory compliance.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenNumber rdf:type rdf:Property ;
    rdfs:label 'Specimen Number' ;
    rdfs:comment 'Unique business identifier for the biospecimen, typically a barcode or alphanumeric code assigned at collection. Used for chain-of-custody tracking and laboratory processing.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenQuality rdf:type rdf:Property ;
    rdfs:label 'Specimen Quality' ;
    rdfs:comment 'Assessment of the specimen quality upon receipt or processing. Identifies any conditions that may affect assay results or specimen usability.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenStatus rdf:type rdf:Property ;
    rdfs:label 'Specimen Status' ;
    rdfs:comment 'The current lifecycle status of the biospecimen, indicating its stage in the collection, processing, storage, and analysis workflow. [ENUM-REF-CANDIDATE: collected|processed|stored|shipped|received|analyzed|depleted|discarded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenSubtype rdf:type rdf:Property ;
    rdfs:label 'Specimen Subtype' ;
    rdfs:comment 'Further classification or detail of the specimen type, such as specific tissue origin or blood component. Provides granular categorization for specialized assays.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenType rdf:type rdf:Property ;
    rdfs:label 'Specimen Type' ;
    rdfs:comment 'Classification of the biological specimen collected. Defines the nature of the sample for processing and analysis requirements. [ENUM-REF-CANDIDATE: blood|serum|plasma|urine|tissue|csf|saliva|bone_marrow|tumor_biopsy — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperature rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature' ;
    rdfs:comment 'The temperature condition under which the specimen is stored, such as room temperature, refrigerated (2-8°C), frozen at -20°C, frozen at -80°C, or in liquid nitrogen. Critical for specimen stability and assay integrity.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDay rdf:type rdf:Property ;
    rdfs:label 'Study Day' ;
    rdfs:comment 'The day relative to the reference date (typically first dose or randomization) on which the specimen was collected. Negative values indicate pre-treatment, positive values indicate post-treatment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The date and time when this biospecimen record was last modified in the system. Supports audit trail and change tracking for regulatory compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volumeCollected rdf:type rdf:Property ;
    rdfs:label 'Volume Collected' ;
    rdfs:comment 'The quantity of specimen collected, measured in the unit specified in volume_unit. Used to determine sufficiency for planned assays.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdiscDomainMapId rdf:type rdf:Property ;
    rdfs:label 'Cdisc Domain Map Id' ;
    rdfs:comment 'Unique identifier for the CDISC domain mapping record. Primary key for this entity.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: CDISC mapping specifications require qualified reviewer approval for regulatory submission readiness. Current text field \'approved_by\' should be FK to employee for qualification tracking and 21 CFR Pa' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dataManagementPlanId rdf:type rdf:Property ;
    rdfs:label 'Data Management Plan Id' ;
    rdfs:comment 'Foreign key linking to clinical.data_management_plan. Business justification: CDISC SDTM domain mappings are defined in the clinical data management plan (DMP). The DMP specifies SDTM version, mapping standards, and controlled terminology versions. Linking cdisc_domain_map to d' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataManagementPlan .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.submission. Business justification: CDISC mappings are submission-specific and must align with target health authority expectations (FDA, EMA, PMDA have different requirements). Regulatory data operations must version CDISC mappings per' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when this domain mapping configuration was formally approved for use in clinical data processing and regulatory submission.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdashFieldName rdf:type rdf:Property ;
    rdfs:label 'Cdash Field Name' ;
    rdfs:comment 'CDASH standard field name from which the data originates, representing the source data collection instrument field.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codelistVersion rdf:type rdf:Property ;
    rdfs:label 'Codelist Version' ;
    rdfs:comment 'Version of the CDISC controlled terminology codelist being used for this mapping, ensuring alignment with the correct terminology release.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledTerminologyCodelist rdf:type rdf:Property ;
    rdfs:label 'Controlled Terminology Codelist' ;
    rdfs:comment 'Reference to the CDISC controlled terminology codelist used for standardizing values (e.g., C66728 for Units, C71113 for Sex), ensuring regulatory compliance.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crfFieldLabel rdf:type rdf:Property ;
    rdfs:label 'Crf Field Label' ;
    rdfs:comment 'Human-readable label or prompt text displayed on the CRF for the field being mapped.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crfFieldName rdf:type rdf:Property ;
    rdfs:label 'Crf Field Name' ;
    rdfs:comment 'Actual field name or identifier from the electronic data capture (EDC) system CRF that is being mapped to the SDTM variable.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionScenario rdf:type rdf:Property ;
    rdfs:label 'Data Collection Scenario' ;
    rdfs:comment 'Description of the clinical data collection scenario or context in which this mapping applies (e.g., baseline visit, adverse event reporting, laboratory assessments).' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcOid rdf:type rdf:Property ;
    rdfs:label 'Edc Oid' ;
    rdfs:comment 'Object identifier (OID) from the EDC system that uniquely identifies the form or field being mapped, enabling traceability to the source system.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date after which this domain mapping configuration is no longer effective and should not be applied to new data, supporting versioning and change management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this domain mapping configuration becomes effective and should be applied to clinical trial data.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isRequiredForSubmission rdf:type rdf:Property ;
    rdfs:label 'Is Required For Submission' ;
    rdfs:comment 'Boolean flag indicating whether this domain mapping is mandatory for regulatory submission to FDA, EMA, or other health authorities.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mappingName rdf:type rdf:Property ;
    rdfs:label 'Mapping Name' ;
    rdfs:comment 'Human-readable name or label for this domain mapping configuration, used for identification and reference purposes.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingNotes rdf:type rdf:Property ;
    rdfs:label 'Mapping Notes' ;
    rdfs:comment 'Additional notes, comments, or clarifications regarding the mapping logic, special cases, or implementation considerations for data managers and programmers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingPriority rdf:type rdf:Property ;
    rdfs:label 'Mapping Priority' ;
    rdfs:comment 'Priority level of this mapping for regulatory submission: critical (required for submission), high (important for analysis), medium (supporting data), or low (optional).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingStatus rdf:type rdf:Property ;
    rdfs:label 'Mapping Status' ;
    rdfs:comment 'Current lifecycle status of the domain mapping: draft (in development), under_review (pending approval), approved (validated), active (in use), deprecated (superseded), or retired (no longer used).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingType rdf:type rdf:Property ;
    rdfs:label 'Mapping Type' ;
    rdfs:comment 'Type of mapping transformation applied: direct (one-to-one), derived (calculated), concatenated (multiple fields combined), split (one field to multiple), conditional (logic-based), or lookup (reference table).' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingVersion rdf:type rdf:Property ;
    rdfs:label 'Mapping Version' ;
    rdfs:comment 'Version number or identifier for this domain mapping configuration, tracking changes and iterations over time.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmDomainCode rdf:type rdf:Property ;
    rdfs:label 'Sdtm Domain Code' ;
    rdfs:comment 'Two-character CDISC SDTM domain code (e.g., DM for Demographics, AE for Adverse Events, LB for Laboratory) to which the CRF data is mapped.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmDomainName rdf:type rdf:Property ;
    rdfs:label 'Sdtm Domain Name' ;
    rdfs:comment 'Full descriptive name of the SDTM domain (e.g., Demographics, Adverse Events, Laboratory Test Results) corresponding to the domain code.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVariableLabel rdf:type rdf:Property ;
    rdfs:label 'Sdtm Variable Label' ;
    rdfs:comment 'Human-readable label for the SDTM variable, providing descriptive context for the mapped field.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVariableName rdf:type rdf:Property ;
    rdfs:label 'Sdtm Variable Name' ;
    rdfs:comment 'Specific SDTM variable name (e.g., USUBJID, AETERM, LBTEST) to which the CRF field is mapped, following CDISC controlled terminology.' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVersion rdf:type rdf:Property ;
    rdfs:label 'Sdtm Version' ;
    rdfs:comment 'Version of the CDISC SDTM standard being used for this mapping (e.g., 3.2, 3.3, 3.4), ensuring compliance with the correct specification.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Name of the source electronic data capture (EDC) system or clinical trial management system (CTMS) from which the data originates (e.g., Medidata Rave, Oracle Clinical).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionType rdf:type rdf:Property ;
    rdfs:label 'Submission Type' ;
    rdfs:comment 'Type of regulatory submission for which this mapping is intended: IND (Investigational New Drug), NDA (New Drug Application), BLA (Biologics License Application), MAA (Marketing Authorization Application), ANDA (Abbreviated New Drug Application), or 510k (medical device).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationLogic rdf:type rdf:Property ;
    rdfs:label 'Transformation Logic' ;
    rdfs:comment 'Detailed description or pseudocode of the transformation logic applied to convert CRF data to SDTM format, including any calculations, concatenations, or conditional rules.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRule rdf:type rdf:Property ;
    rdfs:label 'Validation Rule' ;
    rdfs:comment 'Data validation rules or constraints applied to ensure the mapped data conforms to CDISC standards and regulatory requirements (e.g., range checks, format validations, consistency checks).' ;
    rdfs:domain ind:CdiscDomainMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationText rdf:type rdf:Property ;
    rdfs:label 'Annotation Text' ;
    rdfs:comment 'Annotated CRF text describing the SDTM variable mappings, derivation rules, and coding instructions associated with each field on this form. Used by data management and programming teams for SDTM dataset creation.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current lifecycle approval state of the CRF form definition. \'draft\' indicates design in progress; \'under_review\' indicates pending sponsor/CRO review; \'approved\' indicates GCP-compliant sign-off; \'superseded\' indicates replaced by a newer version; \'retired\' indicates no longer in use.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this CRF form definition received formal GCP-compliant approval. Recorded in ISO 8601 format with timezone offset. Required for audit trail under 21 CFR Part 11.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cdashDomain rdf:type rdf:Property ;
    rdfs:label 'Cdash Domain' ;
    rdfs:comment 'CDISC CDASH domain code indicating the data collection standard this form adheres to (e.g., \'AE\', \'VS\', \'CM\'). Ensures harmonized data collection aligned with CDASH implementation guides.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionInstructions rdf:type rdf:Property ;
    rdfs:label 'Completion Instructions' ;
    rdfs:comment 'Detailed instructions for site staff on how to complete this CRF form, including definitions, coding conventions, and data source guidance. Embedded in the EDC and printed CRF booklet.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRequirement rdf:type rdf:Property ;
    rdfs:label 'Completion Requirement' ;
    rdfs:comment 'Specifies whether completion of this CRF form is mandatory for all subjects, optional, or conditional on specific criteria (e.g., only if a prior form field triggers it). Drives data completeness monitoring and query generation.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEntryMode rdf:type rdf:Property ;
    rdfs:label 'Data Entry Mode' ;
    rdfs:comment 'Specifies the data entry mode configured for this CRF form in Medidata Rave. \'single\' requires one entry; \'double\' requires independent dual entry for critical data; \'auto\' is populated programmatically from device or lab feeds.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editCheckCount rdf:type rdf:Property ;
    rdfs:label 'Edit Check Count' ;
    rdfs:comment 'Total number of programmed edit checks (validation rules) configured for this CRF form in Medidata Rave. Provides a measure of form complexity and data quality control coverage.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldCount rdf:type rdf:Property ;
    rdfs:label 'Field Count' ;
    rdfs:comment 'Total number of data fields (questions/items) defined on this CRF form. Used for form complexity assessment, site burden estimation, and data management planning.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formLabel rdf:type rdf:Property ;
    rdfs:label 'Form Label' ;
    rdfs:comment 'Short display label for the CRF form used in the EDC user interface and printed CRF booklets. May differ from form_name for brevity in UI contexts.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formName rdf:type rdf:Property ;
    rdfs:label 'Form Name' ;
    rdfs:comment 'Human-readable name of the CRF form as displayed in Medidata Rave and study documentation. Examples: \'Adverse Event Form\', \'Vital Signs\', \'Concomitant Medications\'.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOid rdf:type rdf:Property ;
    rdfs:label 'Form Oid' ;
    rdfs:comment 'Unique Object Identifier (OID) for the CRF form as defined in Medidata Rave and conforming to CDISC ODM standards. Used for cross-system referencing and SDTM mapping. Example: \'AE_FORM_V2\'.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOrder rdf:type rdf:Property ;
    rdfs:label 'Form Order' ;
    rdfs:comment 'Numeric sequence order of this form within its associated visit or study schedule of events. Determines the display order in the EDC and printed CRF booklet.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formType rdf:type rdf:Property ;
    rdfs:label 'Form Type' ;
    rdfs:comment 'Classification of the CRF form by its data collection pattern in Medidata Rave. \'scheduled\' forms appear at predefined visits; \'unscheduled\' are event-driven; \'common\' appear across all visits; \'log\' forms capture repeating events (e.g., AE log); \'repeating\' forms allow multiple instances per visit.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formVersion rdf:type rdf:Property ;
    rdfs:label 'Form Version' ;
    rdfs:comment 'Version identifier of the CRF form definition, following semantic versioning (e.g., \'1.0\', \'2.1\', \'3.0.1\'). Tracks design changes over the trial lifecycle and supports audit trail requirements.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlinded rdf:type rdf:Property ;
    rdfs:label 'Is Blinded' ;
    rdfs:comment 'Indicates whether this CRF form contains blinded data (e.g., treatment assignment, randomization code) that must be restricted from unblinded personnel during the trial. Supports GCP-compliant blinding controls.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeating rdf:type rdf:Property ;
    rdfs:label 'Is Repeating' ;
    rdfs:comment 'Indicates whether this CRF form allows multiple instances per subject per visit (e.g., an Adverse Event log form where each AE is a separate instance). Drives EDC configuration in Medidata Rave.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSdvRequired rdf:type rdf:Property ;
    rdfs:label 'Is Sdv Required' ;
    rdfs:comment 'Indicates whether Source Data Verification (SDV) is required for data entered on this CRF form. Critical forms (e.g., primary endpoints, safety data) typically require 100% SDV; others may be risk-based.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Is Signature Required' ;
    rdfs:comment 'Indicates whether an electronic signature (e-signature) is required on this CRF form by the investigator or site staff upon completion, as mandated by 21 CFR Part 11 and GCP requirements.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ittPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Itt Population Flag' ;
    rdfs:comment 'Indicates whether this CRF form contributes data to the Intent-to-Treat (ITT) analysis population definition. ITT-relevant forms are critical for primary efficacy analysis and regulatory review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when this CRF form definition record was last modified. Recorded in ISO 8601 format with timezone offset. Supports audit trail, change control, and GCP compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryEndpointFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Flag' ;
    rdfs:comment 'Indicates whether this CRF form captures data for the trial\'s primary efficacy or safety endpoint (e.g., ORR, PFS, OS). Primary endpoint forms receive heightened monitoring, SDV, and data review scrutiny.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:raveFormDraftVersion rdf:type rdf:Property ;
    rdfs:label 'Rave Form Draft Version' ;
    rdfs:comment 'The internal Medidata Rave draft version number for this CRF form, distinct from the business version. Tracks incremental design changes within the Rave study build environment prior to promotion to production.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raveStudyName rdf:type rdf:Property ;
    rdfs:label 'Rave Study Name' ;
    rdfs:comment 'The study name as configured in Medidata Rave EDC system, used to identify the parent study context for this CRF form. Supports cross-referencing between the data lakehouse and the source EDC system.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether data collected on this CRF form is included in regulatory submissions (NDA/BLA/MAA/IND). Drives SDTM dataset inclusion and eCTD packaging requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyFormFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Form Flag' ;
    rdfs:comment 'Indicates whether this CRF form is designated as a safety-critical form (e.g., Adverse Event, Serious Adverse Event, SUSAR reporting). Safety forms trigger expedited review workflows and pharmacovigilance data feeds.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdtmDomain rdf:type rdf:Property ;
    rdfs:label 'Sdtm Domain' ;
    rdfs:comment 'Two-letter CDISC SDTM domain code to which this CRF form maps for regulatory submission (e.g., \'AE\' for Adverse Events, \'VS\' for Vital Signs, \'CM\' for Concomitant Medications, \'LB\' for Laboratory). Drives SDTM dataset generation for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvPercentage rdf:type rdf:Property ;
    rdfs:label 'Sdv Percentage' ;
    rdfs:comment 'The percentage of data points on this CRF form subject to Source Data Verification (SDV) under the risk-based monitoring plan. Ranges from 0.00 (no SDV) to 100.00 (full SDV). Supports risk-based monitoring strategy.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemFormCode rdf:type rdf:Property ;
    rdfs:label 'Source System Form Code' ;
    rdfs:comment 'Native identifier of this CRF form record in the source EDC system (Medidata Rave). Enables lineage tracing from the Silver Layer back to the operational system of record.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRuleSet rdf:type rdf:Property ;
    rdfs:label 'Validation Rule Set' ;
    rdfs:comment 'Identifier or name of the edit check / validation rule set applied to this CRF form in Medidata Rave. References the programmed edit checks that enforce data quality, range checks, and cross-form consistency rules.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitOid rdf:type rdf:Property ;
    rdfs:label 'Visit Oid' ;
    rdfs:comment 'CDISC ODM-compliant OID of the study visit to which this form is assigned, as defined in Medidata Rave. Supports cross-system visit-form linkage without requiring a resolved FK at this stage.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Data Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Data Management Plans are owned by qualified data managers. ICH E6(R2) requires documented roles and responsibilities. Essential for GxP accountability, audit trail, and succession planning in clinica' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:masterBatchRecordId rdf:type rdf:Property ;
    rdfs:label 'Master Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.master_batch_record. Business justification: DMP references MBR for investigational product specifications to design eCRFs capturing manufacturing-related data (batch number, expiry, storage conditions). Critical for SDTM CM/EX domain mapping, r' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterBatchRecord .

ind:ownerOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Owner Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: DMP is owned by a specific organizational unit (data management team, biometrics department). Required for accountability, resource planning, quality management system (QMS) documentation, and organiz' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:part11SystemId rdf:type rdf:Property ;
    rdfs:label 'Part11 System Id' ;
    rdfs:comment 'Foreign key linking to compliance.part11_system. Business justification: DMP specifies which Part 11 compliant systems (EDC, CTMS, eTMF) are used for trial data collection and management. Essential for CSV validation, audit trail requirements, and electronic signature comp' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Part11System .

ind:adamVersion rdf:type rdf:Property ;
    rdfs:label 'Adam Version' ;
    rdfs:comment 'Version of the CDISC ADaM standard used for analysis datasets and statistical programming.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the individual who approved this data management plan version.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivalStrategy rdf:type rdf:Property ;
    rdfs:label 'Archival Strategy' ;
    rdfs:comment 'Strategy for long-term archival of clinical data including media type, location, and retrieval procedures.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequirements rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Requirements' ;
    rdfs:comment 'Specification of audit trail capture requirements including what changes are logged, timestamp precision, and user attribution.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingMaintainedFlag rdf:type rdf:Property ;
    rdfs:label 'Blinding Maintained Flag' ;
    rdfs:comment 'Indicates whether treatment blinding is maintained in the EDC system and data management processes.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for additional notes, clarifications, or special instructions related to this data management plan.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionStandards rdf:type rdf:Property ;
    rdfs:label 'Data Collection Standards' ;
    rdfs:comment 'Description of the data collection standards and conventions applied, including CDASH alignment and custom specifications.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEntryMethod rdf:type rdf:Property ;
    rdfs:label 'Data Entry Method' ;
    rdfs:comment 'Primary method of data entry into the EDC system, indicating whether single entry, double entry, or direct electronic capture is used.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyCompliance rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Compliance' ;
    rdfs:comment 'Description of data privacy and protection measures implemented to comply with GDPR, HIPAA, and other applicable regulations.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityMetrics rdf:type rdf:Property ;
    rdfs:label 'Data Quality Metrics' ;
    rdfs:comment 'Definition of key data quality metrics and KPIs tracked throughout the trial including query rates, missing data rates, and protocol deviation rates.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataReconciliationPlan rdf:type rdf:Property ;
    rdfs:label 'Data Reconciliation Plan' ;
    rdfs:comment 'Plan for reconciling data across multiple systems including EDC, CTMS, IRT, safety databases, and laboratory systems.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Years' ;
    rdfs:comment 'Number of years clinical trial data must be retained per regulatory requirements and company policy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:databaseLockCriteria rdf:type rdf:Property ;
    rdfs:label 'Database Lock Criteria' ;
    rdfs:comment 'Detailed criteria and conditions that must be met before database lock, including query resolution thresholds, SDV completion, and data cleaning milestones.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmpNumber rdf:type rdf:Property ;
    rdfs:label 'Dmp Number' ;
    rdfs:comment 'Business identifier for the data management plan document, used for external reference and regulatory submissions.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmpStatus rdf:type rdf:Property ;
    rdfs:label 'Dmp Status' ;
    rdfs:comment 'Current lifecycle status of the data management plan indicating its approval and operational state.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmpTitle rdf:type rdf:Property ;
    rdfs:label 'Dmp Title' ;
    rdfs:comment 'Full title of the data management plan document, typically aligned with the protocol title.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmpVersion rdf:type rdf:Property ;
    rdfs:label 'Dmp Version' ;
    rdfs:comment 'Version number of the data management plan document, incremented with each revision or amendment.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcEnvironment rdf:type rdf:Property ;
    rdfs:label 'Edc Environment' ;
    rdfs:comment 'EDC system environment designation indicating whether this is a production, validation, or training instance.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcStudyName rdf:type rdf:Property ;
    rdfs:label 'Edc Study Name' ;
    rdfs:comment 'Study name or identifier within the EDC system corresponding to this trial.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editCheckSpecification rdf:type rdf:Property ;
    rdfs:label 'Edit Check Specification' ;
    rdfs:comment 'Reference to the document or system configuration defining all programmatic edit checks, validation rules, and query generation logic.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date when this data management plan version becomes effective and operational for the trial.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:etmfDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Etmf Document Reference' ;
    rdfs:comment 'Reference identifier for this data management plan document in the eTMF system, typically Veeva Vault.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date when this data management plan version is superseded or no longer applicable, nullable for active plans.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalDataTransferPlan rdf:type rdf:Property ;
    rdfs:label 'External Data Transfer Plan' ;
    rdfs:comment 'Description of external data transfers including laboratory data, imaging data, ePRO data, and integration specifications.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraVersion rdf:type rdf:Property ;
    rdfs:label 'Meddra Version' ;
    rdfs:comment 'Version of MedDRA coding dictionary used for adverse event and medical history coding.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryManagementProcess rdf:type rdf:Property ;
    rdfs:label 'Query Management Process' ;
    rdfs:comment 'Description of the query lifecycle management process including query generation, resolution, escalation, and closure criteria.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvPercentageTarget rdf:type rdf:Property ;
    rdfs:label 'Sdv Percentage Target' ;
    rdfs:comment 'Target percentage of data points or CRF pages to be source verified, expressed as a decimal (e.g., 25.00 for 25%).' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvStrategy rdf:type rdf:Property ;
    rdfs:label 'Sdv Strategy' ;
    rdfs:comment 'Source data verification approach defined for this trial, specifying the percentage and targeting criteria for on-site verification.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whodrugVersion rdf:type rdf:Property ;
    rdfs:label 'Whodrug Version' ;
    rdfs:comment 'Version of WHO Drug dictionary used for concomitant medication coding.' ;
    rdfs:domain ind:DataManagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationalProductId rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Id' ;
    rdfs:comment 'Foreign key linking to clinical.investigational_product. Business justification: Enrolled subjects are assigned to specific investigational product kits at randomization. While enrollment has treatment_arm_code, linking to investigational_product provides the actual IMP kit assign' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestigationalProduct .

ind:randomizationScheduleId rdf:type rdf:Property ;
    rdfs:label 'Randomization Schedule Id' ;
    rdfs:comment 'Reference to the randomization scheme (schedule) used for this subject\'s assignment. A trial may use multiple schemes (e.g., by phase, cohort, or amendment). Links to the randomization scheme master record in Medidata Rave RTSM.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RandomizationSchedule .

ind:allocationRatio rdf:type rdf:Property ;
    rdfs:label 'Allocation Ratio' ;
    rdfs:comment 'The ratio of subjects allocated to each treatment arm as defined in the randomization scheme (e.g., \'1:1\', \'2:1\', \'1:1:1\'). Determines the probability of assignment to each arm. Sourced from the RTSM randomization schedule.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingStatus rdf:type rdf:Property ;
    rdfs:label 'Blinding Status' ;
    rdfs:comment 'Indicates the current blinding state of the subject\'s treatment assignment. \'blinded\' = treatment assignment concealed; \'open_label\' = treatment known from outset; \'unblinded\' = previously blinded assignment has been revealed. Critical for data integrity and regulatory compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockSize rdf:type rdf:Property ;
    rdfs:label 'Block Size' ;
    rdfs:comment 'The number of subjects per randomization block used in the blocked randomization scheme. Confidential as knowledge of block size could compromise blinding. Sourced from Medidata Rave RTSM randomization parameters.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date on which the subject completed all protocol-required study procedures and follow-up visits. Populated only when enrollment_status = completed. Used for study close-out and final analysis datasets.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctmsSubjectKey rdf:type rdf:Property ;
    rdfs:label 'Ctms Subject Key' ;
    rdfs:comment 'The natural/business key for this subject enrollment record as assigned by Oracle Clinical / Siebel CTMS. Used for cross-system reconciliation between CTMS and Medidata Rave EDC. Supports data lineage and audit trail requirements.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLockFlag rdf:type rdf:Property ;
    rdfs:label 'Data Lock Flag' ;
    rdfs:comment 'Flag indicating whether the subject\'s enrollment and randomization data has been locked for analysis (database lock). True = data locked and frozen for statistical analysis; False = data still open for query resolution or updates. Critical for regulatory submission readiness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityConfirmed rdf:type rdf:Property ;
    rdfs:label 'Eligibility Confirmed' ;
    rdfs:comment 'Flag indicating whether the subject has been confirmed as meeting all inclusion criteria and none of the exclusion criteria as defined in the trial protocol. True = eligible; False = not eligible or assessment pending. Drives enrollment decision in RTSM.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date on which the subject was formally enrolled into the clinical trial following eligibility confirmation. Represents the principal business event timestamp for the enrollment transaction. Sourced from Medidata Rave RTSM.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the subject within the enrollment and randomization workflow. Drives Intent-to-Treat (ITT), modified ITT, and Per-Protocol (PP) population definitions. Sourced from Medidata Rave RTSM and Oracle CTMS. [ENUM-REF-CANDIDATE: screened|screen_failed|enrolled|randomized|withdrawn|completed|discontinued — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentConfirmed rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Confirmed' ;
    rdfs:comment 'Flag indicating whether a valid, signed Informed Consent Form (ICF) has been confirmed for this subject prior to any study procedures. True = ICF confirmed; False = ICF not confirmed or pending. Mandatory GCP compliance check.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:informedConsentDate rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Date' ;
    rdfs:comment 'Date on which the subject signed the Informed Consent Form (ICF), confirming voluntary participation in the trial. Must precede any study-specific procedures per GCP requirements. Critical for regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mittPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Mitt Population Flag' ;
    rdfs:comment 'Flag indicating whether the subject is included in the modified Intent-to-Treat (mITT) analysis population. Criteria for mITT inclusion are protocol-defined (e.g., received at least one dose). Supports secondary efficacy analyses.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Pp Population Flag' ;
    rdfs:comment 'Flag indicating whether the subject is included in the Per-Protocol (PP) analysis population. True = subject completed the trial per protocol without major deviations. Used for sensitivity analyses in NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationCode rdf:type rdf:Property ;
    rdfs:label 'Randomization Code' ;
    rdfs:comment 'Unique alphanumeric code assigned by the RTSM system at the point of randomization, linking the subject to their treatment arm assignment within the randomization schedule. Confidential during blinded phase; revealed only upon unblinding. Sourced from Medidata Rave RTSM.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationDate rdf:type rdf:Property ;
    rdfs:label 'Randomization Date' ;
    rdfs:comment 'Date on which the subject was randomized and assigned to a treatment arm via the RTSM system. May differ from enrollment_date in trials with a run-in period. Null for screen-failed or non-randomized subjects.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:raveSubjectKey rdf:type rdf:Property ;
    rdfs:label 'Rave Subject Key' ;
    rdfs:comment 'The natural/business key for this subject enrollment record as assigned by Medidata Rave EDC/RTSM. Used for cross-system reconciliation and data lineage tracing back to the authoritative EDC source system.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenFailureReason rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Reason' ;
    rdfs:comment 'Coded or free-text reason why a subject failed screening and was not enrolled. Populated only when enrollment_status = screen_failed. Used for protocol feasibility analysis and site performance monitoring. Sourced from Medidata Rave EDC screen failure CRF.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'Date on which the subject first presented at the investigational site for screening assessments. Marks the start of the eligibility evaluation period. Sourced from Medidata Rave EDC.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Number' ;
    rdfs:comment 'Unique alphanumeric identifier assigned to a subject at the point of screening, prior to eligibility confirmation. Format is site-specific and assigned sequentially by the RTSM system in Medidata Rave. Used to track screen failures and pre-enrollment activity.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactor1 rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 1' ;
    rdfs:comment 'Value of the first stratification factor used to balance treatment arm assignments across key prognostic variables (e.g., disease stage, geographic region, biomarker status). Defined in the trial protocol and captured at randomization in RTSM.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactor2 rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 2' ;
    rdfs:comment 'Value of the second stratification factor used to balance treatment arm assignments (e.g., prior therapy, performance status, age group). Null if the trial uses fewer than two stratification factors. Captured at randomization in RTSM.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactor3 rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 3' ;
    rdfs:comment 'Value of the third stratification factor used to balance treatment arm assignments (e.g., country, mutation status, weight band). Null if the trial uses fewer than three stratification factors. Captured at randomization in RTSM.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectNumber rdf:type rdf:Property ;
    rdfs:label 'Subject Number' ;
    rdfs:comment 'Unique identifier assigned to a subject upon successful enrollment into the trial. Typically formatted as site-number-sequential-ID (e.g., 001-001). Assigned by Medidata Rave RTSM upon eligibility confirmation and enrollment confirmation.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentArmCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Code' ;
    rdfs:comment 'Code identifying the treatment arm (e.g., active drug, placebo, comparator, dose level) to which the subject was assigned at randomization. Confidential in blinded trials. Sourced from Medidata Rave RTSM randomization schedule.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentArmDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Description' ;
    rdfs:comment 'Human-readable description of the treatment arm assignment (e.g., \'Drug A 100mg QD\', \'Placebo\', \'Drug B 200mg BID\'). Confidential in blinded trials. Complements treatment_arm_code for reporting and analysis.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindingDate rdf:type rdf:Property ;
    rdfs:label 'Unblinding Date' ;
    rdfs:comment 'Date on which the subject\'s treatment assignment was unblinded. Populated only when blinding_status = unblinded. Emergency unblinding events must be documented per GCP. Null for blinded or open-label subjects.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unblindingReason rdf:type rdf:Property ;
    rdfs:label 'Unblinding Reason' ;
    rdfs:comment 'Coded reason for the unblinding of the subject\'s treatment assignment. Emergency unblinding (e.g., for medical management of a Serious Adverse Event) must be documented and reported per GCP and pharmacovigilance requirements. Null for blinded or open-label subjects.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date on which the subject withdrew from the trial or was discontinued. Populated only when enrollment_status = withdrawn. Used for survival analysis (censoring) and dropout rate reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Coded or free-text reason for subject withdrawal or discontinuation from the trial (e.g., adverse event, consent withdrawal, lost to follow-up, protocol deviation, investigator decision). Null for active or completed subjects. [ENUM-REF-CANDIDATE: adverse_event|consent_withdrawal|lost_to_follow_up|protocol_deviation|investigator_decision|sponsor_decision|death|other — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessStrategyId rdf:type rdf:Property ;
    rdfs:label 'Access Strategy Id' ;
    rdfs:comment 'Foreign key linking to market.access_strategy. Business justification: Access strategies are product-specific, targeting market access for each investigational product/indication combination. Each strategy plans pricing, reimbursement pathway, and HTA approach for a spec' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessStrategy .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Foreign key linking to commercial.brand. Business justification: Investigational products become commercial brands post-approval. Links IND/NDA submissions to commercial portfolio for lifecycle management, supply chain transition planning, and regulatory-commercial' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:coaId rdf:type rdf:Property ;
    rdfs:label 'Coa Id' ;
    rdfs:comment 'Foreign key linking to quality.coa. Business justification: Each IMP batch shipped to sites must have a Certificate of Analysis documenting compliance with specifications per GMP/GCP requirements. Essential for site accountability and regulatory inspection rea' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coa .

ind:compoundId rdf:type rdf:Property ;
    rdfs:label 'Compound Id' ;
    rdfs:comment 'Foreign key linking to discovery.compound. Business justification: IND filings, CMC documentation, and pharmacovigilance require traceability from clinical investigational products back to discovery compound registration records. Essential for regulatory submissions ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:contentId rdf:type rdf:Property ;
    rdfs:label 'Content Id' ;
    rdfs:comment 'Foreign key linking to medical.medical_content. Business justification: Medical content (scientific platforms, detail aids, MLR-approved materials) references specific investigational products for MSL engagement and medical education. Content approval requires product-spe' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Content .

ind:drugProductId rdf:type rdf:Property ;
    rdfs:label 'Drug Product Id' ;
    rdfs:comment 'Foreign key linking to product.drug_product. Business justification: Investigational products ARE drug products in clinical testing. Critical for IMP accountability, regulatory traceability (21 CFR 312), linking clinical batches to commercial formulations, and CMC-clin' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugProduct .

ind:formulationId rdf:type rdf:Property ;
    rdfs:label 'Formulation Id' ;
    rdfs:comment 'Foreign key linking to product.formulation. Business justification: IMP batch records must trace to specific formulations for comparability protocols, bridging studies, and regulatory compliance (ICH Q5E). Essential when formulation changes occur during development or' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulation .

ind:impCogsEntryId rdf:type rdf:Property ;
    rdfs:label 'Imp Cogs Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.cogs_entry. Business justification: IMP consumption drives COGS for clinical supply manufacturing. Standard pharma cost accounting requires linking clinical supply batches to manufacturing costs for R&D capitalization decisions and tria' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CogsEntry .

ind:inspectionReadinessId rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Id' ;
    rdfs:comment 'Foreign key linking to compliance.inspection_readiness. Business justification: Investigational products are scope of GMP/GCP inspection readiness programs. IMP accountability, storage conditions, and batch documentation are key inspection focus areas. Links product management to' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionReadiness .

ind:manufacturingBatchRecordId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.batch_record. Business justification: Investigational products used in clinical trials must link to manufacturing batch records for traceability, GMP compliance, and clinical supply chain management. This is critical for regulatory submis' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:manufacturingPlantId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: IMP is manufactured at specific GMP-certified plants. Required for batch genealogy, GMP traceability, regulatory submissions (manufacturing site identification in CTD Module 3), supply chain planning,' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Foreign key linking to masterdata.material. Business justification: Investigational products are materials in the master data system. Links clinical trial drug supply to manufacturing/procurement master data. Essential for supply chain planning, batch traceability, re' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:patentId rdf:type rdf:Property ;
    rdfs:label 'Patent Id' ;
    rdfs:comment 'Foreign key linking to intellectual.patent. Business justification: Investigational products (formulations, delivery mechanisms, manufacturing processes) are patented assets. Linking supports IP protection tracking, orange book/purple book listings, patent term extens' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patent .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_plan. Business justification: Clinical supply planning aligns IMP production schedules with trial enrollment rates, site activation dates, and dosing regimens. Direct operational dependency for ensuring adequate IMP availability w' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:procurementPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Procurement Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Clinical supply procurement tracks which PO supplied each IMP batch/kit to trial sites. Essential for supply chain accountability, batch reconciliation audits, financial reconciliation, and tracing su' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:pvProductId rdf:type rdf:Property ;
    rdfs:label 'Pv Product Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.pv_product. Business justification: Investigational products must map to authorized PV products for listedness determination (expected vs unexpected AE classification), SUSAR assessment, and RSI reference. Critical for regulatory expect' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PvProduct .

ind:qualityBatchDispositionId rdf:type rdf:Property ;
    rdfs:label 'Quality Batch Disposition Id' ;
    rdfs:comment 'Foreign key linking to quality.batch_disposition. Business justification: Every IMP batch requires QA disposition approval before shipment to clinical sites per GMP Annex 13. Tracks release decision, quarantine status, and QP certification for clinical supply chain.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchDisposition .

ind:rawMaterialInventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Raw Material Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: IMP manufacturing consumes raw material lots; regulatory traceability (21 CFR Part 312.57) requires linking clinical products to source inventory lots for safety reporting, recalls, and batch genealog' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: IMPs are manufactured and released against approved quality specifications defining acceptance criteria. Links clinical product identity to quality standards, essential for batch release and regulator' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:stabilityStudyId rdf:type rdf:Property ;
    rdfs:label 'Stability Study Id' ;
    rdfs:comment 'Foreign key linking to quality.stability_study. Business justification: IMPs undergo stability testing to establish expiry dates and storage conditions for clinical use. Links clinical supply planning to ongoing stability data, critical for protocol amendments and supply ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StabilityStudy .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Clinical supply chain requires tracking which qualified vendor/CMO manufactured each IMP batch. Essential for regulatory filing (DMF references), GMP compliance verification, supply chain traceability' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:vendorSiteId rdf:type rdf:Property ;
    rdfs:label 'Vendor Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor_site. Business justification: Regulatory requirement to track specific manufacturing site for each IMP batch. Site-specific GMP certification, regulatory inspections, and batch release documentation require site-level traceability' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorSite .

ind:accountabilityLogReference rdf:type rdf:Property ;
    rdfs:label 'Accountability Log Reference' ;
    rdfs:comment 'Document reference number or system identifier for the IMP accountability log maintained at the investigational site or centrally. Links to the eTMF document in Veeva Vault per ICH E6(R2) Section 8.3.15.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcCode rdf:type rdf:Property ;
    rdfs:label 'Atc Code' ;
    rdfs:comment 'WHO Anatomical Therapeutic Chemical (ATC) classification code for the IMP active ingredient. Used for cross-trial analytics, portfolio reporting, and regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Manufacturer-assigned batch or lot number for the specific IMP batch supplied to the trial. Essential for GMP traceability, recall management, and IMP accountability per ICH E6(R2) Section 8.3.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingType rdf:type rdf:Property ;
    rdfs:label 'Blinding Type' ;
    rdfs:comment 'Blinding configuration for this IMP in the trial (open-label, single-blind, double-blind, triple-blind). Determines whether subjects, investigators, and/or sponsor personnel are masked to treatment assignment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether this IMP requires cold-chain logistics (temperature-controlled storage and transport) throughout the supply chain from manufacturer to investigational site. Drives GDP-compliant distribution planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispensationUnit rdf:type rdf:Property ;
    rdfs:label 'Dispensation Unit' ;
    rdfs:comment 'Unit of measure used for IMP dispensation, return, and destruction quantities (e.g., tablet, capsule, vial, mL). Ensures consistent accountability across all quantity fields. [ENUM-REF-CANDIDATE: tablet|capsule|vial|ampoule|mL|mg|patch|sachet|unit — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Gmp Certificate Reference' ;
    rdfs:comment 'Reference to the GMP certificate or Qualified Person (QP) release certificate confirming the IMP batch was manufactured in compliance with current Good Manufacturing Practice (cGMP). Required for EU CTA and IND.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impCode rdf:type rdf:Property ;
    rdfs:label 'Imp Code' ;
    rdfs:comment 'Sponsor-assigned alphanumeric code uniquely identifying this IMP or comparator within the trial supply system. Used for dispensation tracking and accountability logs in Oracle CTMS and SAP MM.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impdReference rdf:type rdf:Property ;
    rdfs:label 'Impd Reference' ;
    rdfs:comment 'Reference number or document identifier for the Investigational Medicinal Product Dossier (IMPD) submitted to EU competent authorities. Supports EMA/MHRA CTA submissions.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indNumber rdf:type rdf:Property ;
    rdfs:label 'Ind Number' ;
    rdfs:comment 'FDA-assigned Investigational New Drug (IND) application number under which this IMP is authorized for clinical investigation in the United States. Links to the regulatory.application record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitNumber rdf:type rdf:Property ;
    rdfs:label 'Kit Number' ;
    rdfs:comment 'Unique identifier for the IMP dispensation kit as labeled and shipped to the investigational site. Used for kit-level accountability tracking and IWRS-driven dispensation in Oracle CTMS.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date on which the IMP batch was manufactured. Used to calculate shelf life, retest dates, and to verify GMP compliance of the batch at time of dispensation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchingPlaceboCode rdf:type rdf:Property ;
    rdfs:label 'Matching Placebo Code' ;
    rdfs:comment 'IMP code of the matching placebo formulated to be indistinguishable from the active investigational product in appearance, taste, and smell. Required for double-blind trial integrity and IMP accountability.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanismOfAction rdf:type rdf:Property ;
    rdfs:label 'Mechanism Of Action' ;
    rdfs:comment 'Narrative description of the mechanism of action (MOA) of the IMP\'s active pharmaceutical ingredient (API), describing how it produces its pharmacological effect at the molecular or cellular level.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of the product role in the trial: investigational (test article), comparator (active control), placebo (matching or non-matching), rescue medication, or auxiliary medicinal product per ICH E6(R2) definitions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDestroyed rdf:type rdf:Property ;
    rdfs:label 'Quantity Destroyed' ;
    rdfs:comment 'Total quantity of this IMP destroyed at site or centrally, expressed in the dispensation unit. Required for complete IMP accountability reconciliation and destruction certificate documentation.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed' ;
    rdfs:comment 'Total quantity of this IMP dispensed to trial subjects from this batch, expressed in the dispensation unit (e.g., tablets, vials, mL). Core field for IMP accountability log per ICH E6(R2) Section 8.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'Total quantity of this IMP returned by trial subjects or sites, expressed in the dispensation unit. Used to calculate compliance rates and reconcile IMP accountability per GCP requirements.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Date by which the IMP batch must be retested to confirm continued suitability for use, particularly for drug substances with defined retest periods rather than expiry dates. Supports stability management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage conditions for the IMP as specified in the CoA and IMPD/IND (e.g., 2-8°C refrigerated, 15-25°C controlled room temperature, -20°C frozen, protect from light). Critical for cold-chain management and GDP compliance. [ENUM-REF-CANDIDATE: refrigerated_2_8c|controlled_room_temp|frozen_minus20c|frozen_minus80c|protect_from_light|ambient — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyStatus rdf:type rdf:Property ;
    rdfs:label 'Supply Status' ;
    rdfs:comment 'Current status of this IMP record in the trial supply lifecycle: available (at site, ready for dispensation), dispensed (issued to subject), returned (received back from subject), destroyed, quarantine (hold pending investigation), or expired.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticArea rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area' ;
    rdfs:comment 'Primary therapeutic area or disease indication for which the IMP is being investigated (e.g., oncology, immunology, rare diseases, cardiovascular). Aligns with ATC classification and sponsor portfolio taxonomy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryId rdf:type rdf:Property ;
    rdfs:label 'Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Sites are physically located in countries. Essential for regulatory authority jurisdiction determination, IRB/IEC requirements, site selection strategy, country-level enrollment tracking, and GCP comp' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:distributionNetworkId rdf:type rdf:Property ;
    rdfs:label 'Distribution Network Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_network. Business justification: Sites receive IMP through specific distribution nodes (depots/warehouses); GDP compliance requires documented supply chain routing. Clinical supply management uses this for shipment planning, temperat' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionNetwork .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Identifier of the Clinical Research Associate (CRA) assigned as the primary monitor for this site. The CRA is responsible for site initiation, ongoing monitoring visits, and GCP compliance oversight.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:healthAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Health Authority Id' ;
    rdfs:comment 'Foreign key linking to regulatory.health_authority. Business justification: Sites must comply with jurisdiction-specific regulations and inspection requirements. Site qualification, GCP inspection readiness, and regulatory compliance tracking require knowing which health auth' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthAuthority .

ind:masterdataAddressId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Address Id' ;
    rdfs:comment 'Foreign key linking to masterdata.address. Business justification: Sites have standardized physical addresses. Required for site management, investigational product shipments, monitoring visit planning, regulatory documentation (site lists in submissions), and geoloc' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_program. Business justification: Sites participate in compliance programs (GCP training, data integrity, inspection readiness). Site qualification and monitoring includes compliance program enrollment and performance tracking. Essent' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:siteInternalOrderId rdf:type rdf:Property ;
    rdfs:label 'Site Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Sites incur costs tracked via internal orders for site activation, monitoring, patient recruitment, and investigator fees. Essential for trial budget management, site payment processing, and cost-per-' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:siteLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Site Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Sites are owned/operated by legal entities (hospitals, research institutions, private practices). Required for clinical trial agreements (CTAs), payment processing, insurance/liability coverage, and r' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:siteManagementVendorId rdf:type rdf:Property ;
    rdfs:label 'Site Management Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Many trial sites are managed by Site Management Organizations (SMOs) who are contracted vendors. Business process: vendor qualification for site services, payment processing, contract management, and ' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:territoryMslProfileId rdf:type rdf:Property ;
    rdfs:label 'Territory Msl Profile Id' ;
    rdfs:comment 'Foreign key linking to medical.msl_profile. Business justification: MSLs are assigned to geographic territories covering investigational sites for site engagement, investigator support, medical information delivery, and IIT identification. Territory-based MSL assignme' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MslProfile .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date on which the site close-out visit was completed and the site was formally closed. All essential documents must be archived in eTMF (Veeva Vault) by this date.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrolledSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Subject Count' ;
    rdfs:comment 'Actual number of subjects who have been randomized and enrolled at this site to date. Compared against enrollment_target to assess site performance and trigger enrollment support actions.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentTarget rdf:type rdf:Property ;
    rdfs:label 'Enrollment Target' ;
    rdfs:comment 'Planned number of subjects to be enrolled at this site as agreed between the sponsor and principal investigator. Used for enrollment forecasting, site performance benchmarking, and IMP supply planning.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etmfSiteFolderReference rdf:type rdf:Property ;
    rdfs:label 'Etmf Site Folder Reference' ;
    rdfs:comment 'Reference identifier for the site-level folder in the Veeva Vault eTMF system. Links the site master record to its essential document archive for GCP inspection readiness and regulatory submission support.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feasibilityDate rdf:type rdf:Property ;
    rdfs:label 'Feasibility Date' ;
    rdfs:comment 'Date on which the site feasibility assessment was completed, confirming the site\'s capability, patient population, and infrastructure to conduct the trial. First milestone in the site activation timeline tracked in CTMS.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fpfvActualDate rdf:type rdf:Property ;
    rdfs:label 'Fpfv Actual Date' ;
    rdfs:comment 'Actual date on which the first patient first visit (FPFV) occurred at this site. Compared against fpfv_target_date to measure site activation performance and enrollment timeline adherence.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fpfvTargetDate rdf:type rdf:Property ;
    rdfs:label 'Fpfv Target Date' ;
    rdfs:comment 'Planned date for the first patient first visit (FPFV) at this site, representing the target enrollment start. Used for enrollment forecasting and site performance tracking against the clinical development timeline.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Gcp Inspection Status' ;
    rdfs:comment 'Current GCP inspection status of the investigational site by a regulatory authority (FDA, EMA, MHRA, PMDA). Critical for site risk assessment, regulatory submission support, and pre-approval inspection (PAI) readiness.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationalSiteStatus rdf:type rdf:Property ;
    rdfs:label 'Investigational Site Status' ;
    rdfs:comment 'Current operational lifecycle status of the investigational site within the clinical program. Drives CRA monitoring schedules, IMP shipment eligibility, and enrollment reporting. Values: selected (identified for participation), activated (SIV complete, ready to enroll), enrolling (actively screening/randomizing subjects), on_hold (enrollment paused), closed (no further activity), terminated (early discontinuation).' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecApprovalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Expiry Date' ;
    rdfs:comment 'Date on which the current IRB/IEC approval for the trial protocol at this site expires. Triggers renewal workflow; enrollment must be suspended if approval lapses without renewal.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irbIecApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Number' ;
    rdfs:comment 'Official approval reference number issued by the IRB/IEC for the clinical trial protocol at this site. Mandatory for site activation and must be filed in the eTMF (Veeva Vault) prior to first patient first visit (FPFV).' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecName rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Name' ;
    rdfs:comment 'Name of the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) of record responsible for ethical oversight of clinical trial activities at this site. Required for GCP compliance and eTMF documentation in Veeva Vault.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGcpTrained rdf:type rdf:Property ;
    rdfs:label 'Is Gcp Trained' ;
    rdfs:comment 'Indicates whether all required site staff have completed GCP training as documented in the eTMF (Veeva Vault) prior to site activation. Mandatory pre-condition for site initiation per ICH E6(R2).' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadSite rdf:type rdf:Property ;
    rdfs:label 'Is Lead Site' ;
    rdfs:comment 'Indicates whether this site is designated as the lead or coordinating site for a multi-center trial. Lead sites often host the coordinating investigator and serve as the primary regulatory contact.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastGcpInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Gcp Inspection Date' ;
    rdfs:comment 'Date of the most recent GCP inspection conducted at this site by a regulatory authority. Used to assess inspection recency and site compliance history for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lplvActualDate rdf:type rdf:Property ;
    rdfs:label 'Lplv Actual Date' ;
    rdfs:comment 'Actual date on which the last patient last visit (LPLV) occurred at this site, marking the end of active patient participation. Triggers site close-out visit scheduling and IMP reconciliation.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthorityJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Jurisdiction' ;
    rdfs:comment 'Primary regulatory authority with jurisdiction over the investigational site\'s clinical trial activities. Determines applicable GCP guidelines, inspection readiness requirements, and submission standards (IND/NDA/BLA/MAA). [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|OTHER — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenFailureCount rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Count' ;
    rdfs:comment 'Number of subjects who were screened but failed to meet eligibility criteria at this site. Used to calculate screen failure rate and assess protocol feasibility and patient population fit.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selectionDate rdf:type rdf:Property ;
    rdfs:label 'Selection Date' ;
    rdfs:comment 'Date on which the sponsor formally selected the site for participation in the clinical trial, following feasibility review. Marks transition to site status \'selected\' in CTMS.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the investigational site by institutional category, used for site selection strategy, feasibility analysis, and enrollment benchmarking. [ENUM-REF-CANDIDATE: academic_medical_center|community_hospital|private_clinic|research_center|cro_managed|veterans_affairs|pediatric_center — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sivDate rdf:type rdf:Property ;
    rdfs:label 'Siv Date' ;
    rdfs:comment 'Date on which the Site Initiation Visit (SIV) was conducted by the Clinical Research Associate (CRA). Confirms site readiness, staff training, and IMP accountability procedures. Required before first patient enrollment.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the investigational site (e.g., America/New_York, Europe/London). Used for accurate timestamp alignment of EDC data from Medidata Rave, adverse event reporting timelines, and CRA scheduling.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labResultId rdf:type rdf:Property ;
    rdfs:label 'Lab Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each laboratory test result record in the clinical trial data product. Primary key for the lab_result entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityLabTestResultId rdf:type rdf:Property ;
    rdfs:label 'Quality Lab Test Result Id' ;
    rdfs:comment 'Foreign key linking to quality.lab_test_result. Business justification: Central lab results for clinical trials may leverage quality lab infrastructure and validated methods. Links clinical lab data to quality-validated analytical procedures for regulatory submission and ' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabTestResult .

ind:clinicallySignificantFlag rdf:type rdf:Property ;
    rdfs:label 'Clinically Significant Flag' ;
    rdfs:comment 'Boolean flag indicating whether the laboratory result has been assessed by the investigator as clinically significant. Corresponds to CDISC CDASH/SDTM LBCLSIG. A clinically significant abnormal result may trigger an adverse event report or protocol-defined action.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Data Entry Status' ;
    rdfs:comment 'Status of the Case Report Form (CRF) data entry for this laboratory result in Medidata Rave EDC. Tracks the data management workflow from initial entry through verification and database lock. Used for data cleaning and trial master file completeness tracking.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enteredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entered Timestamp' ;
    rdfs:comment 'Date and time when the laboratory result was entered or imported into the Medidata Rave EDC system. Used for audit trail compliance per 21 CFR Part 11 and ICH E6(R2) to demonstrate timely data entry and GCP compliance.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:labAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Accreditation Number' ;
    rdfs:comment 'Accreditation or certification number of the central or local laboratory that performed the analysis (e.g., CAP accreditation number, ISO 15189 certification reference, CLIA certificate number). Required for GCP compliance documentation and regulatory submissions to confirm laboratory qualification.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labName rdf:type rdf:Property ;
    rdfs:label 'Lab Name' ;
    rdfs:comment 'Name of the central or local laboratory that performed the laboratory analysis (e.g., \'Covance Central Laboratory\', \'Q2 Solutions\', \'Local Site Lab\'). Used for lab-level data quality monitoring, audit trail, and regulatory submission documentation.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labType rdf:type rdf:Property ;
    rdfs:label 'Lab Type' ;
    rdfs:comment 'Indicates whether the laboratory result was generated by a central laboratory (contracted central lab with standardized methods across all sites) or a local laboratory (site-specific lab). Central lab results are preferred for primary efficacy and safety endpoints due to standardization.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodCode rdf:type rdf:Property ;
    rdfs:label 'Method Code' ;
    rdfs:comment 'Code identifying the analytical method or assay used by the laboratory to generate the result (e.g., spectrophotometry, flow cytometry, PCR, ELISA). Corresponds to CDISC SDTM LBMETHOD. Important for result comparability and method validation documentation.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalFlag rdf:type rdf:Property ;
    rdfs:label 'Normal Flag' ;
    rdfs:comment 'Flag indicating whether the result is within, below, or above the laboratory\'s normal reference range. Corresponds to CDISC SDTM LBNRIND. Values: normal, low, high, critically_low, critically_high. Used in safety data listings and shift tables for regulatory submissions.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfRangeFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Range Flag' ;
    rdfs:comment 'Boolean flag indicating whether the result value falls outside the laboratory\'s defined reference range (either below lower limit or above upper limit). Distinct from clinical significance — a result can be out of range but not clinically significant. Used for automated data quality checks and safety signal detection.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panicValueFlag rdf:type rdf:Property ;
    rdfs:label 'Panic Value Flag' ;
    rdfs:comment 'Boolean flag indicating whether the result meets the laboratory\'s criteria for a panic (critical) value requiring immediate notification to the investigator or site. Supports GCP-compliant safety monitoring and timely SAE/AE reporting obligations.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queryFlag rdf:type rdf:Property ;
    rdfs:label 'Query Flag' ;
    rdfs:comment 'Boolean flag indicating whether an open data query (discrepancy) exists for this laboratory result record in Medidata Rave EDC. Used by data managers to track unresolved data issues requiring site clarification before database lock.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:raveRecordReference rdf:type rdf:Property ;
    rdfs:label 'Rave Record Reference' ;
    rdfs:comment 'Source system record identifier from Medidata Rave EDC for this laboratory result entry. Used for data lineage, reconciliation, and audit trail back to the originating EDC system.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Reference Range High' ;
    rdfs:comment 'Upper bound of the laboratory\'s normal reference range for this test, applicable to the subject\'s demographic group (age, sex). Corresponds to CDISC SDTM LBSTNRHI. Used for normal/abnormal flagging and shift table generation.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceRangeLow rdf:type rdf:Property ;
    rdfs:label 'Reference Range Low' ;
    rdfs:comment 'Lower bound of the laboratory\'s normal reference range for this test, applicable to the subject\'s demographic group (age, sex). Corresponds to CDISC SDTM LBSTNRLO. Used for normal/abnormal flagging and shift table generation.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the laboratory result was officially reported and transmitted by the laboratory to the sponsor or EDC system. Used for turnaround time monitoring, GCP compliance (timely reporting of critical values), and data transfer reconciliation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current status of the laboratory result record reflecting its lifecycle in the EDC and central lab workflow. Values: preliminary (initial result), final (verified and released), corrected (amended after initial release), cancelled (result voided), pending (awaiting analysis). Corresponds to HL7 observation status.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultUnitStandard rdf:type rdf:Property ;
    rdfs:label 'Result Unit Standard' ;
    rdfs:comment 'Standardized unit of measure for the laboratory result after conversion to a common unit for cross-site and cross-study comparability. Corresponds to CDISC SDTM LBSTRESU. Enables pooled analyses and regulatory submission datasets.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'The reported result value for the laboratory test as a string to accommodate both numeric and character results (e.g., \'5.4\', \'>100\', \'POSITIVE\', \'NEGATIVE\', \'TRACE\'). Corresponds to CDISC SDTM LBORRES. Stored as STRING to preserve original reported value including qualifiers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultValueNumeric rdf:type rdf:Property ;
    rdfs:label 'Result Value Numeric' ;
    rdfs:comment 'Numeric representation of the laboratory result value after standardization and unit conversion. Corresponds to CDISC SDTM LBSTRESN. Used for quantitative statistical analyses, shift tables, and outlier detection. Null for non-numeric results.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCategory rdf:type rdf:Property ;
    rdfs:label 'Test Category' ;
    rdfs:comment 'Broad classification of the laboratory test panel or category (e.g., hematology, chemistry, urinalysis, coagulation). Corresponds to CDISC SDTM LBCAT variable. Used for grouping and filtering in safety data review and regulatory submissions. [ENUM-REF-CANDIDATE: hematology|chemistry|urinalysis|coagulation|immunology|microbiology|pharmacokinetics|other — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testName rdf:type rdf:Property ;
    rdfs:label 'Test Name' ;
    rdfs:comment 'Human-readable name of the laboratory test performed (e.g., Hemoglobin, Serum Creatinine, ALT, White Blood Cell Count). Sourced from the central lab data transfer file and mapped to the CRF lab panel definition in Medidata Rave.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSubcategory rdf:type rdf:Property ;
    rdfs:label 'Test Subcategory' ;
    rdfs:comment 'More granular sub-classification of the laboratory test within its category (e.g., liver function tests within chemistry, CBC within hematology). Corresponds to CDISC SDTM LBSCAT variable.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toxicityGrade rdf:type rdf:Property ;
    rdfs:label 'Toxicity Grade' ;
    rdfs:comment 'Toxicity grade assigned to the laboratory abnormality per the NCI Common Terminology Criteria for Adverse Events (CTCAE) grading scale (Grade 1=Mild, Grade 2=Moderate, Grade 3=Severe, Grade 4=Life-threatening, Grade 5=Death). Used for safety signal detection, dose modification decisions, and regulatory safety reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Date and time when the laboratory result was verified (source data verified, SDV) by the clinical monitor or data manager in Medidata Rave. Required for GCP audit trail and trial master file completeness.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:monitoringVisitId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Visit Id' ;
    rdfs:comment 'Unique identifier for each monitoring visit conducted at an investigational site. Primary key for the monitoring visit record.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key linking to quality.audit. Business justification: Clinical site monitoring visits conducted as quality audits (vs routine monitoring) are tracked in quality audit system per ICH E6. Enables integrated audit program management and CAPA tracking across' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:craPositionId rdf:type rdf:Property ;
    rdfs:label 'Cra Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Monitoring visits are position-based activities (CRA role). Position tracking enables workload balancing, capacity planning, and role-based qualification verification for GxP compliance. Complements e' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:ctmsVisitId rdf:type rdf:Property ;
    rdfs:label 'Ctms Visit Id' ;
    rdfs:comment 'External identifier for this monitoring visit in the Clinical Trial Management System (CTMS), typically Oracle Clinical or Siebel CTMS. Used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Visit .

ind:masterdataCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Cost Center Id' ;
    rdfs:comment 'Foreign key linking to masterdata.cost_center. Business justification: Monitoring visits are charged to clinical operations cost centers. Required for clinical trial budgeting, cost allocation, CRO invoice validation, and financial reporting. Real financial management li' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:monitoringAccountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: CRA monitoring visits generate travel, accommodation, and expense AP entries. Essential for trial budget management, CRO invoice reconciliation, and monitoring cost tracking per site and protocol.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:principalInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Id' ;
    rdfs:comment 'Foreign key linking to clinical.principal_investigator. Business justification: Monitoring visits include meetings with the principal investigator to review site performance and compliance. Linking monitoring_visit to principal_investigator enables tracking which PI was met with ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrincipalInvestigator .

ind:actualVisitDate rdf:type rdf:Property ;
    rdfs:label 'Actual Visit Date' ;
    rdfs:comment 'The date on which the monitoring visit actually occurred. Primary business event timestamp for the monitoring activity.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeReportingVerified rdf:type rdf:Property ;
    rdfs:label 'Ae Reporting Verified' ;
    rdfs:comment 'Indicates whether adverse event (AE) and serious adverse event (SAE) reporting was reviewed for completeness, accuracy, and timeliness during the monitoring visit. AE reporting is a critical safety requirement.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capaItemsRaised rdf:type rdf:Property ;
    rdfs:label 'Capa Items Raised' ;
    rdfs:comment 'Number of Corrective and Preventive Action (CAPA) items initiated as a result of findings from this monitoring visit. CAPA items track remediation activities required to address identified deficiencies.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:craName rdf:type rdf:Property ;
    rdfs:label 'Cra Name' ;
    rdfs:comment 'Full name of the Clinical Research Associate who performed the monitoring visit. Captured for audit trail and accountability purposes.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical findings identified during the monitoring visit. Critical findings represent major deviations from GCP, protocol, or regulatory requirements that pose significant risk to subject safety, data integrity, or trial validity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Narrative summary of key findings, observations, and issues identified during the monitoring visit. Provides context for the quantitative finding counts and highlights areas requiring attention.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpLetterDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Letter Date' ;
    rdfs:comment 'Date on which the formal monitoring visit follow-up letter was issued to the investigational site. The follow-up letter documents findings, required actions, and timelines for resolution.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Status' ;
    rdfs:comment 'Overall assessment of the investigational sites compliance with Good Clinical Practice (GCP) standards based on observations during the monitoring visit. GCP compliance is mandatory for regulatory acceptance of trial data.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentVerifiedCount rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Verified Count' ;
    rdfs:comment 'Number of informed consent forms reviewed and verified for completeness, signatures, and regulatory compliance during the visit.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigatorMeetingHeld rdf:type rdf:Property ;
    rdfs:label 'Investigator Meeting Held' ;
    rdfs:comment 'Indicates whether a face-to-face meeting was conducted with the principal investigator during the monitoring visit to discuss trial progress, findings, and site performance.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAccountabilityVerified rdf:type rdf:Property ;
    rdfs:label 'Ip Accountability Verified' ;
    rdfs:comment 'Indicates whether investigational product (IP) accountability records were reviewed and verified during the visit. IP accountability ensures proper receipt, storage, dispensing, and return/destruction of study drug.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major findings identified during the monitoring visit. Major findings represent significant deviations that require corrective action but do not immediately threaten subject safety or data integrity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor findings or observations identified during the monitoring visit. Minor findings represent low-impact deviations or areas for improvement that do not significantly affect trial conduct.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringReportDate rdf:type rdf:Property ;
    rdfs:label 'Monitoring Report Date' ;
    rdfs:comment 'Date on which the formal monitoring visit report was completed and submitted. The monitoring report is a GCP-required document that summarizes visit activities, findings, and recommendations.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringReportReference rdf:type rdf:Property ;
    rdfs:label 'Monitoring Report Reference' ;
    rdfs:comment 'Document reference or identifier for the formal monitoring visit report stored in the Trial Master File (TMF) or electronic Trial Master File (eTMF) system.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorCapaResolvedCount rdf:type rdf:Property ;
    rdfs:label 'Prior Capa Resolved Count' ;
    rdfs:comment 'Number of CAPA items from previous monitoring visits that were verified as resolved during this visit. Tracks effectiveness of corrective actions and continuous improvement.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolDeviationsIdentified rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviations Identified' ;
    rdfs:comment 'Number of protocol deviations identified during the monitoring visit. Protocol deviations represent departures from the approved study protocol that may affect subject safety, data integrity, or trial outcomes.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryBinderReviewed rdf:type rdf:Property ;
    rdfs:label 'Regulatory Binder Reviewed' ;
    rdfs:comment 'Indicates whether the site regulatory binder (containing essential documents such as IRB approvals, investigator CVs, licenses, and training records) was reviewed for completeness and currency during the visit.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScoreChange rdf:type rdf:Property ;
    rdfs:label 'Risk Score Change' ;
    rdfs:comment 'Direction of change in the site risk score compared to the previous assessment. Indicates whether site performance and compliance are improving, deteriorating, or stable.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned date for the monitoring visit as defined in the monitoring plan or risk-based monitoring (RBM) strategy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdvCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Sdv Completion Percentage' ;
    rdfs:comment 'Percentage of case report form (CRF) data points verified against source documents during this monitoring visit. SDV is a core GCP requirement to ensure data accuracy and integrity.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteRiskScore rdf:type rdf:Property ;
    rdfs:label 'Site Risk Score' ;
    rdfs:comment 'Updated risk score for the investigational site following the monitoring visit. Risk scores inform risk-based monitoring (RBM) strategies and determine frequency and intensity of future monitoring activities.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subjectsReviewedCount rdf:type rdf:Property ;
    rdfs:label 'Subjects Reviewed Count' ;
    rdfs:comment 'Number of enrolled subjects whose records were reviewed during this monitoring visit for protocol compliance, data quality, and safety assessment.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Visit End Timestamp' ;
    rdfs:comment 'Precise date and time when the monitoring visit concluded at the investigational site.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitMode rdf:type rdf:Property ;
    rdfs:label 'Visit Mode' ;
    rdfs:comment 'Method by which the monitoring visit was conducted. On-site visits involve physical presence at the investigational site, remote visits use electronic systems and telecommunications, and hybrid visits combine both approaches.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Visit Start Timestamp' ;
    rdfs:comment 'Precise date and time when the monitoring visit commenced at the investigational site.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ctmsInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Ctms Investigator Id' ;
    rdfs:comment 'Source system identifier for this investigator as recorded in Oracle Clinical / Siebel CTMS. Used for cross-system reconciliation and lineage tracing back to the operational CTMS record.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:hcpMasterId rdf:type rdf:Property ;
    rdfs:label 'Hcp Master Id' ;
    rdfs:comment 'FK to hcp.hcp_master.hcp_master_id — Principal investigators are HCPs — linking PI records to HCP master enables unified view of an HCPs relationship with the company across clinical, commercial, and medical affairs activities.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:licenseCountryId rdf:type rdf:Property ;
    rdfs:label 'License Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: PIs hold medical licenses in specific countries. Required for regulatory compliance verification, license validation against country-specific medical boards, Form FDA 1572 validation, and investigator' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:medicalKolProfileId rdf:type rdf:Property ;
    rdfs:label 'Medical Kol Profile Id' ;
    rdfs:comment 'Foreign key linking to medical.medical_kol_profile. Business justification: Principal investigators are frequently KOLs tracked in medical affairs for advisory boards, publication authorship, congress speaking, and strategic engagement. Same individual has dual roles requirin' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalKolProfile .

ind:reporterId rdf:type rdf:Property ;
    rdfs:label 'Reporter Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.reporter. Business justification: Principal Investigators are primary reporters of trial SAEs/SUSARs to sponsors. Linking PI identity to PV reporter records enables causality assessment tracking, follow-up correspondence, and regulato' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reporter .

ind:country rdf:type rdf:Property ;
    rdfs:label 'Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the investigator primarily practices and conducts clinical trial activities. Determines applicable regulatory framework (FDA, EMA, PMDA, NMPA, etc.).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Cv Document Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the investigator\'s current curriculum vitae stored in Veeva Vault eTMF. The CV is a mandatory eTMF document (TMF Reference Model artifact 01.01) required for regulatory submissions and site qualification.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationLogReference rdf:type rdf:Property ;
    rdfs:label 'Delegation Log Reference' ;
    rdfs:comment 'Reference identifier pointing to the investigator\'s delegation of authority log stored in Veeva Vault eTMF or site trial master file. The delegation log documents which trial tasks have been assigned to sub-investigators and site staff, as required by GCP.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary professional email address of the investigator used for trial-related communications, protocol amendments, and safety notifications. Distinct from personal email; should be institutional or practice-based.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaDebarmentCheckDate rdf:type rdf:Property ;
    rdfs:label 'Fda Debarment Check Date' ;
    rdfs:comment 'Date on which the investigator was last verified against the FDA Debarment List and the Office of Inspector General (OIG) exclusion database. Mandatory pre-engagement check and periodic re-verification per sponsor SOPs.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Financial Disclosure Date' ;
    rdfs:comment 'Date on which the investigator\'s financial disclosure form (FDA Form 3454 or 3455) was most recently submitted or updated. Required for NDA/BLA submissions to FDA.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialDisclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Disclosure Status' ;
    rdfs:comment 'Status of the investigator\'s financial disclosure form (FDA Form 3454/3455) as required under 21 CFR Part 54. Indicates whether the investigator has disclosed financial interests that could affect trial integrity. \'Disclosed\' means the form has been submitted and reviewed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal given name of the principal investigator or sub-investigator as it appears on their medical license and regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:form1572Date rdf:type rdf:Property ;
    rdfs:label 'Form 1572 Date' ;
    rdfs:comment 'Date on which the investigator signed FDA Form 1572 (Statement of Investigator) for the most recent trial engagement. Form 1572 is a legal commitment by the investigator to comply with FDA regulations and GCP. Required for all IND-regulated trials in the US.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Date' ;
    rdfs:comment 'Date on which the investigator most recently completed GCP training as required by ICH E6(R2). Mandatory for trial participation; triggers re-training alerts when approaching the validity window (typically 2-3 years).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Expiry Date' ;
    rdfs:comment 'Date on which the current GCP training certification expires. Investigators with expired GCP training must not conduct trial activities. Drives compliance monitoring and site qualification workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingProvider rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Provider' ;
    rdfs:comment 'Name of the organization or platform that delivered the GCP training (e.g., CITI Program, TransCelerate, sponsor-internal training). Supports audit trail for regulatory inspections.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionalAffiliation rdf:type rdf:Property ;
    rdfs:label 'Institutional Affiliation' ;
    rdfs:comment 'Name of the hospital, academic medical center, research institution, or private practice with which the investigator is primarily affiliated (e.g., Memorial Sloan Kettering Cancer Center, Mayo Clinic). Used for site qualification and regulatory submissions.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorRole rdf:type rdf:Property ;
    rdfs:label 'Investigator Role' ;
    rdfs:comment 'GCP-defined role of the individual at the investigational site: Principal Investigator (PI) who bears overall responsibility, Sub-Investigator (sub-I) who assists under PI supervision, or Coordinating Investigator who coordinates multi-site activities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorStatus rdf:type rdf:Property ;
    rdfs:label 'Investigator Status' ;
    rdfs:comment 'Current lifecycle status of the investigator record. \'Active\' indicates the investigator is qualified and currently engaged in trial conduct. \'Disqualified\' reflects FDA or regulatory authority debarment or disqualification actions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Registration Number' ;
    rdfs:comment 'Registration number of the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) with which the investigator\'s site is registered. Required for FDA-regulated trials under 21 CFR Part 56 and ICH E6(R2).' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDebarred rdf:type rdf:Property ;
    rdfs:label 'Is Debarred' ;
    rdfs:comment 'Indicates whether the investigator is currently listed on the FDA Debarment List or OIG exclusion database. A value of True immediately disqualifies the investigator from participating in any FDA-regulated clinical trial.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal family name of the principal investigator or sub-investigator as it appears on their medical license and regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date on which the investigator\'s medical license expires. Triggers re-qualification workflows to ensure continued GCP-compliant trial conduct. Null if the license has no expiry.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'License Issuing Authority' ;
    rdfs:comment 'Name of the regulatory or professional body that issued the medical license (e.g., California Medical Board, General Medical Council UK, Ordre des Médecins France). Required for cross-border trial conduct verification.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Medical License Number' ;
    rdfs:comment 'State or national medical license number issued by the relevant licensing authority. Required for regulatory submissions and site qualification. Uniquely identifies the investigator\'s right to practice medicine.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalSpecialty rdf:type rdf:Property ;
    rdfs:label 'Medical Specialty' ;
    rdfs:comment 'Primary board-certified or recognized medical specialty of the investigator (e.g., Oncology, Immunology, Cardiology, Neurology). Used to match investigator expertise to trial therapeutic area and protocol requirements.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the investigator as recorded on official credentials. Used for disambiguation when first and last names are not unique.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npiNumber rdf:type rdf:Property ;
    rdfs:label 'Npi Number' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) assigned by CMS to US-based healthcare providers. Used for US-specific investigator identification, cross-referencing with HCP databases, and commercial engagement separation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orcidIdentifier rdf:type rdf:Property ;
    rdfs:label 'Orcid Identifier' ;
    rdfs:comment 'Persistent digital identifier (ORCID iD) assigned to the investigator by the ORCID registry. Used to uniquely identify researchers across publications, grant applications, and clinical trial registries (e.g., ClinicalTrials.gov).' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary professional phone number for the investigator, used for urgent safety communications, protocol queries, and site monitoring contact. Includes country code for international trials.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorTrialCount rdf:type rdf:Property ;
    rdfs:label 'Prior Trial Count' ;
    rdfs:comment 'Total number of GCP-regulated clinical trials in which the investigator has previously served as PI or sub-investigator. Key feasibility metric used by sponsors and CROs during site selection.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:professionalTitle rdf:type rdf:Property ;
    rdfs:label 'Professional Title' ;
    rdfs:comment 'Highest relevant professional or academic degree held by the investigator (e.g., MD, PhD, PharmD). Used in regulatory submissions and delegation logs. [ENUM-REF-CANDIDATE: MD|DO|PhD|MD-PhD|PharmD|MBBS|MBChB|DVM|Other — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Verified Date' ;
    rdfs:comment 'Date on which the sponsor or CRO last verified the investigator\'s qualifications, credentials, and GCP training as part of the site qualification or re-qualification process. Supports audit trail for regulatory inspections.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the principal investigator master record was first created in the system. Supports audit trail, data lineage, and GCP-compliant record management per 21 CFR Part 11.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when the principal investigator master record was most recently modified. Required for audit trail compliance under 21 CFR Part 11 and GCP data integrity requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryAuthorityRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Registration Number' ;
    rdfs:comment 'Identifier assigned by a national regulatory authority for the investigator\'s registration to conduct clinical trials (e.g., FDA investigator registration number, EudraCT investigator ID, MHRA registration). Required for IND/NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subSpecialty rdf:type rdf:Property ;
    rdfs:label 'Sub Specialty' ;
    rdfs:comment 'Secondary or sub-specialty area of clinical expertise (e.g., Hematologic Oncology, Pediatric Immunology). Provides finer-grained matching for complex or rare disease trials.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaExpertise rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Expertise' ;
    rdfs:comment 'Primary therapeutic area(s) in which the investigator has documented clinical trial experience (e.g., Oncology, Immunology, Rare Diseases, Neurology). Used for protocol-to-investigator matching and feasibility assessments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfClinicalTrialExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Clinical Trial Experience' ;
    rdfs:comment 'Number of years the investigator has been conducting GCP-regulated clinical trials. Used during site feasibility assessments to evaluate investigator experience relative to protocol complexity.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gxpObligationId rdf:type rdf:Property ;
    rdfs:label 'Gxp Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.gxp_obligation. Business justification: Protocol design must reference applicable GXP obligations (GCP, GLP) for compliance attestation. IRB submissions and regulatory filings require explicit citation of regulatory obligations the protocol' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GxpObligation .

ind:internalOrderId rdf:type rdf:Property ;
    rdfs:label 'Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Protocols drive R&D cost tracking via internal orders for trial execution budgets (personnel, materials, CRO costs). Standard pharma cost accounting requires protocol-level cost center assignment for ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:medicalPublicationId rdf:type rdf:Property ;
    rdfs:label 'Medical Publication Id' ;
    rdfs:comment 'Foreign key linking to medical.medical_publication. Business justification: Publications reference specific protocol versions for methods, endpoints, statistical analysis plans, and regulatory alignment. Publication planning requires protocol-level traceability for authorship' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalPublication .

ind:medicalWriterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Medical Writer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Protocols are authored and medically reviewed by internal medical writers. Regulatory submissions require documented authorship and review chains. Essential for document lifecycle management and GxP c' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryApplicationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Application Id' ;
    rdfs:comment 'Foreign key linking to regulatory.application. Business justification: Protocols are written to support specific regulatory applications (IND, NDA, BLA). Regulatory teams must track which protocols support which applications for submission planning, health authority meet' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:rsiId rdf:type rdf:Property ;
    rdfs:label 'Rsi Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.rsi. Business justification: Protocols reference current Reference Safety Information (IB/RSI) for SUSAR determination during trial conduct. Investigators assess expectedness against RSI version effective at AE onset; link requir' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rsi .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential integer counter for protocol amendments. Zero (0) indicates the original protocol; each subsequent amendment increments by one. Supports amendment history tracking and regulatory submission traceability.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentRationale rdf:type rdf:Property ;
    rdfs:label 'Amendment Rationale' ;
    rdfs:comment 'Documented justification for protocol changes introduced in this amendment version. Required by regulatory agencies to assess the impact of changes on subject safety, data integrity, and study validity. Null for original protocol (amendment_number = 0).' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment\'s regulatory significance. \'Substantial\' amendments require prior regulatory authority approval; \'non_substantial\' require notification only; \'administrative\' are minor corrections. Determines regulatory submission pathway.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingMethod rdf:type rdf:Property ;
    rdfs:label 'Blinding Method' ;
    rdfs:comment 'Level of masking applied to the trial to prevent bias. Double-blind masks both subject and investigator; open-label has no masking. Critical for GCP compliance and regulatory acceptance of efficacy data.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicaltrialsGovNumber rdf:type rdf:Property ;
    rdfs:label 'Clinicaltrials Gov Number' ;
    rdfs:comment 'National Clinical Trial (NCT) identifier assigned by ClinicalTrials.gov upon trial registration. Mandatory for FDA-regulated trials under FDAAA 801 and required for publication in peer-reviewed journals per ICMJE policy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designType rdf:type rdf:Property ;
    rdfs:label 'Design Type' ;
    rdfs:comment 'Structural design of the clinical trial. Determines how treatment arms are organized and how subjects are allocated. Informs statistical analysis plan and regulatory review strategy. [ENUM-REF-CANDIDATE: parallel|crossover|factorial|single_arm|basket|umbrella|platform — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosingRegimen rdf:type rdf:Property ;
    rdfs:label 'Dosing Regimen' ;
    rdfs:comment 'Description of the investigational product dose, route of administration, frequency, and duration for each treatment arm (e.g., Drug X 200mg IV Q3W for 12 cycles). Directly linked to CMC and IND/NDA/BLA submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudractNumber rdf:type rdf:Property ;
    rdfs:label 'Eudract Number' ;
    rdfs:comment 'European Union Drug Regulating Authorities Clinical Trials (EudraCT) registration number assigned by EMA for clinical trials conducted in the EU/EEA. Required for MAA submissions and EU Clinical Trial Regulation compliance.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Conditions or characteristics that disqualify a subject from enrollment (e.g., prior therapy, comorbidities, contraindications). Complements inclusion criteria to define the eligible study population.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exploratoryObjectives rdf:type rdf:Property ;
    rdfs:label 'Exploratory Objectives' ;
    rdfs:comment 'Hypothesis-generating objectives not powering the study, such as biomarker analyses, translational research endpoints, or health economics and outcomes research (HEOR) assessments. Supports future study design and RWE generation.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpComplianceAttestation rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Attestation' ;
    rdfs:comment 'Boolean flag indicating whether this protocol version has been formally attested as compliant with ICH E6(R2) Good Clinical Practice guidelines. Required for regulatory submissions and audit readiness.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Inclusion Criteria' ;
    rdfs:comment 'Eligibility criteria that subjects must meet to be enrolled in the trial (e.g., age range, diagnosis, performance status, biomarker positivity). Defines the Intent-to-Treat (ITT) population. Stored as structured free text per protocol.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indication rdf:type rdf:Property ;
    rdfs:label 'Indication' ;
    rdfs:comment 'Specific disease or medical condition being studied in the trial (e.g., Non-Small Cell Lung Cancer, Rheumatoid Arthritis). Mapped to ICD-10 or MedDRA coding for regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Date' ;
    rdfs:comment 'Date on which the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) granted approval for this protocol version. Milestone date for site activation and GCP compliance documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irbApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the IRB/IEC approval for this protocol version. Required for GCP compliance and site activation. Tracked in Veeva Vault eTMF under the Trial Master File structure.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Regulatory development phase of the clinical trial as defined by ICH and FDA guidelines. Determines the study objectives, patient population size, and regulatory pathway (IND, NDA, BLA, MAA).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSampleSize rdf:type rdf:Property ;
    rdfs:label 'Planned Sample Size' ;
    rdfs:comment 'Total number of subjects planned for enrollment as determined by the sample size justification in the protocol. Based on statistical power calculations for the primary endpoint. Drives site activation and enrollment planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEndpoint rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint' ;
    rdfs:comment 'The principal clinical outcome measure used to evaluate the primary objective (e.g., Overall Survival (OS), Progression-Free Survival (PFS), Objective Response Rate (ORR)). Drives sample size calculation and statistical analysis plan.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryObjective rdf:type rdf:Property ;
    rdfs:label 'Primary Objective' ;
    rdfs:comment 'The principal scientific and clinical objective of the trial as stated in the protocol. Defines the primary endpoint and the key question the study is designed to answer (e.g., demonstrate superiority in Overall Survival).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolNumber rdf:type rdf:Property ;
    rdfs:label 'Protocol Number' ;
    rdfs:comment 'Sponsor-assigned unique protocol identifier used across all regulatory submissions, eTMF filings, and CTMS records. Externally known identifier referenced in IND/NDA/BLA/MAA dossiers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolStatus rdf:type rdf:Property ;
    rdfs:label 'Protocol Status' ;
    rdfs:comment 'Current lifecycle state of this protocol version. \'draft\' indicates work-in-progress; \'under_review\' indicates IRB/IEC or sponsor review; \'approved\' indicates fully authorized for use; \'superseded\' indicates replaced by a newer amendment; \'retired\' indicates withdrawn.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationScheme rdf:type rdf:Property ;
    rdfs:label 'Randomization Scheme' ;
    rdfs:comment 'Method used to randomly allocate subjects to treatment arms. Stratified randomization accounts for prognostic factors; adaptive randomization adjusts allocation ratios based on accumulating data. Documented in the protocol and statistical analysis plan.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeJustification rdf:type rdf:Property ;
    rdfs:label 'Sample Size Justification' ;
    rdfs:comment 'Narrative description of the statistical assumptions and power calculations supporting the planned sample size, including assumed effect size, alpha level, power, and dropout rate. Required by ICH E9(R1) and regulatory agencies.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapReference rdf:type rdf:Property ;
    rdfs:label 'Sap Reference' ;
    rdfs:comment 'Document identifier or version reference for the Statistical Analysis Plan (SAP) associated with this protocol version. The SAP details the pre-specified statistical methods for analyzing primary and secondary endpoints per ICH E9(R1).' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryObjectives rdf:type rdf:Property ;
    rdfs:label 'Secondary Objectives' ;
    rdfs:comment 'Supporting scientific objectives of the trial beyond the primary endpoint. May include secondary efficacy endpoints (PFS, ORR, QoL), safety objectives, and PK/PD assessments. Stored as free text per protocol document.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortTitle rdf:type rdf:Property ;
    rdfs:label 'Short Title' ;
    rdfs:comment 'Abbreviated or lay-language title of the protocol used in operational communications, CTMS displays, and site-facing materials. Distinct from the full regulatory title.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactors rdf:type rdf:Property ;
    rdfs:label 'Stratification Factors' ;
    rdfs:comment 'Clinical or demographic variables used to stratify randomization to ensure balanced treatment arms (e.g., disease stage, ECOG performance status, geographic region, biomarker status). Stored as free text per protocol specification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Broad classification of the study design indicating whether the trial involves an active intervention, passive observation, or special access program. Aligns with ClinicalTrials.gov and EudraCT registration categories.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Full official title of the clinical trial protocol as it appears on the protocol document and regulatory submissions. Typically includes the investigational product name, indication, and study design descriptor.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Doc Reference' ;
    rdfs:comment 'Document identifier in Veeva Vault eTMF where the authoritative protocol document is stored. Enables direct traceability from the data product record to the source document in the electronic Trial Master File.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version identifier for this protocol document (e.g., 1.0, 2.0, 2.1). Each approved amendment increments the version. Used to distinguish original protocol from subsequent amendments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitScheduleSummary rdf:type rdf:Property ;
    rdfs:label 'Visit Schedule Summary' ;
    rdfs:comment 'High-level description of the Schedule of Assessments (SoA) including number of study visits, key assessment windows, and follow-up duration. Detailed SoA is maintained in the protocol appendix and Medidata Rave EDC configuration.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Validated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Randomization schedule validation requires qualified statistician or data manager signature per GxP. Current text field \'validated_by\' should be FK to employee for qualification verification and audit' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date on which the randomization schedule was activated and made available for subject randomization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blindingLevel rdf:type rdf:Property ;
    rdfs:label 'Blinding Level' ;
    rdfs:comment 'Level of blinding applied in the trial: open-label (no blinding), single-blind (subject blinded), double-blind (subject and investigator blinded), or triple-blind (subject, investigator, and sponsor blinded).' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codesAllocated rdf:type rdf:Property ;
    rdfs:label 'Codes Allocated' ;
    rdfs:comment 'Number of randomization codes that have been allocated to subjects. Updated as subjects are randomized.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codesRemaining rdf:type rdf:Property ;
    rdfs:label 'Codes Remaining' ;
    rdfs:comment 'Number of randomization codes remaining available for allocation. Calculated as total codes minus codes allocated.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the randomization schedule was deactivated or suspended. Null if still active.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyUnblindingEnabled rdf:type rdf:Property ;
    rdfs:label 'Emergency Unblinding Enabled' ;
    rdfs:comment 'Indicates whether emergency unblinding is enabled in the IWRS/IRT system for this randomization schedule.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iwrsConfigurationReference rdf:type rdf:Property ;
    rdfs:label 'Iwrs Configuration Reference' ;
    rdfs:comment 'Configuration identifier or reference code in the IWRS/IRT system for this randomization schedule.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iwrsSystemName rdf:type rdf:Property ;
    rdfs:label 'Iwrs System Name' ;
    rdfs:comment 'Name of the IWRS or IRT system used to manage randomization and treatment allocation (e.g., Medidata Rave RTSM, Oracle InForm IWRS).' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationListLocation rdf:type rdf:Property ;
    rdfs:label 'Randomization List Location' ;
    rdfs:comment 'Secure storage location or document management system reference where the master randomization list is maintained. Confidential to preserve blinding.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationType rdf:type rdf:Property ;
    rdfs:label 'Randomization Type' ;
    rdfs:comment 'Type of randomization method used in the schedule: simple randomization, block randomization, stratified randomization, adaptive randomization, response-adaptive randomization, or minimization.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name or label for this randomization schedule configuration.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the randomization schedule: draft (under development), validated (tested and approved), active (in use), suspended (temporarily paused), completed (trial finished), or archived (historical record).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version number or identifier for this randomization schedule, supporting version control and audit trail.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedValue rdf:type rdf:Property ;
    rdfs:label 'Seed Value' ;
    rdfs:comment 'Seed value used by the random number generator to produce the randomization sequence. Confidential to maintain blinding integrity.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stratificationFactor4 rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 4' ;
    rdfs:comment 'Fourth stratification factor used to balance treatment allocation. Null if not applicable.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactorCount rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor Count' ;
    rdfs:comment 'Number of stratification factors used in the randomization scheme. Zero if no stratification is applied.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRandomizationCodes rdf:type rdf:Property ;
    rdfs:label 'Total Randomization Codes' ;
    rdfs:comment 'Total number of randomization codes generated in this schedule to support the planned enrollment.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentArmCount rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Count' ;
    rdfs:comment 'Total number of treatment arms in the trial for which this randomization schedule allocates subjects.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unblindingProcedure rdf:type rdf:Property ;
    rdfs:label 'Unblinding Procedure' ;
    rdfs:comment 'Description of the procedure and circumstances under which treatment assignment may be unblinded (e.g., medical emergency, SAE reporting).' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the randomization schedule was validated and approved for use in the clinical trial.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:variableBlockSizes rdf:type rdf:Property ;
    rdfs:label 'Variable Block Sizes' ;
    rdfs:comment 'Comma-separated list of variable block sizes used when block size varies to enhance blinding (e.g., 4,6,8). Null if fixed block size is used.' ;
    rdfs:domain ind:RandomizationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectObservationId rdf:type rdf:Property ;
    rdfs:label 'Subject Observation Id' ;
    rdfs:comment 'Unique surrogate identifier for each subject observation record in the EDC (Medidata Rave). Represents the atomic unit of clinical trial data collected per subject per visit per Case Report Form (CRF) field.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enteredByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Entered By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Data entry requires documented employee identity for 21 CFR Part 11 audit trail and GxP compliance. Current text field \'entered_by\' should be FK to employee for training verification and electronic si' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analysisPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Analysis Population Flag' ;
    rdfs:comment 'Indicates the analysis population(s) to which this observation contributes: Intent-to-Treat (ITT), Per Protocol (PP), Safety population, or excluded. Drives statistical analysis dataset (ADaM) construction and primary/secondary endpoint derivation.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this observation to its complete audit trail record in the EDC system (Medidata Rave). Enables traceability of all data changes, user actions, and timestamps per 21 CFR Part 11 electronic records requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcRecordReference rdf:type rdf:Property ;
    rdfs:label 'Edc Record Reference' ;
    rdfs:comment 'Native record identifier assigned by the EDC system (Medidata Rave) for this observation. Used for source system traceability, audit trail reconciliation, and data migration validation.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The date and time at which the data was first entered into the EDC system (Medidata Rave) by the site user. Used for data entry timeliness monitoring, audit trail compliance, and GCP inspection readiness per ICH E6(R2).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Baseline' ;
    rdfs:comment 'Indicates whether this observation represents the baseline measurement for the subject, used as the reference value for change-from-baseline calculations in efficacy endpoint derivation (e.g., tumor size at baseline for ORR). Corresponds to SDTM ABLFL flag in ADaM datasets.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnscheduled rdf:type rdf:Property ;
    rdfs:label 'Is Unscheduled' ;
    rdfs:comment 'Indicates whether this observation was collected during an unscheduled visit (not defined in the protocol schedule of assessments). Unscheduled observations may be excluded from primary efficacy analyses per the statistical analysis plan.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The date and time of the most recent modification to this observation record in the EDC system. Supports audit trail tracking, data change monitoring, and 21 CFR Part 11 electronic records compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:normalRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Normal Range High' ;
    rdfs:comment 'The upper bound of the reference (normal) range for this observation type as defined by the central laboratory or clinical standard. Used for out-of-range flagging, safety signal detection, and SDTM STNRHI derivation.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:normalRangeLow rdf:type rdf:Property ;
    rdfs:label 'Normal Range Low' ;
    rdfs:comment 'The lower bound of the reference (normal) range for this observation type as defined by the central laboratory or clinical standard. Used for out-of-range flagging, safety signal detection, and SDTM STNRLO derivation.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numericValue rdf:type rdf:Property ;
    rdfs:label 'Numeric Value' ;
    rdfs:comment 'The numeric representation of the observation value after unit standardization, corresponding to the SDTM STRESN variable. Used for quantitative analyses, endpoint derivation (ORR, PFS, OS), and statistical modeling in ADaM datasets.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observationStatus rdf:type rdf:Property ;
    rdfs:label 'Observation Status' ;
    rdfs:comment 'Current workflow status of the observation record within the EDC system lifecycle. Drives data cleaning workflows, lock readiness assessment, and database lock milestones. [ENUM-REF-CANDIDATE: entered|verified|locked|queried|resolved|deleted — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryStatus rdf:type rdf:Property ;
    rdfs:label 'Query Status' ;
    rdfs:comment 'Status of any data query (discrepancy) raised against this observation in the EDC system. Open queries must be resolved prior to database lock. Supports data cleaning metrics and site performance monitoring.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryText rdf:type rdf:Property ;
    rdfs:label 'Query Text' ;
    rdfs:comment 'The text of the most recent data query raised against this observation, describing the discrepancy or clarification required from the site. Supports data management review and site communication workflows.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawValue rdf:type rdf:Property ;
    rdfs:label 'Raw Value' ;
    rdfs:comment 'The verbatim data value as entered by the site user in the EDC system (Medidata Rave), prior to any derivation or standardization. Stored as STRING to accommodate all data types (numeric, text, coded). Represents the source data for SDV and audit trail purposes.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonForChange rdf:type rdf:Property ;
    rdfs:label 'Reason For Change' ;
    rdfs:comment 'The documented reason provided by the site user when modifying a previously entered observation value in the EDC system. Mandatory per 21 CFR Part 11 and GCP requirements for any post-entry data correction. Stored as the most recent change reason.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVariable rdf:type rdf:Property ;
    rdfs:label 'Sdtm Variable' ;
    rdfs:comment 'The specific CDISC SDTM variable name to which this CRF field maps (e.g., VSSTRESN, LBORRES, AEDECOD). Enables automated SDTM dataset generation and submission-ready data transformation.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvDate rdf:type rdf:Property ;
    rdfs:label 'Sdv Date' ;
    rdfs:comment 'The date on which Source Data Verification (SDV) was completed for this observation. Used for monitoring visit planning, SDV coverage reporting, and GCP audit trail documentation.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdvStatus rdf:type rdf:Property ;
    rdfs:label 'Sdv Status' ;
    rdfs:comment 'Status of Source Data Verification (SDV) for this observation, indicating whether the EDC-entered value has been verified against the original source document (e.g., medical record, lab report) by the CRA or site monitor. Critical for GCP compliance and regulatory inspection readiness.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Unit' ;
    rdfs:comment 'The standardized unit of measure after conversion to the study-defined reference unit (SDTM STRESU). Enables cross-site and cross-study comparability for endpoint derivation and pooled analyses.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unit rdf:type rdf:Property ;
    rdfs:label 'Unit' ;
    rdfs:comment 'The unit of measure for the observation value as collected (e.g., mmHg, mg/dL, kg, beats/min). Corresponds to SDTM ORRESU variable. Required for clinical interpretation and cross-site data harmonization.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'The username or identifier of the Clinical Research Associate (CRA) or monitor who performed Source Data Verification (SDV) for this observation. Supports GCP compliance documentation and monitoring visit reports.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affairsPlanId rdf:type rdf:Property ;
    rdfs:label 'Affairs Plan Id' ;
    rdfs:comment 'Foreign key linking to medical.medical_affairs_plan. Business justification: Clinical trials are executed within medical affairs strategic plans that define evidence generation strategy, publication planning, and KOL engagement. Medical affairs plans govern trial portfolio pri' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffairsPlan .

ind:clinicalSupplyContractId rdf:type rdf:Property ;
    rdfs:label 'Clinical Supply Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.supply_contract. Business justification: Master supply agreements govern clinical material supply terms for trials. Business process: contract management for clinical supplies, pricing terms, quality agreements, supply commitments, and regul' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyContract .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.demand_plan. Business justification: Commercial supply planning uses Phase 3 trial enrollment forecasts and launch timelines to model post-approval demand. S&OP process requires linking trial data to demand planning for manufacturing cap' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlan .

ind:exclusivityPeriodId rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Period Id' ;
    rdfs:comment 'Foreign key linking to intellectual.exclusivity_period. Business justification: Clinical trials generate regulatory data establishing exclusivity periods (orphan, pediatric, data exclusivity). Linking enables lifecycle planning, loss-of-exclusivity forecasting, and regulatory str' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExclusivityPeriod .

ind:financeInternalOrderId rdf:type rdf:Property ;
    rdfs:label 'Finance Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Clinical trials should link to finance internal orders for trial budget tracking and cost allocation. This enables accurate R&D capitalization and trial cost management across the enterprise.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:licensingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Licensing Agreement Id' ;
    rdfs:comment 'Foreign key linking to intellectual.licensing_agreement. Business justification: In-licensed compounds require tracking which licensing agreement governs each trial to manage milestone payments, royalty obligations, territory restrictions, and diligence requirements. Essential for' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicensingAgreement .

ind:molecularTargetId rdf:type rdf:Property ;
    rdfs:label 'Molecular Target Id' ;
    rdfs:comment 'Foreign key linking to discovery.molecular_target. Business justification: Portfolio reviews, competitive intelligence, and regulatory submissions require linking trials to their molecular targets. Essential for target validation reporting, strategic planning, and demonstrat' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MolecularTarget .

ind:primaryCountryId rdf:type rdf:Property ;
    rdfs:label 'Primary Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Trials have primary regulatory jurisdiction countries. Required for regulatory authority mapping, submission planning (FDA, EMA, PMDA), country-specific compliance requirements, and trial registry sel' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Foreign key linking to discovery.discovery_project. Business justification: Stage-gate reviews, portfolio management, and budget tracking require linking clinical trials back to originating discovery projects. Essential for ROI analysis, resource allocation decisions, and int' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:sponsorDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Department Id' ;
    rdfs:comment 'Foreign key linking to workforce.department. Business justification: Trials are sponsored by specific internal departments (e.g., Oncology Clinical Development) for budget allocation, resource planning, and organizational accountability. Essential for financial reporti' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:sponsorLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Trials are sponsored by legal entities. Essential for financial consolidation, regulatory submissions (sponsor identification in CTD), contract management, and liability tracking. Core business relati' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:actualEnrollment rdf:type rdf:Property ;
    rdfs:label 'Actual Enrollment' ;
    rdfs:comment 'Actual number of patients enrolled (consented and randomized or assigned to treatment) as tracked in Oracle/Siebel CTMS and Medidata Rave EDC. Updated in real-time during trial execution. Used for enrollment rate monitoring and milestone tracking.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPrimaryCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Primary Completion Date' ;
    rdfs:comment 'Actual date on which the last patient completed the primary endpoint assessment (LPLV). Recorded in CTMS and Medidata Rave. Triggers database lock procedures and Clinical Study Report (CSR) preparation.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date on which the first patient was enrolled and received the first dose (FPFV). Recorded in Oracle/Siebel CTMS and Medidata Rave. Compared against planned_start_date to calculate enrollment delay variance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisPopulation rdf:type rdf:Property ;
    rdfs:label 'Analysis Population' ;
    rdfs:comment 'Statistical analysis population used for the primary endpoint analysis. Intent-to-Treat (ITT) is the regulatory gold standard for confirmatory trials. Per Protocol (PP) is used as a sensitivity analysis. Defined in the Statistical Analysis Plan (SAP).' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateNominationId rdf:type rdf:Property ;
    rdfs:label 'Candidate Nomination Id' ;
    rdfs:comment 'Foreign key linking to discovery.candidate_nomination. Business justification: Candidate nomination is the formal discovery-to-clinical handoff event. IND preparation, transition meetings, and regulatory strategy require linking trials to their originating nomination decision. E' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CandidateNomination .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Type of control arm used in the trial. Placebo-controlled is standard for regulatory approval; active comparator is required when placebo is unethical. Historical control is used in rare disease single-arm studies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:croName rdf:type rdf:Property ;
    rdfs:label 'Cro Name' ;
    rdfs:comment 'Name of the primary Contract Research Organization (CRO) engaged to conduct or support trial operations. Captured from SAP vendor master and CTMS. Sponsors may delegate GCP responsibilities to CROs per ICH E6(R2) Section 5.2.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Csr Completion Date' ;
    rdfs:comment 'Date on which the Clinical Study Report (CSR) was finalized and approved per ICH E3 guidelines. The CSR is a mandatory component of NDA/BLA/MAA regulatory submissions. Tracked in Veeva Vault eTMF.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctaReference rdf:type rdf:Property ;
    rdfs:label 'Cta Reference' ;
    rdfs:comment 'Regulatory authority-assigned Clinical Trial Authorisation reference number for trials conducted in EU/EEA, UK (MHRA), or other ex-US jurisdictions. Supports multi-regional trial tracking.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:databaseLockDate rdf:type rdf:Property ;
    rdfs:label 'Database Lock Date' ;
    rdfs:comment 'Date on which the clinical trial database was locked in Medidata Rave EDC following data cleaning, query resolution, and medical review sign-off. Marks the point after which no further data changes are permitted without formal unblinding procedures. Critical milestone for regulatory submissions.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eclinicalSystemStudyReference rdf:type rdf:Property ;
    rdfs:label 'Eclinical System Study Reference' ;
    rdfs:comment 'Study identifier assigned in Medidata Rave EDC system. Used to cross-reference clinical data collected in Rave with CTMS records and the trial master record. Enables data lineage tracing from source EDC to the Silver layer.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etmfVaultReference rdf:type rdf:Property ;
    rdfs:label 'Etmf Vault Reference' ;
    rdfs:comment 'Veeva Vault eTMF study-level document identifier linking this trial master record to the corresponding eTMF study folder. Enables direct navigation to trial documentation for regulatory inspection readiness.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Date' ;
    rdfs:comment 'Planned date for the pre-specified interim efficacy or futility analysis reviewed by the Data Safety Monitoring Board (DSMB). Relevant for adaptive trials and trials with early stopping rules. Defined in the Statistical Analysis Plan.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irbApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Status' ;
    rdfs:comment 'Status of IRB/Independent Ethics Committee (IEC) approval for the trial protocol. Mandatory before any patient enrollment. Tracked per jurisdiction. Suspension triggers immediate halt of enrollment per GCP requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdaptiveDesign rdf:type rdf:Property ;
    rdfs:label 'Is Adaptive Design' ;
    rdfs:comment 'Indicates whether the trial employs a pre-specified adaptive design allowing modifications to the trial or statistical procedures based on interim data analysis. Requires additional FDA/EMA guidance compliance per ICH E20.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPediatricStudy rdf:type rdf:Property ;
    rdfs:label 'Is Pediatric Study' ;
    rdfs:comment 'Indicates whether the trial includes a pediatric population (patients under 18 years). Triggers Pediatric Study Plan (PIP/PSP) requirements under FDA PREA and EMA Paediatric Regulation. Impacts regulatory strategy and labeling.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nctNumber rdf:type rdf:Property ;
    rdfs:label 'Nct Number' ;
    rdfs:comment 'Unique public registry identifier assigned by ClinicalTrials.gov (U.S. National Library of Medicine). Mandatory for trials subject to FDAAA 801 registration requirements. Used in regulatory submissions and public disclosure.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEnrollment rdf:type rdf:Property ;
    rdfs:label 'Planned Enrollment' ;
    rdfs:comment 'Target number of patients to be enrolled in the trial as specified in the approved protocol and IND/CTA. Basis for site activation planning, supply chain forecasting, and budget allocation in SAP.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedPrimaryCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Primary Completion Date' ;
    rdfs:comment 'Planned date for Last Patient Last Visit (LPLV) for the primary endpoint assessment. Registered in ClinicalTrials.gov as the Primary Completion Date. Drives regulatory submission timeline planning for NDA/BLA/MAA.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Planned date for First Patient First Visit (FPFV) — the target date for the first patient to be enrolled and dosed. Used for milestone planning, CRO contracting, and supply chain scheduling. Tracked against actual FPFV for variance analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Type' ;
    rdfs:comment 'Type of regulatory submission associated with this trial\'s data package. IND for US investigational studies; NDA/BLA for US marketing applications; MAA for EU; CTA for clinical trial authorisation. Links to the regulatory.submission domain. [ENUM-REF-CANDIDATE: IND|NDA|BLA|MAA|sNDA|sBLA|CTA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEndpoints rdf:type rdf:Property ;
    rdfs:label 'Secondary Endpoints' ;
    rdfs:comment 'Pipe-delimited list of secondary outcome measures supporting the primary endpoint (e.g., \'Duration of Response|Quality of Life (QoL)|Disease-Free Survival|Patient-Reported Outcomes\'). Included in the protocol and eCTD submission.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsor Protocol Number' ;
    rdfs:comment 'Internal protocol identifier assigned by Pharmaceuticals as the trial sponsor. Used as the primary cross-system reference in Oracle/Siebel CTMS, Medidata Rave EDC, Veeva Vault eTMF, and SAP. Serves as the BUSINESS_IDENTIFIER for this master record.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDesignType rdf:type rdf:Property ;
    rdfs:label 'Study Design Type' ;
    rdfs:comment 'Fundamental design classification of the clinical trial. Determines statistical analysis plan requirements, randomization procedures, and regulatory acceptability. Adaptive designs require additional ICH E20 compliance documentation. [ENUM-REF-CANDIDATE: randomized|non_randomized|single_arm|crossover|adaptive|basket|umbrella — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialStatus rdf:type rdf:Property ;
    rdfs:label 'Trial Status' ;
    rdfs:comment 'Current lifecycle state of the clinical trial. Drives operational workflows, regulatory reporting obligations, and eTMF archival triggers. \'on_hold\' indicates a clinical hold per 21 CFR 312.42. Serves as the LIFECYCLE_STATUS for this master record.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialAdverseEventId rdf:type rdf:Property ;
    rdfs:label 'Trial Adverse Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each adverse event record reported by a subject during a clinical trial. Primary key for this transactional entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aeAccountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Ae Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: SAE processing triggers vendor invoices for emergency labs, imaging, hospitalization, and specialist consultations. Required for trial cost reconciliation, safety budget tracking, and sponsor financia' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:htaSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Hta Submission Id' ;
    rdfs:comment 'Foreign key linking to market.hta_submission. Business justification: Safety data (AE profiles, SAE rates) is mandatory for HTA dossiers. HTA bodies require comprehensive safety evidence from clinical trials for benefit-risk assessment. AE data directly populates HTA su' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HtaSubmission .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_incident. Business justification: Serious adverse events (SAEs) or reporting failures may trigger compliance incidents requiring root cause analysis and CAPA. Links safety event management to compliance investigation workflow for regu' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:masterId rdf:type rdf:Property ;
    rdfs:label 'Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.hcp_master. Business justification: Adverse events are often reported by treating physicians who are not the principal investigator. Regulatory authorities (FDA, EMA) require traceability of the reporting healthcare professional for cau' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:productComplaintId rdf:type rdf:Property ;
    rdfs:label 'Product Complaint Id' ;
    rdfs:comment 'Foreign key linking to quality.complaint. Business justification: Product complaints reported during clinical trials (packaging defects, appearance issues, administration problems) are tracked in quality complaint system per 21 CFR 820.198. Enables trend analysis an' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Complaint .

ind:productRecallId rdf:type rdf:Property ;
    rdfs:label 'Product Recall Id' ;
    rdfs:comment 'Foreign key linking to supply.product_recall. Business justification: Safety signals from AEs may trigger product recalls; 21 CFR Part 7 requires tracing recall decisions to originating safety data. Pharmacovigilance and supply chain quality must link AE reports to reca' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRecall .

ind:qualityCapaId rdf:type rdf:Property ;
    rdfs:label 'Quality Capa Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_capa. Business justification: Serious AEs potentially related to product quality defects trigger CAPA investigations per ICH E2A and GMP requirements. Links pharmacovigilance to quality systems for root cause analysis and correcti' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityCapa .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Action taken with the investigational medicinal product (IMP) in response to the adverse event (e.g., Dose not changed, Dose reduced, Drug interrupted, Drug withdrawn, Not applicable). [ENUM-REF-CANDIDATE: Dose not changed|Dose reduced|Drug interrupted|Drug withdrawn|Not applicable|Unknown — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeNumber rdf:type rdf:Property ;
    rdfs:label 'Ae Number' ;
    rdfs:comment 'Externally-known, human-readable identifier for the adverse event as assigned in the EDC system (Medidata Rave). Used for cross-referencing in CRFs, safety narratives, and regulatory submissions.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Ae Reporting Category' ;
    rdfs:comment 'Regulatory reporting classification of the adverse event: AE (non-serious), SAE (Serious Adverse Event), SUSAR (Suspected Unexpected Serious Adverse Reaction), or AESI (Adverse Event of Special Interest). Drives reporting timelines and workflows.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeSeverity rdf:type rdf:Property ;
    rdfs:label 'Ae Severity' ;
    rdfs:comment 'Descriptive severity classification of the adverse event as recorded in the CRF. Corresponds to CTCAE grade but expressed as a categorical label for reporting and filtering.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeStatus rdf:type rdf:Property ;
    rdfs:label 'Ae Status' ;
    rdfs:comment 'Current lifecycle status of the adverse event, indicating whether it is still ongoing, has resolved, resolved with residual effects, or resulted in death.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeTermVerbatim rdf:type rdf:Property ;
    rdfs:label 'Ae Term Verbatim' ;
    rdfs:comment 'The exact verbatim term as reported by the investigator or subject in the CRF prior to MedDRA coding. Preserved for audit and coding reconciliation purposes.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aesiFlag rdf:type rdf:Property ;
    rdfs:label 'Aesi Flag' ;
    rdfs:comment 'Indicates whether the adverse event has been designated as an Adverse Event of Special Interest (AESI) per the trial protocol or regulatory guidance, requiring enhanced monitoring and reporting.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:argusCaseReference rdf:type rdf:Property ;
    rdfs:label 'Argus Case Reference' ;
    rdfs:comment 'The case identifier assigned in the Argus Safety / Oracle AERS pharmacovigilance system when this trial AE is escalated to an ICSR. Enables traceability between the trial-level AE record and the PV safety database.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causalityAssessment rdf:type rdf:Property ;
    rdfs:label 'Causality Assessment' ;
    rdfs:comment 'Investigator\'s assessment of the causal relationship between the adverse event and the investigational medicinal product (IMP). Used in safety reporting and benefit-risk evaluation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concomitantMedication rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication' ;
    rdfs:comment 'Name or description of any concomitant medication administered to treat or manage the adverse event. Free-text field as captured in the CRF.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctcaeGrade rdf:type rdf:Property ;
    rdfs:label 'Ctcae Grade' ;
    rdfs:comment 'Severity grade of the adverse event per NCI CTCAE grading scale (1=Mild, 2=Moderate, 3=Severe, 4=Life-threatening, 5=Death). Mandatory for oncology trials and widely used across therapeutic areas.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dechallengeResult rdf:type rdf:Property ;
    rdfs:label 'Dechallenge Result' ;
    rdfs:comment 'Result of withdrawing or reducing the investigational product dose in response to the adverse event. Positive dechallenge (AE improved on withdrawal) supports causal relationship.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Ha Report Due Date' ;
    rdfs:comment 'The regulatory deadline by which the SAE or SUSAR must be reported to the relevant health authority (e.g., FDA 7-day or 15-day, EMA 7-day or 15-day). Calculated from sponsor_aware_date.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:haReportedDate rdf:type rdf:Property ;
    rdfs:label 'Ha Reported Date' ;
    rdfs:comment 'The actual date on which the SAE or SUSAR was submitted to the health authority. Used to assess compliance with regulatory reporting timelines.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialReportDate rdf:type rdf:Property ;
    rdfs:label 'Initial Report Date' ;
    rdfs:comment 'The date on which the adverse event was first reported by the investigator or site to the sponsor. Day 0 for regulatory reporting clock calculations (7-day/15-day timelines).' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isSerious rdf:type rdf:Property ;
    rdfs:label 'Is Serious' ;
    rdfs:comment 'Indicates whether the adverse event meets the regulatory definition of a Serious Adverse Event (SAE) per ICH E2A criteria (death, life-threatening, hospitalization, disability, congenital anomaly, or other medically important condition).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSusar rdf:type rdf:Property ;
    rdfs:label 'Is Susar' ;
    rdfs:comment 'Indicates whether this adverse event has been classified as a Suspected Unexpected Serious Adverse Reaction (SUSAR), triggering expedited 7-day or 15-day regulatory reporting obligations to health authorities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnexpected rdf:type rdf:Property ;
    rdfs:label 'Is Unexpected' ;
    rdfs:comment 'Indicates whether the adverse event is unexpected — i.e., not listed in the current Investigator\'s Brochure (IB) or Reference Safety Information (RSI). A serious, unexpected, related AE constitutes a SUSAR requiring expedited reporting.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledToDiscontinuation rdf:type rdf:Property ;
    rdfs:label 'Led To Discontinuation' ;
    rdfs:comment 'Indicates whether the adverse event led to the subject\'s permanent discontinuation from the clinical trial. Critical for ITT and safety analysis populations.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meddraPreferredTerm rdf:type rdf:Property ;
    rdfs:label 'Meddra Preferred Term' ;
    rdfs:comment 'The MedDRA Preferred Term (PT) assigned to the adverse event following medical coding. Standard term used in regulatory submissions and safety databases.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraPtCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Pt Code' ;
    rdfs:comment 'The 8-digit numeric MedDRA code corresponding to the assigned Preferred Term. Used for programmatic safety analysis and ICSR generation in Argus Safety.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraSystemOrganClass rdf:type rdf:Property ;
    rdfs:label 'Meddra System Organ Class' ;
    rdfs:comment 'The MedDRA System Organ Class (SOC) associated with the coded adverse event preferred term. Used for safety signal detection and aggregate reporting.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Review Status' ;
    rdfs:comment 'Current status of the medical monitor\'s review of the adverse event record. Tracks the safety review workflow from initial entry through medical sign-off.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalReviewer rdf:type rdf:Property ;
    rdfs:label 'Medical Reviewer' ;
    rdfs:comment 'Name or identifier of the sponsor medical monitor or physician who reviewed and assessed the adverse event record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Free-text medical narrative describing the adverse event, its clinical course, management, and outcome. Used in ICSR submissions and clinical study reports (CSR).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onsetDate rdf:type rdf:Property ;
    rdfs:label 'Onset Date' ;
    rdfs:comment 'The date on which the adverse event first began or was first observed by the subject or investigator. Principal real-world event date for the AE lifecycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The final or current clinical outcome of the adverse event as assessed by the investigator. Used in ICSR generation and aggregate safety reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rechallengeResult rdf:type rdf:Property ;
    rdfs:label 'Rechallenge Result' ;
    rdfs:comment 'Result of re-administering the investigational product after the adverse event resolved, to assess causality. Positive rechallenge strengthens causal relationship.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date on which the adverse event resolved or returned to baseline. Null if the event is ongoing at the time of data cut.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saeCriteria rdf:type rdf:Property ;
    rdfs:label 'Sae Criteria' ;
    rdfs:comment 'The specific ICH E2A seriousness criterion or criteria met by this SAE (e.g., Death, Life-threatening, Hospitalization required, Persistent disability, Congenital anomaly, Medically significant). Multiple criteria may apply. [ENUM-REF-CANDIDATE: Death|Life-threatening|Hospitalization required|Persistent disability|Congenital anomaly|Medically significant|Other — promote to reference product]' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorAwareDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Aware Date' ;
    rdfs:comment 'The date on which the sponsor first became aware of the serious adverse event. Starts the regulatory reporting clock for SAE/SUSAR expedited reporting to health authorities.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentGiven rdf:type rdf:Property ;
    rdfs:label 'Treatment Given' ;
    rdfs:comment 'Indicates whether concomitant medication or other treatment was administered to manage or treat the adverse event.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trialConsentId rdf:type rdf:Property ;
    rdfs:label 'Trial Consent Id' ;
    rdfs:comment 'Unique surrogate identifier for each informed consent event record in the clinical trial. Primary key for the trial_consent data product.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigatorId rdf:type rdf:Property ;
    rdfs:label 'Investigator Id' ;
    rdfs:comment 'Reference to the Principal Investigator (PI) or sub-investigator who conducted the informed consent discussion and signed the consent form. Links to the investigator master record in the CTMS.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:privacyObligationId rdf:type rdf:Property ;
    rdfs:label 'Privacy Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_obligation. Business justification: Informed consent fulfills specific privacy obligations under GDPR (lawful basis for processing), HIPAA (authorization), and local regulations. Links consent management to regulatory privacy compliance' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyObligation .

ind:witnessEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Witness Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: When consent witness is an internal employee (e.g., study coordinator), regulatory requirements mandate documented identity and qualification. Replaces text field \'witness_name\' with FK for GxP tracea' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the subject (or LAR) signed and dated the informed consent form, confirming voluntary agreement to participate in the trial. This is the principal business event date for the consent transaction.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentFormVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Form Version' ;
    rdfs:comment 'Version identifier of the Informed Consent Form (ICF) used for this consent event, as approved by the Institutional Review Board (IRB) or Independent Ethics Committee (IEC). Critical for regulatory traceability when protocol amendments trigger re-consent.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) of the language in which the ICF was presented and signed by the subject, ensuring the subject received information in their native language per GCP requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this consent event, used for regulatory traceability and audit purposes. Typically generated by the CTMS or EDC system (e.g., Medidata Rave or Oracle Clinical).' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle state of the consent record. \'Active\' indicates valid consent in force; \'withdrawn\' indicates subject has revoked consent; \'superseded\' indicates replaced by a newer consent version; \'pending\' indicates awaiting subject signature; \'expired\' indicates consent period has lapsed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Precise date and time at which the consent was electronically captured or recorded in the EDC/CTMS system (e.g., Medidata Rave), supporting 21 CFR Part 11 electronic records compliance.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Classification of the consent event: initial consent at enrollment, re-consent triggered by protocol amendment, assent from a minor subject, consent by a Legally Authorized Representative (LAR), or withdrawal of consent.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:econsentPlatform rdf:type rdf:Property ;
    rdfs:label 'Econsent Platform' ;
    rdfs:comment 'Name or identifier of the eConsent platform used to capture electronic consent (e.g., Medidata Rave eConsent, Veeva Vault). Populated only when electronic_consent is True.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicConsent rdf:type rdf:Property ;
    rdfs:label 'Electronic Consent' ;
    rdfs:comment 'Indicates whether the consent was obtained via an electronic consent (eConsent) platform rather than a traditional paper-based process. Relevant for 21 CFR Part 11 compliance and audit trail requirements.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorSigned rdf:type rdf:Property ;
    rdfs:label 'Investigator Signed' ;
    rdfs:comment 'Indicates whether the Principal Investigator (PI) or delegated sub-investigator has signed the informed consent form, confirming the consent discussion was conducted per GCP requirements.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Date' ;
    rdfs:comment 'Date on which the IRB or IEC approved the ICF version referenced in this consent event. Consent must not be obtained prior to this date to maintain GCP compliance.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ittFlag rdf:type rdf:Property ;
    rdfs:label 'Itt Flag' ;
    rdfs:comment 'Indicates whether the subject is included in the Intent-to-Treat (ITT) analysis population. Subjects who consented and received at least one dose of investigational product are typically included in the ITT population.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:larName rdf:type rdf:Property ;
    rdfs:label 'Lar Name' ;
    rdfs:comment 'Full legal name of the Legally Authorized Representative (LAR) who provided consent on behalf of the subject. Populated only when lar_required is True.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:larRelationship rdf:type rdf:Property ;
    rdfs:label 'Lar Relationship' ;
    rdfs:comment 'Relationship of the Legally Authorized Representative (LAR) to the trial subject (e.g., parent, legal guardian, spouse). Required when lar_required is True to establish legal authority to consent.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:larRequired rdf:type rdf:Property ;
    rdfs:label 'Lar Required' ;
    rdfs:comment 'Indicates whether a Legally Authorized Representative (LAR) was required to provide consent on behalf of the subject, applicable for minors, cognitively impaired subjects, or other legally incapacitated individuals.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:larSigned rdf:type rdf:Property ;
    rdfs:label 'Lar Signed' ;
    rdfs:comment 'Indicates whether the Legally Authorized Representative (LAR) has signed and dated the informed consent form. Applicable only when lar_required is True.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionalConsentBiobank rdf:type rdf:Property ;
    rdfs:label 'Optional Consent Biobank' ;
    rdfs:comment 'Indicates whether the subject provided optional consent for long-term storage and future use of biological samples in a biobank. This is a separate optional consent element from the main trial consent.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionalConsentGenetic rdf:type rdf:Property ;
    rdfs:label 'Optional Consent Genetic' ;
    rdfs:comment 'Indicates whether the subject provided optional consent for genetic or genomic research using their biological samples. Separate from the main trial consent and biobank consent.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconsentDate rdf:type rdf:Property ;
    rdfs:label 'Reconsent Date' ;
    rdfs:comment 'Date on which the subject provided re-consent following a protocol amendment or updated ICF version. Null if no re-consent has been required for this subject.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconsentReason rdf:type rdf:Property ;
    rdfs:label 'Reconsent Reason' ;
    rdfs:comment 'Reason that triggered the re-consent requirement, such as a protocol amendment, new safety information identified during the trial, or a regulatory authority request. Null if no re-consent was required.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentLocation rdf:type rdf:Property ;
    rdfs:label 'Source Document Location' ;
    rdfs:comment 'Location reference for the original signed consent form source document, such as the eTMF folder path in Veeva Vault or physical file location at the investigational site. Supports GCP source data verification (SDV) and audit trail requirements.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectSigned rdf:type rdf:Property ;
    rdfs:label 'Subject Signed' ;
    rdfs:comment 'Indicates whether the subject has personally signed and dated the informed consent form. False if consent was provided solely by a Legally Authorized Representative (LAR) without subject co-signature.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:witnessRequired rdf:type rdf:Property ;
    rdfs:label 'Witness Required' ;
    rdfs:comment 'Indicates whether an impartial witness was required to be present during the consent process, applicable when the subject or LAR is unable to read or when a short-form consent is used.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trialEndpointId rdf:type rdf:Property ;
    rdfs:label 'Trial Endpoint Id' ;
    rdfs:comment 'Unique surrogate identifier for each trial endpoint assessment record in the clinical lakehouse silver layer.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceGapId rdf:type rdf:Property ;
    rdfs:label 'Evidence Gap Id' ;
    rdfs:comment 'Foreign key linking to medical.evidence_gap. Business justification: Trial endpoints are designed to address specific evidence gaps identified in medical affairs planning for regulatory approval, payer negotiations, and clinical guideline inclusion. Evidence gap analys' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvidenceGap .

ind:marketHeorStudyId rdf:type rdf:Property ;
    rdfs:label 'Market Heor Study Id' ;
    rdfs:comment 'Foreign key linking to market.heor_study. Business justification: Clinical endpoint data (response rates, survival, QoL) feeds HEOR economic models for QALY calculations and ICER modeling. HEOR studies reference specific trial endpoint results for cost-effectiveness' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketHeorStudy .

ind:adjudicationDate rdf:type rdf:Property ;
    rdfs:label 'Adjudication Date' ;
    rdfs:comment 'Date on which the independent adjudication committee completed its review and issued a final determination for this endpoint assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjudicationRequired rdf:type rdf:Property ;
    rdfs:label 'Adjudication Required' ;
    rdfs:comment 'Indicates whether this endpoint assessment requires review by an independent adjudication committee (e.g., BICR, DSMB, IRC) due to discordance between investigator and central read, or per protocol mandate.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjudicationResult rdf:type rdf:Property ;
    rdfs:label 'Adjudication Result' ;
    rdfs:comment 'Final response category or concordance determination issued by the independent adjudication committee after review. Overrides investigator assessment when discordant, per protocol rules. [ENUM-REF-CANDIDATE: CR|PR|SD|PD|NE|concordant|discordant — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjudicationStatus rdf:type rdf:Property ;
    rdfs:label 'Adjudication Status' ;
    rdfs:comment 'Current status of the independent adjudication committee review for this endpoint assessment. Tracks workflow from pending through completed adjudication, supporting BICR and IRC processes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Calendar date on which the endpoint assessment was performed. This is the principal real-world event date for the endpoint record, distinct from data entry or audit timestamps.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Standardized methodology used to evaluate the endpoint (e.g., RECIST 1.1 for solid tumor response, iRECIST for immunotherapy, BICR for blinded independent central review, RANO for CNS tumors). Critical for regulatory submission credibility. [ENUM-REF-CANDIDATE: RECIST_1.1|iRECIST|BICR|investigator|RANO|mRECIST|PCWG3|Cheson|IWG — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current workflow status of the endpoint assessment record: planned (scheduled but not yet performed), completed (data captured and verified), missed (visit occurred but assessment not done), not_done (subject not available), or invalid (data quality issue).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'Baseline measurement value for the endpoint at study entry (e.g., sum of longest diameters at baseline for RECIST). Used to calculate percent change from baseline and determine response categories.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bestOverallResponse rdf:type rdf:Property ;
    rdfs:label 'Best Overall Response' ;
    rdfs:comment 'Best overall response achieved by the subject across all assessment timepoints up to and including this assessment, per RECIST or applicable criteria. Used in ORR and DOR calculations for regulatory submissions.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:censoringReason rdf:type rdf:Property ;
    rdfs:label 'Censoring Reason' ;
    rdfs:comment 'Reason for censoring a subject in time-to-event analyses when the endpoint event has not occurred (e.g., lost to follow-up, withdrawal of consent, initiation of new anticancer therapy, end of study). Required for regulatory-grade survival analyses. [ENUM-REF-CANDIDATE: lost_to_followup|withdrawal|new_anticancer_therapy|end_of_study|administrative|death_other_cause — promote to reference product]' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedResponse rdf:type rdf:Property ;
    rdfs:label 'Confirmed Response' ;
    rdfs:comment 'Indicates whether the response (CR or PR) has been confirmed by a subsequent assessment at least 4 weeks later, as required by RECIST 1.1 for ORR determination in regulatory submissions.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endpointCategory rdf:type rdf:Property ;
    rdfs:label 'Endpoint Category' ;
    rdfs:comment 'Classification of the endpoint as primary, secondary, exploratory, or safety per the study protocol. Primary endpoints drive the primary efficacy analysis for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointCode rdf:type rdf:Property ;
    rdfs:label 'Endpoint Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the endpoint definition within the study (e.g., EP001, PFS_PRIMARY). Sourced from the study protocol and EDC configuration in Medidata Rave.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointName rdf:type rdf:Property ;
    rdfs:label 'Endpoint Name' ;
    rdfs:comment 'Full descriptive name of the clinical endpoint being assessed (e.g., Objective Response Rate, Progression-Free Survival, Overall Survival, Duration of Response, Quality of Life). Aligns with protocol-defined endpoint nomenclature.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointType rdf:type rdf:Property ;
    rdfs:label 'Endpoint Type' ;
    rdfs:comment 'Functional type of the endpoint indicating the nature of the measurement: efficacy (ORR, PFS, OS), safety (AE rate), pharmacokinetic (PK), pharmacodynamic (PD), biomarker, or patient-reported outcome (PRO/QoL). [ENUM-REF-CANDIDATE: efficacy|safety|pharmacokinetic|pharmacodynamic|biomarker|patient_reported|composite — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluableFlag rdf:type rdf:Property ;
    rdfs:label 'Evaluable Flag' ;
    rdfs:comment 'Indicates whether the subject is considered evaluable for this specific endpoint at this timepoint, based on protocol-defined evaluability criteria (e.g., minimum number of prior assessments, no major protocol deviations).' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Date on which the endpoint event (progression, death, response) occurred. For censored subjects, this is the last known event-free date. Used in time-to-event analyses for PFS and OS.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventOccurred rdf:type rdf:Property ;
    rdfs:label 'Event Occurred' ;
    rdfs:comment 'Indicates whether the endpoint event (e.g., disease progression, death) has occurred for time-to-event endpoints such as PFS and OS. False indicates censoring. Critical for Kaplan-Meier and Cox regression analyses.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nadirValue rdf:type rdf:Property ;
    rdfs:label 'Nadir Value' ;
    rdfs:comment 'Lowest (nadir) measurement value recorded for the subject across all prior assessments. Used in RECIST PD determination (≥20% increase from nadir) and DOR calculations.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentChangeFromBaseline rdf:type rdf:Property ;
    rdfs:label 'Percent Change From Baseline' ;
    rdfs:comment 'Percentage change in the endpoint measurement from the baseline value to the current assessment value. Directly used in waterfall plots and response determination per RECIST criteria.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppFlag rdf:type rdf:Property ;
    rdfs:label 'Pp Flag' ;
    rdfs:comment 'Indicates whether this subject\'s endpoint assessment is included in the Per Protocol (PP) analysis population, used as a sensitivity analysis alongside ITT in regulatory submissions.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queryOpen rdf:type rdf:Property ;
    rdfs:label 'Query Open' ;
    rdfs:comment 'Indicates whether there is an open data query (discrepancy) raised against this endpoint record in the EDC system (Medidata Rave). Open queries must be resolved before database lock.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseCategory rdf:type rdf:Property ;
    rdfs:label 'Response Category' ;
    rdfs:comment 'Categorical tumor response classification per the applicable assessment criteria: Complete Response (CR), Partial Response (PR), Stable Disease (SD), Progressive Disease (PD), or Not Evaluable (NE). Directly feeds ORR calculation for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultUnit rdf:type rdf:Property ;
    rdfs:label 'Result Unit' ;
    rdfs:comment 'Unit of measurement for the numeric result value (e.g., mm, months, days, percent, score). Follows CDISC controlled terminology for units.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToEventDays rdf:type rdf:Property ;
    rdfs:label 'Time To Event Days' ;
    rdfs:comment 'Duration in days from the study reference date (e.g., randomization date) to the endpoint event or censoring date. Used directly in PFS, OS, and DOR analyses for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trialMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Trial Milestone Id' ;
    rdfs:comment 'Unique surrogate identifier for each trial milestone record in the clinical trial management system. Primary key for the trial_milestone data product.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ctmsMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Ctms Milestone Id' ;
    rdfs:comment 'The native milestone identifier from the source Oracle Clinical / Siebel CTMS system. Preserved for traceability and reconciliation between the lakehouse silver layer and the operational CTMS source of record.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:milestonePaymentId rdf:type rdf:Property ;
    rdfs:label 'Milestone Payment Id' ;
    rdfs:comment 'Foreign key linking to finance.milestone_payment. Business justification: Clinical milestones (FPFV, LPLV, database lock, CSR completion) trigger contractual payments to CROs, sites, or licensing partners. Direct business process linking clinical achievement to financial ob' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MilestonePayment .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_order. Business justification: Clinical milestones (FPFV, enrollment targets, database lock) trigger and constrain clinical supply production orders. Essential for supply forecasting, campaign planning, manufacturing slot allocatio' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:responsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Trial milestones require named accountable owners for project management and regulatory commitment tracking. Current text field \'responsible_owner\' should be normalized to employee FK for workforce pl' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The confirmed date on which the milestone was achieved. Populated only upon milestone completion. Used to calculate variance against planned_date and to update regulatory commitment trackers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the milestone completion or date change was formally approved. Supports electronic audit trail requirements under 21 CFR Part 11 and GCP inspection readiness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionEvidenceType rdf:type rdf:Property ;
    rdfs:label 'Completion Evidence Type' ;
    rdfs:comment 'Type of documentation used to confirm milestone completion (e.g., signed memo, system-generated log from Medidata Rave, regulatory authority letter, DSMB report). Required for GCP inspection readiness and audit trail completeness.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:databaseLockType rdf:type rdf:Property ;
    rdfs:label 'Database Lock Type' ;
    rdfs:comment 'Specifies the type of database lock associated with this milestone, where applicable: interim (for interim analysis), final (for primary analysis), or partial (for a subset of sites or data). Populated only for database lock milestones. Supports data management planning.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'The current best estimate of when the milestone will be achieved, updated dynamically as the trial progresses. Distinct from planned_date (baseline) and actual_date (confirmed completion). Supports rolling forecast and portfolio timeline management.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthAuthority rdf:type rdf:Property ;
    rdfs:label 'Health Authority' ;
    rdfs:comment 'The regulatory health authority to which this milestone is committed or reported (e.g., FDA, EMA, MHRA, PMDA, NMPA). Relevant when is_regulatory_commitment is True. Supports multi-regional regulatory commitment tracking. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Number' ;
    rdfs:comment 'Sequential number identifying which interim analysis this milestone represents (e.g., 1 for IA1, 2 for IA2). Populated only when is_interim_analysis is True. Supports tracking of multiple pre-specified interim analyses within a single trial.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Indicates whether this milestone lies on the critical path of the clinical trial project plan. Critical path milestones directly impact the overall trial completion date and receive elevated monitoring priority in portfolio management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInterimAnalysis rdf:type rdf:Property ;
    rdfs:label 'Is Interim Analysis' ;
    rdfs:comment 'Indicates whether this milestone represents an interim analysis event (e.g., a pre-specified interim efficacy or futility analysis). When True, additional blinding and DSMB (Data Safety Monitoring Board) governance controls apply.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryCommitment rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Commitment' ;
    rdfs:comment 'Indicates whether this milestone represents a formal commitment made to a health authority (e.g., FDA, EMA, PMDA) as part of an approval condition, post-approval commitment, or REMS requirement. When True, triggers mandatory regulatory commitment tracking workflows.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Category' ;
    rdfs:comment 'Indicates whether the milestone is a planned internal target, a contractual obligation (e.g., with a CRO/CMO), a regulatory commitment (e.g., FDA/EMA post-approval commitment), or an internal management checkpoint. Drives escalation and governance workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the milestone type within the organization\'s CTMS (e.g., FPFV, LPLV, DBL, CSR, IND_SUB). Used for cross-trial portfolio reporting and regulatory commitment tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Full descriptive name of the clinical trial milestone (e.g., \'First Patient First Visit\', \'Last Patient Last Visit\', \'Database Lock\', \'Clinical Study Report Completion\', \'Regulatory Submission\'). Human-readable label used in portfolio dashboards and regulatory commitment trackers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneSequence rdf:type rdf:Property ;
    rdfs:label 'Milestone Sequence' ;
    rdfs:comment 'Integer defining the chronological order of this milestone within the trial\'s project plan. Used to enforce milestone sequencing logic, detect out-of-order completions, and render Gantt-style timeline visualizations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current operational status of the milestone in its lifecycle. \'at_risk\' indicates the milestone is projected to miss its planned date. \'delayed\' indicates the actual date has passed the planned date without completion. Used for portfolio-level trial timeline management and escalation triggers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Categorical classification of the milestone by functional area: enrollment (patient-facing), data_management (EDC/database activities), analysis (statistical/interim), regulatory (submission-related), safety (DSMB/safety review), or operational (site/logistics). Supports portfolio-level filtering and reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether stakeholder notifications (e.g., to regulatory affairs, clinical operations leadership, CRO partners) have been dispatched upon milestone completion or delay detection. Supports automated workflow orchestration.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'The originally baselined target date for achieving this milestone, as defined in the clinical trial protocol or project plan. Used as the reference point for variance calculation and regulatory commitment tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:predecessorMilestoneCode rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Code' ;
    rdfs:comment 'The milestone_code of the immediately preceding milestone that must be completed before this milestone can begin. Enables dependency-aware critical path analysis and automated scheduling in the CTMS.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region associated with this milestone for regional portfolio reporting and regulatory tracking. Used when a milestone applies to a specific region rather than a single country or globally.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleFunction rdf:type rdf:Property ;
    rdfs:label 'Responsible Function' ;
    rdfs:comment 'The organizational function or department accountable for achieving this milestone (e.g., Clinical Operations, Data Management, Biostatistics, Regulatory Affairs). Used for workload planning and accountability tracking. [ENUM-REF-CANDIDATE: clinical_operations|data_management|biostatistics|regulatory_affairs|medical_affairs|pharmacovigilance|cro|cmdo|quality — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceCommentary rdf:type rdf:Property ;
    rdfs:label 'Variance Commentary' ;
    rdfs:comment 'Free-text narrative explaining the reason for any deviation between planned and actual/forecast milestone dates. Captures context not covered by variance_reason_code, including mitigation actions taken. Required for regulatory commitment reporting to FDA/EMA.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Signed integer representing the difference in calendar days between the actual (or forecast) date and the planned date. Positive values indicate delay; negative values indicate early completion. Stored as a business field to support regulatory commitment reporting without requiring runtime calculation.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standardized code categorizing the root cause of any milestone variance. Used for portfolio-level trend analysis and process improvement. [ENUM-REF-CANDIDATE: site_activation_delay|enrollment_shortfall|protocol_amendment|regulatory_hold|safety_event|data_quality|resource_constraint|vendor_delay|other — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Ae Reported Flag' ;
    rdfs:comment 'Indicates whether one or more Adverse Events (AEs) were reported at or since the previous visit (True) or not (False). Triggers downstream pharmacovigilance workflows in Argus Safety / Oracle AERS.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:armName rdf:type rdf:Property ;
    rdfs:label 'Arm Name' ;
    rdfs:comment 'The name of the treatment arm or study arm to which the subject was assigned at the time of this visit (e.g., \'Drug A 100mg\', \'Placebo\', \'Drug A + Drug B Combination\'). Sourced from CTMS and EDC randomization records.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPct rdf:type rdf:Property ;
    rdfs:label 'Completion Pct' ;
    rdfs:comment 'The percentage of protocol-required assessments and procedures that were completed at this visit (0.00–100.00). Supports partial visit analysis and data completeness reporting for regulatory submissions.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conmedUpdatedFlag rdf:type rdf:Property ;
    rdfs:label 'Conmed Updated Flag' ;
    rdfs:comment 'Indicates whether the subject\'s concomitant medication list was reviewed and updated at this visit (True) or not (False). Supports safety and drug-drug interaction analysis.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Entry Timestamp' ;
    rdfs:comment 'The date and time when the visit data was first entered into the EDC system (Medidata Rave) by the site staff. Supports audit trail requirements under 21 CFR Part 11 and ICH E6(R2).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataLockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Lock Timestamp' ;
    rdfs:comment 'The date and time when the visit record was locked in the EDC (Medidata Rave), preventing further data entry or modification without an authorized unlock. Null if the record has not yet been locked.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dayFromReference rdf:type rdf:Property ;
    rdfs:label 'Day From Reference' ;
    rdfs:comment 'The study day number calculated from the subject\'s reference date (typically first dose date or randomization date) to the actual visit date. Corresponds to the CDISC VISITDY variable. Negative values indicate pre-dose visits.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationCategory rdf:type rdf:Property ;
    rdfs:label 'Deviation Category' ;
    rdfs:comment 'Classification of the protocol deviation severity at this visit: major (could affect subject safety or data integrity), minor (unlikely to affect safety or data integrity), or administrative (procedural/documentation only).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Indicates whether one or more protocol deviations were recorded for this visit (True) or not (False). A True value triggers linkage to the protocol deviation register in the CTMS or eTMF (Veeva Vault).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationReason rdf:type rdf:Property ;
    rdfs:label 'Early Termination Reason' ;
    rdfs:comment 'The reason the subject discontinued the study at or before this visit, if applicable. Null for non-termination visits. [ENUM-REF-CANDIDATE: adverse_event|withdrawal_of_consent|lost_to_follow_up|protocol_violation|sponsor_decision|death|other — promote to reference product]' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcVisitOid rdf:type rdf:Property ;
    rdfs:label 'Edc Visit Oid' ;
    rdfs:comment 'The unique object identifier (OID) assigned to this visit record within the Medidata Rave EDC system. Used for traceability and reconciliation between the Silver Layer and the source EDC system.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epoch rdf:type rdf:Property ;
    rdfs:label 'Epoch' ;
    rdfs:comment 'The trial epoch during which this visit occurred, as defined in the CDISC SDTM Trial Design model (e.g., Screening, Run-In, Treatment, Follow-Up, Post-Study). Supports epoch-level analysis.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Verified' ;
    rdfs:comment 'Indicates whether the subject\'s current informed consent form (ICF) was verified as valid and current at the time of this visit (True) or not (False). Critical for GCP compliance and regulatory inspection readiness.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queryOpenCount rdf:type rdf:Property ;
    rdfs:label 'Query Open Count' ;
    rdfs:comment 'The number of data queries (discrepancies) currently open against this visit record in the EDC (Medidata Rave). A non-zero value indicates outstanding data cleaning actions required before database lock.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:randomizationNumber rdf:type rdf:Property ;
    rdfs:label 'Randomization Number' ;
    rdfs:comment 'The unique randomization number assigned to the subject at the time of randomization, as recorded in the Interactive Response Technology (IRT) system. Confidential as it may reveal treatment assignment in blinded trials.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saeReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Sae Reported Flag' ;
    rdfs:comment 'Indicates whether one or more Serious Adverse Events (SAEs) were reported at this visit (True) or not (False). SAEs require expedited reporting to health authorities per ICH E2A and 21 CFR Part 312.32.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Source Verified Flag' ;
    rdfs:comment 'Indicates whether Source Data Verification (SDV) has been completed for this visit by the Clinical Research Associate (CRA) or monitor (True) or not (False). Critical for GCP compliance and regulatory inspection readiness.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitName rdf:type rdf:Property ;
    rdfs:label 'Visit Name' ;
    rdfs:comment 'Human-readable label for the visit as defined in the protocol Schedule of Assessments (e.g., \'Screening\', \'Cycle 1 Day 1\', \'Week 12 Follow-Up\', \'End of Study\'). Sourced from Medidata Rave EDC visit folder name.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitNumber rdf:type rdf:Property ;
    rdfs:label 'Visit Number' ;
    rdfs:comment 'Sequential numeric identifier for the visit as defined in the protocol Schedule of Assessments (SoA). Unscheduled visits may carry a non-integer or supplemental numbering convention captured separately.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitStatus rdf:type rdf:Property ;
    rdfs:label 'Visit Status' ;
    rdfs:comment 'Current lifecycle status of the visit record indicating whether the visit was completed, missed, partially completed, cancelled, or rescheduled. Sourced from Medidata Rave EDC and CTMS.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitType rdf:type rdf:Property ;
    rdfs:label 'Visit Type' ;
    rdfs:comment 'Classification of the visit according to its role in the trial timeline. [ENUM-REF-CANDIDATE: screening|baseline|treatment|follow_up|end_of_study|unscheduled|early_termination — promote to reference product]' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowLowerDay rdf:type rdf:Property ;
    rdfs:label 'Window Lower Day' ;
    rdfs:comment 'The number of days before the planned visit date that defines the lower boundary of the acceptable visit window per the protocol. Used to assess visit window compliance.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowUpperDay rdf:type rdf:Property ;
    rdfs:label 'Window Upper Day' ;
    rdfs:comment 'The number of days after the planned visit date that defines the upper boundary of the acceptable visit window per the protocol. Used to assess visit window compliance.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withinWindowFlag rdf:type rdf:Property ;
    rdfs:label 'Within Window Flag' ;
    rdfs:comment 'Indicates whether the actual visit date fell within the protocol-defined visit window (True) or outside it (False). Derived at ingestion from planned_date, actual_date, window_lower_day, and window_upper_day; stored for analytical efficiency.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Brand-level budgets track promotional spend, sample distribution, speaker programs. Core commercial finance control for brand P&L management and variance analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Brands are owned/marketed by specific legal entities. Required for financial consolidation, regulatory submissions (NDA/BLA ownership attribution), transfer pricing, P&L reporting by legal entity, and' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:masterdataAtcClassificationId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Atc Classification Id' ;
    rdfs:comment 'Foreign key linking to masterdata.atc_classification. Business justification: Brands map to ATC therapeutic classification. Essential for regulatory submissions, formulary positioning, market access dossiers, competitive intelligence, and HTA submissions requiring standardized ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtcClassification .

ind:masterdataNdcCodeId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Ndc Code Id' ;
    rdfs:comment 'Foreign key linking to masterdata.ndc_code. Business justification: Brands have associated NDC codes for US market identification. Required for distribution, pricing submissions to CMS, Medicaid rebate calculations, 340B program compliance, and chargeback processing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterdataNdcCode .

ind:patentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Patent Family Id' ;
    rdfs:comment 'Foreign key linking to intellectual.patent_family. Business justification: Brands are covered by patent families; portfolio management, global launch sequencing, and IP strategy require patent family linkage for comprehensive protection view.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentFamily .

ind:pricingDecisionId rdf:type rdf:Property ;
    rdfs:label 'Pricing Decision Id' ;
    rdfs:comment 'Foreign key linking to market.pricing_decision. Business justification: Pricing decisions set list prices (WAC) and net prices for brands by market. Fundamental commercial strategy linking brand to primary pricing decision for tracking price positioning and changes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingDecision .

ind:royaltyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Royalty Agreement Id' ;
    rdfs:comment 'Foreign key linking to finance.royalty_agreement. Business justification: Brands may be licensed-in products requiring royalty payments on net sales. Links brand revenue to royalty obligations for accurate gross-to-net and payment calculations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyAgreement .

ind:sourcingMaterialId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Material Id' ;
    rdfs:comment 'Foreign key linking to procurement.sourcing_material. Business justification: Brand manufacturing requires specific sourced APIs and excipients. Procurement teams source materials for brand-specific formulations. Links brand planning to material availability, lead times, and su' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingMaterial .

ind:trademarkId rdf:type rdf:Property ;
    rdfs:label 'Trademark Id' ;
    rdfs:comment 'Foreign key linking to intellectual.trademark. Business justification: Brand names are registered trademarks; legal protection, brand strategy, and market exclusivity depend on trademark registration. Core IP protection for commercial brands.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trademark .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the brand across commercial systems including Veeva CRM, SAP SD, and Salesforce Health Cloud. Used as the business key for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The proprietary trade name of the pharmaceutical product as approved by the regulatory authority (e.g., FDA, EMA) and used in commercial promotion, packaging, and market-facing communications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current operational status of the brand within the commercial organization. Controls whether the brand is eligible for promotional spend, sales force detailing, and market access activities.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Schedule' ;
    rdfs:comment 'The DEA controlled substance schedule classification for the brand, if applicable. Determines distribution controls, sample restrictions, and reporting obligations under the Controlled Substances Act. \'not_scheduled\' for non-controlled products.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalBrandOwner rdf:type rdf:Property ;
    rdfs:label 'Global Brand Owner' ;
    rdfs:comment 'The legal entity name of the global brand owner responsible for the NDA/BLA/MAA and global P&L accountability. Relevant for intercompany transfer pricing, royalty agreements, and IP ownership tracking.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalLaunchSequence rdf:type rdf:Property ;
    rdfs:label 'Global Launch Sequence' ;
    rdfs:comment 'Numeric sequence indicating the order in which this brand was launched globally relative to other brands in the portfolio. Used for portfolio prioritization, resource allocation, and launch excellence benchmarking.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFlagshipBrand rdf:type rdf:Property ;
    rdfs:label 'Is Flagship Brand' ;
    rdfs:comment 'Indicates whether this brand is designated as a flagship or priority brand by commercial leadership, warranting elevated promotional investment, dedicated sales force, and executive-level performance reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date on which the brand was first commercially available in its primary market following regulatory approval. Used as the anchor date for launch performance tracking, market share ramp analysis, and P&L reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage of the brand in its commercial lifecycle. Drives resource allocation, promotional investment levels, and strategic planning. Loss of exclusivity (LOE) stage triggers biosimilar/generic competition response planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossOfExclusivityDate rdf:type rdf:Property ;
    rdfs:label 'Loss Of Exclusivity Date' ;
    rdfs:comment 'The projected or confirmed date on which the brand\'s market exclusivity expires, enabling generic or biosimilar competition. Critical for long-range financial planning, patent strategy, and lifecycle management decisions.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orphanDrugDesignation rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Designation' ;
    rdfs:comment 'Indicates whether the brand has received Orphan Drug Designation from the FDA (ODD) or EMA (OMP), conferring 7-year US market exclusivity, 10-year EU exclusivity, and tax incentives. Affects pricing strategy and market access negotiations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Patent Expiry Date' ;
    rdfs:comment 'The expiry date of the primary composition-of-matter or method-of-use patent protecting the brand. Distinct from LOE date as patent term extensions (PTE) and data exclusivity may extend commercial protection beyond patent expiry.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plCostCenter rdf:type rdf:Property ;
    rdfs:label 'Pl Cost Center' ;
    rdfs:comment 'The SAP cost center code to which all brand-level revenues, promotional spend, and COGS are allocated for P&L reporting. Enables brand-level financial performance tracking and budget variance analysis.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCompetitorBrands rdf:type rdf:Property ;
    rdfs:label 'Primary Competitor Brands' ;
    rdfs:comment 'Comma-separated list of key competitor brand names in the same therapeutic class. Used for competitive intelligence, market share benchmarking, and sales force training. Classified as confidential competitive intelligence.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMarket rdf:type rdf:Property ;
    rdfs:label 'Primary Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the brand\'s primary commercial market (e.g., USA, GBR, DEU). Determines the lead regulatory authority, pricing reference, and commercial reporting currency.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'The SAP profit center assigned to the brand for internal management accounting and brand-level P&L reporting. Distinct from cost center; used for contribution margin analysis and brand portfolio performance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsRequired rdf:type rdf:Property ;
    rdfs:label 'Rems Required' ;
    rdfs:comment 'Indicates whether the FDA has mandated a Risk Evaluation and Mitigation Strategy (REMS) for this brand due to serious safety risks. REMS programs impose specific distribution, prescribing, and patient monitoring requirements that affect commercial operations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleEligible rdf:type rdf:Property ;
    rdfs:label 'Sample Eligible' ;
    rdfs:comment 'Indicates whether the brand is eligible for distribution of drug samples to healthcare professionals (HCPs) by the sales force. Controlled by PDMA regulations and PhRMA code. DEA scheduled products and REMS products may have restrictions.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Number' ;
    rdfs:comment 'The SAP material master number assigned to the brand\'s primary commercial SKU in SAP S/4HANA MM/SD modules. Used for order management, COGS tracking, and supply chain integration.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyStatement rdf:type rdf:Property ;
    rdfs:label 'Strategy Statement' ;
    rdfs:comment 'The overarching commercial strategy statement for the brand, capturing positioning, differentiation, and value proposition relative to competitors. Classified as confidential business strategy. Sourced from the brand plan approved by commercial leadership.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunshineActReportable rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Reportable' ;
    rdfs:comment 'Indicates whether transfers of value associated with this brand (samples, speaker fees, meals, educational grants) are subject to Open Payments (Sunshine Act) reporting to CMS. Drives compliance workflows in Veeva CRM and SAP.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetPatientPopulation rdf:type rdf:Property ;
    rdfs:label 'Target Patient Population' ;
    rdfs:comment 'Description of the intended patient population for the brand, including disease stage, biomarker status, prior treatment history, and demographic criteria. Informs HCP targeting, patient support program design, and HEOR value dossier development.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaCrmProductCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Product Code' ;
    rdfs:comment 'The product identifier assigned to this brand in Veeva CRM (Salesforce Health Cloud), used to link brand records to HCP call activity, sample transactions, promotional material approvals (PromoMats), and speaker program events.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandPlanId rdf:type rdf:Property ;
    rdfs:label 'Brand Plan Id' ;
    rdfs:comment 'Unique identifier for the brand plan. Primary key for the brand plan entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandPlan .

ind:congressEventId rdf:type rdf:Property ;
    rdfs:label 'Congress Event Id' ;
    rdfs:comment 'Foreign key linking to medical.congress_event. Business justification: Brand plans specify key congress participation strategy, booth presence, satellite symposia, and commercial messaging aligned with medical affairs scientific activities at same congress. Critical for ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CongressEvent .

ind:masterdataProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Profit Center Id' ;
    rdfs:comment 'Foreign key linking to masterdata.profit_center. Business justification: Brand plans drive profit center performance and revenue targets. Required for segment reporting, brand P&L, strategic portfolio management, and financial consolidation by therapeutic area or product l' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:planOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Plan Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Brand plan ownership tracking is essential for commercial planning accountability and approval workflows. Plan_owner currently stores text name; FK enables proper organizational hierarchy tracking and' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rdCapitalizationId rdf:type rdf:Property ;
    rdfs:label 'Rd Capitalization Id' ;
    rdfs:comment 'Foreign key linking to finance.rd_capitalization. Business justification: Brand plans for pre-launch products reference capitalized R&D costs that will be amortized post-launch. Required for launch economics and ROI analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RdCapitalization .

ind:brandPositioning rdf:type rdf:Property ;
    rdfs:label 'Brand Positioning' ;
    rdfs:comment 'The core brand positioning statement that defines how the brand is differentiated in the market and the value proposition communicated to Healthcare Professionals (HCPs) and patients.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for all financial amounts in this brand plan (e.g., \'USD\', \'EUR\', \'JPY\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStrategy rdf:type rdf:Property ;
    rdfs:label 'Channel Strategy' ;
    rdfs:comment 'The multi-channel engagement strategy defining how the brand will reach HCPs and patients through field force, digital channels, medical science liaisons, patient support programs, and market access initiatives.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveLandscape rdf:type rdf:Property ;
    rdfs:label 'Competitive Landscape' ;
    rdfs:comment 'Summary of the competitive environment, including key competitor brands, market share dynamics, and competitive threats or opportunities identified for the planning period.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geography rdf:type rdf:Property ;
    rdfs:label 'Geography' ;
    rdfs:comment 'The geographic market or region covered by this brand plan (e.g., \'USA\', \'EUR\', \'JPN\', \'Global\'). Uses ISO 3166-1 alpha-3 country codes or regional groupings.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'The date when the brand plan was last reviewed or updated. Brand plans are typically reviewed quarterly or semi-annually to assess progress and adjust tactics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:launchPhase rdf:type rdf:Property ;
    rdfs:label 'Launch Phase' ;
    rdfs:comment 'The current phase of the product launch lifecycle covered by this brand plan: pre-launch (preparation before regulatory approval), launch (initial market introduction), post-launch (ongoing commercialization), or not applicable (for established brands).' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketShareTarget rdf:type rdf:Property ;
    rdfs:label 'Market Share Target' ;
    rdfs:comment 'The target market share percentage (by volume or value) that the brand aims to achieve in its therapeutic category during the plan period. Expressed as a percentage (e.g., 25.50 for 25.5%).' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Unique business identifier or code for the brand plan used in financial and commercial systems (e.g., \'BP-2024-ONCX-US\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'The date when the brand plan period concludes. For annual plans, typically one year from start date. May be extended for multi-year plans.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'The official name or title of the brand plan, typically including brand name, year, and geography (e.g., \'Oncology Brand X US Commercial Plan 2024\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'The date when the brand plan becomes effective and execution begins. Typically aligns with fiscal year start or product launch date.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the brand plan: draft (in development), submitted (under review), approved (finalized and authorized), active (currently executing), on hold (temporarily suspended), or closed (completed or archived).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the brand plan by its strategic purpose: annual (standard yearly plan), multi-year (strategic multi-year roadmap), launch (new product launch plan), lifecycle management (mature product optimization), indication expansion (new therapeutic indication), or line extension (new formulation/strength).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'The fiscal or calendar year for which this brand plan is effective (e.g., 2024). For multi-year plans, this represents the start year.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescriptionVolumeTarget rdf:type rdf:Property ;
    rdfs:label 'Prescription Volume Target' ;
    rdfs:comment 'The target number of prescriptions (Total Prescriptions or TRx) or New-to-Brand (NTB) prescriptions the brand aims to generate during the plan period. Sourced from prescription data providers (e.g., IQVIA).' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalMixStrategy rdf:type rdf:Property ;
    rdfs:label 'Promotional Mix Strategy' ;
    rdfs:comment 'Description of the promotional mix strategy, including the balance and integration of personal promotion (field force), non-personal promotion (advertising, digital), medical education, congress participation, and speaker programs.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDependency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Dependency' ;
    rdfs:comment 'Description of any regulatory approval milestones or dependencies that impact the brand plan execution, such as pending New Drug Application (NDA), Biologics License Application (BLA), or Marketing Authorization Application (MAA) approvals, or supplemental indication approvals.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTarget rdf:type rdf:Property ;
    rdfs:label 'Revenue Target' ;
    rdfs:comment 'The target revenue or net sales goal for the brand during the plan period. Key Performance Indicator (KPI) for commercial success and P&L performance.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'The overarching strategic goal or objective for the brand during this plan period (e.g., \'Achieve market leadership in NSCLC\', \'Maximize peak sales before LOE\', \'Establish brand in rare disease segment\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetHcpSegment rdf:type rdf:Property ;
    rdfs:label 'Target Hcp Segment' ;
    rdfs:comment 'The primary Healthcare Professional (HCP) segment or specialty targeted by this brand plan (e.g., \'Oncologists\', \'Rheumatologists\', \'Primary Care Physicians\'). May include sub-segmentation by prescribing behavior or Key Opinion Leader (KOL) status.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callActivityId rdf:type rdf:Property ;
    rdfs:label 'Call Activity Id' ;
    rdfs:comment 'Unique surrogate identifier for each field force call activity record in the Databricks Silver layer. Primary key for the call_activity data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CallActivity .

ind:hcoMasterId rdf:type rdf:Property ;
    rdfs:label 'Hco Master Id' ;
    rdfs:comment 'Reference to the Healthcare Organization (HCO) where the call took place or which is the primary target when the call is at an institutional level. Nullable when the call is exclusively HCP-targeted.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HcoMaster .

ind:inquiryId rdf:type rdf:Property ;
    rdfs:label 'Inquiry Id' ;
    rdfs:comment 'Foreign key linking to medical.medical_inquiry. Business justification: Commercial sales calls frequently trigger medical information requests that must be routed to medical affairs for compliant response. Direct operational handoff tracked for regulatory compliance and o' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inquiry .

ind:marketFormularyPositionId rdf:type rdf:Property ;
    rdfs:label 'Market Formulary Position Id' ;
    rdfs:comment 'Foreign key linking to market.formulary_position. Business justification: Call activities capture HCP feedback on formulary access barriers (PA, step therapy). Field intelligence gathering process links call records to formulary positions for tracking access issues and info' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketFormularyPosition .

ind:promoMaterialId rdf:type rdf:Property ;
    rdfs:label 'Promo Material Id' ;
    rdfs:comment 'Reference to the primary promotional material (detail aid, leave-behind, or digital asset) presented during the call, as approved in Veeva PromoMats. Supports promotional compliance auditing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoMaterial .

ind:salesRepId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Id' ;
    rdfs:comment 'Reference to the field sales representative (Medical Science Liaison, Sales Rep, or Key Account Manager) who conducted the call.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesRep .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Reference to the sales territory in which this call activity occurred. Used for field force effectiveness measurement and territory performance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'The calendar date on which the field force interaction (detail call) took place. Principal business event date used for field force effectiveness reporting and Sunshine Act transparency reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call End Timestamp' ;
    rdfs:comment 'Precise date and time when the call interaction concluded, as recorded in Veeva CRM. Used together with call_start_timestamp to derive call duration for field force effectiveness analytics.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callNotes rdf:type rdf:Property ;
    rdfs:label 'Call Notes' ;
    rdfs:comment 'Free-text narrative entered by the sales representative summarizing the content and outcome of the interaction. Classified as confidential due to potential inclusion of commercially sensitive HCP engagement details.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callObjective rdf:type rdf:Property ;
    rdfs:label 'Call Objective' ;
    rdfs:comment 'Pre-call stated objective or purpose of the interaction as entered by the sales representative in Veeva CRM. Supports pre-call planning analytics and coaching.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callOutcome rdf:type rdf:Property ;
    rdfs:label 'Call Outcome' ;
    rdfs:comment 'Result of the call attempt as recorded by the sales representative. \'No_see\' indicates the HCP was unavailable. Used for field force effectiveness and access rate analytics.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Start Timestamp' ;
    rdfs:comment 'Precise date and time when the call interaction began, as recorded in Veeva CRM. Used for call duration calculation and scheduling compliance.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callStatus rdf:type rdf:Property ;
    rdfs:label 'Call Status' ;
    rdfs:comment 'Current lifecycle state of the call activity record within Veeva CRM workflow. \'Submitted\' indicates the rep has locked the record; \'Approved\' indicates manager sign-off has been completed.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callType rdf:type rdf:Property ;
    rdfs:label 'Call Type' ;
    rdfs:comment 'Classification of the interaction channel used for the detail call. Drives field force effectiveness segmentation and PhRMA code compliance checks. [ENUM-REF-CANDIDATE: face_to_face|remote_video|phone|email|congress|group_meeting|medical_education_event — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMixCode rdf:type rdf:Property ;
    rdfs:label 'Channel Mix Code' ;
    rdfs:comment 'Categorizes the call within the omnichannel engagement model (field, inside sales, digital, or hybrid). Supports channel mix optimization analytics and commercial strategy reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Crm Sync Timestamp' ;
    rdfs:comment 'Timestamp when the call record was last synchronized from Veeva CRM into the Databricks Silver layer. Used for data freshness monitoring and pipeline audit.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detailPriority1Product rdf:type rdf:Property ;
    rdfs:label 'Detail Priority 1 Product' ;
    rdfs:comment 'Brand name of the first-priority product detailed during the call, as recorded in Veeva CRM. Retained as a denormalized field for reporting convenience and Sunshine Act submission.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detailPriority2Product rdf:type rdf:Property ;
    rdfs:label 'Detail Priority 2 Product' ;
    rdfs:comment 'Brand name of the second-priority product detailed during the call, if applicable. Supports multi-product detailing analysis and share-of-voice reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detailPriority3Product rdf:type rdf:Property ;
    rdfs:label 'Detail Priority 3 Product' ;
    rdfs:comment 'Brand name of the third-priority product detailed during the call, if applicable. Supports multi-product detailing analysis and share-of-voice reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpReaction rdf:type rdf:Property ;
    rdfs:label 'Hcp Reaction' ;
    rdfs:comment 'Sales representative\'s assessment of the Healthcare Professional\'s reaction to the product detail during the call. Used for HCP engagement scoring and brand sentiment analytics.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolFlag rdf:type rdf:Property ;
    rdfs:label 'Kol Flag' ;
    rdfs:comment 'Indicates whether the HCP visited during this call is classified as a Key Opinion Leader (KOL). Used for KOL engagement tracking and Medical Affairs coordination.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealCostUsd rdf:type rdf:Property ;
    rdfs:label 'Meal Cost Usd' ;
    rdfs:comment 'Actual cost in US dollars of the meal or refreshment provided during the call. Used for PhRMA Code per-person meal cap compliance monitoring and Sunshine Act reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Provided Flag' ;
    rdfs:comment 'Indicates whether a meal or refreshment was provided to the HCP or HCO staff during this call. Required for PhRMA Code compliance and Sunshine Act transfer-of-value reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextBestAction rdf:type rdf:Property ;
    rdfs:label 'Next Best Action' ;
    rdfs:comment 'Recommended follow-up action for the sales representative as determined by the CRM system or rep input (e.g., schedule follow-up call, send clinical reprint, invite to speaker program). Supports field force coaching and CRM-driven engagement planning.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offLabelDiscussionFlag rdf:type rdf:Property ;
    rdfs:label 'Off Label Discussion Flag' ;
    rdfs:comment 'Indicates whether any off-label (unapproved indication) discussion occurred during the call. Classified as confidential due to regulatory sensitivity. Triggers compliance review workflow when True.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phrmaCodeCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Phrma Code Compliant Flag' ;
    rdfs:comment 'Indicates whether the call activity was conducted in full compliance with the PhRMA Code on Interactions with Healthcare Professionals. Used for internal compliance monitoring and audit reporting.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promoMaterialVersion rdf:type rdf:Property ;
    rdfs:label 'Promo Material Version' ;
    rdfs:comment 'Version identifier of the promotional material presented during the call, as tracked in Veeva PromoMats. Ensures only current, approved versions are used in the field.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleLotNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Lot Number' ;
    rdfs:comment 'Manufacturing lot number of the drug samples distributed during the call. Required for PDMA sample accountability and product recall traceability.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Total number of drug sample units distributed to the HCP during this call. Used for PDMA sample accountability reconciliation and Sunshine Act transfer-of-value reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplesDroppedFlag rdf:type rdf:Property ;
    rdfs:label 'Samples Dropped Flag' ;
    rdfs:comment 'Indicates whether drug samples were distributed to the HCP during this call. Drives sample accountability reporting and Prescription Drug Marketing Act (PDMA) compliance.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Captured Flag' ;
    rdfs:comment 'Indicates whether the HCP\'s electronic signature was captured during this call, as required for sample distribution under PDMA. A value of True confirms regulatory signature compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:speakerProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Speaker Program Flag' ;
    rdfs:comment 'Indicates whether this call activity is associated with or resulted from a speaker program event. Links commercial call data to speaker program compliance and Sunshine Act reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Timestamp when the sales representative locked and submitted the call record in Veeva CRM, transitioning it from draft to submitted status. Key lifecycle event for field force compliance monitoring.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sunshineActReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Reportable Flag' ;
    rdfs:comment 'Indicates whether this call activity constitutes a reportable transfer of value under the Physician Payments Sunshine Act (Open Payments). Drives inclusion in the annual CMS Open Payments submission.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferOfValueUsd rdf:type rdf:Property ;
    rdfs:label 'Transfer Of Value Usd' ;
    rdfs:comment 'Monetary value in US dollars of any transfer of value (e.g., meals, samples, educational materials) provided to the HCP during this call, as required for Sunshine Act Open Payments reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veevaCallCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Call Code' ;
    rdfs:comment 'Source system identifier for the call record as assigned by Veeva CRM. Used for lineage tracing and deduplication against the operational system of record.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAccountId rdf:type rdf:Property ;
    rdfs:label 'Contract Account Id' ;
    rdfs:comment 'Unique identifier for the commercial contract account. Primary key for institutional customer accounts including hospital systems, IDNs, GPOs, specialty pharmacies, and retail pharmacy chains.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAccount .

ind:businessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Contract accounts are business partners in master data. Required for customer master synchronization, credit limit management, payment terms, order-to-cash integration, and ERP-CRM data consistency.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:parentAccountContractAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Contract Account Id' ;
    rdfs:comment 'Reference to the parent contract account for hierarchical account structures. Used for IDN systems where individual hospitals roll up to a corporate parent. Null for top-level accounts.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAccount .

ind:payerAccountId rdf:type rdf:Property ;
    rdfs:label 'Payer Account Id' ;
    rdfs:comment 'Foreign key linking to market.payer_account. Business justification: Contract accounts may represent institutional payers (hospitals, health systems) that also have payer contracts. Account classification and contracting process links commercial accounts to payer entit' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayerAccount .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Legal or trading name of the institutional customer account. Primary human-readable identifier for the account.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-known unique business identifier for the contract account. Used in commercial operations, invoicing, and customer communications. Typically assigned by ERP system (SAP SD module).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the contract account. Active accounts are eligible for orders and promotional activities. Suspended accounts have temporary restrictions. Closed accounts are no longer serviced.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the institutional customer account type. IDN = Integrated Delivery Network, GPO = Group Purchasing Organization. Determines sales strategy, pricing tier, and field force coverage model.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenuePotential rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Potential' ;
    rdfs:comment 'Estimated annual revenue opportunity for this account based on market analysis, historical performance, and account size. Used for territory planning and resource allocation.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address for the institutional account. Used for invoicing and financial correspondence.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address (suite, floor, building). Optional field for additional address details.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City name for the billing address of the institutional account.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the billing address. Determines regulatory jurisdiction and tax treatment.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the billing address. Used for tax calculation and geographic analysis.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province code for the billing address. Used for tax jurisdiction determination and regulatory reporting.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Business unit or division responsible for managing this account. Used for P&L reporting and organizational alignment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiration date of the current contract agreement. Triggers contract renewal workflow. Null for evergreen contracts without fixed expiration.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the current contract agreement with this institutional account. Pricing and terms become active on this date.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTier rdf:type rdf:Property ;
    rdfs:label 'Contract Tier' ;
    rdfs:comment 'Pricing and service tier assigned to the account based on volume commitments, GPO affiliation, and negotiated terms. Determines discount levels, rebate structures, and service level agreements.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center code for account management expenses. Used for internal cost allocation and budget tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit exposure allowed for this account. Enforced during order processing to manage financial risk. Set by credit management team based on financial assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the credit limit amount. Typically matches the accounts primary transaction currency.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deaNumber rdf:type rdf:Property ;
    rdfs:label 'Dea Number' ;
    rdfs:comment 'DEA registration number for accounts authorized to handle controlled substances. Required for distribution of Schedule II-V medications. Format: 2 letters followed by 7 digits.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpoAffiliation rdf:type rdf:Property ;
    rdfs:label 'Gpo Affiliation' ;
    rdfs:comment 'Name of the Group Purchasing Organization (GPO) that this account is affiliated with, if applicable. GPO affiliation determines contract pricing tier and rebate eligibility. Null if account is not GPO-affiliated.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hinNumber rdf:type rdf:Property ;
    rdfs:label 'Hin Number' ;
    rdfs:comment 'Health Industry Number assigned by GS1 for healthcare supply chain identification. Used for EDI transactions and supply chain traceability.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified this record. Audit field for accountability and compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms negotiated with the account. Defines invoice due date calculation and early payment discount eligibility. Format examples: net_30 (payment due in 30 days), 2_10_net_30 (2% discount if paid within 10 days, otherwise net 30).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary business contact. Used for contract communications, order confirmations, and account notifications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Name of the primary business contact at the institutional account. Typically the procurement director, pharmacy director, or contracting officer.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary phone number for the institutional account contact. Used for urgent communications and relationship management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'First line of the primary shipping address for product deliveries. May differ from billing address for multi-site organizations.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line2' ;
    rdfs:comment 'Second line of the shipping address (dock, receiving department). Optional field for delivery instructions.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'City name for the primary shipping address of the institutional account.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipping address. Determines export compliance requirements and GDP regulations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the shipping address. Used for freight calculation and delivery routing.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'State or province code for the shipping address. Used for logistics planning and distribution compliance.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicClassification rdf:type rdf:Property ;
    rdfs:label 'Strategic Classification' ;
    rdfs:comment 'Strategic importance tier of the account based on revenue potential, market influence, and relationship depth. Tier 1 accounts receive dedicated account management and customized engagement programs.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identification number (TIN, VAT number, or equivalent) for the institutional account. Required for tax-compliant invoicing and regulatory reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copayProgramId rdf:type rdf:Property ;
    rdfs:label 'Copay Program Id' ;
    rdfs:comment 'Unique identifier for the co-pay assistance program record. Primary key.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CopayProgram .

ind:administeringVendorId rdf:type rdf:Property ;
    rdfs:label 'Administering Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Copay programs are administered by third-party pharmacy benefit vendors. While vendor_contract_id exists, direct vendor_id enables operational queries for vendor performance monitoring, contact inform' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:medicalHeorStudyId rdf:type rdf:Property ;
    rdfs:label 'Medical Heor Study Id' ;
    rdfs:comment 'Foreign key linking to medical.medical_heor_study. Business justification: Copay program design (benefit levels, eligibility criteria) informed by HEOR evidence on patient affordability barriers, adherence economics, and willingness-to-pay. Strategic evidence-to-access linka' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalHeorStudy .

ind:patientAccessProgramId rdf:type rdf:Property ;
    rdfs:label 'Patient Access Program Id' ;
    rdfs:comment 'Foreign key linking to market.patient_access_program. Business justification: Copay programs are a specific type of patient access program defined in market access strategy. Links commercial copay program execution to strategic market access program for tracking against access ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatientAccessProgram .

ind:activeEnrolledPatients rdf:type rdf:Property ;
    rdfs:label 'Active Enrolled Patients' ;
    rdfs:comment 'Current count of patients with active enrollment status in the co-pay program.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commercialInsuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Insurance Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether patients must have commercial insurance coverage to be eligible for the co-pay program.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Approval Date' ;
    rdfs:comment 'Date when the co-pay program received final compliance and legal approval for launch.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of legal and compliance review for the co-pay program to ensure adherence to Anti-Kickback Statute, PhRMA Code, and promotional regulations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary amounts in this program (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Detailed description of patient eligibility requirements for enrollment in the co-pay program, including insurance type restrictions, income thresholds, and other qualifying conditions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusion340bFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion 340b Flag' ;
    rdfs:comment 'Boolean flag indicating whether prescriptions filled through 340B covered entities are excluded from this co-pay program to maintain compliance with federal regulations.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionGovernmentPayerFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Government Payer Flag' ;
    rdfs:comment 'Boolean flag indicating whether patients with government-funded insurance (Medicare, Medicaid, TRICARE, VA) are excluded from program eligibility per Anti-Kickback Statute compliance.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossToNetCategory rdf:type rdf:Property ;
    rdfs:label 'Gross To Net Category' ;
    rdfs:comment 'Gross-to-net deduction category for financial reporting, used to classify co-pay program costs in revenue reconciliation and brand P&L analysis.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAnnualBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Max Annual Benefit Amount' ;
    rdfs:comment 'Maximum dollar amount of co-pay assistance a patient can receive per calendar year under this program.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBenefitPerPrescription rdf:type rdf:Property ;
    rdfs:label 'Max Benefit Per Prescription' ;
    rdfs:comment 'Maximum dollar amount of co-pay assistance available per individual prescription fill or claim.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional program details, special instructions, or operational notes related to the co-pay program.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwner rdf:type rdf:Property ;
    rdfs:label 'Program Owner' ;
    rdfs:comment 'Name or identifier of the commercial operations leader or brand manager responsible for the co-pay program strategy and performance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the co-pay program indicating whether it is active, inactive, suspended, pending launch, or terminated.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the co-pay program mechanism (e.g., co-pay card, voucher, free trial, instant savings, rebate, patient assistance).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date when the co-pay program was or will be terminated. Null for ongoing programs.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalEnrolledPatients rdf:type rdf:Property ;
    rdfs:label 'Total Enrolled Patients' ;
    rdfs:comment 'Cumulative count of unique patients who have enrolled in the co-pay program since launch.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRedemptionsCount rdf:type rdf:Property ;
    rdfs:label 'Total Redemptions Count' ;
    rdfs:comment 'Cumulative count of co-pay card or voucher redemptions processed under this program since launch.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transparencyReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Transparency Reporting Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether co-pay program benefits must be reported under Physician Payments Sunshine Act or other transparency regulations.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaCrmRecordCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Record Code' ;
    rdfs:comment 'External system identifier linking this co-pay program to the corresponding record in Veeva CRM for commercial operations tracking.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copayRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Copay Redemption Id' ;
    rdfs:comment 'Unique identifier for each co-pay card or voucher redemption transaction. Primary key for the copay_redemption product.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Copay transactions may generate receivables from payers or require chargeback processing affecting AR. Links redemption to revenue recognition and payer reconciliation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:cogsEntryId rdf:type rdf:Property ;
    rdfs:label 'Cogs Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.cogs_entry. Business justification: Copay redemptions affect product COGS through gross-to-net impact. Manufacturer contributions reduce net revenue and must be tracked against product cost.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CogsEntry .

ind:marketGrossToNetAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Market Gross To Net Adjustment Id' ;
    rdfs:comment 'Foreign key linking to market.gross_to_net_adjustment. Business justification: Copay redemptions drive gross-to-net adjustments for manufacturer copay contributions. Financial reconciliation process requires linking redemption transactions to GTN accruals for revenue recognition' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrossToNetAdjustment .

ind:daysSupply rdf:type rdf:Property ;
    rdfs:label 'Days Supply' ;
    rdfs:comment 'Number of days the dispensed quantity is intended to last based on the prescribed dosing regimen.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insurancePaidAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Paid Amount' ;
    rdfs:comment 'The amount paid by the patients insurance plan or pharmacy benefit manager toward the prescription cost.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientOutOfPocketAmount rdf:type rdf:Property ;
    rdfs:label 'Patient Out Of Pocket Amount' ;
    rdfs:comment 'The amount the patient paid out-of-pocket after applying insurance coverage and manufacturer co-pay assistance.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerAdjudicationStatus rdf:type rdf:Property ;
    rdfs:label 'Payer Adjudication Status' ;
    rdfs:comment 'Status of the insurance claim adjudication by the pharmacy benefit manager or payer, indicating whether the claim was approved, denied, or partially approved.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyChainCode rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Chain Code' ;
    rdfs:comment 'Code identifying the pharmacy chain or network to which the dispensing pharmacy belongs (e.g., CVS, Walgreens, independent).' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyName rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Name' ;
    rdfs:comment 'Name of the pharmacy or retail location where the co-pay card was redeemed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyNpi rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Npi' ;
    rdfs:comment 'The 10-digit National Provider Identifier of the pharmacy where the redemption occurred. NPI is the unique identifier for healthcare providers in the United States.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriberNpi rdf:type rdf:Property ;
    rdfs:label 'Prescriber Npi' ;
    rdfs:comment 'The 10-digit National Provider Identifier of the healthcare professional who wrote the prescription.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriberSpecialty rdf:type rdf:Property ;
    rdfs:label 'Prescriber Specialty' ;
    rdfs:comment 'Medical specialty of the prescribing healthcare professional (e.g., oncologist, rheumatologist, endocrinologist).' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Prescription Number' ;
    rdfs:comment 'Pharmacy-assigned prescription number for the dispensed medication associated with this redemption.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programUtilizationCount rdf:type rdf:Property ;
    rdfs:label 'Program Utilization Count' ;
    rdfs:comment 'Sequential count of how many times this patient has utilized the co-pay program, used to track adherence and program engagement.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionDate rdf:type rdf:Property ;
    rdfs:label 'Redemption Date' ;
    rdfs:comment 'The date on which the patient redeemed the co-pay card or voucher at the pharmacy. This is the principal business event date for this transaction.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Number' ;
    rdfs:comment 'Externally-known unique transaction number assigned to this redemption event by the co-pay program administrator or pharmacy benefit manager.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the redemption transaction indicating whether the claim has been submitted, approved, rejected, reversed, or paid.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Precise timestamp when the redemption transaction was processed at the pharmacy point-of-sale or submitted to the pharmacy benefit manager.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Code' ;
    rdfs:comment 'Standard rejection code returned by the pharmacy benefit manager if the claim was denied, indicating the reason for rejection (e.g., prior authorization required, plan limitations exceeded).' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Retail Price Amount' ;
    rdfs:comment 'The full retail price of the prescription before any discounts, insurance, or co-pay assistance.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date on which the redemption transaction was reversed, if applicable.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Boolean indicator of whether this redemption transaction has been reversed or voided due to prescription return, billing correction, or other adjustment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province where the pharmacy is located and the redemption occurred.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Amount' ;
    rdfs:comment 'The total amount paid for the prescription, including patient out-of-pocket, manufacturer contribution, and insurance payment.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hcpTargetId rdf:type rdf:Property ;
    rdfs:label 'Hcp Target Id' ;
    rdfs:comment 'Unique surrogate identifier for the HCP targeting and call planning record within the commercial segmentation and planning layer.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cyclePlanId rdf:type rdf:Property ;
    rdfs:label 'Cycle Plan Id' ;
    rdfs:comment 'Reference to the targeting/planning cycle (e.g., Q1 2025 cycle plan) under which this HCP target record was created. A cycle plan defines the planning period and field force objectives.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:mslEngagementId rdf:type rdf:Property ;
    rdfs:label 'Msl Engagement Id' ;
    rdfs:comment 'Foreign key linking to medical.msl_engagement. Business justification: Commercial targeting decisions informed by most recent MSL scientific engagement with same HCP. Enables coordinated field strategy, prevents engagement conflicts, and supports KOL tier assignment base' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MslEngagement .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the targeting plan record was formally approved by the authorized sales manager or commercial operations team. Marks the transition from planning to execution.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callTypeMixPctF2f rdf:type rdf:Property ;
    rdfs:label 'Call Type Mix Pct F2f' ;
    rdfs:comment 'Percentage of total planned calls that are designated as face-to-face interactions (0.00–100.00). Used to monitor adherence to brand-level call mix strategy and field force deployment guidelines.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorPrescriber rdf:type rdf:Property ;
    rdfs:label 'Competitor Prescriber' ;
    rdfs:comment 'Indicates whether the HCP is known to prescribe a competing product in the same therapeutic class. Used to prioritize conversion-focused engagement strategies and messaging.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentBrandPrescriber rdf:type rdf:Property ;
    rdfs:label 'Current Brand Prescriber' ;
    rdfs:comment 'Indicates whether the HCP is currently an active prescriber of the targeted brand based on the most recent prescribing data. Distinguishes new-to-brand targets from existing prescribers for tailored engagement strategies.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCallCount rdf:type rdf:Property ;
    rdfs:label 'Cycle Call Count' ;
    rdfs:comment 'Number of completed sales calls made to this HCP for the targeted brand within the current cycle plan period. Used to measure in-cycle execution progress against planned_call_frequency.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Indicates that this HCP has requested no promotional contact or has been placed on a do-not-contact list. When true, field force must not initiate promotional calls. Critical for compliance with HCP opt-out preferences and applicable privacy regulations.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementChannelPreference rdf:type rdf:Property ;
    rdfs:label 'Engagement Channel Preference' ;
    rdfs:comment 'HCP\'s preferred channel for sales representative engagement as captured in Veeva CRM or Salesforce Health Cloud. Informs call type mix planning and omnichannel engagement strategy.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKol rdf:type rdf:Property ;
    rdfs:label 'Is Kol' ;
    rdfs:comment 'Indicates whether this HCP is designated as a Key Opinion Leader (KOL) for the targeted brand or therapeutic area. KOL status influences engagement strategy, speaker program eligibility, and medical affairs coordination.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSampleEligible rdf:type rdf:Property ;
    rdfs:label 'Is Sample Eligible' ;
    rdfs:comment 'Indicates whether this HCP is eligible to receive drug samples for the targeted brand. Governed by the Prescription Drug Marketing Act (PDMA) and internal sample distribution policies.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpeakerEligible rdf:type rdf:Property ;
    rdfs:label 'Is Speaker Eligible' ;
    rdfs:comment 'Indicates whether this HCP is eligible to participate in brand speaker programs. Eligibility is governed by PhRMA Code compliance, Sunshine Act reporting requirements, and internal speaker bureau criteria.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDetailDate rdf:type rdf:Property ;
    rdfs:label 'Last Detail Date' ;
    rdfs:comment 'Date of the most recent promotional detail (sales call) made to this HCP for the targeted brand. Used to monitor call recency, identify lapsed targets, and prioritize field force scheduling.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketPotentialSegment rdf:type rdf:Property ;
    rdfs:label 'Market Potential Segment' ;
    rdfs:comment 'Categorical assessment of the HCP\'s overall market potential for the brand, derived from prescribing volume, patient panel size, and payer mix. Used alongside prescribing_potential_decile for targeting decisions.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCallFrequency rdf:type rdf:Property ;
    rdfs:label 'Planned Call Frequency' ;
    rdfs:comment 'Target number of sales calls (details) planned for this HCP during the cycle plan period. Drives field force scheduling and activity quotas in Veeva CRM.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedF2fCalls rdf:type rdf:Property ;
    rdfs:label 'Planned F2f Calls' ;
    rdfs:comment 'Number of planned in-person (face-to-face) sales calls for this HCP within the cycle. Part of the call type mix alongside remote calls. Supports field force activity planning and compliance with call mix targets.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedRemoteCalls rdf:type rdf:Property ;
    rdfs:label 'Planned Remote Calls' ;
    rdfs:comment 'Number of planned remote (virtual/telephone) sales calls for this HCP within the cycle. Complements planned_f2f_calls to define the full call type mix for the planning period.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescribingPotentialDecile rdf:type rdf:Property ;
    rdfs:label 'Prescribing Potential Decile' ;
    rdfs:comment 'Decile ranking (1–10) of the HCP\'s estimated prescribing potential for the targeted brand\'s therapeutic area, derived from claims data or market research. Decile 10 = highest prescribing potential. Key input to target tier assignment.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric rank of this HCP target within the territory for the given brand and cycle plan. Lower rank = higher priority. Used to sequence call planning when field force capacity is constrained.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialtySegment rdf:type rdf:Property ;
    rdfs:label 'Specialty Segment' ;
    rdfs:comment 'Medical specialty segment of the HCP as used for commercial targeting purposes (e.g., Oncology, Cardiology, Immunology, Primary Care). May differ from the HCP master specialty if the brand targets a sub-specialty. [ENUM-REF-CANDIDATE: oncology|cardiology|immunology|primary_care|neurology|endocrinology|rheumatology|hematology|gastroenterology|pulmonology — promote to reference product]' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Target Record Number' ;
    rdfs:comment 'Business-facing unique identifier for this HCP target record, used in Veeva CRM and downstream reporting. Distinct from the surrogate hcp_target_id.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTier rdf:type rdf:Property ;
    rdfs:label 'Target Tier' ;
    rdfs:comment 'Segmentation tier assigned to the HCP for this brand and cycle, reflecting strategic priority for field force engagement. Tier A = highest priority, Tier D = lowest. Drives call frequency and resource allocation.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingRationale rdf:type rdf:Property ;
    rdfs:label 'Targeting Rationale' ;
    rdfs:comment 'Free-text or structured justification for why this HCP has been selected and tiered for this brand and cycle. May reference prescribing behavior, patient population, KOL status, or market development opportunity.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingStatus rdf:type rdf:Property ;
    rdfs:label 'Targeting Status' ;
    rdfs:comment 'Current lifecycle status of this HCP target record within the planning cycle. Active = currently targeted; Inactive = de-prioritized; Pending = awaiting approval; Suspended = temporarily paused; Removed = excluded from targeting.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ytdCallCount rdf:type rdf:Property ;
    rdfs:label 'Ytd Call Count' ;
    rdfs:comment 'Number of completed sales calls (details) made to this HCP for the targeted brand in the current year-to-date period. Tracks field force execution against planned call frequency targets.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveCompensationId rdf:type rdf:Property ;
    rdfs:label 'Incentive Compensation Id' ;
    rdfs:comment 'Unique identifier for the incentive compensation record. Primary key for this entity.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationPlanId rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Id' ;
    rdfs:comment 'Identifier of the compensation plan under which this incentive is calculated. Links to the compensation plan master record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompensationPlan .

ind:performancePeriodId rdf:type rdf:Property ;
    rdfs:label 'Performance Period Id' ;
    rdfs:comment 'Identifier of the performance period for which this compensation is calculated. Links to the performance period reference.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformancePeriod .

ind:acceleratorAmount rdf:type rdf:Property ;
    rdfs:label 'Accelerator Amount' ;
    rdfs:comment 'Additional bonus amount earned through accelerators for exceeding quota thresholds. Applied when attainment exceeds predefined levels (e.g., 120%, 150%).' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Sales Amount' ;
    rdfs:comment 'Actual sales achieved by the representative during the performance period. Numerator for attainment percentage calculation.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Manual adjustment amount applied to the calculated bonus. May be positive (additional credit) or negative (deduction). Requires approval and documented reason.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Business justification for any manual adjustment applied to the calculated bonus. Required when adjustment_amount is non-zero. Examples: territory realignment, data correction, special recognition.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attainmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Attainment Percentage' ;
    rdfs:comment 'Percentage of quota achieved by the representative. Calculated as (actual_sales_amount / quota_amount) * 100. Determines bonus tier eligibility.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseBonusAmount rdf:type rdf:Property ;
    rdfs:label 'Base Bonus Amount' ;
    rdfs:comment 'Base incentive bonus amount calculated before any adjustments, accelerators, or deductions. Determined by attainment percentage and compensation plan formula.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusTier rdf:type rdf:Property ;
    rdfs:label 'Bonus Tier' ;
    rdfs:comment 'Bonus tier achieved based on attainment percentage. Each tier corresponds to a different payout multiplier or fixed amount per the compensation plan.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'Date on which the incentive compensation was calculated by the system or compensation analyst.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationStatus rdf:type rdf:Property ;
    rdfs:label 'Compensation Status' ;
    rdfs:comment 'Current lifecycle status of the incentive compensation record. Tracks progression from calculation through approval to payout.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmRecordCode rdf:type rdf:Property ;
    rdfs:label 'Crm Record Code' ;
    rdfs:comment 'Identifier of the corresponding record in the CRM system (Veeva CRM or Salesforce Health Cloud) that tracks the sales activities underlying this compensation.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Document Number' ;
    rdfs:comment 'Document number generated in the ERP system (SAP S/4HANA) when this incentive compensation expense was posted to the general ledger.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code to which this incentive compensation expense is posted. Aligns with chart of accounts for financial reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutDate rdf:type rdf:Property ;
    rdfs:label 'Payout Date' ;
    rdfs:comment 'Date on which the incentive compensation was paid or is scheduled to be paid to the representative. Aligns with payroll cycle.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payoutStatus rdf:type rdf:Property ;
    rdfs:label 'Payout Status' ;
    rdfs:comment 'Status of the actual payment disbursement to the sales representative. Tracks integration with payroll or finance systems.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollBatchReference rdf:type rdf:Property ;
    rdfs:label 'Payroll Batch Reference' ;
    rdfs:comment 'Identifier of the payroll batch in which this incentive compensation was included for payment processing. Links to HR payroll system.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'Sales quota target assigned to the representative for this performance period. Denominator for attainment percentage calculation.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided when the compensation record is rejected during approval workflow. Required when approval_status is rejected.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBonusAmount rdf:type rdf:Property ;
    rdfs:label 'Total Bonus Amount' ;
    rdfs:comment 'Final incentive compensation amount payable to the representative. Sum of base_bonus_amount, accelerator_amount, and adjustment_amount.' ;
    rdfs:domain ind:IncentiveCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID or system identifier of the person or process that created this record. Audit trail field for compliance and data governance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolEngagementId rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Id' ;
    rdfs:comment 'Unique identifier for the KOL engagement record. Primary key for tracking longitudinal relationships with Key Opinion Leaders across commercial and medical affairs activities.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictOfInterestId rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Id' ;
    rdfs:comment 'Foreign key linking to compliance.conflict_of_interest. Business justification: KOL relationships require COI assessment for advisory boards, consultancies, and research collaborations. Essential for bias management, transparency reporting, and compliance with institutional and r' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConflictOfInterest .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key reference to the consulting or services contract governing this KOL engagement. Links to the legal agreement under which services are provided.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pharmaceuticals .

ind:engagementOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Engagement Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: KOL engagement ownership is critical for medical affairs and commercial collaboration tracking. Engagement_owner currently text; FK enables proper accountability for strategic HCP relationship managem' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:payerEngagementId rdf:type rdf:Property ;
    rdfs:label 'Payer Engagement Id' ;
    rdfs:comment 'Foreign key linking to market.payer_engagement. Business justification: KOL engagements (advisory boards, publications) generate evidence presented in payer negotiations. Evidence generation and deployment process links KOL activities to payer meetings where insights are ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayerEngagement .

ind:advisoryBoardName rdf:type rdf:Property ;
    rdfs:label 'Advisory Board Name' ;
    rdfs:comment 'The name or identifier of the advisory board if the engagement type is advisory board participation. Used to group multiple KOL engagements under a single advisory board event.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Approval Status' ;
    rdfs:comment 'The approval status from the compliance and legal review process. All KOL engagements must receive compliance approval before execution per PhRMA Code and internal policies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceApprover rdf:type rdf:Property ;
    rdfs:label 'Compliance Approver' ;
    rdfs:comment 'Name or identifier of the compliance officer who approved this KOL engagement. Maintains accountability for compliance decisions.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressName rdf:type rdf:Property ;
    rdfs:label 'Congress Name' ;
    rdfs:comment 'The name of the medical congress or scientific conference associated with this engagement, if applicable. Relevant for congress presentation and advisory board engagements held at conferences.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCountry rdf:type rdf:Property ;
    rdfs:label 'Engagement Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the engagement occurred. Required for regional compliance reporting and transparency obligations.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Date' ;
    rdfs:comment 'The date on which the KOL engagement activity occurred. Used for tracking engagement frequency and compliance reporting timelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementDurationHours rdf:type rdf:Property ;
    rdfs:label 'Engagement Duration Hours' ;
    rdfs:comment 'The total duration of the KOL engagement activity measured in hours. Used for fair market value assessment and resource planning.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementLocation rdf:type rdf:Property ;
    rdfs:label 'Engagement Location' ;
    rdfs:comment 'The physical or virtual location where the KOL engagement took place. May include city, venue name, or virtual platform identifier.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle status of the KOL engagement. Tracks progression from planning through completion or cancellation, including compliance approval gates.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementTopic rdf:type rdf:Property ;
    rdfs:label 'Engagement Topic' ;
    rdfs:comment 'The specific subject matter or agenda topic discussed during the KOL engagement. Provides context for the scientific or clinical focus of the interaction.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'The category of engagement activity conducted with the KOL. Distinguishes between advisory boards, speaker training sessions, publication reviews, congress presentations, consulting engagements, and investigator meetings.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairMarketValueAssessment rdf:type rdf:Property ;
    rdfs:label 'Fair Market Value Assessment' ;
    rdfs:comment 'Assessment status indicating whether the honorarium and engagement terms comply with fair market value guidelines per PhRMA Code and internal policies.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honorariumAmount rdf:type rdf:Property ;
    rdfs:label 'Honorarium Amount' ;
    rdfs:comment 'The monetary compensation paid to the KOL for their participation in this engagement activity. Subject to fair market value assessment and transparency reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:honorariumCurrency rdf:type rdf:Property ;
    rdfs:label 'Honorarium Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the honorarium payment (e.g., USD, EUR, GBP). Required for multi-country operations and financial reporting.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationTitle rdf:type rdf:Property ;
    rdfs:label 'Publication Title' ;
    rdfs:comment 'The title of the scientific publication or manuscript being reviewed by the KOL, if the engagement type is publication review. Links engagement to publication planning activities.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicRelationshipTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Relationship Tier' ;
    rdfs:comment 'Classification of the KOL\'s strategic importance to the organization. Tier 1 represents national/international thought leaders, Tier 2 regional influencers, Tier 3 local experts, and Emerging represents developing relationships.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transparencyReportDate rdf:type rdf:Property ;
    rdfs:label 'Transparency Report Date' ;
    rdfs:comment 'The date on which this KOL engagement was reported to the applicable transparency reporting system or regulatory authority.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transparencyReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Transparency Reporting Required' ;
    rdfs:comment 'Boolean flag indicating whether this KOL engagement must be reported under transparency regulations such as the Sunshine Act (US), EFPIA Code (EU), or similar country-specific requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaCrmActivityCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Activity Code' ;
    rdfs:comment 'The unique activity identifier from Veeva CRM system linking this KOL engagement to the source system record. Enables traceability to operational CRM data.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlrReviewId rdf:type rdf:Property ;
    rdfs:label 'Mlr Review Id' ;
    rdfs:comment 'Unique system-generated identifier for each MLR review record. Primary key for the mlr_review data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MlrReview .

ind:internalControlId rdf:type rdf:Property ;
    rdfs:label 'Internal Control Id' ;
    rdfs:comment 'Foreign key linking to compliance.internal_control. Business justification: MLR reviews are SOX-relevant controls for promotional content approval. Required for control testing, effectiveness assessment, and SOX 404 compliance documentation in pharmaceutical promotional opera' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalControl .

ind:primaryMlrEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Mlr Employee Id' ;
    rdfs:comment 'Reference to the medical affairs reviewer responsible for evaluating the scientific accuracy and clinical claims within the promotional material.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorSubmissionMlrReviewId rdf:type rdf:Property ;
    rdfs:label 'Prior Submission Mlr Review Id' ;
    rdfs:comment 'Reference to the previous MLR review record for the same promotional material, enabling resubmission history tracking and cycle lineage. Null for initial submissions (review_cycle_number = 1).' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MlrReview .

ind:quaternaryMlrSubmitterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Mlr Submitter Employee Id' ;
    rdfs:comment 'Reference to the individual (typically from the commercial or marketing team) who submitted the promotional material for MLR review.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryMlrRegulatoryReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Mlr Regulatory Reviewer Employee Id' ;
    rdfs:comment 'Reference to the regulatory affairs reviewer responsible for assessing compliance with FDA promotional regulations, labeling requirements, and applicable agency guidance.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalDecision rdf:type rdf:Property ;
    rdfs:label 'Approval Decision' ;
    rdfs:comment 'Final consolidated approval decision rendered by the MLR committee upon completion of all three review streams (medical, legal, regulatory). Null until the review is concluded.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the market or jurisdiction for which the promotional material is intended. Determines applicable regulatory authority (FDA, EMA, MHRA, PMDA, NMPA) and review standards.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'The intended distribution channel through which the approved promotional material will be disseminated to the target audience. Informs channel-specific compliance requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairBalanceVerified rdf:type rdf:Property ;
    rdfs:label 'Fair Balance Verified' ;
    rdfs:comment 'Indicates whether the promotional material includes adequate fair balance presentation of risks and benefits as required by FDA regulations for prescription drug advertising.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date on which the legal reviewer completed their review and rendered a decision for this review cycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Review Status' ;
    rdfs:comment 'Current decision status from the legal reviewer for this review cycle. Tracks the legal component of the MLR tripartite review process.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Medical Review Date' ;
    rdfs:comment 'Date on which the medical affairs reviewer completed their review and rendered a decision for this review cycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phramaCodeCompliant rdf:type rdf:Property ;
    rdfs:label 'Phrama Code Compliant' ;
    rdfs:comment 'Indicates whether the promotional material has been assessed and confirmed as compliant with the PhRMA Code on Interactions with Healthcare Professionals. Set to True upon successful regulatory review.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'The regulatory authority whose promotional guidelines govern this MLR review, determined by the target market. Drives applicable review standards and compliance requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReviewDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Date' ;
    rdfs:comment 'Date on which the regulatory affairs reviewer completed their review and rendered a decision for this review cycle.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Status' ;
    rdfs:comment 'Current decision status from the regulatory affairs reviewer for this review cycle. Tracks the regulatory component of the MLR tripartite review process.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Resubmission Deadline' ;
    rdfs:comment 'Date by which a revised version of the rejected promotional material must be resubmitted for the next review cycle. Populated when approval_decision is \'rejected\' or \'approved_with_changes\'.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Consolidated reviewer comments, change requests, and annotations captured during the MLR review cycle. Includes feedback from medical, legal, and regulatory reviewers requiring action by the submitter.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Number' ;
    rdfs:comment 'Sequential integer indicating which review cycle this record represents for the associated promotional material. A value of 1 indicates the initial submission; values greater than 1 indicate resubmission cycles following prior rejection or revision.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Target date by which the MLR review must be completed, based on internal SLA commitments and commercial launch timelines. Used for workflow prioritization and escalation management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle state of the MLR review workflow. Tracks progression from initial submission through final approval or rejection decision. [ENUM-REF-CANDIDATE: draft|submitted|in_review|approved|rejected|withdrawn|expired — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the promotional material was formally submitted to the MLR review committee for evaluation. Represents the principal business event timestamp for the review lifecycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the MLR review submission, used for cross-functional tracking and audit trail purposes within Veeva Vault PromoMats.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunshineActApplicable rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Applicable' ;
    rdfs:comment 'Indicates whether the promotional activity associated with this material is subject to Open Payments (Sunshine Act) reporting requirements under 42 CFR Part 403.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaVaultDocCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Doc Code' ;
    rdfs:comment 'The document identifier assigned by Veeva Vault PromoMats to the promotional material record. Used for cross-system traceability between the lakehouse silver layer and the source system of record.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientSupportProgramId rdf:type rdf:Property ;
    rdfs:label 'Patient Support Program Id' ;
    rdfs:comment 'Unique identifier for the patient support program record. Primary key.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatientSupportProgram .

ind:programOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Patient support program ownership is essential for operational accountability, budget management, and vendor oversight. Program_owner currently text; FK enables proper tracking of responsible commerci' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplyContractId rdf:type rdf:Property ;
    rdfs:label 'Supply Contract Id' ;
    rdfs:comment 'Reference identifier for the legal contract with the administering vendor governing program operations and service level agreements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyContract .

ind:adherenceRateActual rdf:type rdf:Property ;
    rdfs:label 'Adherence Rate Actual' ;
    rdfs:comment 'Actual medication adherence rate (as percentage) achieved among enrolled patients, measured using prescription refill data or patient-reported outcomes.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adherenceRateTarget rdf:type rdf:Property ;
    rdfs:label 'Adherence Rate Target' ;
    rdfs:comment 'Target medication adherence rate (as percentage) that the program aims to achieve among enrolled patients.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitType rdf:type rdf:Property ;
    rdfs:label 'Benefit Type' ;
    rdfs:comment 'Primary type of benefit or service provided to enrolled patients through this program.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerEnrollment rdf:type rdf:Property ;
    rdfs:label 'Cost Per Enrollment' ;
    rdfs:comment 'Average cost to the program per patient enrollment, calculated as total spend divided by total enrollments.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Primary channel through which patients can enroll in the support program.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Compliant Flag' ;
    rdfs:comment 'Indicates whether the program operations and vendor have been certified as compliant with HIPAA Privacy and Security Rules.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incomeThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Income Threshold Amount' ;
    rdfs:comment 'Maximum annual household income level for patient eligibility in financial assistance programs. Null if program does not have income restrictions.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Income Threshold Currency' ;
    rdfs:comment 'Currency code for the income threshold amount using ISO 4217 three-letter codes.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Max Benefit Amount' ;
    rdfs:comment 'Maximum financial benefit amount per patient per year for co-pay assistance or free drug programs. Null if program does not have a cap.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBenefitCurrency rdf:type rdf:Property ;
    rdfs:label 'Max Benefit Currency' ;
    rdfs:comment 'Currency code for the maximum benefit amount using ISO 4217 three-letter codes.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programBudgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Program Budget Currency' ;
    rdfs:comment 'Currency code for the program budget amount using ISO 4217 three-letter codes.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory approval or notification for the patient support program where required by local health authorities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Score' ;
    rdfs:comment 'Composite performance score (0-100 scale) for the administering vendor based on service level agreement (SLA) metrics including enrollment processing time, patient satisfaction, and compliance.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyDocumentId rdf:type rdf:Property ;
    rdfs:label 'Policy Document Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy_document. Business justification: Promotional materials must reference and comply with promotional SOPs and policies. Links materials to governing policy documents for MLR review requirements, fair balance standards, and regulatory co' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PolicyDocument .

ind:productionVendorId rdf:type rdf:Property ;
    rdfs:label 'Production Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Promotional materials are produced by external vendors (printers, digital agencies, video production). Marketing procurement tracks which vendor produced each piece for quality control, compliance ver' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:aggregateDecision rdf:type rdf:Property ;
    rdfs:label 'Aggregate Decision' ;
    rdfs:comment 'Overall consolidated MLR committee decision for the current review cycle, reflecting the combined outcome of medical, legal, and regulatory reviewer decisions. Drives the approval_status field transition.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentOwner rdf:type rdf:Property ;
    rdfs:label 'Content Owner' ;
    rdfs:comment 'Name or employee identifier of the brand team member or marketing manager who owns and is accountable for the promotional material content, including initiating the MLR submission and managing the approval lifecycle.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairBalanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Fair Balance Included' ;
    rdfs:comment 'Indicates whether the promotional material includes the required fair balance statement (risk information) as mandated by FDA 21 CFR Part 202.1 for prescription drug advertising. Must be True for all HCP-directed materials.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isiIncluded rdf:type rdf:Property ;
    rdfs:label 'Isi Included' ;
    rdfs:comment 'Indicates whether the Important Safety Information (ISI) section is included in the promotional material, as required for HCP-directed promotional pieces under FDA promotional regulations.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 region subtag) indicating the language of the promotional material content (e.g., en-US, fr-FR, de-DE). Required for multi-market localization tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastResubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Resubmission Date' ;
    rdfs:comment 'Date of the most recent resubmission of this promotional material to the MLR committee after a prior rejection or change request. Null if the material has never been resubmitted.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalDecision rdf:type rdf:Property ;
    rdfs:label 'Legal Decision' ;
    rdfs:comment 'Individual decision rendered by the Legal reviewer for the current MLR review cycle. All three reviewer decisions must be \'approved\' for aggregate approval.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewer rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer' ;
    rdfs:comment 'Name or employee identifier of the assigned Legal reviewer responsible for evaluating legal risk, intellectual property, and fair balance claims in the promotional material during the MLR review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:market rdf:type rdf:Property ;
    rdfs:label 'Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the market for which this promotional material is approved and intended for distribution. Drives regulatory jurisdiction applicability (FDA, EMA, MHRA, PMDA, NMPA).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the promotional material across commercial operations, field force systems, and print/digital distribution. Used on physical materials and in Veeva CRM detailing records.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the promotional material by format and intended use. Drives distribution channel eligibility and MLR review routing. [ENUM-REF-CANDIDATE: detail_aid|leave_behind|patient_brochure|digital_asset|journal_ad|video|banner_ad|email_template|sales_aid|speaker_slide_deck|website_content|social_media_post — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalDecision rdf:type rdf:Property ;
    rdfs:label 'Medical Decision' ;
    rdfs:comment 'Individual decision rendered by the Medical Affairs reviewer for the current MLR review cycle. All three reviewer decisions (medical, legal, regulatory) must be \'approved\' for aggregate approval.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlrSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Mlr Submission Date' ;
    rdfs:comment 'Date on which the promotional material was formally submitted to the MLR review committee for the current review cycle. Triggers the review SLA clock.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piReferenceIncluded rdf:type rdf:Property ;
    rdfs:label 'Pi Reference Included' ;
    rdfs:comment 'Indicates whether a reference to the full Prescribing Information (PI) or a brief summary thereof is included in the promotional material, as required by FDA 21 CFR Part 202.1(e).' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryDecision rdf:type rdf:Property ;
    rdfs:label 'Regulatory Decision' ;
    rdfs:comment 'Individual decision rendered by the Regulatory Affairs reviewer for the current MLR review cycle. All three reviewer decisions must be \'approved\' for aggregate approval.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReviewer rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reviewer' ;
    rdfs:comment 'Name or employee identifier of the assigned Regulatory Affairs reviewer responsible for evaluating compliance with FDA labeling, 21 CFR Part 202, and applicable EMA/MHRA promotional guidelines during the MLR review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'Total number of times this promotional material has been resubmitted to the MLR committee following a rejection or request for changes. Tracks review efficiency and content quality metrics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplePiece rdf:type rdf:Property ;
    rdfs:label 'Sample Piece' ;
    rdfs:comment 'Indicates whether this material is a sample or specimen piece used for internal review, training, or regulatory submission purposes, as opposed to a commercially distributed piece.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Intended recipient audience for the promotional material. Drives compliance review requirements — HCP-directed materials require full MLR review; patient materials require additional plain-language review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Vault Document Code' ;
    rdfs:comment 'The native document identifier assigned by Veeva Vault PromoMats, used to cross-reference the record in the source system of record.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionLineage rdf:type rdf:Property ;
    rdfs:label 'Version Lineage' ;
    rdfs:comment 'Pipe-delimited or comma-separated list of predecessor material numbers and version identifiers representing the full version history chain for this material. Supports audit trail and content genealogy tracking in Veeva PromoMats.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pspEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Psp Enrollment Id' ;
    rdfs:comment 'Unique identifier for the patient support program enrollment record. Primary key.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: PSP enrollment audit trail requires employee tracking for HIPAA compliance and data integrity investigations. Modified_by currently text; FK enables proper audit trail linking to workforce records for' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:namedPatientRequestId rdf:type rdf:Property ;
    rdfs:label 'Named Patient Request Id' ;
    rdfs:comment 'Foreign key linking to medical.named_patient_request. Business justification: Patient support programs may transition patients to named patient/compassionate use pathways for pre-approval access when commercial product unavailable. Operational handoff for continuity of care and' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NamedPatientRequest .

ind:administeringVendor rdf:type rdf:Property ;
    rdfs:label 'Administering Vendor' ;
    rdfs:comment 'Name of the third-party vendor or Contract Research Organization (CRO) administering the patient support program on behalf of the pharmaceutical company.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCurrency rdf:type rdf:Property ;
    rdfs:label 'Benefit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the benefit amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEndDate rdf:type rdf:Property ;
    rdfs:label 'Benefit End Date' ;
    rdfs:comment 'Date when the patient support program benefits expire or are scheduled to terminate. May be null for open-ended programs.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitStartDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Start Date' ;
    rdfs:comment 'Date when the patient support program benefits become active and available for use by the patient.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether patient consent for program participation and data usage was obtained in compliance with HIPAA and privacy regulations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Date' ;
    rdfs:comment 'Date when patient eligibility for the program was verified or determined.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Status' ;
    rdfs:comment 'Status of the eligibility verification process to determine if patient qualifies for program benefits based on income, insurance, or other criteria.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing enrollment confirmation number provided to patient and HCP for reference and tracking purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source Record Reference' ;
    rdfs:comment 'Unique identifier of the enrollment record in the source system for traceability and reconciliation.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source System' ;
    rdfs:comment 'Source system or application from which the enrollment record originated (e.g., Veeva CRM, Salesforce Health Cloud, vendor portal).' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitDate rdf:type rdf:Property ;
    rdfs:label 'Exit Date' ;
    rdfs:comment 'Date when the patient exited or was terminated from the patient support program. Null if enrollment is still active.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'Reason for patient exit from the support program. Supports program retention and adherence analysis.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescribingNpi rdf:type rdf:Property ;
    rdfs:label 'Prescribing Npi' ;
    rdfs:comment 'National Provider Identifier of the prescribing healthcare professional. Used for Sunshine Act transparency reporting.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Benefit Amount' ;
    rdfs:comment 'Remaining financial benefit amount available to the patient under this enrollment.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Sales Performance Id' ;
    rdfs:comment 'Unique identifier for the sales performance record. Primary key for the sales performance data product.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Commercial sales performance should link to finance budgets for sales budget tracking and variance analysis. This enables integrated financial planning and performance management across commercial and' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:actualPerformanceAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Performance Amount' ;
    rdfs:comment 'Actual sales performance achieved during the period, measured in the same units as quota (prescription volume or revenue).' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callAttainmentPercent rdf:type rdf:Property ;
    rdfs:label 'Call Attainment Percent' ;
    rdfs:comment 'Percentage of target call frequency achieved, calculated as (call_frequency_achieved / call_frequency_target) * 100.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callFrequencyAchieved rdf:type rdf:Property ;
    rdfs:label 'Call Frequency Achieved' ;
    rdfs:comment 'Actual number of Healthcare Professional (HCP) calls completed by the sales representative during the performance period.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callFrequencyTarget rdf:type rdf:Property ;
    rdfs:label 'Call Frequency Target' ;
    rdfs:comment 'Target number of Healthcare Professional (HCP) calls planned for the sales representative during the performance period.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Source system or data provider for the sales performance metrics (e.g., Veeva CRM for call data, IQVIA for prescription data).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Compensation Amount' ;
    rdfs:comment 'Calculated incentive compensation earned by the sales representative for the performance period based on quota attainment.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveCompensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Incentive Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the incentive compensation amount.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSharePercent rdf:type rdf:Property ;
    rdfs:label 'Market Share Percent' ;
    rdfs:comment 'Brand market share as a percentage of total prescriptions in the therapeutic category within the territory during the performance period.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newPrescriptions rdf:type rdf:Property ;
    rdfs:label 'New Prescriptions' ;
    rdfs:comment 'Number of new prescriptions (NRx) written for the brand during the performance period, excluding refills.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performancePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period End Date' ;
    rdfs:comment 'End date of the performance measurement period (weekly, monthly, or quarterly cycle).' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performancePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period Start Date' ;
    rdfs:comment 'Start date of the performance measurement period (weekly, monthly, or quarterly cycle).' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Current status of the sales performance record in the review and approval workflow.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Type of performance measurement period: weekly, monthly, quarterly, or annual.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAttainmentPercent rdf:type rdf:Property ;
    rdfs:label 'Quota Attainment Percent' ;
    rdfs:comment 'Percentage of quota achieved, calculated as (actual_performance_amount / quota_amount) * 100. Used for incentive compensation calculation.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaCurrency rdf:type rdf:Property ;
    rdfs:label 'Quota Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quota amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDropRate rdf:type rdf:Property ;
    rdfs:label 'Sample Drop Rate' ;
    rdfs:comment 'Average number of sample units distributed per HCP call during the performance period.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleUnitsDistributed rdf:type rdf:Property ;
    rdfs:label 'Sample Units Distributed' ;
    rdfs:comment 'Total number of product sample units distributed by the sales representative during the performance period.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPrescriptions rdf:type rdf:Property ;
    rdfs:label 'Total Prescriptions' ;
    rdfs:comment 'Total number of prescriptions (TRx) written for the brand during the performance period, including both new and refill prescriptions.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:districtId rdf:type rdf:Property ;
    rdfs:label 'District Id' ;
    rdfs:comment 'Identifier of the sales district to which this representative\'s territory belongs. Districts aggregate multiple territories under a District Manager. Used for mid-level performance roll-up and quota management.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:primarySalesEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Employee Id' ;
    rdfs:comment 'Human Resources (HR) employee identifier sourced from SAP S/4HANA HCM or equivalent HR system of record. Links the commercial field force record to the enterprise workforce master. Used for payroll, benefits, and HR lifecycle cross-referencing.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regionId rdf:type rdf:Property ;
    rdfs:label 'Region Id' ;
    rdfs:comment 'Identifier of the sales region encompassing the representative\'s district. Regions aggregate multiple districts under a Regional Business Director. Used for regional P&L reporting and strategic planning.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:annualCallTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Call Target' ;
    rdfs:comment 'Target number of HCP sales calls (details) the representative is expected to complete within the fiscal year, as set by the commercial operations team. Used for field force productivity tracking and performance management in Veeva CRM.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date on which the sales representative\'s current product or compliance certification expires. Triggers re-certification workflows and may restrict sample distribution or promotional activity if expired.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment lifecycle status of the sales representative. Drives CRM access provisioning, territory assignment eligibility, sample authorization, and Sunshine Act reporting inclusion. Active = currently employed and field-active; On Leave = temporary absence (FMLA, medical, parental); Terminated = employment ended; Suspended = temporarily restricted from field activity; Pending Start = hired but not yet active.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpCertified rdf:type rdf:Property ;
    rdfs:label 'Gcp Certified' ;
    rdfs:comment 'Indicates whether the sales representative holds a current Good Clinical Practice (GCP) certification. Required for MSLs and reps supporting clinical trial site engagement or investigator-initiated study discussions. Sourced from the Learning Management System (LMS).' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcpEngagementTier rdf:type rdf:Property ;
    rdfs:label 'Hcp Engagement Tier' ;
    rdfs:comment 'Classification of the sales representative\'s HCP engagement level based on the complexity and strategic importance of their account portfolio. Tier 1 = high-value specialist/KOL accounts; Tier 2 = mid-level specialist accounts; Tier 3 = primary care/general accounts. Drives call frequency targets and resource allocation.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Official date on which the sales representative was hired by the organization, as recorded in the HR system of record (SAP S/4HANA). Used for tenure calculations, vesting schedules, and compliance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title of the sales representative as recorded in the HR system (e.g., \'Senior Specialty Sales Representative\', \'Oncology Territory Manager\', \'Medical Science Liaison\'). Used for organizational reporting and external business card / signature purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Product Certification Status' ;
    rdfs:comment 'Current status of the sales representative\'s product knowledge certification for their assigned brand(s). Reps must be certified before being authorized to promote a product or distribute samples. Sourced from the LMS or MasterControl/TrackWise training records.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repRole rdf:type rdf:Property ;
    rdfs:label 'Rep Role' ;
    rdfs:comment 'Commercial field force role classification defining the rep\'s function and engagement model. Territory Manager (TM) handles primary care accounts; Specialty Rep focuses on specialist HCPs; Key Account Manager (KAM) manages institutional/payer accounts; Medical Science Liaison (MSL) provides scientific exchange; Managed Care Specialist handles formulary access; National Account Manager handles national-level payer/GPO relationships. [ENUM-REF-CANDIDATE: territory_manager|specialty_rep|key_account_manager|medical_science_liaison|managed_care_specialist|national_account_manager — promote to reference product]' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Authorization Status' ;
    rdfs:comment 'Current authorization status of the sales representative to distribute drug samples to HCPs. Governed by the Prescription Drug Marketing Act (PDMA) and PhRMA Code. Suspended or revoked status prevents sample transactions in Veeva CRM.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speakerProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Speaker Program Eligible' ;
    rdfs:comment 'Indicates whether the sales representative is authorized to organize or facilitate HCP speaker programs on behalf of the company. Eligibility requires completion of speaker program compliance training and manager approval. Governed by PhRMA Code and OIG guidelines.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 state or province code for the primary operating geography of the sales representative (e.g., NY, CA, TX). Used for state-level compliance reporting, state Sunshine Act equivalents, and territory boundary management.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaCrmUserCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm User Code' ;
    rdfs:comment 'Unique user identifier assigned to the sales representative within Veeva CRM (Salesforce Health Cloud / Veeva CRM). Used to link field activity records, call logs, HCP interactions, and sample transactions back to the rep. Critical for CRM data lineage and compliance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaPromomatsAccess rdf:type rdf:Property ;
    rdfs:label 'Veeva Promomats Access' ;
    rdfs:comment 'Indicates whether the sales representative has active access to Veeva PromoMats for retrieving approved promotional materials. Access is role-based and tied to brand assignment and certification status. Ensures only MLR-approved content is used in HCP interactions.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'Corporate email address of the sales representative used for official business communications, Veeva CRM login, and system notifications. Sourced from the enterprise directory (e.g., Active Directory / SAP S/4HANA).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'Primary corporate mobile or desk phone number assigned to the sales representative for field communications and HCP engagement. Sourced from HR or CRM system.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleManagementId rdf:type rdf:Property ;
    rdfs:label 'Sample Management Id' ;
    rdfs:comment 'Primary key for sample_management' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleManagement .

ind:discrepancyQuantity rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Quantity' ;
    rdfs:comment 'Net difference between the physical count and the system-recorded quantity on hand during reconciliation. Non-zero values trigger a PDMA compliance investigation. Positive = overage; Negative = shortage.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Expiration date of the sample lot as printed on the package. Samples past this date must not be disbursed and must be removed from inventory per cGMP and PDMA requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hcpDeaNumber rdf:type rdf:Property ;
    rdfs:label 'Hcp Dea Number' ;
    rdfs:comment 'DEA registration number of the HCP, required when distributing controlled substance samples. Validates prescribing authority for scheduled drug samples per DEA regulations.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Hcp License Number' ;
    rdfs:comment 'State medical license number of the HCP at the time of sample disbursement. Required by PDMA to verify the HCP is a licensed practitioner authorized to receive samples. Captured at point of disbursement.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Hcp Signature Captured' ;
    rdfs:comment 'Indicates whether the HCP\'s electronic signature was captured at the time of sample disbursement, as required by PDMA. True = signature obtained; False = signature not obtained (requires justification).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcpSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hcp Signature Timestamp' ;
    rdfs:comment 'Date and time when the HCP\'s electronic signature was captured for the sample disbursement. Required for 21 CFR Part 11 electronic records compliance and PDMA audit trail.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryNumber rdf:type rdf:Property ;
    rdfs:label 'Inventory Number' ;
    rdfs:comment 'Externally-known business identifier for this sample inventory position record. Used for PDMA audit trails, reconciliation reports, and regulatory submissions. Generated by the sample management system (Veeva CRM or SAP MM).' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle state of the sample inventory position. Active = open and in use; Reconciled = periodic reconciliation completed; Closed = inventory position closed; Suspended = temporarily frozen pending investigation; Pending Review = flagged for compliance review.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturing lot or batch number assigned to the sample units in this inventory position. Critical for product recall management, quality investigations, and PDMA lot-level accountability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Code' ;
    rdfs:comment 'FDA-assigned National Drug Code uniquely identifying the drug product, dosage form, and package size of the sample. Required for PDMA compliance reporting and lot-level traceability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'Number of units (tablets, capsules, vials, etc.) contained in each sample package. Used to calculate total units disbursed and for PDMA annual accountability reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdmaCompliant rdf:type rdf:Property ;
    rdfs:label 'Pdma Compliant' ;
    rdfs:comment 'Indicates whether this sample transaction meets all PDMA compliance requirements (HCP signature captured, valid license verified, request form on file, quantity within limits). True = compliant; False = non-compliant, requires remediation.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityAdjusted rdf:type rdf:Property ;
    rdfs:label 'Quantity Adjusted' ;
    rdfs:comment 'Net quantity adjustment applied to the inventory position (positive = increase, negative = decrease). Used for inventory corrections, expired sample write-offs, and reconciliation discrepancy resolution.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityDisbursed rdf:type rdf:Property ;
    rdfs:label 'Quantity Disbursed' ;
    rdfs:comment 'Number of sample units disbursed to a Healthcare Professional (HCP) in this transaction. Zero for non-disbursement transaction types. Used for PDMA annual sample accountability and Sunshine Act reporting.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical inventory count of sample units held by the sales representative for this product/lot combination at the time of this record. Used for reconciliation and PDMA compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Number of sample units received by the sales representative from the warehouse, CMO, or another rep in this transaction. Zero for non-receipt transaction types.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationPeriod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period' ;
    rdfs:comment 'The fiscal quarter (e.g., \'2024-Q1\') to which this inventory reconciliation record belongs. PDMA requires periodic reconciliation of sample inventories. Used for compliance reporting and audit.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current status of the PDMA sample reconciliation process for this inventory position and period. Discrepancy Identified = physical count does not match system records; Resolved = discrepancy investigated and closed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleFormType rdf:type rdf:Property ;
    rdfs:label 'Sample Form Type' ;
    rdfs:comment 'Finished dosage form (FDF) type of the sample product (e.g., tablet, capsule, injectable). Used for inventory categorization, storage planning, and regulatory reporting. [ENUM-REF-CANDIDATE: tablet|capsule|injectable|topical|inhaler|liquid|patch|other — promote to reference product]' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequestFormNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Request Form Number' ;
    rdfs:comment 'Reference number of the HCP\'s written or electronic sample request form (SRF) associated with this disbursement. PDMA requires a signed request for each sample disbursement. Links to the eTMF or Veeva Vault document.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strength rdf:type rdf:Property ;
    rdfs:label 'Strength' ;
    rdfs:comment 'Dosage strength of the sample product (e.g., \'10 mg\', \'500 mg/5 mL\'). Distinguishes between different strength variants of the same product for inventory tracking and PDMA reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The real-world business date on which the sample transaction (disbursement, receipt, transfer, etc.) occurred. Used as the principal event date for PDMA reporting and Sunshine Act transparency reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Precise date and time when the sample transaction was recorded in the system (Veeva CRM or SAP). Provides sub-day precision for audit trail and compliance investigations.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the sample movement or inventory event. Disbursement = sample given to HCP; Receipt = samples received by rep; Transfer = rep-to-rep or warehouse transfer; Adjustment = inventory correction; Reconciliation = periodic count reconciliation; Return = samples returned to warehouse; Destruction = samples destroyed per policy. [ENUM-REF-CANDIDATE: disbursement|receipt|transfer|adjustment|reconciliation|return|destruction — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speakerEngagementId rdf:type rdf:Property ;
    rdfs:label 'Speaker Engagement Id' ;
    rdfs:comment 'Unique surrogate identifier for each speaker engagement record in the Databricks Silver layer. Primary key for this transactional entity.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commercialSpeakerProgramId rdf:type rdf:Property ;
    rdfs:label 'Commercial Speaker Program Id' ;
    rdfs:comment 'Reference to the parent speaker program event under which this individual engagement occurred. Links to the speaker program master record in Veeva CRM.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommercialSpeakerProgram .

ind:speakerContractId rdf:type rdf:Property ;
    rdfs:label 'Speaker Contract Id' ;
    rdfs:comment 'Reference identifier for the executed speaker bureau contract or consulting agreement governing this engagement. Links to the contract management system (e.g., Veeva Vault) for fair market value (FMV) validation and compliance documentation.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:attendanceConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Attendance Confirmation Date' ;
    rdfs:comment 'Date on which the HCP\'s attendance was formally confirmed and recorded in the system. Used for audit trail and compliance documentation.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attendanceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Attendance Confirmed' ;
    rdfs:comment 'Indicates whether the HCP\'s physical or virtual attendance at the speaker program has been formally confirmed and documented. Required for compliance validation before processing any transfer of value payment.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA cost center code to which the speaker engagement expenditure is allocated. Used for brand-level P&L reporting and commercial budget management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efpiaReportable rdf:type rdf:Property ;
    rdfs:label 'Efpia Reportable' ;
    rdfs:comment 'Indicates whether this engagement is reportable under the EFPIA Disclosure Code for European HCP transparency reporting. Applicable for engagements with HCPs in EU/EEA countries.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementNumber rdf:type rdf:Property ;
    rdfs:label 'Engagement Number' ;
    rdfs:comment 'Externally-known business reference number for this speaker engagement record, as assigned by Veeva CRM or the speaker bureau management system. Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmvCompliant rdf:type rdf:Property ;
    rdfs:label 'Fmv Compliant' ;
    rdfs:comment 'Indicates whether the honorarium paid for this engagement is within the pre-approved fair market value (FMV) range for this HCP. A value of False triggers a compliance review workflow. Critical for Anti-Kickback Statute compliance.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmvRate rdf:type rdf:Property ;
    rdfs:label 'Fmv Rate' ;
    rdfs:comment 'The pre-approved fair market value (FMV) hourly or per-engagement rate for this HCP\'s speaking services, as determined by an independent FMV assessment. Used to validate that honorarium payments do not exceed FMV, a key anti-kickback compliance requirement.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openPaymentsCategory rdf:type rdf:Property ;
    rdfs:label 'Open Payments Category' ;
    rdfs:comment 'CMS Open Payments program category under which this transfer of value is classified for federal reporting. \'general_payment\' covers speaker fees, meals, and travel. Determines the submission record type in the CMS Open Payments system.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openPaymentsNatureOfPayment rdf:type rdf:Property ;
    rdfs:label 'Open Payments Nature Of Payment' ;
    rdfs:comment 'CMS-defined nature of payment code describing the type of transfer of value (e.g., \'Speaking Fees\', \'Food and Beverage\', \'Travel and Lodging\', \'Education\'). Required field for CMS Open Payments submission. [ENUM-REF-CANDIDATE: speaking_fees|food_and_beverage|travel_and_lodging|education|consulting_fees|gift|entertainment|grant — promote to reference product]' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openPaymentsRecordCode rdf:type rdf:Property ;
    rdfs:label 'Open Payments Record Code' ;
    rdfs:comment 'CMS-assigned record identifier returned upon successful submission to the Open Payments system. Used for dispute resolution, correction submissions, and audit trail linking back to the federal database.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openPaymentsSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Open Payments Submission Status' ;
    rdfs:comment 'Status of this engagement record\'s submission to the CMS Open Payments (Sunshine Act) federal reporting system. Tracks the full submission lifecycle from initial filing through dispute resolution and correction.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationRole rdf:type rdf:Property ;
    rdfs:label 'Participation Role' ;
    rdfs:comment 'The role of the HCP in the speaker program event. Determines honorarium eligibility, transfer of value category for Sunshine Act reporting, and PhRMA code compliance classification.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phirmaCodeCompliant rdf:type rdf:Property ;
    rdfs:label 'Phirma Code Compliant' ;
    rdfs:comment 'Indicates whether this engagement fully complies with the PhRMA Code on Interactions with Healthcare Professionals, including meal value limits, venue appropriateness, and educational content requirements.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programFormat rdf:type rdf:Property ;
    rdfs:label 'Program Format' ;
    rdfs:comment 'Delivery format of the speaker program event. Determines applicable PhRMA code meal value caps (in-person only) and influences Sunshine Act reporting requirements for virtual engagements.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'Calendar year (YYYY) to which this engagement is attributed for CMS Open Payments annual reporting purposes. May differ from the engagement_date year in cases of late payments or corrections.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Number' ;
    rdfs:comment 'SAP S/4HANA vendor master number assigned to the HCP for accounts payable processing of honorarium and expense reimbursements. Required for payment processing through SAP FI/AP module.' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCity rdf:type rdf:Property ;
    rdfs:label 'Venue City' ;
    rdfs:comment 'City where the speaker program venue is located. Used for geographic analysis of speaker program distribution and state-level Sunshine Act reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCountryCode rdf:type rdf:Property ;
    rdfs:label 'Venue Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the speaker program venue is located. Supports international commercial operations and country-level compliance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueName rdf:type rdf:Property ;
    rdfs:label 'Venue Name' ;
    rdfs:comment 'Name of the physical venue or virtual platform where the speaker program was held. Required for in-person program compliance documentation and PhRMA code venue appropriateness review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueStateCode rdf:type rdf:Property ;
    rdfs:label 'Venue State Code' ;
    rdfs:comment 'Two-letter U.S. state code (or equivalent jurisdiction code) for the venue location. Used for state-level aggregate spend reporting and compliance with state transparency laws (e.g., Massachusetts, Vermont, Minnesota disclosure laws).' ;
    rdfs:domain ind:SpeakerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmvAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Fmv Assessment Id' ;
    rdfs:comment 'Reference to the fair market value (FMV) assessment record that validates the honorarium rate paid to the speaker is consistent with FMV for their credentials and specialty. Required for Anti-Kickback Statute compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FmvAssessment .

ind:logisticsVendorId rdf:type rdf:Property ;
    rdfs:label 'Logistics Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Speaker programs use event management, catering, AV, and venue vendors. Commercial operations procurement tracks vendor performance for program logistics, cost management, compliance verification, and' ;
    rdfs:domain ind:CommercialSpeakerProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:monitoringActivityId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Activity Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_monitoring_activity. Business justification: Speaker programs are subject to compliance monitoring audits for PhRMA Code adherence, FMV compliance, and transparency reporting. Links programs to monitoring activities for findings documentation an' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringActivity .

ind:mslProfileId rdf:type rdf:Property ;
    rdfs:label 'Msl Profile Id' ;
    rdfs:comment 'Foreign key linking to medical.msl_profile. Business justification: MSL scientific support for speaker programs including speaker training verification, scientific content review, and KOL identification/vetting. Standard pharmaceutical practice for ensuring scientific' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MslProfile .

ind:openPaymentsSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Open Payments Submission Id' ;
    rdfs:comment 'CMS Open Payments system submission identifier assigned upon successful filing of the transfer of value records associated with this program. Used for audit trail and resubmission tracking.' ;
    rdfs:domain ind:CommercialSpeakerProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:attendeeCountActual rdf:type rdf:Property ;
    rdfs:label 'Attendee Count Actual' ;
    rdfs:comment 'Actual number of HCP attendees who attended the speaker program. Used for per-attendee cost calculation and compliance validation.' ;
    rdfs:domain ind:CommercialSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendeeCountPlanned rdf:type rdf:Property ;
    rdfs:label 'Attendee Count Planned' ;
    rdfs:comment 'Number of HCP attendees planned for the speaker program at time of approval. Used for venue sizing, meal ordering, and budget estimation.' ;
    rdfs:domain ind:CommercialSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text or coded reason for cancellation of the speaker program. Populated only when program_status is \'cancelled\'. Used for operational analysis and budget recovery.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date on which the compliance review for this speaker program was completed. Used for audit trail and SOP adherence tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'Indicates whether the speaker program was delivered in-person, virtually (webinar), or as a hybrid event. Affects meal cap applicability and PhRMA code compliance rules.' ;
    rdfs:domain ind:CommercialSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phrmCodeCompliant rdf:type rdf:Property ;
    rdfs:label 'Phrm Code Compliant' ;
    rdfs:comment 'Indicates whether the speaker program was assessed as compliant with the PhRMA Code on Interactions with Healthcare Professionals, including meal cap, venue appropriateness, and educational content requirements.' ;
    rdfs:domain ind:CommercialSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programDate rdf:type rdf:Property ;
    rdfs:label 'Program Date' ;
    rdfs:comment 'The principal real-world date on which the speaker program event is scheduled or was held. Used as the event date for Sunshine Act Open Payments reporting period assignment.' ;
    rdfs:domain ind:CommercialSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programEndTime rdf:type rdf:Property ;
    rdfs:label 'Program End Time' ;
    rdfs:comment 'Precise date and time the speaker program event concludes. Used to calculate event duration and validate meal/entertainment cap compliance.' ;
    rdfs:domain ind:CommercialSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:programStartTime rdf:type rdf:Property ;
    rdfs:label 'Program Start Time' ;
    rdfs:comment 'Precise date and time the speaker program event begins. Used for scheduling, venue booking, and compliance audit trail.' ;
    rdfs:domain ind:CommercialSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:speakerTrainingVerified rdf:type rdf:Property ;
    rdfs:label 'Speaker Training Verified' ;
    rdfs:comment 'Indicates whether the lead speaker has completed mandatory speaker bureau training and certification prior to the program. Required for speaker bureau eligibility.' ;
    rdfs:domain ind:CommercialSpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:venueStateProvince rdf:type rdf:Property ;
    rdfs:label 'Venue State Province' ;
    rdfs:comment 'State or province of the speaker program venue. Used for state-level aggregate spend reporting and compliance with state transparency laws.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunshineDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Sunshine Disclosure Id' ;
    rdfs:comment 'Unique surrogate identifier for each Sunshine Act disclosure record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinicalTrialId rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Id' ;
    rdfs:comment 'Reference to the internal clinical trial record associated with this research payment disclosure. Populated when the transfer of value is linked to a specific clinical trial in the CTMS.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trial .

ind:disclosureId rdf:type rdf:Property ;
    rdfs:label 'Disclosure Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_disclosure. Business justification: Sunshine Act disclosures are a specific type of compliance disclosure submission. Links operational sunshine records to regulatory disclosure filings for CMS Open Payments reporting and audit reconcil' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Disclosure .

ind:grantId rdf:type rdf:Property ;
    rdfs:label 'Grant Id' ;
    rdfs:comment 'Foreign key linking to medical.medical_grant. Business justification: Sunshine Act reporting aggregates transfers of value from both commercial activities (speaker fees, meals) and medical grants to same recipients. Required for complete CMS Open Payments submission.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Sunshine Act payments must be recorded in GL. Disclosure records should reference underlying journal entries for audit trail and SOX compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:reviewedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sunshine Act compliance review tracking is mandatory for CMS Open Payments regulatory audit trail. Reviewed_by currently text; FK enables proper documentation of compliance personnel responsible for d' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cmsRecordCode rdf:type rdf:Property ;
    rdfs:label 'Cms Record Code' ;
    rdfs:comment 'Unique record identifier assigned by CMS upon successful submission to the Open Payments system. Used to track and reconcile submissions with the CMS portal. Null prior to submission.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctionIndicator rdf:type rdf:Property ;
    rdfs:label 'Correction Indicator' ;
    rdfs:comment 'Indicates whether this record is a corrected re-submission of a previously submitted disclosure. True when the record has been amended following a dispute resolution or internal data quality review.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the reason provided by the covered recipient for disputing this disclosure record. Populated when dispute_status is not no_dispute.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Status of any dispute raised by the covered recipient against this disclosure record during the CMS Open Payments review and dispute period. Tracks the resolution lifecycle of recipient-initiated disputes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOfPayment rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment' ;
    rdfs:comment 'Method by which the transfer of value was delivered to the covered recipient (e.g., cash, check, in-kind goods or services, stock). Required field for CMS Open Payments submission.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Reference Number' ;
    rdfs:comment 'Company-assigned internal tracking number for the disclosure record, used to cross-reference with source transactions in Veeva CRM, SAP, or other operational systems prior to CMS submission.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Internal Review Status' ;
    rdfs:comment 'Status of the internal compliance review process for this disclosure record prior to CMS submission. Tracks the company\'s internal approval workflow to ensure accuracy and PhRMA Code compliance before submission.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isResearchPayment rdf:type rdf:Property ;
    rdfs:label 'Is Research Payment' ;
    rdfs:comment 'Indicates whether this transfer of value is classified as a research payment under the CMS Open Payments research payment program, which has distinct reporting requirements from general payments.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalCmsRecordCode rdf:type rdf:Property ;
    rdfs:label 'Original Cms Record Code' ;
    rdfs:comment 'CMS-assigned record ID of the original submission that this record corrects or supersedes. Populated only when correction_indicator is True, enabling audit trail linkage between original and corrected records.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCategory rdf:type rdf:Property ;
    rdfs:label 'Payment Category' ;
    rdfs:comment 'CMS-defined category describing the nature of the transfer of value (e.g., consulting fees, honoraria, food and beverage, travel and lodging, education, research). Mandatory field for Open Payments submission. [ENUM-REF-CANDIDATE: consulting_fee|honoraria|food_and_beverage|travel_and_lodging|education|research|gift|entertainment|royalty_or_license|current_or_prospective_ownership — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date on which the transfer of value was provided to the covered recipient. This is the real-world event date used for annual program year assignment and CMS reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date on which CMS publicly published this disclosure record on the Open Payments website. Marks the point at which the record becomes publicly accessible.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recipientFirstName rdf:type rdf:Property ;
    rdfs:label 'Recipient First Name' ;
    rdfs:comment 'First (given) name of the covered recipient HCP as registered with CMS. Required for physician and non-physician practitioner records; not applicable for teaching hospitals.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Recipient Institution Name' ;
    rdfs:comment 'Legal name of the teaching hospital or healthcare organization receiving the transfer of value. Populated when recipient_type is covered_recipient_teaching_hospital; otherwise null.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientLastName rdf:type rdf:Property ;
    rdfs:label 'Recipient Last Name' ;
    rdfs:comment 'Last (family) name of the covered recipient HCP as registered with CMS. Required for physician and non-physician practitioner records; not applicable for teaching hospitals.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientNpi rdf:type rdf:Property ;
    rdfs:label 'Recipient Npi' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) of the Healthcare Professional (HCP) or teaching hospital receiving the transfer of value. Required field for CMS Open Payments submission and used to uniquely identify covered recipients.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPrimarySpecialty rdf:type rdf:Property ;
    rdfs:label 'Recipient Primary Specialty' ;
    rdfs:comment 'Primary medical specialty of the covered recipient physician or non-physician practitioner as registered with CMS (e.g., Internal Medicine, Oncology, Cardiology). Used for analytics and compliance segmentation.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientState rdf:type rdf:Property ;
    rdfs:label 'Recipient State' ;
    rdfs:comment 'Two-letter US state code of the covered recipient\'s primary practice or institution address, as registered with CMS. Used for geographic compliance reporting and territory analytics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'Classification of the payment recipient as defined by the Sunshine Act: a covered physician, a teaching hospital, or a non-physician practitioner (e.g., nurse practitioner, physician assistant). Determines applicable reporting rules.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchStudyName rdf:type rdf:Property ;
    rdfs:label 'Research Study Name' ;
    rdfs:comment 'Name of the clinical study or research project associated with this transfer of value, when is_research_payment is True. Corresponds to the study name as registered with CMS Open Payments research program.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date on which the internal compliance review of this disclosure record was completed. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the disclosure record within the CMS Open Payments submission workflow. [ENUM-REF-CANDIDATE: draft|pending_review|submitted|accepted|disputed|corrected|deleted — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyEntityName rdf:type rdf:Property ;
    rdfs:label 'Third Party Entity Name' ;
    rdfs:comment 'Name of the third-party entity that made the payment on behalf of the reporting company, when third_party_payment_flag is True. Required for indirect payment transparency reporting.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Payment Flag' ;
    rdfs:comment 'Indicates whether the payment was made by a third party (e.g., a CRO or CMO) on behalf of the reporting pharmaceutical company. Relevant for indirect payment disclosure requirements under the Sunshine Act.' ;
    rdfs:domain ind:SunshineDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryBrandId rdf:type rdf:Property ;
    rdfs:label 'Primary Brand Id' ;
    rdfs:comment 'FK to commercial.brand' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:alignmentVersion rdf:type rdf:Property ;
    rdfs:label 'Alignment Version' ;
    rdfs:comment 'Version identifier of the territory alignment cycle that produced this territory definition (e.g., \'FY2024-Q1\', \'ALIGN-2024-H2\'). Enables tracking of territory changes across realignment cycles and supports historical performance attribution.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'Code identifying the sales area (highest-level geographic grouping above region) to which this territory belongs. Supports national-level roll-up reporting and executive P&L attribution.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brickCount rdf:type rdf:Property ;
    rdfs:label 'Brick Count' ;
    rdfs:comment 'Number of geographic \'bricks\' (smallest geographic unit used in pharmaceutical territory alignment, typically a ZIP+4 or sub-ZIP unit) assigned to this territory. Used to measure territory size and workload balance during alignment planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callPlanFrequency rdf:type rdf:Property ;
    rdfs:label 'Call Plan Frequency' ;
    rdfs:comment 'Target number of calls (HCP visits) per representative per cycle (typically quarterly) for this territory as defined in the call plan. Used for field force productivity measurement and compliance tracking in Veeva CRM.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countyList rdf:type rdf:Property ;
    rdfs:label 'County List' ;
    rdfs:comment 'Semicolon-delimited list of county names or FIPS county codes included within this territory\'s geographic boundary. Complements ZIP code alignment for rural territory definitions and Sunshine Act county-level reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Crm Territory Code' ;
    rdfs:comment 'Native territory identifier from the source CRM system (Veeva CRM or Salesforce Health Cloud). Used for cross-system reconciliation, data lineage tracing, and integration with call activity and sample distribution records.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decileRank rdf:type rdf:Property ;
    rdfs:label 'Decile Rank' ;
    rdfs:comment 'Decile ranking (1–10) of the territory based on market potential or historical sales performance relative to all territories in the same alignment. Decile 1 represents the highest-potential territories. Used for resource allocation and call frequency prioritization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicAreaSqMiles rdf:type rdf:Property ;
    rdfs:label 'Geographic Area Sq Miles' ;
    rdfs:comment 'Total geographic area of the territory in square miles. Used to assess travel burden for field representatives and to balance territory workload during alignment planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOpenTerritory rdf:type rdf:Property ;
    rdfs:label 'Is Open Territory' ;
    rdfs:comment 'Indicates whether the territory is currently unassigned (open) with no active field representative. Open territories require coverage planning and may be temporarily covered by adjacent representatives or district managers.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpecialtyOverlay rdf:type rdf:Property ;
    rdfs:label 'Is Specialty Overlay' ;
    rdfs:comment 'Indicates whether this territory is a specialty overlay territory that operates in conjunction with a primary territory (e.g., an oncology specialist overlay on top of a primary care territory). Used to manage co-promotion and dual-rep call planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRealignmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Realignment Date' ;
    rdfs:comment 'Date on which this territory\'s boundaries, targets, or assignments were last modified as part of a formal territory realignment exercise. Used to track alignment cycle history and assess the currency of territory definitions.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketPotentialIndex rdf:type rdf:Property ;
    rdfs:label 'Market Potential Index' ;
    rdfs:comment 'Normalized index score (typically 0.0000–9.9999) representing the estimated prescribing potential of the territory based on IQVIA/IQVIA data, patient population, and payer mix. Used for territory sizing, quota setting, and alignment optimization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sunshineActReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Reporting Required' ;
    rdfs:comment 'Indicates whether HCP engagement activities within this territory are subject to mandatory Open Payments (Sunshine Act) transparency reporting to CMS. Typically true for US territories; false for territories outside US jurisdiction.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAccountCount rdf:type rdf:Property ;
    rdfs:label 'Target Account Count' ;
    rdfs:comment 'Number of institutional accounts (hospitals, clinics, group practices, IDNs) designated as call targets within this territory. Used for key account planning and workload analysis.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetHcpCount rdf:type rdf:Property ;
    rdfs:label 'Target Hcp Count' ;
    rdfs:comment 'Number of Healthcare Professionals (HCPs) designated as call targets within this territory for the current alignment cycle. Used for workload balancing, call planning, and field force sizing analysis.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the territory within the field force alignment system. Used as the business key in Veeva CRM and Salesforce Health Cloud for call planning and target assignment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the sales territory (e.g., \'Northeast Oncology Zone 3\'). Used for display in CRM dashboards, call planning tools, and performance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory record. Active territories are in use for call planning and performance attribution; inactive territories have been decommissioned; pending territories are awaiting activation in a future alignment cycle; archived territories are retained for historical reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory by its role in the field force structure. Primary territories are standard rep assignments; secondary territories represent overlapping coverage; specialty territories cover specific therapeutic areas; managed_care and key_account types address payer and institutional customers.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urbanRuralClassification rdf:type rdf:Property ;
    rdfs:label 'Urban Rural Classification' ;
    rdfs:comment 'Classification of the territory\'s geographic character as urban, suburban, rural, or mixed. Influences call planning strategy, travel time estimates, and field force resource allocation decisions.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workloadIndex rdf:type rdf:Property ;
    rdfs:label 'Workload Index' ;
    rdfs:comment 'Composite index score measuring the estimated field representative workload for this territory, factoring in target HCP count, call frequency, geographic travel burden, and account complexity. Used for territory balancing during alignment cycles.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zipCodeList rdf:type rdf:Property ;
    rdfs:label 'Zip Code List' ;
    rdfs:comment 'Semicolon-delimited list of US ZIP codes (or equivalent postal codes) that define the geographic boundary of this territory. Used for HCP target assignment, call planning, and territory alignment in Veeva CRM. Stored as a delimited string per Silver Layer conventions; spatial decomposition occurs in the Gold Layer.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationId rdf:type rdf:Property ;
    rdfs:label 'Attestation Id' ;
    rdfs:comment 'Unique identifier for the compliance attestation record. Primary key for the compliance attestation entity.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attestationAttestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Attestation Attestor Employee Id' ;
    rdfs:comment 'Identifier of the employee submitting the attestation. Links to the employee master data record.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attestationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Attestation Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this attestation record. Provides audit trail for record changes.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attestorSiteId rdf:type rdf:Property ;
    rdfs:label 'Attestor Site Id' ;
    rdfs:comment 'Identifier of the physical site or location where the attestor is based. Critical for GxP and site-specific compliance tracking.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Identifier of the compliance officer or manager who reviewed and approved this attestation. Null if attestation is pending review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attestationNumber rdf:type rdf:Property ;
    rdfs:label 'Attestation Number' ;
    rdfs:comment 'Business-facing unique identifier for the attestation, formatted as ATT-YYYYNNNN for external reference and audit trail purposes.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationStatus rdf:type rdf:Property ;
    rdfs:label 'Attestation Status' ;
    rdfs:comment 'Current lifecycle status of the attestation record. Tracks progression from submission through approval or rejection. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|expired|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationType rdf:type rdf:Property ;
    rdfs:label 'Attestation Type' ;
    rdfs:comment 'Category of compliance attestation being submitted. Defines the regulatory or policy framework under which the attestation is made.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestorDepartment rdf:type rdf:Property ;
    rdfs:label 'Attestor Department' ;
    rdfs:comment 'Organizational department or business unit of the attestor. Used for compliance reporting and analytics by organizational segment.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestorEmail rdf:type rdf:Property ;
    rdfs:label 'Attestor Email' ;
    rdfs:comment 'Corporate email address of the attestor at the time of submission. Used for confirmation and audit trail.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestorJobTitle rdf:type rdf:Property ;
    rdfs:label 'Attestor Job Title' ;
    rdfs:comment 'Job title or role of the attestor at the time of attestation submission. Provides context for attestation authority and scope.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestorName rdf:type rdf:Property ;
    rdfs:label 'Attestor Name' ;
    rdfs:comment 'Full legal name of the individual submitting the attestation. Captured at time of submission for audit trail purposes.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:content rdf:type rdf:Property ;
    rdfs:label 'Content' ;
    rdfs:comment 'Full text of the attestation statement that the attestor is certifying. Captures the exact language of the commitment or declaration made.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignature rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature' ;
    rdfs:comment 'Electronic signature or digital signature hash applied by the attestor to certify the attestation. Meets 21 CFR Part 11 requirements for electronic records.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed description of any exceptions, qualifications, or instances of non-compliance disclosed by the attestor. Null if no exceptions were disclosed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionsDisclosedFlag rdf:type rdf:Property ;
    rdfs:label 'Exceptions Disclosed Flag' ;
    rdfs:comment 'Indicates whether the attestor disclosed any exceptions, qualifications, or non-compliance instances as part of this attestation. True if exceptions were disclosed, false otherwise.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter to which this attestation applies, if applicable. Used for quarterly SOX sub-certifications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year to which this attestation applies. Used for SOX certifications and annual compliance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether follow-up action or investigation is required based on disclosed exceptions or review findings. True if follow-up is needed, false otherwise.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpCategory rdf:type rdf:Property ;
    rdfs:label 'Gxp Category' ;
    rdfs:comment 'Category of Good Practice regulation that this attestation covers. Applicable for GxP compliance declarations in pharmaceutical operations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address from which the attestation was submitted. Captured for audit trail and security purposes per 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic jurisdiction or country code where this attestation applies. Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'Ending date of the period covered by this attestation. Together with start date defines the attestation coverage window.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Beginning date of the period covered by this attestation. Defines the temporal scope of compliance being certified.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version number of the compliance policy or code of conduct document that the attestor is certifying adherence to. Ensures attestations are tied to specific policy versions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory framework or standard that governs this attestation (e.g., 21 CFR Part 11, GDPR, HIPAA). Provides regulatory context for the attestation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Comments or notes entered by the reviewer during the attestation review process. May include reasons for rejection or requests for clarification.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the attestation was reviewed and approved or rejected by the compliance reviewer. Null if not yet reviewed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk level associated with this attestation based on the role, scope, and exceptions disclosed. Used for prioritizing compliance reviews and follow-up actions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxSection rdf:type rdf:Property ;
    rdfs:label 'Sox Section' ;
    rdfs:comment 'Specific section of the Sarbanes-Oxley Act that this attestation relates to, if applicable. Primarily used for CEO/CFO certifications and internal control attestations.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method or channel through which the attestation was submitted. Tracks the interface used for compliance reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the attestation was formally submitted by the attestor. Serves as the official submission record for audit and compliance purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when the attestor completed the required compliance training associated with this attestation. Null if training was not required or not completed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCompletionFlag rdf:type rdf:Property ;
    rdfs:label 'Training Completion Flag' ;
    rdfs:comment 'Indicates whether required compliance training was completed prior to attestation submission. True if training was completed, false otherwise.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCapaId rdf:type rdf:Property ;
    rdfs:label 'Compliance Capa Id' ;
    rdfs:comment 'Unique identifier for the compliance CAPA record. Primary key for compliance-function-owned CAPAs addressing regulatory, SOX, and privacy remediation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceCapa .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to masterdata.cost_center. Business justification: Compliance CAPAs incur costs (remediation, system upgrades, consulting). Cost centers track compliance spending for budgeting and variance analysis. Required for financial planning, cost allocation, a' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:soxControlTestId rdf:type rdf:Property ;
    rdfs:label 'Sox Control Test Id' ;
    rdfs:comment 'Reference identifier for the SOX control that was deficient, if this CAPA addresses a SOX control deficiency.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoxControlTest .

ind:triggeringEventId rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Id' ;
    rdfs:comment 'Reference identifier for the originating event (e.g., inspection observation number, audit finding ID, SOX control ID, incident ticket number).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TriggeringEvent .

ind:actionOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Action Owner Department' ;
    rdfs:comment 'Department or functional area of the action owner (e.g., Regulatory Affairs, Quality Assurance, IT Compliance, Legal).' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwnerName rdf:type rdf:Property ;
    rdfs:label 'Action Owner Name' ;
    rdfs:comment 'Full name of the individual assigned as the action owner for this compliance CAPA.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when all CAPA actions were completed. Null if still in progress.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedRegulation rdf:type rdf:Property ;
    rdfs:label 'Affected Regulation' ;
    rdfs:comment 'Specific regulation, standard, or requirement that was violated or at risk (e.g., 21 CFR Part 11, EU Annex 11, GDPR Article 32, SOX Section 404).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business identifier for the compliance CAPA, typically formatted as CCAPA-NNNNNN. Used for external communication and tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the compliance CAPA: open (initiated), in progress (actions underway), pending review (awaiting approval), effectiveness check (verifying success), closed (completed and verified), or cancelled (no longer applicable).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classification of the CAPA as corrective (addressing existing deficiency), preventive (mitigating potential risk), or combined (both corrective and preventive actions).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerificationBy rdf:type rdf:Property ;
    rdfs:label 'Closure Verification By' ;
    rdfs:comment 'Name or role of the individual who verified and approved CAPA closure (typically compliance manager, quality director, or regulatory lead).' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Closure Verification Date' ;
    rdfs:comment 'Date when the CAPA was formally verified as complete and closed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Detailed description of corrective actions to be taken to address the existing compliance deficiency and prevent recurrence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityAlcoaPlusFlag rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Alcoa Plus Flag' ;
    rdfs:comment 'Boolean indicator whether this CAPA addresses a data integrity deficiency related to ALCOA+ principles (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available).' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivenessCheckCriteria rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Criteria' ;
    rdfs:comment 'Defined criteria and metrics to verify that the CAPA actions effectively resolved the deficiency and prevented recurrence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Date' ;
    rdfs:comment 'Date when the effectiveness check was performed to verify CAPA success.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Result' ;
    rdfs:comment 'Outcome of the effectiveness check: effective (CAPA resolved issue), partially effective (some improvement), ineffective (issue persists), or pending (check not yet performed).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the CAPA was escalated to higher authority or governance body.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Boolean indicator whether this CAPA requires escalation to senior management, regulatory authority, or board-level governance committee.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionCitationReference rdf:type rdf:Property ;
    rdfs:label 'Inspection Citation Reference' ;
    rdfs:comment 'Specific citation or observation number from regulatory inspection report (e.g., FDA 483 observation number, EMA inspection finding reference).' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Username or identifier of the individual who last modified the compliance CAPA record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Plan' ;
    rdfs:comment 'Detailed description of preventive actions to be taken to mitigate similar compliance risks in other areas or future scenarios.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Due Date' ;
    rdfs:comment 'Deadline by which formal response to regulatory authority must be submitted.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryResponseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Required Flag' ;
    rdfs:comment 'Boolean indicator whether a formal response to regulatory authority is required for this CAPA (e.g., FDA 483 response, EMA inspection response).' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryResponseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Submitted Date' ;
    rdfs:comment 'Date when formal response to regulatory authority was submitted.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'Methodology used to determine root cause: 5 Whys, Fishbone (Ishikawa), Fault Tree Analysis, Pareto Analysis, Failure Mode and Effects Analysis (FMEA), or other structured approach.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorization of the root cause: process deficiency, people/competency gap, technology/system failure, documentation inadequacy, training gap, or oversight/governance weakness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDetermination rdf:type rdf:Property ;
    rdfs:label 'Root Cause Determination' ;
    rdfs:comment 'Detailed narrative of the identified root cause(s) of the compliance deficiency, based on the RCA methodology applied.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Severity classification of the compliance deficiency: critical (immediate regulatory action risk), major (significant compliance gap), moderate (notable issue), minor (low impact).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which all corrective and preventive actions must be completed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringEventDate rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Date' ;
    rdfs:comment 'Date when the triggering event occurred or was identified (e.g., inspection date, audit date, incident date).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringEventType rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Type' ;
    rdfs:comment 'Category of event that initiated the compliance CAPA. Includes regulatory inspections, audit findings, SOX control deficiencies, GDPR breaches, and data integrity incidents.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Identifier of the senior employee or executive who provided final approval for the compliance disclosure submission, typically a Chief Compliance Officer or General Counsel.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disclosurePreparerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Disclosure Preparer Employee Id' ;
    rdfs:comment 'Identifier of the employee who prepared or compiled the compliance disclosure filing.' ;
    rdfs:domain ind:Disclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originalDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Original Disclosure Id' ;
    rdfs:comment 'Reference to the original compliance disclosure record that this filing amends or replaces, establishing the amendment chain for audit purposes.' ;
    rdfs:domain ind:Disclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Disclosure .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the regulatory authority acknowledged receipt and acceptance of the compliance disclosure.' ;
    rdfs:domain ind:Disclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Receipt Number' ;
    rdfs:comment 'Confirmation or receipt number issued by the regulatory authority upon successful submission and acceptance of the compliance disclosure.' ;
    rdfs:domain ind:Disclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Business justification or explanation for amending a previously submitted compliance disclosure, documenting what was corrected or updated.' ;
    rdfs:domain ind:Disclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Total aggregate monetary value disclosed in this filing, representing the sum of all transfers of value, payments, or financial transactions covered by the disclosure for the reporting period. Null for non-monetary disclosures such as conflict of interest declarations.' ;
    rdfs:domain ind:Disclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the operational system or application from which the underlying transaction data for this compliance disclosure was extracted (e.g., Veeva CRM, SAP, Argus Safety).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureNumber rdf:type rdf:Property ;
    rdfs:label 'Disclosure Number' ;
    rdfs:comment 'Externally-known unique business identifier for the compliance disclosure filing, typically formatted as DISC-YYYY-NNNNNN.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Current lifecycle status of the compliance disclosure: draft (in preparation), pending_review (awaiting internal approval), submitted (filed with regulatory body), acknowledged (receipt confirmed by authority), rejected (returned for correction), amended (resubmitted after correction), or withdrawn (cancelled). [ENUM-REF-CANDIDATE: draft|pending_review|submitted|acknowledged|rejected|amended|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureType rdf:type rdf:Property ;
    rdfs:label 'Disclosure Type' ;
    rdfs:comment 'Category of compliance disclosure: Sunshine Act / Open Payments aggregate disclosure, EFPIA Disclosure Code submission, anti-bribery declaration, conflict of interest disclosure, beneficial ownership filing, or other regulatory filing type.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Regulatory deadline by which the compliance disclosure must be submitted to remain in compliance with applicable laws and regulations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationUrl rdf:type rdf:Property ;
    rdfs:label 'Publication Url' ;
    rdfs:comment 'Web address where the compliance disclosure has been publicly published, if applicable (e.g., EFPIA disclosures are typically published on company websites or central platforms).' ;
    rdfs:domain ind:Disclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCount rdf:type rdf:Property ;
    rdfs:label 'Recipient Count' ;
    rdfs:comment 'Total number of individual recipients (Healthcare Professionals, Healthcare Organizations, or other parties) included in this aggregate compliance disclosure. Applicable primarily to Sunshine Act and EFPIA disclosures.' ;
    rdfs:domain ind:Disclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the reporting period covered by this compliance disclosure, typically the end of the calendar or fiscal year for annual aggregate disclosures.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the reporting period covered by this compliance disclosure, typically the beginning of the calendar or fiscal year for annual aggregate disclosures.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittingEntityName rdf:type rdf:Property ;
    rdfs:label 'Submitting Entity Name' ;
    rdfs:comment 'Legal name of the entity submitting the compliance disclosure, as registered with regulatory authorities.' ;
    rdfs:domain ind:Disclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentLocation rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Location' ;
    rdfs:comment 'File path, document management system reference, or storage location for supporting documentation, evidence, and source data used to prepare the compliance disclosure.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'Total number of individual transfer of value transactions aggregated and reported in this compliance disclosure filing.' ;
    rdfs:domain ind:Disclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedSiteId rdf:type rdf:Property ;
    rdfs:label 'Affected Site Id' ;
    rdfs:comment 'Identifier of the manufacturing site, clinical site, or facility where the incident occurred.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:incidentClosureApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incident Closure Approved By Employee Id' ;
    rdfs:comment 'Identifier of the quality or compliance manager who approved the closure of the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:incidentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incident Employee Id' ;
    rdfs:comment 'Identifier of the employee assigned as the primary owner responsible for investigating the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:incidentReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incident Reported By Employee Id' ;
    rdfs:comment 'Identifier of the employee or individual who initially reported the compliance incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Compliance incidents (deviations, data integrity issues) occur at specific sites. Root cause and CAPA are site-specific. Essential for incident investigation, trend analysis, regulatory reporting. Rem' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Actual date when the incident was formally closed after completion of investigation and corrective actions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Batch Number' ;
    rdfs:comment 'Batch or lot number of the affected product, if the incident is batch-specific.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedFunction rdf:type rdf:Property ;
    rdfs:label 'Affected Function' ;
    rdfs:comment 'Business function or department where the incident occurred (e.g., Manufacturing, Quality Control, Clinical Operations, Regulatory Affairs).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductName rdf:type rdf:Property ;
    rdfs:label 'Affected Product Name' ;
    rdfs:comment 'Name of the product affected by the compliance incident.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRegulationSection rdf:type rdf:Property ;
    rdfs:label 'Affected Regulation Section' ;
    rdfs:comment 'Specific section, article, or clause of the regulation that was violated.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Authority Notification Date' ;
    rdfs:comment 'Date when the regulatory authority was notified of the incident, if reportable.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Authority Reference Number' ;
    rdfs:comment 'Reference or tracking number assigned by the regulatory authority upon notification.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRequired rdf:type rdf:Property ;
    rdfs:label 'Capa Required' ;
    rdfs:comment 'Indicates whether a formal CAPA is required to address the root cause and prevent recurrence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureApprovedByName rdf:type rdf:Property ;
    rdfs:label 'Closure Approved By Name' ;
    rdfs:comment 'Full name of the individual who approved the incident closure.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentEffective rdf:type rdf:Property ;
    rdfs:label 'Containment Effective' ;
    rdfs:comment 'Indicates whether immediate containment actions were effective in preventing further impact.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Date when the compliance incident was first identified or discovered.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Precise date and time when the compliance incident was first identified, including timezone.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Indicates the level to which the incident has been escalated within the organization based on severity and impact.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of immediate containment or corrective actions taken upon discovery of the incident to prevent further impact.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'Primary classification of the compliance incident type. Categories align with major compliance program areas.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the compliance incident, including what occurred, where, and initial observations.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Business-facing unique incident tracking number assigned upon incident creation. Format: INC-YYYYMMDD-sequence.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the compliance incident in the investigation and resolution workflow.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationOwnerName rdf:type rdf:Property ;
    rdfs:label 'Investigation Owner Name' ;
    rdfs:comment 'Full name of the employee responsible for leading the incident investigation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Occurrence Date' ;
    rdfs:comment 'Actual or estimated date when the compliance incident occurred or began. May differ from discovery date.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportableToAuthority rdf:type rdf:Property ;
    rdfs:label 'Reportable To Authority' ;
    rdfs:comment 'Indicates whether the incident must be reported to a regulatory authority per applicable regulations.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Full name of the individual who reported the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk rating considering both likelihood and impact of the compliance incident.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed description of the identified root cause(s) of the compliance incident, determined through investigation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing additional granularity within the incident category (e.g., GMP deviation, GCP protocol violation, GDPR breach).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Planned or target date by which the incident investigation and all corrective actions should be completed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryMonitoringMonitorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Monitoring Monitor Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee who conducted the compliance monitoring activity. Links to the human resources employee master data.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityNumber rdf:type rdf:Property ;
    rdfs:label 'Activity Number' ;
    rdfs:comment 'Business-facing unique identifier for the compliance monitoring activity, formatted as CMA-YYYYNNNN for external reference and tracking.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alcoaPlusAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Alcoa Plus Assessment Flag' ;
    rdfs:comment 'Boolean indicator of whether this monitoring activity specifically assessed data integrity compliance against ALCOA+ principles (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available). True indicates ALCOA+ assessment was performed.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Boolean indicator of whether formal Corrective and Preventive Action (CAPA) is required based on the monitoring findings. True indicates CAPA must be initiated; false indicates findings can be addressed through informal actions or no action required.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Evidence Location' ;
    rdfs:comment 'File path, document management system location, or repository reference where supporting evidence and documentation for the monitoring activity is stored.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the compliance monitoring activity was actually performed or executed. Represents the real-world business event timestamp for the monitoring action.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'Total number of compliance findings, observations, or exceptions identified during the monitoring activity. Zero indicates no issues found.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionReadinessImpact rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Impact' ;
    rdfs:comment 'Assessment of how the monitoring findings impact the organizations readiness for regulatory inspection. Positive indicates findings improve readiness; neutral indicates no impact; negative indicates findings expose inspection vulnerabilities.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitorName rdf:type rdf:Property ;
    rdfs:label 'Monitor Name' ;
    rdfs:comment 'Full name of the compliance professional or auditor who conducted the monitoring activity.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoredFunction rdf:type rdf:Property ;
    rdfs:label 'Monitored Function' ;
    rdfs:comment 'Name of the business function or department being monitored, such as Commercial, Clinical Operations, Manufacturing, Quality Assurance, Regulatory Affairs, or Medical Affairs.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoredSiteCode rdf:type rdf:Property ;
    rdfs:label 'Monitored Site Code' ;
    rdfs:comment 'Code identifying the specific site, facility, or location being monitored. May reference manufacturing plants, clinical sites, distribution centers, or office locations.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoredSiteName rdf:type rdf:Property ;
    rdfs:label 'Monitored Site Name' ;
    rdfs:comment 'Full name of the site, facility, or location being monitored for compliance.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringMethodology rdf:type rdf:Property ;
    rdfs:label 'Monitoring Methodology' ;
    rdfs:comment 'Approach or method used to conduct the compliance monitoring activity. Includes desk review of documentation, on-site inspection, remote audit, data analytics and automated monitoring, statistical sampling, or continuous monitoring techniques.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringNotes rdf:type rdf:Property ;
    rdfs:label 'Monitoring Notes' ;
    rdfs:comment 'Additional notes, observations, or contextual information captured during the monitoring activity that provide supplementary detail beyond the structured findings.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Monitoring Period End Date' ;
    rdfs:comment 'End date of the period being monitored. Defines the conclusion of the timeframe for which compliance activities are being reviewed.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Monitoring Period Start Date' ;
    rdfs:comment 'Start date of the period being monitored. Defines the beginning of the timeframe for which compliance activities are being reviewed.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringScope rdf:type rdf:Property ;
    rdfs:label 'Monitoring Scope' ;
    rdfs:comment 'Detailed description of the scope of the compliance monitoring activity, including specific processes, systems, sites, or functions being monitored and the boundaries of the monitoring effort.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Status' ;
    rdfs:comment 'Current lifecycle status of the compliance monitoring activity. Tracks progression from planning through execution to completion or cancellation.' ;
    rdfs:domain ind:MonitoringActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Type' ;
    rdfs:comment 'Category of compliance monitoring activity being conducted. Includes Healthcare Professional (HCP) engagement monitoring for Sunshine Act compliance, promotional materials compliance monitoring, clinical trial compliance monitoring, Good Practice (GxP) process compliance monitoring, data integrity monitoring per ALCOA+ principles, and Sarbanes-Oxley (SOX) control monitoring.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationSize rdf:type rdf:Property ;
    rdfs:label 'Population Size' ;
    rdfs:comment 'Total number of records, transactions, or items in the population from which the monitoring sample was drawn. Provides context for sample representativeness.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'Detailed recommendations for corrective actions, process improvements, or remediation steps to address the findings identified during the monitoring activity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which remediation actions or corrective measures must be completed to address the monitoring findings. Null if no remediation is required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation efforts to address the monitoring findings. Tracks progress from identification through completion of corrective actions.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the compliance manager or supervisor who reviewed and approved the monitoring activity results.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of records, transactions, or items included in the monitoring sample when sampling methodology is used. Null for full population reviews or continuous monitoring.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: Compliance programs are organized by business unit (Quality, Manufacturing, Clinical). Program ownership and budget allocation follow org structure. Required for program governance, resource planning,' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:programEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Employee Id' ;
    rdfs:comment 'Identifier of the executive or senior manager accountable for the compliance program. Typically a Vice President of Quality, Chief Compliance Officer, or functional head.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alcoaPlusCompliant rdf:type rdf:Property ;
    rdfs:label 'Alcoa Plus Compliant' ;
    rdfs:comment 'Indicates whether the compliance program enforces ALCOA+ data integrity principles: Attributable, Legible, Contemporaneous, Original, Accurate, plus Complete, Consistent, Enduring, and Available. Critical for GxP compliance programs.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdictions' ;
    rdfs:comment 'Comma-separated list of countries or regulatory regions where this compliance program applies. Uses three-letter ISO country codes (e.g., USA, GBR, DEU, JPN, CHN) or regional codes (e.g., EU for European Union member states).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Annual budget allocated to the compliance program in USD, covering personnel, training, technology, consulting, and audit costs.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget amount. Typically USD for global pharmaceutical enterprises.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaIntegration rdf:type rdf:Property ;
    rdfs:label 'Capa Integration' ;
    rdfs:comment 'Indicates whether this compliance program is integrated with the enterprise CAPA system for tracking and resolving compliance deviations, audit findings, and quality issues.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Status of external certification or accreditation for this compliance program. Examples include ISO 37301 certification, SOX attestation, or industry-specific accreditation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterDocument rdf:type rdf:Property ;
    rdfs:label 'Charter Document' ;
    rdfs:comment 'Reference identifier or document management system location for the formal program charter that defines objectives, governance, roles, responsibilities, and success criteria.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csvRequired rdf:type rdf:Property ;
    rdfs:label 'Csv Required' ;
    rdfs:comment 'Indicates whether systems covered by this compliance program require formal Computer System Validation per 21 CFR Part 11, EU Annex 11, or GAMP 5 guidelines.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the escalation path and notification procedures for compliance breaches, audit findings, or regulatory issues identified within this program. Includes roles, timelines, and communication protocols.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditFirm rdf:type rdf:Property ;
    rdfs:label 'External Audit Firm' ;
    rdfs:comment 'Name of the external audit or consulting firm that provides independent assessment or certification of this compliance program. Applicable for SOX, ISO, or third-party GxP audits.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceCommittee rdf:type rdf:Property ;
    rdfs:label 'Governance Committee' ;
    rdfs:comment 'Name of the cross-functional governance committee or steering group that oversees this compliance program. Examples include Quality Council, Compliance Steering Committee, or Data Integrity Governance Board.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Level' ;
    rdfs:comment 'Assessment of the programs preparedness for regulatory inspection or external audit. Inspection Ready indicates all documentation, training, and evidence are current and accessible. Audit Verified indicates recent successful inspection or third-party audit.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyPerformanceIndicators rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicators' ;
    rdfs:comment 'Comma-separated list of key performance indicators used to measure compliance program effectiveness. Examples include training completion rate, audit finding closure rate, deviation response time, or inspection deficiency count.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection or external audit that assessed this compliance program.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review or assessment of the compliance program by the governance committee or internal audit function.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the compliance program across the enterprise. Used in regulatory submissions and audit documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Comprehensive description of the compliance programs objectives, regulatory obligations, key controls, and business impact. Used in governance materials and regulatory submissions.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Official name of the compliance program as documented in the program charter and governance materials.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programScope rdf:type rdf:Property ;
    rdfs:label 'Program Scope' ;
    rdfs:comment 'Detailed description of the business functions, processes, systems, and geographic regions covered by this compliance program. Defines boundaries and applicability across the enterprise.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCadence rdf:type rdf:Property ;
    rdfs:label 'Reporting Cadence' ;
    rdfs:comment 'Frequency at which program performance metrics, compliance status, and risk indicators are reported to governance committees and executive leadership. [ENUM-REF-CANDIDATE: Weekly|Biweekly|Monthly|Quarterly|Semiannual|Annual|Ad Hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Enterprise risk classification of the compliance program based on potential regulatory, financial, and reputational impact. Critical tier programs address patient safety, product quality, or financial reporting. High tier programs address significant regulatory obligations. Medium and Low tier programs address operational compliance requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopCount rdf:type rdf:Property ;
    rdfs:label 'Sop Count' ;
    rdfs:comment 'Number of Standard Operating Procedures (SOPs) that define processes and controls for this compliance program. Indicates program maturity and documentation completeness.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Training Frequency Months' ;
    rdfs:comment 'Number of months between required refresher training cycles for personnel covered by this compliance program. Typical values are 12 (annual), 24 (biennial), or 36 (triennial) months.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether personnel working under this compliance program must complete mandatory training and demonstrate competency. Required for all GxP programs per ICH guidelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Unique identifier for the compliance risk register entry. Primary key for the compliance risk register.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskRegister .

ind:primaryRiskOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee who is accountable for managing and monitoring this compliance risk. Typically a senior leader or functional head.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRiskLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Risk Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who most recently modified this compliance risk register record. Required for 21 CFR Part 11 electronic signature and audit trail compliance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRiskCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Risk Created By Employee Id' ;
    rdfs:comment 'Identifier of the employee who created this compliance risk register record. Required for 21 CFR Part 11 electronic signature and audit trail compliance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdiction' ;
    rdfs:comment 'Geographic or regulatory jurisdiction(s) where this compliance risk applies. Comma-separated list of ISO 3166-1 alpha-3 country codes or regional identifiers (e.g., USA, GBR, DEU, EU, APAC).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Board Reporting Flag' ;
    rdfs:comment 'Indicates whether this compliance risk is included in Board Audit Committee reporting. True for Critical risks, material compliance exposures, and risks with significant financial or reputational impact.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness' ;
    rdfs:comment 'Assessment of how well existing controls are operating to mitigate the compliance risk. Effective indicates controls are operating as designed; Partially Effective indicates gaps or weaknesses; Ineffective indicates controls are not functioning; Not Tested indicates controls have not been evaluated.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:existingControlsDescription rdf:type rdf:Property ;
    rdfs:label 'Existing Controls Description' ;
    rdfs:comment 'Narrative description of current controls, processes, and safeguards in place to mitigate the compliance risk. Includes preventive controls, detective controls, and corrective controls.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'Date when the compliance risk was first identified and entered into the risk register.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identificationSource rdf:type rdf:Property ;
    rdfs:label 'Identification Source' ;
    rdfs:comment 'Origin or method by which the compliance risk was identified. Sources include internal audit findings, external audit observations, regulatory inspection findings, self-assessment activities, Corrective and Preventive Action (CAPA) investigations, incident reports, management review, or third-party assessments. [ENUM-REF-CANDIDATE: Internal Audit|External Audit|Regulatory Inspection|Self-Assessment|CAPA|Incident Report|Management Review|Third-Party Assessment — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentImpact rdf:type rdf:Property ;
    rdfs:label 'Inherent Impact' ;
    rdfs:comment 'Severity or magnitude of consequences if the compliance risk materializes, without considering existing controls. Rated on a five-point scale from Very Low to Very High. Impact dimensions include patient safety, product quality, regulatory sanctions, financial loss, and reputational damage.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentLikelihood rdf:type rdf:Property ;
    rdfs:label 'Inherent Likelihood' ;
    rdfs:comment 'Probability or frequency of the compliance risk occurring in the absence of any controls. Rated on a five-point scale from Very Low to Very High.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'Qualitative inherent risk classification derived from the inherent risk score. Used for risk prioritization and resource allocation. Critical risks require immediate executive attention and Board notification.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Quantitative inherent risk rating calculated as likelihood multiplied by impact, using a numerical scale (e.g., 1-25 where Very Low=1, Low=2, Medium=3, High=4, Very High=5). Represents risk exposure before controls.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualImpact rdf:type rdf:Property ;
    rdfs:label 'Residual Impact' ;
    rdfs:comment 'Severity or magnitude of consequences if the compliance risk materializes, after considering the effectiveness of existing controls. Rated on a five-point scale from Very Low to Very High.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualLikelihood rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood' ;
    rdfs:comment 'Probability or frequency of the compliance risk occurring after considering the effectiveness of existing controls. Rated on a five-point scale from Very Low to Very High.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Qualitative residual risk classification derived from the residual risk score. Used for risk appetite alignment and treatment decision-making.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Quantitative residual risk rating calculated as residual likelihood multiplied by residual impact. Represents risk exposure after considering existing controls. Used for risk acceptance decisions and treatment prioritization.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Cadence at which this compliance risk is formally reviewed and reassessed. High and Critical risks typically require more frequent review (monthly or quarterly); Low and Medium risks may be reviewed semi-annually or annually.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAppetiteAlignment rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Alignment' ;
    rdfs:comment 'Indicates whether the residual risk rating is aligned with the organization\'s risk appetite threshold. Exceeds Appetite triggers mandatory risk treatment; Within Appetite indicates acceptable risk level; Below Appetite may indicate over-control.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAppetiteThreshold rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Threshold' ;
    rdfs:comment 'Maximum level of residual risk that the organization is willing to accept for this compliance domain, as defined by the Board and executive leadership. Used to determine if additional risk treatment is required.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Primary regulatory domain or compliance framework to which this risk belongs. Categories include Good Practice (GxP), Sarbanes-Oxley (SOX), General Data Protection Regulation (GDPR), Anti-Bribery and Anti-Corruption (ABAC), Physician Payments Sunshine Act, Data Integrity (ALCOA+), Computer System Validation (CSV), and Health Insurance Portability and Accountability Act (HIPAA). [ENUM-REF-CANDIDATE: GxP|SOX|GDPR|ABAC|Sunshine Act|Data Integrity|CSV|HIPAA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCode rdf:type rdf:Property ;
    rdfs:label 'Risk Code' ;
    rdfs:comment 'Business identifier for the compliance risk, formatted as RISK-{DOMAIN}-{SEQUENCE} (e.g., RISK-GXP-000123). Used for external reporting and cross-referencing.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed description of the compliance risk, including the nature of the risk, potential triggers, and business context. Provides comprehensive understanding for risk assessment and treatment planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskOwnerFunction rdf:type rdf:Property ;
    rdfs:label 'Risk Owner Function' ;
    rdfs:comment 'Business function or department of the risk owner (e.g., Quality Assurance, Regulatory Affairs, Manufacturing, Clinical Operations, IT, Finance).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle status of the compliance risk. Open indicates newly identified; Under Assessment indicates risk analysis in progress; Treatment in Progress indicates mitigation actions underway; Monitoring indicates residual risk being tracked; Closed indicates risk retired or no longer applicable; Escalated indicates risk elevated to executive or Board level.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'Secondary classification providing granular categorization within the primary risk category (e.g., within GxP: GMP, GLP, GCP, GDP; within Data Integrity: ALCOA+, audit trail, electronic signature).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Concise title or name of the identified compliance risk. Used for executive dashboards and Board Audit Committee reporting.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTreatmentDecision rdf:type rdf:Property ;
    rdfs:label 'Risk Treatment Decision' ;
    rdfs:comment 'Strategic decision on how to address the compliance risk. Accept means no further action, risk is within appetite; Mitigate means implement additional controls to reduce risk; Transfer means shift risk to third party (e.g., insurance, outsourcing); Avoid means eliminate the activity that creates the risk.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Completion Date' ;
    rdfs:comment 'Actual date when the risk treatment plan was fully implemented and verified. Null if treatment is not yet complete or if risk treatment decision is Accept.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Due Date' ;
    rdfs:comment 'Target completion date for implementing the risk treatment plan. Used for tracking and escalation. Null if risk treatment decision is Accept.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Plan Description' ;
    rdfs:comment 'Detailed description of planned actions to mitigate, transfer, or avoid the compliance risk. Includes specific control enhancements, process changes, technology implementations, or organizational changes. Null if risk treatment decision is Accept.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Treatment Status' ;
    rdfs:comment 'Current status of risk treatment plan execution. Not Started indicates plan approved but not yet initiated; In Progress indicates actions underway; Completed indicates all treatment actions implemented and verified; Overdue indicates treatment past due date; Cancelled indicates treatment plan abandoned. Null if risk treatment decision is Accept.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTrialId rdf:type rdf:Property ;
    rdfs:label 'Applicable Trial Id' ;
    rdfs:comment 'Identifier of the clinical trial to which this COI declaration applies, if relevant. Null for non-trial-related declarations.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trial .

ind:primaryConflictDeclarantEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Conflict Declarant Employee Id' ;
    rdfs:comment 'Employee identifier if the declarant is an internal employee. Null for external declarants.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attestationStatement rdf:type rdf:Property ;
    rdfs:label 'Attestation Statement' ;
    rdfs:comment 'Text of the attestation or certification statement signed by the declarant affirming the accuracy and completeness of the declaration.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Attestation Timestamp' ;
    rdfs:comment 'Date and time when the declarant electronically signed or attested to the COI declaration.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Name of the organization, institution, or individual with whom the declarant has a conflicting relationship.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Category of the counterparty entity: pharmaceutical company, biotech company, Contract Research Organization (CRO), medical device company, academic institution, healthcare provider, government agency, or individual. [ENUM-REF-CANDIDATE: pharmaceutical_company|biotech_company|cro|medical_device_company|academic_institution|healthcare_provider|government_agency|individual — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarantEmail rdf:type rdf:Property ;
    rdfs:label 'Declarant Email' ;
    rdfs:comment 'Primary email address of the declarant for correspondence regarding the COI declaration.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarantName rdf:type rdf:Property ;
    rdfs:label 'Declarant Name' ;
    rdfs:comment 'Full legal name of the individual making the conflict of interest declaration.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarantType rdf:type rdf:Property ;
    rdfs:label 'Declarant Type' ;
    rdfs:comment 'Category of individual making the declaration: employee, principal investigator, advisory board member, healthcare professional, consultant, or vendor representative.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date on which the conflict of interest declaration was submitted by the declarant.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'Business identifier for the COI declaration, formatted as COI-YYYYNNNN where YYYY is year and NNNN is sequence.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the COI declaration: draft, submitted, under review, approved, rejected, or withdrawn.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Type of COI declaration: initial submission, annual recertification, ad-hoc update, triggered by event, or amendment to prior declaration.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Value Amount' ;
    rdfs:comment 'Monetary value of the financial interest or relationship, if quantifiable. Null for non-financial relationships.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the declared value amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'Date on which the conflict of interest was disclosed to the relevant regulatory authority, IRB, or other external body.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Disclosure Required Flag' ;
    rdfs:comment 'Indicates whether this COI must be disclosed to regulatory authorities, institutional review boards (IRBs), or in publications (True) or not (False).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestDescription rdf:type rdf:Property ;
    rdfs:label 'Interest Description' ;
    rdfs:comment 'Detailed narrative description of the nature, scope, and context of the conflict of interest or relationship.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementPlan rdf:type rdf:Property ;
    rdfs:label 'Management Plan' ;
    rdfs:comment 'Documented plan for managing or mitigating the identified conflict of interest, including specific controls, restrictions, or oversight measures.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Mitigation Required Flag' ;
    rdfs:comment 'Indicates whether mitigation actions are required to manage the conflict of interest (True) or not (False).' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'Current status of mitigation actions: not required, planned, in progress, completed, or verified by compliance.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date by which the declarant must submit an annual recertification or update of the COI declaration.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Recertification Status' ;
    rdfs:comment 'Status of annual recertification requirement: current (up to date), overdue, not applicable, or pending submission.' ;
    rdfs:domain ind:ConflictOfInterest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Nature of the conflict of interest: financial interest, employment, consulting arrangement, equity ownership, family relationship, personal relationship, board membership, or intellectual property rights. [ENUM-REF-CANDIDATE: financial_interest|employment|consulting|equity_ownership|family_relationship|personal_relationship|board_membership|intellectual_property — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'Result of the COI review: no conflict identified, managed conflict (acceptable with controls), prohibited conflict (unacceptable), requires mitigation, or pending review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Control Assessment Id' ;
    rdfs:comment 'Unique identifier for the control assessment record. Primary key for the control assessment entity.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryControlAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Control Assessor Employee Id' ;
    rdfs:comment 'Reference to the employee who performed the control assessment. Must be independent of the control owner per segregation of duties requirements. For external auditor assessments, references the engagement team member.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Execution Date' ;
    rdfs:comment 'Date when the control assessment testing was performed. Represents the principal business event timestamp for the assessment activity. May differ from period end date for interim or retrospective testing.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text field for assessor observations, testing procedures performed, evidence examined, and other relevant assessment details. Supports audit trail and provides context for assessment conclusions and recommendations.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the control assessment. Format: CA-YYYY-NNNNNN where YYYY is fiscal year and NNNNNN is sequential number. Used for external reporting and audit trail references.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period End Date' ;
    rdfs:comment 'Ending date of the period under assessment. Defines the scope boundary for transaction sampling and control effectiveness evaluation.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period Start Date' ;
    rdfs:comment 'Beginning date of the period under assessment. For SOX testing, typically aligns with fiscal quarter or year start. For GxP assessments, may align with batch production periods or clinical trial phases.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the control assessment activity. SOX control testing covers Sarbanes-Oxley 404 internal control evaluations. GxP compliance assessment covers Good Practice (GMP, GLP, GCP) regulatory compliance. ITGC evaluation covers IT General Controls. Process walkthrough covers end-to-end process documentation and control identification. Data integrity review covers ALCOA+ (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available) principles. Vendor audit covers third-party Contract Manufacturing Organization (CMO) and Contract Research Organization (CRO) assessments.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness Rating' ;
    rdfs:comment 'Qualitative assessment of control design and operating effectiveness. Highly effective indicates robust control with no exceptions and strong design. Effective indicates control operates as designed with minor exceptions. Needs improvement indicates control operates but has design weaknesses or recurring exceptions. Ineffective indicates control does not mitigate risk or has material failures.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityAlcoaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Alcoa Compliance Flag' ;
    rdfs:comment 'Indicator whether control assessment verified compliance with ALCOA+ data integrity principles: Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, and Available. Critical for GxP systems validation and 21 CFR Part 11 electronic records compliance.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deficiencyClassification rdf:type rdf:Property ;
    rdfs:label 'Deficiency Classification' ;
    rdfs:comment 'Severity classification of identified control deficiencies per SOX 404 and PCAOB standards. No deficiency indicates effective control. Control deficiency indicates a weakness that does not rise to significant deficiency. Significant deficiency indicates a deficiency or combination of deficiencies that is less severe than a material weakness yet important enough to merit attention by those charged with governance. Material weakness indicates a deficiency or combination of deficiencies such that there is a reasonable possibility that a material misstatement will not be prevented or detected on a timely basis.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Detailed narrative description of identified control deficiencies, including root cause analysis, impact assessment, and specific instances of control failure. Required for significant deficiencies and material weaknesses reported to audit committee and external auditors.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Exceptions Identified Count' ;
    rdfs:comment 'Number of control failures or deviations identified during testing. Exceptions indicate instances where the control did not operate as designed or was not performed. Used to calculate control deficiency rate and determine control effectiveness conclusion.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAuditorRelianceFlag rdf:type rdf:Property ;
    rdfs:label 'External Auditor Reliance Flag' ;
    rdfs:comment 'Indicator whether external auditors can rely on this internal control assessment for their financial statement audit. True indicates assessment meets PCAOB standards for auditor reliance. False indicates external auditors must perform independent testing. Critical for SOX 404(b) external auditor attestation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryInspectionReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Readiness Flag' ;
    rdfs:comment 'Indicator whether control assessment documentation is inspection-ready for FDA Pre-Approval Inspection (PAI), EMA inspection, or other regulatory authority audits. True indicates assessment package complete with evidence, work papers, and management sign-off per GxP requirements.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Actual date when corrective action implementation was completed. Used to calculate remediation cycle time and track compliance with remediation commitments made to audit committee and external auditors.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicator whether corrective action is required to address identified deficiencies. True indicates Corrective and Preventive Action (CAPA) plan must be developed and tracked. False indicates no remediation needed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxScopingFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scoping Flag' ;
    rdfs:comment 'Indicator whether this control is in scope for SOX 404 management assessment and external auditor attestation. True indicates control is key to preventing or detecting material misstatements in financial reporting. Scoping based on materiality, risk assessment, and process-level controls over significant accounts and disclosures.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Overall conclusion on control operating effectiveness. Effective indicates control operated as designed with no material exceptions. Ineffective indicates control failures that could result in material misstatement or compliance violation. Not tested indicates assessment planned but not executed. Not applicable indicates control not in operation during assessment period.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingApproach rdf:type rdf:Property ;
    rdfs:label 'Testing Approach' ;
    rdfs:comment 'Methodology used to evaluate control effectiveness. Inquiry involves interviewing control performers. Observation involves watching control execution in real-time. Inspection involves examining documentary evidence. Reperformance involves independently executing the control. Walkthrough involves tracing a single transaction end-to-end. Sample testing involves statistical sampling of control instances. Full population testing involves examining all control instances in the period. [ENUM-REF-CANDIDATE: inquiry|observation|inspection|reperformance|walkthrough|sample_testing|full_population_testing — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debarmentCheckId rdf:type rdf:Property ;
    rdfs:label 'Debarment Check Id' ;
    rdfs:comment 'Unique identifier for the debarment screening check record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DebarmentCheck .

ind:primaryDebarmentAdjudicatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Debarment Adjudicator Employee Id' ;
    rdfs:comment 'Identifier of the employee who performed the adjudication review and made the final determination.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:thirdPartyDueDiligenceId rdf:type rdf:Property ;
    rdfs:label 'Third Party Due Diligence Id' ;
    rdfs:comment 'Foreign key linking to compliance.third_party_due_diligence. Business justification: Debarment checks are performed as part of third-party due diligence assessments. This FK establishes the parent-child relationship where a due diligence assessment includes multiple screening checks (' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyDueDiligence .

ind:adjudicationNotes rdf:type rdf:Property ;
    rdfs:label 'Adjudication Notes' ;
    rdfs:comment 'Detailed notes and rationale documented by the adjudicator explaining the decision and any mitigating factors considered.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjudicationOutcome rdf:type rdf:Property ;
    rdfs:label 'Adjudication Outcome' ;
    rdfs:comment 'Final determination from the adjudication process regarding whether the subject is cleared for participation or engagement.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Business identifier for the debarment screening check, used for tracking and reference purposes.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euSanctionsCheckedFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Sanctions Checked Flag' ;
    rdfs:comment 'Indicates whether EU sanctions lists were checked during this screening.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Effective Date' ;
    rdfs:comment 'Date when the exclusion or debarment became effective for the matched individual or entity.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Expiration Date' ;
    rdfs:comment 'Date when the exclusion or debarment expires, if applicable. Null indicates permanent exclusion.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusionReason rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason' ;
    rdfs:comment 'Reason for exclusion or debarment as documented in the regulatory list, such as fraud, patient abuse, or controlled substance violations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaDebarmentCheckedFlag rdf:type rdf:Property ;
    rdfs:label 'Fda Debarment Checked Flag' ;
    rdfs:comment 'Indicates whether the FDA Debarment List under 21 CFR Part 312.70 was checked during this screening.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gcpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Flag' ;
    rdfs:comment 'Indicates whether this screening check is required for Good Clinical Practice compliance under ICH E6(R2) guidelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listsChecked rdf:type rdf:Property ;
    rdfs:label 'Lists Checked' ;
    rdfs:comment 'Comma-separated list of regulatory exclusion and sanctions lists checked during this screening, such as FDA Debarment List, OIG LEIE, GSA SAM, OFAC SDN, EU Sanctions.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Match Confidence Score' ;
    rdfs:comment 'Numerical score representing the confidence level of the match, typically expressed as a percentage from 0 to 100.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchCount rdf:type rdf:Property ;
    rdfs:label 'Match Count' ;
    rdfs:comment 'Number of potential matches identified across all checked exclusion and sanctions lists.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchDetails rdf:type rdf:Property ;
    rdfs:label 'Match Details' ;
    rdfs:comment 'Detailed information about any matches found, including list name, match score, matched fields, and exclusion reason.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchListName rdf:type rdf:Property ;
    rdfs:label 'Match List Name' ;
    rdfs:comment 'Name of the specific exclusion or sanctions list on which a match was identified.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Result of the screening check indicating whether the subject was found on any exclusion or sanctions list.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScreeningDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Screening Due Date' ;
    rdfs:comment 'Date when the next periodic re-screening check is due for this subject.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ofacSdnCheckedFlag rdf:type rdf:Property ;
    rdfs:label 'Ofac Sdn Checked Flag' ;
    rdfs:comment 'Indicates whether the OFAC Specially Designated Nationals and Blocked Persons list was checked during this screening.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oigLeieCheckedFlag rdf:type rdf:Property ;
    rdfs:label 'Oig Leie Checked Flag' ;
    rdfs:comment 'Indicates whether the OIG List of Excluded Individuals and Entities was checked during this screening.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rescreeningTrigger rdf:type rdf:Property ;
    rdfs:label 'Rescreening Trigger' ;
    rdfs:comment 'Business event or condition that triggered this screening check, such as new hire, contract renewal, periodic review, or regulatory inspection preparation.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samExclusionCheckedFlag rdf:type rdf:Property ;
    rdfs:label 'Sam Exclusion Checked Flag' ;
    rdfs:comment 'Indicates whether the GSA System for Award Management exclusions database was checked during this screening.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningFrequency rdf:type rdf:Property ;
    rdfs:label 'Screening Frequency' ;
    rdfs:comment 'Required frequency for re-screening this subject based on risk assessment and regulatory requirements.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningMethod rdf:type rdf:Property ;
    rdfs:label 'Screening Method' ;
    rdfs:comment 'Method used to perform the debarment screening check, indicating level of automation versus manual review.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current status of the debarment screening check in its lifecycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystem rdf:type rdf:Property ;
    rdfs:label 'Screening System' ;
    rdfs:comment 'Name of the software system or service used to perform the debarment screening check.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Precise timestamp when the debarment screening check was executed, including time zone information.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningType rdf:type rdf:Property ;
    rdfs:label 'Screening Type' ;
    rdfs:comment 'Type of subject being screened for debarment or exclusion status. [ENUM-REF-CANDIDATE: individual|entity|site|investigator|vendor|employee|contractor — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAddress rdf:type rdf:Property ;
    rdfs:label 'Subject Address' ;
    rdfs:comment 'Physical address of the individual or entity being screened, used for enhanced matching against exclusion lists.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCountryCode rdf:type rdf:Property ;
    rdfs:label 'Subject Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the country of residence or registration of the subject being screened.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Subject Date Of Birth' ;
    rdfs:comment 'Date of birth of the individual being screened, used to improve matching accuracy and reduce false positives.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectFirstName rdf:type rdf:Property ;
    rdfs:label 'Subject First Name' ;
    rdfs:comment 'First name of the individual being screened, used for more precise matching against exclusion lists.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectIdentifier rdf:type rdf:Property ;
    rdfs:label 'Subject Identifier' ;
    rdfs:comment 'Unique identifier for the subject being screened, such as employee ID, vendor ID, investigator ID, or national identification number.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectLastName rdf:type rdf:Property ;
    rdfs:label 'Subject Last Name' ;
    rdfs:comment 'Last name of the individual being screened, used for more precise matching against exclusion lists.' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Classification of the entity being screened (individual person or organizational entity).' ;
    rdfs:domain ind:DebarmentCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esignatureEventId rdf:type rdf:Property ;
    rdfs:label 'Esignature Event Id' ;
    rdfs:comment 'Unique identifier for the electronic signature event. Primary key for the esignature_event product.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorSignatureEventEsignatureEventId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Signature Event Esignature Event Id' ;
    rdfs:comment 'Identifier of the preceding electronic signature event in a sequential approval chain, if applicable.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsignatureEvent .

ind:primaryEsignatureEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Esignature Employee Id' ;
    rdfs:comment 'Unique identifier of the individual who executed the electronic signature. Links to the enterprise user or employee master.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Unique identifier of the user session during which the electronic signature was executed, linking the signature to the broader audit trail.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsignatureSession .

ind:workflowStepId rdf:type rdf:Property ;
    rdfs:label 'Workflow Step Id' ;
    rdfs:comment 'Identifier of the specific workflow step or approval stage at which the electronic signature was executed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkflowStep .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Method used to authenticate the signer\'s identity at the time of signature execution (e.g., username/password, biometric, token-based, multi-factor authentication).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationResult rdf:type rdf:Property ;
    rdfs:label 'Authentication Result' ;
    rdfs:comment 'Outcome of the authentication attempt (success, failure, account locked, credentials expired).' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricDataHash rdf:type rdf:Property ;
    rdfs:label 'Biometric Data Hash' ;
    rdfs:comment 'Cryptographic hash of biometric data (fingerprint, retina scan) used for authentication, if biometric method was employed. Raw biometric data is not stored.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceValidationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Validation Timestamp' ;
    rdfs:comment 'Date and time when the electronic signature event was validated for regulatory compliance by the system or quality assurance process.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delegationFlag rdf:type rdf:Property ;
    rdfs:label 'Delegation Flag' ;
    rdfs:comment 'Indicates whether the signature was executed under delegated authority (True) or by the originally assigned individual (False).' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Device Identifier' ;
    rdfs:comment 'Unique identifier of the device (workstation, tablet, mobile device) used to execute the electronic signature.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonRepudiationToken rdf:type rdf:Property ;
    rdfs:label 'Non Repudiation Token' ;
    rdfs:comment 'Cryptographic hash or token generated at the time of signing to ensure non-repudiation and integrity of the signature event.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordReference rdf:type rdf:Property ;
    rdfs:label 'Record Reference' ;
    rdfs:comment 'Unique identifier of the business record or document being signed within the source system (e.g., batch record ID, protocol ID, SOP ID).' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Type or category of the business record being signed. [ENUM-REF-CANDIDATE: batch_record|protocol|sop|deviation|capa|change_control|specification|validation_report|clinical_trial_document|manufacturing_instruction|quality_record|regulatory_submission|training_record|audit_report|investigation_report|other — promote to reference product]' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Record Version Number' ;
    rdfs:comment 'Version number or identifier of the business record at the time the electronic signature was executed, ensuring signature is tied to a specific record state.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether the electronic signature event meets all regulatory compliance requirements (21 CFR Part 11, EU Annex 11) at the time of execution.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureImagePath rdf:type rdf:Property ;
    rdfs:label 'Signature Image Path' ;
    rdfs:comment 'File path or URI to the stored graphical representation of the electronic signature, if captured (e.g., stylus signature on tablet).' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureMeaning rdf:type rdf:Property ;
    rdfs:label 'Signature Meaning' ;
    rdfs:comment 'The intended meaning or purpose of the electronic signature as defined by the business process (e.g., reviewed, approved, authored, verified). [ENUM-REF-CANDIDATE: authored|reviewed|approved|verified|witnessed|acknowledged|released|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureReason rdf:type rdf:Property ;
    rdfs:label 'Signature Reason' ;
    rdfs:comment 'Optional free-text reason or comment provided by the signer at the time of signature execution, explaining the basis for their action.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Signature Sequence Number' ;
    rdfs:comment 'Sequential order of this signature within a multi-signature workflow or approval chain for the same record.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatureStatus rdf:type rdf:Property ;
    rdfs:label 'Signature Status' ;
    rdfs:comment 'Current status of the electronic signature event in its lifecycle.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'Date and time when the electronic signature was executed, recorded in UTC with millisecond precision for audit trail integrity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signerFullName rdf:type rdf:Property ;
    rdfs:label 'Signer Full Name' ;
    rdfs:comment 'Full legal name of the individual who executed the electronic signature, captured at the time of signing for non-repudiation.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerRole rdf:type rdf:Property ;
    rdfs:label 'Signer Role' ;
    rdfs:comment 'Functional role or job title of the signer at the time of signature execution (e.g., QA Manager, Manufacturing Supervisor, Principal Investigator).' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerUsername rdf:type rdf:Property ;
    rdfs:label 'Signer Username' ;
    rdfs:comment 'Username or login ID of the individual who executed the electronic signature at the time of signing.' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the source GxP-regulated system from which the electronic signature event was captured (e.g., Veeva Vault, MasterControl, TrackWise).' ;
    rdfs:domain ind:EsignatureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStepName rdf:type rdf:Property ;
    rdfs:label 'Workflow Step Name' ;
    rdfs:comment 'Human-readable name or description of the workflow step at which the electronic signature was executed (e.g., QA Review, Final Approval).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableFunctions rdf:type rdf:Property ;
    rdfs:label 'Applicable Functions' ;
    rdfs:comment 'Comma-separated list of business functions to which this obligation applies (e.g., \'Quality Assurance\', \'Manufacturing\', \'Clinical Operations\', \'Pharmacovigilance\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProducts rdf:type rdf:Property ;
    rdfs:label 'Applicable Products' ;
    rdfs:comment 'Comma-separated list of product codes, therapeutic areas, or product families to which this obligation applies. Null if not product-specific.' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Scope' ;
    rdfs:comment 'The organizational scope to which this obligation applies: Enterprise-wide (all sites and functions), Site-specific (particular manufacturing or R&D sites), Function-specific (e.g., Quality, Clinical), Product-specific (certain drug products or therapeutic areas), or Process-specific (particular manufacturing or testing processes).' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSites rdf:type rdf:Property ;
    rdfs:label 'Applicable Sites' ;
    rdfs:comment 'Comma-separated list of site codes or names where this obligation applies. Null if scope is enterprise-wide or not site-specific.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Boolean indicator of whether systems or processes supporting this obligation must maintain complete audit trails of all activities and changes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeControlRequired rdf:type rdf:Property ;
    rdfs:label 'Change Control Required' ;
    rdfs:comment 'Boolean indicator of whether changes affecting this obligation must go through formal change control procedures.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current assessment of the organization\'s compliance with this obligation: Compliant (fully meeting requirements), Non-Compliant (not meeting requirements), Partially Compliant (meeting some but not all requirements), Not Assessed (no assessment performed yet), or Remediation in Progress (corrective actions underway).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityRequirement rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Requirement' ;
    rdfs:comment 'Boolean indicator of whether this obligation includes specific data integrity requirements under ALCOA+ principles (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available).' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Documentation Retention Years' ;
    rdfs:comment 'The minimum number of years that documentation related to this obligation must be retained, as mandated by regulation or internal policy.' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electronicRecordsRequirement rdf:type rdf:Property ;
    rdfs:label 'Electronic Records Requirement' ;
    rdfs:comment 'Boolean indicator of whether this obligation mandates compliance with electronic records and electronic signatures regulations (21 CFR Part 11, EU Annex 11).' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprApplicability rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicability' ;
    rdfs:comment 'Boolean indicator of whether this obligation involves processing of personal data subject to GDPR (General Data Protection Regulation) requirements.' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaApplicability rdf:type rdf:Property ;
    rdfs:label 'Hipaa Applicability' ;
    rdfs:comment 'Boolean indicator of whether this obligation involves protected health information (PHI) subject to HIPAA (Health Insurance Portability and Accountability Act) requirements.' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Flag' ;
    rdfs:comment 'Boolean indicator of whether the organization is inspection-ready for this obligation (True if all required documentation, controls, and evidence are in place and current; False otherwise).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'The date of the most recent compliance assessment or audit for this obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Date' ;
    rdfs:comment 'The scheduled date for the next compliance assessment or audit of this obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Business identifier for the obligation, typically derived from the source regulation or internal compliance framework (e.g., GMP-210-001, GCP-ICH-E6).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of what the organization is required to do under this obligation, including specific actions, documentation, or controls mandated.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationOwner rdf:type rdf:Property ;
    rdfs:label 'Obligation Owner' ;
    rdfs:comment 'The role, department, or individual responsible for ensuring compliance with this obligation (e.g., \'VP Quality Assurance\', \'Head of Clinical Operations\').' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the obligation: Active (currently enforceable), Superseded (replaced by newer regulation), Retired (no longer applicable), Under Review (being assessed for applicability), or Pending Implementation (identified but not yet operationalized).' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationTitle rdf:type rdf:Property ;
    rdfs:label 'Obligation Title' ;
    rdfs:comment 'Short descriptive title of the regulatory obligation (e.g., \'Batch Record Review and Approval\', \'Informed Consent Documentation\').' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationSource rdf:type rdf:Property ;
    rdfs:label 'Regulation Source' ;
    rdfs:comment 'The specific regulation, guideline, or directive that mandates this obligation (e.g., \'21 CFR Part 211.192\', \'EU GMP Annex 1\', \'ICH Q7\', \'GDPR Article 32\').' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationType rdf:type rdf:Property ;
    rdfs:label 'Regulation Type' ;
    rdfs:comment 'The legal or normative type of the source document: Federal Regulation (e.g., CFR), Directive (e.g., EU Directive), Guideline (e.g., ICH), Standard (e.g., ISO), or internal Policy.' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPolicyReferences rdf:type rdf:Property ;
    rdfs:label 'Related Policy References' ;
    rdfs:comment 'Comma-separated list of internal policy document numbers or identifiers that govern compliance with this obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedSopReferences rdf:type rdf:Property ;
    rdfs:label 'Related Sop References' ;
    rdfs:comment 'Comma-separated list of SOP document numbers or identifiers that implement or support compliance with this obligation.' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Boolean indicator of whether this obligation is also subject to SOX (Sarbanes-Oxley Act) internal control requirements for financial reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationRequirement rdf:type rdf:Property ;
    rdfs:label 'Validation Requirement' ;
    rdfs:comment 'The type of validation required to demonstrate compliance with this obligation, if applicable: Process Validation, Computer System Validation (CSV), Cleaning Validation, Analytical Method Validation, or Not Applicable.' ;
    rdfs:domain ind:GxpObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionObservationId rdf:type rdf:Property ;
    rdfs:label 'Inspection Observation Id' ;
    rdfs:comment 'Unique identifier for the inspection observation record. Primary key.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionObservation .

ind:previousObservationInspectionObservationId rdf:type rdf:Property ;
    rdfs:label 'Previous Observation Inspection Observation Id' ;
    rdfs:comment 'Foreign key reference to the prior inspection observation record if this is identified as a repeat observation. Links to historical observation for trend analysis.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionObservation .

ind:regulatoryInspectionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Id' ;
    rdfs:comment 'Foreign key reference to the parent regulatory inspection event during which this observation was raised.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryInspection .

ind:rootCauseAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Id' ;
    rdfs:comment 'Foreign key reference to the formal root cause analysis investigation conducted to determine the underlying cause of this observation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RootCauseAnalysis .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Foreign key reference to the manufacturing facility, laboratory, or site where this observation was identified during the inspection.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:cfrCitation rdf:type rdf:Property ;
    rdfs:label 'Cfr Citation' ;
    rdfs:comment 'The specific CFR section(s) cited by the inspector as the regulatory basis for this observation. For US inspections, typically references 21 CFR Parts 11, 210, 211, 312, or 314. For non-US inspections, may reference equivalent regulatory framework sections.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Closure Verification Method' ;
    rdfs:comment 'The method by which closure of this observation was verified and confirmed. Indicates whether closure was based on health authority acceptance, follow-up inspection, or internal verification.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'The committed or actual date by which the corrective action will be or was completed. This date is communicated to the health authority as part of the response commitment.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCitation rdf:type rdf:Property ;
    rdfs:label 'Gmp Citation' ;
    rdfs:comment 'The specific GMP guideline or ICH guideline section cited as the basis for this observation. May reference EU GMP Annex, PIC/S guidelines, or ICH Q-series quality guidelines.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'A summary of the business and regulatory impact assessment conducted for this observation, including potential impact on product quality, patient safety, regulatory standing, and commercial operations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'The name of the regulatory inspector who documented this observation. Used for tracking inspector patterns and communication history.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal company notes and commentary regarding this observation, response strategy, lessons learned, or coordination activities. Not shared with the health authority.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationCategory rdf:type rdf:Property ;
    rdfs:label 'Observation Category' ;
    rdfs:comment 'The functional area or GMP system category to which this observation relates. Used to classify observations by business process area for trending and root cause analysis. [ENUM-REF-CANDIDATE: quality_system|data_integrity|facility_equipment|materials_management|production_process|laboratory_controls|packaging_labeling — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationClassification rdf:type rdf:Property ;
    rdfs:label 'Observation Classification' ;
    rdfs:comment 'The severity classification assigned to the observation indicating the level of regulatory concern. Critical observations represent serious violations that may result in regulatory action; major observations are significant deviations from GxP requirements; minor observations are less serious deficiencies; informational observations are recommendations without compliance impact.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationDate rdf:type rdf:Property ;
    rdfs:label 'Observation Date' ;
    rdfs:comment 'The date on which the inspector documented this observation during the inspection. This is the business event date from the inspection timeline.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Observation Reference Number' ;
    rdfs:comment 'The official reference number or citation identifier assigned by the regulatory inspector to this specific observation. This is the externally-known identifier used in all correspondence with the health authority.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationText rdf:type rdf:Property ;
    rdfs:label 'Observation Text' ;
    rdfs:comment 'The verbatim text of the observation, finding, or deficiency as documented by the regulatory inspector. This is the exact wording from the inspection report and must be preserved without modification for regulatory response purposes.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedCorrectiveAction rdf:type rdf:Property ;
    rdfs:label 'Proposed Corrective Action' ;
    rdfs:comment 'The detailed description of the corrective and preventive actions (CAPA) proposed by the company to address the root cause of this observation and prevent recurrence. This text will be included in the formal response submission to the health authority.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionRisk rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Risk' ;
    rdfs:comment 'The assessed risk level that this observation may result in formal regulatory action such as warning letter, consent decree, import alert, or product recall. Based on observation severity, repeat status, and health authority enforcement history.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatObservationFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Observation Flag' ;
    rdfs:comment 'Boolean indicator of whether this observation is a repeat finding from a previous inspection at the same facility. Repeat observations carry higher regulatory risk and may trigger escalated enforcement action.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'The regulatory deadline by which the company must submit its formal response to the health authority addressing this observation. Typically 15 business days from inspection closeout for FDA inspections.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseOwnerName rdf:type rdf:Property ;
    rdfs:label 'Response Owner Name' ;
    rdfs:comment 'The full name of the individual or organizational unit assigned as the response owner for this observation.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Response Submission Date' ;
    rdfs:comment 'The actual date on which the company submitted its formal written response to the health authority addressing this observation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'The internal risk score assigned to this observation based on the company\'s risk assessment methodology. Used to prioritize response efforts and resource allocation. Typically scored on a scale such as 1-25 based on severity and detectability.' ;
    rdfs:domain ind:InspectionObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationId rdf:type rdf:Property ;
    rdfs:label 'Application Id' ;
    rdfs:comment 'Foreign key linking to regulatory.application. Business justification: Readiness programs scoped to application lifecycle (original application, supplements). Tracks readiness status against application milestones for regulatory strategy execution and inspection risk mit' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:designationId rdf:type rdf:Property ;
    rdfs:label 'Designation Id' ;
    rdfs:comment 'Foreign key linking to regulatory.regulatory_designation. Business justification: Designations (Breakthrough, PRIME, Orphan) trigger accelerated timelines and heightened inspection scrutiny. Links readiness program to designation for tailored preparation strategies and priority rev' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designation .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the inspection readiness program record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryInspectionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for coordinating the inspection readiness program.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:submissionId rdf:type rdf:Property ;
    rdfs:label 'Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.submission. Business justification: Inspection readiness programs prepare sites for PAI triggered by specific submissions (NDA, BLA, MAA). Links readiness activities to submission timeline for PDUFA date planning and resource allocation' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:criticalGapsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Critical Gaps Identified Count' ;
    rdfs:comment 'Number of critical gaps or deficiencies identified during readiness assessment that require immediate remediation.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:csvComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Csv Compliance Status' ;
    rdfs:comment 'Status of Computer System Validation compliance for systems within the inspection scope, per 21 CFR Part 11 and GAMP 5 guidelines.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Assessment Status' ;
    rdfs:comment 'Status of the ALCOA+ (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available) data integrity assessment conducted as part of readiness.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReviewCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Document Review Completion Percentage' ;
    rdfs:comment 'Percentage of required Standard Operating Procedures (SOPs), batch records, and quality documents reviewed and updated for inspection readiness.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gapsRemediatedCount rdf:type rdf:Property ;
    rdfs:label 'Gaps Remediated Count' ;
    rdfs:comment 'Total number of identified gaps that have been successfully remediated and closed.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionAnnouncementType rdf:type rdf:Property ;
    rdfs:label 'Inspection Announcement Type' ;
    rdfs:comment 'Indicates whether the inspection is announced in advance, unannounced, or triggered by a specific cause (e.g., adverse event, complaint).' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotificationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Notification Received Flag' ;
    rdfs:comment 'Indicates whether formal notification of the regulatory inspection has been received from the authority.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Detailed description of the scope of the inspection readiness program, including functional areas, product lines, or processes covered.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Type of regulatory inspection the readiness program is preparing for. FDA PAI = Pre-Approval Inspection, EMA GMP = European Medicines Agency Good Manufacturing Practice, MHRA = Medicines and Healthcare products Regulatory Agency, WHO PQ = World Health Organization Prequalification, PMDA = Pharmaceuticals and Medical Devices Agency.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorGapsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Major Gaps Identified Count' ;
    rdfs:comment 'Number of major gaps or deficiencies identified during readiness assessment that require remediation before inspection.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorGapsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Minor Gaps Identified Count' ;
    rdfs:comment 'Number of minor gaps or observations identified during readiness assessment.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mockInspectionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Mock Inspection Completed Date' ;
    rdfs:comment 'Date when the mock inspection or readiness assessment exercise was completed.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mockInspectionScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Mock Inspection Scheduled Date' ;
    rdfs:comment 'Scheduled date for the mock inspection or readiness assessment exercise.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Notification Received Date' ;
    rdfs:comment 'Date when formal notification of the regulatory inspection was received.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openCapaCount rdf:type rdf:Property ;
    rdfs:label 'Open Capa Count' ;
    rdfs:comment 'Number of open CAPA records associated with inspection readiness gaps that are still pending closure.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'Date when the inspection readiness program was completed or closed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Start Date' ;
    rdfs:comment 'Date when the inspection readiness program was initiated.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readinessDetermination rdf:type rdf:Property ;
    rdfs:label 'Readiness Determination' ;
    rdfs:comment 'Final determination of inspection readiness status based on assessment results and remediation completion.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readinessScore rdf:type rdf:Property ;
    rdfs:label 'Readiness Score' ;
    rdfs:comment 'Quantitative assessment score representing the overall inspection readiness level, typically expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAssessmentCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Completed Flag' ;
    rdfs:comment 'Indicates whether a formal risk assessment has been completed to identify inspection vulnerabilities and prioritize remediation activities.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetInspectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Target Inspection End Date' ;
    rdfs:comment 'Expected or announced end date of the regulatory inspection.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetInspectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Inspection Start Date' ;
    rdfs:comment 'Expected or announced start date of the regulatory inspection.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Training Completion Percentage' ;
    rdfs:comment 'Percentage of required inspection readiness training completed by personnel within the scope of the program.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionResponseId rdf:type rdf:Property ;
    rdfs:label 'Inspection Response Id' ;
    rdfs:comment 'Unique identifier for the inspection response record. Primary key for the inspection response entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionResponse .

ind:quaternaryInspectionLegalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Inspection Legal Reviewer Employee Id' ;
    rdfs:comment 'Reference to the legal counsel who reviewed the response for legal risk and compliance implications. Null if no legal review was required.' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryInspectionLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Inspection Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the inspection response record. Supports audit trail and accountability requirements.' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryInspectionQualityHeadApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Inspection Quality Head Approver Employee Id' ;
    rdfs:comment 'Reference to the senior quality executive who provided final approval for the response submission. Required signatory for formal regulatory responses.' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:commitmentSummary rdf:type rdf:Property ;
    rdfs:label 'Commitment Summary' ;
    rdfs:comment 'High-level summary of the corrective and preventive actions (CAPA) committed to in the response. Provides executive overview of remediation strategy.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDecreeRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Decree Related Flag' ;
    rdfs:comment 'Indicates whether this response is related to an existing consent decree or regulatory agreement. True if consent decree obligations apply.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executiveNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Executive Notification Flag' ;
    rdfs:comment 'Indicates whether executive leadership was formally notified of this inspection response due to severity or business impact. True if executive notification occurred.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthAuthorityAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Health Authority Acceptance Status' ;
    rdfs:comment 'Health authority determination on the adequacy of the response and proposed corrective actions. Drives follow-up actions and regulatory risk assessment. [ENUM-REF-CANDIDATE: pending_review|accepted|partially_accepted|rejected|additional_information_requested|closed_satisfactory|closed_unsatisfactory — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthAuthorityAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Health Authority Acknowledgment Date' ;
    rdfs:comment 'Date when the health authority formally acknowledged receipt of the response. Confirms successful delivery and initiates review period.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthAuthorityFeedback rdf:type rdf:Property ;
    rdfs:label 'Health Authority Feedback' ;
    rdfs:comment 'Official comments or additional requirements provided by the health authority in response to the submission. May include requests for clarification or supplemental information.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedProductList rdf:type rdf:Property ;
    rdfs:label 'Impacted Product List' ;
    rdfs:comment 'Comma-separated list of product names or National Drug Code (NDC) numbers affected by the inspection findings. Used for impact assessment and regulatory reporting.' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Indicates whether legal counsel review was required for this response due to severity of findings or potential enforcement action. True if legal review was conducted.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Total number of inspection observations or findings being addressed in this response. Used for tracking response completeness and scope.' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Product Impact Flag' ;
    rdfs:comment 'Indicates whether the inspection findings and corrective actions impact marketed products, requiring potential regulatory notifications or market actions. True if products are impacted.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinspectionDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Date' ;
    rdfs:comment 'Scheduled or actual date of the follow-up inspection to verify corrective action implementation. Null if no reinspection is required.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required Flag' ;
    rdfs:comment 'Indicates whether the health authority has mandated a follow-up inspection to verify implementation of corrective actions. True if reinspection is required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Response Document Number' ;
    rdfs:comment 'Unique business identifier for the formal response document submitted to the health authority. Used for tracking and referencing in regulatory correspondence.' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Response Document Url' ;
    rdfs:comment 'Link to the stored response document in the document management system. Provides access to the full formal response submission.' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDocumentVersion rdf:type rdf:Property ;
    rdfs:label 'Response Document Version' ;
    rdfs:comment 'Version number of the response document. Tracks revisions and resubmissions if additional information is requested by the health authority.' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseLanguage rdf:type rdf:Property ;
    rdfs:label 'Response Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the language in which the response was submitted. Typically matches the health authority\'s official language.' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle state of the inspection response. Tracks progression from initial drafting through health authority closure. [ENUM-REF-CANDIDATE: draft|under_review|approved|submitted|acknowledged|closed|reopened — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'Classification of the response based on the type of regulatory communication being addressed. Determines the formality level and required content structure of the response.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processId rdf:type rdf:Property ;
    rdfs:label 'Process Id' ;
    rdfs:comment 'Foreign key reference to the business process taxonomy. Identifies which business process this control operates within (e.g., Procure-to-Pay, Order-to-Cash, Record-to-Report, Drug Manufacturing).' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessProcess .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree to which the control is automated. Fully Automated controls execute without human intervention; Semi-Automated controls combine system logic with manual review; Manual controls require complete human execution.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cfrPart11ApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Cfr Part 11 Applicable Flag' ;
    rdfs:comment 'Indicates whether this control ensures compliance with 21 CFR Part 11 requirements for electronic records and electronic signatures in FDA-regulated systems.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensatingControlFlag rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Flag' ;
    rdfs:comment 'Indicates whether this control serves as a compensating control for another control that has a deficiency or is not operating effectively. Compensating controls provide alternative risk mitigation.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlActivity rdf:type rdf:Property ;
    rdfs:label 'Control Activity' ;
    rdfs:comment 'Specific action or procedure performed to execute the control (e.g., \'Quality Assurance reviews and approves batch records before release\', \'System enforces dual authorization for payments over $50,000\').' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlCategory rdf:type rdf:Property ;
    rdfs:label 'Control Category' ;
    rdfs:comment 'High-level categorization of the control. IT General Controls (ITGC) support IT infrastructure and applications; Business Process Controls operate within specific business processes; Entity-Level Controls operate across the organization; Application Controls are embedded in software; Manual Controls require human execution; Automated Controls execute via system logic.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Detailed narrative describing the control objective, control activities, and how the control mitigates the identified risk. Includes the what, who, when, and how of the control execution.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEvidence rdf:type rdf:Property ;
    rdfs:label 'Control Evidence' ;
    rdfs:comment 'Description of the documentation or artifacts that demonstrate control execution (e.g., \'Signed batch record with QA approval stamp\', \'System audit log showing dual approval\', \'Monthly reconciliation report with preparer and reviewer signatures\').' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrequency rdf:type rdf:Property ;
    rdfs:label 'Control Frequency' ;
    rdfs:comment 'How often the control is executed or evaluated. Continuous and real-time controls operate automatically; periodic controls execute on a schedule; event-driven controls trigger based on specific business events. [ENUM-REF-CANDIDATE: continuous|real_time|daily|weekly|monthly|quarterly|annual|event_driven — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Short descriptive name of the internal control (e.g., \'Segregation of Duties for Invoice Approval\', \'Batch Record Review and Approval\').' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNumber rdf:type rdf:Property ;
    rdfs:label 'Control Number' ;
    rdfs:comment 'Business-facing unique identifier for the control, typically formatted as domain-category-sequence (e.g., FI-ITGC-0001, QM-BPC-0023). Used in audit documentation and control testing reports.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlObjective rdf:type rdf:Property ;
    rdfs:label 'Control Objective' ;
    rdfs:comment 'High-level statement of what the control is designed to achieve (e.g., \'Ensure completeness and accuracy of batch production records\', \'Prevent unauthorized access to financial systems\').' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwner rdf:type rdf:Property ;
    rdfs:label 'Control Owner' ;
    rdfs:comment 'Name or identifier of the individual or role responsible for the design, implementation, and ongoing operation of the control. Accountable for control effectiveness and remediation of deficiencies.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Control Owner Email' ;
    rdfs:comment 'Primary email address of the control owner for audit notifications, testing requests, and deficiency communications.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of the control. Active controls are in operation; Inactive controls are temporarily suspended; Under Review controls are being assessed for design changes; Remediation in Progress controls have identified deficiencies being corrected; Retired controls are no longer in scope.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityControlFlag rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Control Flag' ;
    rdfs:comment 'Indicates whether this control specifically addresses ALCOA+ principles (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available). Critical for pharmaceutical data integrity compliance.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Number of open control deficiencies, exceptions, or findings identified during testing. Includes control design deficiencies and operating effectiveness deficiencies.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable Flag' ;
    rdfs:comment 'Indicates whether this control supports GDPR compliance for personal data protection, privacy rights, and data subject rights in EU operations or clinical trials.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Applicable Flag' ;
    rdfs:comment 'Indicates whether this control supports GxP compliance (GMP, GLP, GCP, GDP). True if the control ensures data integrity, product quality, or patient safety in regulated pharmaceutical operations.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpRegulation rdf:type rdf:Property ;
    rdfs:label 'Gxp Regulation' ;
    rdfs:comment 'Specific GxP regulation(s) this control supports (e.g., \'21 CFR Part 211\', \'EU GMP Annex 11\', \'ICH Q7\'). Multiple regulations may be comma-separated. [ENUM-REF-CANDIDATE: 21_cfr_part_11|21_cfr_part_210|21_cfr_part_211|21_cfr_part_312|eu_gmp_annex_11|ich_q7|ich_q10|gdp_guidelines — promote to reference product]' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Applicable Flag' ;
    rdfs:comment 'Indicates whether this control supports HIPAA compliance for protected health information (PHI) in US clinical trials, patient support programs, or pharmacovigilance activities.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyControlFlag rdf:type rdf:Property ;
    rdfs:label 'Key Control Flag' ;
    rdfs:comment 'Indicates whether this is a key control that directly addresses a significant risk and must be tested annually. Key controls are critical to the overall control environment and receive heightened audit focus.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'Date when the control was most recently tested for design and operating effectiveness by internal audit, external audit, or compliance team.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialWeaknessFlag rdf:type rdf:Property ;
    rdfs:label 'Material Weakness Flag' ;
    rdfs:comment 'Indicates whether a material weakness has been identified in this control. Material weaknesses are deficiencies that create a reasonable possibility of material misstatement in financial statements and must be disclosed under SOX Section 404.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'Scheduled date for the next control testing cycle based on control frequency and risk rating. Used for audit planning and compliance monitoring.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:significantDeficiencyFlag rdf:type rdf:Property ;
    rdfs:label 'Significant Deficiency Flag' ;
    rdfs:comment 'Indicates whether a significant deficiency has been identified in this control. Significant deficiencies are less severe than material weaknesses but important enough to merit attention by those charged with governance.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Applicable Flag' ;
    rdfs:comment 'Indicates whether this control is in scope for SOX Section 302/404 compliance and must be tested annually for financial reporting integrity. True if the control is a key control over financial reporting.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testingMethod rdf:type rdf:Property ;
    rdfs:label 'Testing Method' ;
    rdfs:comment 'Primary audit testing procedure used to evaluate control design and operating effectiveness. Inquiry involves asking control performers; Observation involves watching control execution; Inspection involves examining evidence; Reperformance involves auditor executing the control; Data Analytics involves statistical or automated testing.' ;
    rdfs:domain ind:InternalControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlImplemented rdf:type rdf:Property ;
    rdfs:label 'Access Control Implemented' ;
    rdfs:comment 'Indicates whether the system has access controls to limit system access to authorized individuals based on role and responsibility.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessControlMethod rdf:type rdf:Property ;
    rdfs:label 'Access Control Method' ;
    rdfs:comment 'Type of access control mechanism implemented to enforce authorization policies and restrict system functions.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annex11Applicable rdf:type rdf:Property ;
    rdfs:label 'Annex11 Applicable' ;
    rdfs:comment 'Indicates whether the system is subject to EU Annex 11 requirements for computerized systems in GMP environments.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled' ;
    rdfs:comment 'Indicates whether the system has audit trail functionality enabled to capture secure, computer-generated, time-stamped electronic records of user actions.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Review Frequency' ;
    rdfs:comment 'Frequency at which audit trail records are reviewed by quality assurance or system owners to detect unauthorized access or data manipulation.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupRecoveryValidated rdf:type rdf:Property ;
    rdfs:label 'Backup Recovery Validated' ;
    rdfs:comment 'Indicates whether backup and disaster recovery procedures have been validated to ensure data availability and business continuity.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataIntegrityControls rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Controls' ;
    rdfs:comment 'Level of data integrity controls implemented to ensure data is Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, and Available.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataResidencyLocation rdf:type rdf:Property ;
    rdfs:label 'Data Residency Location' ;
    rdfs:comment 'Geographic location or jurisdiction where system data is stored, critical for GDPR and data sovereignty compliance.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the system was retired from production use, requiring data archival and retention procedures per regulatory requirements.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentEnvironment rdf:type rdf:Property ;
    rdfs:label 'Deployment Environment' ;
    rdfs:comment 'Infrastructure deployment model for the system, impacting validation scope and data residency compliance.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureEnabled rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Enabled' ;
    rdfs:comment 'Indicates whether the system supports electronic signatures that are legally binding equivalents to handwritten signatures under Part 11 requirements.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electronicSignatureType rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Type' ;
    rdfs:comment 'Method used for electronic signature implementation, ensuring unique identification and authentication of the signatory.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether the system processes personal data of EU residents and is subject to GDPR privacy and data protection requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Date when the system was first deployed into production and made available for business use following validation approval.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gxpCriticality rdf:type rdf:Property ;
    rdfs:label 'Gxp Criticality' ;
    rdfs:comment 'Classification indicating whether the system directly impacts product quality, patient safety, or data integrity under GxP regulations (GMP, GLP, GCP, GDP).' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaApplicable rdf:type rdf:Property ;
    rdfs:label 'Hipaa Applicable' ;
    rdfs:comment 'Indicates whether the system processes protected health information (PHI) and is subject to HIPAA privacy and security rules.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionFindings rdf:type rdf:Property ;
    rdfs:label 'Inspection Findings' ;
    rdfs:comment 'Classification of findings or observations from the last regulatory inspection related to this system.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:part11Applicable rdf:type rdf:Property ;
    rdfs:label 'Part11 Applicable' ;
    rdfs:comment 'Indicates whether the system is subject to 21 CFR Part 11 requirements for electronic records and electronic signatures.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:part11SystemDescription rdf:type rdf:Property ;
    rdfs:label 'Part11 System Description' ;
    rdfs:comment 'Detailed description of the system\'s business purpose, functional scope, and role in pharmaceutical operations.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Record Retention Period Years' ;
    rdfs:comment 'Number of years that electronic records from this system must be retained to meet regulatory and business requirements.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revalidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Revalidation Due Date' ;
    rdfs:comment 'Scheduled date for periodic revalidation or validation review to ensure continued system compliance and fitness for use.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxControlsApplicable rdf:type rdf:Property ;
    rdfs:label 'Sox Controls Applicable' ;
    rdfs:comment 'Indicates whether the system is subject to SOX internal controls over financial reporting, requiring additional audit and access controls.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemCategory rdf:type rdf:Property ;
    rdfs:label 'System Category' ;
    rdfs:comment 'Functional category of the computerized system indicating its primary business domain and operational scope. [ENUM-REF-CANDIDATE: infrastructure|laboratory|manufacturing|clinical|quality|regulatory|commercial|supply_chain — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemCode rdf:type rdf:Property ;
    rdfs:label 'System Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the system for identification and tracking purposes across compliance documentation.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemName rdf:type rdf:Property ;
    rdfs:label 'System Name' ;
    rdfs:comment 'Official name of the computerized system as registered in the enterprise system inventory.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemOwner rdf:type rdf:Property ;
    rdfs:label 'System Owner' ;
    rdfs:comment 'Name or identifier of the individual or department responsible for the system\'s business operation, compliance, and validation maintenance.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemStatus rdf:type rdf:Property ;
    rdfs:label 'System Status' ;
    rdfs:comment 'Current operational status of the system in the enterprise inventory, indicating whether it is in active use or retired.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemVersion rdf:type rdf:Property ;
    rdfs:label 'System Version' ;
    rdfs:comment 'Current version number or release identifier of the system software, critical for change control and validation documentation.' ;
    rdfs:domain ind:Part11System ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the system under CSV requirements, indicating compliance with documented evidence of system fitness for intended use.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the software vendor or system provider responsible for system development and support.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Policy Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPolicyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Policy Employee Id' ;
    rdfs:comment 'Identifier of the employee who is the designated owner and accountable party for this policy document. Typically a compliance officer, quality manager, or functional leader.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'Primary regulatory citation or framework that this document addresses (e.g., 21 CFR Part 11, EU Annex 11, GDPR Article 32, SOX Section 404, ICH Q10). Multiple regulations may be listed as comma-separated values.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Requirement Flag' ;
    rdfs:comment 'Indicates whether this policy document addresses ALCOA+ (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available) data integrity principles. True = data integrity requirements included; False = not applicable.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionScope rdf:type rdf:Property ;
    rdfs:label 'Distribution Scope' ;
    rdfs:comment 'Defines the organizational scope to which this policy document applies. Enterprise Wide = all employees and sites; Site Specific = applies to designated sites only; Department Specific = applies to specific functional areas; Role Specific = applies to specific job roles; Restricted = limited distribution to authorized personnel only.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'Primary compliance domain category that this document governs. GxP = Good Practice regulations (GMP, GLP, GCP); SOX = Sarbanes-Oxley financial controls; GDPR = General Data Protection Regulation; ABAC = Anti-Bribery and Anti-Corruption; Data Integrity = ALCOA+ principles; CSV = Computer System Validation. [ENUM-REF-CANDIDATE: gxp|sox|gdpr|abac|data_integrity|csv|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed narrative description of the policy document purpose, scope, and key requirements. Provides context and summary of the document content.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Externally-known unique identifier for the policy document following enterprise document numbering convention (e.g., COMP-POL-0001, COMP-SOP-0234).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the policy document. Draft = under development; In Review = submitted for approval; Approved = approved but not yet effective; Effective = currently in force; Superseded = replaced by newer version; Retired = no longer applicable; Obsolete = archived. [ENUM-REF-CANDIDATE: draft|in_review|approved|effective|superseded|retired|obsolete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Document Storage Location' ;
    rdfs:comment 'File path, URL, or repository location where the official controlled copy of this policy document is stored (e.g., Veeva Vault document ID, SharePoint URL, document management system path).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Full title of the compliance policy or procedure document as it appears on the official document.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the document type within the compliance document hierarchy. Policy = high-level governance statement; SOP (Standard Operating Procedure) = detailed operational procedure; Guideline = recommended practice; Work Instruction = step-by-step task instruction; Procedure = process description; Standard = technical specification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicRecordsRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Records Requirement Flag' ;
    rdfs:comment 'Indicates whether this policy addresses electronic records and electronic signatures requirements per 21 CFR Part 11 or EU Annex 11. True = electronic records requirements included; False = not applicable.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprApplicabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicability Flag' ;
    rdfs:comment 'Indicates whether this policy addresses General Data Protection Regulation requirements for personal data protection and privacy. True = GDPR-related policy; False = not GDPR-related.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaApplicabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Applicability Flag' ;
    rdfs:comment 'Indicates whether this policy addresses Health Insurance Portability and Accountability Act requirements for protected health information. True = HIPAA-related policy; False = not HIPAA-related.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date by which the next periodic review of this policy document must be completed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Frequency in months at which this policy document must be reviewed for continued relevance and accuracy (e.g., 12 for annual review, 24 for biennial review).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded Document Number' ;
    rdfs:comment 'Document number of the previous version that this current version supersedes or replaces. Null if this is the first version.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether formal training on this policy document is mandatory for applicable personnel. True = training required; False = training not required.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataProcessingActivityId rdf:type rdf:Property ;
    rdfs:label 'Data Processing Activity Id' ;
    rdfs:comment 'Foreign key linking to compliance.data_processing_activity. Business justification: Privacy Impact Assessments (PIAs/DPIAs) evaluate specific data processing activities for GDPR and privacy compliance. This FK links the assessment to the processing activity being evaluated. The proce' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataProcessingActivity .

ind:assessmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Completion Date' ;
    rdfs:comment 'Date when the privacy impact assessment was completed and approved. Processing must not commence until DPIA is finalized and any required supervisory authority consultation is complete.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentConductedBy rdf:type rdf:Property ;
    rdfs:label 'Assessment Conducted By' ;
    rdfs:comment 'Name and role of the individual or team who conducted the privacy impact assessment. Accountability requirement under GDPR Article 5(2) and Article 24.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the privacy impact assessment, used for tracking and audit purposes. Format: PIA-YYYY-NNNNNN.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Date' ;
    rdfs:comment 'Date when the privacy impact assessment process was initiated. DPIA must be conducted before processing begins under GDPR Article 35(1) and Article 35(10).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:automatedDecisionMaking rdf:type rdf:Property ;
    rdfs:label 'Automated Decision Making' ;
    rdfs:comment 'Indicates whether the processing involves automated decision-making including profiling that produces legal or similarly significant effects. Triggers mandatory DPIA under GDPR Article 35(3)(a).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCategoriesProcessed rdf:type rdf:Property ;
    rdfs:label 'Data Categories Processed' ;
    rdfs:comment 'Comma-separated list of personal data categories processed (e.g., name, contact details, health records, genetic data, biometric identifiers, employment records). Required for GDPR Article 35(7)(b) assessment.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionByDesign rdf:type rdf:Property ;
    rdfs:label 'Data Protection By Design' ;
    rdfs:comment 'Description of how data protection by design and by default principles (GDPR Article 25) are implemented in the processing activity, including technical measures and default settings that minimize data processing.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriod rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period' ;
    rdfs:comment 'Defined retention period for personal data processed in this activity. Must comply with GDPR Article 5(1)(e) storage limitation principle and applicable regulatory requirements (e.g., ICH E6 25-year retention for clinical trial data).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectCategories rdf:type rdf:Property ;
    rdfs:label 'Data Subject Categories' ;
    rdfs:comment 'Categories of individuals whose personal data is processed (e.g., clinical trial subjects, patients, healthcare professionals, employees, contractors). Required for GDPR Article 35(7)(b) assessment.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectConsultation rdf:type rdf:Property ;
    rdfs:label 'Data Subject Consultation' ;
    rdfs:comment 'Description of how data subjects\' views were sought regarding the processing activity, where appropriate. GDPR Article 35(9) requires seeking views of data subjects or their representatives unless inappropriate.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Data Subject Count Estimate' ;
    rdfs:comment 'Estimated number of data subjects whose personal data will be processed. Large-scale processing is a high-risk criterion under GDPR Article 35(3)(b) requiring mandatory DPIA.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataTransferOutsideEea rdf:type rdf:Property ;
    rdfs:label 'Data Transfer Outside Eea' ;
    rdfs:comment 'Indicates whether personal data is transferred outside the EEA. International transfers require additional safeguards under GDPR Chapter V (adequacy decision, standard contractual clauses, or binding corporate rules).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'File path or document management system reference to the full DPIA documentation. GDPR Article 35(7) requires documented assessment; Article 30 requires records of processing activities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Consultation Date' ;
    rdfs:comment 'Date when the DPO was consulted regarding the privacy impact assessment. Required for audit trail and GDPR Article 35(2) compliance demonstration.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpoConsulted rdf:type rdf:Property ;
    rdfs:label 'Dpo Consulted' ;
    rdfs:comment 'Indicates whether the Data Protection Officer was consulted during the DPIA process. DPO consultation is mandatory under GDPR Article 35(2) when conducting a DPIA.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpoRecommendation rdf:type rdf:Property ;
    rdfs:label 'Dpo Recommendation' ;
    rdfs:comment 'DPO\'s advice and recommendations regarding the processing activity, risk mitigation measures, and compliance with GDPR. DPO must provide advice under GDPR Article 39(1)(c).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:largeScaleProcessing rdf:type rdf:Property ;
    rdfs:label 'Large Scale Processing' ;
    rdfs:comment 'Indicates whether the processing activity is considered large-scale under GDPR. Large-scale processing of special category data triggers mandatory DPIA under Article 35(3)(b).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'Legal basis under GDPR Article 6 that justifies the processing of personal data. For special category data (health data in clinical trials), additional Article 9 basis must be documented separately.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures' ;
    rdfs:comment 'Detailed description of technical and organizational measures implemented to mitigate identified risks, including encryption, pseudonymization, access controls, data minimization, and safeguards. Required under GDPR Article 35(7)(d).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:necessityAssessment rdf:type rdf:Property ;
    rdfs:label 'Necessity Assessment' ;
    rdfs:comment 'Assessment of whether the processing is necessary for the specified purpose and whether the same purpose could be achieved with less intrusive means. Required under GDPR Article 35(7)(b) necessity and proportionality evaluation.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'Specific purpose(s) for which personal data is processed in this activity. Must be explicit, legitimate, and specified in accordance with GDPR Article 5(1)(b) purpose limitation principle.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proportionalityAssessment rdf:type rdf:Property ;
    rdfs:label 'Proportionality Assessment' ;
    rdfs:comment 'Assessment of whether the processing is proportionate to the purpose, considering data minimization, storage limitation, and impact on data subjects. Required under GDPR Article 35(7)(b).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Risk level remaining after implementation of mitigation measures. If residual risk remains high, supervisory authority consultation under GDPR Article 36 is mandatory.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskIdentificationSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Identification Summary' ;
    rdfs:comment 'Summary of identified risks to the rights and freedoms of data subjects arising from the processing activity. Includes risks of unauthorized access, data breach, discrimination, identity theft, or other harms. Required under GDPR Article 35(7)(c).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryDataProcessed rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Processed' ;
    rdfs:comment 'Indicates whether special category personal data (health data, genetic data, biometric data) is processed. True triggers heightened GDPR Article 9 requirements and mandatory DPIA under Article 35(3)(b).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Date' ;
    rdfs:comment 'Date when the supervisory authority was consulted regarding the high-risk processing activity. Supervisory authority must respond within 8 weeks (extendable to 14 weeks) under GDPR Article 36(2).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisoryAuthorityConsultationRequired rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Required' ;
    rdfs:comment 'Indicates whether prior consultation with the supervisory authority is required under GDPR Article 36. Required when DPIA indicates high residual risk that cannot be adequately mitigated.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityResponse rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Response' ;
    rdfs:comment 'Written advice received from the supervisory authority following consultation under GDPR Article 36. May include additional measures required or prohibition of processing.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systematicMonitoring rdf:type rdf:Property ;
    rdfs:label 'Systematic Monitoring' ;
    rdfs:comment 'Indicates whether the processing involves systematic monitoring of data subjects. Systematic monitoring of publicly accessible areas triggers mandatory DPIA under GDPR Article 35(3)(c).' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyProcessors rdf:type rdf:Property ;
    rdfs:label 'Third Party Processors' ;
    rdfs:comment 'List of third-party data processors (CROs, CMOs, cloud service providers) involved in the processing activity. Each processor must have a GDPR Article 28 data processing agreement in place.' ;
    rdfs:domain ind:PrivacyImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferMechanism rdf:type rdf:Property ;
    rdfs:label 'Transfer Mechanism' ;
    rdfs:comment 'Legal mechanism used for international data transfers outside EEA (e.g., EU-US Data Privacy Framework adequacy decision, Standard Contractual Clauses, Binding Corporate Rules). Required when data_transfer_outside_eea is true.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPrivacyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Privacy Employee Id' ;
    rdfs:comment 'Identifier of the individual or role responsible for ensuring compliance with this privacy obligation (typically a Data Protection Officer, Privacy Officer, or Compliance Manager).' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableDataCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Data Category' ;
    rdfs:comment 'The category of data to which this obligation applies (e.g., personal data, sensitive health data, clinical trial data, employee data, special category data). May be a comma-separated list for obligations spanning multiple categories.' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'The date by which the organization must achieve or demonstrate compliance with this obligation. Null if no specific deadline applies.' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controlProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Control Procedure Reference' ;
    rdfs:comment 'Reference to the Standard Operating Procedure (SOP), policy document, or control framework that governs how this obligation is fulfilled.' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Dpia Completion Date' ;
    rdfs:comment 'Date when the Data Protection Impact Assessment was completed for this obligation, if applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpiaRequired rdf:type rdf:Property ;
    rdfs:label 'Dpia Required' ;
    rdfs:comment 'Indicates whether a Data Protection Impact Assessment is required for this obligation under GDPR Article 35 or equivalent privacy regulations.' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'External Reference Url' ;
    rdfs:comment 'URL link to external guidance, regulatory text, or official documentation related to this privacy obligation.' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent internal or external audit conducted to verify compliance with this privacy obligation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCitation rdf:type rdf:Property ;
    rdfs:label 'Legal Citation' ;
    rdfs:comment 'Specific legal citation or article reference in the regulation that mandates this obligation (e.g., \'GDPR Article 33\', \'HIPAA 45 CFR 164.404\', \'CCPA Section 1798.150\').' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Human-readable name of the privacy obligation (e.g., \'GDPR Data Subject Access Request\', \'HIPAA Breach Notification\').' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Category of privacy obligation: consent management, data subject rights (access, erasure, portability), breach notification, data retention limits, cross-border transfer restrictions, or privacy impact assessment requirements.' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Maximum financial penalty or fine amount for non-compliance with this obligation, in the specified currency.' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty amount (e.g., EUR, USD, GBP).' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationFramework rdf:type rdf:Property ;
    rdfs:label 'Regulation Framework' ;
    rdfs:comment 'The primary privacy regulation or framework that mandates this obligation (e.g., GDPR, CCPA, HIPAA, LGPD, PIPEDA, APPI).' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeframeHours rdf:type rdf:Property ;
    rdfs:label 'Response Timeframe Hours' ;
    rdfs:comment 'The maximum number of hours allowed to respond to or fulfill this obligation once triggered (e.g., 72 hours for GDPR breach notification, 30 days for data subject access requests).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'The business department or function responsible for implementing and maintaining compliance with this obligation (e.g., Legal, IT, Clinical Operations, Human Resources).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Number of months between scheduled reviews of this privacy obligation (e.g., 6, 12, 24).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionRatePct rdf:type rdf:Property ;
    rdfs:label 'Training Completion Rate Pct' ;
    rdfs:comment 'Percentage of required staff who have completed training related to this privacy obligation.' ;
    rdfs:domain ind:PrivacyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the on-site inspection activities concluded. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Authority Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country of the inspecting regulatory authority (e.g., USA for FDA, GBR for MHRA, JPN for PMDA).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaCompletionTargetDate rdf:type rdf:Property ;
    rdfs:label 'Capa Completion Target Date' ;
    rdfs:comment 'Target date by which all CAPA activities related to the inspection findings are planned to be completed. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Date' ;
    rdfs:comment 'Scheduled or actual date of the follow-up inspection to verify closure of findings. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Required' ;
    rdfs:comment 'Boolean flag indicating whether the regulatory authority has indicated that a follow-up or re-inspection is required to verify corrective actions.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:form483Issued rdf:type rdf:Property ;
    rdfs:label 'Form 483 Issued' ;
    rdfs:comment 'Boolean flag indicating whether the FDA issued a Form 483 (Inspectional Observations) at the conclusion of the inspection. Applicable to FDA inspections only.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectingAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspecting Authority' ;
    rdfs:comment 'Name of the regulatory authority or health agency conducting the inspection (e.g., FDA, EMA, MHRA, PMDA, NMPA, state health department).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Days' ;
    rdfs:comment 'Total number of calendar days the inspection lasted, from actual start to actual end date.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text field for internal notes, observations, or context related to the inspection. May include preparation notes, key discussion points, or lessons learned.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number assigned by the regulatory authority or internal tracking system for this inspection.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Official outcome classification issued by the regulatory authority. NAI (No Action Indicated - no objectionable conditions), VAI (Voluntary Action Indicated - objectionable conditions that do not meet threshold for regulatory action), OAI (Official Action Indicated - significant violations requiring regulatory action), warning_letter (formal enforcement letter issued), consent_decree (legal agreement), pending (outcome not yet determined).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Received Date' ;
    rdfs:comment 'Date when the company received the official inspection report or final classification letter from the regulatory authority. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionReportUrl rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Url' ;
    rdfs:comment 'URL or file path to the stored inspection report document in the document management system (e.g., Veeva Vault RIM or QualityDocs).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection: scheduled (planned but not started), in_progress (inspection underway), completed (inspection finished and report issued), cancelled (inspection did not occur), follow_up_required (additional actions or re-inspection needed).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnnounced rdf:type rdf:Property ;
    rdfs:label 'Is Announced' ;
    rdfs:comment 'Boolean flag indicating whether the inspection was announced (true) or unannounced (false). Unannounced inspections are common for GMP and pharmacovigilance.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadInspectorName rdf:type rdf:Property ;
    rdfs:label 'Lead Inspector Name' ;
    rdfs:comment 'Full name of the lead inspector or principal investigator from the regulatory authority responsible for conducting the inspection.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date when the company was officially notified by the regulatory authority of the upcoming inspection. May be null for unannounced inspections. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfObservations rdf:type rdf:Property ;
    rdfs:label 'Number Of Observations' ;
    rdfs:comment 'Total count of observations, findings, or deficiencies cited by the inspectors during the inspection (e.g., number of items on Form 483 or equivalent inspection report).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Actual date when the company submitted its formal written response to the regulatory authority addressing the inspection findings. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned or scheduled date when the inspection is expected to begin. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primarySoxEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sox Employee Id' ;
    rdfs:comment 'Identifier of the individual who performed the control test, typically from internal audit or management.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountAffected rdf:type rdf:Property ;
    rdfs:label 'Account Affected' ;
    rdfs:comment 'General Ledger account or financial statement line item that this control is designed to protect.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlCode rdf:type rdf:Property ;
    rdfs:label 'Control Code' ;
    rdfs:comment 'Business identifier for the control being tested, typically following organizational control numbering scheme.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityLevelControlFlag rdf:type rdf:Property ;
    rdfs:label 'Entity Level Control Flag' ;
    rdfs:comment 'Indicates whether this is an entity-level control that operates across the organization rather than at a process level.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialStatementAssertion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Assertion' ;
    rdfs:comment 'The specific financial statement assertion(s) addressed by this control (e.g., existence, completeness, valuation, rights and obligations, presentation and disclosure).' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itDependentFlag rdf:type rdf:Property ;
    rdfs:label 'It Dependent Flag' ;
    rdfs:comment 'Indicates whether the control relies on IT general controls or application controls for its effectiveness.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementConclusion rdf:type rdf:Property ;
    rdfs:label 'Management Conclusion' ;
    rdfs:comment 'Management\'s overall conclusion on the operating effectiveness of the control based on test results.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'Business process area to which this control belongs (e.g., Revenue Recognition, Inventory Valuation, Payroll, Fixed Assets).' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Description of the corrective action plan to address identified deficiencies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSelectionMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Selection Method' ;
    rdfs:comment 'Statistical or non-statistical approach used to select the sample from the population for testing.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Test Documentation Reference' ;
    rdfs:comment 'Reference to the location or document management system identifier where detailed test workpapers and evidence are stored.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Test Execution Date' ;
    rdfs:comment 'Date on which the control test was actually performed by the tester.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testObjective rdf:type rdf:Property ;
    rdfs:label 'Test Objective' ;
    rdfs:comment 'Specific objective or assertion being tested for this control (e.g., completeness, accuracy, authorization, existence).' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Test Period End Date' ;
    rdfs:comment 'Ending date of the period for which the control effectiveness is being tested.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Period Start Date' ;
    rdfs:comment 'Beginning date of the period for which the control effectiveness is being tested.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the control test execution.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testerName rdf:type rdf:Property ;
    rdfs:label 'Tester Name' ;
    rdfs:comment 'Full name of the individual who executed the control test.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testerRole rdf:type rdf:Property ;
    rdfs:label 'Tester Role' ;
    rdfs:comment 'Organizational role of the individual performing the test, indicating whether performed by management or audit function.' ;
    rdfs:domain ind:SoxControlTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryThirdAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Third Assessor Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for conducting the due diligence assessment.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:thirdPartyBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Third Party Business Partner Id' ;
    rdfs:comment 'Identifier of the third party entity being assessed (HCP, CRO, CMO, distributor, agent, consultant, vendor).' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:abacScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Abac Screening Date' ;
    rdfs:comment 'Date when anti-bribery and corruption screening was performed.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:abacScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Abac Screening Status' ;
    rdfs:comment 'Status of anti-bribery and corruption due diligence screening to assess corruption risk and compliance with FCPA (Foreign Corrupt Practices Act) and UK Bribery Act.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalConditions rdf:type rdf:Property ;
    rdfs:label 'Approval Conditions' ;
    rdfs:comment 'Specific conditions or restrictions attached to the approval decision, if applicable.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Completed Date' ;
    rdfs:comment 'Date when the due diligence assessment was completed and finalized.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Initiated Date' ;
    rdfs:comment 'Date when the due diligence assessment was formally initiated.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryOfOperation rdf:type rdf:Property ;
    rdfs:label 'Country Of Operation' ;
    rdfs:comment 'Primary country where the third party operates or is registered, using ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Verified Flag' ;
    rdfs:comment 'Indicates whether data integrity controls and ALCOA+ (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available) compliance were verified during due diligence.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debarmentMatchFoundFlag rdf:type rdf:Property ;
    rdfs:label 'Debarment Match Found Flag' ;
    rdfs:comment 'Indicates whether a match was found on any debarment or exclusion list during screening.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debarmentScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Debarment Screening Date' ;
    rdfs:comment 'Date when debarment screening was performed.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debarmentScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Debarment Screening Status' ;
    rdfs:comment 'Status of screening against FDA debarment list, OIG (Office of Inspector General) exclusion list, and other regulatory debarment databases.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDiligenceTier rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Tier' ;
    rdfs:comment 'Level of due diligence rigor applied based on risk assessment. Simplified for low-risk, standard for medium-risk, enhanced for high-risk third parties.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDocumentLocation rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Location' ;
    rdfs:comment 'File path or document management system reference where supporting evidence and documentation for the due diligence assessment is stored.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpComplianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Compliance Verified Flag' ;
    rdfs:comment 'Indicates whether GxP (Good Practice) compliance was verified for third parties involved in GxP-regulated activities (GMP, GLP, GCP, GDP).' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRescreeningDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Rescreening Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic rescreening of the third party.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallRiskRating rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Rating' ;
    rdfs:comment 'Consolidated risk rating assigned to the third party based on all due diligence screening results.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reputationalRiskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Reputational Risk Assessment Date' ;
    rdfs:comment 'Date when reputational risk assessment was performed.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reputationalRiskAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Reputational Risk Assessment Status' ;
    rdfs:comment 'Status of reputational risk assessment including adverse media screening and background checks.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescreeningFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Rescreening Frequency Months' ;
    rdfs:comment 'Number of months between periodic rescreening cycles for ongoing third party relationships.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numerical risk score calculated based on due diligence findings, typically on a scale of 0-100.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sanctionsMatchFoundFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Match Found Flag' ;
    rdfs:comment 'Indicates whether a match was found on any sanctions list during screening.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'Date when sanctions screening was performed.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'Status of sanctions screening against OFAC (Office of Foreign Assets Control) and other global sanctions lists.' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyType rdf:type rdf:Property ;
    rdfs:label 'Third Party Type' ;
    rdfs:comment 'Classification of the third party entity type. HCP = Healthcare Professional, CRO = Contract Research Organization, CMO = Contract Manufacturing Organization, CDMO = Contract Development and Manufacturing Organization. [ENUM-REF-CANDIDATE: HCP|CRO|CMO|CDMO|distributor|agent|consultant|vendor|service_provider|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ThirdPartyDueDiligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningLetterId rdf:type rdf:Property ;
    rdfs:label 'Warning Letter Id' ;
    rdfs:comment 'Unique identifier for the warning letter enforcement action record. Primary key.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarningLetter .

ind:primaryWarningEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Warning Employee Id' ;
    rdfs:comment 'Employee identifier of the individual responsible for coordinating the warning letter response across quality, regulatory, and site teams.' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:receivingEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Receiving Entity Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Warning letters are issued to specific legal entities. The entity must respond and implement CAPAs. Essential for regulatory action tracking, executive reporting, and consent decree management. Remove' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:receivingSiteId rdf:type rdf:Property ;
    rdfs:label 'Receiving Site Id' ;
    rdfs:comment 'Identifier of the manufacturing site, clinical site, or facility that received the warning letter.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:responseDocumentId rdf:type rdf:Property ;
    rdfs:label 'Response Document Id' ;
    rdfs:comment 'Document management system identifier or reference number for the formal response document submitted to the health authority.' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PolicyDocument .

ind:cfrCitations rdf:type rdf:Property ;
    rdfs:label 'Cfr Citations' ;
    rdfs:comment 'Specific CFR citations referenced in the warning letter (e.g., 21 CFR 211.22, 21 CFR 211.160, 21 CFR 312.50). Pipe-separated list for multiple citations.' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citedViolations rdf:type rdf:Property ;
    rdfs:label 'Cited Violations' ;
    rdfs:comment 'Summary of the violations cited in the warning letter, including specific regulatory deficiencies and non-compliance findings.' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Final closure determination by the health authority indicating whether the response and corrective actions were satisfactory.' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Import Alert Flag' ;
    rdfs:comment 'Indicates whether the warning letter resulted in an FDA import alert preventing product importation into the United States.' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date the warning letter was officially issued by the health authority. This is the principal business event timestamp for the enforcement action.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the regulatory health authority that issued the warning letter (e.g., FDA, EMA, MHRA, PMDA, NMPA).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the health authority that issued the letter (e.g., USA, GBR, JPN, CHN, DEU).' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:letterDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Letter Document Url' ;
    rdfs:comment 'Document management system URL or file path to the original warning letter document received from the health authority.' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:letterReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Letter Reference Number' ;
    rdfs:comment 'Official reference number assigned by the health authority to the warning letter or untitled letter (e.g., FDA Warning Letter WL-2023-001234). This is the externally-known unique identifier for the enforcement communication.' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:letterStatus rdf:type rdf:Property ;
    rdfs:label 'Letter Status' ;
    rdfs:comment 'Current lifecycle status of the warning letter from receipt through response, commitment fulfillment, and health authority closure. [ENUM-REF-CANDIDATE: received|under_review|response_in_progress|response_submitted|pending_closure|closed|escalated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:letterType rdf:type rdf:Property ;
    rdfs:label 'Letter Type' ;
    rdfs:comment 'Classification of the enforcement communication type issued by the health authority.' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processScope rdf:type rdf:Property ;
    rdfs:label 'Process Scope' ;
    rdfs:comment 'Description of the manufacturing processes, quality control processes, or clinical trial processes that are within the scope of the warning letter.' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Description of the drug products, drug substances, or biologics that are within the scope of the warning letter. May include product names, NDC codes, or therapeutic areas.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether the warning letter has been publicly disclosed by the health authority (e.g., published on FDA Warning Letters database).' ;
    rdfs:domain ind:WarningLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date the warning letter was received by the organization or site.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:admeProfileId rdf:type rdf:Property ;
    rdfs:label 'Adme Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for each ADME profiling record in the discovery domain. Primary key for the adme_profile data product. Entity role: TRANSACTION_HEADER — captures a discrete ADME assay event with its own lifecycle and results.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assayPanelId rdf:type rdf:Property ;
    rdfs:label 'Assay Panel Id' ;
    rdfs:comment 'Reference to the standardized ADME assay panel applied during this profiling run, defining the battery of tests performed (e.g., Tier 1 ADME screen, full ADME panel).' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssayPanel .

ind:admeRiskScore rdf:type rdf:Property ;
    rdfs:label 'Adme Risk Score' ;
    rdfs:comment 'Composite numerical risk score (e.g., 0–100) summarizing overall ADME liability across solubility, permeability, metabolic stability, and DDI risk dimensions. Used for compound ranking and portfolio prioritization in discovery.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayConcentrationUm rdf:type rdf:Property ;
    rdfs:label 'Assay Concentration Um' ;
    rdfs:comment 'Concentration of the compound used in the ADME assay incubation, expressed in micromolar (µM). Required for result interpretation and inter-assay comparability; standard concentrations are typically 1–10 µM.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayDate rdf:type rdf:Property ;
    rdfs:label 'Assay Date' ;
    rdfs:comment 'Calendar date on which the ADME assay panel was executed in the laboratory. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category (day-level precision for assay scheduling and trending).' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bbbKpUu rdf:type rdf:Property ;
    rdfs:label 'Bbb Kp Uu' ;
    rdfs:comment 'Unbound brain-to-plasma concentration ratio (Kp,uu,brain), the quantitative measure of CNS penetration accounting for plasma protein binding. Values >0.3 indicate meaningful CNS exposure; used in CNS drug discovery programs.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bbbPenetration rdf:type rdf:Property ;
    rdfs:label 'Bbb Penetration' ;
    rdfs:comment 'Indicates whether the compound demonstrates blood-brain barrier penetration based on in vitro BBB assay (e.g., MDCK-MDR1, hCMEC/D3) or in vivo brain-to-plasma ratio. Critical for CNS-targeted and CNS-safety assessments.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bioavailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Bioavailability Pct' ;
    rdfs:comment 'Estimated oral bioavailability percentage (%F) derived from permeability, solubility, and metabolic stability data using predictive ADME models. Key compound progression criterion for oral drug candidates.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearanceMlMinKg rdf:type rdf:Property ;
    rdfs:label 'Clearance Ml Min Kg' ;
    rdfs:comment 'Predicted in vivo hepatic clearance in mL/min/kg, scaled from in vitro microsomal intrinsic clearance using the well-stirred liver model. Used to estimate dose and dosing interval in early drug discovery.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyp2c9InhibitionIc50Um rdf:type rdf:Property ;
    rdfs:label 'Cyp2c9 Inhibition Ic50 Um' ;
    rdfs:comment 'Half-maximal inhibitory concentration (IC50) for CYP2C9 enzyme inhibition in µM. CYP2C9 metabolizes warfarin and NSAIDs; inhibition is a critical DDI safety signal for regulatory submissions.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyp2d6InhibitionIc50Um rdf:type rdf:Property ;
    rdfs:label 'Cyp2d6 Inhibition Ic50 Um' ;
    rdfs:comment 'Half-maximal inhibitory concentration (IC50) for CYP2D6 enzyme inhibition in µM. CYP2D6 metabolizes ~25% of marketed drugs; inhibition is a major DDI liability assessed by FDA and EMA.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyp3a4InhibitionIc50Um rdf:type rdf:Property ;
    rdfs:label 'Cyp3a4 Inhibition Ic50 Um' ;
    rdfs:comment 'Half-maximal inhibitory concentration (IC50) for CYP3A4 enzyme inhibition in µM. CYP3A4 metabolizes ~50% of marketed drugs; inhibition predicts drug-drug interaction (DDI) liability. Key regulatory safety flag.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cypInhibitionFlag rdf:type rdf:Property ;
    rdfs:label 'Cyp Inhibition Flag' ;
    rdfs:comment 'Composite boolean flag indicating whether the compound exhibits significant CYP inhibition risk (any CYP isoform IC50 below the regulatory concern threshold, typically <10 µM). Used for rapid compound triage and progression gating.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effluxRatio rdf:type rdf:Property ;
    rdfs:label 'Efflux Ratio' ;
    rdfs:comment 'Ratio of basolateral-to-apical (B→A) over apical-to-basolateral (A→B) permeability in Caco-2 assay. Values >2 indicate active efflux transport (e.g., P-gp substrate), impacting oral bioavailability and CNS penetration.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elnNotebookReference rdf:type rdf:Property ;
    rdfs:label 'Eln Notebook Reference' ;
    rdfs:comment 'Reference identifier linking this ADME profile to the corresponding experiment entry in the Electronic Lab Notebook (IDBS E-WorkBook or Dotmatics), providing traceability to raw experimental data and GLP documentation.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halfLifeH rdf:type rdf:Property ;
    rdfs:label 'Half Life H' ;
    rdfs:comment 'Predicted or measured plasma half-life of the compound in hours, derived from in vitro microsomal clearance data using allometric scaling or measured directly in in vivo PK studies. Informs dosing frequency predictions.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hlmClintUlMinMg rdf:type rdf:Property ;
    rdfs:label 'Hlm Clint Ul Min Mg' ;
    rdfs:comment 'Intrinsic metabolic clearance measured in human liver microsomes (HLM), expressed as µL/min/mg protein. Used to predict in vivo hepatic clearance and half-life via well-stirred liver model. Critical for dose prediction.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsSampleCode rdf:type rdf:Property ;
    rdfs:label 'Lims Sample Code' ;
    rdfs:comment 'Sample identifier assigned by the LIMS (LabWare or Thermo Fisher SampleManager) for the compound sample used in this ADME assay. Enables traceability from ADME result back to physical sample chain of custody.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metabolicStabilityClass rdf:type rdf:Property ;
    rdfs:label 'Metabolic Stability Class' ;
    rdfs:comment 'Categorical classification of compound metabolic stability based on microsomal half-life thresholds (e.g., low: t½ <30 min, medium: 30–60 min, high: >60 min). Used in compound progression scoring and SAR triage.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microsomalHalfLifeMin rdf:type rdf:Property ;
    rdfs:label 'Microsomal Half Life Min' ;
    rdfs:comment 'In vitro half-life of the compound in liver microsome incubation (human or rat), expressed in minutes. Derived from substrate depletion kinetics; used to classify metabolic stability as low/medium/high.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permeabilityCaco2NmS rdf:type rdf:Property ;
    rdfs:label 'Permeability Caco2 Nm S' ;
    rdfs:comment 'Apparent permeability coefficient (Papp A→B) measured in Caco-2 cell monolayer assay, expressed in nm/s. Predicts intestinal absorption and oral bioavailability. Key ADME parameter for BCS classification.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permeabilityPampaNmS rdf:type rdf:Property ;
    rdfs:label 'Permeability Pampa Nm S' ;
    rdfs:comment 'Passive transcellular permeability measured by PAMPA assay in nm/s. Complements Caco-2 data by isolating passive diffusion component, informing SAR optimization for membrane permeability.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pgpSubstrate rdf:type rdf:Property ;
    rdfs:label 'Pgp Substrate' ;
    rdfs:comment 'Indicates whether the compound is identified as a P-glycoprotein (P-gp / MDR1) efflux transporter substrate based on Caco-2 bidirectional permeability or dedicated P-gp inhibition assay. Impacts CNS penetration and oral bioavailability predictions.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plasmaProteinBindingPct rdf:type rdf:Property ;
    rdfs:label 'Plasma Protein Binding Pct' ;
    rdfs:comment 'Percentage of compound bound to plasma proteins (albumin, alpha-1-acid glycoprotein) measured by equilibrium dialysis or ultrafiltration. Determines free fraction available for pharmacological activity and clearance.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppbMethod rdf:type rdf:Property ;
    rdfs:label 'Ppb Method' ;
    rdfs:comment 'Analytical method used to determine plasma protein binding percentage. Rapid equilibrium dialysis (RED) is the industry standard; method choice affects result interpretation and cross-study comparability.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this ADME profiling run, used in ELN (IDBS/Dotmatics) and LIMS cross-referencing. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current workflow state of the ADME profile record from data entry through scientific review and approval. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS category. [ENUM-REF-CANDIDATE: draft|in_progress|completed|reviewed|approved|invalidated — promote to reference product if additional states are needed]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Progression Recommendation' ;
    rdfs:comment 'Scientific recommendation for compound progression based on the overall ADME profile assessment. Drives hit-to-lead and lead optimization decisions. Assigned by the ADME scientist upon profile review and approval.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rlmClintUlMinMg rdf:type rdf:Property ;
    rdfs:label 'Rlm Clint Ul Min Mg' ;
    rdfs:comment 'Intrinsic metabolic clearance measured in rat liver microsomes (RLM), expressed as µL/min/mg protein. Supports cross-species PK scaling and preclinical-to-clinical translation of metabolic stability data.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solubilityMethod rdf:type rdf:Property ;
    rdfs:label 'Solubility Method' ;
    rdfs:comment 'Analytical method used to determine aqueous solubility, distinguishing kinetic from thermodynamic measurements which have different interpretive implications for drug development.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solubilityUm rdf:type rdf:Property ;
    rdfs:label 'Solubility Um' ;
    rdfs:comment 'Measured aqueous solubility of the compound in micromolar (µM), typically from kinetic or thermodynamic solubility assay. Critical for assessing oral bioavailability and formulation feasibility. Satisfies TRANSACTION_HEADER QUANTITATIVE_RESULT category.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:species rdf:type rdf:Property ;
    rdfs:label 'Species' ;
    rdfs:comment 'Biological species from which the biological matrix (microsomes, plasma, cells) was derived for this ADME assay. Enables cross-species PK comparison and allometric scaling for preclinical-to-clinical translation.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeOfDistributionLKg rdf:type rdf:Property ;
    rdfs:label 'Volume Of Distribution L Kg' ;
    rdfs:comment 'Predicted or measured apparent volume of distribution (Vd) in L/kg, reflecting the extent of compound distribution into tissues versus plasma. Informs PK/PD modeling and dose prediction.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayId rdf:type rdf:Property ;
    rdfs:label 'Assay Id' ;
    rdfs:comment 'Unique surrogate identifier for the assay master record in the discovery domain. Primary key for the assay data product. Role classification: MASTER_RESOURCE.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assay .

ind:responsibleScientistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Scientist Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GxP compliance and regulatory inspections require traceable accountability for assay validation and execution. Responsible scientist must link to qualified employee record for training verification, e' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assayCode rdf:type rdf:Property ;
    rdfs:label 'Assay Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to the assay within the ELN or LIMS (e.g., ASY-HTS0042). Serves as the BUSINESS_IDENTIFIER category for MASTER_RESOURCE role. Used for cross-system referencing between IDBS/Dotmatics, LabWare LIMS, and SAP QM.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayName rdf:type rdf:Property ;
    rdfs:label 'Assay Name' ;
    rdfs:comment 'Full descriptive name of the assay as registered in the ELN (e.g., \'EGFR Kinase Inhibition HTRF Assay\'). Serves as the IDENTITY_LABEL category for MASTER_RESOURCE role. Used in scientific reports, regulatory submissions, and compound screening dashboards.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayType rdf:type rdf:Property ;
    rdfs:label 'Assay Type' ;
    rdfs:comment 'Primary scientific classification of the assay based on its biological or chemical mode of measurement. Serves as the CLASSIFICATION_OR_TYPE category for MASTER_RESOURCE role. Drives downstream SAR analysis workflows and compound triage decisions. [ENUM-REF-CANDIDATE: biochemical|cell_based|phenotypic|ADME|toxicity|binding|functional — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationCompatible rdf:type rdf:Property ;
    rdfs:label 'Automation Compatible' ;
    rdfs:comment 'Indicates whether the assay has been adapted and validated for automated liquid handling platforms (e.g., Hamilton, Tecan, Beckman Coulter). Determines eligibility for inclusion in HTS screening campaigns and impacts throughput capacity planning.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cellLine rdf:type rdf:Property ;
    rdfs:label 'Cell Line' ;
    rdfs:comment 'Name of the cell line used in cell-based assays (e.g., HEK293, HeLa, Jurkat, A549, MCF-7). Null for biochemical or cell-free assays. Required for assay reproducibility and cross-site comparability. Cell line authentication records are maintained in the ELN.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coefficientOfVariationPct rdf:type rdf:Property ;
    rdfs:label 'Coefficient Of Variation Pct' ;
    rdfs:comment 'Percentage coefficient of variation (%CV) of the assay signal across replicate measurements, representing assay precision and reproducibility. Typically required to be ≤ 15% for HTS assays and ≤ 20% for bioanalytical assays per ICH Q2(R1). Stored from the assay validation run.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measurement for compound concentrations used in the assay (e.g., nM, µM, mM). Standardizes concentration reporting across compound screening results and SAR analysis. Required for dose-response curve fitting and IC50/EC50 calculations. [ENUM-REF-CANDIDATE: nM|uM|mM|mg_mL|ug_mL|ng_mL|pM — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerWellUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Well Usd' ;
    rdfs:comment 'Estimated reagent and consumable cost per assay well in US dollars. Used for screening campaign cost modeling, budget planning, and make-vs-buy decisions for outsourcing to CROs. Sourced from SAP S/4HANA MM procurement data and lab supply records.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:croVendorName rdf:type rdf:Property ;
    rdfs:label 'Cro Vendor Name' ;
    rdfs:comment 'Name of the external Contract Research Organization (CRO) executing this assay when outsourced_to_cro is true. Null for in-house assays. Used for vendor performance tracking, contract management, and regulatory audit trail documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Physical or chemical detection principle used to measure the assay signal (e.g., fluorescence, luminescence, radioactivity, mass spectrometry). Distinct from technology_platform — platform is the instrument system, detection_method is the underlying measurement principle. Used for assay validation documentation and GLP compliance records. [ENUM-REF-CANDIDATE: fluorescence|luminescence|absorbance|radioactivity|mass_spectrometry|NMR|SPR|calorimetry — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstUsedDate rdf:type rdf:Property ;
    rdfs:label 'First Used Date' ;
    rdfs:comment 'Date when the assay was first deployed for compound screening or profiling activities. Marks the operational start of the assay lifecycle. Used for assay age tracking, periodic revalidation scheduling, and portfolio lifecycle management.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Operational format describing how the assay is run in the screening workflow (e.g., High-Throughput Screening (HTS) primary screen, dose-response, selectivity panel). Determines throughput capacity planning and compound consumption requirements.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glpCompliant rdf:type rdf:Property ;
    rdfs:label 'Glp Compliant' ;
    rdfs:comment 'Indicates whether the assay is conducted under Good Laboratory Practice (GLP) regulations as required for regulatory submissions (IND/NDA/BLA). GLP-compliant assays require full audit trails, validated equipment, and certified personnel. Critical for preclinical safety study data submitted to FDA/EMA.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hitThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Hit Threshold Unit' ;
    rdfs:comment 'Unit of measurement for the hit_threshold_value (e.g., percent inhibition, nM IC50). Ensures unambiguous interpretation of the hit-calling criterion across different assay types and readout formats.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hitThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Hit Threshold Value' ;
    rdfs:comment 'Numerical threshold used to classify a compound as a \'hit\' in primary screening (e.g., ≥ 50% inhibition at 10 µM). Defined during assay validation and used by automated hit-calling algorithms in the HTS data analysis pipeline. Critical for hit-to-lead progression decisions.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incubationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Incubation Time Hours' ;
    rdfs:comment 'Standard incubation duration in hours for the assay reaction or cell treatment step. Critical for assay reproducibility and scheduling of automated liquid handling workflows. Stored from the validated assay protocol.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastValidatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Validated Date' ;
    rdfs:comment 'Date of the most recent formal validation or requalification of the assay per ICH Q2(R1) or fit-for-purpose qualification criteria. Used to trigger periodic revalidation workflows and to assess whether assay data is current for regulatory submissions.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limsAssayCode rdf:type rdf:Property ;
    rdfs:label 'Lims Assay Code' ;
    rdfs:comment 'Cross-reference identifier for this assay in the Laboratory Information Management System (LIMS) — LabWare or Thermo Fisher SampleManager. Enables bidirectional traceability between the discovery data product and the LIMS assay execution records.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplexed rdf:type rdf:Property ;
    rdfs:label 'Multiplexed' ;
    rdfs:comment 'Indicates whether the assay measures multiple analytes or endpoints simultaneously in a single well or reaction (multiplexed assay). Multiplexed assays increase data density per compound and reduce reagent consumption. Relevant for assay cost modeling and data analysis pipeline configuration.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outsourcedToCro rdf:type rdf:Property ;
    rdfs:label 'Outsourced To Cro' ;
    rdfs:comment 'Indicates whether this assay is currently outsourced to an external Contract Research Organization (CRO) for execution. When true, the cro_vendor_name field captures the CRO identity. Impacts data governance, IP ownership, and regulatory audit trail requirements.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'Name of the research department or functional group that owns and maintains the assay (e.g., \'HTS Group\', \'In Vitro Pharmacology\', \'ADME Sciences\', \'Toxicology\'). Used for resource allocation, cost center attribution, and assay portfolio governance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plateFormat rdf:type rdf:Property ;
    rdfs:label 'Plate Format' ;
    rdfs:comment 'Microplate format used in the assay (e.g., 96-well, 384-well, 1536-well). Determines reagent volumes, automation compatibility, and throughput capacity. Critical for liquid handling robot programming and compound dispensing protocols.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolReference rdf:type rdf:Property ;
    rdfs:label 'Protocol Reference' ;
    rdfs:comment 'Document identifier or URL reference to the Standard Operating Procedure (SOP) or assay protocol document stored in the ELN (IDBS/Dotmatics) or document management system (Veeva Vault QualityDocs). Ensures traceability from assay execution to the governing protocol version.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolVersion rdf:type rdf:Property ;
    rdfs:label 'Protocol Version' ;
    rdfs:comment 'Version number of the assay protocol document in effect at the time of assay execution (e.g., v1.0, v2.3). Required for GLP audit trails and regulatory submission traceability. Distinct from protocol_reference which is the document identifier.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readoutType rdf:type rdf:Property ;
    rdfs:label 'Readout Type' ;
    rdfs:comment 'Primary quantitative output metric reported by the assay (e.g., IC50, EC50, Ki, Kd, percent inhibition, percent activation). Determines how compound activity data is interpreted in SAR analysis and hit-to-lead progression decisions. [ENUM-REF-CANDIDATE: IC50|EC50|Ki|Kd|percent_inhibition|percent_activation|ratio|count|viability_pct — promote to reference product]' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionEligible rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Eligible' ;
    rdfs:comment 'Indicates whether assay results generated using this assay are eligible for inclusion in regulatory submissions (IND, NDA, BLA, MAA). Eligibility requires full validation per ICH Q2(R1) and GLP compliance where applicable. Governs data governance workflows for regulatory data packages.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the assay was formally retired and removed from active use. Null for active assays. Retirement is triggered by target deprioritization, supersession by a superior assay, or platform decommissioning. Required for data governance and historical data archival.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signalWindow rdf:type rdf:Property ;
    rdfs:label 'Signal Window' ;
    rdfs:comment 'Ratio of the maximum signal (positive control) to the minimum signal (negative control), quantifying the dynamic range of the assay. A signal window ≥ 2 is typically required for HTS qualification. Used in assay validation reports and Z-factor calculations.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speciesOrigin rdf:type rdf:Property ;
    rdfs:label 'Species Origin' ;
    rdfs:comment 'Biological species from which the assay target, cells, or biological material is derived (e.g., human, mouse, rat, recombinant). Critical for translational relevance assessment and cross-species selectivity profiling. Impacts regulatory acceptability of preclinical data for IND submissions. [ENUM-REF-CANDIDATE: human|mouse|rat|rabbit|dog|monkey|in_vitro_recombinant — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyPlatform rdf:type rdf:Property ;
    rdfs:label 'Technology Platform' ;
    rdfs:comment 'Detection technology or instrument platform used to execute the assay (e.g., HTRF, AlphaScreen, Surface Plasmon Resonance (SPR), NMR, FRET, TR-FRET, Luminescence, Flow Cytometry). Critical for assay reproducibility assessment and equipment scheduling. [ENUM-REF-CANDIDATE: HTRF|AlphaScreen|SPR|NMR|FRET|TR-FRET|luminescence|flow_cytometry|mass_spectrometry|fluorescence_polarization — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Standard incubation or reaction temperature in degrees Celsius for the assay. Critical for assay reproducibility across sites and instruments. Deviations from this value are flagged as out-of-specification (OOS) events in the LIMS.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputCapacity rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity' ;
    rdfs:comment 'Maximum number of compounds or samples that can be processed per day using this assay under standard HTS conditions. Serves as the MEASUREMENT_OR_VALUE category for MASTER_RESOURCE role. Used for compound library screening campaign planning and resource scheduling in the discovery lab.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zPrimeFactor rdf:type rdf:Property ;
    rdfs:label 'Z Prime Factor' ;
    rdfs:comment 'Statistical measure of assay quality (Z\') calculated from positive and negative control variability. Values ≥ 0.5 indicate an excellent assay suitable for HTS. Stored as the validated Z\' from the assay qualification run. Used to gate assay deployment for compound screening campaigns.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:htsCampaignId rdf:type rdf:Property ;
    rdfs:label 'Hts Campaign Id' ;
    rdfs:comment 'Reference to the High-Throughput Screening (HTS) campaign in LIMS (LabWare or SampleManager) from which the hit compound was originally identified prior to lead optimization. Provides full traceability from HTS hit to development candidate.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HtsCampaign .

ind:leadSeriesId rdf:type rdf:Property ;
    rdfs:label 'Lead Series Id' ;
    rdfs:comment 'Reference to the lead chemical series from which the nominated development candidate was optimized. Supports Structure-Activity Relationship (SAR) traceability and series-level portfolio analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeadSeries .

ind:methodValidationId rdf:type rdf:Property ;
    rdfs:label 'Method Validation Id' ;
    rdfs:comment 'Foreign key linking to quality.method_validation. Business justification: Candidate nomination triggers validation of analytical methods (potency, purity, identity) for the nominated compound. Method validation is a regulatory requirement for IND filing and ensures data qua' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MethodValidation .

ind:nominatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Nominated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory audit trails for IND submissions require traceable accountability for candidate nomination decisions. Links nominator to qualified employee record for verification of scientific authority, ' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:preclinicalPlanId rdf:type rdf:Property ;
    rdfs:label 'Preclinical Plan Id' ;
    rdfs:comment 'Reference to the IND-enabling preclinical development plan created upon approved nomination. Links the nomination milestone to the downstream preclinical program and study schedule.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:admePkSummary rdf:type rdf:Property ;
    rdfs:label 'Adme Pk Summary' ;
    rdfs:comment 'Narrative summary of the compound\'s Absorption, Distribution, Metabolism, and Excretion (ADME) and Pharmacokinetics (PK) profile, including key parameters such as oral bioavailability, half-life, clearance, and metabolic stability. Critical for dose prediction and formulation strategy.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmcFeasibilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Cmc Feasibility Assessment' ;
    rdfs:comment 'Assessment of the Chemistry, Manufacturing, and Controls (CMC) feasibility for the nominated compound, evaluating synthetic accessibility, scalability, and formulation developability. Informs manufacturing strategy and go/no-go decision.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date on which the nomination committee rendered its formal decision (approved, deferred, or rejected) on the development candidate nomination. May differ from nomination_date if committee review takes multiple sessions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deferralReason rdf:type rdf:Property ;
    rdfs:label 'Deferral Reason' ;
    rdfs:comment 'Documented rationale for deferral or rejection of the development candidate nomination, capturing the scientific, safety, CMC, IP, or strategic basis for the committee\'s decision. Required for governance records and future re-nomination consideration.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficacySummary rdf:type rdf:Property ;
    rdfs:label 'Efficacy Summary' ;
    rdfs:comment 'Narrative summary of key in vitro and in vivo efficacy data supporting the nomination, including primary pharmacology results from High-Throughput Screening (HTS) and lead optimization assays. Sourced from LIMS and ELN records.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedIndDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Ind Date' ;
    rdfs:comment 'Projected target date for filing the Investigational New Drug (IND) application with the FDA (or equivalent CTA with EMA/MHRA) based on the approved nomination and preclinical development plan. Key pipeline milestone for portfolio planning.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstInClass rdf:type rdf:Property ;
    rdfs:label 'First In Class' ;
    rdfs:comment 'Indicates whether the nominated development candidate represents a first-in-class mechanism of action with no approved drugs acting on the same molecular target. Informs competitive positioning, IP strategy, and regulatory designation eligibility.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoffDate rdf:type rdf:Property ;
    rdfs:label 'Handoff Date' ;
    rdfs:comment 'Date on which the nominated development candidate was formally handed off to the preclinical development team. Marks the transition from discovery to preclinical and initiates IND-enabling studies planning.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Status' ;
    rdfs:comment 'Current status of intellectual property protection for the nominated development candidate, including patent filing status and Freedom-to-Operate (FTO) assessment outcome. Confidential business data critical for portfolio valuation and licensing strategy.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moaSummary rdf:type rdf:Property ;
    rdfs:label 'Moa Summary' ;
    rdfs:comment 'Narrative summary of the compound\'s Mechanism of Action (MOA) — how it interacts with the molecular target to produce the desired pharmacological effect. Sourced from ELN (IDBS/Dotmatics) and used in IND applications and regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modality rdf:type rdf:Property ;
    rdfs:label 'Modality' ;
    rdfs:comment 'The drug modality class of the nominated development candidate, distinguishing New Chemical Entities (NCE) from New Biological Entities (NBE) and advanced therapy types. Determines regulatory pathway (NDA vs BLA) and CMC strategy.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:molecularTarget rdf:type rdf:Property ;
    rdfs:label 'Molecular Target' ;
    rdfs:comment 'The biological macromolecule (protein, receptor, enzyme, nucleic acid) that the nominated compound is designed to modulate. Central to target identification and Mechanism of Action (MOA) characterization (e.g., EGFR, PD-1, BRAF, JAK1).' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nceNbeClassification rdf:type rdf:Property ;
    rdfs:label 'Nce Nbe Classification' ;
    rdfs:comment 'Classification of the nominated compound as a New Chemical Entity (NCE) — a small molecule not previously approved — or a New Biological Entity (NBE) — a biologic not previously approved. Determines regulatory exclusivity, data protection, and CMC requirements.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationCommittee rdf:type rdf:Property ;
    rdfs:label 'Nomination Committee' ;
    rdfs:comment 'Name or identifier of the governance committee responsible for reviewing and rendering the nomination decision (e.g., Drug Discovery Committee, Portfolio Review Board, R&D Leadership Team). Supports governance traceability.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationDate rdf:type rdf:Property ;
    rdfs:label 'Nomination Date' ;
    rdfs:comment 'The formal calendar date on which the development candidate was officially nominated for progression from discovery into preclinical development. This is the principal business event date for this milestone record.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nominationNumber rdf:type rdf:Property ;
    rdfs:label 'Nomination Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the development candidate nomination (e.g., DC-ONCO-2024-0042). Used in cross-functional communications, regulatory filings, and portfolio tracking systems such as IDBS/Dotmatics ELN.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationStatus rdf:type rdf:Property ;
    rdfs:label 'Nomination Status' ;
    rdfs:comment 'Current lifecycle status of the development candidate nomination decision made by the nomination committee. Drives pipeline progression and resource allocation decisions. [ENUM-REF-CANDIDATE: approved|deferred|rejected|pending_review|withdrawn — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDrugEligible rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Eligible' ;
    rdfs:comment 'Indicates whether the nominated development candidate is potentially eligible for Orphan Drug Designation (ODD) based on the proposed indication affecting fewer than 200,000 patients in the US (or equivalent EU criteria). Triggers early regulatory strategy planning.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioPriority rdf:type rdf:Property ;
    rdfs:label 'Portfolio Priority' ;
    rdfs:comment 'Strategic priority classification assigned to the nominated development candidate by the R&D portfolio governance committee, reflecting unmet medical need, competitive landscape, commercial potential, and scientific confidence. Drives resource allocation.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedIndication rdf:type rdf:Property ;
    rdfs:label 'Proposed Indication' ;
    rdfs:comment 'The specific disease or clinical condition for which the development candidate is proposed to be developed (e.g., Non-Small Cell Lung Cancer, Rheumatoid Arthritis, Sickle Cell Disease). Informs IND strategy and regulatory pathway selection.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPathway rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pathway' ;
    rdfs:comment 'Anticipated regulatory approval pathway for the development candidate based on the proposed indication and unmet medical need (e.g., Standard, Fast Track, Breakthrough Therapy Designation, Accelerated Approval). Drives regulatory strategy and timeline planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySummary rdf:type rdf:Property ;
    rdfs:label 'Safety Summary' ;
    rdfs:comment 'Narrative summary of early safety and tolerability findings from in vitro toxicology screens, genotoxicity assays, and any preliminary in vivo safety studies conducted under Good Laboratory Practice (GLP). Informs risk assessment for IND-enabling studies.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectivityProfile rdf:type rdf:Property ;
    rdfs:label 'Selectivity Profile' ;
    rdfs:comment 'Summary of the compound\'s selectivity against the primary target versus off-target proteins or receptors, derived from selectivity panel screening (e.g., kinase panel, GPCR panel). Informs safety risk and differentiation strategy.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugMasterFileId rdf:type rdf:Property ;
    rdfs:label 'Drug Master File Id' ;
    rdfs:comment 'Foreign key linking to intellectual.drug_master_file. Business justification: Compounds (APIs) are covered by DMFs for regulatory submissions; linkage supports IND/NDA filings, tracks manufacturing site authorization, and enables CMC strategy coordination between discovery and ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugMasterFile .

ind:drugSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Drug Substance Id' ;
    rdfs:comment 'Foreign key linking to product.drug_substance. Business justification: Regulatory CMC requirement: IND/NDA submissions must trace marketed API back to discovery compound for chemistry documentation. Critical for candidate nomination handoff, regulatory filing preparation' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugSubstance .

ind:patentClaimId rdf:type rdf:Property ;
    rdfs:label 'Patent Claim Id' ;
    rdfs:comment 'Foreign key linking to intellectual.patent_claim. Business justification: Compounds must link to patent claims to track IP protection. This is essential for pharmaceutical asset valuation and freedom-to-operate analysis. No visible redundant columns to remove.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentClaim .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Globally unique Chemical Abstracts Service (CAS) registry number assigned by the American Chemical Society to uniquely identify the chemical substance. Used for regulatory submissions, procurement, and cross-system compound lookup.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundClass rdf:type rdf:Property ;
    rdfs:label 'Compound Class' ;
    rdfs:comment 'Broad classification of the compound by molecular modality. Drives regulatory pathway selection (NDA vs BLA), manufacturing strategy (chemical synthesis vs biologics), and analytical method requirements. [ENUM-REF-CANDIDATE: small_molecule|biologic|peptide|adc|oligonucleotide|cell_therapy|rna_therapy|gene_therapy — promote to reference product]' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundName rdf:type rdf:Property ;
    rdfs:label 'Compound Name' ;
    rdfs:comment 'Internal working name or code name assigned to the compound during discovery (e.g., project code name such as \'ABC-1234\'). Used as the primary human-readable label in ELN, LIMS, and CTMS systems before an INN or USAN is assigned.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundStatus rdf:type rdf:Property ;
    rdfs:label 'Compound Status' ;
    rdfs:comment 'Current lifecycle status of the compound within the discovery pipeline. \'Active\' indicates the compound is under active research; \'promoted\' indicates advancement to preclinical or clinical development; \'discontinued\' indicates the compound has been deprioritized or terminated.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryStage rdf:type rdf:Property ;
    rdfs:label 'Discovery Stage' ;
    rdfs:comment 'Current stage of the compound within the drug discovery pipeline. Tracks progression from target identification through hit identification, hit-to-lead, lead optimization, and candidate selection before IND filing. Used for portfolio reporting and stage-gate decision making.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elnReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Eln Reference Code' ;
    rdfs:comment 'Reference identifier linking this compound record to the originating experiment or notebook entry in the Electronic Lab Notebook (ELN) system (IDBS E-WorkBook or Dotmatics). Provides traceability from the compound master record back to the primary research data and synthesis records.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Regulatory classification of the compound as a New Chemical Entity (NCE), New Biological Entity (NBE), biosimilar, fixed-dose combination, or prodrug. Determines regulatory exclusivity periods, patent strategy, and submission pathway under FDA, EMA, and ICH guidelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Globally Harmonized System (GHS) hazard classification for the compound covering health, physical, and environmental hazards (e.g., \'Acute Toxicity Cat. 2, Carcinogen Cat. 1A\'). Required for Safety Data Sheet (SDS) preparation, occupational health risk assessment, and EHS compliance.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hbaCount rdf:type rdf:Property ;
    rdfs:label 'Hba Count' ;
    rdfs:comment 'Number of hydrogen bond acceptors (HBA) in the compound structure. Key Lipinski Rule of Five parameter (threshold: ≤ 10 HBAs) used in drug-likeness assessment and oral bioavailability prediction during hit-to-lead and lead optimization.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hbdCount rdf:type rdf:Property ;
    rdfs:label 'Hbd Count' ;
    rdfs:comment 'Number of hydrogen bond donors (HBD) in the compound structure. Key Lipinski Rule of Five parameter (threshold: ≤ 5 HBDs) used in drug-likeness assessment and oral bioavailability prediction during hit-to-lead and lead optimization.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inchi rdf:type rdf:Property ;
    rdfs:label 'Inchi' ;
    rdfs:comment 'IUPAC International Chemical Identifier (InChI) string providing a standardized, layered representation of the compound\'s chemical structure. Used for cross-system compound deduplication, registry lookups, and interoperability with external databases (PubChem, ChEMBL). Classified confidential as it encodes proprietary structural IP.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inchiKey rdf:type rdf:Property ;
    rdfs:label 'Inchi Key' ;
    rdfs:comment 'Fixed-length 27-character hashed representation of the InChI string (InChIKey). Used as a compact, searchable identifier for compound lookup in external databases (PubChem, ChEMBL, CAS SciFinder) and for deduplication across compound registries.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inn rdf:type rdf:Property ;
    rdfs:label 'Inn' ;
    rdfs:comment 'World Health Organization (WHO)-assigned International Nonproprietary Name (INN) for the active pharmaceutical ingredient. Used in regulatory submissions (NDA, BLA, MAA) and scientific communications. May be null for early-stage compounds not yet assigned an INN.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iupacName rdf:type rdf:Property ;
    rdfs:label 'Iupac Name' ;
    rdfs:comment 'Systematic chemical name of the compound following International Union of Pure and Applied Chemistry (IUPAC) nomenclature rules. Provides an unambiguous, internationally recognized chemical identity for regulatory submissions and scientific publications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which the compound record was last reviewed by a qualified scientist or data steward for accuracy, completeness, and continued relevance in the discovery portfolio. Supports data governance and periodic compound library curation activities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:libraryMembership rdf:type rdf:Property ;
    rdfs:label 'Library Membership' ;
    rdfs:comment 'Designation of the compound library or collection to which this compound belongs within the corporate compound library management system. Drives screening campaign design, compound availability, and resource allocation in HTS and fragment-based drug discovery programs.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logp rdf:type rdf:Property ;
    rdfs:label 'Logp' ;
    rdfs:comment 'Logarithm of the octanol-water partition coefficient (LogP), a measure of the compound\'s lipophilicity. Critical SAR and ADME parameter used to predict membrane permeability, oral bioavailability, and CNS penetration. Lipinski Rule of Five threshold: LogP ≤ 5.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:molecularFormula rdf:type rdf:Property ;
    rdfs:label 'Molecular Formula' ;
    rdfs:comment 'Empirical molecular formula of the compound expressed using Hill notation (e.g., C21H30N2O5). Represents the elemental composition and is used in regulatory submissions, analytical method development, and structural verification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:molecularWeight rdf:type rdf:Property ;
    rdfs:label 'Molecular Weight' ;
    rdfs:comment 'Average molecular weight of the compound expressed in grams per mole (g/mol). Critical physicochemical property used in SAR analysis, ADME profiling, formulation development, and Lipinski Rule of Five drug-likeness assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalState rdf:type rdf:Property ;
    rdfs:label 'Physical State' ;
    rdfs:comment 'Physical state of the compound at standard conditions (solid, liquid, gas, semi-solid). Determines handling procedures, formulation approach, and storage requirements. Captured in the ELN and LIMS at time of compound registration.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTarget rdf:type rdf:Property ;
    rdfs:label 'Primary Target' ;
    rdfs:comment 'Primary biological molecular target of the compound (e.g., gene name, protein name, receptor, enzyme — such as \'EGFR\', \'PD-1\', \'BCL-2\'). Used in target identification, SAR analysis, and cross-compound target coverage analysis within the discovery portfolio.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purityPercent rdf:type rdf:Property ;
    rdfs:label 'Purity Percent' ;
    rdfs:comment 'Measured chemical purity of the compound expressed as a percentage (0.00–100.00%). Determined by analytical methods such as HPLC or NMR. Critical quality attribute (CQA) for assay reliability, GLP compliance, and advancement decisions in hit-to-lead progression.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date on which the compound was formally registered in the corporate compound registry (IDBS/Dotmatics). Marks the official entry of the compound into the discovery compound library and initiates the compound lifecycle tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Internally assigned unique registration number for the compound within the corporate compound registry (e.g., IDBS/Dotmatics compound registration system). Serves as the primary business identifier used across discovery, CMC, and regulatory workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotatableBondCount rdf:type rdf:Property ;
    rdfs:label 'Rotatable Bond Count' ;
    rdfs:comment 'Number of rotatable bonds in the compound structure. Veber rule parameter (threshold: ≤ 10) used alongside TPSA to predict oral bioavailability and molecular flexibility in SAR and lead optimization analyses.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:smiles rdf:type rdf:Property ;
    rdfs:label 'Smiles' ;
    rdfs:comment 'Canonical SMILES (Simplified Molecular Input Line Entry System) string representing the two-dimensional chemical structure of the compound. Used in cheminformatics, HTS data analysis, SAR modeling, and AI/ML-based drug discovery workflows. Classified confidential as it encodes proprietary structural IP.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solubilityAqueousUm rdf:type rdf:Property ;
    rdfs:label 'Solubility Aqueous Um' ;
    rdfs:comment 'Measured or predicted aqueous solubility of the compound expressed in micromolar (µM). Key ADME physicochemical property used in SAR analysis, formulation feasibility assessment, and drug-likeness profiling (Lipinski, Veber rules).' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Origin classification of the compound indicating how it was obtained. Synthesized compounds are produced in-house; purchased compounds are acquired from external vendors or CROs; natural products are derived from biological sources. Impacts IP strategy and CMC documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tpsaAngstrom2 rdf:type rdf:Property ;
    rdfs:label 'Tpsa Angstrom2' ;
    rdfs:comment 'Topological Polar Surface Area (TPSA) of the compound expressed in square angstroms (Å²). Used to predict intestinal absorption, blood-brain barrier penetration, and oral bioavailability. Veber rule threshold: TPSA ≤ 140 Å² for oral drugs.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usan rdf:type rdf:Property ;
    rdfs:label 'Usan' ;
    rdfs:comment 'United States Adopted Name (USAN) assigned by the USAN Council for the compound. Used in US regulatory submissions (NDA/BLA) and US commercial labeling. May differ slightly from INN.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCatalogNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Catalog Number' ;
    rdfs:comment 'Vendor-assigned catalog or product number for purchased compounds. Used for reorder, procurement traceability, and cross-referencing with vendor CoA and SDS documentation. Applicable only when source_type is \'purchased\'.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundSynthesisId rdf:type rdf:Property ;
    rdfs:label 'Compound Synthesis Id' ;
    rdfs:comment 'Unique surrogate identifier for each compound synthesis record in the discovery domain. Primary key for the compound_synthesis data product. Entity role: TRANSACTION_HEADER — a discrete synthesis event with its own lifecycle, reagents, conditions, and outcomes.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventionDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Invention Disclosure Id' ;
    rdfs:comment 'Foreign key linking to intellectual.invention_disclosure. Business justification: Novel synthetic routes and processes are disclosed as inventions; disclosure linkage tracks process IP, supports patent filing for manufacturing methods, and protects CMC innovations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventionDisclosure .

ind:primaryCompoundEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compound Employee Id' ;
    rdfs:comment 'Reference to the medicinal chemist who performed the synthesis. Supports attribution, GLP accountability, and ELN audit trail requirements.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:synthesisRouteId rdf:type rdf:Property ;
    rdfs:label 'Synthesis Route Id' ;
    rdfs:comment 'Reference to the defined synthetic route used for this synthesis event. A route captures the ordered sequence of chemical transformations from starting materials to target compound.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SynthesisRoute .

ind:catalyst rdf:type rdf:Property ;
    rdfs:label 'Catalyst' ;
    rdfs:comment 'Name and loading of the catalyst or catalytic system used in the reaction (e.g., Pd(PPh3)4, Pd2(dba)3/XPhos, DMAP). Null if the reaction is uncatalysed. Critical for SAR and process chemistry knowledge management.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundType rdf:type rdf:Property ;
    rdfs:label 'Compound Type' ;
    rdfs:comment 'Classification of the synthesized compound by modality. Distinguishes New Chemical Entities (NCE), New Biological Entities (NBE), peptides, oligonucleotides, PROTACs, fragments, and natural product derivatives. Drives downstream development pathway and regulatory strategy. [ENUM-REF-CANDIDATE: NCE|NBE|peptide|oligonucleotide|PROTAC|fragment|natural_product_derivative — promote to reference product]' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elnExperimentRef rdf:type rdf:Property ;
    rdfs:label 'Eln Experiment Ref' ;
    rdfs:comment 'Unique experiment identifier from the Electronic Lab Notebook system (IDBS E-WorkBook or Dotmatics) that documents the full experimental procedure, observations, and raw data for this synthesis. Provides traceability back to the authoritative source record.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Free-text description of the reason for synthesis failure or cancellation when synthesis_status is \'failed\' or \'cancelled\'. Captures root cause information (e.g., no reaction observed, product decomposition, purification failure, starting material unavailable) to support process learning and SAR knowledge management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hplcPurityPercent rdf:type rdf:Property ;
    rdfs:label 'Hplc Purity Percent' ;
    rdfs:comment 'Purity of the synthesized compound as determined by High-Performance Liquid Chromatography (HPLC), expressed as area percentage. A Critical Quality Attribute (CQA) for compound registration and screening eligibility. Compounds typically require ≥95% purity for HTS submission.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nmrPurityPercent rdf:type rdf:Property ;
    rdfs:label 'Nmr Purity Percent' ;
    rdfs:comment 'Purity of the synthesized compound as determined by quantitative Nuclear Magnetic Resonance (NMR) spectroscopy, expressed as percentage. Orthogonal purity assessment to HPLC; used for structural confirmation and identity verification per GLP requirements.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productMassMg rdf:type rdf:Property ;
    rdfs:label 'Product Mass Mg' ;
    rdfs:comment 'Actual mass of isolated compound product in milligrams. Used to determine availability for biological screening, ADME assays, and compound library registration. Directly linked to synthesis scale and yield.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purificationMethod rdf:type rdf:Property ;
    rdfs:label 'Purification Method' ;
    rdfs:comment 'Method used to purify the crude reaction product to achieve the required purity specification (e.g., column chromatography, preparative HPLC, recrystallisation, trituration). Influences final yield and purity outcomes and informs process development decisions.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Reaction Duration Hours' ;
    rdfs:comment 'Total elapsed time of the synthesis reaction in hours. A Critical Process Parameter (CPP) used in reaction optimization and SAR/process correlation studies.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reactionTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Reaction Temperature C' ;
    rdfs:comment 'Temperature at which the synthesis reaction was conducted, expressed in degrees Celsius. A Critical Process Parameter (CPP) that directly influences reaction selectivity, yield, and purity. Captured from ELN experimental conditions.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentsDescription rdf:type rdf:Property ;
    rdfs:label 'Reagents Description' ;
    rdfs:comment 'Free-text or structured description of the key reagents and their stoichiometric equivalents used in the synthesis (e.g., \'K2CO3 (2.0 eq), Pd(OAc)2 (5 mol%), SPhos (10 mol%)\'). Supports reproducibility and GLP documentation requirements.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredInLibrary rdf:type rdf:Property ;
    rdfs:label 'Registered In Library' ;
    rdfs:comment 'Indicates whether the synthesized compound has been registered in the corporate compound library for HTS and biological screening. True = registered and available for screening; False = not yet registered or failed registration criteria (e.g., purity < 95%).' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smilesNotation rdf:type rdf:Property ;
    rdfs:label 'Smiles Notation' ;
    rdfs:comment 'Canonical SMILES (Simplified Molecular-Input Line-Entry System) string representing the two-dimensional chemical structure of the synthesized compound. Machine-readable format used for cheminformatics, SAR analysis, and compound database registration in Dotmatics.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solvent rdf:type rdf:Property ;
    rdfs:label 'Solvent' ;
    rdfs:comment 'Name of the primary solvent or solvent system used in the synthesis reaction (e.g., DMF, THF, DCM, EtOH, water). Influences reaction kinetics, selectivity, and downstream purification strategy. Relevant to ICH Q3C solvent classification for later-stage development.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical storage location of the synthesized compound batch (e.g., freezer ID, rack, position in compound management system). Enables inventory management and sample retrieval for biological testing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuralConfirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Structural Confirmation Method' ;
    rdfs:comment 'Analytical technique(s) used to confirm the chemical structure of the synthesized compound (e.g., 1H-NMR, 13C-NMR, LCMS, HRMS, IR, X-ray crystallography). Structural confirmation is mandatory for compound registration and GLP compliance. [ENUM-REF-CANDIDATE: 1H-NMR|13C-NMR|LCMS|HRMS|IR|X-ray|multiple — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synthesisDate rdf:type rdf:Property ;
    rdfs:label 'Synthesis Date' ;
    rdfs:comment 'Calendar date on which the synthesis reaction was initiated. Principal business event date for this transaction record. Used for timeline tracking, GLP compliance dating, and SAR trend analysis.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:synthesisNumber rdf:type rdf:Property ;
    rdfs:label 'Synthesis Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for this synthesis event, typically assigned by the ELN (IDBS E-WorkBook or Dotmatics). Follows site-specific numbering conventions (e.g., MED-SYN-000123). Used for cross-referencing in lab notebooks, SAR databases, and regulatory submissions.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synthesisPurpose rdf:type rdf:Property ;
    rdfs:label 'Synthesis Purpose' ;
    rdfs:comment 'Scientific purpose for which this compound was synthesized. Classifies the synthesis within the drug discovery workflow (e.g., hit confirmation from HTS, lead optimisation, SAR exploration, ADME probe, tool compound, library synthesis). Enables portfolio analytics and resource allocation reporting.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synthesisScaleMmol rdf:type rdf:Property ;
    rdfs:label 'Synthesis Scale Mmol' ;
    rdfs:comment 'Molar scale of the synthesis reaction expressed in millimoles (mmol). Determines reagent quantities, expected yield mass, and suitability for downstream biological screening (e.g., HTS vs. focused assay).' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:synthesisStatus rdf:type rdf:Property ;
    rdfs:label 'Synthesis Status' ;
    rdfs:comment 'Current lifecycle state of the synthesis experiment. Tracks progression from planned through execution to completion or failure. Drives workflow routing in the medicinal chemistry pipeline.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syntheticMethod rdf:type rdf:Property ;
    rdfs:label 'Synthetic Method' ;
    rdfs:comment 'Name or classification of the synthetic methodology applied (e.g., Suzuki coupling, reductive amination, Buchwald-Hartwig amination, solid-phase synthesis). Enables SAR analysis by correlating method with yield and purity outcomes.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Percent' ;
    rdfs:comment 'Isolated yield of the target compound expressed as a percentage of the theoretical maximum based on the limiting reagent. A primary quantitative outcome metric for synthesis efficiency and SAR optimization. Range: 0.00–100.00.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:computationalModelId rdf:type rdf:Property ;
    rdfs:label 'Computational Model Id' ;
    rdfs:comment 'Unique surrogate identifier for the computational or in silico model record within the drug discovery data product. Primary key for the computational_model entity.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Model Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: CSV (Computer System Validation) and regulatory submissions require traceable model ownership to qualified employees. Model validation, change control, and periodic review processes depend on linking ' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:algorithm rdf:type rdf:Property ;
    rdfs:label 'Algorithm' ;
    rdfs:comment 'The computational or machine learning algorithm used to build the model (e.g., \'Random Forest\', \'Support Vector Machine\', \'Deep Neural Network\', \'Glide SP docking\', \'Gaussian Process Regression\'). Essential for reproducibility and scientific peer review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityDomainDescription rdf:type rdf:Property ;
    rdfs:label 'Applicability Domain Description' ;
    rdfs:comment 'Narrative or technical description of the chemical space within which the model is considered reliable (e.g., \'MW 150–600 Da, logP -2 to 5, Tanimoto similarity ≥0.4 to training set\'). Mandatory for OECD-compliant QSAR models; guides scientists on when predictions are trustworthy.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aucRoc rdf:type rdf:Property ;
    rdfs:label 'Auc Roc' ;
    rdfs:comment 'Area Under the Receiver Operating Characteristic Curve performance metric for classification models (range 0.0–1.0). Primary discriminatory performance indicator for virtual screening and ADMET classification models.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compartmentStructure rdf:type rdf:Property ;
    rdfs:label 'Compartment Structure' ;
    rdfs:comment 'Pharmacokinetic compartment structure of the model (e.g., one_compartment, two_compartment, physiologically_based). Applicable to PK/PD and ADME prediction models. Null or not_applicable for QSAR and docking models.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossValidationFolds rdf:type rdf:Property ;
    rdfs:label 'Cross Validation Folds' ;
    rdfs:comment 'Number of folds used in k-fold cross-validation during model training and internal validation (e.g., 5, 10). Null if cross-validation was not used. Supports reproducibility and scientific peer review.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Date on which the model was first deployed to a production or internal scientific environment for active use in compound design or screening decisions.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Operational deployment state of the model within the computational chemistry or pharmacometrics platform. Distinguishes models available for active compound scoring from those under development or retired.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ec50 rdf:type rdf:Property ;
    rdfs:label 'Ec50' ;
    rdfs:comment 'Concentration producing 50% of the maximum pharmacodynamic effect (EC50) in the PK/PD model, expressed in molar or mass concentration units. Key parameter for dose selection and therapeutic window assessment.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elnReference rdf:type rdf:Property ;
    rdfs:label 'Eln Reference' ;
    rdfs:comment 'Reference identifier linking this model to the corresponding experiment or notebook entry in the ELN system (IDBS E-WorkBook or Dotmatics). Provides traceability from the model record back to the primary scientific data and experimental context.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emax rdf:type rdf:Property ;
    rdfs:label 'Emax' ;
    rdfs:comment 'Maximum pharmacodynamic effect (Emax) parameter from a PK/PD model, expressed in the units of the pharmacodynamic endpoint. Applicable only to PK/PD and pharmacometric models; null for QSAR or docking models.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrichmentFactor rdf:type rdf:Property ;
    rdfs:label 'Enrichment Factor' ;
    rdfs:comment 'Enrichment factor at a defined percentage of the ranked library (e.g., EF1% or EF5%) for virtual screening models. Measures the model\'s ability to prioritise active compounds over inactives. Critical for HTS triage decisions.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hillCoefficient rdf:type rdf:Property ;
    rdfs:label 'Hill Coefficient' ;
    rdfs:comment 'Hill coefficient (n or γ) describing the steepness of the concentration-effect relationship in the Emax model. Values >1 indicate cooperative binding; values <1 indicate negative cooperativity. Applicable to PK/PD models only.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGlpCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Glp Compliant' ;
    rdfs:comment 'Indicates whether the model and its supporting data were generated under GLP (Good Laboratory Practice) conditions. GLP-compliant models may be used to support regulatory submissions including IND and NDA/BLA filings.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Externally-known, human-readable unique business identifier for the model (e.g., CM-QSAR0042). Used in scientific publications, ELN references, and cross-system traceability within IDBS E-WorkBook or Dotmatics.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelDescription rdf:type rdf:Property ;
    rdfs:label 'Model Description' ;
    rdfs:comment 'Free-text scientific description of the model\'s purpose, scope, key assumptions, and intended use cases within the drug discovery workflow. Provides context for scientists and regulatory reviewers.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Descriptive human-readable name of the computational model (e.g., \'EGFR Kinase QSAR Model v2\', \'ADMET Solubility Predictor\'). Used as the primary display label in scientific dashboards and model registries.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelStatus rdf:type rdf:Property ;
    rdfs:label 'Model Status' ;
    rdfs:comment 'Current lifecycle state of the computational model. Controls whether the model may be used for active compound design decisions. Validated and deployed models are authoritative for NCE/NBE progression decisions.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Classification of the computational model by its scientific methodology. Drives downstream routing to appropriate validation workflows and performance benchmarks. [ENUM-REF-CANDIDATE: QSAR|molecular_docking|virtual_screening|pharmacophore|PKPD|ADMET|AI_ML_property|scaffold_hopping|free_energy_perturbation|other — promote to reference product]' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Semantic version number of the model (e.g., 1.0, 2.3.1). Enables tracking of model evolution, retraining cycles, and reproducibility of predictions across drug discovery campaigns.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:molecularDescriptorSet rdf:type rdf:Property ;
    rdfs:label 'Molecular Descriptor Set' ;
    rdfs:comment 'Name or description of the molecular descriptor set or fingerprint type used as model input features (e.g., \'ECFP4 Morgan fingerprints\', \'RDKit 2D descriptors\', \'MACCS keys\', \'3D pharmacophore features\'). Required for OECD QSAR Principle 2 (unambiguous algorithm definition).' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Name of the scientific team or department responsible for the model (e.g., \'Computational Chemistry\', \'Pharmacometrics\', \'AI Drug Design\'). Supports organisational accountability and model governance reporting.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictedProperty rdf:type rdf:Property ;
    rdfs:label 'Predicted Property' ;
    rdfs:comment 'The specific biological, physicochemical, or pharmacokinetic property or endpoint the model predicts (e.g., \'pIC50 vs EGFR\', \'aqueous solubility (logS)\', \'human hepatic clearance\', \'hERG inhibition\'). Central to model cataloguing and scientific search.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationReference rdf:type rdf:Property ;
    rdfs:label 'Publication Reference' ;
    rdfs:comment 'DOI, PubMed ID, or internal report number of the scientific publication or technical report describing the model methodology and validation. Supports IP management, scientific credibility, and regulatory submission traceability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rSquared rdf:type rdf:Property ;
    rdfs:label 'R Squared' ;
    rdfs:comment 'R-squared (coefficient of determination) for regression models, measuring the proportion of variance in the predicted property explained by the model. Reported on the external test set per OECD guidelines.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmse rdf:type rdf:Property ;
    rdfs:label 'Rmse' ;
    rdfs:comment 'Root Mean Square Error of prediction on the test set for regression models. Primary accuracy metric for QSAR regression and PK/PD parameter prediction models. Units match the predicted property.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softwarePlatform rdf:type rdf:Property ;
    rdfs:label 'Software Platform' ;
    rdfs:comment 'Name and version of the computational software or platform used to build and run the model (e.g., \'Schrödinger Suite 2023-3\', \'RDKit 2023.09\', \'MOE 2022.02\', \'KNIME 4.7\', \'Python 3.10 / scikit-learn 1.3\'). Required for CSV (Computer System Validation) and reproducibility.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSetSize rdf:type rdf:Property ;
    rdfs:label 'Test Set Size' ;
    rdfs:comment 'Number of compounds or data points in the external test/validation dataset used to assess model generalisability. Distinct from training set; required for OECD-compliant QSAR validation.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingDatasetName rdf:type rdf:Property ;
    rdfs:label 'Training Dataset Name' ;
    rdfs:comment 'Name or identifier of the dataset used to train the model (e.g., \'ChEMBL34_EGFR_IC50\', \'Internal_HTS_2022_Q3\'). Supports data lineage, model reproducibility, and regulatory traceability per OECD QSAR principles.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingSetSize rdf:type rdf:Property ;
    rdfs:label 'Training Set Size' ;
    rdfs:comment 'Number of compounds or data points in the training dataset. Key model quality indicator; small training sets flag potential overfitting risk during scientific review.' ;
    rdfs:domain ind:ComputationalModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationMethod rdf:type rdf:Property ;
    rdfs:label 'Validation Method' ;
    rdfs:comment 'Statistical or experimental method used to validate the model\'s predictive performance (e.g., cross_validation, external_test_set, prospective validation). Determines regulatory acceptability of the model for decision-making.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundLibraryId rdf:type rdf:Property ;
    rdfs:label 'Compound Library Id' ;
    rdfs:comment 'Reference to the primary compound library or collection used in HTS (High-Throughput Screening) campaigns for this project. Links to the compound management system for screening deck traceability.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompoundLibrary .

ind:ftoAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Fto Analysis Id' ;
    rdfs:comment 'Foreign key linking to intellectual.fto_analysis. Business justification: Discovery projects require FTO clearance at stage gates (target validation, lead optimization, candidate nomination); analysis linkage supports portfolio decisions, risk assessment, and strategic plan' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtoAnalysis .

ind:leaderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Leader Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Project resource planning, performance reviews, succession planning, and portfolio governance require FK to employee. Project leader accountability is critical for stage-gate decisions, budget ownersh' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:owningOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Owning Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: Discovery projects are owned and managed by specific organizational units for governance, resource allocation, headcount planning, and portfolio management. Essential for matrix reporting and accounta' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:projectMolecularTargetId rdf:type rdf:Property ;
    rdfs:label 'Project Molecular Target Id' ;
    rdfs:comment 'Standardized identifier for the primary biological target (e.g., UniProt accession, HGNC gene symbol) the project is designed to modulate. Central to SAR analysis and MOA documentation in IDBS/Dotmatics ELN.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MolecularTarget .

ind:actualCandidateNominationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Candidate Nomination Date' ;
    rdfs:comment 'Date on which the development candidate was formally nominated and the project transitioned to preclinical development. Nullable until nomination occurs. Used for cycle time analytics and portfolio performance measurement.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collaborationPartnerName rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partner Name' ;
    rdfs:comment 'Name of the primary external collaboration partner (CRO, academic institution, or partner pharma company) if external_collaboration_flag is true. Classified confidential as it reveals strategic partnership information.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationType rdf:type rdf:Property ;
    rdfs:label 'Collaboration Type' ;
    rdfs:comment 'Classification of the external collaboration arrangement. Determines applicable contractual, IP, and regulatory frameworks governing data sharing and compound rights.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseIndication rdf:type rdf:Property ;
    rdfs:label 'Disease Indication' ;
    rdfs:comment 'Specific disease or condition the project aims to treat or prevent (e.g., Non-Small Cell Lung Cancer, Rheumatoid Arthritis). Free-text aligned to ICD-10 or MeSH terminology for cross-system interoperability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elnProjectCode rdf:type rdf:Property ;
    rdfs:label 'Eln Project Code' ;
    rdfs:comment 'Reference identifier for this discovery project in the IDBS E-WorkBook or Dotmatics ELN system. Enables traceability from the lakehouse silver layer back to the authoritative source system for raw experimental data.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCollaborationFlag rdf:type rdf:Property ;
    rdfs:label 'External Collaboration Flag' ;
    rdfs:comment 'Indicates whether the project involves external partners such as CROs, academic institutions, or other pharmaceutical companies. Triggers additional data governance, IP agreement, and confidentiality controls.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Glp Compliance Flag' ;
    rdfs:comment 'Indicates whether the project\'s studies are conducted under GLP regulations as required for regulatory submission. GLP-compliant studies are required for safety data submitted in IND applications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:htsCampaignCount rdf:type rdf:Property ;
    rdfs:label 'Hts Campaign Count' ;
    rdfs:comment 'Number of HTS campaigns executed under this discovery project. Provides a summary indicator of screening activity volume for portfolio reporting and resource utilization analysis.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd10 Code' ;
    rdfs:comment 'Standardized ICD-10 disease classification code for the primary disease indication. Enables cross-domain linkage to clinical, regulatory, and medical affairs data and supports regulatory submissions.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipStrategyNote rdf:type rdf:Property ;
    rdfs:label 'Ip Strategy Note' ;
    rdfs:comment 'Brief description of the IP strategy for the project, including patentability assessment, freedom-to-operate (FTO) status, and filing intentions. Classified confidential as it contains pre-filing IP strategy.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the discovery project record. Required for data lineage tracking, change control auditing, and incremental ETL processing in the Databricks lakehouse silver layer. Aligns with RECORD_AUDIT_UPDATED canonical category.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:moaDescription rdf:type rdf:Property ;
    rdfs:label 'Moa Description' ;
    rdfs:comment 'Scientific description of the proposed mechanism by which the drug candidate modulates the target to achieve therapeutic effect. Captured from ELN records in IDBS/Dotmatics. Critical for IND and NDA/BLA submissions.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioDecision rdf:type rdf:Property ;
    rdfs:label 'Portfolio Decision' ;
    rdfs:comment 'Most recent portfolio governance committee decision for the project. Recorded at each stage-gate review and drives resource reallocation and pipeline reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Portfolio Decision Date' ;
    rdfs:comment 'Date of the most recent portfolio governance committee decision. Used for audit trail and decision history tracking in conjunction with portfolio_decision.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known alphanumeric project identifier assigned by the portfolio governance office (e.g., DISC-20240001). Used as the business key across IDBS/Dotmatics ELN, SAP project structures, and regulatory submissions. Aligns with the BUSINESS_IDENTIFIER canonical category.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name of the drug discovery project (e.g., \'KRAS G12C Inhibitor Program\'). Classified confidential as it may reveal pipeline strategy prior to public disclosure. Aligns with the IDENTITY_LABEL canonical category.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the discovery project as managed in the portfolio governance system. Drives portfolio dashboards and resource allocation decisions. Aligns with the LIFECYCLE_STATUS canonical category.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the discovery project by the nature of the entity being developed. NCE (New Chemical Entity) and NBE (New Biological Entity) drive distinct regulatory and IP strategies. Aligns with CLASSIFICATION_OR_TYPE canonical category.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedCandidateNominationDate rdf:type rdf:Property ;
    rdfs:label 'Projected Candidate Nomination Date' ;
    rdfs:comment 'Target date by which a development candidate is expected to be nominated and handed off to preclinical development. Key milestone for pipeline planning, IND filing timelines, and portfolio forecasting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP Project System WBS element code that maps this discovery project to the financial controlling structure in SAP S/4HANA. Enables cost allocation, budget tracking, and financial reporting at the project level.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsor rdf:type rdf:Property ;
    rdfs:label 'Sponsor' ;
    rdfs:comment 'Senior executive or therapeutic area head who sponsors and champions the project at the portfolio governance level. Distinct from the project leader who manages day-to-day execution.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Official date on which the discovery project was formally initiated and approved by portfolio governance. Used for project duration calculations, milestone tracking, and portfolio timeline reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Tier' ;
    rdfs:comment 'Portfolio governance classification indicating the strategic importance of the project (Tier 1 = highest priority, Tier 3 = exploratory). Drives resource allocation, budget prioritization, and executive reporting. Classified confidential as it reflects pipeline strategy.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOrganism rdf:type rdf:Property ;
    rdfs:label 'Target Organism' ;
    rdfs:comment 'Primary biological system or organism used in discovery assays and preclinical models. Relevant for GLP study design, species selection justification in IND applications, and ADME/PK modeling.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Documented reason for project termination or discontinuation (e.g., safety signal, lack of efficacy, strategic reprioritization, IP conflict). Nullable for active projects. Critical for lessons-learned analysis and portfolio retrospectives. [ENUM-REF-CANDIDATE: safety_signal|lack_of_efficacy|strategic_reprioritization|ip_conflict|resource_constraints|competitive_landscape|regulatory_concern — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryHtsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Hts Employee Id' ;
    rdfs:comment 'Reference to the scientist or principal investigator responsible for the HTS campaign. Accountable for campaign design, execution quality, and data integrity. Maps to the employee/researcher master record.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assayFormat rdf:type rdf:Property ;
    rdfs:label 'Assay Format' ;
    rdfs:comment 'Scientific format of the assay used in the campaign, indicating whether the screen measures biochemical activity (purified protein), cellular response, whole-organism phenotype, direct binding (biophysical), or fragment-based interactions. Critical for interpreting hit quality and SAR analysis.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayTechnology rdf:type rdf:Property ;
    rdfs:label 'Assay Technology' ;
    rdfs:comment 'Specific detection technology or instrumentation platform used in the assay (e.g., HTRF, AlphaScreen, FRET, TR-FRET, FP, luminescence, absorbance, imaging). Determines data interpretation rules and quality thresholds. [ENUM-REF-CANDIDATE: HTRF|AlphaScreen|FRET|TR-FRET|FP|luminescence|absorbance|imaging|SPR|ITC — promote to reference product]' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the HTS campaign, assigned by the ELN or LIMS system (e.g., HTS-EGFR-2024). Used for cross-system referencing in Dotmatics, LabWare, and project management tools.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Free-text scientific description of the HTS campaign objectives, biological rationale, assay design, and any special conditions or deviations from standard protocols. Provides context for data interpretation and scientific review.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable descriptive name of the HTS campaign, typically including the target name and campaign purpose (e.g., \'EGFR Kinase Primary Screen Q1 2024\'). Used in reports, dashboards, and scientific communications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the HTS campaign, tracking progression from planning through execution to completion or cancellation. Drives operational dashboards and resource allocation decisions.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coefficientOfVariationPercent rdf:type rdf:Property ;
    rdfs:label 'Coefficient Of Variation Percent' ;
    rdfs:comment 'Percentage coefficient of variation of the neutral control wells across all campaign plates, measuring intra- and inter-plate reproducibility. Acceptable CV% thresholds are defined per assay type and are a key quality acceptance criterion.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compoundsScreenedCount rdf:type rdf:Property ;
    rdfs:label 'Compounds Screened Count' ;
    rdfs:comment 'Total number of unique compounds tested in this HTS campaign. Key operational metric for campaign scope, resource planning, and hit rate denominator calculation.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:croInvolved rdf:type rdf:Property ;
    rdfs:label 'Cro Involved' ;
    rdfs:comment 'Indicates whether a Contract Research Organization (CRO) was engaged to execute or support this HTS campaign. Drives vendor management, data transfer agreement requirements, and IP ownership tracking.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Overall data quality assessment for the HTS campaign based on Z\' factor, CV%, plate failure rate, and control performance. Determines whether campaign data is accepted for hit identification and downstream SAR analysis.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedPlateCount rdf:type rdf:Property ;
    rdfs:label 'Failed Plate Count' ;
    rdfs:comment 'Number of assay plates that failed quality control criteria and were excluded from hit identification analysis. High failed plate counts may trigger campaign re-screening decisions.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hitCount rdf:type rdf:Property ;
    rdfs:label 'Hit Count' ;
    rdfs:comment 'Number of compounds that met or exceeded the hit threshold criteria in this campaign. Used to calculate hit rate and to scope confirmatory screening workload.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hitRatePercent rdf:type rdf:Property ;
    rdfs:label 'Hit Rate Percent' ;
    rdfs:comment 'Percentage of screened compounds that qualified as hits (hit_count / compounds_screened_count × 100). Key campaign quality metric used to assess assay selectivity, library quality, and target druggability. Stored as a raw business measurement, not a derived KPI.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hitThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Hit Threshold Percent' ;
    rdfs:comment 'Percentage inhibition or activation threshold used to define a \'hit\' in this campaign (e.g., ≥50% inhibition at screening concentration). Determines the stringency of hit identification and directly impacts hit count and hit rate.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsBatchCode rdf:type rdf:Property ;
    rdfs:label 'Lims Batch Code' ;
    rdfs:comment 'Batch or run identifier assigned by the LIMS (LabWare or Thermo Fisher SampleManager) for the sample processing associated with this HTS campaign. Enables traceability of compound samples, plate preparation, and analytical results.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plateCount rdf:type rdf:Property ;
    rdfs:label 'Plate Count' ;
    rdfs:comment 'Total number of assay plates processed during the campaign. Used for capacity planning, reagent consumption tracking, and quality control review scope.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positiveControlCompound rdf:type rdf:Property ;
    rdfs:label 'Positive Control Compound' ;
    rdfs:comment 'Name or identifier of the reference compound used as the positive control in the assay (known active compound). Defines the 100% inhibition/activation benchmark for data normalization and Z\' factor calculation.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenType rdf:type rdf:Property ;
    rdfs:label 'Screen Type' ;
    rdfs:comment 'Classification of the screening campaign by its scientific purpose in the HTS funnel. Primary screens test the full compound library; confirmatory screens re-test hits; counter-screens eliminate false positives; dose-response screens establish potency; selectivity screens assess off-target activity.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningConcentrationUm rdf:type rdf:Property ;
    rdfs:label 'Screening Concentration Um' ;
    rdfs:comment 'Single-point screening concentration in micromolar (µM) at which compounds are tested in the primary screen. Defines the activity threshold context for hit identification and is a critical parameter for hit rate comparability across campaigns.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signalToBackgroundRatio rdf:type rdf:Property ;
    rdfs:label 'Signal To Background Ratio' ;
    rdfs:comment 'Ratio of the positive control signal to the background (negative control) signal, measuring the dynamic range of the assay. A higher S/B ratio indicates a more robust assay window. Complementary to Z\' factor for assay quality assessment.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetClass rdf:type rdf:Property ;
    rdfs:label 'Target Class' ;
    rdfs:comment 'Pharmacological class of the molecular target being screened. Used for portfolio analysis, technology platform selection, and benchmarking hit rates across target families. [ENUM-REF-CANDIDATE: kinase|GPCR|protease|ion_channel|nuclear_receptor|epigenetic|PPI|phosphatase|transporter|other — promote to reference product]' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Name of the biological target (protein, enzyme, receptor, pathway node) being screened against in this campaign (e.g., EGFR, BRAF V600E, TNF-alpha). Central scientific identifier linking the campaign to the drug discovery target portfolio.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inVitroStudyId rdf:type rdf:Property ;
    rdfs:label 'In Vitro Study Id' ;
    rdfs:comment 'Unique surrogate identifier for each in vitro mechanistic or safety study record in the discovery domain. Primary key for this entity.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assayZPrimeFactor rdf:type rdf:Property ;
    rdfs:label 'Assay Z Prime Factor' ;
    rdfs:comment 'Z\'-factor statistical metric quantifying assay quality and separation between positive and negative controls (range 0–1; values ≥0.5 indicate an excellent assay). Required for HTS and in vitro assay quality acceptance.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biologicalSystemType rdf:type rdf:Property ;
    rdfs:label 'Biological System Type' ;
    rdfs:comment 'Category of the biological system used in the study. Determines the physiological relevance, regulatory acceptance, and interpretation framework for the results.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellLineName rdf:type rdf:Property ;
    rdfs:label 'Cell Line Name' ;
    rdfs:comment 'Specific name or designation of the cell line, primary cell type, organoid model, or other biological system used (e.g., HeLa, HepG2, Caco-2, iPSC-derived hepatocytes). Essential for scientific reproducibility and cross-study comparability.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellLinePassageNumber rdf:type rdf:Property ;
    rdfs:label 'Cell Line Passage Number' ;
    rdfs:comment 'Number of times the cell line has been subcultured since its original isolation or receipt. High passage numbers can affect cell behaviour and result validity; tracked for quality and reproducibility.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compoundBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Compound Batch Number' ;
    rdfs:comment 'Specific batch or lot identifier of the compound used in this study. Critical for reproducibility, traceability, and investigation of batch-to-batch variability in results.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationMaxNm rdf:type rdf:Property ;
    rdfs:label 'Concentration Max Nm' ;
    rdfs:comment 'Highest concentration of the compound tested in this study, expressed in nanomolar (nM). Defines the upper bound of the concentration-response range; used to assess ceiling effects and cytotoxicity thresholds.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationMinNm rdf:type rdf:Property ;
    rdfs:label 'Concentration Min Nm' ;
    rdfs:comment 'Lowest concentration of the compound tested in this study, expressed in nanomolar (nM). Defines the lower bound of the concentration-response range used for dose-response modelling.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationPointCount rdf:type rdf:Property ;
    rdfs:label 'Concentration Point Count' ;
    rdfs:comment 'Number of distinct concentration levels tested in the dose-response series. Indicates the resolution of the concentration-response curve and the robustness of derived potency estimates.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cytotoxicityFlag rdf:type rdf:Property ;
    rdfs:label 'Cytotoxicity Flag' ;
    rdfs:comment 'Indicates whether cytotoxic effects were observed at the tested concentration range. A True value signals that the primary endpoint result may be confounded by non-specific cell death and requires scientific interpretation caution.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cytotoxicityThresholdNm rdf:type rdf:Property ;
    rdfs:label 'Cytotoxicity Threshold Nm' ;
    rdfs:comment 'Concentration in nanomolar at which cytotoxic effects were first observed (CC50 or NOEC for cytotoxicity). Used to define the safe concentration window for interpreting mechanistic results.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Glp Compliant Flag' ;
    rdfs:comment 'Indicates whether this in vitro study was conducted in full compliance with Good Laboratory Practice (GLP) regulations. GLP-compliant studies are required for regulatory submissions supporting IND/NDA/BLA applications.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incubationTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Incubation Temperature C' ;
    rdfs:comment 'Temperature in degrees Celsius at which the compound was incubated with the biological system. Deviations from protocol-specified temperature can invalidate results.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moaConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Moa Confirmed Flag' ;
    rdfs:comment 'Indicates whether this study confirmed the hypothesised mechanism of action (MOA) for the compound at the tested target. A True value supports progression to the next stage of hit-to-lead development.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:positiveControlResult rdf:type rdf:Property ;
    rdfs:label 'Positive Control Result' ;
    rdfs:comment 'Measured result value for the positive control compound included in this study run. Used to validate assay performance and confirm that the assay window is within acceptable limits.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replicateCount rdf:type rdf:Property ;
    rdfs:label 'Replicate Count' ;
    rdfs:comment 'Number of independent experimental replicates performed for this study. Higher replicate counts increase statistical confidence; minimum thresholds are defined in the study protocol.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultConfidenceInterval rdf:type rdf:Property ;
    rdfs:label 'Result Confidence Interval' ;
    rdfs:comment '95% confidence interval for the primary result value, expressed as a string range (e.g., \'0.032-0.061 µM\'). Quantifies statistical uncertainty around the point estimate for SAR and progression decisions.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultQualifier rdf:type rdf:Property ;
    rdfs:label 'Result Qualifier' ;
    rdfs:comment 'Relational qualifier for the result value indicating whether the measurement is exact, a lower bound, or an upper bound (e.g., \'>\' for greater than, \'<\' for less than). Used when the true value falls outside the assay detection range.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectivityRatio rdf:type rdf:Property ;
    rdfs:label 'Selectivity Ratio' ;
    rdfs:comment 'Ratio of the cytotoxicity threshold (CC50) to the primary pharmacological potency endpoint (IC50/EC50). A higher ratio indicates greater selectivity for the intended target over non-specific cytotoxic effects. Key SAR metric for compound progression.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyDate rdf:type rdf:Property ;
    rdfs:label 'Study Date' ;
    rdfs:comment 'Calendar date on which the in vitro study experiment was physically conducted. Distinct from the record creation timestamp; used for scientific timeline tracking and GLP audit trail.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyNumber rdf:type rdf:Property ;
    rdfs:label 'Study Number' ;
    rdfs:comment 'Externally-known, human-readable unique study identifier assigned by the ELN (IDBS E-WorkBook or Dotmatics) or LIMS at study initiation. Used for cross-system traceability and regulatory reference. Format: IVS-<ProjectCode>-<SequenceNumber>.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle state of the in vitro study. Controls workflow progression from planning through execution to data review and archival.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyTitle rdf:type rdf:Property ;
    rdfs:label 'Study Title' ;
    rdfs:comment 'Descriptive title of the in vitro study summarising the scientific objective, biological system, and compound under investigation. Used for search, reporting, and scientific communication.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Vehicle Concentration Pct' ;
    rdfs:comment 'Final concentration of the vehicle/solvent in the assay expressed as a percentage. Concentrations above accepted thresholds (e.g., >0.1% DMSO) can cause non-specific cytotoxicity or assay interference.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleSolvent rdf:type rdf:Property ;
    rdfs:label 'Vehicle Solvent' ;
    rdfs:comment 'Solvent or vehicle used to dissolve and dilute the compound for testing (e.g., DMSO, PBS, ethanol). Solvent effects can confound results; tracked for quality control and reproducibility.' ;
    rdfs:domain ind:InVitroStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inVivoStudyId rdf:type rdf:Property ;
    rdfs:label 'In Vivo Study Id' ;
    rdfs:comment 'Unique surrogate identifier for the in vivo animal study record within the discovery domain lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InVivoStudy .

ind:studyDirectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Study Director Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GLP compliance mandates study director accountability with traceable qualifications. FDA inspections verify study director training, experience, and authority. FK to employee enables verification of G' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:animalCount rdf:type rdf:Property ;
    rdfs:label 'Animal Count' ;
    rdfs:comment 'Total number of animals used across all dose groups in the study. Required for IACUC protocol compliance, 3Rs (Replacement, Reduction, Refinement) reporting, and statistical power justification.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:animalSex rdf:type rdf:Property ;
    rdfs:label 'Animal Sex' ;
    rdfs:comment 'Sex of the animals used in the study (male, female, or both sexes). Relevant for sex-specific PK/PD differences, hormonal effects, and regulatory requirements for balanced study design.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalSpecies rdf:type rdf:Property ;
    rdfs:label 'Animal Species' ;
    rdfs:comment 'Species of animal used in the in vivo study (e.g., mouse, rat, dog, non-human primate). Determines applicable regulatory guidelines, PK/PD scaling factors, and IACUC protocol requirements. [ENUM-REF-CANDIDATE: mouse|rat|rabbit|dog|monkey|minipig|hamster|guinea_pig — promote to reference product]' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalStrain rdf:type rdf:Property ;
    rdfs:label 'Animal Strain' ;
    rdfs:comment 'Specific strain or substrain of the animal species used (e.g., C57BL/6 mouse, Sprague-Dawley rat, Beagle dog). Strain selection impacts pharmacological response, metabolic profile, and cross-study comparability.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundIdentifier rdf:type rdf:Property ;
    rdfs:label 'Compound Identifier' ;
    rdfs:comment 'Internal compound registration number or code (e.g., NCE/NBE identifier from the compound library) as assigned in the ELN or compound management system. Denormalized here for operational traceability without requiring a join. Classified confidential due to IP sensitivity.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conductingFacility rdf:type rdf:Property ;
    rdfs:label 'Conducting Facility' ;
    rdfs:comment 'Name of the facility (internal research site or external CRO/CMO) where the in vivo study was physically conducted. Relevant for multi-site studies, CRO oversight, and GLP facility qualification tracking.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:croFlag rdf:type rdf:Property ;
    rdfs:label 'Cro Flag' ;
    rdfs:comment 'Indicates whether the study was outsourced to a Contract Research Organization (CRO) rather than conducted in-house. Drives CRO oversight workflows, contract management linkage, and sponsor responsibility documentation under GLP.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doseFrequency rdf:type rdf:Property ;
    rdfs:label 'Dose Frequency' ;
    rdfs:comment 'Frequency of compound administration during the study (e.g., single dose, once daily, twice daily). Defines the dosing regimen and is critical for PK/PD modeling and exposure calculations.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseLevels rdf:type rdf:Property ;
    rdfs:label 'Dose Levels' ;
    rdfs:comment 'Comma-separated list of dose levels tested in the study (e.g., \'1, 3, 10, 30\' in the unit specified by dose_unit). Captures the full dose range including vehicle/control group. Stored as a structured string for multi-dose studies; individual dose group records are managed in the study design detail.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseRoute rdf:type rdf:Property ;
    rdfs:label 'Dose Route' ;
    rdfs:comment 'Route of compound administration to the animals (e.g., oral, intravenous, subcutaneous). Directly impacts bioavailability, PK profile, and translational relevance to the intended clinical route. [ENUM-REF-CANDIDATE: oral|intravenous|subcutaneous|intraperitoneal|intramuscular|inhalation|topical|intranasal — promote to reference product]' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseUnit rdf:type rdf:Property ;
    rdfs:label 'Dose Unit' ;
    rdfs:comment 'Unit of measurement for dose levels administered in the study (e.g., mg/kg, µg/kg). Standardized unit required for cross-study comparability, allometric scaling, and regulatory submission.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficacyEndpoint rdf:type rdf:Property ;
    rdfs:label 'Efficacy Endpoint' ;
    rdfs:comment 'Description of the primary efficacy endpoint measured in the study (e.g., tumor volume reduction, blood glucose normalization, survival rate, biomarker inhibition percentage). Defines the scientific success criterion for the study and links to the compound\'s mechanism of action (MOA).' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficacyResultSummary rdf:type rdf:Property ;
    rdfs:label 'Efficacy Result Summary' ;
    rdfs:comment 'Narrative summary of the primary efficacy outcome observed in the study (e.g., \'60% tumor growth inhibition at 10 mg/kg QD\', \'statistically significant reduction in target biomarker at all dose levels\'). Supports portfolio review and go/no-go decision-making.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iacucApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Iacuc Approval Date' ;
    rdfs:comment 'Date on which the IACUC protocol was formally approved, authorizing the commencement of animal studies. Study start_date must not precede this date. Critical for GLP compliance and regulatory audit readiness.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iacucProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Iacuc Protocol Number' ;
    rdfs:comment 'Unique protocol number assigned by the Institutional Animal Care and Use Committee (IACUC) approving the animal use in this study. Mandatory for all in vivo studies conducted in the US under the Animal Welfare Act and PHS Policy. Required for regulatory submissions and audit.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsStudyReference rdf:type rdf:Property ;
    rdfs:label 'Lims Study Reference' ;
    rdfs:comment 'Reference identifier linking this study record to the corresponding study or sample set in the LIMS (LabWare or Thermo Fisher SampleManager). Enables traceability of sample management, analytical results, and chain of custody for study samples.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noaelMgKg rdf:type rdf:Property ;
    rdfs:label 'Noael Mg Kg' ;
    rdfs:comment 'No Observed Adverse Effect Level (NOAEL) determined from the study, expressed in mg/kg. The highest dose at which no statistically or biologically significant adverse effects were observed. Critical for safety margin calculations, human dose prediction, and IND-enabling study packages.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pkAucNgMlH rdf:type rdf:Property ;
    rdfs:label 'Pk Auc Ng Ml H' ;
    rdfs:comment 'Area Under the plasma concentration-time Curve (AUC) representing total systemic exposure to the compound, expressed in ng·mL⁻¹·h. Fundamental PK parameter for bioavailability assessment, dose proportionality analysis, and PK/PD modeling.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pkBioavailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Pk Bioavailability Pct' ;
    rdfs:comment 'Absolute oral bioavailability (%F) of the compound expressed as a percentage, calculated as the ratio of AUC after oral administration to AUC after intravenous administration. Critical for oral drug candidate selection and dose prediction.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pkClearanceMlMinKg rdf:type rdf:Property ;
    rdfs:label 'Pk Clearance Ml Min Kg' ;
    rdfs:comment 'Systemic clearance (CL) of the compound normalized to body weight (mL/min/kg). Represents the volume of plasma cleared of the compound per unit time. Key parameter for predicting human PK and first-in-human dose selection.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pkCmaxNgMl rdf:type rdf:Property ;
    rdfs:label 'Pk Cmax Ng Ml' ;
    rdfs:comment 'Maximum observed plasma concentration (Cmax) of the compound following administration, expressed in nanograms per milliliter (ng/mL). Key PK parameter for exposure assessment, dose-response modeling, and allometric scaling to human dose prediction.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pkHalfLifeH rdf:type rdf:Property ;
    rdfs:label 'Pk Half Life H' ;
    rdfs:comment 'Terminal elimination half-life (t½) of the compound in hours, representing the time required for plasma concentration to decrease by 50%. Used for dosing frequency determination, accumulation prediction, and species-to-human PK translation.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pkVdLKg rdf:type rdf:Property ;
    rdfs:label 'Pk Vd L Kg' ;
    rdfs:comment 'Apparent volume of distribution (Vd) of the compound normalized to body weight (L/kg). Indicates the extent of tissue distribution versus plasma binding. Critical for PK/PD modeling and human dose prediction via allometric scaling.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:principalInvestigator rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator' ;
    rdfs:comment 'Full name of the Principal Investigator (PI) responsible for the scientific design and execution of the study. May differ from the Study Director in multi-site or CRO-conducted studies. Classified confidential as an internal personnel reference.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDurationDays rdf:type rdf:Property ;
    rdfs:label 'Study Duration Days' ;
    rdfs:comment 'Total planned duration of the in vivo study in calendar days from first dose to last observation/sample collection. Used for study planning, resource allocation, and regulatory classification (e.g., single-dose vs. repeat-dose toxicology).' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyPhase rdf:type rdf:Property ;
    rdfs:label 'Study Phase' ;
    rdfs:comment 'Drug discovery pipeline phase during which this in vivo study was conducted. Indicates the maturity of the compound under investigation and the decision gate this study supports (e.g., hit-to-lead progression, candidate selection).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyReportNumber rdf:type rdf:Property ;
    rdfs:label 'Study Report Number' ;
    rdfs:comment 'Unique identifier of the final GLP or non-GLP study report generated upon study completion. Used for cross-referencing in regulatory submissions (IND, NDA, BLA, eCTD), dossier compilation, and audit trail. Null until the study report is issued.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerabilityFinding rdf:type rdf:Property ;
    rdfs:label 'Tolerability Finding' ;
    rdfs:comment 'Summary of tolerability observations recorded during the study, including body weight changes, clinical signs, and any adverse findings at tested dose levels. Informs the therapeutic index assessment and maximum tolerated dose (MTD) determination for candidate progression.' ;
    rdfs:domain ind:InVivoStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bestInClassCompoundId rdf:type rdf:Property ;
    rdfs:label 'Best In Class Compound Id' ;
    rdfs:comment 'Reference to the compound record representing the best-performing compound within this lead series at the current stage, used as the benchmark for potency, selectivity, and ADME profiling comparisons.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:admeProfileSummary rdf:type rdf:Property ;
    rdfs:label 'Adme Profile Summary' ;
    rdfs:comment 'Summary of the Absorption, Distribution, Metabolism, and Excretion (ADME) profile for the lead series, including key in vitro ADME data such as microsomal stability, permeability (Caco-2/PAMPA), plasma protein binding, and CYP inhibition flags.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundCount rdf:type rdf:Property ;
    rdfs:label 'Compound Count' ;
    rdfs:comment 'Total number of discrete compounds synthesized and registered within this lead series. Indicates the breadth of SAR exploration and medicinal chemistry effort invested in the series.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentStage rdf:type rdf:Property ;
    rdfs:label 'Current Stage' ;
    rdfs:comment 'Current stage of the lead series within the drug discovery pipeline, from hit confirmation through candidate nomination. Distinct from series_status in that it reflects the scientific progression stage rather than the governance lifecycle state.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprioritizationDate rdf:type rdf:Property ;
    rdfs:label 'Deprioritization Date' ;
    rdfs:comment 'Date on which the lead series was formally deprioritized or stopped. Null if the series is still active. Used for portfolio analytics and resource reallocation tracking.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugLikenessScore rdf:type rdf:Property ;
    rdfs:label 'Drug Likeness Score' ;
    rdfs:comment 'Composite drug-likeness score for the best-in-class compound in the series, typically based on Lipinski Rule of Five parameters or QED (Quantitative Estimate of Drug-likeness). Ranges from 0 to 1; higher values indicate better drug-likeness.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipLandscapeAssessment rdf:type rdf:Property ;
    rdfs:label 'Ip Landscape Assessment' ;
    rdfs:comment 'Narrative assessment of the Intellectual Property (IP) landscape for the lead series, including freedom-to-operate (FTO) status, known competitor patents covering the scaffold, and patentability assessment. Classified as confidential due to competitive sensitivity.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:molecularWeightDa rdf:type rdf:Property ;
    rdfs:label 'Molecular Weight Da' ;
    rdfs:comment 'Molecular weight of the core scaffold or best-in-class compound in Daltons (Da). Key physicochemical property used in drug-likeness assessment (Lipinski Rule of Five: MW ≤ 500 Da for oral drugs).' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oralBioavailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Oral Bioavailability Pct' ;
    rdfs:comment 'Best-in-class oral bioavailability percentage (%F) for the lead series from preclinical in vivo PK studies. Key ADME metric for assessing drug-likeness and oral dosing feasibility.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pkProfileSummary rdf:type rdf:Property ;
    rdfs:label 'Pk Profile Summary' ;
    rdfs:comment 'Summary of in vivo Pharmacokinetics (PK) data for the lead series, including key parameters such as oral bioavailability (%F), half-life (t½), clearance (CL), and volume of distribution (Vd) from preclinical species studies.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potencyAssayType rdf:type rdf:Property ;
    rdfs:label 'Potency Assay Type' ;
    rdfs:comment 'Type of biochemical or cellular assay used to determine the potency benchmark value (e.g., IC50, Ki, EC50, Kd). Provides context for interpreting the potency_benchmark_nm value.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potencyBenchmarkNm rdf:type rdf:Property ;
    rdfs:label 'Potency Benchmark Nm' ;
    rdfs:comment 'Best-in-class potency value (IC50 or Ki) for the lead series expressed in nanomolar (nM) concentration. Represents the principal quantitative performance metric for the series and is used in stage-gate go/no-go decisions.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Flag' ;
    rdfs:comment 'Indicates whether any significant safety liabilities (e.g., genotoxicity, hERG inhibition, reactive metabolites, phototoxicity) have been identified for compounds in this lead series. True = known safety liability requiring mitigation.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyLiabilityNotes rdf:type rdf:Property ;
    rdfs:label 'Safety Liability Notes' ;
    rdfs:comment 'Narrative description of identified safety liabilities for the lead series, including the nature of the liability, affected compounds, and proposed mitigation strategies. Populated when safety_flag is True.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarMaturityLevel rdf:type rdf:Property ;
    rdfs:label 'Sar Maturity Level' ;
    rdfs:comment 'Qualitative assessment of the maturity of the Structure-Activity Relationship (SAR) understanding for the lead series, from early (limited data) to mature (well-defined SAR with predictive models). Used in stage-gate assessments.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaffoldDescription rdf:type rdf:Property ;
    rdfs:label 'Scaffold Description' ;
    rdfs:comment 'Textual description of the core chemical scaffold or chemotype defining the lead series, including key structural features relevant to Structure-Activity Relationship (SAR) analysis. Captured from ELN records.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectivityProfileSummary rdf:type rdf:Property ;
    rdfs:label 'Selectivity Profile Summary' ;
    rdfs:comment 'Narrative summary of the selectivity profile for the lead series, describing off-target activity, selectivity ratios against related targets, and any known liabilities identified through selectivity panels (e.g., kinase selectivity panel, GPCR panel).' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesCode rdf:type rdf:Property ;
    rdfs:label 'Series Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the lead series within the compound governance system (e.g., ONCO-SER-00042). Used as the business identifier across ELN, LIMS, and medicinal chemistry platforms.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesName rdf:type rdf:Property ;
    rdfs:label 'Series Name' ;
    rdfs:comment 'Human-readable name assigned to the lead series, typically reflecting the chemotype or scaffold class (e.g., \'Pyrimidine Kinase Inhibitor Series A\'). Used in medicinal chemistry reports and stage-gate presentations.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesStartDate rdf:type rdf:Property ;
    rdfs:label 'Series Start Date' ;
    rdfs:comment 'Date on which the lead series was formally initiated following hit confirmation from the originating HTS campaign. Marks the beginning of the hit-to-lead phase and is used for timeline and cycle-time analytics.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seriesStatus rdf:type rdf:Property ;
    rdfs:label 'Series Status' ;
    rdfs:comment 'Current lifecycle status of the lead series within the drug discovery pipeline. Governs stage-gate decisions and resource allocation. Values: hit_to_lead (active hit confirmation and early profiling), lead_optimization (active medicinal chemistry optimization), deprioritized (paused or stopped), nominated (candidate nominated for development), on_hold (temporarily paused pending decision).' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smilesScaffold rdf:type rdf:Property ;
    rdfs:label 'Smiles Scaffold' ;
    rdfs:comment 'Simplified Molecular Input Line Entry System (SMILES) string representing the core scaffold structure of the lead series. Enables cheminformatics analysis, substructure searching, and computational chemistry workflows.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageGateDate rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Date' ;
    rdfs:comment 'Date on which the most recent stage-gate committee decision was made for this lead series. Used for tracking progression timelines and portfolio reporting.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageGateDecision rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Decision' ;
    rdfs:comment 'Most recent stage-gate committee decision for the lead series, indicating whether the series has been approved to progress (go), stopped (no_go), placed on hold, or conditionally approved pending specific criteria.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageGateRationale rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Rationale' ;
    rdfs:comment 'Documented rationale for the most recent stage-gate decision, capturing the scientific, strategic, and risk-based reasoning of the decision committee. Supports audit trail and portfolio governance.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPatentClaimId rdf:type rdf:Property ;
    rdfs:label 'Primary Patent Claim Id' ;
    rdfs:comment 'Foreign key linking to intellectual.patent_claim. Business justification: Specific patent claims cover target modulation methods; claim-level tracking required for FTO clearance, licensing negotiations, and assessing blocking IP in target validation stage gates.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentClaim .

ind:competitiveLandscapeSummary rdf:type rdf:Property ;
    rdfs:label 'Competitive Landscape Summary' ;
    rdfs:comment 'Summary of known competitive programs targeting this molecular target, including approved drugs, clinical-stage compounds, and disclosed research programs from competitor organizations. Business-confidential intelligence used for portfolio strategy.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryProgramCode rdf:type rdf:Property ;
    rdfs:label 'Discovery Program Code' ;
    rdfs:comment 'Internal program or project code under which this target is being investigated. Links the target to the broader drug discovery program for portfolio management, resource allocation, and P&L tracking.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseAssociation rdf:type rdf:Property ;
    rdfs:label 'Disease Association' ;
    rdfs:comment 'Specific disease or condition(s) associated with this molecular target, as supported by published literature or internal research data. May reference ICD-10/ICD-11 disease codes or MeSH disease terms.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:druggabilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Druggability Assessment' ;
    rdfs:comment 'Scientific assessment of the target\'s amenability to small molecule or biologic modulation based on structural, biochemical, and computational analyses. Key input to portfolio prioritization and NCE/NBE strategy decisions.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ensemblGeneCode rdf:type rdf:Property ;
    rdfs:label 'Ensembl Gene Code' ;
    rdfs:comment 'Ensembl stable gene identifier (e.g., ENSG00000146648) for the gene encoding the molecular target. Used for genomic cross-referencing, variant analysis, and bioinformatics pipelines.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expressionTissue rdf:type rdf:Property ;
    rdfs:label 'Expression Tissue' ;
    rdfs:comment 'Primary tissue(s) or cell type(s) where this molecular target is expressed at therapeutically relevant levels, as determined by transcriptomic or proteomic profiling (e.g., liver, lung epithelium, T-cells). Informs tissue selectivity and delivery strategy.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstDisclosedDate rdf:type rdf:Property ;
    rdfs:label 'First Disclosed Date' ;
    rdfs:comment 'Date on which this molecular target was first formally disclosed or documented in the internal ELN or target identification database. Establishes the scientific priority date for IP purposes.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geneName rdf:type rdf:Property ;
    rdfs:label 'Gene Name' ;
    rdfs:comment 'Official HGNC (HUGO Gene Nomenclature Committee) approved gene symbol encoding the molecular target (e.g., EGFR, TP53, BRCA1). Standard identifier used in regulatory submissions and scientific publications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneticAssociationScore rdf:type rdf:Property ;
    rdfs:label 'Genetic Association Score' ;
    rdfs:comment 'Quantitative score (0.0000–1.0000) representing the strength of genetic evidence linking this target to the associated disease, derived from GWAS, Mendelian randomization, or Open Targets Platform data. Higher scores indicate stronger genetic validation.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indicationCode rdf:type rdf:Property ;
    rdfs:label 'Indication Code' ;
    rdfs:comment 'ICD-11 (International Classification of Diseases, 11th Revision) code for the primary indication associated with this target. Enables standardized cross-referencing with regulatory submissions and clinical trial registries.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moaType rdf:type rdf:Property ;
    rdfs:label 'Moa Type' ;
    rdfs:comment 'Categorical classification of the pharmacological mechanism of action for compounds acting on this target. Used to group targets by intervention strategy in SAR analysis and portfolio reporting. [ENUM-REF-CANDIDATE: agonist|antagonist|inhibitor|activator|allosteric_modulator|degrader|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noveltyStatus rdf:type rdf:Property ;
    rdfs:label 'Novelty Status' ;
    rdfs:comment 'Classification of the target\'s novelty relative to the competitive landscape. Novel targets represent first-in-class opportunities; established targets have existing approved drugs; repurposed targets are being explored in new indications.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organism rdf:type rdf:Property ;
    rdfs:label 'Organism' ;
    rdfs:comment 'Biological organism in which the molecular target is expressed and studied. Typically Homo sapiens for human targets, but may include model organisms used in preclinical validation studies.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentLandscapeSummary rdf:type rdf:Property ;
    rdfs:label 'Patent Landscape Summary' ;
    rdfs:comment 'High-level summary of the patent landscape around this molecular target, including freedom-to-operate (FTO) considerations and known composition-of-matter or method-of-use patents. Supports IP strategy decisions.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathwayName rdf:type rdf:Property ;
    rdfs:label 'Pathway Name' ;
    rdfs:comment 'Name of the primary biological signaling or metabolic pathway in which this target participates (e.g., PI3K/AKT/mTOR, RAS/MAPK, JAK/STAT). Supports pathway-based target clustering and polypharmacology analysis.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdbCode rdf:type rdf:Property ;
    rdfs:label 'Pdb Code' ;
    rdfs:comment 'RCSB Protein Data Bank accession code for the primary 3D structure of this molecular target. Used by computational chemistry and structure-based drug design (SBDD) teams for molecular docking and virtual screening.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prioritizationTier rdf:type rdf:Property ;
    rdfs:label 'Prioritization Tier' ;
    rdfs:comment 'Portfolio prioritization tier assigned to this target by the Target Selection Committee, reflecting strategic importance, scientific confidence, and commercial potential. Tier 1 targets receive maximum resource allocation.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proteinStructureAvailable rdf:type rdf:Property ;
    rdfs:label 'Protein Structure Available' ;
    rdfs:comment 'Indicates whether a resolved 3D protein structure (X-ray crystallography, cryo-EM, or NMR) is available for this target in the Protein Data Bank (PDB) or internal structural biology repository. Directly impacts structure-based drug design (SBDD) feasibility.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyConcernDescription rdf:type rdf:Property ;
    rdfs:label 'Safety Concern Description' ;
    rdfs:comment 'Narrative description of identified safety liabilities associated with modulation of this target (e.g., hERG channel activity, hepatotoxicity risk, immunosuppression). Populated only when safety_concern_flag is True.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyConcernFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Concern Flag' ;
    rdfs:comment 'Indicates whether known safety liabilities or toxicological concerns have been identified for this target based on literature, genetic association studies, or internal preclinical data. Triggers mandatory safety review before progression.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Internally assigned alphanumeric business identifier for the molecular target, used as the externally-known unique code across systems (ELN, LIMS, CTMS). Distinct from the surrogate PK and from external database accession numbers.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEngagementAssay rdf:type rdf:Property ;
    rdfs:label 'Target Engagement Assay' ;
    rdfs:comment 'Name or identifier of the primary biochemical or biophysical assay used to measure compound engagement with this target (e.g., HTRF binding assay, SPR, ITC, NanoBRET). Registered in LIMS (LabWare/SampleManager) and ELN.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOwner rdf:type rdf:Property ;
    rdfs:label 'Target Owner' ;
    rdfs:comment 'Name or employee identifier of the principal scientist or research team lead responsible for this molecular target within the discovery organization. Accountable for target validation decisions and data quality.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Biological molecule type of the target (e.g., protein, enzyme, receptor, ion channel, nucleic acid). Determines the modality of drug intervention and screening assay design. [ENUM-REF-CANDIDATE: protein|enzyme|receptor|ion_channel|nucleic_acid|lipid|carbohydrate|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniprotAccession rdf:type rdf:Property ;
    rdfs:label 'Uniprot Accession' ;
    rdfs:comment 'Universal Protein Resource (UniProt) accession number uniquely identifying the protein target in the global UniProtKB database. Enables cross-referencing with external biological databases and regulatory submissions.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Validation Completion Date' ;
    rdfs:comment 'Date on which target validation studies were completed and the target was formally declared validated (in vitro or in vivo). Marks the transition from target identification to hit-to-lead progression stage.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarStudyId rdf:type rdf:Property ;
    rdfs:label 'Sar Study Id' ;
    rdfs:comment 'Unique system-generated identifier for the SAR study record. Primary key for this entity.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bestCompoundId rdf:type rdf:Property ;
    rdfs:label 'Best Compound Id' ;
    rdfs:comment 'Reference to the single best-performing compound identified from this SAR study, based on the combination of potency, selectivity, and ADME profile. Candidate for progression to the next discovery stage.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:primarySarEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sar Employee Id' ;
    rdfs:comment 'Reference to the principal medicinal chemist or scientist responsible for designing and executing this SAR study. Used for accountability, expertise tracking, and publication attribution.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sarDirectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sar Director Employee Id' ;
    rdfs:comment 'Reference to the study director responsible for the overall scientific and regulatory conduct of the SAR study. Required for GLP-compliant studies per 21 CFR Part 58.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:admeImpactSummary rdf:type rdf:Property ;
    rdfs:label 'Adme Impact Summary' ;
    rdfs:comment 'Narrative summary of how structural modifications in this SAR study impacted ADME properties including metabolic stability, permeability, solubility, plasma protein binding, and CYP inhibition. Sourced from LIMS and ELN data.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analogsSynthesizedCount rdf:type rdf:Property ;
    rdfs:label 'Analogs Synthesized Count' ;
    rdfs:comment 'Total count of chemical analogs synthesized and tested within this SAR study. Key productivity metric for medicinal chemistry resource planning and portfolio reporting.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Numeric score (0–100) reflecting the completeness and reliability of the experimental data captured in this SAR study, based on assay reproducibility, data completeness, and ELN audit trail integrity. Used for data governance and AI/ML model training quality gates.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyStructuralFeatures rdf:type rdf:Property ;
    rdfs:label 'Key Structural Features' ;
    rdfs:comment 'Free-text or structured description of the key chemical structural features (pharmacophores, functional groups, scaffolds, substituents) analyzed in this SAR study to drive potency, selectivity, or ADME properties.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metabolicStabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Metabolic Stability Flag' ;
    rdfs:comment 'Indicates whether the lead compounds in this SAR study met the predefined metabolic stability criteria (e.g., microsomal half-life threshold). True = criteria met; False = criteria not met.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nceNbeType rdf:type rdf:Property ;
    rdfs:label 'Nce Nbe Type' ;
    rdfs:comment 'Classification of the compound series as a New Chemical Entity (NCE, small molecule) or New Biological Entity (NBE, biologic/large molecule) or hybrid. Determines regulatory pathway and IP strategy.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentFilingFlag rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Flag' ;
    rdfs:comment 'Indicates whether a patent application has been initiated for compounds or methods arising from this SAR study. True = patent filing in progress or completed; False = no patent action taken.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permeabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Permeability Flag' ;
    rdfs:comment 'Indicates whether the lead compounds demonstrated acceptable membrane permeability (e.g., Caco-2 or PAMPA assay thresholds). True = acceptable permeability achieved; False = not achieved.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:potencyMetricType rdf:type rdf:Property ;
    rdfs:label 'Potency Metric Type' ;
    rdfs:comment 'Type of biochemical potency measurement used to characterize compound activity in this SAR study (e.g., IC50 for inhibitory concentration, Ki for inhibition constant, EC50 for effective concentration).' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potencyRangeMaxNm rdf:type rdf:Property ;
    rdfs:label 'Potency Range Max Nm' ;
    rdfs:comment 'Highest (least potent) IC50 or Ki value observed across all analogs in this SAR study, expressed in nanomolar (nM). Together with the minimum, defines the potency range of the series.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potencyRangeMinNm rdf:type rdf:Property ;
    rdfs:label 'Potency Range Min Nm' ;
    rdfs:comment 'Lowest (most potent) IC50 or Ki value observed across all analogs in this SAR study, expressed in nanomolar (nM). Represents the best-in-series potency achieved.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressionDecision rdf:type rdf:Property ;
    rdfs:label 'Progression Decision' ;
    rdfs:comment 'Outcome decision made at the conclusion of the SAR study regarding whether the lead series should progress to the next stage of drug discovery (e.g., lead optimization, candidate selection) or be deprioritized.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarHypothesis rdf:type rdf:Property ;
    rdfs:label 'Sar Hypothesis' ;
    rdfs:comment 'Scientific hypothesis describing the proposed relationship between structural features of the compound series and the observed or expected biological activity. Captured from the ELN study plan.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectivityFindings rdf:type rdf:Property ;
    rdfs:label 'Selectivity Findings' ;
    rdfs:comment 'Summary of selectivity data for the lead compounds against off-target proteins or related family members. Describes selectivity ratios, panel screening results, and any observed off-target liabilities.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'Descriptive title of the SAR study, typically including the lead series name and therapeutic target (e.g., \'Series-7 EGFR Kinase Inhibitor Optimization\'). Used for display and search in ELN and project management tools.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyReportReference rdf:type rdf:Property ;
    rdfs:label 'Study Report Reference' ;
    rdfs:comment 'Document identifier or Veeva Vault reference for the formal SAR study report summarizing findings, conclusions, and progression recommendations. Provides traceability to the official scientific record.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningResultId rdf:type rdf:Property ;
    rdfs:label 'Screening Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual screening result record in the HTS or dose-response assay campaign. Primary key for the screening_result data product in the discovery domain.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryScreeningCompoundId rdf:type rdf:Property ;
    rdfs:label 'Primary Screening Compound Id' ;
    rdfs:comment 'Reference to the compound (NCE or NBE) that was screened in this assay run. Links to the compound master record in the compound library.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:compoundConcentrationUm rdf:type rdf:Property ;
    rdfs:label 'Compound Concentration Um' ;
    rdfs:comment 'Concentration of the compound tested in the assay well, expressed in micromolar (µM). Critical for dose-response curve fitting and potency determination.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:curveFitRSquared rdf:type rdf:Property ;
    rdfs:label 'Curve Fit R Squared' ;
    rdfs:comment 'Coefficient of determination (R²) from the dose-response curve fitting model. Values close to 1.0 indicate a high-quality fit. Used as a data quality gate for potency value acceptance.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ec50Nm rdf:type rdf:Property ;
    rdfs:label 'Ec50 Nm' ;
    rdfs:comment 'Half-maximal effective concentration (EC50) derived from dose-response curve fitting, expressed in nanomolar (nM). Key potency metric for agonist/activator compounds.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elnNotebookRef rdf:type rdf:Property ;
    rdfs:label 'Eln Notebook Ref' ;
    rdfs:comment 'Reference identifier linking this screening result to the corresponding experiment entry in the Electronic Lab Notebook (ELN) system (IDBS E-WorkBook or Dotmatics). Provides traceability to the original experimental record.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hillSlope rdf:type rdf:Property ;
    rdfs:label 'Hill Slope' ;
    rdfs:comment 'Hill slope (cooperativity coefficient) from the four-parameter logistic (4PL) dose-response curve fit. Values near 1 indicate simple binding; values significantly different from 1 may indicate cooperativity, aggregation, or assay artifacts.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ic50Nm rdf:type rdf:Property ;
    rdfs:label 'Ic50 Nm' ;
    rdfs:comment 'Half-maximal inhibitory concentration (IC50) derived from dose-response curve fitting, expressed in nanomolar (nM). Key potency metric for inhibitory compounds in SAR analysis and hit-to-lead progression.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Identifier of the laboratory instrument (e.g., plate reader, liquid handler, mass spectrometer) used to generate the raw signal. Supports instrument qualification tracking and systematic error investigation per GLP.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHitToLeadEligible rdf:type rdf:Property ;
    rdfs:label 'Is Hit To Lead Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this compound result meets the predefined criteria for progression into the hit-to-lead (H2L) phase, based on potency, selectivity, and data quality thresholds.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kiNm rdf:type rdf:Property ;
    rdfs:label 'Ki Nm' ;
    rdfs:comment 'Inhibition constant (Ki) representing the binding affinity of the compound to the target, expressed in nanomolar (nM). Derived from competitive binding or enzyme kinetics assays. Used in mechanistic SAR studies.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsResultRef rdf:type rdf:Property ;
    rdfs:label 'Lims Result Ref' ;
    rdfs:comment 'Reference identifier from the Laboratory Information Management System (LIMS) for this screening result record. Enables bidirectional traceability between the lakehouse silver layer and the operational LIMS source system.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxResponsePercent rdf:type rdf:Property ;
    rdfs:label 'Max Response Percent' ;
    rdfs:comment 'Maximum observed response (top asymptote) from the dose-response curve, expressed as a percentage of control. Indicates the efficacy ceiling of the compound at the target.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minResponsePercent rdf:type rdf:Property ;
    rdfs:label 'Min Response Percent' ;
    rdfs:comment 'Minimum observed response (bottom asymptote) from the dose-response curve, expressed as a percentage of control. Used to assess baseline signal and curve quality.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panAssayInterferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Pan Assay Interference Flag' ;
    rdfs:comment 'Boolean flag indicating whether the compound has been identified as a Pan-Assay Interference Compound (PAINS) — a compound that produces artifactual activity signals across multiple assays due to non-specific mechanisms. PAINS compounds are deprioritized in hit-to-lead.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:percentActivation rdf:type rdf:Property ;
    rdfs:label 'Percent Activation' ;
    rdfs:comment 'Calculated percentage activation of the target relative to controls. Primary activity metric for agonist/activator HTS campaigns. Null for inhibition assays.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentInhibition rdf:type rdf:Property ;
    rdfs:label 'Percent Inhibition' ;
    rdfs:comment 'Calculated percentage inhibition of the target activity relative to positive and negative controls on the same plate. Primary activity metric for inhibitory HTS campaigns. Null for activation assays.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plateBarcode rdf:type rdf:Property ;
    rdfs:label 'Plate Barcode' ;
    rdfs:comment 'Unique barcode identifier of the physical assay plate on which the compound was tested. Used for traceability back to the physical plate in the LIMS and for QC investigations.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plateColumn rdf:type rdf:Property ;
    rdfs:label 'Plate Column' ;
    rdfs:comment 'Numeric column designation (1–24) of the well on the assay plate. Used for spatial analysis of plate effects and systematic error detection.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plateRow rdf:type rdf:Property ;
    rdfs:label 'Plate Row' ;
    rdfs:comment 'Row designation (A–P) of the well on the assay plate. Used for spatial analysis of plate effects and edge-effect QC.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityFlagReason rdf:type rdf:Property ;
    rdfs:label 'Quality Flag Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why a data quality flag was applied (e.g., \'edge well effect\', \'reagent lot failure\', \'instrument malfunction\', \'outlier replicate\'). Required when data_quality_flag is \'flagged\' or \'rejected\'.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawSignalValue rdf:type rdf:Property ;
    rdfs:label 'Raw Signal Value' ;
    rdfs:comment 'Unprocessed instrument signal reading from the assay detector (e.g., fluorescence units, luminescence counts, absorbance). Preserved as the primary measurement for audit and reanalysis.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentLotNumber rdf:type rdf:Property ;
    rdfs:label 'Reagent Lot Number' ;
    rdfs:comment 'Lot identifier of the key assay reagent (e.g., enzyme, antibody, cell line passage) used in this assay run. Enables reagent lot correlation analysis for systematic variability investigation.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicateNumber rdf:type rdf:Property ;
    rdfs:label 'Replicate Number' ;
    rdfs:comment 'Sequential replicate index for this compound-assay combination within the same run (e.g., 1, 2, 3). Enables statistical aggregation across replicates and assessment of intra-assay variability.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultClassification rdf:type rdf:Property ;
    rdfs:label 'Result Classification' ;
    rdfs:comment 'Scientific classification of the screening result based on activity thresholds and confirmatory data. Drives hit-to-lead progression decisions. [ENUM-REF-CANDIDATE: active|inactive|inconclusive|toxic|hit|confirmed_hit|false_positive|pan_assay_interference — promote to reference product]' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'Calendar date on which the assay run was executed. Used for temporal trending, reagent lot correlation, and GLP audit trail compliance.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'Precise date and time when the assay instrument reading was captured. Supports intra-day sequencing, instrument log correlation, and 21 CFR Part 11 electronic record compliance.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:selectivityScore rdf:type rdf:Property ;
    rdfs:label 'Selectivity Score' ;
    rdfs:comment 'Quantitative selectivity score measuring the compound\'s specificity for the primary target versus off-target activities in a selectivity panel. Higher scores indicate greater selectivity. Used in SAR-driven lead optimization.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellPosition rdf:type rdf:Property ;
    rdfs:label 'Well Position' ;
    rdfs:comment 'Alphanumeric well position on the assay plate (e.g., A01, H12, P24) indicating the exact location of the compound in the plate layout. Standard SBS/ANSI plate format.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValidationStudyId rdf:type rdf:Property ;
    rdfs:label 'Target Validation Study Id' ;
    rdfs:comment 'Unique surrogate identifier for the target validation study record in the discovery domain. Primary key for this entity.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Target Employee Id' ;
    rdfs:comment 'Reference to the principal scientist responsible for conducting and interpreting the target validation study. Links to the HR/personnel master data.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetStudyDirectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Target Study Director Employee Id' ;
    rdfs:comment 'Reference to the GLP Study Director accountable for the overall scientific conduct and regulatory compliance of the study, as required under 21 CFR Part 58.33.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:therapeuticAreaId rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Id' ;
    rdfs:comment 'Reference to the therapeutic area master record under which this target validation study is funded and governed, enabling portfolio-level investment tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TherapeuticArea .

ind:biomarkerHypothesis rdf:type rdf:Property ;
    rdfs:label 'Biomarker Hypothesis' ;
    rdfs:comment 'Proposed patient selection or pharmacodynamic biomarker hypothesis arising from the validation study, informing future clinical trial design and companion diagnostic strategy.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseArea rdf:type rdf:Property ;
    rdfs:label 'Disease Area' ;
    rdfs:comment 'Primary therapeutic area or disease indication for which the target is being validated (e.g., oncology, immunology, rare disease, neurology). Aligns with the company\'s therapeutic area taxonomy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseLinkageEvidence rdf:type rdf:Property ;
    rdfs:label 'Disease Linkage Evidence' ;
    rdfs:comment 'Summary of the genetic, epidemiological, or clinical evidence linking the target to the disease (e.g., GWAS associations, somatic mutation frequency, patient cohort data, biomarker correlations).' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointResultUnit rdf:type rdf:Property ;
    rdfs:label 'Endpoint Result Unit' ;
    rdfs:comment 'Unit of measure for the primary endpoint result value (e.g., %, nM, fold-change, mm³). Ensures dimensional correctness for cross-study comparisons.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointResultValue rdf:type rdf:Property ;
    rdfs:label 'Endpoint Result Value' ;
    rdfs:comment 'Quantitative result value for the primary study endpoint (e.g., 85.3 for 85.3% knockdown efficiency). Paired with endpoint_result_unit for dimensional context.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goNoGoDecision rdf:type rdf:Property ;
    rdfs:label 'Go No Go Decision' ;
    rdfs:comment 'Portfolio governance decision on whether to proceed with further investment in this target based on the validation study outcome. Drives hit-to-lead progression.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelSystemName rdf:type rdf:Property ;
    rdfs:label 'Model System Name' ;
    rdfs:comment 'Specific name or designation of the biological model system used (e.g., HeLa, MCF-7, C57BL/6 mouse, HCT116 xenograft). Provides experimental reproducibility context.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelSystemType rdf:type rdf:Property ;
    rdfs:label 'Model System Type' ;
    rdfs:comment 'Category of biological model system used in the validation study (e.g., cell line, animal model, patient-derived xenograft, organoid). Determines translational relevance of the findings.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Patent Relevance Flag' ;
    rdfs:comment 'Indicates whether the target validation findings have been flagged as potentially patentable or relevant to existing IP filings, triggering IP team review.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationReferences rdf:type rdf:Property ;
    rdfs:label 'Publication References' ;
    rdfs:comment 'Comma-separated list of PubMed IDs, DOIs, or internal report identifiers for published or internal literature supporting the target validation findings (e.g., PMID:12345678, DOI:10.1016/...).' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Study Completion Date' ;
    rdfs:comment 'The date on which all experimental work and data analysis for the target validation study were completed and the final study report was issued.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyOutcome rdf:type rdf:Property ;
    rdfs:label 'Study Outcome' ;
    rdfs:comment 'Overall scientific conclusion of the target validation study, indicating whether the target has been confirmed as suitable for drug intervention in the specified disease context.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'The date on which experimental work for the target validation study formally commenced, as recorded in the ELN.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationEvidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Validation Evidence Level' ;
    rdfs:comment 'Qualitative assessment of the strength of evidence supporting the target\'s role in disease, based on reproducibility, model translatability, and mechanistic clarity. Drives go/no-go investment decisions.' ;
    rdfs:domain ind:TargetValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'The identifier of the vendor bank account used for payment execution, referencing the SAP FI-AP bank details record. Sensitive financial data subject to PCI and SOX controls.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: AP transactions post to GL accounts (liability accounts, expense accounts). The existing gl_account_code is a STRING; adding general_ledger_id FK links AP to the GL account master record. This further' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'The SAP automatic payment program run identifier (F110 run ID) that generated the payment for this invoice. Enables batch payment reconciliation and audit trail for automated payment processing.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Reference to the originating purchase order against which this invoice was raised, enabling three-way match (PO, goods receipt, invoice) per SAP MM-FI integration.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:updatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Updated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: AP modification tracking for audit trail, SOX compliance, and payment controls. Enables validation that changes were made by authorized personnel, supports segregation of duties analysis, and provides' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:warehouseReceiptId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Receipt Id' ;
    rdfs:comment 'Foreign key linking to supply.warehouse_receipt. Business justification: Three-way match (PO/GR/Invoice) is mandatory in pharma procure-to-pay. AP invoices are verified against goods receipts for quantity/quality confirmation before payment approval. Regulatory and SOX con' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseReceipt .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The SAP FI clearing document number (AUGBL) that offsets the open payable item upon payment or credit memo application. Used for open item management and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The SAP FI company code (BUKRS) representing the legal entity within the pharmaceutical group that is the obligor for this payable. Supports intercompany reconciliation and legal entity P&L reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'The cash discount amount captured if payment is made within the discount period defined in the payment terms (e.g., 2% discount for payment within 10 days). Supports working capital optimization analytics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The last date by which payment must be made to qualify for the early payment discount defined in the payment terms. Used by treasury for dynamic discounting and supply chain finance decisions.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The accounting period (MONAT, 1–16 including special periods) within the fiscal year in which the invoice is posted in SAP FI, used for monthly close and accrual management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The SAP MM goods receipt document number (MBLNR) confirming receipt of goods or services against the purchase order. Required for three-way match (PO-GR-Invoice) in GMP-compliant pharmaceutical procurement.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total gross amount of the vendor invoice before deduction of discounts, withholding tax, or other adjustments, as stated on the invoice document. Represents the full obligation amount.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date printed on the vendor invoice document (BLDAT in SAP), representing the principal business event date for the payable obligation. Used for aging analysis and payment term calculation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the goods or services invoiced, as provided by the vendor or entered during invoice processing in SAP FI-AP. Supports spend categorization and audit review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The externally-assigned invoice number provided by the vendor on the invoice document. Used for three-way match and duplicate invoice detection in SAP FI-AP.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the vendor invoice by business nature. Milestone and royalty types are specific to pharmaceutical licensing and CRO/CMO contracts. [ENUM-REF-CANDIDATE: standard|credit_memo|debit_memo|milestone|royalty|advance|recurring — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this payable is an intercompany transaction between legal entities within the pharmaceutical group, requiring elimination in consolidated financial statements per IFRS 10.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRdCapitalized rdf:type rdf:Property ;
    rdfs:label 'Is Rd Capitalized' ;
    rdfs:comment 'Indicates whether the expenditure represented by this payable has been capitalized as an intangible asset under IAS 38 (development phase costs meeting capitalization criteria), as opposed to expensed immediately as R&D.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net amount payable to the vendor after deducting withholding tax and applicable discounts from the gross invoice amount. Represents the actual cash outflow obligation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'SAP payment block key (ZLSPR) indicating whether the invoice is blocked from automatic payment processing. Common values: R=Manual review required, B=Blocked by purchasing, A=Blocked for audit, V=Verified/released, blank=Not blocked.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'The SAP FI document number of the outgoing payment transaction that cleared this invoice (AUGBL). Populated upon payment execution; null for open/blocked invoices.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument used to settle the vendor invoice (e.g., ACH for domestic US transfers, SWIFT/wire for international payments, SEPA for EU transactions, check for legacy vendors).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the accounts payable record indicating whether the invoice obligation is open, partially settled, fully paid, blocked for payment, cancelled, or under dispute. [ENUM-REF-CANDIDATE: open|partially_paid|paid|blocked|cancelled|disputed — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The SAP payment terms key (ZTERM) defining the agreed payment schedule, discount conditions, and due date calculation rules (e.g., NT30 = Net 30 days, 2/10NT30 = 2% discount if paid within 10 days).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the invoice was posted to the SAP general ledger (BUDAT), determining the accounting period for financial reporting and period-end close.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'The internal SAP FI document number (BELNR) assigned upon posting of the vendor invoice in the general ledger. Serves as the primary system-of-record identifier within SAP.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The value-added tax (VAT) or sales tax amount included in the vendor invoice, as calculated by SAP FI tax determination. Used for tax reporting and input tax recovery.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Category' ;
    rdfs:comment 'Pharmaceutical industry classification of the vendor type. Enables spend analytics by vendor category (e.g., CRO spend for clinical operations, CMO/CDMO spend for outsourced manufacturing, licensor for royalty and milestone obligations). [ENUM-REF-CANDIDATE: CRO|CMO|CDMO|raw_material_supplier|licensor|service_provider|logistics|other — promote to reference product]' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax (WHT) deducted from the vendor payment, applicable to royalty payments, milestone payments to licensors, and cross-border service fees per local tax regulations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Id' ;
    rdfs:comment 'Foreign key linking to supply.delivery_order. Business justification: Commercial deliveries trigger AR creation and revenue recognition in pharma order-to-cash. Links physical delivery (proof of transfer of control) to financial receivable. Required for revenue recognit' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryOrder .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Reference to the originating customer invoice document that generated this receivable. Links to the billing document in SAP SD/FI.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:arStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Status' ;
    rdfs:comment 'Current lifecycle status of the receivable. \'open\' = outstanding balance; \'partially_cleared\' = partial payment received; \'cleared\' = fully paid or offset; \'disputed\' = customer dispute raised; \'written_off\' = bad debt write-off applied; \'in_dunning\' = active dunning process initiated. [ENUM-REF-CANDIDATE: open|partially_cleared|cleared|disputed|written_off|in_dunning — promote to reference product]' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'Date on which the customer invoice was issued (billing document date). Used as the principal business event date for revenue recognition under ASC 606 / IFRS 15. Corresponds to SAP BLDAT.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Amount' ;
    rdfs:comment 'Total chargeback deductions claimed by wholesalers or distributors against this invoice, representing the difference between the contract price and the wholesale acquisition cost (WAC). Critical for pharmaceutical gross-to-net revenue calculations.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date on which this AR item was fully cleared (settled) in SAP FI-AR. Corresponds to SAP AUGDT. Null for open or partially cleared items. Used for DSO and cash flow reporting.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Business segment classification of the customer for this receivable. Supports P&L analysis by channel and revenue recognition reporting under ASC 606 / IFRS 15. [ENUM-REF-CANDIDATE: wholesaler|distributor|hospital_network|government_payer|retail_pharmacy|specialty_pharmacy — promote to reference product]' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days this AR item is past its due date as of the last refresh date. Calculated as (refresh_date - due_date) for open items. Used for aging bucket classification and credit risk assessment.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date on which the most recent dunning notice was issued to the customer for this overdue AR item. Corresponds to SAP MAHND. Used to track collections activity and avoid duplicate dunning.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning escalation level (0–4) assigned to this AR item by the SAP dunning program. Level 0 = no dunning; higher levels indicate increasing overdue severity. Drives collections escalation for wholesalers and distributors.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Foreign exchange rate applied at posting date to translate the document currency amount to local currency. Sourced from SAP exchange rate table (TCURR). Required for multi-currency pharmaceutical operations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Net invoice amount translated into the company code local currency (e.g., USD for US entity) using the SAP exchange rate at posting date. Required for consolidated P&L reporting and SOX compliance.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the company code local currency used for translation of the AR document amount (e.g., USD for US legal entity).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Remaining unpaid balance on this AR document at the time of last update. Equals gross_amount minus all clearing payments and credit memos applied. Used for aging reports and collections management.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Payment Receipt Date' ;
    rdfs:comment 'Date on which the incoming customer payment was received and applied against this AR document. Null if no payment has been received. Used for Days Sales Outstanding (DSO) calculation.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'Accounting period (01–12 for regular months, 13–16 for special closing periods) within the fiscal year in which this AR document was posted. Aligns with SAP FI period control.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productNdc rdf:type rdf:Property ;
    rdfs:label 'Product Ndc' ;
    rdfs:comment 'FDA-assigned National Drug Code (NDC) for the pharmaceutical product billed on this invoice. Uniquely identifies the drug product, labeler, and package configuration. Required for government payer reporting and Medicaid rebate calculations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Contractual rebate amount accrued or applied against this AR document for government payers (Medicaid, Medicare) or commercial payer contracts. Part of gross-to-net revenue deductions under ASC 606.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'Date on which revenue was or is scheduled to be recognized in the income statement per ASC 606 / IFRS 15 performance obligation criteria. May differ from billing date for deferred or accrued revenue entries.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionType rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Type' ;
    rdfs:comment 'Classification of the revenue treatment for this AR record under ASC 606 / IFRS 15: \'recognized\' = revenue fully recognized at point of sale; \'deferred\' = revenue deferred pending performance obligation fulfillment; \'accrued\' = period-end accrual entry; \'reversed\' = accrual reversal.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTerritory rdf:type rdf:Property ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Geographic or organizational sales territory associated with this receivable. Used for P&L reporting by geography and market access analysis. Sourced from SAP SD sales area configuration.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Reference to the General Ledger (GL) account to which this budget line is posted, enabling financial reporting and variance analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Reference to the profit center associated with this budget, enabling P&L planning by therapeutic area, brand, or geography.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual expenditure posted against this budget line item to date, sourced from SAP FI actuals. Used to compute budget variance (planned minus actual) for management reporting and SOX compliance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level functional category of the budget line item within the pharmaceutical value chain. Enables cross-functional spend analysis and allocation reporting. [ENUM-REF-CANDIDATE: clinical_trials|manufacturing|commercial|medical_affairs|regulatory|rd_discovery|general_admin|supply_chain — promote to reference product]' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Human-readable descriptive name for the budget plan (e.g., \'FY2025 Oncology R&D Operating Budget\', \'Phase III Clinical Trial Budget - Program X\'). Used in reporting and stakeholder communications.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the budget plan, used in financial reporting, approval workflows, and cross-system references. Follows the enterprise budget numbering convention (e.g., BUD-2025-ONCOL001).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle state of the budget record within the approval workflow. Transitions from draft through submission, review, and approval to locked (frozen for actuals comparison) or closed (period end). [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|locked|closed — promote to reference product]' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget by expenditure category: opex (operating expenditure), capex (capital expenditure), rd (research and development), headcount, contingency, or other. Drives P&L treatment and financial reporting. [ENUM-REF-CANDIDATE: opex|capex|rd|headcount|contingency|other — promote to reference product]' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationStage rdf:type rdf:Property ;
    rdfs:label 'Capitalization Stage' ;
    rdfs:comment 'Indicates the R&D stage for capitalization accounting purposes: research (expensed under IFRS IAS 38), development (potentially capitalizable once technical feasibility is established), or not_applicable. Drives correct accounting treatment for pharmaceutical R&D spend.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount encumbered by open purchase orders, contracts, or obligations not yet invoiced. Represents funds committed but not yet expensed. Supports available budget calculation (planned minus actual minus committed).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costElementCode rdf:type rdf:Property ;
    rdfs:label 'Cost Element Code' ;
    rdfs:comment 'SAP CO cost element code that categorizes the nature of the expenditure (e.g., personnel costs, material costs, external services, depreciation). Provides granular cost classification for management accounting and COGS analysis.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The last date of the period covered by this budget plan. For annual budgets, typically the last day of the fiscal year. Nullable for open-ended multi-year plans.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographyCode rdf:type rdf:Property ;
    rdfs:label 'Geography Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country or region code indicating the geographic scope of this budget (e.g., USA, GBR, DEU, JPN). Supports P&L planning by geography and market access financial analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCapitalized rdf:type rdf:Property ;
    rdfs:label 'Is Capitalized' ;
    rdfs:comment 'Indicates whether this budget line relates to R&D expenditure that is subject to capitalization under IFRS IAS 38 or US GAAP ASC 730 (True = capitalized; False = expensed). Critical for R&D capitalization accounting in pharmaceutical development programs.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or employee identifier of the business owner accountable for managing and reporting against this budget. Typically the cost center manager or program lead responsible for spend governance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'The total planned budget amount for this line item in the transaction currency. Represents the approved or forecasted spend for the associated cost center, GL account, and period. Core field for variance analysis against actuals.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Indicates the time horizon covered by this budget plan: annual (single fiscal year), multi_year (2–5 year strategic plan), quarterly (quarterly rolling forecast), or rolling_12m (12-month rolling forecast). Supports both short-term operational and long-term R&D investment planning.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The difference between planned amount and actual amount (planned minus actual) for this budget line. A positive value indicates underspend; negative indicates overspend. Stored as a pre-computed field from SAP CO variance reports to support management reporting without recalculation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'The budget variance expressed as a percentage of the planned amount ((planned minus actual) / planned × 100). Sourced from SAP CO variance reporting. Supports threshold-based exception reporting and management dashboards.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Indicates the iteration of the budget plan: original (initial approved plan), revised (formally amended plan), forecast (rolling in-year estimate), reforecast (mid-year replan), or final (year-end close). Supports variance analysis between versions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Reference to the specific manufacturing batch from which this COGS entry originates. Enables batch-level cost traceability and variance analysis per cGMP requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:cmoVendorId rdf:type rdf:Property ;
    rdfs:label 'Cmo Vendor Id' ;
    rdfs:comment 'Reference to the CMO or CDMO vendor record when cmo_indicator is true. Enables COGS analysis by external manufacturing partner and supports vendor performance and cost benchmarking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:costingRunId rdf:type rdf:Property ;
    rdfs:label 'Costing Run Id' ;
    rdfs:comment 'Identifier of the SAP CO-PC costing run that generated the standard cost estimate for this entry. Enables traceability of cost roll-up calculations and standard cost updates.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostingRun .

ind:goodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Id' ;
    rdfs:comment 'Foreign key linking to supply.goods_issue. Business justification: Goods issues trigger COGS recognition in pharmaceutical accounting. Direct link required for inventory valuation, P&L accuracy, and audit trail from physical movement to financial posting. Standard ER' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsIssue .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: COGS postings triggered by goods receipts need direct linkage for inventory valuation and perpetual inventory accounting. Critical for FIFO/weighted average cost calculation, period-end inventory valu' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:inventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: COGS recognition in pharma requires tracing to specific inventory lots for actual cost determination (FIFO/FEFO). Core inventory valuation and P&L process. New FK needed to link financial postings to ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Reference to the specific SKU (Stock Keeping Unit) representing the packaged, market-ready form of the drug product. Enables COGS granularity at the sellable unit level for gross margin and pricing analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'The actual cost incurred for the drug product batch or SKU as recorded in SAP CO-PC actual costing. Reflects real material consumption, labor hours, and overhead absorption during production.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligible' ;
    rdfs:comment 'Flag indicating whether this COGS entry is eligible for R&D capitalization under applicable accounting standards (e.g., IFRS IAS 38 development phase costs). Supports the finance domain\'s R&D capitalization tracking process.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmoIndicator rdf:type rdf:Property ;
    rdfs:label 'Cmo Indicator' ;
    rdfs:comment 'Flag indicating whether this COGS entry relates to drug product manufactured by a Contract Manufacturing Organization (CMO) or Contract Development and Manufacturing Organization (CDMO) rather than internal manufacturing. Supports make-vs-buy cost analysis.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costComponentType rdf:type rdf:Property ;
    rdfs:label 'Cost Component Type' ;
    rdfs:comment 'Classification of the cost component captured in this COGS entry. Enables granular COGS decomposition into material (API/excipients), labor, overhead absorption, depreciation, and royalty components for margin analysis. [ENUM-REF-CANDIDATE: material|labor|overhead|depreciation|royalty|contract_manufacturing|quality_control|packaging|other — promote to reference product]' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'The calculated cost per unit of drug product (standard or actual, per costing_type) derived from total cost divided by quantity produced. Used for pricing decisions, gross margin analysis, and transfer pricing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'The difference between actual cost and standard cost (actual minus standard) for this COGS entry. Positive variance indicates cost overrun; negative indicates favorable performance. Critical for manufacturing efficiency analysis and pricing decisions.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingType rdf:type rdf:Property ;
    rdfs:label 'Costing Type' ;
    rdfs:comment 'Classification of the costing methodology applied to this entry. Standard costing uses pre-set rates; actual costing uses real incurred costs. Determines how variances are calculated and reported.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of the COGS entry within the financial posting workflow. Controls whether the entry is included in period-close reporting and gross margin calculations.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'The cost attributable to direct and indirect labor (production operators, QC analysts, supervisors) involved in manufacturing the batch. Sourced from SAP CO-PC labor cost component and PP work center confirmations.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Market Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the market/geography for which this COGS entry is recorded. Enables COGS analysis by geography to support regional P&L reporting and transfer pricing compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCostAmount rdf:type rdf:Property ;
    rdfs:label 'Material Cost Amount' ;
    rdfs:comment 'The cost attributable to raw materials, active pharmaceutical ingredients (API), excipients, and packaging materials consumed in producing the batch. Sourced from SAP CO-PC material cost component.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadAbsorbedAmount rdf:type rdf:Property ;
    rdfs:label 'Overhead Absorbed Amount' ;
    rdfs:comment 'The manufacturing overhead costs (facility, utilities, equipment depreciation, indirect costs) absorbed into the product cost using overhead rates defined in SAP CO. Represents the overhead absorption component of COGS.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:comment 'The quantity of drug product units (tablets, vials, doses, kg) produced in the manufacturing batch to which this COGS entry relates. Used to calculate per-unit cost and yield-adjusted COGS.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'The unit of measure for the quantity produced field (e.g., EA for each, KG for kilograms, TAB for tablets, VIAL for vials). Aligns with SAP MM base unit of measure for the material. [ENUM-REF-CANDIDATE: EA|KG|L|MG|ML|TAB|VIAL|DOSE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Doc Number' ;
    rdfs:comment 'The SAP FI document number of the reversal posting if this COGS entry has been reversed. Populated only when entry_status is \'reversed\'. Supports audit trail and period-close reconciliation.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'The pre-determined standard cost for the drug product batch or SKU as calculated by the SAP CO-PC costing run. Represents the expected cost under normal operating conditions and is the baseline for variance analysis.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceCategory rdf:type rdf:Property ;
    rdfs:label 'Variance Category' ;
    rdfs:comment 'Classification of the primary driver of cost variance for this entry. Supports root cause analysis of COGS deviations: price variance (input cost changes), quantity variance (material usage), efficiency variance (labor/machine), mix variance (product mix), or volume variance (absorption).' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique surrogate identifier for each fixed asset record in the enterprise fixed asset register. Primary key for the fixed_asset data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Asset creation tracking for SOX controls, capitalization audit trail, and GMP equipment accountability. Enables validation that assets were capitalized by authorized finance personnel, supports asset ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation charged against the asset from the capitalization date to the current reporting period. Expressed as a negative value in SAP FI-AA. Used to calculate net book value and supports IAS 16 / ASC 360 balance sheet disclosures.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original historical cost of the fixed asset at the time of acquisition, including purchase price, import duties, installation costs, and directly attributable costs to bring the asset to its intended use. Expressed in the company code currency. Corresponds to SAP FI-AA \'Acquisition and Production Costs (APC)\'.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date on which the fixed asset was acquired or placed in service. Used as the start date for depreciation calculations and CAPEX reporting. Corresponds to the \'Asset Value Date\' in SAP FI-AA for the initial acquisition posting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'SAP FI-AA asset class code that categorizes the asset for depreciation, accounting, and reporting purposes (e.g., manufacturing equipment, laboratory instruments, IT infrastructure, leasehold improvements, vehicles, furniture). Drives default depreciation key and useful life.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassName rdf:type rdf:Property ;
    rdfs:label 'Asset Class Name' ;
    rdfs:comment 'Descriptive name of the SAP FI-AA asset class (e.g., \'Manufacturing Equipment\', \'Laboratory Instruments\', \'IT Infrastructure\', \'Leasehold Improvements\', \'Right-of-Use Assets\'). Supports reporting and analytics without requiring a join to a reference table.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Human-readable description of the fixed asset as recorded in the SAP FI-AA asset master (e.g., \'HPLC Analytical Instrument - QC Lab Building 4\', \'Bioreactor 2000L - API Manufacturing\'). Used for identification and reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique asset number assigned in SAP FI-AA (Asset Master record number). Used as the primary business identifier for the asset across finance, operations, and audit processes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset within the enterprise asset register. Drives inclusion in depreciation runs, CAPEX reporting, and balance sheet presentation. \'under_construction\' maps to Assets Under Construction (AuC) in SAP FI-AA.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubnumber rdf:type rdf:Property ;
    rdfs:label 'Asset Subnumber' ;
    rdfs:comment 'SAP FI-AA sub-number used to track components or additions to a main asset (e.g., a capital improvement to a piece of manufacturing equipment). Enables component-level tracking under a parent asset number.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical asset tag or barcode number affixed to the asset for inventory tracking and physical verification purposes. Used during annual physical asset counts and GMP equipment identification audits.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP FI business area code used to segment the asset for internal financial reporting by therapeutic area, product line, or business division (e.g., Oncology, Immunology, Rare Diseases, Consumer Health). Supports P&L reporting by therapeutic area.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexProjectNumber rdf:type rdf:Property ;
    rdfs:label 'Capex Project Number' ;
    rdfs:comment 'Capital expenditure (CAPEX) project or appropriation request number under which the asset was approved and funded. Links the asset to the approved capital budget and supports CAPEX tracking and variance reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date on which the asset was formally capitalized and transferred from Assets Under Construction (AuC) to a productive asset class in SAP FI-AA. Marks the start of the depreciation period. May differ from acquisition_date for self-constructed assets.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area Code' ;
    rdfs:comment 'SAP FI-AA depreciation area identifier that specifies the valuation basis for the asset (e.g., \'01\' for book depreciation per local GAAP, \'15\' for IFRS, \'20\' for tax depreciation, \'30\' for cost accounting). Supports parallel accounting under IAS 16 and US GAAP ASC 360.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'SAP FI-AA depreciation key that defines the depreciation method and calculation rules for the asset (e.g., LINR for straight-line, DGRV for declining balance, MANU for manual). Determines how periodic depreciation amounts are computed.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Insurance policy number under which the fixed asset is covered. Required for insurance valuation, claims processing, and risk management reporting. Particularly relevant for high-value manufacturing equipment and laboratory instruments.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuredValue rdf:type rdf:Property ;
    rdfs:label 'Insured Value' ;
    rdfs:comment 'Replacement or insured value of the fixed asset as declared to the insurer. May differ from net book value and is used for insurance premium calculation and claims settlement. Stored in SAP FI-AA insurance data fields.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGmpCritical rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Critical' ;
    rdfs:comment 'Indicates whether the asset is classified as GMP-critical equipment subject to qualification (IQ/OQ/PQ), periodic requalification, and regulatory inspection under 21 CFR Part 211, EU GMP, or PIC/S guidelines. True = GMP-critical; False = non-GMP.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRdEquipment rdf:type rdf:Property ;
    rdfs:label 'Is Rd Equipment' ;
    rdfs:comment 'Indicates whether the asset is classified as R&D equipment for the purpose of R&D capitalization analysis, tax credit eligibility, and ASC 730 / IAS 38 accounting treatment. True = R&D equipment; False = non-R&D.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPhysicalVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Verification Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or asset verification exercise confirming the asset\'s existence and location. Required for SOX compliance and GMP equipment audit readiness. Corresponds to SAP FI-AA \'Last Inventory Date\'.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Specific physical location code within the plant or facility where the asset is installed or stored (e.g., building, room, floor, warehouse location). Used for physical asset verification, GMP equipment mapping, and insurance purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer\'s model or part number for the fixed asset. Used for equipment qualification, spare parts identification, and procurement of replacement units in GMP-regulated manufacturing and laboratory environments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying amount of the fixed asset, calculated as acquisition cost less accumulated depreciation and any accumulated impairment losses. Represents the asset\'s value on the balance sheet as of the last depreciation posting period. Corresponds to SAP FI-AA \'Book Value\'.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'Remaining useful economic life of the asset in years as of the last review date. Calculated as useful_life_years minus elapsed depreciation periods. Used for impairment testing and residual value assessments under IAS 36 and ASC 360.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'Estimated amount the enterprise would currently obtain from disposal of the asset at the end of its useful life, after deducting estimated disposal costs. Used in the depreciable amount calculation. Corresponds to SAP FI-AA \'Scrap Value\'.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer\'s serial number of the fixed asset. Critical for GMP equipment qualification (IQ/OQ/PQ), maintenance tracking, warranty management, and regulatory inspection readiness. Stored in SAP FI-AA \'Serial Number\' field.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful economic life of the asset in years, as defined in the SAP FI-AA asset master. Used to calculate the annual depreciation charge under straight-line method. Must be reviewed periodically per IAS 16.51 and ASC 360-10-35-21.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'SAP ledger identifier distinguishing between parallel ledgers (e.g., \'0L\' for leading ledger, \'N1\' for IFRS non-leading ledger, \'U1\' for US GAAP ledger). Supports multi-GAAP reporting requirements across the pharmaceutical group.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Account group code that controls the number range and field selection for the GL account (e.g., \'OPEX\', \'CAPX\', \'COGS\', \'RDEX\'). Used to segment accounts by business function such as R&D expense, COGS, or capital expenditure in pharmaceutical reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetAccount rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account' ;
    rdfs:comment 'Indicates whether the GL account is a balance sheet account (True) or a profit and loss (P&L) income statement account (False). Balance sheet accounts carry forward balances; P&L accounts are reset at year-end. Critical for financial statement classification.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP business area code used for internal segment reporting across legal entities. Supports cross-company-code P&L and balance sheet reporting by business division (e.g., Pharmaceuticals, Consumer Health, Vaccines).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Identifier for the chart of accounts framework applied to this GL account (e.g., \'INT1\' for international, \'USGP\' for US GAAP). Supports multi-GAAP reporting across the pharmaceutical group.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'The GL account balance at the end of the fiscal period in transaction currency, calculated as opening balance plus debits minus credits (or vice versa depending on account type). Authoritative balance for trial balance, balance sheet, and income statement reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBalanceGc rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Gc' ;
    rdfs:comment 'The GL account closing balance translated into the group consolidation currency. Used for consolidated financial statements, group P&L reporting, and multi-entity consolidation eliminations.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBalanceLc rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Lc' ;
    rdfs:comment 'The GL account closing balance translated into the company code local currency. Used for statutory reporting and local GAAP compliance in each legal entity\'s jurisdiction.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Company Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the local (company code) currency in which balances are reported for statutory purposes. Distinct from transaction currency to support currency translation and consolidation eliminations.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Total credit postings to the GL account during the fiscal period in transaction currency. Sourced from aggregated journal entry postings in SAP FI. Used in trial balance and double-entry bookkeeping validation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'Total debit postings to the GL account during the fiscal period in transaction currency. Sourced from aggregated journal entry postings in SAP FI. Used in trial balance and double-entry bookkeeping validation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsItem rdf:type rdf:Property ;
    rdfs:label 'Fs Item' ;
    rdfs:comment 'Financial statement item code mapping the GL account to a specific line in the balance sheet or income statement (e.g., P&L by therapeutic area, balance sheet line). Supports multi-GAAP consolidation and statutory reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area code classifying the GL account balance by business function (e.g., \'MFGC\' for manufacturing/COGS, \'RDEX\' for R&D expense, \'SELL\' for selling expense, \'GADM\' for general and administrative). Supports cost-of-goods-sold (COGS) and P&L by function reporting. [ENUM-REF-CANDIDATE: MFGC|RDEX|SELL|GADM|CLIN|REGL|PROC — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapStandard rdf:type rdf:Property ;
    rdfs:label 'Gaap Standard' ;
    rdfs:comment 'The accounting standard under which this ledger balance is reported (US_GAAP, IFRS, LOCAL_GAAP, or IFRS_AND_US_GAAP for dual-reporting ledgers). Supports multi-GAAP reporting requirements for the pharmaceutical group\'s global legal entities.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountName rdf:type rdf:Property ;
    rdfs:label 'Gl Account Name' ;
    rdfs:comment 'Short descriptive name of the GL account as defined in the chart of accounts (e.g., \'Research and Development Expense\', \'API Inventory\', \'Accrued Clinical Trial Costs\'). Used in financial reports and trial balance outputs.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:comment 'The chart-of-accounts account number uniquely identifying the GL account within the company code. Used as the primary business identifier for account lookup, trial balance, and financial statement mapping.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the group (consolidation) currency used in consolidated financial statements (e.g., USD for a US-headquartered pharmaceutical group). Supports group-level P&L and balance sheet consolidation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this GL account balance contains intercompany transactions (True) that require elimination during group consolidation. Supports consolidation eliminations for the pharmaceutical group\'s multi-entity structure.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPostedDate rdf:type rdf:Property ;
    rdfs:label 'Last Posted Date' ;
    rdfs:comment 'The most recent date on which a journal entry posting was made to this GL account within the fiscal period. Used for account activity monitoring, dormant account identification, and period-end close validation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The GL account balance at the start of the fiscal period in transaction currency. Represents the carried-forward closing balance from the prior period. Used in trial balance preparation and period-end close processes.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodCloseStatus rdf:type rdf:Property ;
    rdfs:label 'Period Close Status' ;
    rdfs:comment 'Current status of the financial period close process for this GL account balance: open (period active), in_progress (close activities underway), closed (period-end close completed), or locked (period locked against further postings). Supports SOX-compliant financial close tracking.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlock rdf:type rdf:Property ;
    rdfs:label 'Posting Block' ;
    rdfs:comment 'Indicates whether postings to this GL account are currently blocked (True) at the company code level. A blocked account prevents new journal entries, used during period-end close or account restructuring.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rdCapitalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Rd Capitalization Flag' ;
    rdfs:comment 'Indicates whether the GL account balance is subject to R&D capitalization rules under IFRS IAS 38 (True) or expensed as incurred under US GAAP ASC 730 (False). Critical for pharmaceutical companies managing the boundary between R&D expense and intangible asset capitalization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconAccountType rdf:type rdf:Property ;
    rdfs:label 'Recon Account Type' ;
    rdfs:comment 'Indicates if this GL account is a reconciliation account and its type: D=Accounts Receivable (Customers), K=Accounts Payable (Vendors), A=Assets, or empty for non-reconciliation accounts. Reconciliation accounts aggregate subledger balances into the GL.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Segment identifier for IFRS 8 / ASC 280 segment reporting (e.g., \'Oncology\', \'Immunology\', \'Rare Disease\', \'Consumer Health\'). Enables disaggregated P&L and asset reporting by operating segment for external financial disclosures.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRelevant rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant' ;
    rdfs:comment 'Indicates whether this GL account is in scope for SOX Section 302/404 internal controls over financial reporting (ICFR). SOX-relevant accounts require documented controls, testing, and sign-off during the annual audit cycle.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'SAP tax code associated with the GL account for VAT/GST and withholding tax determination. Relevant for pharmaceutical entities operating across multiple tax jurisdictions. Supports indirect tax reporting and compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartner rdf:type rdf:Property ;
    rdfs:label 'Trading Partner' ;
    rdfs:comment 'Company code of the intercompany trading partner for balances involving intercompany transactions. Used to identify and eliminate intercompany balances during group consolidation. Populated only when intercompany_flag is True.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each intercompany transaction record within the pharmaceutical group\'s consolidated financial system.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:intercompanyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Agreement Id' ;
    rdfs:comment 'Reference to the master intercompany agreement or service level agreement that governs the terms, pricing, and conditions of this transaction between the two legal entities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyAgreement .

ind:originalTransactionIntercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Intercompany Transaction Id' ;
    rdfs:comment 'Reference to the original intercompany transaction that this record reverses or amends. Null for original transactions; populated only for reversal or adjustment entries.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:primaryIntercompanyLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Intercompany Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity within the pharmaceutical group that initiates and books the intercompany charge, sale, or loan as the originating party.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.shipment. Business justification: Cross-border shipments between affiliates create intercompany transactions for transfer pricing. Links physical movement to financial settlement, customs valuation, and withholding tax calculation. Re' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:stockTransferOrderId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Order Id' ;
    rdfs:comment 'Foreign key linking to supply.stock_transfer_order. Business justification: Intercompany stock transfers between legal entities generate IC transactions at transfer prices. Required for legal entity P&L, transfer pricing documentation, and tax compliance. Core pharma supply c' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockTransferOrder .

ind:transferPriceId rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Id' ;
    rdfs:comment 'Foreign key linking to finance.transfer_price. Business justification: Intercompany transactions for product transfers must reference the applicable transfer pricing record for tax compliance and audit. This is a core transfer pricing requirement. Cardinality: Many IC tr' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferPrice .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference to the originating source document number (e.g., SAP FI document number, invoice number, loan agreement reference, or intercompany billing document) that triggered this transaction.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationDate rdf:type rdf:Property ;
    rdfs:label 'Elimination Date' ;
    rdfs:comment 'The date on which the intercompany transaction was eliminated in the group consolidation process. Null if elimination has not yet occurred.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Indicates whether this intercompany transaction has been eliminated in the consolidated financial statements to avoid double-counting of intra-group revenues and expenses per IFRS 10.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The net transaction amount translated into the pharmaceutical group\'s reporting currency (e.g., USD) using the applicable exchange rate for consolidation and P&L reporting by therapeutic area.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanInterestRate rdf:type rdf:Property ;
    rdfs:label 'Loan Interest Rate' ;
    rdfs:comment 'Annual interest rate applicable to intercompany loan transactions, expressed as a decimal (e.g., 0.035000 = 3.5%). Must comply with arm\'s-length interest rate requirements under OECD BEPS guidelines.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The contractual due date by which the receiving entity must settle the intercompany payable. Used for cash flow forecasting and intercompany aging analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'SAP CO profit center associated with the intercompany transaction, enabling P&L reporting by brand, therapeutic area (e.g., oncology, immunology), or geography.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'SAP S/4HANA four-character company code identifying the receiving legal entity. Used for automated intercompany matching and elimination in the consolidation system.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'SAP S/4HANA four-character company code identifying the sending legal entity. Used for automated intercompany matching and elimination in the consolidation system.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tpDocumentationRef rdf:type rdf:Property ;
    rdfs:label 'Tp Documentation Ref' ;
    rdfs:comment 'Reference identifier for the transfer pricing documentation file (e.g., master file, local file, or country-by-country report) supporting the arm\'s-length nature of this transaction per OECD BEPS Action 13.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the intercompany transaction is denominated (e.g., USD, EUR, JPY). Drives foreign currency translation for consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known business reference number assigned to the intercompany transaction, used for cross-entity reconciliation and audit trail. Format: ICT-{YYYY}-{8-digit sequence}.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the intercompany transaction within the financial close and consolidation workflow. \'Eliminated\' indicates the transaction has been removed in consolidated reporting per IFRS 10.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriceBasis rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Basis' ;
    rdfs:comment 'The OECD-approved transfer pricing methodology used to determine the arm\'s-length price for this intercompany transaction. CUP=Comparable Uncontrolled Price, RPM=Resale Price Method, CPM=Cost Plus Method, TNMM=Transactional Net Margin Method, PSM=Profit Split Method. [ENUM-REF-CANDIDATE: CUP|CUT|RPM|CPM|TNMM|PSM|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'The withholding tax rate (as a decimal, e.g., 0.1500 = 15%) applicable to this intercompany transaction under the relevant bilateral tax treaty or domestic tax law.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryInternalResponsibleCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Internal Responsible Cost Center Id' ;
    rdfs:comment 'Reference to the cost center organizationally responsible for managing and monitoring this internal order. Corresponds to KOSTV in SAP AUFK. Used for P&L reporting by therapeutic area and organizational unit.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Reference to the SAP PS Work Breakdown Structure element linked to this internal order. Used when the internal order is subordinate to a larger capital or R&D project structure. Corresponds to PSPNR in SAP AUFK.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:actualFinishDate rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Date' ;
    rdfs:comment 'Actual date on which the internal order activity was completed (technically completed or closed). Used for variance analysis between planned and actual project duration and for R&D capitalization period determination.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetProfile rdf:type rdf:Property ;
    rdfs:label 'Budget Profile' ;
    rdfs:comment 'SAP CO budget profile code assigned to this internal order, defining the budgeting rules, availability control tolerance levels, and fiscal year distribution method. Corresponds to PROFL in SAP AUFK.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'Total open commitment value (purchase orders, contracts, and reservations) posted against this internal order but not yet invoiced. Represents future obligated spend. Sourced from SAP CO commitment management (COOI table). Critical for total exposure reporting.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP CO controlling area code that defines the organizational unit within which cost accounting is performed. Determines the currency and fiscal year variant applicable to this internal order. Corresponds to KOKRS in SAP AUFK.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether this internal order has been flagged for deletion in SAP CO. Deletion-flagged orders are excluded from active reporting but retained for audit trail purposes. Corresponds to LOEKZ in SAP AUFK.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant code defining the fiscal year and period structure applicable to this internal order (e.g., K4 for calendar year, V3 for April–March). Determines period-end processing and budget distribution. Corresponds to PERIV in SAP AUFK.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentMeasureType rdf:type rdf:Property ;
    rdfs:label 'Investment Measure Type' ;
    rdfs:comment 'Classifies the internal order as a capital expenditure (CAPEX), operating expense (OPEX), R&D expense (RD_EXPENSE), or capitalizable R&D (RD_CAPITAL) measure. Drives balance sheet vs. P&L treatment and supports CAPEX lifecycle governance and ROI analysis.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Date and time of the most recent modification to this internal order record in SAP CO. Corresponds to AEDAT and AEZET fields in SAP AUFK. Used for change tracking and SOX audit trail.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Extended narrative description of the internal order providing full business context, scope, and objectives. Supports R&D capitalization documentation and audit trail requirements under SOX and 21 CFR Part 11.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCategory rdf:type rdf:Property ;
    rdfs:label 'Order Category' ;
    rdfs:comment 'SAP internal order category code distinguishing overhead orders (01), investment orders (04), accrual orders (02), and statistical orders (10/20). Drives settlement and budget management behavior in SAP CO.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderName rdf:type rdf:Property ;
    rdfs:label 'Order Name' ;
    rdfs:comment 'Human-readable short description of the internal order, typically identifying the R&D program, clinical trial phase, capital project, or overhead activity being tracked. Corresponds to KTEXT in SAP AUFK.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'SAP-assigned alphanumeric identifier for the internal order, used as the externally-known business key across finance, R&D, and project management systems. Corresponds to the AUFNR field in SAP CO table AUFK.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current system status of the internal order in SAP CO. CRTD=Created, REL=Released (costs can be posted), TECO=Technically Completed (no further postings), CLSD=Closed (settled and locked), DLT=Deletion Flagged, LKD=Locked. Governs cost posting eligibility and settlement processing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'SAP order type code classifying the purpose of the internal order (e.g., R&D expense, capital expenditure, overhead, clinical trial cost collection, manufacturing overhead). Corresponds to AUART in SAP AUFK. [ENUM-REF-CANDIDATE: RD01|CAPEX|OVHD|CLIN|MFG|MKTG — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadKey rdf:type rdf:Property ;
    rdfs:label 'Overhead Key' ;
    rdfs:comment 'SAP CO overhead key assigned to this internal order, determining the overhead surcharge rates applied during overhead calculation (costing sheet). Used for allocating indirect manufacturing or R&D overhead costs to the order. Corresponds to ZUONR in SAP AUFK.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCostAmount rdf:type rdf:Property ;
    rdfs:label 'Plan Cost Amount' ;
    rdfs:comment 'Total planned cost amount for this internal order in the controlling area currency, as entered in SAP CO planning. Supports budget vs. plan vs. actual three-way variance analysis for R&D program financial governance.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFinishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Date' ;
    rdfs:comment 'Planned completion date for the activity or project represented by this internal order. Used for R&D program milestone tracking, CAPEX project scheduling, and budget period governance. Corresponds to PLSEZ in SAP AUFK.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programPhase rdf:type rdf:Property ;
    rdfs:label 'Program Phase' ;
    rdfs:comment 'Drug development lifecycle phase associated with this internal order. Drives R&D capitalization eligibility (costs may be capitalized from Phase 3 under IAS 38 criteria), ROI analysis, and budget governance. Aligns with ICH M4 eCTD structure.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the internal order was released in SAP CO (status changed to REL), enabling cost postings to begin. Marks the start of the active cost collection period. Corresponds to IDAT2 in SAP AUFK.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementReceiverType rdf:type rdf:Property ;
    rdfs:label 'Settlement Receiver Type' ;
    rdfs:comment 'Category of the primary settlement receiver for this internal order. CTR=Cost Center, AUC=Asset Under Construction, WBS=WBS Element, PSG=Profitability Segment, GL=G/L Account, ORD=Internal Order. Determines the accounting treatment of settled costs.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRuleType rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule Type' ;
    rdfs:comment 'Defines how costs accumulated on this internal order are settled to receivers (cost centers, G/L accounts, assets, WBS elements, profitability segments). FUL=Full settlement, PER=Periodic settlement, MAN=Manual settlement. Governs period-end cost allocation and R&D capitalization postings.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Statistical Order Flag' ;
    rdfs:comment 'Indicates whether this internal order is a statistical order (costs posted in parallel for reporting purposes only, without affecting the primary cost object). Statistical orders are used for management reporting overlays such as therapeutic area P&L without impacting actual cost flows.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor_invoice. Business justification: Journal entries for invoice accruals and postings need vendor invoice traceability for audit trail and invoice-to-GL reconciliation. Critical for pharmaceutical financial close processes, SOX complian' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorInvoice .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'Monetary amount of the journal entry translated into the corporate group reporting currency (typically USD or EUR) for consolidated P&L reporting by therapeutic area, brand, and geography.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'Monetary amount of the journal entry translated into the company code\'s local (functional) currency using the applicable exchange rate. Used for statutory financial reporting and local tax compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'Gross monetary amount of the journal entry in the original transaction currency. For debit entries this is positive; for credit entries this is negative (SAP sign convention). Core monetary fact for the posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'SAP assignment field (ZUONR) used for sorting and matching open items in accounts payable, accounts receivable, and bank reconciliation. Typically populated with invoice number, payment reference, or contract number for automated clearing.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'SAP indicator specifying whether the line item is a debit (S=Soll/Debit) or credit (H=Haben/Credit) posting. Fundamental double-entry bookkeeping attribute required for GL balance validation and trial balance generation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the original source document (invoice date, payment date, contract date) that triggered the journal entry. May differ from posting_date; used for aging analysis and vendor/customer terms calculation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'SAP GL account number to which the journal entry line is posted. Determines the financial statement line item (P&L or balance sheet). Supports COGS by product, R&D capitalization, and therapeutic area P&L analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text description at the journal entry header level explaining the business purpose of the posting (e.g., \'Q3 R&D accrual – Oncology Phase III\', \'API procurement – CMO settlement\'). Supports audit review and financial close documentation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Indicates whether this journal entry is itself a reversal of a prior posting (True) or an original entry (False). Used to filter reversals from net financial reporting and to identify accrual reversal patterns in period-end close.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line item number within the journal entry document (e.g., 001, 002). Uniquely identifies each debit/credit line within the document for reconciliation, audit, and subledger matching.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-text description at the individual line item level providing context for the specific debit or credit posting (e.g., \'API batch #XYZ123 – COGS\', \'Phase III trial accrual – CRO milestone\'). Supports granular audit review.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency. Used for statutory reporting in the country of the legal entity.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current workflow state of the journal entry in the general ledger lifecycle. \'posted\' = fully committed to GL; \'parked\' = saved but not posted; \'held\' = incomplete draft; \'reversed\' = offset entry created; \'cleared\' = matched against open items; \'blocked\' = pending approval.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number from the source document (e.g., vendor invoice number, purchase order number, contract reference, or regulatory submission reference). Enables cross-system reconciliation and audit traceability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Document number of the reversing journal entry if this posting has been reversed. Populated only for reversed entries; null otherwise. Supports audit trail completeness and period-end close validation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerType rdf:type rdf:Property ;
    rdfs:label 'Subledger Type' ;
    rdfs:comment 'Identifies the subledger from which the journal entry originates: AP (Accounts Payable), AR (Accounts Receivable), asset accounting, tax accounting, material ledger, or none (direct GL posting). Enables subledger-to-GL reconciliation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Base Amount' ;
    rdfs:comment 'The taxable base amount in local currency on which the tax is calculated. Required for indirect tax return preparation and multi-jurisdiction VAT/GST compliance reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction (country, state, county, city) applicable to the transaction for multi-jurisdiction indirect tax reporting. Required for US sales tax (Vertex/Avalara integration) and international VAT compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Return Period' ;
    rdfs:comment 'The reporting period (YYYY-MM) to which this tax posting belongs for indirect tax return filing purposes. May differ from the accounting fiscal period; used for VAT/GST return preparation across multiple tax jurisdictions.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatClassification rdf:type rdf:Property ;
    rdfs:label 'Vat Classification' ;
    rdfs:comment 'Classification of the tax posting type for indirect tax reporting: input VAT (recoverable on purchases), output VAT (collected on sales), deferred VAT (timing difference), exempt, zero-rated, or not applicable. Supports multi-jurisdiction VAT compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingTreatment rdf:type rdf:Property ;
    rdfs:label 'Accounting Treatment' ;
    rdfs:comment 'Accounting classification applied to this milestone payment per applicable accounting standards: rd_expense (expensed as R&D), capitalize (capitalized as intangible asset), cogs (recognized as cost of goods sold), deferred_revenue (deferred until performance obligation met), contingent_liability (disclosed as contingent liability until triggered).' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualAmount rdf:type rdf:Property ;
    rdfs:label 'Contractual Amount' ;
    rdfs:comment 'The gross payment amount as specified in the partnership or licensing agreement for this milestone, in the contract currency. This is the base obligation before any adjustments, withholding taxes, or FX conversion.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentStage rdf:type rdf:Property ;
    rdfs:label 'Development Stage' ;
    rdfs:comment 'Development stage of the associated drug program at the time the milestone is triggered (e.g., preclinical, Phase 1, Phase 2, Phase 3, NDA/BLA Filed). Used for R&D capitalization assessment and program tracking. [ENUM-REF-CANDIDATE: discovery|preclinical|phase_1|phase_2|phase_3|nda_bla_filed|approved|commercial — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Expected Trigger Date' ;
    rdfs:comment 'Projected date by which the triggering event is expected to occur, based on current program timelines. Used for contingent liability forecasting and cash flow planning.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Milestone payment amount converted to the company\'s functional currency (typically USD) using the applicable exchange rate at the time of recognition or payment. Used for consolidated financial reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the company\'s functional currency used in the functional_currency_amount field (e.g., USD).' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'Exchange rate applied to convert the contractual_amount from contract currency to functional currency at the time of recognition or payment. Sourced from SAP FI treasury rates.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isContingentLiability rdf:type rdf:Property ;
    rdfs:label 'Is Contingent Liability' ;
    rdfs:comment 'Indicates whether this milestone payment represents a contingent liability that must be disclosed in financial statements prior to the triggering event occurring. True if the payment obligation is contingent on a future uncertain event.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneNumber rdf:type rdf:Property ;
    rdfs:label 'Milestone Number' ;
    rdfs:comment 'Externally-known business identifier for this milestone payment, typically referenced in the partnership agreement schedule. Format: MS-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Actual net amount paid or received after deducting withholding taxes and any other contractual adjustments from the contractual_amount. Represents the cash flow impact.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDirection rdf:type rdf:Property ;
    rdfs:label 'Payment Direction' ;
    rdfs:comment 'Indicates whether this milestone payment is an obligation owed by the company to a counterparty (payable) or a receipt due from a counterparty (receivable). Critical for balance sheet classification and contingent liability disclosure.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEvent rdf:type rdf:Property ;
    rdfs:label 'Triggering Event' ;
    rdfs:comment 'Description of the specific contractual event that triggers this milestone payment (e.g., \'IND Filing Accepted by FDA\', \'Phase II Primary Endpoint Met\', \'NDA Approval Received\', \'First Commercial Sale in US\', \'Annual Net Sales Exceed $500M\').' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The accounting standard framework under which the R&D capitalization is recognized and reported. IAS 38 (IFRS) permits capitalization of development costs meeting specific criteria; ASC 730 (US GAAP) generally requires expensing except for certain software and acquired IPR&D.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accumulatedAmortization rdf:type rdf:Property ;
    rdfs:label 'Accumulated Amortization' ;
    rdfs:comment 'The total amortization charged against the capitalized R&D asset from the amortization start date to the current reporting period. Used to calculate the net book value of the intangible asset.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amortizationMethod rdf:type rdf:Property ;
    rdfs:label 'Amortization Method' ;
    rdfs:comment 'The accounting method applied to systematically allocate the capitalized R&D cost over the asset\'s useful life. Straight-line is most common for pharmaceutical intangibles; units-of-production may apply for royalty-bearing assets.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amortizationStartDate rdf:type rdf:Property ;
    rdfs:label 'Amortization Start Date' ;
    rdfs:comment 'The date on which systematic amortization of the capitalized R&D intangible asset commences, typically aligned with the date the asset is available for use (e.g., regulatory approval date or commercial launch date).' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualAmortizationAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Amortization Amount' ;
    rdfs:comment 'The annual amortization expense recognized in the income statement for this capitalized R&D asset, calculated based on the capitalized amount, useful life, and amortization method.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationNumber rdf:type rdf:Property ;
    rdfs:label 'Capitalization Number' ;
    rdfs:comment 'Externally-known business identifier for the capitalization record, used in SAP FI/CO asset accounting and financial reporting. Follows the format CAP-YYYY-NNNNNN.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationStatus rdf:type rdf:Property ;
    rdfs:label 'Capitalization Status' ;
    rdfs:comment 'Current lifecycle state of the R&D capitalization record. Tracks progression from initial recognition through active amortization, impairment, full amortization, or write-off. [ENUM-REF-CANDIDATE: draft|active|impaired|fully_amortized|written_off|under_review — promote to reference product]' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationType rdf:type rdf:Property ;
    rdfs:label 'Capitalization Type' ;
    rdfs:comment 'Classification of the nature of the capitalized R&D asset. Distinguishes between internally developed assets, acquired in-process R&D (IPR&D), licensed technology, milestone-triggered payments, and software development costs. [ENUM-REF-CANDIDATE: internal_development|acquired_iprd|licensed_technology|milestone_payment|software_development — promote to reference product]' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizedAmount rdf:type rdf:Property ;
    rdfs:label 'Capitalized Amount' ;
    rdfs:comment 'The gross monetary amount of R&D expenditure recognized as an intangible asset on the balance sheet at the point of initial capitalization, expressed in the reporting currency.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentPhase rdf:type rdf:Property ;
    rdfs:label 'Development Phase' ;
    rdfs:comment 'The clinical development phase of the drug program at the time of capitalization or as of the current reporting date. Used to assess technical feasibility criteria under IAS 38 and for R&D pipeline reporting. [ENUM-REF-CANDIDATE: preclinical|phase_i|phase_ii|phase_iii|nda_bla_filing|approved|post_approval — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Impairment Assessment Date' ;
    rdfs:comment 'The date on which the most recent formal impairment assessment was performed for this capitalized R&D asset, as required by IAS 36 or ASC 350 at each reporting period end.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impairmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator' ;
    rdfs:comment 'Flag indicating whether an impairment trigger event has been identified for this capitalized R&D asset (e.g., clinical trial failure, regulatory rejection, competitive obsolescence). Triggers a formal impairment assessment per IAS 36.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLossAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss Amount' ;
    rdfs:comment 'The monetary amount by which the carrying value of the capitalized R&D asset exceeds its recoverable amount, recognized as an impairment loss in the income statement. Null if no impairment has been recognized.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentReason rdf:type rdf:Property ;
    rdfs:label 'Impairment Reason' ;
    rdfs:comment 'Narrative description of the reason for impairment recognition, such as clinical trial failure, regulatory rejection (FDA Complete Response Letter, EMA refusal), patent invalidation, or market withdrawal.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Date' ;
    rdfs:comment 'The date on which the qualifying milestone trigger event occurred, establishing the point at which R&D expenditures meet the IAS 38 or ASC 730 criteria for capitalization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneTrigger rdf:type rdf:Property ;
    rdfs:label 'Milestone Trigger' ;
    rdfs:comment 'The specific regulatory or technical feasibility milestone that triggered the transition from expensed research costs to capitalized development costs (e.g., Phase III initiation, NDA filing, BLA submission, EMA MAA submission, IND clearance, proof-of-concept). [ENUM-REF-CANDIDATE: ind_clearance|phase_iii_initiation|nda_filing|bla_submission|maa_submission|proof_of_concept|regulatory_approval — promote to reference product]' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingEntityCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity Code' ;
    rdfs:comment 'Code identifying the legal entity or company code within the pharmaceutical group that owns and reports the capitalized R&D asset, supporting multi-entity consolidated financial reporting.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The financial reporting period end date (e.g., quarter-end or year-end) as of which this capitalization record\'s carrying value, amortization, and impairment status were last reviewed and confirmed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxControlReference rdf:type rdf:Property ;
    rdfs:label 'Sox Control Reference' ;
    rdfs:comment 'Reference to the SOX internal control identifier governing the R&D capitalization process, used for audit trail and financial reporting compliance documentation.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedCompoundId rdf:type rdf:Property ;
    rdfs:label 'Licensed Compound Id' ;
    rdfs:comment 'Reference to the specific compound, drug substance (DS), or active pharmaceutical ingredient (API) that is the subject of the royalty agreement. Links to the compound master record in the discovery domain for IP cost tracking of in-licensed compounds.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:licensorBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Licensor Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Licensor is a business_partner (bp_role=\'Licensor\'). Essential for royalty payment processing, withholding tax calculation, audit rights enforcement, and vendor master data integration. Role-prefixed ' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:agreementDescription rdf:type rdf:Property ;
    rdfs:label 'Agreement Description' ;
    rdfs:comment 'Free-text description of the royalty agreement summarizing the key commercial terms, licensed rights, and strategic context. Used for business user reference and reporting narratives. Not a substitute for the legal agreement document.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known, human-readable agreement reference number assigned at execution (e.g., RA-2024-00123). Used for cross-system reconciliation with SAP FI/CO contract management and legal document repositories. Maps to the BUSINESS_IDENTIFIER category for MASTER_AGREEMENT role.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the royalty agreement. Draft indicates the agreement is under negotiation; active indicates it is fully executed and binding; suspended indicates temporarily paused due to dispute or regulatory hold; terminated indicates early termination by either party; expired indicates the agreement reached its natural end date. Maps to LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the royalty agreement by direction and structure of the licensing relationship. In-license covers compounds or IP acquired from external parties; out-license covers IP granted to third parties; cross-license covers mutual IP sharing; sublicense covers rights granted by a licensee to a third party; co-development covers joint R&D arrangements with shared royalty obligations. Maps to CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyYears rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Years' ;
    rdfs:comment 'Maximum frequency (in years) at which the licensor may exercise audit rights under the agreement (e.g., once every 2 years). Null when audit_rights_flag is False. Used to schedule and track audit obligations.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether the licensor has the contractual right to audit the licensee\'s books and records to verify royalty calculations and net sales reporting. True if audit rights are granted; False otherwise. Relevant for SOX compliance and royalty audit defense.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRoyaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Base Royalty Rate Pct' ;
    rdfs:comment 'The primary or base royalty rate expressed as a percentage of net sales applicable to the first tier or flat rate structure. For tiered agreements, this represents the lowest tier rate. Stored with five decimal places to accommodate fractional rates common in pharmaceutical licensing (e.g., 3.50000%). Used as the default rate in accrual calculations.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the interpretation and enforcement of the royalty agreement (e.g., USA, GBR, DEU). Relevant for dispute resolution, tax treaty application, and withholding tax obligations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeName rdf:type rdf:Property ;
    rdfs:label 'Licensee Name' ;
    rdfs:comment 'Legal name of the entity receiving the license rights (licensee). For in-license agreements, this is typically the pharmaceutical company itself or a subsidiary. For out-license agreements, this is the external partner receiving rights.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAnnualRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Annual Royalty Amount' ;
    rdfs:comment 'Contractually guaranteed minimum royalty payment due to the licensor per calendar or contract year, regardless of actual net sales. If actual royalties calculated on net sales fall below this floor, the minimum amount is payable. Critical for accrual adequacy assessment and cash flow planning.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSalesDefinition rdf:type rdf:Property ;
    rdfs:label 'Net Sales Definition' ;
    rdfs:comment 'Contractual definition of net sales as the royalty base, specifying which deductions are permitted (e.g., trade discounts, chargebacks, returns, freight, taxes, gross-to-net adjustments). Critical for accurate royalty calculation and audit defense. Stored as free text capturing the contractual language or a standardized reference code.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDays rdf:type rdf:Property ;
    rdfs:label 'Payment Due Days' ;
    rdfs:comment 'Number of calendar days after the close of each reporting period within which the royalty payment must be remitted to the licensor (e.g., 45 days after quarter end). Used to calculate payment due dates for each accrual period and to assess timeliness of settlements.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Contractual frequency at which royalty payments must be remitted to the licensor. Drives the accrual period schedule and payment due date calculation in SAP FI accounts payable. Quarterly is the most common frequency in pharmaceutical licensing agreements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRateType rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Type' ;
    rdfs:comment 'Structure of the royalty rate calculation methodology. Flat applies a single fixed percentage to all net sales; tiered applies different rates to different net sales bands; stepped changes the rate at defined cumulative thresholds; running is a continuous percentage; milestone_based triggers payments upon achievement of defined development or commercial milestones.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'Source system contract or purchase order number from SAP S/4HANA FI/CO module that corresponds to this royalty agreement. Used for financial reconciliation, accounts payable matching, and audit trail between the data lakehouse and the ERP system of record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicenseRoyaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Sublicense Royalty Rate Pct' ;
    rdfs:comment 'Royalty rate percentage applicable to sublicense revenues received by the licensee, payable to the original licensor. Applicable only when sublicensing_rights_flag is True. May differ from the standard net sales royalty rate. Null when sublicensing is not permitted.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sublicensingRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Rights Flag' ;
    rdfs:comment 'Indicates whether the licensee has the contractual right to grant sublicenses to third parties under this agreement. True if sublicensing is permitted; False if rights are non-sublicensable. Impacts royalty flow-through obligations and sublicense revenue sharing calculations.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days of advance written notice required by either party to terminate the agreement for convenience or material breach. Used for contract lifecycle management and accrual wind-down planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic scope of the royalty agreement defining the countries or regions where the licensee has rights to commercialize the licensed compound. Expressed as ISO 3166-1 alpha-3 country codes (comma-separated for multi-country) or a named region (e.g., WORLDWIDE, EU, USA). Drives territory-specific royalty rate application and net sales calculation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier1ThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tier1 Threshold Amount' ;
    rdfs:comment 'Net sales threshold amount (in the agreement currency) at which the royalty rate transitions from the base rate to the tier 2 rate. For tiered agreements, net sales up to this amount are subject to base_royalty_rate_pct. Null for flat-rate agreements.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2RoyaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Tier2 Royalty Rate Pct' ;
    rdfs:comment 'Royalty rate percentage applicable to the second net sales tier for tiered or stepped royalty structures. Null for flat-rate agreements. Applied when cumulative or annual net sales exceed the tier 1 threshold defined in tier1_threshold_amount.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2ThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tier2 Threshold Amount' ;
    rdfs:comment 'Net sales threshold amount (in the agreement currency) at which the royalty rate transitions from tier 2 to tier 3 rate. Null if the agreement has only two tiers or is flat-rate. Supports up to three-tier royalty structures common in pharmaceutical licensing.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3RoyaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Tier3 Royalty Rate Pct' ;
    rdfs:comment 'Royalty rate percentage applicable to net sales exceeding the tier 2 threshold for three-tier royalty structures. Null for flat-rate or two-tier agreements. Typically the highest rate in escalating structures or lowest in de-escalating structures.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontLicenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Upfront License Fee Amount' ;
    rdfs:comment 'One-time non-refundable upfront payment made to the licensor upon execution of the agreement, separate from ongoing running royalties. Relevant for R&D capitalization assessment under FASB ASC 730 and IP cost tracking for in-licensed compounds.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRatePct rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate Pct' ;
    rdfs:comment 'Applicable withholding tax rate percentage on royalty payments as determined by the governing tax treaty between the licensor and licensee jurisdictions. Used for net payment calculation and tax reporting. Zero if no withholding tax applies under a treaty exemption.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxPostingId rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Id' ;
    rdfs:comment 'Unique surrogate identifier for each tax-related financial posting record in the SAP FI-TX module. Serves as the primary key for the tax_posting data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deductiblePct rdf:type rdf:Property ;
    rdfs:label 'Deductible Pct' ;
    rdfs:comment 'The percentage of input tax that is recoverable when a pharmaceutical entity makes both taxable and exempt supplies (partial exemption / pro-rata recovery). Calculated per the applicable tax authority\'s partial exemption method and applied to determine the recoverable portion of input VAT.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDeductible rdf:type rdf:Property ;
    rdfs:label 'Is Deductible' ;
    rdfs:comment 'Indicates whether the input tax amount on this posting is fully deductible (recoverable) from the tax authority. Non-deductible input tax arises on purchases used for exempt pharmaceutical activities (e.g., certain clinical trial services or exempt healthcare supplies). Drives VAT recovery calculations.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'The SAP plant code (WERKS) identifying the manufacturing or distribution facility associated with the taxable transaction. Relevant for excise tax, customs duty, and VAT on pharmaceutical manufacturing activities subject to cGMP and GDP regulations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingType rdf:type rdf:Property ;
    rdfs:label 'Posting Type' ;
    rdfs:comment 'Indicates whether the tax posting represents output tax (collected on pharmaceutical product sales), input tax (recoverable on purchases of raw materials, API, or services), withholding tax on royalties or intercompany payments, or deferred tax asset/liability per IFRS IAS 12.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAccount rdf:type rdf:Property ;
    rdfs:label 'Tax Account' ;
    rdfs:comment 'The SAP general ledger account number (HKONT) to which the tax amount is posted. Identifies the specific tax liability or tax receivable account in the chart of accounts, enabling tax account reconciliation and balance sheet reporting under IFRS IAS 12.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmountDocCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Amount Doc Currency' ;
    rdfs:comment 'The tax amount expressed in the original transaction document currency (FWSTE in SAP). Relevant for cross-border pharmaceutical transactions where the invoice currency differs from the company code local currency, supporting foreign currency tax reporting.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The applicable tax rate as a percentage (e.g., 20.0000 for 20% VAT) used to calculate the tax amount from the taxable base. Derived from the tax code configuration in SAP FI-TX and varies by jurisdiction, product classification, and applicable tax treaty.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'The tax registration number of the counterparty (vendor or customer) involved in the taxable transaction, such as a VAT registration number (EU), Employer Identification Number (US), or equivalent. Required for EC Sales List reporting, Intrastat, and cross-border VAT compliance in pharmaceutical distribution.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period' ;
    rdfs:comment 'The calendar year and month (YYYY-MM format) of the tax reporting period to which this posting belongs for indirect tax return purposes. May differ from the SAP fiscal period when the company uses a non-calendar fiscal year. Used for VAT return filing, Intrastat reporting, and withholding tax declarations.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnReference rdf:type rdf:Property ;
    rdfs:label 'Tax Return Reference' ;
    rdfs:comment 'The reference number of the periodic tax return (VAT return, sales tax return, or withholding tax declaration) to which this posting has been assigned. Enables reconciliation between individual tax postings and filed tax returns submitted to FDA-regulated markets, EU member states, HMRC, PMDA, or other tax authorities.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax category applicable to this posting. Distinguishes between Value Added Tax (VAT), sales tax, withholding tax on royalties or intercompany payments, deferred tax, customs duty on API imports, and excise tax on pharmaceutical products. [ENUM-REF-CANDIDATE: VAT|sales_tax|withholding_tax|deferred_tax|customs_duty|excise_tax — promote to reference product]' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTransferLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Transfer Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity that is the seller or supplier in the intercompany transaction (the entity transferring the product, API, or service).' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:priorVersionTransferPriceId rdf:type rdf:Property ;
    rdfs:label 'Prior Version Transfer Price Id' ;
    rdfs:comment 'Reference to the immediately preceding version of this transfer price record (self-referential). Enables reconstruction of the full price history chain for audit and tax authority documentation purposes.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferPrice .

ind:apaReference rdf:type rdf:Property ;
    rdfs:label 'Apa Reference' ;
    rdfs:comment 'Reference to an Advance Pricing Agreement (APA) or bilateral APA (BAPA) concluded with one or more tax authorities that pre-approves the transfer pricing methodology and price range for this transaction. Null if no APA is in place.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedPrice rdf:type rdf:Property ;
    rdfs:label 'Approved Price' ;
    rdfs:comment 'The arm\'s-length intercompany price approved for the transfer of the product or service per unit, expressed in the transaction currency. This is the operative price used in intercompany invoicing.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:armLengthRangeMax rdf:type rdf:Property ;
    rdfs:label 'Arm Length Range Max' ;
    rdfs:comment 'The upper bound of the arm\'s-length price range (interquartile range) established through benchmarking analysis. The approved transfer price must fall within this range to satisfy OECD and local tax authority requirements.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:armLengthRangeMin rdf:type rdf:Property ;
    rdfs:label 'Arm Length Range Min' ;
    rdfs:comment 'The lower bound of the arm\'s-length price range (interquartile range) established through benchmarking analysis. The approved transfer price must fall within this range to satisfy OECD and local tax authority requirements.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkingStudyRef rdf:type rdf:Property ;
    rdfs:label 'Benchmarking Study Ref' ;
    rdfs:comment 'Document reference number or identifier for the economic benchmarking study (comparables analysis) that supports the arm\'s-length determination for this transfer price. Links to the transfer pricing documentation file.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Base Amount' ;
    rdfs:comment 'The total cost base (direct manufacturing cost, overhead, and allocated R&D) used as the starting point for cost-plus or TNMM pricing method calculations. Expressed in the transaction currency.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markupPct rdf:type rdf:Property ;
    rdfs:label 'Markup Pct' ;
    rdfs:comment 'The arm\'s-length markup percentage applied to the cost base to arrive at the approved transfer price under cost-plus or TNMM methodology. Expressed as a decimal percentage (e.g., 15.0000 = 15%).' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit Of Measure' ;
    rdfs:comment 'The unit of measure to which the approved transfer price applies (e.g., per kg of API, per vial of drug product, per batch). Aligns with SAP S/4HANA base unit of measure on the material master. [ENUM-REF-CANDIDATE: kg|g|mg|L|mL|unit|vial|tablet|capsule|batch — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingMethod rdf:type rdf:Property ;
    rdfs:label 'Pricing Method' ;
    rdfs:comment 'OECD-recognized transfer pricing methodology applied to determine the arm\'s-length price. CUP = Comparable Uncontrolled Price; TNMM = Transactional Net Margin Method; RPM = Resale Price Method; PSM = Profit Split Method; cost_plus = Cost-Plus Method.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Stage' ;
    rdfs:comment 'The commercial lifecycle stage of the pharmaceutical product at the time this transfer price is established. Influences the pricing methodology and markup applied (e.g., pre-launch products may use cost-plus; commercial products may use CUP).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which the receiving legal entity is domiciled. Used for bilateral tax treaty analysis and OECD country-by-country reporting.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordNumber rdf:type rdf:Property ;
    rdfs:label 'Record Number' ;
    rdfs:comment 'Externally-known business identifier for the transfer pricing record, used in intercompany agreements, tax authority documentation, and OECD compliance filings. Format: TP-YYYY-NNNNNN.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle state of the transfer pricing record. Active records govern live intercompany transactions; superseded records have been replaced by a newer version. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|superseded|expired|cancelled — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDocRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Doc Ref' ;
    rdfs:comment 'Reference to the formal transfer pricing documentation package (local file, master file, or country-by-country report) filed with tax authorities in accordance with OECD BEPS Action 13 requirements. May reference a Veeva Vault document ID or SAP document number.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Sending Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which the sending legal entity is domiciled. Used for bilateral tax treaty analysis and OECD country-by-country reporting.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRulingRef rdf:type rdf:Property ;
    rdfs:label 'Tax Ruling Ref' ;
    rdfs:comment 'Reference to any binding tax ruling, private letter ruling, or competent authority agreement issued by a tax authority that specifically governs or validates this transfer pricing arrangement.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxApplicable rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Applicable' ;
    rdfs:comment 'Indicates whether withholding tax applies to the intercompany transaction governed by this transfer price (e.g., royalty payments or service fees may be subject to withholding tax under bilateral tax treaties).' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique identifier for the consent record. Primary key for the consent_record product.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The specific communication channel to which this consent or restriction applies. Enables channel-specific consent management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiration Date' ;
    rdfs:comment 'The date on which the consent automatically expires and is no longer valid. Null for consents with no expiration.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Consent Granted Date' ;
    rdfs:comment 'The date on which the HCP granted consent or permission for the specified communication or engagement type. Principal business event timestamp for this record.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The method by which consent was obtained. Explicit indicates affirmative action by HCP; implicit or inferred indicates consent derived from behavior or context.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The origin or method through which the consent or restriction was captured. Identifies the system or channel that recorded the consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentText rdf:type rdf:Property ;
    rdfs:label 'Consent Text' ;
    rdfs:comment 'The full text or summary of the consent statement presented to and accepted by the HCP. Provides audit trail of what was agreed to.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent form or policy under which this consent was granted. Enables tracking of consent policy changes over time.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentWithdrawnDate rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawn Date' ;
    rdfs:comment 'The date on which the HCP withdrew or revoked their consent. Null if consent has not been withdrawn.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:digitalChannelSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Channel Sync Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record has been synchronized to digital engagement platforms. True indicates sync is complete.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dncFlag rdf:type rdf:Property ;
    rdfs:label 'Dnc Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP is on the Do Not Contact list. True indicates contact is prohibited.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailPlatformSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Email Platform Sync Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record has been synchronized to email marketing platforms for enforcement. True indicates sync is complete.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'Indicates whether the consent or restriction is currently being enforced in downstream systems. Active means the rule is enforced; override indicates temporary suspension.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentRecord rdf:type rdf:Property ;
    rdfs:label 'Is Current Record' ;
    rdfs:comment 'Boolean indicator of whether this is the current active version of the consent record. True indicates this is the latest version; false indicates historical version.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record is under legal hold and must be preserved for litigation or regulatory investigation. True indicates legal hold is active.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldReason rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Reason' ;
    rdfs:comment 'Explanation or case reference for why the legal hold was applied. Null if no legal hold is active.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noSeeFlag rdf:type rdf:Property ;
    rdfs:label 'No See Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP has requested no in-person visits from field representatives. True indicates no-see restriction is active.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP has explicitly opted in to receive communications. True indicates active opt-in consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP has opted out of communications. True indicates active opt-out or withdrawal.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Record Effective Date' ;
    rdfs:comment 'The date from which this consent record version is effective. Supports temporal tracking and historical analysis.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordEndDate rdf:type rdf:Property ;
    rdfs:label 'Record End Date' ;
    rdfs:comment 'The date on which this consent record version ceased to be effective. Null for current active records. Supports temporal tracking and historical analysis.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'The primary regulatory framework or legal basis governing this consent or restriction. Identifies the compliance driver for the record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'The geographic or legal jurisdiction under which this consent or restriction is governed. May be country code, state code, or region identifier.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionReason rdf:type rdf:Property ;
    rdfs:label 'Restriction Reason' ;
    rdfs:comment 'Free-text explanation or code describing why the restriction was applied. May reference regulatory requirement, HCP request, or internal policy.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'The type of restriction or limitation applied to HCP contact. DNC (Do Not Contact), no-see (field rep restriction), legal hold, compliance-driven restriction, or channel-specific limitation.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaCrmSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Sync Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record has been synchronized to Veeva CRM for field force enforcement. True indicates sync is complete.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaCrmSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Sync Timestamp' ;
    rdfs:comment 'The date and time when this consent record was last synchronized to Veeva CRM. Null if never synchronized.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hcpEngagementId rdf:type rdf:Property ;
    rdfs:label 'Hcp Engagement Id' ;
    rdfs:comment 'Unique identifier for the HCP (Healthcare Professional) or HCO (Healthcare Organization) engagement record. Primary key.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementId rdf:type rdf:Property ;
    rdfs:label 'Engagement Id' ;
    rdfs:comment 'Unique identifier for this HCP-employee engagement relationship record. Primary key for the association.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Engagement .

ind:primaryHcpMslEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Hcp Msl Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Medical affairs employees (MSLs, medical directors) conduct scientific engagements with HCPs distinct from commercial sales calls. Required for medical affairs activity tracking, resource allocation, ' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adverseEventReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Reported Flag' ;
    rdfs:comment 'Boolean indicator of whether an adverse event was reported by the HCP during this engagement. True if an AE was mentioned, triggering pharmacovigilance follow-up. False otherwise.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewed Flag' ;
    rdfs:comment 'Boolean indicator of whether this engagement record has been reviewed and approved by compliance or legal teams. True if reviewed, False if pending review.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the engagement activity measured in minutes. Calculated from start and end times or manually entered.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Precise timestamp when the engagement activity concluded. Used for duration calculation and resource planning.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next planned follow-up action or engagement with this HCP. Nullable if no follow-up is planned.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Planned or actual frequency of professional interactions between the employee and HCP for this relationship. Used for territory planning, resource allocation, and relationship maintenance strategies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpFeedback rdf:type rdf:Property ;
    rdfs:label 'Hcp Feedback' ;
    rdfs:comment 'Free-text capture of feedback, questions, or comments provided by the HCP during the engagement. Used for medical affairs insights and product feedback loops.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyMessageDelivered rdf:type rdf:Property ;
    rdfs:label 'Key Message Delivered' ;
    rdfs:comment 'The primary approved key message or talking point that was communicated during the engagement. Aligns with approved promotional messaging and Medical-Legal-Regulatory (MLR) reviewed content.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent professional interaction (meeting, call, email exchange, conference encounter) between this employee and HCP. Used to identify stale relationships requiring re-engagement and for compliance reporting of HCP interaction frequency.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Free-text description of the physical or virtual location where the engagement occurred. May include office name, hospital department, conference venue, or virtual platform name.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsShared rdf:type rdf:Property ;
    rdfs:label 'Materials Shared' ;
    rdfs:comment 'Description or list of promotional materials, medical information documents, or educational resources shared with the HCP during the engagement. May include brochure names, approved material IDs, or content titles.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalInquiryFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Inquiry Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP made a medical information request or inquiry during the engagement. True if a medical inquiry was raised, False otherwise. Triggers medical affairs follow-up.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Free-text description of the planned follow-up action or next step resulting from this engagement. May include scheduling another meeting, sending additional information, or other commitments.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this employee is designated as the primary point of contact for this HCP within the organization. Used for routing inquiries, coordinating multi-functional engagement, and preventing duplicate outreach. An HCP may have different primary contacts for different therapeutic areas.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when this employee-HCP engagement relationship was formally ended or reassigned. Null for active relationships. Used for tracking relationship handoffs during territory changes, employee transitions, or strategic deprioritization.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when this employee-HCP engagement relationship was formally established or assigned. Used for relationship tenure analysis, onboarding tracking, and historical relationship mapping.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of this HCP-employee engagement relationship. Active relationships require ongoing management and interaction tracking. Inactive or Suspended relationships are retained for historical analysis and potential reactivation.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength Score' ;
    rdfs:comment 'Quantitative metric (0-100 scale) assessing the strength and quality of this specific HCP-employee engagement relationship based on interaction frequency, responsiveness, collaboration depth, and strategic value. Used for prioritizing engagement efforts and measuring field team effectiveness.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplesProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Samples Provided Flag' ;
    rdfs:comment 'Boolean indicator of whether product samples were provided to the HCP during this engagement. True if samples were dispensed, False otherwise.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The unique identifier of this engagement record in the source operational system. Used for data reconciliation and traceability back to the source.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Precise timestamp when the engagement activity began. Used for duration calculation and detailed scheduling analytics.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:territoryAssignment rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment' ;
    rdfs:comment 'Geographic or organizational territory code under which this HCP-employee engagement relationship is managed. Used for field force alignment, territory planning, and sales/medical affairs coordination. Territory assignments can change during organizational restructuring while maintaining relationship continuity.' ;
    rdfs:domain ind:HcpEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferOfValueAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Of Value Amount' ;
    rdfs:comment 'Monetary value of any transfer of value provided to the HCP during this engagement. Includes meals, honoraria, consulting fees, or other payments. Nullable if no transfer of value occurred. Used for Sunshine Act transparency reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferOfValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Transfer Of Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transfer of value amount. Nullable if no transfer of value occurred.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiration Date' ;
    rdfs:comment 'Date when the current accreditation certification expires. Triggers re-evaluation and compliance monitoring workflows.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current accreditation status from recognized healthcare accreditation bodies. Indicates quality standards compliance and eligibility for certain programs.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditingBody rdf:type rdf:Property ;
    rdfs:label 'Accrediting Body' ;
    rdfs:comment 'Name of the primary accreditation organization that has certified this healthcare organization (e.g., Joint Commission, NCQA, DNV, AAAHC).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the healthcare organization headquarters or primary location. Used for territory assignment and geographic analytics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, or building information.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedCount rdf:type rdf:Property ;
    rdfs:label 'Bed Count' ;
    rdfs:comment 'Total number of licensed inpatient beds at the healthcare facility. Used for market sizing, territory planning, and commercial targeting segmentation.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City name for the healthcare organization primary address.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Cms Certification Number' ;
    rdfs:comment 'CMS Certification Number (CCN) assigned to Medicare-certified healthcare facilities. Six-character alphanumeric identifier used for Medicare reimbursement.' ;
    rdfs:domain ind:HcoMaster ;
