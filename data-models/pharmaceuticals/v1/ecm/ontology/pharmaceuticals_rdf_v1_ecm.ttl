ind:nextCredentialingDate rdf:type rdf:Property ;
    rdfs:label 'Next Credentialing Date' ;
    rdfs:comment 'Scheduled date for the next credentialing review and renewal.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours of the pharmacy including days and times of operation.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyStatus rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Status' ;
    rdfs:comment 'Current operational and regulatory status of the pharmacy in the network.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyType rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Type' ;
    rdfs:comment 'Classification of pharmacy based on operational model and service delivery channel.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementRateSchedule rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Rate Schedule' ;
    rdfs:comment 'Code identifying the reimbursement rate schedule or fee schedule applicable to this pharmacy for claims adjudication.' ;
    rdfs:domain ind:Pharmacy ;
