ind:utilizationManagementLevel rdf:type rdf:Property ;
    rdfs:label 'Utilization Management Level' ;
    rdfs:comment 'The intensity of utilization management controls applied by the PBM, including prior authorization, step therapy, and quantity limits.' ;
    rdfs:domain ind:Pbm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Id' ;
