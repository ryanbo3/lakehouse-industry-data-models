    rdfs:comment 'Indicates whether the pharmacy participates in formulary-based reimbursement programs and accepts formulary restrictions.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:homeDeliveryAvailable rdf:type rdf:Property ;
    rdfs:label 'Home Delivery Available' ;
    rdfs:comment 'Indicates whether the pharmacy offers home delivery service for prescriptions.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immunizationServices rdf:type rdf:Property ;
    rdfs:label 'Immunization Services' ;
    rdfs:comment 'Indicates whether the pharmacy provides immunization and vaccination services.' ;
    rdfs:domain ind:Pharmacy ;
