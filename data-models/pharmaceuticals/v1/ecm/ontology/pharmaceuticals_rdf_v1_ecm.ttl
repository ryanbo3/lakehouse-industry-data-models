    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biobankName rdf:type rdf:Property ;
    rdfs:label 'Biobank Name' ;
    rdfs:comment 'Official name of the biobank facility or biological sample repository.' ;
