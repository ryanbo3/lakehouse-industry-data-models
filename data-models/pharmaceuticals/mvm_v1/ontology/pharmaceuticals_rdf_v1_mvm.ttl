# RDFS Schema for Business: Pharmaceuticals

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/pharmaceuticals#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Pharmaceuticals ---
ind:Pharmaceuticals rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Pharmaceuticals' ;
    rdfs:comment 'Pharmaceuticals is a research-intensive industry focused on discovering, developing, and manufacturing medicines, vaccines, and consumer health products to treat and prevent diseases across therapeutic areas including oncology, immunology, and rare diseases.' .

# --- Domain Classes ---
ind:Discovery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Discovery' ;
    rdfs:comment 'Owns all data generated during drug discovery and target identification, including high-throughput screening (HTS) results, structure-activity relationship (SAR) analysis, mechanism of action (MOA) studies, hit-to-lead progression, molecular targets, and early-stage compound optimization under GLP. Manages research data from electronic lab notebooks (ELN) in IDBS/Dotmatics, assay results, and compound libraries. Authoritative source for NCE (New Chemical Entity) and NBE (New Biological Entity) research data entering the development pipeline.' .

ind:Clinical rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Clinical' ;
    rdfs:comment 'Manages end-to-end clinical trial design, execution, and data management across all phases (I-IV). Covers investigational sites, principal investigators, trial protocols, case report forms (CRF), electronic data capture (EDC) from Medidata Rave, CTMS records from Oracle/Siebel, eTMF in Veeva Vault, and GCP-compliant execution. Includes patient enrollment, randomization, blinding, and intent-to-treat (ITT) analysis. Authoritative source for clinical efficacy and safety endpoints including ORR, PFS, OS, and QoL metrics. Supports IND/NDA/BLA/MAA submissions.' .

ind:Regulatory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Regulatory' ;
    rdfs:comment 'Manages all regulatory submissions, approvals, and compliance management including IND, NDA, BLA, MAA, and eCTD dossiers. Tracks interactions with FDA, EMA, PMDA, MHRA, and NMPA health authorities. Manages regulatory milestones, pre-approval inspections (PAI), REMS programs, post-approval commitments, drug master files (DMF), label management, and regulatory correspondence. Integrates with Veeva Vault RIM and RIMS for submission tracking and lifecycle management.' .

ind:Manufacturing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Manufacturing' ;
    rdfs:comment 'Manages production of drug substances (DS) and drug products (DP) including API production, formulation, fill-finish, and packaging under cGMP. Covers manufacturing execution system (MES) data, batch records, critical process parameters (CPP), critical quality attributes (CQA), equipment scheduling, and production schedules. Includes CMO and CDMO oversight. Integrates with SAP PP/QM and MES systems. Supports QbD principles and PAT implementation per 21 CFR Parts 210/211.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Quality' ;
    rdfs:comment 'Controls quality management system (QMS) including quality control testing, quality assurance oversight, CAPA (corrective and preventive action), deviation management, OOS (out of specification) investigations, OOT (out of trend) analysis, change controls, SOPs, and audit findings. Manages LIMS data, stability studies, method validation, and certificate of analysis (CoA) issuance. Integrates with MasterControl/TrackWise and SAP QM. Implements QbD and PAT principles across GMP, GLP, and GCP quality oversight.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Supply' ;
    rdfs:comment 'Manages end-to-end pharmaceutical supply chain planning and execution including demand forecasting, inventory management, cold-chain logistics, GDP (Good Distribution Practice) compliance, and distribution network management. Covers raw materials, API, excipients, packaging components, and finished goods across manufacturing sites, distribution centers, and third-party logistics providers. Integrates with Kinaxis RapidResponse/Blue Yonder and SAP MM/WM/SD. Tracks SKU, NDC, and lot/batch traceability for both commercial and clinical trial supply chains.' .

ind:Pharmacovigilance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Pharmacovigilance' ;
    rdfs:comment 'Owns all post-market safety surveillance and adverse event management. Collects, processes, and reports individual case safety reports (ICSR), serious adverse events (SAE), suspected unexpected serious adverse reactions (SUSAR), periodic safety update reports (PSUR), risk management plans (RMP), and signal detection records. Integrates with Argus Safety/Oracle AERS. Supports mandatory regulatory reporting to FDA, EMA, and other health authorities per PV regulations.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Product' ;
    rdfs:comment 'Authoritative catalog and lifecycle management for all pharmaceutical products including branded drugs, generics, biosimilars, vaccines, and consumer health products. Manages product hierarchies, drug substance/drug product definitions, finished dosage forms (FDF), SKUs, NDC codes, ATC classifications, international nonproprietary names (INN), USAN, formulations, strengths, dosage forms, packaging configurations, and regulatory identifiers. Serves as the master product catalog referenced by manufacturing, commercial, regulatory, and supply chain domains.' .

ind:Patient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Patient' ;
    rdfs:comment 'Single source of truth for patient and clinical trial participant master data including demographics, enrollment status, informed consent, medical history, longitudinal treatment records, and patient-reported outcomes. Manages patient registries, patient support programs, adherence monitoring, and copay assistance programs. Ensures HIPAA and GDPR compliance for protected health information (PHI). Authoritative source for patient identity across clinical trials, pharmacovigilance, and market access programs.' .

ind:Commercial rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Commercial' ;
    rdfs:comment 'Handles commercial operations including sales force management, healthcare professional (HCP) engagement, key opinion leader (KOL) relationships, promotional materials (Veeva PromoMats), territory management, product launch activities, sample distribution, and speaker programs. Integrates with Veeva CRM and Salesforce Health Cloud. Manages compliance with promotional regulations, PhRMA code, and Sunshine Act transparency reporting. Supports brand performance tracking and P&L reporting by brand.' .

ind:Market rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Market' ;
    rdfs:comment 'Coordinates market access, pricing, reimbursement, and payer relations. Manages formulary positioning, health technology assessment (HTA) submissions, value dossiers, contracting with payers, pharmacy benefit managers (PBM), and group purchasing organizations (GPO). Tracks reimbursement policies, coverage decisions, patient access programs, copay assistance, and gross-to-net revenue management. Owns RWE and RWD assets used for payer negotiations.' .

ind:Hcp rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Hcp' ;
    rdfs:comment 'Healthcare professional and healthcare organization master data including physicians, pharmacists, hospitals, clinics, and key opinion leaders (KOL). Manages HCP credentials, specialties, prescribing patterns, affiliations, and engagement history. Ensures compliance with Sunshine Act transparency reporting and anti-kickback regulations. Authoritative source for HCP identity and relationship data used across commercial, medical affairs, and clinical operations.' .

ind:Intellectual rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Intellectual' ;
    rdfs:comment 'SSOT for intellectual property portfolio including patents (NCE, NBE, formulations, processes), patent expiry timelines, exclusivity periods (orphan drug, data exclusivity, pediatric), trademark registrations, drug master files, freedom-to-operate analyses, and licensing agreements. Supports lifecycle management decisions, generic/biosimilar entry defense strategies, and coordination with legal counsel on patent litigation.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Owns enterprise financial data including general ledger, accounts payable, accounts receivable, cost accounting, budgeting, R&D capitalization, COGS by product, royalty accounting, and SOX-compliant financial reporting. Integrates with SAP FI/CO modules. Supports P&L by therapeutic area, brand, and geography, return on investment (ROI) for R&D programs, and capital expenditure tracking.' .

ind:Masterdata rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmaceuticals ;
    rdfs:label 'Masterdata' ;
    rdfs:comment 'Governs enterprise master data including organization hierarchy, chart of accounts, vendor master, material master, geographic reference data, units of measure, and code sets (ATC, NDC). Serves as the cross-domain reference layer ensuring consistent identifiers across SAP S/4HANA, Veeva, LIMS, and other operational systems. Supports MDM governance, data stewardship, and data quality management.' .

# --- Data Product Classes (Tables) ---
ind:Patent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Patent' ;
    rdfs:comment 'Core master record for all pharmaceutical patents owned or licensed by the company. Captures patent number, title, filing/grant/expiry dates, patent family reference, jurisdiction, patent type (composition of matter, method of use, formulation, process, polymorph, salt form), covered compound (INN/USAN), therapeutic area, legal status, and assignee. Also serves as the anchor for trade secrets and know-how records via asset classification. SSOT for the IP portfolio — anchors lifecycle management, LOE planning, litigation defense, and generic/biosimilar entry strategy.' .

ind:PatentClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Patent Claim' ;
    rdfs:comment 'Individual claims within a granted or pending patent, capturing claim number, claim type (independent, dependent), claim text, claim scope classification (broad, narrow, genus, species), and validity status. Critical for freedom-to-operate analyses, infringement assessments, and generic/biosimilar entry defense strategies. Each claim has its own legal standing and may be challenged independently during inter partes review (IPR) or opposition proceedings.' .

ind:PatentFamily rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Patent Family' ;
    rdfs:comment 'Groups related patents and patent applications filed across multiple jurisdictions that share a common priority application. Tracks the priority application number, priority date, PCT application number, family type (simple, extended, INPADOC), and member count. Enables portfolio-level analysis of global IP coverage for a given invention and supports lifecycle management across jurisdictions.' .

ind:ExclusivityPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Exclusivity Period' ;
    rdfs:comment 'Tracks all regulatory exclusivity periods granted to pharmaceutical products, distinct from patent protection. Covers orphan drug exclusivity (7 years US / 10 years EU), data exclusivity (5 years NCE / 3 years new indication), pediatric exclusivity extension (6 months), new chemical entity exclusivity, biologics exclusivity (12 years US), and REMS exclusivity. Captures exclusivity type, granting authority (FDA, EMA, PMDA), start date, expiry date, product reference, and associated NDA/BLA/MAA number. Critical for lifecycle management and generic/biosimilar entry defense.' .

ind:Trademark rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Trademark' ;
    rdfs:comment 'Master record for all pharmaceutical trademark registrations including brand names, logos, trade dress, and slogans. Captures trademark name, registration number, filing date, registration date, expiry/renewal date, jurisdiction, Nice classification, goods and services description, trademark type (word mark, figurative, combined), owner entity, and current status (pending, registered, opposed, cancelled). Supports brand protection strategy and commercial launch activities.' .

ind:DrugMasterFile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Drug Master File' ;
    rdfs:comment 'Master record for Drug Master Files (DMFs) submitted to regulatory authorities. Covers Type I-V DMFs (manufacturing site, drug substance/API, packaging, excipient, reference information). Captures DMF number, type, holder, submission/amendment dates, regulatory authority, active status, and associated substance. Supports CMC submissions and third-party API/excipient qualification for regulatory filings.' .

ind:LicensingAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Licensing Agreement' ;
    rdfs:comment 'Records all IP licensing agreements (in-licensing, out-licensing, cross-licensing, co-development, collaboration) including deal terms, milestone obligations, and milestone payment tracking. Captures agreement type, parties, licensed assets, territory, field of use, exclusivity scope, royalty structure, milestone events (regulatory filing, IND submission, phase completion, NDA approval, first commercial sale, sales thresholds), milestone descriptions, trigger events, milestone due dates, achieved dates, milestone payment amounts, currency, payment status, responsible party, sublicensing rights, and termination conditions. Supports deal management, milestone tracking, revenue recognition (ASC 606), royalty accounting, and partner relationship management.' .

ind:RoyaltyPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Royalty Payment' ;
    rdfs:comment 'Transactional record of royalty payments made or received under licensing agreements. Captures payment date, payment direction (inbound/outbound), royalty basis (net sales, units sold), royalty rate applied, calculation period, gross sales, net sales, deductions, royalty amount, currency, payment status, and reconciliation status. Supports financial reporting, royalty audits, and compliance with licensing agreement terms.' .

ind:FtoAnalysis rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Fto Analysis' ;
    rdfs:comment 'Freedom-to-Operate (FTO) analysis and competitive IP watch records. Covers FTO assessments determining whether a product, process, or technology can be commercialized without infringing third-party IP rights, plus ongoing monitoring of competitor IP activities (patent filings, ANDA/505(b)(2) submissions, biosimilar applications, patent challenges). Captures analysis title, scope, requestor, conducting attorney or firm, analysis date, product or technology assessed, jurisdictions covered, identified blocking patents, risk level, recommended actions, final opinion, watch type, competitor identity, filing dates, reference numbers, technology area, affected products, and threat assessment. Supports go/no-go decisions for product development, commercial launch, and proactive IP defense strategy.' .

ind:PatentLitigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Patent Litigation' ;
    rdfs:comment 'Tracks active and historical patent litigation cases including Paragraph IV ANDA challenges, inter partes review (IPR) petitions, post-grant review (PGR), patent infringement suits, and declaratory judgment actions. Captures case number, court or tribunal, case type, filing date, parties (plaintiff, defendant), asserted patents, accused products, litigation status, key milestones, outside counsel, estimated liability, and outcome. Critical for generic/biosimilar entry defense strategy and legal budget management.' .

ind:PatentProsecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Patent Prosecution' ;
    rdfs:comment 'Tracks patent application prosecution workflow from filing through grant or abandonment, including all annuity and maintenance fee payment obligations across all jurisdictions. Captures application number, prosecution stage, patent office, examiner, office actions received, response deadlines, prosecution attorney, prosecution strategy, and complete annuity/maintenance fee history (fee year, due dates, amounts, currencies, payment status, paying agents, confirmation receipts, grace periods, surcharge amounts). Failure to pay annuities results in patent lapse. Supports docketing, deadline management, fee compliance, cost tracking, portfolio maintenance operations, and annuity budget forecasting.' .

ind:PatentTermExtension rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Patent Term Extension' ;
    rdfs:comment 'Records all patent term extension and supplementary protection mechanisms across global jurisdictions that compensate for regulatory review time lost during drug approval. Covers US Hatch-Waxman Patent Term Extension (PTE), EU/UK Supplementary Protection Certificates (SPC), Japanese patent term extension, and equivalent national mechanisms. Captures application number, mechanism type (PTE, SPC, national equivalent), filing date, patent reference, product reference, marketing authorization reference, regulatory review period, calculated/granted extension duration, adjusted expiry date, granting authority, decision status, SPC-specific fields (basic patent, product definition per Article 1(b)), and pediatric extension eligibility. Single source of truth for all patent term adjustments — critical for accurate LOE date calculation across all markets.' .

ind:OrangeBookListing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Orange Book Listing' ;
    rdfs:comment 'Records of patents and exclusivities listed in the FDA Orange Book (Approved Drug Products with Therapeutic Equivalence Evaluations) for each NDA/ANDA product. Captures NDA number, product name, active ingredient, dosage form, strength, listed patent number, patent expiry date, exclusivity code, exclusivity expiry date, and listing status. Directly governs generic entry timelines and Paragraph IV challenge eligibility. Analogous listings for EU (Article 10 reference) and other markets are also captured.' .

ind:Submission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Submission' ;
    rdfs:comment 'Master record and single source of truth for all regulatory submissions (filing events) to health authorities including original applications, supplements, amendments, responses to information requests, and annual reports. Each submission represents a discrete eCTD sequence filed under a parent application. Tracks submission type, sequence number, dossier format (eCTD), submission date, target agency, eCTD lifecycle operation (new, replace, append, delete), submission medium, validation status, regulatory pathway, priority designation, and current lifecycle status. Includes document-level composition tracking with CTD module/section assignment (Modules 1-5), individual document metadata (title, type, version, author, status, file format, checksum), version control, and dossier completeness assessment aligned with ICH M4 (CTD structure) and M8 (eCTD technical specification). SSOT for regulatory submission identity, lifecycle, sequence tracking, dossier content, and document inventory in Veeva Vault RIM.' .

ind:HealthAuthority rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Health Authority' ;
    rdfs:comment 'Reference master for all global health authority agencies with which the company interacts, including FDA, EMA, PMDA, MHRA, NMPA, WHO, and national competent authorities. Captures agency name, acronym, jurisdiction, country/region, agency type, contact details, submission portal URL, accepted dossier formats, and applicable regulatory frameworks. Enables consistent agency identification across all regulatory activities.' .

ind:Application rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Application' ;
    rdfs:comment 'Master record for a regulatory application (IND, NDA, BLA, MAA, ANDA, 510k) representing the formal dossier filed with a health authority for a specific drug product. Tracks application number assigned by the agency, application type, applicant entity, lead product, therapeutic indication, regulatory pathway, orphan designation status, priority review status, PDUFA/action date, and overall approval status. One application may have multiple submissions (original + supplements).' .

ind:SubmissionSequence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Submission Sequence' ;
    rdfs:comment 'Tracks individual eCTD submission sequences within a regulatory application, representing each discrete filing event (original submission, amendment, response to information request, annual report, supplement). Captures sequence number, submission date, submission type (original, class I/II supplement, CBE, PAS), eCTD lifecycle operation (new, replace, append), submission medium, and validation status. Aligns with ICH M8 eCTD technical specification.' .

ind:Milestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Milestone' ;
    rdfs:comment 'Tracks key regulatory milestones and target dates for submissions and applications, including IND filing date, End-of-Phase 2 meeting, NDA/BLA filing date, PDUFA date, advisory committee meeting, complete response letter (CRL) receipt, approval date, and post-approval commitment due dates. Captures planned vs. actual dates, milestone type, responsible owner, and completion status. Critical for regulatory project management and timeline tracking.' .

ind:Approval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Approval' ;
    rdfs:comment 'Records formal regulatory approvals and marketing authorizations granted by health authorities for drug products. Captures approval date, approval type (full, accelerated, conditional, provisional), approved indication, approved dosage form and strength, approved patient population, approval conditions, post-approval commitments, and approval certificate reference. SSOT for product approval status across all markets. Links to application and health authority.' .

ind:HaInteraction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Ha Interaction' ;
    rdfs:comment 'Single source of truth for ALL formal interactions and communications with health authorities including Type A/B/C meetings (FDA), scientific advice (EMA), pre-submission meetings, advisory committee meetings, and all written correspondence (information requests, complete response letters, deficiency letters, acknowledgment letters, approval letters, agency queries, and general regulatory correspondence). Captures interaction type, format (in-person, teleconference, written), direction (inbound/outbound), dates, participants, discussion topics, agreed outcomes, response deadlines, follow-up actions, correspondence tracking numbers, document references, and response timeline compliance. Consolidates both meeting-based and written communications into a single chronological record per application. SSOT for all health authority communications — no separate correspondence product exists. Sourced from Veeva Vault RIM correspondence and meeting modules.' .

ind:Dmf rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Dmf' ;
    rdfs:comment 'Drug Master File (DMF) registry tracking all DMFs filed with health authorities for APIs, excipients, packaging materials, and manufacturing sites. Captures DMF number, DMF type (Type I-V), holder name, subject of DMF, filing date, last annual update date, authorization letters issued, and associated products referencing the DMF. Supports CMC regulatory strategy and third-party supplier qualification. Aligns with 21 CFR 314.420 and EMA DMF guidelines.' .

ind:Label rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Label' ;
    rdfs:comment 'Single source of truth for approved product labeling (prescribing information, package insert, patient information leaflet, SmPC) and complete change history across all markets and languages. Tracks current label version, effective date, approval date, market/country, language, label type, content sections, and lifecycle status. Maintains full amendment history including change reason (safety update, new indication, dosage modification, black box warning), change type (agency-initiated, company-initiated), regulatory basis, affected sections, submission reference, and implementation status across markets. SSOT for both current approved labeling and all historical label changes — no separate label change product exists. Integrates with Veeva Vault PromoMats and RIM.' .

ind:LabelChange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Label Change' ;
    rdfs:comment 'Tracks all label changes and labeling amendments including the reason for change, change type (safety update, new indication, dosage modification, black box warning addition), regulatory basis, submission reference, effective date, and implementation status across markets. Captures the specific sections modified, change description, and whether the change was agency-initiated or company-initiated. Critical for pharmacovigilance-driven label updates and post-approval lifecycle management.' .

ind:Rems rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Rems' ;
    rdfs:comment 'Risk Evaluation and Mitigation Strategy (REMS) program master record for products requiring FDA-mandated risk management programs. Captures REMS program name, associated NDA/BLA, REMS elements (medication guide, communication plan, ETASU), program approval date, assessment schedule, enrollment requirements, certified pharmacy/prescriber requirements, and program status. Tracks REMS modifications and assessment submission history. Specific to FDA-regulated products under 21 CFR 314.520.' .

ind:PostApprovalCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Post Approval Commitment' ;
    rdfs:comment 'Single source of truth for all post-approval commitments, post-marketing requirements (PMR/PMC), and their granular fulfillment actions. Tracks commitment type (PMR, PMC, Phase IV study, label update, stability study), description, due dates, agency-assigned tracking number, and individual action-level tasks (protocol submission, interim reports, final study reports) with responsible functions, deliverable types, due dates, completion dates, and status. Monitors compliance with FDA PMR/PMC requirements under FDAAA and EMA post-authorization measures. Provides both executive-level commitment status and operational task-level progress tracking in a single entity. SSOT for all regulatory obligation tracking — no separate action-level product exists.' .

ind:Strategy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Strategy' ;
    rdfs:comment 'Documents the regulatory strategy for each drug development program, capturing the planned regulatory pathway, target product profile (TPP), key regulatory risks, agency engagement plan, global filing sequence, priority markets, expedited program designations pursued (Breakthrough, Fast Track, PRIME, Sakigake), competitive landscape considerations, and strategic rationale. Serves as the authoritative regulatory plan linking development programs to submission plans and commercial launch timelines. Managed within Veeva Vault RIM.' .

ind:Designation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Designation' ;
    rdfs:comment 'Tracks special regulatory designations and expedited program grants for drug products including FDA Breakthrough Therapy, Fast Track, Accelerated Approval, Priority Review, Orphan Drug Designation (ODD), Rare Pediatric Disease, EMA PRIME, and PMDA Sakigake. Captures designation type, granting agency, request date, grant date, expiry date, associated product and indication, and designation-specific benefits and obligations. Critical for regulatory strategy and commercial planning.' .

ind:Variation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Variation' ;
    rdfs:comment 'Tracks post-approval variations and supplements to marketing authorizations including Type IA, IB, and II variations (EMA), CBE-0, CBE-30, and PAS supplements (FDA), and equivalent changes in other markets. Captures variation type, change description, affected CTD sections, submission date, approval date, implementation date, and regulatory basis. Manages the lifecycle of approved product changes across global markets. Sourced from Veeva Vault RIM variation management module.' .

ind:ProductRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Product Registration' ;
    rdfs:comment 'Single source of truth for country-level product registration master tracking the marketing authorization status, complete renewal lifecycle, and maintenance calendar of each drug product in each country/market. Captures registration number, country, registration holder, registration date, expiry date, approved indication, approved dosage forms and strengths, local brand name, and registration status (active, suspended, withdrawn, expired). Includes complete renewal tracking: renewal type (5-year, annual, sunset clause), renewal due dates, submission dates, approval dates, fee payment status, and renewal outcomes. Manages the renewal calendar across all markets to prevent registration lapse. SSOT for global product registration footprint, renewal compliance, and commercial continuity — no separate renewal product exists.' .

ind:MolecularTarget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Molecular Target' ;
    rdfs:comment 'Master record for biological molecular targets identified during drug discovery, including proteins, enzymes, receptors, ion channels, and nucleic acids. Captures target class, gene name, UniProt/Ensembl identifiers, mechanism of action (MOA), therapeutic area relevance, target validation status, druggability assessment, and disease association. Authoritative SSOT for all target identification data entering the discovery pipeline from IDBS/Dotmatics ELN.' .

ind:Compound rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Compound' ;
    rdfs:comment 'Master record for all chemical and biological compounds in the discovery compound library, including NCEs (New Chemical Entities) and NBEs (New Biological Entities). Captures compound identity (IUPAC name, INN/USAN, registration number, CAS number), structural representation (molecular formula, molecular weight, SMILES, InChI), compound class (small molecule, biologic, peptide, ADC), source (synthesized, purchased, natural product), physicochemical properties (purity, physical state, storage conditions), and library membership. Authoritative SSOT for compound identity and structure across the discovery domain.' .

ind:Assay rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Assay' ;
    rdfs:comment 'Master record for biological and biochemical assays used in drug discovery screening and profiling. Captures assay name, assay type (biochemical, cell-based, phenotypic, ADME, toxicity), assay format (HTS, dose-response, selectivity), target association, assay technology platform (HTRF, AlphaScreen, SPR, NMR), assay validation status, GLP compliance flag, detection method, assay protocol reference, throughput capacity, and responsible scientist. Sourced from IDBS/Dotmatics ELN.' .

ind:HtsCampaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Hts Campaign' ;
    rdfs:comment 'Master record for High-Throughput Screening (HTS) campaigns executed against compound libraries. Captures campaign name, target or assay being screened, compound library used, screening format (primary, confirmatory, counter-screen), campaign status, start and end dates, number of compounds screened, hit rate, assay window (Z-prime factor), screening technology platform, CRO involvement flag, and campaign owner. Central operational entity for HTS execution tracking.' .

ind:ScreeningResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Screening Result' ;
    rdfs:comment 'Transactional record capturing individual compound screening results from HTS campaigns, dose-response assays, and selectivity panels. Captures compound, assay, and campaign references, plate/well position, raw signal, percent inhibition/activation, potency values (IC50/EC50/Ki), Hill slope, curve fit quality (R-squared), result classification (active, inactive, inconclusive, toxic, hit, confirmed hit, false positive), selectivity score, replicate number, run date, and data quality flags. Includes hit-to-lead eligibility determination. Distinct from in_vitro_study: screening_result covers primary and confirmatory screening at scale; in_vitro_study covers deeper mechanistic follow-up on selected compounds.' .

ind:SarStudy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Sar Study' ;
    rdfs:comment 'Master record for Structure-Activity Relationship (SAR) studies conducted to understand how structural modifications to a compound affect its biological activity. Captures study name, lead series identifier, target identifier, SAR hypothesis, key structural features analyzed, number of analogs synthesized, potency range observed, selectivity findings, ADME impact, study status, lead scientist, and ELN notebook reference from IDBS/Dotmatics. Core entity for medicinal chemistry optimization.' .

ind:LeadSeries rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Lead Series' ;
    rdfs:comment 'Master record for chemical lead series progressing through hit-to-lead and lead optimization stages. Captures series name, scaffold/chemotype description, originating HTS campaign, primary target, series status (hit-to-lead, lead optimization, deprioritized, nominated), best-in-class compound identifier, potency benchmark, selectivity profile, ADME profile summary, IP landscape assessment, therapeutic area, program code, and stage-gate progression history with decision rationale. Central entity for tracking medicinal chemistry progression and compound governance decisions from hit confirmation through candidate nomination.' .

ind:CompoundSynthesis rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Compound Synthesis' ;
    rdfs:comment 'Transactional record capturing the synthesis of individual compounds by medicinal chemistry teams. Captures compound identifier, synthesis route identifier, synthetic method, reagents used, reaction conditions (temperature, solvent, catalyst), yield percentage, purity by HPLC/NMR, batch number, synthesis date, synthesizing chemist, ELN experiment reference from IDBS/Dotmatics, and GLP compliance flag. Tracks the manufacturing provenance of discovery compounds.' .

ind:AdmeProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Adme Profile' ;
    rdfs:comment 'Transactional record capturing ADME (Absorption, Distribution, Metabolism, Excretion) profiling results for compounds under evaluation. Captures compound identifier, assay panel used, solubility value, permeability (Caco-2/PAMPA), plasma protein binding, microsomal stability (human/rat liver microsomes), CYP inhibition profile, P-glycoprotein substrate flag, blood-brain barrier penetration, half-life, clearance rate, bioavailability estimate, assay date, and ADME scientist. Critical for compound progression decisions.' .

ind:Project rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Project' ;
    rdfs:comment 'Master record for drug discovery research projects organized around one or more therapeutic targets or disease indications. Captures project name, project code, therapeutic area, disease indication (ICD-10/MeSH reference), primary and secondary target identifiers (supporting multi-target programs), project phase (target identification, target validation, hit identification, hit-to-lead, lead optimization, candidate nomination), project status, start date, projected candidate nomination date, project leader, team members, budget allocation, strategic priority tier, external collaboration references, and portfolio governance decisions. Top-level organizational entity for the discovery domain providing project-centric views of all discovery activities.' .

ind:CandidateNomination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Discovery ;
    rdfs:label 'Candidate Nomination' ;
    rdfs:comment 'Transactional record capturing the formal nomination of a development candidate (DC) compound for progression from discovery into preclinical development. Captures nominated compound identifier, lead series identifier, discovery project identifier, nomination date, therapeutic area, target, proposed indication, key efficacy data summary, key safety data summary, ADME/PK profile summary, IP status, CMC feasibility assessment, nomination decision (approved, deferred, rejected), decision committee, and handoff date to preclinical team. Critical milestone event linking discovery to clinical development pipeline.' .

ind:Trial rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Trial' ;
    rdfs:comment 'Master record for each clinical trial (study) conducted by Pharmaceuticals, covering all phases (I–IV). Captures investigational product, therapeutic area, phase, study design (randomized, blinded, open-label), primary and secondary endpoints (ORR, PFS, OS, QoL), IND/CTA reference numbers, EudraCT/NCT identifiers, sponsor, CRO partner, planned vs. actual start/end dates, GCP compliance status, regulatory submission references (IND, NDA, BLA, MAA), overall trial lifecycle state, and key operational milestones (FPFV, LPLV, database lock, CSR completion, interim analysis dates) with planned vs. actual tracking and variance commentary. Authoritative SSOT for all trial-level metadata and timeline milestones consumed by regulatory submissions and eTMF in Veeva Vault.' .

ind:Protocol rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Protocol' ;
    rdfs:comment 'Formal clinical trial protocol document master, representing each approved version of the study protocol. Tracks protocol number, version, amendment history and rationale, approval date, IRB/IEC approval reference, study objectives (primary, secondary, exploratory), inclusion/exclusion criteria, dosing regimen, visit schedule (schedule of assessments), randomization design (scheme type, stratification factors, allocation ratio, blinding method), statistical analysis plan reference, sample size justification, and GCP compliance attestation. Linked to the parent trial and managed in Veeva Vault eTMF. Each amendment creates a new versioned protocol record with change justification.' .

ind:InvestigationalSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Investigational Site' ;
    rdfs:comment 'Master record for each clinical investigational site (hospital, clinic, research center) participating in one or more trials. Captures site name, address, country, site number, IRB/IEC of record, site activation milestones (feasibility, selection, SIV, FPFV target), site closure date, enrollment capacity, GCP inspection history, site status (selected, activated, enrolling, on-hold, closed), regulatory authority jurisdiction, and CRA assignment for site initiation and ongoing oversight. Serves as the geographic and operational anchor for site-level enrollment, monitoring, and IMP accountability activities.' .

ind:PrincipalInvestigator rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Principal Investigator' ;
    rdfs:comment 'Master record for each Principal Investigator (PI) and sub-investigator responsible for conducting a clinical trial at a site. Captures investigator name, medical license number, specialty, GCP training certification date, CV reference, financial disclosure status, delegation log reference, and regulatory authority registration. Distinct from the HCP domain (which covers commercial HCP engagement) — this entity is specifically scoped to GCP-regulated trial conduct roles.' .

ind:ClinicalEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Clinical Enrollment' ;
    rdfs:comment 'Transactional record capturing each subject\'s complete enrollment and randomization journey within a clinical trial. Tracks screening number, subject number, enrollment date, informed consent confirmation, eligibility assessment (inclusion/exclusion criteria verification), screen failure reason, randomization date, randomization code, treatment arm assignment, stratification factors, blinding status, allocation ratio, block size reference, unblinding event details (if applicable), and enrollment/randomization status (screened, screen-failed, enrolled, randomized, withdrawn, completed). Supports ITT, modified ITT, and per-protocol population definitions. Authoritative SSOT for all subject-level randomization data including scheme parameters and individual assignments. Sourced from Medidata Rave RTSM (Randomization and Trial Supply Management) and Oracle CTMS.' .

ind:Visit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Visit' ;
    rdfs:comment 'Transactional record for each scheduled or unscheduled patient visit within a clinical trial, as captured in the EDC (Medidata Rave). Tracks visit number, visit name per protocol schedule of assessments, planned visit date, actual visit date, visit window compliance, visit type (screening, treatment, follow-up, end-of-study), visit status, and deviations noted. Forms the backbone of the clinical data collection timeline.' .

ind:CrfForm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Crf Form' ;
    rdfs:comment 'Master record for each Case Report Form (CRF) design used in a trial, representing the electronic data capture instrument definition in Medidata Rave. Captures form name, form OID, associated visit, data domain (SDTM domain mapping), version, validation rules, completion requirements, and approval status. Distinct from CRF data (captured in subject_observation) — this is the instrument definition, not the collected data.' .

ind:SubjectObservation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Subject Observation' ;
    rdfs:comment 'Core transactional table capturing all clinical data collected per subject per visit per CRF form in the EDC (Medidata Rave). Stores data point value, unit, SDTM variable mapping, collection date, data entry date, query status, source data verification (SDV) status, and audit trail reference. Represents the atomic unit of clinical trial data — the foundation for efficacy and safety endpoint derivation (ORR, PFS, OS, QoL) and CDISC SDTM/ADaM dataset generation.' .

ind:TrialAdverseEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Trial Adverse Event' ;
    rdfs:comment 'Transactional record for each Adverse Event (AE) reported by a subject during a clinical trial, as captured in the EDC and CTMS. Captures AE term (MedDRA coded), onset date, resolution date, severity grade (CTCAE), seriousness flag (SAE), causality assessment, action taken (dose modification, discontinuation), outcome, and SAE/SUSAR reporting status. Distinct from the pharmacovigilance domain\'s ICSR — this is the trial-level AE record feeding into safety reporting workflows.' .

ind:TrialConsent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Trial Consent' ;
    rdfs:comment 'Transactional record capturing each informed consent event for a trial subject, including consent form version, consent date, re-consent date (if protocol amended), subject signature confirmation, legally authorized representative details (if applicable), consent withdrawal date, and IRB/IEC approval reference for the consent version used. Ensures GCP-compliant documentation of subject autonomy and regulatory traceability.' .

ind:InvestigationalProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Investigational Product' ;
    rdfs:comment 'Master record for each investigational medicinal product (IMP) and comparator used in clinical trials, including drug substance name (INN/USAN), formulation, dosage form, strength, route of administration, manufacturer, batch/lot number, expiry date, storage conditions (cold-chain requirements), blinding configuration (matching placebo details), IND/IMPD reference, dispensation tracking (quantity dispensed, return, destruction), and accountability log reference. Distinct from the commercial product catalog (owned by the product domain) — this entity is scoped to GCP-regulated IMP accountability, trial supply management, and regulatory compliance per ICH E6 R2 section 8.' .

ind:TrialEndpoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Trial Endpoint' ;
    rdfs:comment 'Transactional record capturing the formal assessment of primary and secondary clinical endpoints for each subject at defined timepoints. Captures endpoint name (ORR, PFS, OS, QoL, DOR), assessment date, assessment method (RECIST, BICR, investigator assessment), result value, unit, response category, and adjudication committee review status. Feeds directly into efficacy analyses for NDA/BLA/MAA submissions.' .

ind:LabResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Lab Result' ;
    rdfs:comment 'Transactional record for each central or local laboratory test result collected during a clinical trial. Captures lab test name (LOINC coded), specimen type, collection date, result value, unit, reference range, normal/abnormal flag, clinically significant flag, out-of-range flag, and laboratory accreditation reference. Sourced from central lab data transfers into Medidata Rave. Distinct from manufacturing LIMS results — this is trial-specific clinical lab data.' .

ind:TrialMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Trial Milestone' ;
    rdfs:comment 'Transactional record tracking key operational milestones for each clinical trial, including FPFV (First Patient First Visit), LPLV (Last Patient Last Visit), database lock date, CSR completion date, regulatory submission date, and interim analysis dates. Captures planned vs. actual dates, milestone status, responsible function, and variance commentary. Supports portfolio-level trial timeline management and regulatory commitment tracking.' .

ind:Icsr rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Icsr' ;
    rdfs:comment 'Individual Case Safety Report — the primary transactional record in pharmacovigilance. Captures all adverse event/adverse drug reaction reports from healthcare professionals, patients, literature, clinical trials, and spontaneous sources. Stores case identifiers (worldwide unique case ID), report type (spontaneous, literature, clinical trial, solicited, SAE), source channel, seriousness criteria, listedness assessment, causality assessment, narrative, regulatory clock start date, case processing status, and submission compliance. For literature-sourced cases, stores publication reference (PMID/DOI). For clinical trial cases, stores reconciliation status with EDC, dechallenge/rechallenge results, and site details. Includes version history tracking (initial, follow-up, nullification) with full audit trail per ICH E2B and 21 CFR Part 314. Includes de-identified patient demographics (age, sex, weight, medical history) per GDPR/HIPAA. Includes intake triage, minimum criteria validation, duplicate assessment outcome, and case assignment. SSOT for all individual safety cases. Supports regional requirements for FDA (MedWatch), EMA (EudraVigilance), PMDA (J-ICSR), NMPA, and TGA reporting. SLA-critical: 7-day and 15-day regulatory reporting deadlines.' .

ind:PvAdverseReaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Pv Adverse Reaction' ;
    rdfs:comment 'Granular adverse event record linked to an ICSR. Captures the specific event term (MedDRA coded at PT, HLT, HLGT, SOC levels with version tracking), verbatim reporter term, onset date, resolution date, outcome (recovered, not recovered, fatal, unknown), seriousness criteria, severity grade (CTCAE where applicable), and listedness determination against reference safety information. Includes coding metadata: auto-coded vs manual review, coding date. One ICSR may contain multiple adverse events. Supports signal detection aggregation by MedDRA term and regulatory line listing generation.' .

ind:Susar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Susar' ;
    rdfs:comment 'Suspected Unexpected Serious Adverse Reaction record for clinical trial expedited reporting. Captures SUSARs identified from clinical trial ICSRs meeting expedited criteria: unexpected (not in IB/RSI), serious, and at least possibly causally related. Stores parent ICSR reference, trial phase, investigational product, expectedness determination against current IB, causality assessment by sponsor and investigator, 7-day (fatal/life-threatening) or 15-day reporting clock, and submission status to authorities (FDA IND safety report, EMA SUSAR, MHRA, PMDA). SLA-critical: 7-day and 15-day expedited reporting deadlines with criminal liability for non-compliance.' .

ind:SaeReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Sae Report' ;
    rdfs:comment 'Serious Adverse Event report record capturing SAEs from clinical trials, post-market surveillance, and spontaneous sources. Stores SAE classification criteria (death, life-threatening, hospitalization, disability, congenital anomaly, medically important), time to onset, treatment given, dechallenge/rechallenge results, reporter information, site/investigator details, and reconciliation status with clinical trial EDC systems. Tracks the SAE from initial receipt through medical review, causality assessment, and regulatory submission. Supports reconciliation workflows between clinical database and PV safety database per ICH E2D guidance. SLA-critical: initial SAE notification within 24 hours of site awareness.' .

ind:PvSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Pv Submission' ;
    rdfs:comment 'Regulatory submission record for all pharmacovigilance reports submitted to health authorities worldwide. Covers expedited individual case reports (7-day fatal/life-threatening, 15-day serious), periodic aggregate reports (PSUR, PBRER, PADER, DSUR), and ad-hoc safety communications. Stores submission type, target authority, submission date, acknowledgement status, error handling, submission format (E2B R2/R3 XML, eCTD), gateway/portal details, submission reference number, resubmission history, and compliance status. Supports all major regulatory gateways including EudraVigilance (EVWEB/gateway), FAERS (FDA), MHRA Sentinel, PMDA gateway, and NMPA. Tracks authority-specific technical requirements (E2B R3 for EMA, E2B R2 for some national authorities). SLA-critical: regulatory deadline compliance with automatic escalation.' .

ind:Psur rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Psur' ;
    rdfs:comment 'Periodic aggregate safety report master record covering PSUR, PBRER (ICH E2C R2), PADER (FDA), and DSUR (development phase) for each product-indication combination. Captures data lock point, reporting interval, international birth date (IBD), cumulative exposure data, interval and cumulative case summaries, signal summary, benefit-risk evaluation conclusion, and submission status per applicable authority. Tracks preparation milestones, author assignments, medical review, QC, and approval workflow. Supports EU PSUR single assessment (PSUSA) process, FDA PADER requirements, and ICH DSUR for investigational products. Includes structured benefit-risk assessment sections. SLA-critical: fixed regulatory submission deadlines based on IBD.' .

ind:Rmp rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Rmp' ;
    rdfs:comment 'Risk Management Plan master record. Captures RMP version, scope (product, indication, population), safety specification (important identified risks, important potential risks, missing information), pharmacovigilance plan activities (routine and additional), risk minimization measures (routine and additional including REMS for US), effectiveness evaluation plan, and PASS commitments. Tracks RMP approval status per authority (EMA, MHRA) and version history. Supports EU GVP Module V template, FDA REMS requirements, and PMDA RMP format. Links to resulting PV actions and PASS study commitments.' .

ind:SafetySignal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Safety Signal' ;
    rdfs:comment 'Safety signal record representing a new or evolving safety concern identified through signal detection activities. Captures signal source (spontaneous database, literature, clinical trial, real-world data), detection method (disproportionality analysis, clinical review, machine learning), MedDRA-coded term, signal strength metrics (PRR, ROR, EBGM, IC), and signal status lifecycle (new, under evaluation, validated, refuted, closed). Includes formal assessment records: methodology, data sources reviewed, benefit-risk impact evaluation, proposed label change recommendation, regulatory action required, PRAC/PSUR referral status, and final disposition. Each signal supports multiple assessment iterations. Tracks the full signal management workflow from detection through triage, validation, prioritization, assessment, and closure or regulatory action per GVP Module IX. SLA-critical: PRAC rapporteur notification timelines.' .

ind:PvProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Pv Product' ;
    rdfs:comment 'Pharmacovigilance product master — the authoritative PV-domain view of medicinal products under safety surveillance. Captures product name, INN, ATC code, MAH (Marketing Authorization Holder), authorization numbers per country/region, formulation, route of administration, reference safety information document reference, international birth date (IBD), PSMF reference, QPPV assignment, and PV system governance metadata. Distinct from the commercial product catalog — this is the PV-specific product registration used for case processing, signal detection, PSUR scheduling, and regulatory reporting. Includes PSMF-level metadata: PV system description, organizational structure for pharmacovigilance, contracted party references, and compliance status per EU GVP Module II.' .

ind:SuspectDrug rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Suspect Drug' ;
    rdfs:comment 'Suspect and concomitant drug record within an ICSR. Captures drug name (verbatim and WHO Drug Dictionary coded), drug role (suspect, concomitant, interacting), dose, frequency, route, indication, start/stop dates, action taken (drug withdrawn, dose reduced, dose not changed, unknown), dechallenge result, rechallenge result, and batch/lot number. One ICSR may have multiple suspect and concomitant drugs. Enables product-level case aggregation for signal detection, line listing generation, and exposure-based analyses.' .

ind:Reporter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Reporter' ;
    rdfs:comment 'Reporter master data — the individual or organization who submitted an adverse event report. Captures reporter type (healthcare professional, patient/consumer, lawyer, regulatory authority, literature), qualification (physician, pharmacist, nurse, dentist, consumer), country, institution, anonymized reporter identifier (per GDPR/HIPAA), contact preference for follow-up, and reporter reliability assessment. Enables reporter-level case aggregation, duplicate detection, follow-up management, and compliance with ICH E2B reporter data requirements. Distinct from HCP master — this is the PV-specific reporter identity used solely for case processing.' .

ind:PvAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Pv Action' ;
    rdfs:comment 'Pharmacovigilance action record capturing regulatory and safety actions taken in response to validated signals, PSUR findings, RMP updates, or authority requests. Action types include: labeling updates (CCDS, SmPC, USPI changes), DHPC (Dear Healthcare Professional Communication), restricted indication, market suspension/withdrawal, REMS modification, RMP update trigger, and PASS study initiation. Tracks action type, triggering event, responsible party, target completion date, authority notification requirement, implementation evidence, and effectiveness assessment. Links signals, PSURs, and RMPs to their downstream regulatory consequences.' .

ind:PvAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Pv Agreement' ;
    rdfs:comment 'Pharmacovigilance agreement record governing safety data exchange obligations between the MAH and partners. Covers SDEAs (Safety Data Exchange Agreements), PVAs (Pharmacovigilance Agreements), and co-vigilance arrangements with licensees, CROs, CMOs, co-promotion partners, and local affiliates. Captures agreement type, counterparty, effective/expiry dates, reporting timelines (days to exchange), product scope, responsible party designations (PSUR authorship, signal management, regulatory submission), and compliance monitoring status. Required under GVP Module I and ICH E2E for all outsourced PV activities.' .

ind:AccessStrategy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Access Strategy' ;
    rdfs:comment 'Master record defining the market access strategy for a pharmaceutical product in a given geography or payer segment. Captures overarching access objectives, value proposition, target formulary tier, reimbursement pathway, HTA strategy, launch sequencing plan, identified access barriers with severity and remediation actions, key access milestones with planned and actual dates, and milestone status tracking. Serves as the strategic anchor for all downstream access activities including HTA submissions, payer contracting, patient support programs, and systematic access gap management.' .

ind:PayerAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Payer Account' ;
    rdfs:comment 'Master record for payer organizations including commercial health plans, government payers (Medicare, Medicaid, NHS, statutory health insurers), pharmacy benefit managers (PBMs), and group purchasing organizations (GPOs). Captures payer type, tier, covered lives, formulary influence, contracting authority, and geographic coverage. SSOT for payer identity within the market access domain.' .

ind:FormularyPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Formulary Position' ;
    rdfs:comment 'Tracks the formulary placement status of a pharmaceutical product within a specific payer formulary at a point in time. Records formulary tier, prior authorization requirements, step therapy requirements, quantity limits, preferred/non-preferred status, and effective dates. Enables gross-to-net revenue modeling and access gap analysis across payer segments.' .

ind:HtaSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Hta Submission' ;
    rdfs:comment 'Master record for the full lifecycle of Health Technology Assessment (HTA) submissions to bodies such as NICE (UK), HAS (France), G-BA (Germany), CADTH (Canada), and PBAC (Australia). Captures submission planning, dossier preparation, submission date, HTA body, therapeutic indication, comparator, clinical evidence package, economic model type, submission status, and the resulting formal decision including recommendation type (positive, negative, restricted, conditional), benefit rating, added therapeutic benefit classification, recommended price range, and reimbursement conditions. Owns both the submission event and the decision outcome as lifecycle stages of a single HTA engagement. Drives downstream payer contracting and pricing decisions.' .

ind:ValueDossier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Value Dossier' ;
    rdfs:comment 'Master record for the global value dossier (GVD) or payer value dossier developed to support market access negotiations. Captures therapeutic area, target indication, clinical evidence summary, HEOR evidence, comparator landscape, budget impact model reference, and version history. Serves as the evidentiary foundation for HTA submissions and payer negotiations.' .

ind:PayerContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Payer Contract' ;
    rdfs:comment 'Master record for all managed care contracts, rebate agreements, and performance-based contracts negotiated with payers, PBMs (Express Scripts, CVS Caremark, OptumRx), GPOs, and other contracting entities. Captures contract type (base rebate, performance rebate, outcomes-based, value-based, PBM formulary rebate, GPO commitment), contracted product, rebate tiers, performance metrics, administrative fees, data sharing provisions, book-of-business structure, PBM-specific formulary management mechanics, contract term, and payment schedule. Central to gross-to-net revenue management and rebate accrual calculations. Covers all payer types including PBM-specific contract structures.' .

ind:RebateClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Rebate Claim' ;
    rdfs:comment 'Transactional record of rebate claims submitted to or received from payers and PBMs under managed care contracts. Captures claim period, contracted product, eligible units, applicable rebate rate, calculated rebate amount, dispute status, and payment date. Feeds gross-to-net revenue deduction accounting and rebate liability accruals in the finance domain.' .

ind:GrossToNetAdjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Gross To Net Adjustment' ;
    rdfs:comment 'Records all gross-to-net revenue deduction components applied to a pharmaceutical product\'s gross sales to arrive at net revenue. Captures adjustment type (base rebate, performance rebate, Medicaid best price, 340B, chargebacks, copay assistance, GPO fees, distribution fees, patient assistance), period, product, channel, and adjustment amount. For copay assistance adjustments, captures individual claim-level detail including dispensing pharmacy, claim date, patient identifier (de-identified), drug product, gross copay amount, assistance amount paid, and remaining patient liability. Enables net revenue reconciliation, deduction category analysis, copay program spend reporting, and patient affordability program financial tracking. SSOT for all GTN deduction records including copay assistance transactions.' .

ind:CoverageDecision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Coverage Decision' ;
    rdfs:comment 'Records national, regional, or plan-level coverage decisions for a pharmaceutical product by a payer or government health authority. Captures coverage status, covered indication, coverage restrictions, prior authorization criteria, step therapy requirements, and effective date. Distinct from formulary position in that it represents the formal coverage policy determination rather than the formulary tier placement.' .

ind:PatientAccessProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Patient Access Program' ;
    rdfs:comment 'Master record for all patient support, early access, and pre-approval access programs designed to improve access to pharmaceutical products. Covers copay assistance programs, free drug programs, patient assistance programs (PAP), hub services, specialty pharmacy support, named patient programs, compassionate use, expanded access, early access programs (EAP), and managed access agreements. Captures program type, eligibility criteria, benefit cap, funding source, enrollment channel, regulatory authorization reference, supply terms, country, patient population, and program status. Bridges pre-approval access through commercial reimbursement and ongoing affordability support across the full product lifecycle.' .

ind:PricingDecision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Pricing Decision' ;
    rdfs:comment 'Master record for formal pricing decisions, approved price corridors, and international reference pricing (IRP) management for pharmaceutical products across markets and channels. Captures list price (WAC/ex-factory), government reference price, IRP constraints, price change type, effective date, approving authority, pricing rationale, and approved price corridors including floor price, target price, ceiling price, IRP basket countries, monitoring frequency, and corridor breach alert thresholds. Serves as the authoritative record of approved prices and price bands, enabling proactive management of cross-country price erosion risk and launch sequencing optimization.' .

ind:HeorStudy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Heor Study' ;
    rdfs:comment 'Master record for Health Economics and Outcomes Research (HEOR) evidence assets including studies, models, and real-world data (RWD) datasets used to support market access, payer negotiations, and HTA submissions. Captures study type (budget impact model, cost-effectiveness analysis, cost-utility analysis, retrospective RWD study, PRO study, indirect treatment comparison), therapeutic indication, target payer audience, study status, model version, patient population assumptions, comparator costs, time horizon, model outputs, publication reference, and budget impact model-specific attributes (market share assumptions, treatment cost inputs). Also manages the inventory of RWD/RWE datasets including data source type (claims database, EHR, registry, patient-reported outcomes), data vendor, data vintage, and data use agreements. SSOT for all HEOR evidence assets and RWD/RWE inventory within the market access domain.' .

ind:PayerEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Payer Engagement' ;
    rdfs:comment 'Transactional record of formal and informal engagements between the market access team and payer organizations. Captures engagement type (formulary committee meeting, medical policy review, rebate negotiation session, outcomes-based contract discussion, advisory board), payer account, attendees, discussion topics, commitments made, and follow-up actions. Supports payer relationship management and negotiation tracking.' .

ind:ReimbursementPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Reimbursement Policy' ;
    rdfs:comment 'Master record for reimbursement policies and coverage decisions issued by payers, government health authorities, and formulary committees for pharmaceutical products. Captures policy type, coverage status, covered indications, excluded populations, prior authorization criteria, step therapy requirements, quantity limits, coverage restrictions, decision authority, decision date, appeal status, policy effective dates, and individual coverage determination records. Records both the ongoing policy framework governing reimbursement and specific point-in-time coverage decisions at national, regional, or plan level. SSOT for all coverage and reimbursement policy data within the market access domain. Enables access gap analysis, policy change monitoring, coverage landscape tracking, and coverage decision audit trails.' .

ind:GeneralLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'General Ledger' ;
    rdfs:comment 'Central repository for all financial accounting entries across the enterprise, representing the authoritative chart of accounts, account balances, and period-end ledger positions. Captures account master data (account number, account type, account group, currency), period balances (opening, debit totals, credit totals, closing balance by period), company code, profit center allocations, cost center references, and currency translations as sourced from SAP FI module. Serves as SSOT for trial balance, balance sheet, income statement, and SOX-compliant period-end close processes across all legal entities in the pharmaceutical group. Supports consolidation eliminations, multi-GAAP reporting (US GAAP and IFRS), and financial close status tracking. Does NOT own individual postings (owned by journal_entry) — owns aggregate balances and account structure.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Individual accounting transactions posted to the general ledger with full header and line-item detail, including tax-specific postings. Header captures posting date, document type, reference number, fiscal year/period, currency, and posting user. Line items capture GL account, cost center, profit center, debit/credit amounts in transaction and local currency, tax code, tax jurisdiction, taxable base amount, tax amount, withholding tax, assignment field, and line item text. Encompasses all subledger postings (AP, AR, asset, tax) and manual adjustments. Tax postings carry additional attributes: tax jurisdiction, tax return reference, VAT/sales tax/deferred tax classification, and indirect tax reporting period for multi-jurisdiction compliance. Supports audit trails required under SOX and 21 CFR Part 11, financial close processes, and granular P&L analysis by therapeutic area, brand, and geography.' .

ind:InternalOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'SAP CO internal order used to collect, monitor, and settle costs for specific projects, R&D programs, clinical trials, or capital expenditure initiatives. Captures order type (R&D, capex, overhead), settlement rule, budget profile, actual costs, commitment values, responsible cost center, project/WBS reference, and order lifecycle status. References milestone_payment records for contractual obligations but does NOT own milestone payment terms or trigger events. Supports R&D capitalization tracking, ROI analysis for drug development programs, and CAPEX lifecycle governance.' .

ind:AccountsPayable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Accounts Payable' ;
    rdfs:comment 'Vendor invoice, payment obligation, and payment execution records managed within SAP FI-AP module. Captures vendor invoice details (invoice number, date, due date, payment terms, gross amount, tax amount, withholding tax, payment block status), payment execution (payment document, payment date, payment method including ACH/wire/check, bank account, clearing document, payment run ID), and settlement status. Covers payables to CROs, CMOs, CDMOs, raw material suppliers, licensors (royalty and milestone payments), and service providers in the pharmaceutical supply chain.' .

ind:AccountsReceivable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Accounts Receivable' ;
    rdfs:comment 'Customer invoice, collection, payment receipt, and revenue accrual records managed within SAP FI-AR module. Captures customer invoices (billing date, due date, payment terms, gross amount, tax, dunning level), incoming payments (receipt date, payment method, clearing document, bank account), and period-end revenue accruals (accrual type, product, customer segment, territory, accrual basis, recognized vs deferred revenue, recognition date, reversal date). Covers receivables from wholesalers, distributors, hospital networks, and government payers. Supports ASC 606 / IFRS 15 revenue recognition compliance for pharmaceutical product sales.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Annual and multi-year financial budget plans with granular line-item detail by cost center, profit center, GL account, cost element, and internal order. Captures budget version (original, revised, forecast), fiscal year, budget type (opex, capex, R&D), line-item breakdowns with planned amounts by period, currency, budget category, approval workflow status, and variance tracking. Supports P&L planning by therapeutic area, R&D program investment planning, clinical trial budget management, and detailed variance analysis between planned and actual spend for drug development, manufacturing, and commercial operations.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Enterprise fixed asset register with complete lifecycle transaction history managed in SAP FI-AA module, covering manufacturing equipment, laboratory instruments, IT infrastructure, and leasehold improvements. Captures asset master data (asset class, acquisition date, acquisition cost, accumulated depreciation, net book value, depreciation key, useful life, location, cost center assignment) and all lifecycle transactions (acquisitions, retirements, transfers, write-ups, impairments, and periodic depreciation postings with transaction type, posting date, amount, document reference, asset value date, and depreciation area). Supports CAPEX tracking, R&D equipment capitalization, and compliance with IAS 16 / US GAAP ASC 360.' .

ind:RoyaltyAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Royalty Agreement' ;
    rdfs:comment 'Master record and periodic accrual lifecycle for royalty and licensing agreements with external partners, universities, and IP licensors. Captures agreement terms (licensor/licensee, licensed compound, royalty rate structure including tiered rates, territory, effective dates, minimum payments, sublicensing rights, audit rights) and periodic accrual calculations (calculation period, net sales base, applicable rate tier, accrued royalty amount, currency, payment due date, settlement status). Serves as SSOT for royalty accounting obligations, IP cost tracking for in-licensed compounds, and royalty payment reconciliation across the pharmaceutical portfolio.' .

ind:MilestonePayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Milestone Payment' ;
    rdfs:comment 'Tracks contractual milestone-based payment obligations and receipts triggered by development, regulatory, or commercial events in pharmaceutical partnerships. Captures milestone type (e.g., IND filing, Phase II completion, NDA approval, first commercial sale, sales thresholds), triggering event date, contractual payment amount, currency, counterparty, associated internal order, payment status, and accounting treatment. Distinct from internal_order (which collects all costs for a program) — milestone_payment owns the individual contractual obligation record and its trigger-based lifecycle. Critical for R&D partnership financial management and contingent liability disclosure.' .

ind:TransferPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Transfer Price' ;
    rdfs:comment 'Transfer pricing master records governing the prices at which pharmaceutical products, APIs, and services are transacted between related legal entities across jurisdictions. Captures product or service, sending entity, receiving entity, transfer price method (CUP, cost-plus, TNMM), approved price, currency, effective date, and regulatory documentation reference. Supports OECD transfer pricing compliance and tax authority documentation.' .

ind:DemandPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Demand Plan' ;
    rdfs:comment 'Statistical and consensus-based demand forecast for pharmaceutical SKUs across commercial and clinical supply chains. Captures baseline forecast, adjusted forecast, consensus-approved quantities, planning horizon, and demand signals from Kinaxis RapidResponse/Blue Yonder. Tracks forecast version, approval status, planning cycle, and demand classification (commercial, clinical, compassionate use). Serves as the authoritative demand signal for supply planning and inventory positioning.' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Constrained and unconstrained supply plan for drug substance (DS), drug product (DP), and finished dosage form (FDF) across manufacturing sites and CMOs/CDMOs. Captures planned production quantities, planned receipt dates, supply source, planning horizon, capacity constraints, and plan version. Integrates with Kinaxis RapidResponse/Blue Yonder and SAP PP. Tracks plan status (draft, approved, frozen) and supply type (make, buy, transfer).' .

ind:InventoryLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inventory Lot' ;
    rdfs:comment 'Lot/batch-level inventory record for raw materials (APIs, excipients), packaging components, drug substance, drug product, and finished goods held at manufacturing sites, distribution centers, and 3PL locations. Captures lot number, NDC, SKU, material number, quantity on hand, quantity reserved, quantity available, storage location, storage condition (ambient, refrigerated, frozen), expiry date, retest date, lot status (unrestricted, quality hold, quarantine, rejected, released), and GDP compliance flags. SSOT for lot-level inventory traceability.' .

ind:WarehouseReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Warehouse Receipt' ;
    rdfs:comment 'Record of physical receipt of materials at a pharmaceutical manufacturing site, warehouse, or distribution center against a purchase order or inbound delivery. Captures GR document number, posting date, material, lot number, received quantity, storage location, vendor, CoA reference, GDP compliance check status, temperature excursion flag, and quarantine status. Aligns with SAP MM goods receipt (MIGO). Triggers quality inspection and lot creation in LIMS.' .

ind:GoodsIssue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Goods Issue' ;
    rdfs:comment 'Record of material consumption or outbound movement from inventory including issuance to production orders, clinical trial supply kits, sample distribution, destruction, quality testing, or customer delivery. Captures GI document number, posting date, material, lot number, issued quantity, movement type (production consumption, sales delivery, sample, scrap, transfer posting), cost center or order reference, and issuing storage location. Aligns with SAP MM goods issue (MIGO). Reduces inventory on hand and triggers cost accounting entries. Supports GMP batch record material consumption documentation.' .

ind:StockTransferOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Stock Transfer Order' ;
    rdfs:comment 'Inter-site or inter-plant stock transfer order for pharmaceutical materials between manufacturing sites, distribution centers, and 3PL locations. Captures transfer order number, sending plant/storage location, receiving plant/storage location, material, lot number, transfer quantity, transfer type (one-step, two-step), GDP compliance requirements, cold-chain requirements, and transfer status. Aligns with SAP MM/WM stock transfer order management.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Physical movement record and SSOT for all pharmaceutical goods movements including outbound customer deliveries, inter-site stock transfers (one-step and two-step), 3PL movements, and returns. Captures shipment number, origin and destination (plant, DC, 3PL, distributor, wholesaler, hospital, pharmacy, clinical trial site), carrier, mode of transport, transfer type, NDC, lot numbers, shipped quantity, shipment date, estimated/actual delivery date, incoterms, cold-chain requirements (temperature range, monitoring device ID), GDP compliance status, customs/import documentation, and stock transfer processing status. Subsumes stock transfer order functionality — inter-site transfers are modeled as shipments with transfer_type indicating one-step or two-step processing. Aligns with SAP SD shipment management and SAP MM stock transfer processing.' .

ind:DeliveryOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Delivery Order' ;
    rdfs:comment 'Outbound delivery document representing the fulfillment instruction for pharmaceutical finished goods against commercial orders or stock transfer requests. Captures delivery number, delivery type (outbound, returns, stock transfer), ship-to party, delivery date, material, lot number, delivery quantity, picking status, packing status, goods issue status, carrier assignment, and FEFO (First Expiry First Out) compliance flag. Aligns with SAP SD outbound delivery (VL01N). Represents the warehouse execution instruction — distinct from shipment which tracks the physical movement after goods issue.' .

ind:DistributionNetwork rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Distribution Network' ;
    rdfs:comment 'Master record defining the pharmaceutical distribution network topology including manufacturing sites, distribution centers, 3PL nodes, wholesalers, direct-to-pharmacy lanes, and warehouse storage zones with bin/rack/zone configuration. Captures node type, node name, geographic region, GDP authorization status, cold-chain capability (temperature zones: ambient, CRT, 2-8°C, -20°C, -80°C), controlled substance handling authorization, storage capacity, physical warehouse layout, lead times, and network lane definitions. Used for supply network planning in Kinaxis RapidResponse/Blue Yonder and SAP APO/IBP.' .

ind:ClinicalSupplyOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Clinical Supply Order' ;
    rdfs:comment 'Supply order for investigational medicinal products (IMPs), comparators, and ancillary supplies destined for clinical trial sites. Captures IMP material code, protocol number, study site, randomization kit number, ordered quantity, blinding requirements, expiry date, cold-chain requirements, import/export permit references, and order status. Distinct from commercial sales orders due to IND/CTA regulatory requirements, blinding, and randomization constraints.' .

ind:ProductRecall rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Product Recall' ;
    rdfs:comment 'Pharmaceutical product recall event record initiated by regulatory authority mandate or voluntary company action. Captures recall number, recall class (Class I, II, III per FDA), affected NDC, affected lot numbers, recall scope (market, distribution level), recall reason, regulatory agency notification date, press release date, customer notification status, quantity recovered, and recall closure date. Supports lot traceability and regulatory reporting obligations under 21 CFR Part 7.' .

ind:SerializationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Serialization Record' ;
    rdfs:comment 'Unit-level and case-level serialization record for pharmaceutical finished goods compliant with DSCSA (Drug Supply Chain Security Act) and EU FMD (Falsified Medicines Directive) requirements. Captures serial number, GTIN, NDC, lot number, expiry date, aggregation hierarchy (unit→case→pallet), commissioning event, decommissioning event, verification status, and trading partner transaction history. Enables end-to-end track-and-trace across the pharmaceutical supply chain.' .

ind:Brand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Brand' ;
    rdfs:comment 'Master record for each pharmaceutical brand managed by the commercial organization. Captures brand identity, therapeutic area, lifecycle stage (pre-launch, launch, growth, mature, LOE), brand strategy, target patient population, approved indications, ATC classification, INN/USAN, and P&L ownership. Serves as the commercial anchor entity linking all brand-level activities, performance tracking, promotional spend, and market share measurement.' .

ind:Territory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Defines the geographic and organizational sales territories used to structure the field force. Captures territory code, name, geographic boundaries (zip codes, counties, states, regions), territory type (primary, secondary, specialty), alignment version, effective dates, and assigned district and region hierarchy. Used for call planning, target assignment, and performance attribution in Veeva CRM and Salesforce Health Cloud.' .

ind:SalesRep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Sales Rep' ;
    rdfs:comment 'Commercial field force representative master record. Captures rep identity, employee ID, role (territory manager, specialty rep, MSL, KAM), assigned territory, district, region, business unit, hire date, certification status, Veeva CRM user ID, and current employment status. This is the commercial-specific view of the field force with CRM linkage, territory assignment, and credentialing — distinct from the workforce domain employee record which owns HR lifecycle data.' .

ind:HcpTarget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Hcp Target' ;
    rdfs:comment 'Commercial targeting and call planning record linking an HCP (owned by the hcp domain) to a brand, territory, and sales rep for a given targeting/planning cycle. Captures target tier (A/B/C), planned call frequency, call type mix (face-to-face vs. remote), specialty segment, prescribing potential decile, targeting rationale, priority rank, effective period, plan approval status, and targeting status. Drives field force activity scheduling, call planning, and promotional resource allocation in Veeva CRM. Distinct from the HCP master (owned by hcp domain) — this is the commercial segmentation and planning layer.' .

ind:CallActivity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Call Activity' ;
    rdfs:comment 'Transactional record of each field force interaction (detail call) with an HCP or HCO, sourced from Veeva CRM. Captures call date, call type (face-to-face, remote, phone), HCP/HCO visited, products detailed, samples dropped, promotional materials presented, call outcome, next best action, signature captured flag, off-label discussion flag, and PhRMA code compliance status. Core to field force effectiveness measurement and Sunshine Act reporting.' .

ind:SampleManagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Sample Management' ;
    rdfs:comment 'Unified sample management product tracking sample inventory positions, all transaction movements (disbursements, receipts, transfers, adjustments, reconciliations), and PDMA compliance for each sales representative' .

ind:PromoMaterial rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Promo Material' ;
    rdfs:comment 'Master catalog, content lifecycle, and MLR approval workflow for all promotional materials managed in Veeva PromoMats. Captures material ID, title, material type (detail aid, leave-behind, patient brochure, digital asset, journal ad, video), brand, indication, distribution channel, and current approval status. Includes full Medical-Legal-Regulatory (MLR) review workflow tracking: submission date, review cycle number, reviewer assignments (medical, legal, regulatory), individual reviewer decisions, review comments, aggregate approval decision, approval date, expiry date, resubmission history, and version lineage. Ensures compliance with FDA promotional regulations (21 CFR Part 202) and internal PhRMA code. Only MLR-approved materials with valid expiry dates may be used in field force detailing.' .

ind:MlrReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Mlr Review' ;
    rdfs:comment 'Tracks the Medical-Legal-Regulatory (MLR) review and approval workflow for promotional materials and communications. Captures submission date, review cycle number, reviewer roles (medical, legal, regulatory), review status, comments, approval decision, approval date, expiry date, and resubmission history. Ensures compliance with FDA promotional regulations (21 CFR Part 202) and internal PhRMA code adherence.' .

ind:BrandPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Brand Plan' ;
    rdfs:comment 'Annual or multi-year commercial brand plan serving as the unified planning, budgeting, and execution tracking entity for a brand\'s commercial strategy. Captures strategic objectives, positioning, competitive differentiation, promotional mix, channel strategy, and KPI targets. Includes detailed promotional spend tracking by tactic (personal promotion, non-personal, digital, samples, speaker programs, congress) with planned budget, actual spend, variance, cost center, and brand P&L line attribution. Also tracks launch activity milestones for new product/indication launches including activity name, launch phase (pre-launch, launch, post-launch), activity type (field force training, formulary pull-through, KOL engagement, patient support activation), planned/actual dates, owner, status, and dependencies on regulatory approval milestones. Serves as the single commercial planning, financial execution, launch management, and brand P&L entity.' .

ind:KolEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Kol Engagement' ;
    rdfs:comment 'Tracks engagement activities with Key Opinion Leaders (KOLs) by the commercial and medical affairs teams. Captures KOL HCP ID, engagement type (advisory board, speaker training, publication review, congress presentation, consulting), engagement date, brand, therapeutic area, honorarium, compliance approval status, and strategic relationship tier. Distinct from speaker_engagement which is program-specific — this is the longitudinal KOL relationship management record.' .

ind:PatientSupportProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Patient Support Program' ;
    rdfs:comment 'Master record and enrollment ledger for patient support programs (PSPs). Program header captures program name, brand, program type (co-pay assistance, free drug, nurse navigator, adherence program, hub services), eligibility criteria, administering vendor, program KPIs, and vendor performance metrics. Enrollment detail captures individual patient enrollments including enrollment date, prescribing HCP, enrollment channel, eligibility verification status, benefit type granted (co-pay card, free drug voucher, nurse call), enrollment status, program exit reason, and adherence milestones. Supports access and adherence analytics, program ROI measurement, patient journey optimization, hub services vendor performance tracking, and HIPAA-compliant de-identified reporting.' .

ind:PspEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Psp Enrollment' ;
    rdfs:comment 'Transactional record of a patient\'s enrollment in a patient support program. Captures enrollment date, program ID, patient reference (anonymized or de-identified per HIPAA), prescribing HCP, enrollment channel, eligibility verification status, benefit type granted (co-pay card, free drug voucher, nurse call), enrollment status, and program exit reason. Supports access and adherence analytics and program ROI measurement.' .

ind:ContractAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Contract Account' ;
    rdfs:comment 'Commercial contract account master for institutional customers including hospital systems, IDNs (Integrated Delivery Networks), GPOs (Group Purchasing Organizations), specialty pharmacies, and retail pharmacy chains. Captures account name, account type, GPO affiliation, contract tier, account manager assignment, strategic classification, and key contact information. Supports institutional selling, account-based marketing, and field force account coverage planning. Distinct from hcp domain (individual practitioners) and market domain (payer contracts).' .

ind:SalesPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Sales Performance' ;
    rdfs:comment 'Periodic (weekly/monthly/quarterly) sales performance record at the territory and rep level by brand. Captures period, territory ID, rep ID, brand, total prescriptions (TRx), new prescriptions (NRx), market share, call frequency achieved vs. target, sample drop rate, and attainment vs. quota. Sourced from CRM and Rx data integration. Supports incentive compensation calculation and field force management.' .

ind:CopayProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Copay Program' ;
    rdfs:comment 'Master record and transactional redemption ledger for co-pay assistance and patient affordability programs. Program header captures program name, brand, program type (co-pay card, voucher, free trial), maximum annual benefit, eligibility rules, administering hub vendor, program status, and 340B exclusion rules. Redemption detail captures each individual co-pay card or voucher redemption including redemption date, pharmacy NPI, product NDC, patient out-of-pocket amount, manufacturer contribution, payer adjudication status, claim reference, and gross-to-net impact. Supports patient access strategy, program utilization analytics, brand P&L gross-to-net deduction reporting, and 340B program exclusion tracking.' .

ind:CopayRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Copay Redemption' ;
    rdfs:comment 'Transactional record of each co-pay card or voucher redemption by a patient at a pharmacy. Captures redemption date, program ID, product NDC, pharmacy NPI, patient out-of-pocket amount, manufacturer contribution amount, payer adjudication status, and gross-to-net impact. Feeds into brand P&L gross-to-net deduction reporting and program utilization tracking.' .

ind:MedicinalProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Medicinal Product' ;
    rdfs:comment 'Core master entity representing an authorized or investigational medicinal product (branded drug, generic, biosimilar, vaccine, or consumer health product). Captures INN/USAN, brand name, ATC classification code, mechanism of action (MOA), therapeutic area, product type (NCE, NBE, biosimilar, vaccine, OTC), development stage, lifecycle status, and for biosimilar products: reference biologic product linkage (reference_product_id, originator BLA/MAA number, interchangeability designation, extrapolation status, analytical similarity assessment outcome). Aligned with ISO IDMP Medicinal Product concept. Serves as the top-level node in the pharmaceutical product hierarchy (medicinal product → drug product → SKU) referenced by manufacturing, commercial, regulatory, and supply chain domains.' .

ind:DrugSubstance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Drug Substance' ;
    rdfs:comment 'Master record for the active pharmaceutical ingredient (API) or drug substance (DS) as defined in ICH Q7. Captures chemical name, molecular formula, molecular weight, CAS registry number, INN/USAN designation, pharmacopoeial monograph reference (USP/EP/JP), physical form, stereochemistry, polymorphic form, salt form, particle size specification, ADME profile summary, BCS classification, and regulatory Drug Master File (DMF) reference number. Represents the DS layer in the DS/DP hierarchy and is the single source of truth for API chemical identity referenced by manufacturing, quality, regulatory, and formulation records.' .

ind:DrugProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Drug Product' ;
    rdfs:comment 'Master record for the finished drug product (DP) or finished dosage form (FDF) derived from one or more drug substances. Captures dosage form (tablet, capsule, injection, etc.), route of administration, strength, formulation type, reference listed drug (RLD) linkage, shelf life, storage conditions, and CMC summary. Bridges the DS/DP hierarchy and is referenced by manufacturing batch records, regulatory submissions, and commercial SKUs.' .

ind:Formulation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Formulation' ;
    rdfs:comment 'Detailed formulation record specifying the qualitative and quantitative composition (Q1/Q2) of a drug product, including all active and inactive ingredients, their pharmacopoeial grades, functional roles, and quantities per unit dose and per batch. Tracks formulation version history, Quality by Design (QbD) design space parameters, critical process parameters (CPP), and critical quality attributes (CQA). Supports CMC Module 3 documentation, scale-up, and technology transfer.' .

ind:FormulationIngredient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Formulation Ingredient' ;
    rdfs:comment 'Line-level record within a formulation capturing each individual ingredient (API or excipient), its INN or INCI name, pharmacopoeial grade, function (binder, filler, preservative, etc.), quantity per unit dose, quantity per batch, and overages. Enables full bill-of-materials traceability for regulatory submissions and manufacturing execution.' .

ind:PackagingConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Master record for the packaging configuration of a drug product, defining primary container (vial, blister, bottle), secondary packaging (carton, wallet), and tertiary/shipper packaging. Captures container closure system (CCS) specifications, pack size, fill volume, headspace, cold-chain requirements (2-8°C, -20°C, -80°C), and serialization/aggregation hierarchy for track-and-trace compliance (DSCSA, EU FMD). Referenced by supply chain, manufacturing, and commercial domains for SKU definition.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock Keeping Unit (SKU) master record representing the commercially sellable unit of a drug product at a specific strength, dosage form, and packaging configuration. Captures GTIN/EAN barcode, SAP material number, trade name, market (country/region), launch date, discontinuation date, commercial status (active, discontinued, withdrawn), and channel designation (retail, hospital, specialty pharmacy). Serves as the SSOT for commercial product identity referenced by supply chain, commercial, and finance domains. NDC codes for US-market SKUs are managed via regulatory_identifier.' .

ind:ProductNdcCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Ndc Code' ;
    rdfs:comment 'National Drug Code (NDC) registry record for each FDA-listed drug product. Captures the 10-digit NDC number (labeler, product, package segments), FDA listing status, listing date, application number linkage (NDA/ANDA/BLA), proprietary name, non-proprietary name, and DEA schedule. Serves as the authoritative NDC-to-product mapping for regulatory compliance, dispensing, and reimbursement.' .

ind:Lifecycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Lifecycle' ;
    rdfs:comment 'Tracks the lifecycle stage and status transitions of a medicinal product from discovery through post-market, including pipeline stage (discovery, preclinical, Phase I/II/III, NDA/BLA submission, approved, launched, LOE, discontinued). Captures stage entry date, exit date, milestone events, responsible team, and lifecycle gate criteria. Provides the authoritative product lifecycle timeline referenced by portfolio planning and regulatory domains.' .

ind:RegulatoryIdentifier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Regulatory Identifier' ;
    rdfs:comment 'Unified catalog of regulatory product identifiers and listing codes assigned by health authorities across all jurisdictions. Captures NDA, ANDA, BLA, MAA, JNDA, EMA product numbers, PMDA approval numbers, NMPA registration numbers, and National Drug Codes (NDC — 10-digit labeler-product-package segments with FDA listing status, listing date, application number linkage, proprietary/non-proprietary names, and DEA schedule). Records identifier type, issuing authority, application number, approval date, approval status, jurisdiction, and listing metadata. Serves as the single source of truth for cross-jurisdiction regulatory identity, product listing, and dispensing/reimbursement code mapping for each drug product.' .

ind:Indication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Indication' ;
    rdfs:comment 'Association record linking a medicinal product to its approved or investigational therapeutic indications, capturing indication name, MedDRA preferred term, ICD-10 code, approval status by jurisdiction, approval date, patient population (adult, pediatric, geriatric), line of therapy, and label claim text. Tracks both approved and pipeline indications to support regulatory, medical affairs, and commercial strategies.' .

ind:Labeling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Labeling' ;
    rdfs:comment 'Master record for the approved product label (prescribing information / SmPC / package insert) for each drug product by jurisdiction. Captures label version, effective date, label type (USPI, SmPC, PIL), regulatory approval reference, black box warning flag, REMS requirement flag, controlled substance schedule, and key label sections (indications, dosing, contraindications, warnings). Supports pharmacovigilance, medical affairs, and regulatory compliance.' .

ind:CombinationProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Combination Product' ;
    rdfs:comment 'Master record for combination products that combine a drug with a device, biologic, or another drug (e.g., auto-injectors, prefilled syringes, inhalers, transdermal patches, drug-eluting stents). Captures combination type (drug-device, drug-biologic, drug-drug-device), constituent parts with their respective regulatory classifications, primary mode of action (PMOA), lead center designation (CDER/CDRH/CBER), combination product agreement number, device constituent specifications (design history file reference, human factors study status), and cross-labeling requirements. Supports 21 CFR Part 4 compliance, regulatory strategy, and CMC documentation.' .

ind:Master rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Master' ;
    rdfs:comment 'Master record for individual healthcare professionals (HCPs) including physicians, pharmacists, nurses, and other licensed practitioners. Captures HCP identity (name, date of birth, gender), NPI number, professional credentials, all state medical licenses (license number, issuing authority, jurisdiction, issue/expiration dates, status, renewal history), DEA controlled substance registrations, board certifications, specialty classifications (primary/secondary, ATC/therapeutic area alignment), professional designations, practice addresses, and contact information. Authoritative single source of truth (SSOT) for HCP identity, credentials, licensing, and practice locations used across commercial, medical affairs, and clinical operations. Sourced from Veeva CRM, Salesforce Health Cloud, and third-party data providers (IQVIA OneKey, NPI Registry).' .

ind:HcoMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Hco Master' ;
    rdfs:comment 'Master record for healthcare organizations (HCOs) including hospitals, clinics, pharmacies, integrated delivery networks (IDNs), group purchasing organizations (GPOs), and academic medical centers. Captures organization name, type, accreditation status, NPI, DEA registration, bed count, magnet status, teaching hospital designation, and geographic footprint. SSOT for institutional identity used in commercial targeting and medical affairs.' .

ind:License rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'License' ;
    rdfs:comment 'Professional licenses and credentials held by each HCP, including state medical licenses, DEA controlled substance registrations, board certifications, and specialty credentials. Tracks license number, issuing authority, state/jurisdiction, issue date, expiration date, license status (active, suspended, revoked), and renewal history. Critical for compliance validation before any promotional or medical engagement.' .

ind:Affiliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Affiliation' ;
    rdfs:comment 'Relationship records linking HCPs to healthcare organizations (HCOs) and to other HCPs, capturing employment, admitting privileges, group practice membership, and referral relationships. Tracks affiliation type (employee, contractor, admitting, consulting), role, start and end dates, primary affiliation flag, and affiliation strength. Essential for account-based selling, network mapping, and understanding prescribing influence hierarchies.' .

ind:KolProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Kol Profile' ;
    rdfs:comment 'Key Opinion Leader (KOL) profile extending the base HCP record with scientific influence metrics, publication history, clinical trial investigator status, advisory board participation, congress speaking history, and KOL tier classification (national, regional, local). Tracks h-index, citation count, therapeutic area expertise, and KOL engagement strategy. Used by medical affairs for publication planning, advisory boards, and MSL targeting.' .

ind:Engagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Engagement' ;
    rdfs:comment 'Records of all interactions between field personnel (sales representatives, MSLs, medical affairs) and HCPs or HCOs. Captures engagement type (detail visit, lunch-and-learn, congress meeting, advisory board, medical information request), channel (face-to-face, virtual, phone), date, duration, products discussed, materials shared, and outcome. Primary transactional record for HCP engagement history. Sourced from Veeva CRM.' .

ind:SampleRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Sample Request' ;
    rdfs:comment 'Drug sample requests and fulfillment records for HCPs under the Prescription Drug Marketing Act (PDMA) and FDA sample accountability requirements. Captures sample product, lot number, quantity requested, quantity dispensed, HCP signature, DEA number validation, sample drop date, and representative ID. Tracks sample inventory reconciliation and compliance with 21 CFR Part 203. Sourced from Veeva CRM sample management module.' .

ind:ConsentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Consent Record' ;
    rdfs:comment 'Unified consent, opt-in/opt-out, do-not-contact (DNC), and no-see records governing all permissible and restricted communication with HCPs. Single source of truth for contact permissions and restrictions across all channels. Captures consent grants (promotional, medical, digital, email, phone), consent withdrawals, DNC requests, no-see restrictions, compliance-driven contact restrictions, legal holds, and channel-specific limitations. Tracks consent date, withdrawal date, restriction type, restriction reason, regulatory basis (GDPR, HIPAA, CCPA, state law), expiration, and enforcement status. Enforced across all field engagement systems including Veeva CRM, email platforms, and digital channels. Replaces any separate DNC or no-see lists as the single authoritative source.' .

ind:SunshineTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Sunshine Transfer' ;
    rdfs:comment 'Open Payments (Sunshine Act) reportable transfers of value from the pharmaceutical company to HCPs and HCOs, as required under 42 CFR Part 403. Captures payment type (consulting fee, speaker honorarium, meal, travel, research grant, royalty), amount, currency, date, product association, nature of payment, and CMS reporting status. Supports annual CMS Open Payments submission and anti-kickback compliance monitoring.' .

ind:SpeakerProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Speaker Program' ;
    rdfs:comment 'Speaker bureau management and individual speaker program event records covering the full speaker lifecycle. Manages HCP enrollment in speaker bureau (speaker tier, therapeutic area, approved products, training completion, certification status, contract terms, honorarium rate, compliance certification), and individual program events (date, venue, format, audience size, spend, compliance approval, materials used). Tracks speaker training completion, programs delivered, speaker performance metrics, and generates Sunshine Act reportable transfers of value. Supports anti-kickback compliance monitoring for speaker fees and honoraria. Single source of truth for all speaker-related data. Managed in Veeva CRM.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Contracts, agreements, and associated fair market value (FMV) rate cards between the pharmaceutical company and HCPs for services including consulting, advisory boards, speaker programs, clinical research, and medical education. Captures contract type, effective dates, scope of services, FMV rate ranges by specialty/service/region, FMV methodology, hourly rate min/max, annual caps, honorarium rate, payment terms, compliance approval status, legal review status, and debarment/exclusion screening results (OIG, GSA SAM, FDA Debarment List checks). Supports anti-kickback compliance validation (ensuring compensation within FMV bounds), exclusion screening before financial transfers, and Sunshine Act reporting for all contracted HCP payments.' .

ind:Investigator rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hcp ;
    rdfs:label 'Investigator' ;
    rdfs:comment 'Clinical trial investigator records for HCPs serving as principal investigators (PIs) or sub-investigators on company-sponsored or investigator-initiated trials. Captures investigator role, GCP training status, CV on file, financial disclosure (Form FDA 3455), IRB approval status, site affiliation, therapeutic area expertise, enrollment performance metrics, and trial participation history. Provides the HCP-domain view of investigator identity and qualifications; clinical trial operational data (protocol, enrollment, visits) resides in the clinical domain. Supports regulatory submissions (Form FDA 1572) and clinical operations planning.' .

ind:ProductionOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Order' ;
    rdfs:comment 'Core manufacturing execution record representing a discrete production order for drug substance (DS), drug product (DP), or packaging/labeling operations. Captures order type (process order, production order, packaging order), planned/actual quantities, scheduled and actual start/finish dates, production facility, manufacturing line, order status (created, released, confirmed, technically complete), priority, batch size, unit of measure, material/SKU, NDC code (for packaging), reconciliation data, and linkage to master batch record. Central transactional entity for all manufacturing execution aligned with SAP PP module.' .

ind:BatchRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Batch Record' ;
    rdfs:comment 'Electronic batch record (eBR) representing the complete manufacturing history of a specific batch of drug substance or drug product, as required under 21 CFR Parts 210/211 and cGMP. Captures batch number, product code, batch size, manufacturing date, expiry date, retest date, manufacturing site, batch status (in-process, released, rejected, quarantine), master batch record reference, yield data (theoretical vs actual, yield percentage, reconciliation status), disposition decision (release/reject with approver and rationale), material consumption actuals, parent/child batch genealogy links, and campaign reference. Serves as the primary cGMP compliance document and SSOT for batch lifecycle from production through disposition. Sourced from MES and SAP PP/QM.' .

ind:MasterBatchRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Master Batch Record' ;
    rdfs:comment 'The approved master batch record (MBR) template defining the standard manufacturing instructions, formulation, process steps, critical process parameters (CPPs) with target values and acceptance criteria, critical quality attributes (CQAs), in-process control specifications, equipment requirements, and expected yields for a specific product and batch size. Represents the recipe or master formula from which individual batch records are generated. Tracks version number, approval status, effective date, superseded date, product code, dosage form, batch size range, and regulatory approval linkage. Serves as the SSOT for all parameter specifications — parameter names, types, target values, control limits (upper/lower), specification limits, and acceptance criteria. Actual measured values during execution are recorded in process_parameter_result, not here. Managed in Veeva Vault QualityDocs or MasterControl.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Site' ;
    rdfs:comment 'Master data for physical manufacturing facilities including owned sites and CMO/CDMO contract sites. Captures site name, site code, address, country, site type (API manufacturing, formulation, fill-finish, packaging, combination), GMP certification status, regulatory approval status (FDA, EMA, PMDA registered), site capacity, site owner (internal vs CMO/CDMO), ERP plant code, and operational status. Serves as the SSOT for manufacturing location master data within the manufacturing domain.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Line' ;
    rdfs:comment 'Master data for individual production lines, suites, or manufacturing units within a site. Captures line code, line name, line type (granulation, blending, compression, coating, filling, lyophilization, packaging), associated site, capacity (units/hour or kg/batch), equipment train composition, cleanroom classification, validated status, current operational status (available, in-use, under maintenance, decommissioned), and qualification expiry date. Enables production scheduling and capacity planning at the line level.' .

ind:Equipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Equipment' ;
    rdfs:comment 'Master data for manufacturing equipment assets including reactors, blenders, granulators, tablet presses, filling machines, lyophilizers, autoclaves, and packaging lines. Captures equipment ID (tag number), equipment name, equipment type, manufacturer, model, serial number, installation date, qualification status (IQ/OQ/PQ), next qualification due date, calibration status, next calibration due date, associated manufacturing line and site, current status (operational, under maintenance, quarantined, decommissioned), and SAP PM equipment number. Supports equipment scheduling and GMP compliance.' .

ind:EquipmentQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Equipment Qualification' ;
    rdfs:comment 'Records of equipment qualification activities including Installation Qualification (IQ), Operational Qualification (OQ), and Performance Qualification (PQ) as required under cGMP and 21 CFR Part 211. Captures qualification type, equipment reference, qualification protocol number, execution date, qualification outcome (pass/fail), next requalification date, approver, and associated validation report reference. Tracks the qualification lifecycle for each piece of equipment to ensure GMP compliance and readiness for production use.' .

ind:ProductionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Schedule' ;
    rdfs:comment 'Planned production schedule for manufacturing lines and sites over a defined planning horizon. Captures schedule version, planning period (start/end date), site, manufacturing line, scheduled production orders, planned batch quantities, scheduled downtime windows, campaign plan, and schedule status (draft, approved, frozen, executed). Integrates with SAP PP capacity planning and Kinaxis RapidResponse supply chain planning. Enables capacity utilization analysis and production campaign management.' .

ind:ProcessParameter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Process Parameter' ;
    rdfs:comment 'Defines and records Critical Process Parameters (CPPs) and non-critical process parameters for manufacturing processes, including both the specification (target values, control limits, specification limits) from the master batch record and the actual measured values recorded during batch execution from MES, PAT instruments, or manual entry. Captures parameter name, type (CPP vs non-critical), process step, target value, control/specification limits, unit of measure, measurement frequency, PAT indicator, and per-batch actual measurements with timestamps, instrument IDs, and pass/fail status. Supports QbD principles, process validation, CPV trending, and regulatory inspection readiness per ICH Q8/Q9/Q10.' .

ind:ProcessParameterResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Process Parameter Result' ;
    rdfs:comment 'Actual measured values of critical process parameters (CPPs), non-critical process parameters, and in-process control (IPC) results recorded during batch manufacturing execution. Captured from MES, PAT instruments, SCADA systems, or manual entry in the electronic batch record. Captures batch reference, process step, parameter name, parameter type (CPP, non-critical, IPC), measured value, unit of measure, measurement timestamp, measurement method, instrument ID, operator ID, pass/fail evaluation against specification limits defined in the master batch record, deviation flag, and PAT indicator. This entity is the sole SSOT for all in-process parameter measurements — parameter specifications (targets, control limits, acceptance criteria) are owned by master_batch_record while this entity owns all actuals. Provides the complete CPP/CQA data trail for each batch, supporting QbD principles, process validation (Stage 2/3), continued process verification (CPV) trending, statistical process control, and regulatory inspection readiness per ICH Q8/Q9/Q10 and 21 CFR 211.188.' .

ind:ManufacturingDeviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Manufacturing Deviation' ;
    rdfs:comment 'Records unplanned departures from approved manufacturing procedures, specifications, or batch records during production. Captures deviation number, batch reference, deviation type (process, equipment, material, environmental, documentation), description, severity (critical, major, minor), detection date, detection phase (in-process, packaging, QC testing), root cause category, immediate containment actions, impact assessment, CAPA reference, closure date, and regulatory reportability flag. Integrates with MasterControl/TrackWise QMS. Distinct from quality CAPA records owned by the quality domain.' .

ind:BillOfMaterials rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Bill Of Materials' ;
    rdfs:comment 'Manufacturing bill of materials (BOM) defining the complete list of raw materials, APIs, excipients, and packaging components required to produce a specific drug product at a defined batch size, including individual component line items. Captures BOM version, product code, batch size, BOM status (active, superseded), and for each component: sequence number, item code, description, category (DS, excipient, solvent, packaging, label), required quantity, unit of measure, overage allowance, substitution flag, GMP grade requirement, and approved supplier reference. Aligned with SAP PP BOM and master batch record formulation. Supports MRP calculations, material traceability, and procurement.' .

ind:ProcessValidation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Process Validation' ;
    rdfs:comment 'Records of process validation studies conducted to demonstrate that a manufacturing process consistently produces a product meeting its predetermined specifications and quality attributes, per FDA Process Validation Guidance (2011) and ICH Q8/Q10. Covers all validation types including process validation (Stages 1-3), cleaning validation (dirty hold time, clean hold time, swab/rinse recovery), and computer system validation (CSV/CSA for MES, SCADA, LIMS). Captures validation protocol number, product, process step or system, validation stage (Stage 1 prospective, Stage 2 process qualification, Stage 3 continued process verification), validation type (process, cleaning, computerized system, analytical method transfer), number of validation batches or runs, acceptance criteria, validation outcome (pass/fail/conditional), approval date, revalidation triggers, and next periodic review date. Supports lifecycle approach to validation per ICH Q12.' .

ind:EnvironmentalMonitoring rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Environmental Monitoring' ;
    rdfs:comment 'Records of environmental monitoring (EM) results for cleanrooms and controlled manufacturing areas, capturing microbial and particulate data as required under cGMP for sterile and non-sterile manufacturing. Captures monitoring location, cleanroom classification (ISO 5/6/7/8, Grade A/B/C/D), monitoring type (viable air, surface, personnel, non-viable particulate), sample date/time, organism identified, colony forming units (CFU), action limit, alert limit, pass/fail status, and trend flag. Supports contamination control strategy per Annex 1 (EMA) and 21 CFR 211.42.' .

ind:Capa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Capa' ;
    rdfs:comment 'Corrective and Preventive Action records managing the full CAPA lifecycle from initiation through effectiveness verification. Captures root cause analysis methodology (5-Why, Fishbone, FMEA), assigned owner, due dates, action plan details, regulatory commitment flag, effectiveness check criteria, closure status, and linkage to originating QMS events. Integrates with MasterControl/TrackWise CAPA module and SAP QM.' .

ind:QualityDeviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Quality Deviation' ;
    rdfs:comment 'Planned and unplanned deviation records capturing departures from approved procedures, specifications, or GMP requirements during manufacturing, laboratory, or clinical operations. Tracks deviation category (planned/unplanned), GMP impact classification, affected batch/lot, process step, immediate containment actions, disposition recommendation, regulatory notification requirement, and linkage to CAPA. Sourced from SAP QM and TrackWise.' .

ind:OosInvestigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Oos Investigation' ;
    rdfs:comment 'Out-of-Specification (OOS) investigation records for laboratory test results that fall outside established acceptance criteria. Captures Phase I (laboratory investigation) and Phase II (full-scale investigation) findings, assignability determination, retesting authorization, invalidation justification, final disposition, regulatory reporting obligation, and linkage to affected batch and test result. Governed by FDA OOS guidance and 21 CFR 211.192.' .

ind:ChangeControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Change Control' ;
    rdfs:comment 'Change control records managing all proposed changes to processes, equipment, materials, facilities, systems, and documents under GMP. Captures change type (minor/major/critical), change rationale, risk assessment, regulatory impact assessment (requires prior approval vs. notification), validation/qualification requirements, implementation plan, affected products and markets, approval workflow status, and post-implementation review. Sourced from MasterControl/TrackWise and SAP QM.' .

ind:Audit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Audit' ;
    rdfs:comment 'Master record for quality audits and regulatory inspections including internal GMP audits, supplier/CMO qualification audits, and regulatory agency inspections (FDA PAI, EMA GMP, MHRA). Captures audit type, scope, lead auditor, audit team, site/facility audited, audit dates, pre-audit preparation status, audit agenda, overall audit outcome, and individual findings with classification (critical/major/minor/observation), cited regulation, response commitments, response due dates, and closure verification. Integrates with MasterControl and Veeva Vault QualityDocs.' .

ind:LabTestResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Lab Test Result' ;
    rdfs:comment 'Laboratory quality control test results from LIMS (LabWare/SampleManager) capturing analytical testing of raw materials, in-process samples, drug substance, drug product, and stability samples. Records test method, instrument used, analyst, test date, raw result value, unit of measure, specification limit (lower/upper), pass/fail determination, OOS/OOT flag, reviewed/approved status, and CoA inclusion flag. Primary source for OOS and OOT investigations.' .

ind:StabilityStudy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Stability Study' ;
    rdfs:comment 'Stability study records managing ICH-compliant long-term, accelerated, intermediate, and stress stability programs including study design, scheduling, and individual time-point test results. Captures study protocol number, ICH storage conditions (25°C/60%RH, 30°C/65%RH, 40°C/75%RH), container-closure system, study type (registration, commitment, ongoing, photostability), pull-point schedule with actual pull dates, individual test results per time point (assay, degradation products, dissolution, appearance, pH, viscosity), result values against specification limits, pass/fail status, OOT flags, statistical trend analysis, shelf-life determination, and regulatory submission reference. Governed by ICH Q1A-Q1F and WHO stability guidelines. Sourced from LIMS stability module.' .

ind:MethodValidation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Method Validation' ;
    rdfs:comment 'Analytical method validation records demonstrating that a test method is fit for its intended purpose per ICH Q2(R1). Captures method type (assay, identification, impurity, dissolution), validation parameters assessed (specificity, linearity, accuracy, precision, LOD, LOQ, robustness), validation protocol number, validation report reference, regulatory submission inclusion flag, method transfer status, and compendial method flag. Sourced from LIMS and Veeva Vault.' .

ind:Coa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Coa' ;
    rdfs:comment 'Certificate of Analysis (CoA) records issued for released batches of drug substance, drug product, excipients, and raw materials. Captures CoA number, issuing site, product name, batch/lot number, manufacturing date, expiry date, test parameters with results and specifications, overall release decision, authorized signatory, customer/recipient, and regulatory market applicability. Integrates with SAP QM and LIMS for automated CoA generation.' .

ind:BatchDisposition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Batch Disposition' ;
    rdfs:comment 'Batch release and disposition decision records capturing the formal quality unit decision to release, reject, reprocess, rework, or retest a manufactured batch per 21 CFR 211.22 and EU GMP Annex 16. Records disposition type, Qualified Person (QP) or quality unit approver, disposition date, disposition rationale, regulatory hold flag, market applicability (US, EU, JP, ROW), quarantine status, and linkage to batch record, CoA, and any open deviations or OOS investigations that must be resolved prior to release. Sourced from SAP QM.' .

ind:Complaint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Complaint' ;
    rdfs:comment 'Product quality complaint records from healthcare professionals, patients, distributors, and regulatory agencies regarding marketed pharmaceutical products. Captures complaint source, category (efficacy, safety, quality defect, packaging/labeling), affected product and lot number, market of origin, initial risk assessment, investigation findings, root cause, regulatory reportability determination (MedWatch, MHRA Yellow Card), corrective action taken, response communication, trend flag, and closure status. Integrates with pharmacovigilance domain for safety-related complaints and SAP QM for quality complaints. Sourced from TrackWise/Veeva Vault.' .

ind:Validation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Validation' ;
    rdfs:comment 'Unified validation records managing the complete lifecycle of process, equipment, cleaning, and computer system validation under GMP — from protocol definition through execution to final report. Captures validation type (IQ/OQ/PQ, process validation stages 1-3, cleaning validation, CSV/21 CFR Part 11), protocol number, acceptance criteria, validation team, execution dates, individual test step results, deviations observed during execution, overall outcome (pass/fail/conditional), validation report reference, and linkage to change control. Supports continued process verification (CPV) as a validation type. Governed by ICH Q8/Q9/Q10, EMA Annex 15, FDA Process Validation Guidance, and GAMP 5. Sourced from MasterControl/Kneat and SAP QM.' .

ind:Specification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Specification' ;
    rdfs:comment 'Product and material quality specification records defining acceptance criteria for drug substances, drug products, raw materials, excipients, packaging components, and in-process controls. Captures specification type (release, shelf-life, in-process), test parameter, acceptance criterion (numeric limit or qualitative), analytical method reference, pharmacopoeial standard (USP, EP, JP), specification version, effective date, and regulatory approval status. Sourced from SAP QM and LIMS.' .

ind:SupplierQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Supplier Qualification' ;
    rdfs:comment 'Quality qualification, agreement, and ongoing oversight records for approved suppliers, CMOs, CDMOs, and CROs providing materials or services under GMP. Captures supplier qualification status (approved/conditional/disqualified), qualification type (audit-based, questionnaire, CoA review), approved material/service scope, quality agreement details (GMP responsibilities matrix, regulatory market coverage, agreement type, effective/expiry dates, review cycle, counterparty obligations), re-qualification schedule, risk tier classification, performance metrics, and approval workflow. Serves as the single quality record for supplier relationships — distinct from procurement vendor master. Sourced from MasterControl/TrackWise and Veeva Vault QualityDocs.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master record for all legal entities within the pharmaceutical enterprise including subsidiaries, affiliates, joint ventures, and holding companies. Captures legal name, registration number, jurisdiction of incorporation, entity type (operating company, holding, JV), tax identification numbers, registered address, functional currency, consolidation group, and SAP company code mapping. Serves as the organizational backbone for financial consolidation, regulatory submissions, and cross-system entity resolution.' .

ind:OrgUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Org Unit' ;
    rdfs:comment 'Master record for organizational units within the enterprise hierarchy including business units, divisions, departments, and functional groups. Captures unit name, unit type (business unit, division, department, function, team), parent unit reference for hierarchy traversal, effective dates, responsible manager, geographic location, headcount, and SAP organizational element mapping. Supports HR organizational structure, operational reporting hierarchies, and management accountability across SAP S/4HANA, Veeva, and LIMS.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Master record for SAP cost centers used in management accounting and financial controlling. Captures cost center code, description, cost center category (production, administration, R&D, sales), responsible person, valid-from and valid-to dates, controlling area, profit center assignment, and functional area classification. Serves as the primary financial dimension for cost allocation across manufacturing, clinical, and R&D operations.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Master record for SAP profit centers representing autonomous business segments for internal profitability reporting. Captures profit center code, name, hierarchy node, responsible manager, segment classification (therapeutic area, product line, geography), controlling area, and dummy profit center flag. Enables P&L reporting by therapeutic area (oncology, immunology, rare diseases) and product portfolio.' .

ind:ChartOfAccounts rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Master record defining all general ledger account codes used across the pharmaceutical enterprise. Captures GL account number, description, account type (asset, liability, equity, revenue, expense), account group, P&L vs balance sheet classification, tax category, reconciliation account indicator, IFRS/US-GAAP mapping, R&D capitalization eligibility flag, and controlling integration settings. Governs financial reporting consistency across all company codes, enabling compliant reporting under multiple accounting standards and supporting pharma-specific accounting requirements (R&D expense vs capitalization, milestone revenue recognition, royalty accruals).' .

ind:Material rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Material' ;
    rdfs:comment 'Central master record for all materials managed within the pharmaceutical enterprise including APIs (Active Pharmaceutical Ingredients), excipients, drug substances (DS), drug products (DP), finished dosage forms (FDF), packaging materials, laboratory reagents, and raw materials. Captures material number, INN (International Nonproprietary Name), USAN, material type, base unit of measure, material group, gross/net weight, shelf life, storage conditions, hazardous material classification, GMP classification, and cross-system identifiers (SAP material number, LIMS material code). SSOT for material identity across SAP MM, LIMS, and MES.' .

ind:Plant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Master record for manufacturing plants, packaging sites, distribution centers, and R&D facilities within the pharmaceutical enterprise. Captures plant code, plant name, plant type (manufacturing, packaging, distribution, R&D, QC laboratory), address, country, GMP certification status, regulatory authority registrations (FDA establishment registration, EMA site number), capacity class, and SAP plant code. Supports manufacturing network planning, regulatory site management, and supply chain operations.' .

ind:StorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Master record for storage locations within pharmaceutical manufacturing and distribution plants. Covers warehouses, cold rooms (2-8°C, -20°C, -80°C), controlled substance vaults (DEA Schedule II-V), quarantine zones, QC sampling areas, returns processing areas, and hazardous material storage. Captures storage location code, plant assignment, temperature range, humidity control requirements, DEA license number (for controlled substances), GMP zone classification (Grade A-D), GDP compliance status, capacity in storage units, and WMS integration flag. Critical for batch traceability, cold-chain integrity, controlled substance accountability, and regulatory inspection readiness.' .

ind:UnitOfMeasure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Reference master for units of measure used across pharmaceutical operations including mass (mg, g, kg), volume (mL, L), concentration (mg/mL, %w/v), potency (IU, mcg), packaging (vial, ampoule, blister, tablet, capsule), and analytical units (ppm, ppb, CFU/mL). Captures UOM code, UOM description, UOM category, ISO unit code, SAP internal UOM, conversion factors to SI base units, and applicable regulatory standards. Ensures consistent measurement across SAP, LIMS, and MES.' .

ind:Country rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Country' ;
    rdfs:comment 'Reference master for countries and territories relevant to pharmaceutical operations, regulatory submissions, and commercial activities. Captures ISO 3166-1 alpha-2 and alpha-3 codes, country name, region, sub-region, regulatory authority (FDA, EMA, MHRA, PMDA, NMPA), ICH region membership, currency code, language, and pharmaceutical market classification (regulated, semi-regulated, unregulated). Supports regulatory submission routing, market access planning, and supply chain geography.' .

ind:AtcClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Atc Classification' ;
    rdfs:comment 'Reference master for the WHO Anatomical Therapeutic Chemical (ATC) classification system used to classify pharmaceutical substances by organ/system and therapeutic, pharmacological, and chemical properties. Captures ATC code at all five levels (anatomical main group, therapeutic subgroup, pharmacological subgroup, chemical subgroup, chemical substance), ATC level description, DDD (Defined Daily Dose), DDD unit, and administration route. Serves as the global standard for drug classification across regulatory submissions, pharmacovigilance, and commercial analytics.' .

ind:MasterdataNdcCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Masterdata Ndc Code' ;
    rdfs:comment 'Reference master for National Drug Codes (NDC) assigned to pharmaceutical products marketed in the United States. Captures NDC number (10-digit or 11-digit format), labeler code, product code, package code, proprietary name, nonproprietary name (INN/USAN), dosage form, route of administration, strength, labeler name, marketing status, application number (NDA/ANDA/BLA), and DEA schedule. Serves as the US product identifier for commercial, supply chain, and pharmacovigilance operations.' .

ind:InnRegistry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Inn Registry' ;
    rdfs:comment 'Reference master for International Nonproprietary Names (INN) as assigned by the WHO for pharmaceutical substances. Captures INN name, USAN (United States Adopted Name), recommended INN status, substance class (small molecule, biologic, vaccine, gene therapy), pharmacological class, CAS registry number, molecular formula, and WHO INN publication reference. Serves as the global nonproprietary naming standard for drug substances across regulatory submissions, labeling, and scientific communications.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Address' ;
    rdfs:comment 'Master record for standardized physical and postal addresses used across pharmaceutical operations including manufacturing sites, distribution centers, clinical trial sites, vendor locations, and customer ship-to/bill-to addresses. Captures address line 1-3, city, state/province, postal code, country, address type (registered, operational, shipping, billing), geocoordinates, address validation status, and standardization source (USPS, Royal Mail, Deutsche Post). Serves as the cross-domain address SSOT referenced by vendor, customer, plant, and site entities.' .

ind:BusinessPartner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Masterdata ;
    rdfs:label 'Business Partner' ;
    rdfs:comment 'Unified master record and Single Source of Truth (SSOT) for ALL external business partners in the pharmaceutical enterprise, following the SAP S/4HANA Business Partner model. Encompasses all vendor/supplier roles (API suppliers, CMOs, CDMOs, CROs, excipient suppliers, packaging suppliers, laboratory reagent vendors) and all customer roles (wholesalers, distributors, hospital networks, pharmacy chains, GPOs, government health agencies) under a single authoritative identity. Captures BP number, BP category (person, organization, group), BP role(s) (supplier, customer, carrier, CMO, CRO, distributor), legal name, tax identification numbers, GMP certification status, qualification status, approved vendor list (AVL) flag, DEA registration number, HIN (Health Industry Number), GLN (Global Location Number), payment terms, credit limits, bank details, sales organization assignment, distribution channel, currency, and cross-system identifiers (SAP BP number, Veeva account ID, LIMS supplier code). Role-specific attributes maintained per role assignment. This is the sole authoritative product for external party identity — no other product in this domain masters vendor or customer identity.' .

ind:Patient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Patient' ;
    rdfs:comment 'Core master entity representing a patient or clinical trial participant. Single source of truth for patient identity across clinical trials, pharmacovigilance, and market access programs. Captures demographics (date of birth, sex, gender, race, ethnicity), contact information, primary language, nationality, country of residence, patient status (active, deceased, lost-to-follow-up), global patient identifier (GPID), cross-system identifiers (CTMS subject number, EDC ID, PV case patient ID, specialty pharmacy ID, EHR MRN), pseudonymization token for HIPAA/GDPR compliance, master patient index (MPI) linkage, consent status flag, data privacy classification, and audit metadata. Authoritative record for all downstream patient-linked data products.' .

ind:PatientEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Patient Enrollment' ;
    rdfs:comment 'Transactional record capturing a participant\'s enrollment into a clinical trial, patient support program, or patient registry, including full disposition lifecycle. Tracks enrollment type (clinical_trial, support_program, registry), enrollment date, randomization date/number, assigned treatment arm, site/investigator identifiers, enrollment status lifecycle (screened, enrolled, randomized, completed, withdrawn, screen-failed), screen failure reason, protocol/ICF version at enrollment. Disposition tracking: disposition event type (completed, withdrawn, lost-to-follow-up, death, screen failure, protocol deviation withdrawal), disposition date, primary and secondary reason codes (standardized per CDISC CT), last dose date, last contact date, and analysis population assignment flags (ITT, mITT, PP, safety). Single source of truth for both enrollment and disposition — serves as authoritative source for CDISC SDTM DM/DS domain derivation and CSR population summaries.' .

ind:InformedConsent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Informed Consent' ;
    rdfs:comment 'Unified consent lifecycle management covering clinical informed consent (ICF), re-consent events, consent withdrawals, and all data privacy authorizations. Clinical consent: ICF version, consent/withdrawal dates, consenting investigator, witness, method (paper, eConsent), language, sub-study consent flags (genetic, biomarker, future use). Privacy consent: GDPR Article 6/9 lawful basis, HIPAA authorization, consent purpose (data processing, research, marketing, data sharing), data subject rights requests (access, erasure, portability, rectification), request/fulfillment dates, jurisdiction (EU, US, UK, JP), consent channel (web, paper, verbal). Captures consent category (clinical_icf, re-consent, withdrawal, privacy_gdpr, privacy_hipaa, data_sharing), LAR/caregiver reference for pediatric populations, and full audit trail. Single source of truth for ALL consent types — clinical and privacy. Mandatory for GCP compliance, regulatory inspection readiness, HIPAA/GDPR compliance, and data subject rights fulfillment.' .

ind:ConcomitantMedication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Concomitant Medication' ;
    rdfs:comment 'Records all concomitant medications taken by a participant during a study or program period. Captures WHO Drug-coded medication name, ATC classification code, dose, dose unit, route of administration, frequency, start date, stop date, ongoing flag, indication for use, and whether the medication is a prohibited concomitant per protocol. Critical for safety assessment, drug-drug interaction analysis, and pharmacovigilance case narratives.' .

ind:AdverseEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Adverse Event' ;
    rdfs:comment 'Captures all adverse events (AEs) and serious adverse events (SAEs) reported by or for a participant during a clinical trial or post-market surveillance program. Records MedDRA-coded preferred term (PT) and system organ class (SOC), onset date, resolution date, severity grade (CTCAE), seriousness criteria (death, hospitalization, life-threatening, etc.), causality assessment, action taken with study drug, outcome, SAE flag, SUSAR flag, and reporting timeline compliance status. Feeds into Argus Safety / Oracle AERS for regulatory reporting.' .

ind:TreatmentExposure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Treatment Exposure' ;
    rdfs:comment 'Longitudinal record of a participant\'s actual exposure to investigational medicinal product (IMP) or approved therapy. Captures drug name, INN, lot number, dose administered, planned dose, dose unit, route of administration, administration date and time, cycle number, visit number, dose modification flag, dose modification reason, cumulative dose, and treatment compliance percentage. Supports PK/PD analysis, dose-response modeling, and safety signal assessment.' .

ind:ClinicalObservation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Clinical Observation' ;
    rdfs:comment 'Consolidated clinical findings and measurements collected from participants across all observation categories. Covers laboratory results (LOINC-coded tests, specimen type, toxicity grade), vital signs (blood pressure, heart rate, temperature, weight, BMI, respiratory rate, SpO2), biomarker/genomic results (CDx, TMB, PD-L1, MSI, PGx panels, gene mutations), and clinical endpoint assessments (RECIST 1.1, iRECIST, DAS28, ECOG PS, Karnofsky). Captures measurement category, test/assessment name, coding (LOINC, assay type), specimen type, collection date/time, visit name, result value, result unit, reference range, out-of-range flag, toxicity grade (CTCAE), result interpretation, assessor, assessment method, laboratory/assay identifier, and delta-from-prior flag. Aligned with OMOP CDM measurement table and CDISC findings-class domains (LB, VS, MB, TR). Sourced from EDC (Medidata Rave), LIMS (LabWare), central labs, and molecular diagnostics vendors.' .

ind:ReportedOutcome rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Reported Outcome' ;
    rdfs:comment 'Captures structured patient-reported outcome (PRO) and quality of life (QoL) data collected via validated instruments (e.g., EQ-5D, FACT-G, SF-36, PROMIS). Records instrument name, instrument version, domain/subscale name, item identifier, response value, total score, subscale score, completion date, completion method (ePRO, paper), visit name, and compliance flag. Supports QoL endpoints, HEOR submissions, and market access dossiers.' .

ind:Registry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Registry' ;
    rdfs:comment 'Master record for patient registries maintained or sponsored by the organization. Covers disease registries (e.g., rare disease natural history studies), pregnancy registries, post-authorization safety studies (PASS), and REMS-mandated registries. Captures registry name, type, therapeutic area, indication, sponsoring organization, regulatory mandate flag, start and planned end dates, target and current enrollment counts, data collection frequency, governing regulatory authority, and registry protocol version. Supports pharmacovigilance commitments, post-marketing requirements (PMRs), and market access evidence generation.' .

ind:SupportProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Support Program' ;
    rdfs:comment 'Master and transactional record for patient support programs (PSPs) and hub services including copay assistance, adherence monitoring, nurse educator support, reimbursement/prior authorization support, and specialty pharmacy coordination. Master attributes: program name, type, associated product (NDC/brand), eligibility criteria, program dates, maximum benefit amount, operational vendor, program status. Copay assistance transactions: claim date, pharmacy identifier, NDC dispensed, quantity, days supply, gross cost, patient OOP amount, assistance amount applied, remaining benefit balance, payer eligibility (commercial only — government patients ineligible), rejection reason code. Adherence monitoring: prescribed regimen, actual doses, MPR, PDC, adherence tier, data source (specialty pharmacy, ePRO, connected device), intervention triggered flag. This is the single source of truth for ALL PSP activity including copay claims formerly tracked separately. Supports commercial access strategy, patient retention, and HEOR real-world evidence.' .

ind:ProtocolDeviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Protocol Deviation' ;
    rdfs:comment 'Documents protocol deviations and violations identified for a participant during a clinical trial. Captures deviation type (inclusion/exclusion criteria, dosing, visit window, prohibited medication, consent), deviation date, discovery date, severity classification (major/minor), impact on participant safety, impact on data integrity, corrective action taken, CAPA reference, and regulatory reportability flag. Sourced from Veeva Vault QualityDocs and Medidata Rave. Critical for GCP compliance and regulatory inspection readiness.' .

ind:BiomarkerResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Patient ;
    rdfs:label 'Biomarker Result' ;
    rdfs:comment 'Stores biomarker and genomic/molecular profiling results for participants, including companion diagnostic (CDx) results, tumor mutation burden (TMB), PD-L1 expression, microsatellite instability (MSI) status, gene mutation panels, pharmacogenomic (PGx) markers, and protein biomarker assay results. Captures biomarker name, assay type, specimen type, collection date, result value, result unit, result interpretation (positive/negative/indeterminate), assay laboratory, assay kit version, and CDx regulatory approval status. Supports precision medicine and patient stratification.' .

ind:Biospecimen rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Biospecimen' ;
    rdfs:comment 'Transactional record for each biological specimen (tissue biopsy, blood draw, urine, CSF) collected from a trial subject at protocol-defined timepoints. Captures specimen type, collection date, collection visit, tube/container type, volume/quantity, processing method, storage temperature, biobank location, shipment tracking to central lab, LOINC/SNOMED coding, chain-of-custody audit trail, and associated assay results reference. Critical for oncology trials requiring RECIST tumor assessments, pharmacogenomic stratification, companion diagnostic validation, and translational research endpoints. Sourced from LIMS integration with Medidata Rave EDC.' .

ind:TherapeuticArea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Therapeutic Area' ;
    rdfs:comment 'Reference master for therapeutic areas (oncology, immunology, rare diseases, neuroscience, etc.) used to classify products, trials, and research programs' .

ind:Excipient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Excipient' ;
    rdfs:comment 'Master record for pharmaceutical excipients used in drug product formulations, capturing functional category, grade, compendial status, and supplier qualification' .

ind:ColdChainRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Cold Chain Record' ;
    rdfs:comment 'Transactional record capturing temperature monitoring data points and excursion events for cold-chain pharmaceutical products during storage and transit, including sensor readings, excursion duration, and disposition decisions' .

ind:PaymentRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payment Run' ;
    rdfs:comment 'Master reference table for payment_run. Referenced by payment_run_id.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Master reference table for bank_account. Referenced by bank_account_id.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Master reference table for invoice. Referenced by invoice_id.' .

ind:Formulary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Market ;
    rdfs:label 'Formulary' ;
    rdfs:comment 'Master reference table for formulary. Referenced by formulary_id.' .

ind:SalesOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Commercial ;
    rdfs:label 'Sales Order' ;
    rdfs:comment 'Master reference table for sales_order. Referenced by sales_order_id.' .

ind:RecallLotScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Recall Lot Scope' ;
    rdfs:comment 'This association product represents the operational scoping event between a product_recall and a specific inventory_lot in pharmaceutical recall management. It captures the per-lot tracking required by FDA 21 CFR Part 7 effectiveness checks, recording the affected quantity, recovery status, disposition method, and notification state for each individual lot included in a recall action. Each record links one product_recall to one inventory_lot and carries attributes that exist only in the context of that specific recall-lot pairing — they cannot reside on the recall header (which is aggregate) or the inventory lot (which reflects current inventory state).. Existence Justification: In pharmaceutical recall operations, a single recall event explicitly targets multiple specific inventory lots (e.g., all lots of NDC 12345-678-90 manufactured between Jan–Jun 2024), and a single inventory lot can be subject to multiple recalls across its lifecycle (e.g., a lot recalled for labeling deficiency and later for contamination). The FDA\'s recall effectiveness check process requires tracking each affected lot individually with its own recovery status, disposition, and notification record. This is an operationally managed relationship — recall coordinators actively create, update, and close records per lot — not an analytical derivation.' .

ind:SignalCaseSeries rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacovigilance ;
    rdfs:label 'Signal Case Series' ;
    rdfs:comment 'This association product represents the Signal Case Series relationship between a safety_signal and an icsr. It captures the operational linkage between a pharmacovigilance safety signal and each Individual Case Safety Report that contributes to or supports that signal, as managed per GVP Module IX and ICH E2E. Each record documents one ICSR\'s participation in one signal detection run, including its contribution score, MedDRA match, and case contribution status. This is the authoritative source for case-level drill-down, regulatory queries, and signal validation workflows in the pharmacovigilance system.. Existence Justification: In pharmacovigilance, a safety signal is identified by aggregating and analyzing multiple ICSRs — a single signal can be supported by hundreds of individual case reports, and a single ICSR can contribute to multiple signals (e.g., the same adverse event case may contribute to a signal for Drug A alone and a signal for a Drug A + Drug B interaction). The business actively manages this \'signal case series\' as a first-class operational concept in safety databases like Argus Safety and Oracle AERS, used for regulatory queries, signal validation, and case-level drill-down. The relationship carries its own data (contribution score, detection run date, MedDRA match flag) that belongs to neither the signal nor the ICSR alone.' .

ind:LicensedPatentSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Intellectual ;
    rdfs:label 'Licensed Patent Schedule' ;
    rdfs:comment 'This association product represents the Contract between licensing_agreement and patent. It captures the formal schedule of intellectual property assets covered under each licensing agreement, recording the specific patents licensed, the per-patent royalty rate, the scope of licensed claims, exclusivity type, and sublicensing rights for each patent-agreement combination. Each record links one licensing_agreement to one patent with attributes that exist only in the context of this contractual relationship — they cannot reside on the agreement (which spans multiple patents) nor on the patent (which may be licensed under multiple agreements with different terms).. Existence Justification: In pharmaceutical IP management, a single licensing agreement routinely covers a portfolio of multiple patents (e.g., a composition-of-matter patent plus a method-of-use patent plus a formulation patent), and a single patent can be licensed under multiple separate agreements to different licensees in different territories or fields of use. The business actively manages this relationship as a \'Licensed Patent Schedule\' — a formal exhibit attached to every licensing agreement that lists each covered patent with its own royalty rate, effective dates, and exclusivity scope. This is not an analytical correlation; it is an operationally managed, legally binding schedule that deal managers create, amend, and terminate throughout the agreement lifecycle.' .

ind:DmfCrossReference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Dmf Cross Reference' ;
    rdfs:comment 'This association product represents the formal Cross-Reference Authorization between a Drug Master File (DMF) and a regulatory application. It captures the operational record of a sponsor\'s authorization to cite a specific DMF within a specific application, including the Letter of Authorization (LoA) lifecycle, FDA-assigned cross-reference identifiers, and access grant status. Each record links one DMF to one regulatory application and carries attributes that exist only in the context of this specific DMF-application cross-reference relationship, in accordance with 21 CFR 314.420 and FDA DMF guidance.. Existence Justification: In pharmaceutical regulatory practice, a single DMF (e.g., an API Drug Master File) is formally cross-referenced by multiple NDA/BLA/ANDA applications from one or more sponsors, and a single application routinely references multiple DMFs (e.g., one for the API, one for the excipient, one for the packaging material, one for the manufacturing site). This cross-referencing process is a formally managed business activity: the DMF holder must issue a Letter of Authorization (LoA) to each referencing applicant, the FDA tracks each cross-reference explicitly, and each authorization has its own lifecycle, reference number, and correspondence history. The relationship is not derivable from transactional joins — it is an operational record that regulatory affairs professionals actively create, update, and manage.' .

ind:SiteActivation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Site Activation' ;
    rdfs:comment 'This association product represents the Site Activation (Trial Site) between investigational_site and trial. It captures the full operational lifecycle of a specific investigational site\'s participation in a specific clinical trial — from site selection and IRB approval through site initiation, enrollment performance, and formal site closure. Each record links one investigational_site to one trial and holds all per-trial-per-site attributes that exist only in the context of that site-trial pairing, including enrollment milestones, IRB/IEC approval details, GCP inspection status, and eTMF folder references. This is the authoritative SSOT for site-level trial operational data consumed by CTMS, eTMF, and clinical operations reporting.. Existence Justification: In pharmaceutical clinical operations, an investigational site participates in MULTIPLE clinical trials over its lifetime, and each clinical trial is conducted across MULTIPLE investigational sites simultaneously. This is the foundational operational reality of multi-site clinical trials. The business actively manages each site-trial pairing as a distinct operational entity — called a \'trial site\' or \'site activation\' — with its own enrollment targets, IRB approvals, SIV dates, FPFV milestones, and closure dates that are specific to that site-trial combination and belong to neither the site master record nor the trial master record alone.' .

# --- Attribute Properties ---
ind:patentId rdf:type rdf:Property ;
    rdfs:label 'Patent Id' ;
    rdfs:comment 'Unique surrogate identifier for each patent record in the IP portfolio. Primary key for the patent master data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patent .

ind:countryId rdf:type rdf:Property ;
    rdfs:label 'Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Patents are jurisdiction-specific; essential for freedom-to-operate analysis, market entry planning, and regulatory strategy in global pharmaceutical operations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Patents are owned by legal entities; critical for IP ownership tracking, portfolio valuation, M&A due diligence, and financial reporting of intangible assets.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:masterdataAtcClassificationId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Atc Classification Id' ;
    rdfs:comment 'Foreign key linking to masterdata.atc_classification. Business justification: Patents are classified by therapeutic area; essential for portfolio analysis, competitive benchmarking, and therapeutic area-specific IP strategy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtcClassification .

ind:masterdataCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Cost Center Id' ;
    rdfs:comment 'Foreign key linking to masterdata.cost_center. Business justification: Patents incur maintenance costs allocated to cost centers; required for IP budget management, financial planning, and cost allocation in pharmaceutical R&D.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:masterdataInnRegistryId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Inn Registry Id' ;
    rdfs:comment 'Foreign key linking to masterdata.inn_registry. Business justification: Patents claim specific INNs; essential for patent landscaping, FTO analysis, and molecule-patent linkage in pharmaceutical IP management.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InnRegistry .

ind:masterdataProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Profit Center Id' ;
    rdfs:comment 'Foreign key linking to masterdata.profit_center. Business justification: Patents are assigned to therapeutic areas/product lines represented by profit centers; critical for portfolio valuation, segment reporting, and strategic IP management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Foreign key linking to masterdata.material. Business justification: Patents cover specific materials (APIs, formulations); essential for product development, supply chain planning, and patent-product linkage in pharmaceutical operations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:patentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Patent Family Id' ;
    rdfs:comment 'Identifier grouping all related patent applications and grants that share a common priority filing across multiple jurisdictions. Used to manage global IP portfolio coherence and track international prosecution strategy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentFamily .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Manufacturing process patents are associated with specific plants; required for technology transfer, GMP compliance, and site-specific IP protection.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:adjustedExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Adjusted Expiry Date' ;
    rdfs:comment 'Final effective expiry date after applying all patent term adjustments (PTA), patent term extensions (PTE) for regulatory review delays, and supplementary protection certificates (SPC). Represents the true end of patent exclusivity for commercial planning purposes.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annuityPaidThroughDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Paid Through Date' ;
    rdfs:comment 'Date through which patent annuity (maintenance) fees have been paid, confirming the patent is in good standing. Used by IP operations to monitor fee payment compliance and prevent unintentional lapse.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClassification rdf:type rdf:Property ;
    rdfs:label 'Asset Classification' ;
    rdfs:comment 'Broader intellectual property asset classification for this record. Primarily \'patent\' for this product, but also supports trade secrets and know-how records anchored to the patent master per the SSOT design. Enables unified IP portfolio reporting across asset types.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this patent record was first created in the IP portfolio system. Supports audit trail, data lineage, and compliance with 21 CFR Part 11 electronic records requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataExclusivityExpiry rdf:type rdf:Property ;
    rdfs:label 'Data Exclusivity Expiry' ;
    rdfs:comment 'Date on which regulatory data exclusivity (RDE) expires, preventing generic/biosimilar applicants from referencing the originator\'s clinical data. In the US, NCEs receive 5 years; biologics receive 12 years under BPCIA. In the EU, the 8+2+1 rule applies. Complements patent expiry in LOE planning.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Calculated or legally determined date on which patent protection lapses, typically 20 years from the filing date subject to patent term adjustments (PTA), patent term extensions (PTE), and supplementary protection certificates (SPC). The primary LOE (Loss of Exclusivity) planning anchor for lifecycle management and generic/biosimilar entry strategy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalCounselRef rdf:type rdf:Property ;
    rdfs:label 'External Counsel Ref' ;
    rdfs:comment 'Reference identifier or name of the external law firm or patent attorney managing prosecution, maintenance, or litigation for this patent. Supports coordination between in-house IP team and outside counsel.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date on which the patent application was formally submitted to the patent office. Establishes the priority date for novelty assessment and is the anchor for calculating patent term and exclusivity periods.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ftoClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Fto Clearance Status' ;
    rdfs:comment 'Current freedom-to-operate (FTO) analysis status for this patent relative to the company\'s commercial activities. Cleared indicates no infringement risk identified; at_risk indicates potential third-party patent conflict; blocked indicates active infringement concern; under_review indicates ongoing FTO analysis. Critical for launch readiness and litigation risk management.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'Date on which the patent was officially granted by the patent office, conferring enforceable rights to the assignee. Null for applications still under examination. Used to calculate patent term adjustments (PTA) and supplementary protection certificate (SPC) eligibility.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Status' ;
    rdfs:comment 'Current legal standing of the patent in its jurisdiction lifecycle. Pending indicates application under examination; granted indicates active protection; abandoned/lapsed indicates failure to prosecute or maintain; opposed indicates third-party challenge; litigated indicates active court proceedings. Drives LOE planning and portfolio valuation. [ENUM-REF-CANDIDATE: pending|granted|abandoned|expired|lapsed|opposed|litigated — promote to reference product]' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Flag' ;
    rdfs:comment 'Indicates whether this patent is currently subject to active litigation, including Paragraph IV ANDA challenges, inter partes review (IPR), post-grant review (PGR), or district court infringement proceedings. Triggers escalated monitoring and legal counsel coordination.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceFeeDueDate rdf:type rdf:Property ;
    rdfs:label 'Maintenance Fee Due Date' ;
    rdfs:comment 'Next scheduled date by which maintenance (annuity) fees must be paid to the patent office to keep the patent in force. Failure to pay results in lapse of patent rights. Critical for IP portfolio maintenance operations.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orangeBookListed rdf:type rdf:Property ;
    rdfs:label 'Orange Book Listed' ;
    rdfs:comment 'Indicates whether this patent is listed in the FDA Approved Drug Products with Therapeutic Equivalence Evaluations (Orange Book). Orange Book listing triggers Paragraph IV certification obligations for ANDA filers and is central to Hatch-Waxman litigation strategy.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orphanDrugExclusivityExpiry rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Exclusivity Expiry' ;
    rdfs:comment 'Date on which orphan drug market exclusivity expires, granting 7 years (US) or 10 years (EU) of market protection for drugs treating rare diseases. Distinct from patent expiry and critical for rare disease portfolio lifecycle planning.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Classification of the company\'s relationship to the patent. Owned indicates full proprietary ownership; licensed_in indicates rights acquired from a third party; licensed_out indicates rights granted to a third party; co_owned indicates joint ownership; assigned indicates transfer of ownership has occurred.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Number' ;
    rdfs:comment 'Officially assigned patent number issued by the relevant patent office (e.g., USPTO, EPO, WIPO). Serves as the primary external business identifier for the patent. Format varies by jurisdiction (e.g., US10123456B2, EP3456789A1).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentType rdf:type rdf:Property ;
    rdfs:label 'Patent Type' ;
    rdfs:comment 'Classification of the patent by the nature of the invention. Composition of matter covers the active molecule (NCE/NBE); method of use covers therapeutic indications; formulation covers drug product design; process covers manufacturing methods; polymorph and salt form cover physical-chemical variants. Critical for LOE (Loss of Exclusivity) strategy and generic/biosimilar entry defense.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pediatricExclusivityExpiry rdf:type rdf:Property ;
    rdfs:label 'Pediatric Exclusivity Expiry' ;
    rdfs:comment 'Date on which the 6-month pediatric exclusivity extension expires, granted by the FDA under the Best Pharmaceuticals for Children Act (BPCA) for conducting pediatric studies. Attaches to and extends both patent and data exclusivity periods.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityDate rdf:type rdf:Property ;
    rdfs:label 'Priority Date' ;
    rdfs:comment 'Earliest claimed priority date, typically the date of the first-filed application in the patent family (provisional or national phase). Determines prior art cutoff and is critical for freedom-to-operate (FTO) analyses and validity challenges.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prosecutionStatus rdf:type rdf:Property ;
    rdfs:label 'Prosecution Status' ;
    rdfs:comment 'Detailed status of the patent application within the prosecution workflow at the patent office. Provides granular tracking beyond legal_status for IP counsel and patent attorneys managing active applications. [ENUM-REF-CANDIDATE: filed|examination|office_action|response_pending|allowed|granted|abandoned — promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpleBookListed rdf:type rdf:Property ;
    rdfs:label 'Purple Book Listed' ;
    rdfs:comment 'Indicates whether this patent is listed in the FDA Purple Book (List of Licensed Biological Products). Relevant for biologics and biosimilar entry defense under the Biologics Price Competition and Innovation Act (BPCIA).' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spcExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Spc Expiry Date' ;
    rdfs:comment 'Date on which the Supplementary Protection Certificate (SPC) expires, representing the final end of patent-based market exclusivity in the relevant EU jurisdiction. Null if no SPC applies.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spcNumber rdf:type rdf:Property ;
    rdfs:label 'Spc Number' ;
    rdfs:comment 'Reference number of the Supplementary Protection Certificate (SPC) granted in EU member states to extend patent protection beyond the standard 20-year term to compensate for regulatory review time. Null if no SPC has been granted.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termAdjustmentDays rdf:type rdf:Property ;
    rdfs:label 'Term Adjustment Days' ;
    rdfs:comment 'Number of days added to the patent term by the USPTO as Patent Term Adjustment (PTA) to compensate for delays in patent prosecution caused by the USPTO. Directly impacts the effective expiry date calculation.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Term Extension Days' ;
    rdfs:comment 'Number of days added to the patent term under 35 U.S.C. § 156 (US) to compensate for time lost during FDA regulatory review of the drug product. Maximum extension is 5 years; total remaining term cannot exceed 14 years post-approval.' ;
    rdfs:domain ind:Patent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:therapeuticArea rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area' ;
    rdfs:comment 'Primary therapeutic area or disease category addressed by the patented compound or method (e.g., Oncology, Immunology, Rare Diseases, Cardiovascular, Neuroscience). Aligns with the company\'s R&D portfolio structure and supports commercial lifecycle planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Official title of the patent as filed and granted by the patent office. Describes the invention in human-readable form and is used for portfolio reporting and IP management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this patent record. Used for change tracking, data synchronization, and audit compliance under 21 CFR Part 11.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:veevaVaultDocReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Doc Reference' ;
    rdfs:comment 'Reference identifier linking this patent record to the corresponding document stored in Veeva Vault (RIM or QualityDocs module), where the patent application, grant certificate, and related correspondence are archived. Supports traceability to the system of record for IP documents.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentClaimId rdf:type rdf:Property ;
    rdfs:label 'Patent Claim Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual patent claim record within the intellectual property portfolio management system.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentClaim .

ind:drugProductId rdf:type rdf:Property ;
    rdfs:label 'Drug Product Id' ;
    rdfs:comment 'Foreign key linking to product.drug_product. Business justification: Specific patent claims cover specific products. Essential for FTO analysis, claim construction in litigation, Orange Book listing accuracy, and claim-level infringement assessment. Removes denormalize' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugProduct .

ind:drugSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Drug Substance Id' ;
    rdfs:comment 'Foreign key linking to product.drug_substance. Business justification: Composition-of-matter and salt-form patent claims cover specific drug substances. IP teams need to link patent claims to drug substances for FTO analysis, claim scope assessment, and validity challeng' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugSubstance .

ind:formulationId rdf:type rdf:Property ;
    rdfs:label 'Formulation Id' ;
    rdfs:comment 'Foreign key linking to product.formulation. Business justification: Formulation patent claims (e.g., extended-release, nanoparticle) cover specific formulations. IP teams link patent claims to formulations for FTO clearance, claim mapping during ANDA challenges, and d' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulation .

ind:orangeBookListingId rdf:type rdf:Property ;
    rdfs:label 'Orange Book Listing Id' ;
    rdfs:comment 'Foreign key linking to intellectual.orange_book_listing. Business justification: patent_claim has is_orange_book_listed (BOOLEAN) indicating whether the specific claim is listed in the Orange Book. The actual listing record is in orange_book_listing. Adding a FK normalizes this — ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrangeBookListing .

ind:outsideCounselBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Outside Counsel Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Outside counsel firms handling patent claim prosecution are business partners in the vendor master. Linking enables legal spend management and AP payment processing. outside_counsel_firm is a denormal' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'The date on which the most recent amendment to this claim was filed or entered. Null if the claim has never been amended. Used to track prosecution history and assess prosecution history estoppel in infringement proceedings.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'The official application number assigned by the patent office upon filing (e.g., US 16/123,456 or EP 19 123 456.7). Used to track prosecution history, office actions, and correspondence with patent counsel. Serves as the primary external identifier for the application.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeStatus rdf:type rdf:Property ;
    rdfs:label 'Challenge Status' ;
    rdfs:comment 'Indicates whether the claim is subject to an active or completed post-grant challenge. IPR (Inter Partes Review) and opposition proceedings can invalidate individual claims independently. Critical for generic/biosimilar entry defense and Paragraph IV ANDA litigation strategy.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimAmendmentVersion rdf:type rdf:Property ;
    rdfs:label 'Claim Amendment Version' ;
    rdfs:comment 'Version number tracking amendments made to the claim text during prosecution or post-grant proceedings (e.g., reexamination, IPR). Version 1 represents the originally filed claim; subsequent versions reflect amendments. Used to maintain prosecution history and support claim construction arguments.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimCategory rdf:type rdf:Property ;
    rdfs:label 'Claim Category' ;
    rdfs:comment 'Subject matter category of the claim defining what is being protected. Composition claims protect chemical or biological entities (NCE, NBE, API); method/use claims protect therapeutic uses or manufacturing processes; formulation claims protect drug product (DP) compositions; dosage form claims protect FDF configurations. [ENUM-REF-CANDIDATE: composition|method|process|apparatus|use|formulation|dosage_form|biological — promote to reference product]' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Sequential number of the claim within the patent document as filed or granted (e.g., Claim 1, Claim 2). Claim numbering follows USPTO and EPO conventions and is used in legal proceedings, IPR petitions, and freedom-to-operate analyses.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPriorityDate rdf:type rdf:Property ;
    rdfs:label 'Claim Priority Date' ;
    rdfs:comment 'The earliest effective filing date from which this claim\'s priority is established, including priority claims under Paris Convention or PCT. The priority date determines prior art cutoff and is critical for validity assessments and patent term calculations.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimScopeClassification rdf:type rdf:Property ;
    rdfs:label 'Claim Scope Classification' ;
    rdfs:comment 'Business classification of the claim\'s legal breadth and coverage. Broad claims cover wide ranges of embodiments; narrow claims are limited to specific embodiments. Genus claims cover a class of compounds or methods; species claims cover a specific member. Used in lifecycle management and generic/biosimilar entry defense strategy.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimText rdf:type rdf:Property ;
    rdfs:label 'Claim Text' ;
    rdfs:comment 'Full verbatim text of the claim as it appears in the granted patent or pending application. This is the legally operative language used in infringement assessments, IPR petitions, inter partes review proceedings, and freedom-to-operate (FTO) analyses. Classified confidential due to strategic IP sensitivity.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Structural classification of the claim indicating whether it stands alone (independent) or references and narrows a prior claim (dependent or multiple dependent). Independent claims define the broadest scope; dependent claims add limitations. Critical for infringement analysis and claim charting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpcClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Cpc Classification Code' ;
    rdfs:comment 'The Cooperative Patent Classification (CPC) code assigned by USPTO or EPO, providing more granular technical classification than IPC. Used in patent landscape analyses, freedom-to-operate searches, and competitive intelligence for drug discovery and CMC domains.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this patent claim record originated. Supports data lineage, reconciliation, and audit trail requirements. Veeva Vault RIM is the primary system of record for IP and regulatory data in the pharmaceutical enterprise.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftoRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Fto Relevance Flag' ;
    rdfs:comment 'Indicates whether this claim has been identified as relevant in one or more freedom-to-operate (FTO) analyses. FTO-relevant claims require monitoring for potential infringement by third-party products or by the company\'s own pipeline compounds.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipcClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Ipc Classification Code' ;
    rdfs:comment 'The International Patent Classification (IPC) code assigned to this claim, indicating the technical field of the invention (e.g., A61K for pharmaceutical preparations, A61P for therapeutic activity). Used for patent landscape analyses, competitive intelligence, and prior art searches.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iprPetitionNumber rdf:type rdf:Property ;
    rdfs:label 'Ipr Petition Number' ;
    rdfs:comment 'The official PTAB (Patent Trial and Appeal Board) or EPO Opposition Division case number for any active or completed inter partes review (IPR) or opposition proceeding challenging this claim. Null if no IPR or opposition has been filed. Critical for litigation tracking and generic/biosimilar defense strategy.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPurpleBookListed rdf:type rdf:Property ;
    rdfs:label 'Is Purple Book Listed' ;
    rdfs:comment 'Indicates whether this claim is associated with a patent listed in the FDA Purple Book (Lists of Licensed Biological Products). Purple Book listing is relevant for biosimilar entry defense under the Biologics Price Competition and Innovation Act (BPCIA) patent dance provisions.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp when this patent claim record was most recently modified in the IP management system. Used for change tracking, audit trail, and data synchronization with Veeva Vault RIM and external patent docketing systems.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:litigationCaseReference rdf:type rdf:Property ;
    rdfs:label 'Litigation Case Reference' ;
    rdfs:comment 'Court case number or docket reference for any active or completed patent infringement litigation involving this claim (e.g., Paragraph IV ANDA litigation, biosimilar patent dance disputes). Classified confidential due to legal privilege sensitivity. Null if no litigation is associated.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moleculeType rdf:type rdf:Property ;
    rdfs:label 'Molecule Type' ;
    rdfs:comment 'Classification of the molecule or biological entity protected by this claim. NCE (New Chemical Entity) for small molecules; NBE (New Biological Entity) for large molecule biologics; biosimilar for follow-on biologics; vaccine, gene therapy, or cell therapy for advanced therapy medicinal products (ATMPs). Determines applicable regulatory pathway and exclusivity provisions.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Claim Number' ;
    rdfs:comment 'For dependent claims, the claim number of the parent claim from which this claim depends. Null for independent claims. Used to reconstruct claim dependency trees for infringement and validity analyses.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patentOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Patent Office Code' ;
    rdfs:comment 'Code identifying the patent office where this claim was filed or is being prosecuted. USPTO (US), EPO (European), UKIPO (UK post-Brexit), JPO (Japan), CNIPA (China), WIPO (PCT international). Determines applicable procedural rules and examination standards. [ENUM-REF-CANDIDATE: USPTO|EPO|UKIPO|JPO|CNIPA|WIPO|PMDA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentTermExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Patent Term Extension Months' ;
    rdfs:comment 'Number of months of patent term extension granted to compensate for regulatory review delays during NDA/BLA/MAA approval processes. In the US, PTE is granted under 35 U.S.C. § 156 (Hatch-Waxman); in Europe, via Supplementary Protection Certificate (SPC). Directly impacts loss-of-exclusivity (LOE) date calculations.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validityStatus rdf:type rdf:Property ;
    rdfs:label 'Validity Status' ;
    rdfs:comment 'Current legal standing of the claim. Valid claims are enforceable; invalid claims have been found unpatentable; cancelled claims were withdrawn during prosecution or post-grant proceedings; amended claims were modified during IPR or reexamination; under_review indicates active challenge proceedings; stayed indicates enforcement is paused pending litigation outcome.' ;
    rdfs:domain ind:PatentClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCountryId rdf:type rdf:Property ;
    rdfs:label 'Priority Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Priority country is fundamental to patent family strategy and filing decisions; required for PCT strategy and global patent portfolio management.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:dataExclusivityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Exclusivity Expiry Date' ;
    rdfs:comment 'The date on which regulatory data exclusivity (RDE) protection expires for the drug covered by this patent family. Data exclusivity prevents generic/biosimilar applicants from referencing the originator\'s clinical data for a defined period (e.g., 5 years NCE in US, 8+2+1 years in EU).' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dmfReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dmf Reference Number' ;
    rdfs:comment 'The FDA Drug Master File (DMF) number or equivalent regulatory dossier reference associated with the API or formulation covered by this patent family. Links IP protection to the regulatory submission record.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earliestExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Expiry Date' ;
    rdfs:comment 'The earliest expiration date among all granted member patents in the family, before any patent term extensions or supplementary protection certificates. Critical for generic/biosimilar entry defense strategy planning.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:familyCode rdf:type rdf:Property ;
    rdfs:label 'Family Code' ;
    rdfs:comment 'Internally assigned alphanumeric code uniquely identifying the patent family within the IP management system. Used for cross-referencing across Veeva Vault RIM and SAP IP modules.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Descriptive name assigned to the patent family, typically reflecting the invention title or the compound/technology it covers (e.g., \'Compound X Formulation Family\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyStatus rdf:type rdf:Property ;
    rdfs:label 'Family Status' ;
    rdfs:comment 'Current lifecycle status of the patent family. \'Active\' indicates at least one member patent is in force; \'Pending\' indicates applications under examination; \'Expired\' indicates all members have lapsed; \'Abandoned\' indicates prosecution was discontinued. [ENUM-REF-CANDIDATE: active|pending|expired|abandoned|licensed_out|litigated — promote to reference product]' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'Classification of the patent family grouping methodology. \'Simple\' groups patents sharing the same priority; \'Extended\' includes equivalents; \'INPADOC\' follows the European Patent Office INPADOC definition. [ENUM-REF-CANDIDATE: simple|extended|INPADOC|domestic|international — promote to reference product]' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freedomToOperateStatus rdf:type rdf:Property ;
    rdfs:label 'Freedom To Operate Status' ;
    rdfs:comment 'Current status of the Freedom-to-Operate (FTO) analysis for this patent family. \'Cleared\' indicates no blocking third-party patents identified; \'At Risk\' indicates potential infringement risk; \'Blocked\' indicates a blocking patent exists; \'Under Review\' indicates analysis in progress.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantedMemberCount rdf:type rdf:Property ;
    rdfs:label 'Granted Member Count' ;
    rdfs:comment 'Number of patent applications within the family that have been granted (issued) patents across all jurisdictions. Distinguishes granted protection from pending applications for portfolio strength assessment.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventionCategory rdf:type rdf:Property ;
    rdfs:label 'Invention Category' ;
    rdfs:comment 'Classification of the type of invention covered by the patent family. New Chemical Entity (NCE) covers novel small molecules; New Biological Entity (NBE) covers biologics; formulation covers drug product compositions; process covers manufacturing methods; method_of_use covers therapeutic indications. [ENUM-REF-CANDIDATE: NCE|NBE|formulation|process|combination|device|method_of_use — promote to reference product]' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionTitle rdf:type rdf:Property ;
    rdfs:label 'Invention Title' ;
    rdfs:comment 'The official title of the invention as stated in the priority or PCT application. Reflects the technical scope of the patent family and is used for portfolio reporting and IP strategy communications.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCount rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Count' ;
    rdfs:comment 'Number of distinct national or regional jurisdictions in which the patent family has at least one active member application or granted patent. Measures geographic breadth of IP protection.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latestExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Latest Expiry Date' ;
    rdfs:comment 'The latest expiration date among all granted member patents in the family, including any patent term extensions (PTE) or supplementary protection certificates (SPC). Defines the outer boundary of IP exclusivity for lifecycle management.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensingStatus rdf:type rdf:Property ;
    rdfs:label 'Licensing Status' ;
    rdfs:comment 'Indicates whether the patent family is subject to a licensing arrangement. \'Licensed In\' means the company holds a license from a third party; \'Licensed Out\' means the company has granted a license to a third party; \'Cross Licensed\' indicates a bilateral arrangement.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationStatus rdf:type rdf:Property ;
    rdfs:label 'Litigation Status' ;
    rdfs:comment 'Current litigation status associated with this patent family. Tracks whether the family is subject to active patent infringement suits, inter partes review (IPR), or post-grant review (PGR) proceedings. [ENUM-REF-CANDIDATE: none|threatened|filed|settled|judgment_for_patentee|judgment_against — promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of individual patent applications and granted patents that are members of this family across all jurisdictions. Indicates the breadth of global IP coverage for the invention.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for IP counsel to record strategic observations, prosecution history highlights, licensing negotiation context, or lifecycle management decisions relevant to the patent family. Not intended for structured data.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDrugExclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the invention covered by this patent family has been granted orphan drug designation and associated market exclusivity (7 years in the US, 10 years in the EU). Relevant for rare disease portfolio strategy.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentRegisterListed rdf:type rdf:Property ;
    rdfs:label 'Patent Register Listed' ;
    rdfs:comment 'Indicates whether patents in this family are listed on the EMA European Patent Register or national patent registers linked to marketing authorisations, triggering data exclusivity and market protection provisions.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentTermExtensionGranted rdf:type rdf:Property ;
    rdfs:label 'Patent Term Extension Granted' ;
    rdfs:comment 'Indicates whether a Patent Term Extension (PTE) or Supplementary Protection Certificate (SPC) has been granted for any member of this family, compensating for regulatory review time under FDA or EMA processes.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pctApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Pct Application Number' ;
    rdfs:comment 'The international application number filed under the Patent Cooperation Treaty (PCT) administered by WIPO, if applicable. Format: PCT/[country code][year]/[serial number]. Enables simultaneous patent protection in multiple jurisdictions.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctFilingDate rdf:type rdf:Property ;
    rdfs:label 'Pct Filing Date' ;
    rdfs:comment 'The international filing date of the PCT application, if applicable. Determines the 30/31-month national phase entry deadline for member jurisdictions.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pctPublicationNumber rdf:type rdf:Property ;
    rdfs:label 'Pct Publication Number' ;
    rdfs:comment 'The WIPO publication number assigned to the PCT international application upon publication (e.g., WO2023/123456). Used for public disclosure tracking and prior art searches.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pediatricExclusivityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pediatric Exclusivity Expiry Date' ;
    rdfs:comment 'The expiry date of pediatric exclusivity granted under the Best Pharmaceuticals for Children Act (BPCA) in the US or the Paediatric Regulation in the EU, adding 6 months of additional exclusivity to qualifying patents.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioSegment rdf:type rdf:Property ;
    rdfs:label 'Portfolio Segment' ;
    rdfs:comment 'Strategic classification of the patent family within the IP portfolio. \'Core\' patents protect primary commercial products; \'Defensive\' patents block competitor freedom to operate; \'Licensing\' patents are monetized through out-licensing; \'Acquired\' patents came through M&A.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Priority Application Number' ;
    rdfs:comment 'The application number of the earliest-filed patent application that establishes the priority date for the family. Typically a national or regional application number (e.g., US provisional or EP application).' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleIpCounsel rdf:type rdf:Property ;
    rdfs:label 'Responsible Ip Counsel' ;
    rdfs:comment 'Name or identifier of the internal IP attorney or external patent counsel responsible for managing prosecution and maintenance of this patent family. Used for accountability and workload management in the IP department.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityPeriodId rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Period Id' ;
    rdfs:comment 'Unique surrogate identifier for each regulatory exclusivity period record in the pharmaceutical intellectual property portfolio.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExclusivityPeriod .

ind:masterdataNdcCodeId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Ndc Code Id' ;
    rdfs:comment 'Foreign key linking to masterdata.ndc_code. Business justification: Exclusivity protects specific NDC-coded products; critical for LOE forecasting, generic entry planning, and product-specific revenue protection.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterdataNdcCode .

ind:medicinalProductId rdf:type rdf:Property ;
    rdfs:label 'Medicinal Product Id' ;
    rdfs:comment 'Reference to the pharmaceutical product (Drug Product or Drug Substance) to which this exclusivity period applies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicinalProduct .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the NDA, BLA, or MAA was approved by the granting authority, which typically triggers the start of the exclusivity period. Serves as the anchor date for exclusivity calculations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The proprietary/trade name of the drug product under which the exclusivity was granted and the product is marketed. Used for commercial lifecycle management and trademark coordination.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPackageType rdf:type rdf:Property ;
    rdfs:label 'Data Package Type' ;
    rdfs:comment 'Type of regulatory data package submitted with the application. Full = complete standalone dossier (NCE/NBE); 505(b)(2) = hybrid relying on published literature or prior approvals; Hybrid = EU hybrid application; Bibliographic = based on published scientific literature. Determines applicable exclusivity type and duration.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmfNumber rdf:type rdf:Property ;
    rdfs:label 'Dmf Number' ;
    rdfs:comment 'FDA Drug Master File (DMF) number associated with the drug substance or drug product covered by this exclusivity, where applicable. Supports CMC (Chemistry Manufacturing and Controls) linkage and regulatory audit.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosageForm rdf:type rdf:Property ;
    rdfs:label 'Dosage Form' ;
    rdfs:comment 'The pharmaceutical dosage form of the product covered by this exclusivity (e.g., tablet, capsule, injection, solution, patch). Relevant because exclusivity may be dosage-form specific.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Category' ;
    rdfs:comment 'Broad category of the exclusivity period indicating whether it applies to a small molecule (NCE/NME), biologic (NBE), orphan drug designation, pediatric extension, or combination product.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityCode rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Code' ;
    rdfs:comment 'Internally assigned unique alphanumeric code identifying this exclusivity period record, used for cross-system referencing and lifecycle management tracking.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Duration Months' ;
    rdfs:comment 'Total duration of the exclusivity period expressed in months as granted by the regulatory authority (e.g., 84 months for US orphan drug, 120 months for EU orphan drug, 144 months for US biologics). Supports duration validation and comparison across jurisdictions.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusivityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Expiry Date' ;
    rdfs:comment 'The date on which the regulatory exclusivity period expires, after which generic or biosimilar applicants may reference the innovator data. Critical for lifecycle management and generic/biosimilar entry defense planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Start Date' ;
    rdfs:comment 'The date on which the regulatory exclusivity period commences, typically aligned with the date of first approval (NDA/BLA/MAA approval date) or orphan designation date depending on exclusivity type.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityStatus rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Status' ;
    rdfs:comment 'Current lifecycle status of the exclusivity period. Active = currently in force; Expired = past expiry date; Withdrawn = voluntarily or involuntarily revoked by authority; Challenged = subject to legal or regulatory challenge; Pending = granted but not yet effective; Suspended = temporarily halted pending review.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityType rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Type' ;
    rdfs:comment 'Classification of the regulatory exclusivity type granted. NCE = New Chemical Entity (5 years US); ODE = Orphan Drug Exclusivity (7 years US / 10 years EU); PED = Pediatric Exclusivity Extension (6 months); DATA = Data Exclusivity for new indication (3 years US); BIOL = Biologics Exclusivity (12 years US); REMS = Risk Evaluation and Mitigation Strategy exclusivity. [ENUM-REF-CANDIDATE: NCE|ODE|PED|DATA|BIOL|REMS|NME|PATENT_LINKAGE — promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstGenericEntryDate rdf:type rdf:Property ;
    rdfs:label 'First Generic Entry Date' ;
    rdfs:comment 'The projected or actual date on which the first generic (ANDA) or biosimilar (351(k) BLA) product may enter the market following expiry or challenge of this exclusivity. Used for lifecycle management, revenue forecasting, and LOE (Loss of Exclusivity) planning.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantingAuthority rdf:type rdf:Property ;
    rdfs:label 'Granting Authority' ;
    rdfs:comment 'Regulatory authority that granted this exclusivity period (e.g., FDA for US market, EMA for EU market, PMDA for Japan, MHRA for UK post-Brexit). Determines jurisdiction and applicable exclusivity rules. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|NMPA|WHO|DEA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indication rdf:type rdf:Property ;
    rdfs:label 'Indication' ;
    rdfs:comment 'The specific disease or condition for which the product is approved and for which this exclusivity was granted. Particularly important for new indication (3-year data exclusivity) and orphan drug exclusivity where exclusivity is indication-specific.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOrphanDesignated rdf:type rdf:Property ;
    rdfs:label 'Is Orphan Designated' ;
    rdfs:comment 'Indicates whether the product holds an orphan drug designation from FDA (Orphan Drug Act) or EMA (Regulation EC 141/2000), which is a prerequisite for orphan drug exclusivity (ODE). Distinct from exclusivity_type as designation may exist without exclusivity being granted.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalCounselNotes rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Notes' ;
    rdfs:comment 'Free-text notes from legal counsel regarding this exclusivity period, including litigation strategy, challenge responses, and coordination with patent attorneys. Classified as confidential due to potential attorney-client privilege content.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current lifecycle management stage of the product relative to this exclusivity period. Pre-Approval = exclusivity anticipated but not yet granted; Active Protection = exclusivity in force; LOE Watch = within 24 months of expiry requiring active monitoring; Post-Expiry = exclusivity has lapsed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loeRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Loe Risk Level' ;
    rdfs:comment 'Assessed risk level for Loss of Exclusivity (LOE) based on proximity to expiry, challenge status, and competitive pipeline. Critical for commercial lifecycle management and strategic planning.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDesignationNumber rdf:type rdf:Property ;
    rdfs:label 'Orphan Designation Number' ;
    rdfs:comment 'Official orphan drug designation number assigned by FDA (ODA) or EMA (EC Regulation 141/2000) when exclusivity_type is ODE. Required for orphan drug exclusivity validation and regulatory reporting.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentLinkageFlag rdf:type rdf:Property ;
    rdfs:label 'Patent Linkage Flag' ;
    rdfs:comment 'Indicates whether this exclusivity period is linked to a listed patent in the FDA Orange Book or equivalent patent register, enabling coordination between patent protection and regulatory exclusivity for lifecycle management.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pediatricExtensionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pediatric Extension Expiry Date' ;
    rdfs:comment 'The adjusted expiry date reflecting the 6-month pediatric exclusivity extension, if granted. Null if pediatric_extension_granted is False.' ;
    rdfs:domain ind:ExclusivityPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pediatricExtensionGranted rdf:type rdf:Property ;
    rdfs:label 'Pediatric Extension Granted' ;
    rdfs:comment 'Indicates whether a 6-month pediatric exclusivity extension (PED) has been granted under the Best Pharmaceuticals for Children Act (BPCA) or EU Paediatric Regulation, extending the base exclusivity or patent term by 6 months.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'The specific statutory or regulatory provision under which this exclusivity was granted (e.g., 21 CFR 314.108(b)(2) for NCE, Orphan Drug Act Section 527, BPCIA Section 7002, EU Regulation 141/2000 Article 8). Supports legal and regulatory audit trails.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsRequired rdf:type rdf:Property ;
    rdfs:label 'Rems Required' ;
    rdfs:comment 'Indicates whether a Risk Evaluation and Mitigation Strategy (REMS) is required as a condition of approval for this product, which may confer additional exclusivity protections or market access restrictions relevant to generic entry.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeOfAdministration rdf:type rdf:Property ;
    rdfs:label 'Route Of Administration' ;
    rdfs:comment 'The route by which the drug product is administered (e.g., oral, intravenous, subcutaneous, topical). Exclusivity may be route-specific, particularly for new indication or new formulation exclusivity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The operational system of record from which this exclusivity period data was sourced (e.g., Veeva Vault RIM, FDA Orange Book feed, EMA EPAR, SAP S/4HANA). Supports data lineage and Silver layer provenance tracking in the Databricks Lakehouse.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkId rdf:type rdf:Property ;
    rdfs:label 'Trademark Id' ;
    rdfs:comment 'Unique system-generated identifier for each trademark registration record in the pharmaceutical intellectual property portfolio.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trademark .

ind:licensingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Licensing Agreement Id' ;
    rdfs:comment 'Foreign key linking to intellectual.licensing_agreement. Business justification: trademark has licensing_flag (BOOLEAN) indicating the trademark is subject to a licensing arrangement. The governing licensing agreement is tracked in licensing_agreement, which covers all IP licensin' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicensingAgreement .

ind:colourClaim rdf:type rdf:Property ;
    rdfs:label 'Colour Claim' ;
    rdfs:comment 'Description of any specific colour or colour combination claimed as a feature of the trademark (e.g., Pantone codes, RGB values, or textual colour descriptions). Relevant for figurative and combined marks where colour is a distinctive element.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclaimerText rdf:type rdf:Property ;
    rdfs:label 'Disclaimer Text' ;
    rdfs:comment 'Any disclaimer of exclusive rights to specific elements of the trademark (e.g., generic or descriptive terms within a combined mark) as required or accepted by the trademark office during examination.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselFirm rdf:type rdf:Property ;
    rdfs:label 'External Counsel Firm' ;
    rdfs:comment 'Name of the external law firm or IP agent responsible for managing the trademark prosecution and maintenance in the relevant jurisdiction. Supports coordination with legal counsel on prosecution strategy and renewal deadlines.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsServicesDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Services Description' ;
    rdfs:comment 'Detailed textual description of the goods and/or services covered by the trademark registration, as specified in the application. For pharmaceutical trademarks, typically describes the therapeutic area, dosage form, and indication of the drug product covered.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Internal Reference Code' ;
    rdfs:comment 'Internal company reference code or docket number assigned to the trademark record in the company\'s IP management system (e.g., Veeva Vault RIM or internal IP docketing system). Enables cross-referencing with internal IP portfolio management tools.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:madridInternationalNumber rdf:type rdf:Property ;
    rdfs:label 'Madrid International Number' ;
    rdfs:comment 'The WIPO-assigned international registration number for trademarks filed under the Madrid Protocol. Populated only when madrid_protocol_flag is True.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:madridProtocolFlag rdf:type rdf:Property ;
    rdfs:label 'Madrid Protocol Flag' ;
    rdfs:comment 'Indicates whether this trademark registration was obtained through the WIPO Madrid Protocol international registration system (True) or through a direct national/regional filing (False). Affects renewal procedures and management workflows.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markType rdf:type rdf:Property ;
    rdfs:label 'Mark Type' ;
    rdfs:comment 'Classification of the trademark by its nature: word mark (text only), figurative mark (logo/image only), combined mark (text and image), three-dimensional mark (shape), sound mark, or colour mark. Drives brand protection strategy and enforcement scope. [ENUM-REF-CANDIDATE: word_mark|figurative_mark|combined_mark|three_dimensional_mark|sound_mark|colour_mark — promote to reference product]' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:niceClassCodes rdf:type rdf:Property ;
    rdfs:label 'Nice Class Codes' ;
    rdfs:comment 'Comma-separated list of Nice Classification class numbers (1–45) under which the trademark is registered. For pharmaceutical trademarks, typically includes Class 5 (pharmaceutical preparations) and potentially Class 10 (medical devices) or Class 44 (medical services). Defines the scope of goods and services covered by the mark.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCode rdf:type rdf:Property ;
    rdfs:label 'Office Code' ;
    rdfs:comment 'Code identifying the trademark office or registry where the application was filed or registration is held (e.g., USPTO for United States, EUIPO for European Union, UKIPO for United Kingdom, JPO for Japan, CNIPA for China, WIPO for international registrations). [ENUM-REF-CANDIDATE: USPTO|EUIPO|UKIPO|JPO|CNIPA|WIPO|CIPO|IP_AUSTRALIA — promote to reference product]' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oppositionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Opposition Deadline Date' ;
    rdfs:comment 'The date by which third parties may file an opposition to the trademark application in the relevant jurisdiction. Critical for monitoring the application\'s progress toward registration and for assessing third-party challenge risk.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oppositionStatus rdf:type rdf:Property ;
    rdfs:label 'Opposition Status' ;
    rdfs:comment 'Current status of any opposition proceedings against the trademark application: not_opposed (no opposition filed), opposition_filed (third-party opposition pending), opposition_withdrawn (opponent withdrew), or opposition_decided (proceeding concluded by the trademark office).' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Owner Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the trademark owner\'s country of domicile or incorporation, as recorded in the trademark register.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityClaimCountryCode rdf:type rdf:Property ;
    rdfs:label 'Priority Claim Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which the priority application was originally filed, as claimed under the Paris Convention.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityClaimDate rdf:type rdf:Property ;
    rdfs:label 'Priority Claim Date' ;
    rdfs:comment 'The date of the earliest priority application claimed under the Paris Convention, if the trademark application claims priority from a prior filing in another jurisdiction. Establishes the effective priority date for multi-jurisdictional filings.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productLaunchCountryCode rdf:type rdf:Property ;
    rdfs:label 'Product Launch Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary market where the associated pharmaceutical drug product is commercially launched or planned for launch under this trademark. Links trademark protection to commercial launch activities.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The date on which the trademark was officially registered by the trademark office. Marks the start of the initial registration term and triggers renewal obligation tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'The official registration number assigned by the trademark office upon successful registration of the mark. Serves as the externally-known unique identifier for the trademark in the relevant jurisdiction.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the trademark registration: pending (application filed, under examination), registered (officially granted), opposed (subject to third-party opposition proceedings), cancelled (registration revoked), expired (lapsed due to non-renewal), or abandoned (application withdrawn or lapsed). Critical for brand protection and commercial launch readiness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date by which the renewal application must be submitted to the trademark office to avoid lapse of the registration. May differ from expiry_date due to grace period provisions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalReminderDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Date' ;
    rdfs:comment 'The internal reminder date set for initiating the trademark renewal process, typically set a defined number of months before the official renewal_date. Supports proactive renewal management and avoidance of unintentional lapse.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trademarkName rdf:type rdf:Property ;
    rdfs:label 'Trademark Name' ;
    rdfs:comment 'The brand name, word mark, or slogan that is the subject of the trademark registration (e.g., a proprietary drug brand name). Serves as the primary human-readable identity label for the trademark record.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useAnywhereDate rdf:type rdf:Property ;
    rdfs:label 'Use Anywhere Date' ;
    rdfs:comment 'The date on which the trademark was first used anywhere (not necessarily in commerce) in connection with the identified goods/services. Relevant for establishing priority in use-based trademark systems.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:useInCommerceDate rdf:type rdf:Property ;
    rdfs:label 'Use In Commerce Date' ;
    rdfs:comment 'The date on which the trademark was first used in commerce in connection with the goods/services identified in the registration. Required for use-based trademark systems (e.g., USPTO) and relevant for establishing priority and defending against cancellation for non-use.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:watchServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Watch Service Flag' ;
    rdfs:comment 'Indicates whether a trademark watch service is active for this mark (True), monitoring for conflicting third-party applications in the relevant jurisdictions. Supports proactive brand protection strategy.' ;
    rdfs:domain ind:Trademark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugMasterFileId rdf:type rdf:Property ;
    rdfs:label 'Drug Master File Id' ;
    rdfs:comment 'Unique surrogate identifier for the Drug Master File record in the enterprise data platform (Silver Layer). Primary key for this entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugMasterFile .

ind:apiManufacturerFlag rdf:type rdf:Property ;
    rdfs:label 'Api Manufacturer Flag' ;
    rdfs:comment 'Indicates whether the DMF holder is the manufacturer of the Active Pharmaceutical Ingredient (API) covered by this DMF. True for Type II DMFs where the holder manufactures the drug substance. Used to distinguish API manufacturers from intermediates suppliers, excipient suppliers, and packaging material suppliers.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'CAS Registry Number uniquely identifying the chemical substance covered by the DMF. Used for substance identification in regulatory submissions, safety databases, and supply chain qualification. Applicable primarily to Type II (API/DS) and Type IV (excipient) DMFs.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmcSectionReference rdf:type rdf:Property ;
    rdfs:label 'Cmc Section Reference' ;
    rdfs:comment 'Reference to the specific CMC (Chemistry, Manufacturing, and Controls) section of the eCTD submission (Module 3) that this DMF supports. Used to map the DMF to the corresponding regulatory dossier section for NDA/BLA/ANDA/MAA submissions.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityCommitmentDate rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Commitment Date' ;
    rdfs:comment 'Date on which the regulatory authority acknowledged the confidential nature of the DMF content. The FDA treats DMF content as confidential trade secret information. This date records when the confidentiality commitment was formally established, supporting IP protection and trade secret management.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crossReferenceCount rdf:type rdf:Property ;
    rdfs:label 'Cross Reference Count' ;
    rdfs:comment 'Number of active regulatory applications (NDA, BLA, ANDA, IND, MAA) that currently cross-reference this DMF. Indicates the commercial and regulatory criticality of the DMF; a high count signals high supply chain dependency and elevated risk if the DMF is withdrawn or goes inactive.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dmfStatus rdf:type rdf:Property ;
    rdfs:label 'Dmf Status' ;
    rdfs:comment 'Current lifecycle status of the DMF with the regulatory authority. \'active\' indicates the DMF is in good standing and available for cross-reference; \'inactive\' indicates it has not been updated within the required period; \'withdrawn\' indicates the holder has formally withdrawn the file; \'under_review\' indicates a pending agency review; \'closed\' indicates the file has been administratively closed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmfType rdf:type rdf:Property ;
    rdfs:label 'Dmf Type' ;
    rdfs:comment 'Classification of the DMF per FDA categorization: Type I (Manufacturing Site, Facilities, Operating Procedures, and Personnel — discontinued by FDA but retained for legacy), Type II (Drug Substance, Drug Substance Intermediate, and Material Used in Their Preparation, or Drug Product), Type III (Packaging Material), Type IV (Excipient, Colorant, Flavor, Essence, or Material Used in Their Preparation), Type V (FDA-Accepted Reference Information). Drives CMC submission strategy and third-party qualification workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ectd Sequence Number' ;
    rdfs:comment 'Four-digit eCTD sequence number assigned to the DMF submission or amendment within the eCTD lifecycle. Used to track the submission history and version control of the DMF in the regulatory authority\'s electronic submission gateway.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date on which the DMF became effective and available for cross-reference by applicants in regulatory submissions (NDA, BLA, ANDA, IND). May differ from submission date if the authority requires a review period before the file is deemed active.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaEstablishmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Fda Establishment Identifier' ;
    rdfs:comment 'FDA Establishment Identifier (FEI) number assigned to the manufacturing facility by the FDA. Used to link the DMF to the FDA\'s establishment registration database, enabling GMP inspection history lookup and import alert monitoring.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Certificate Expiry Date' ;
    rdfs:comment 'Expiry date of the current GMP certificate for the manufacturing site associated with this DMF. Triggers renewal workflows and supplier qualification reviews. An expired GMP certificate may block use of the DMF in new regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Gmp Certificate Number' ;
    rdfs:comment 'Certificate number of the current GMP certificate issued by a recognized regulatory authority or inspection body (e.g., FDA, EMA, PIC/S member authority) for the manufacturing site associated with this DMF. Used for supplier qualification and regulatory compliance verification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or annual update submitted to the regulatory authority for this DMF. FDA requires annual updates to maintain active status. Tracks currency of the file and triggers compliance alerts when updates are overdue.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:letterOfAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Letter Of Authorization Date' ;
    rdfs:comment 'Date on which the DMF holder issued the Letter of Authorization (LOA) permitting the company to cross-reference this DMF in its regulatory submissions. Relevant when the company is the applicant referencing a third-party DMF.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:letterOfAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Letter Of Authorization Required' ;
    rdfs:comment 'Indicates whether a Letter of Authorization (LOA) from the DMF holder is required before an applicant can cross-reference this DMF in their regulatory submission. True for most Type II and Type IV DMFs where the holder controls access to confidential manufacturing information.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingSiteCountryCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the manufacturing site is located. Used for import/export compliance, country-of-origin tracking, supply chain risk management, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAnnualUpdateDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Annual Update Due Date' ;
    rdfs:comment 'Calculated due date for the next mandatory annual update submission to maintain active DMF status with the regulatory authority. Derived from the last amendment date plus 12 months. Used for compliance monitoring and proactive submission planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proprietaryHolderFlag rdf:type rdf:Property ;
    rdfs:label 'Proprietary Holder Flag' ;
    rdfs:comment 'Indicates whether the company itself (Pharmaceuticals) is the holder of this DMF (True) or whether it is a third-party supplier DMF that the company cross-references (False). Drives different workflows: internal DMFs require internal maintenance; third-party DMFs require supplier management and LOA tracking.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'The regulatory authority to which the DMF was submitted (e.g., FDA for US, EMA for EU, PMDA for Japan, MHRA for UK, NMPA for China). Determines applicable regulatory requirements, format standards (e.g., eCTD vs. paper), and review timelines. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|NMPA|WHO|Health Canada|TGA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rimsTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Rims Tracking Number' ;
    rdfs:comment 'Internal tracking number assigned to this DMF record within the company\'s Regulatory Information Management System (RIMS), such as Veeva Vault RIM. Used for internal workflow management, submission tracking, and audit trail purposes.' ;
    rdfs:domain ind:DrugMasterFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the DMF was first submitted to the regulatory authority. Establishes the official filing date and is used to calculate review timelines, annual update obligations, and IP/exclusivity period calculations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFormat rdf:type rdf:Property ;
    rdfs:label 'Submission Format' ;
    rdfs:comment 'Format in which the DMF was submitted to the regulatory authority: \'eCTD\' (Electronic Common Technical Document — mandatory for FDA since 2017 for most submissions), \'paper\' (legacy paper-based submission), or \'NeeS\' (Non-eCTD Electronic Submission — used in some jurisdictions). Determines document management and archival requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'Document identifier in Veeva Vault RIM (Regulatory Information Management) system where the DMF submission package and associated correspondence are stored. Enables traceability between the enterprise data platform record and the source regulatory document management system.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date on which the DMF holder formally withdrew the DMF from the regulatory authority. Populated only when dmf_status is \'withdrawn\'. Triggers downstream impact assessment for any NDA/BLA/ANDA applications that cross-reference this DMF.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseeBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Licensee Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: The licensee in a licensing agreement is a business partner in the vendor/customer master. Linking enables royalty payment processing, credit management, and partner relationship management. licensee_' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:licensorLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Licensor Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Licensing agreements require tracking licensor legal entity for contract management, revenue recognition, and intercompany royalty accounting in pharmaceutical partnerships.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:territoryCountryId rdf:type rdf:Property ;
    rdfs:label 'Territory Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: License territories define geographic scope; essential for revenue allocation, royalty calculation, and compliance with territorial restrictions in pharmaceutical licensing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to the licensing agreement, used in correspondence with counterparties, legal counsel, and regulatory filings. Serves as the BUSINESS_IDENTIFIER for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the licensing agreement. Draft: under negotiation. Active: fully executed and in force. Suspended: temporarily paused by mutual consent or breach notice. Terminated: ended before natural expiry. Expired: reached end of term without renewal. Drives deal management workflows and financial reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the licensing agreement by deal structure. In-licensing: rights acquired from a third party. Out-licensing: rights granted to a third party. Cross-licensing: mutual exchange of IP rights. Co-development: joint development with shared IP. Collaboration: broad research or commercialization partnership. Drives revenue recognition treatment under ASC 606.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOfControlProvision rdf:type rdf:Property ;
    rdfs:label 'Change Of Control Provision' ;
    rdfs:comment 'Indicates whether the agreement contains a change-of-control clause that grants termination or renegotiation rights upon acquisition or merger of either party. True = change-of-control provision exists; False = no such provision. Critical for M&A due diligence and IP portfolio valuation.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Commercial Milestone Value' ;
    rdfs:comment 'Aggregate value of all commercial milestone payments (e.g., first commercial sale, annual net sales thresholds) defined in the agreement, expressed in the agreement currency. Supports commercial launch planning and ASC 606 variable consideration estimation.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which all financial obligations under the agreement (upfront payments, milestones, royalties) are denominated (e.g., USD, EUR, JPY, GBP). Required for multi-currency royalty accounting and foreign exchange hedging.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Development Milestone Value' ;
    rdfs:comment 'Aggregate value of all development-stage milestone payments (e.g., IND submission, Phase I/II/III completion) defined in the agreement, expressed in the agreement currency. Supports clinical development budget planning and ASC 606 variable consideration estimation.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diligenceObligations rdf:type rdf:Property ;
    rdfs:label 'Diligence Obligations' ;
    rdfs:comment 'Narrative description of the commercially reasonable efforts or best efforts diligence obligations imposed on the licensee to develop and commercialize the licensed product. Failure to meet diligence obligations may trigger termination rights. Used for partner relationship management and compliance monitoring.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving disputes between the parties. Arbitration: binding arbitration under specified rules (e.g., ICC, AAA). Litigation: resolution through courts of the governing jurisdiction. Mediation: non-binding mediation before escalation. Expert-determination: technical disputes resolved by independent expert.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date on which the licensing agreement was formally signed and executed by all parties. May differ from the effective date if the agreement has a retroactive or future effective date. Used for legal record-keeping and audit trails.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldOfUse rdf:type rdf:Property ;
    rdfs:label 'Field Of Use' ;
    rdfs:comment 'Specific therapeutic area, indication, or application domain within which the licensee is permitted to use the licensed IP. Examples: \'oncology\', \'rare diseases\', \'human therapeutics only\', \'diagnostic use\'. Restricts the scope of the license and is critical for exclusivity analysis and sublicensing rights management.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the interpretation and enforcement of the agreement. Determines applicable contract law, dispute resolution procedures, and regulatory compliance obligations.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselReference rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Reference' ;
    rdfs:comment 'Name or identifier of the internal or external legal counsel responsible for drafting, negotiating, and maintaining the agreement. Used for coordination on patent litigation, IP enforcement, and contract amendments.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Licensed Asset Description' ;
    rdfs:comment 'Narrative description of the intellectual property assets covered by the license, including compound names (INN/USAN), patent numbers, know-how, trade secrets, trademarks, or biological sequences. Supports IP portfolio management and freedom-to-operate analysis.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedAssetType rdf:type rdf:Property ;
    rdfs:label 'Licensed Asset Type' ;
    rdfs:comment 'Classification of the primary intellectual property asset type covered by the agreement. Patent: granted patent rights. Know-how: proprietary technical knowledge. Trademark: brand or trade name rights. Data-package: regulatory data exclusivity or clinical data. Biological-sequence: gene or protein sequence rights. Trade-secret: confidential proprietary information. [ENUM-REF-CANDIDATE: patent|know-how|trademark|data-package|biological-sequence|trade-secret|formulation|process — promote to reference product]' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of contractually defined milestone events (development, regulatory, and commercial) specified in the agreement. Used for milestone tracking dashboards, deal management reporting, and ASC 606 performance obligation identification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Regulatory Milestone Value' ;
    rdfs:comment 'Aggregate value of all regulatory milestone payments (e.g., NDA/BLA/MAA submission, FDA/EMA approval) defined in the agreement, expressed in the agreement currency. Supports regulatory affairs planning and ASC 606 variable consideration estimation.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Identifies which party bears primary responsibility for conducting development activities (clinical trials, regulatory submissions, manufacturing scale-up) under the agreement. Licensor: licensor retains development responsibility. Licensee: licensee assumes development responsibility. Joint: shared responsibility as defined in the agreement.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightOfFirstNegotiation rdf:type rdf:Property ;
    rdfs:label 'Right Of First Negotiation' ;
    rdfs:comment 'Indicates whether the agreement grants either party a right of first negotiation (ROFN) for additional territories, indications, or follow-on compounds. True = ROFN exists; False = no ROFN. Relevant for lifecycle management and business development strategy.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyBase rdf:type rdf:Property ;
    rdfs:label 'Royalty Base' ;
    rdfs:comment 'The contractual basis on which royalties are calculated. Net-sales: royalties applied to net sales after standard deductions. Gross-sales: royalties applied to gross sales before deductions. Net-revenue: royalties applied to net revenue. Units-sold: royalties calculated per unit sold. Determines the royalty accounting methodology.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRate rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate' ;
    rdfs:comment 'Contractual royalty rate expressed as a decimal fraction of net sales (e.g., 0.050000 = 5.0%) payable by the licensee to the licensor. Used for royalty accrual calculations, revenue recognition under ASC 606/IFRS 15, and P&L forecasting. Null if the agreement uses a tiered royalty structure captured in a separate milestone/royalty schedule.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'Contract number assigned in SAP S/4HANA (SD or FI module) for financial processing of royalty payments, milestone invoicing, and upfront fee recognition. Enables reconciliation between the IP portfolio system and the ERP for royalty accounting and revenue recognition.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensingPermitted rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Permitted' ;
    rdfs:comment 'Indicates whether the licensee has the contractual right to sublicense the licensed IP to third parties (e.g., CMOs, CDMOs, or sub-distributors). True = sublicensing permitted; False = sublicensing prohibited. Impacts CMO/CDMO engagement and supply chain structuring.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationConditions rdf:type rdf:Property ;
    rdfs:label 'Termination Conditions' ;
    rdfs:comment 'Summary of the contractual conditions under which either party may terminate the agreement, including material breach cure periods, insolvency triggers, regulatory failure events, and convenience termination rights. Used by legal counsel for contract management and risk assessment.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date on which the licensing agreement was terminated prior to its natural expiry, whether by mutual consent, breach, or exercise of termination rights. Null if the agreement has not been terminated. Used for financial close-out and IP rights reversion tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalDealValue rdf:type rdf:Property ;
    rdfs:label 'Total Deal Value' ;
    rdfs:comment 'Total potential deal value including upfront payments, all milestone payments, and estimated royalties over the agreement term, expressed in the agreement currency. Used for deal valuation, P&L forecasting, and investor disclosure. Represents the gross deal value before probability-weighting.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Total Milestone Value' ;
    rdfs:comment 'Sum of all contractually defined milestone payment amounts across all milestone events in the agreement, expressed in the agreement currency. Represents the maximum milestone-based consideration achievable under the agreement. Used for deal valuation and revenue recognition planning.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Upfront Payment Amount' ;
    rdfs:comment 'One-time upfront license fee or signing payment due at execution of the agreement, expressed in the agreement currency. Recognized as revenue or capitalized as an intangible asset depending on the nature of the license under ASC 606/IFRS 15. Part of the MONETARY_TRIPLET for this MASTER_AGREEMENT.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyPaymentId rdf:type rdf:Property ;
    rdfs:label 'Royalty Payment Id' ;
    rdfs:comment 'Unique system-generated identifier for each royalty payment transaction record within the intellectual property portfolio management system.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Every royalty payment (in or out) generates a GL posting for revenue/expense recognition. Finance links royalty payments to journal entries for reconciliation, audit trail, SOX compliance, and revenue' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Foreign key linking to finance.payment_run. Business justification: Royalty disbursements are executed via treasury payment runs. Linking royalty_payment to payment_run enables reconciliation of IP royalty payments against bank payment batches — required for treasury ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:primaryRoyaltyBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Royalty Business Partner Id' ;
    rdfs:comment 'Reference to the party granting the license (the entity receiving royalty payments in an outbound scenario or paying in an inbound scenario).' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:royaltyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Royalty Agreement Id' ;
    rdfs:comment 'Foreign key linking to finance.royalty_agreement. Business justification: Royalty payments are calculated under a specific finance royalty_agreement governing rates, tiers, and territory. This FK enables royalty accounting reconciliation, audit trail, and rate-tier validati' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyAgreement .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Any adjustments applied to the calculated royalty amount, such as corrections from prior period reconciliations, audit findings, or contractual true-ups. Positive values increase the payment; negative values reduce it.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Indicates whether this royalty payment record has been flagged for formal royalty audit review, typically triggered by discrepancies between reported sales and expected royalty amounts or by contractual audit rights.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'Bank-issued transaction reference number or wire transfer confirmation number associated with the royalty payment. Used for bank reconciliation and payment verification.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Period End Date' ;
    rdfs:comment 'End date of the royalty calculation period for which net sales or units sold are being reported and royalties computed. Together with start date defines the reporting window per the licensing agreement.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Period Start Date' ;
    rdfs:comment 'Start date of the royalty calculation period (e.g., quarter or year) for which net sales or units sold are being reported and royalties computed. Aligns with licensing agreement reporting obligations.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Deductions Amount' ;
    rdfs:comment 'Total allowable deductions applied to gross sales to arrive at net sales, as defined in the licensing agreement. Typically includes chargebacks, rebates, returns, freight, and applicable taxes.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the reason for disputing the royalty payment amount, applicable when payment_status is \'disputed\'. Documents the basis for disagreement between licensor and licensee for legal and audit purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Contractual deadline by which the royalty payment must be made as specified in the licensing agreement. Used to track overdue payments and trigger escalation workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Foreign exchange rate applied to convert the transaction currency to the company\'s functional reporting currency at the time of payment. Required for multi-currency licensing agreements and consolidated financial reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Total payment amount converted to the company\'s functional reporting currency using the applicable exchange rate. Used for consolidated P&L reporting and SOX financial controls.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'SAP General Ledger account code to which this royalty payment is posted for financial reporting purposes. Distinguishes royalty income (inbound) from royalty expense (outbound) in the P&L.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total gross sales revenue generated from the licensed product during the calculation period, before any deductions. Used as the starting point for net sales calculation per the licensing agreement definition.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licensedTerritory rdf:type rdf:Property ;
    rdfs:label 'Licensed Territory' ;
    rdfs:comment 'Geographic territory or market for which the royalty payment applies, as defined in the licensing agreement. May be a country code (ISO 3166-1 alpha-3), region, or \'GLOBAL\'. Supports territory-level royalty analytics.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Royalty Amount' ;
    rdfs:comment 'Contractual minimum royalty amount guaranteed per period as specified in the licensing agreement, regardless of actual sales performance. Applicable when the calculated royalty falls below this floor.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Net Sales Amount' ;
    rdfs:comment 'Net sales revenue for the licensed product during the calculation period, calculated as gross sales minus allowable deductions per the licensing agreement definition. Forms the royalty basis for net-sales-based agreements.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date on which the royalty payment was executed (funds transferred or received). Represents the principal real-world business event date for this transaction.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDirection rdf:type rdf:Property ;
    rdfs:label 'Payment Direction' ;
    rdfs:comment 'Indicates whether the royalty payment is inbound (received by the company as licensor) or outbound (paid by the company as licensee). Critical for P&L classification and financial reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The financial instrument or mechanism used to execute the royalty payment (e.g., wire transfer, ACH, check, offset against receivables, or netting against other obligations).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this royalty payment transaction, typically matching the SAP FI document number or bank remittance reference used for reconciliation and audit trail.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle state of the royalty payment transaction. Tracks progression from draft calculation through approval, payment execution, and final settlement. [ENUM-REF-CANDIDATE: draft|pending|approved|paid|disputed|cancelled — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current status of the royalty payment reconciliation process, indicating whether the payment has been matched against the licensee\'s royalty report and confirmed as accurate. Supports royalty audit workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Royalty Amount' ;
    rdfs:comment 'Calculated royalty amount due for the calculation period, derived by applying the royalty rate to the applicable royalty basis (net sales, gross sales, or units sold). This is the principal monetary fact of the transaction.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyReportReference rdf:type rdf:Property ;
    rdfs:label 'Royalty Report Reference' ;
    rdfs:comment 'Reference number or identifier of the royalty statement or sales report submitted by the licensee that forms the basis for this royalty payment calculation. Links the payment to the supporting documentation.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyTierLabel rdf:type rdf:Property ;
    rdfs:label 'Royalty Tier Label' ;
    rdfs:comment 'Label identifying the applicable royalty tier when the licensing agreement specifies tiered rates based on cumulative net sales thresholds (e.g., \'Tier 1: 0-$100M\', \'Tier 2: $100M-$500M\'). Null if the agreement uses a flat rate.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Amount' ;
    rdfs:comment 'Final net royalty payment amount after applying the royalty rate to the basis, enforcing any minimum royalty floor, and incorporating adjustments. This is the amount actually paid or received.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'Number of units of the licensed product sold during the calculation period. Used as the royalty basis for unit-based royalty agreements. Expressed as DECIMAL to accommodate partial units or volume-based measures.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax deducted from the royalty payment at source, as required by applicable tax treaties between the licensor and licensee jurisdictions. Relevant for cross-border licensing arrangements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'Applicable withholding tax rate (expressed as a decimal fraction) applied to the royalty payment based on the tax treaty between the relevant jurisdictions. Used to validate withholding tax amount calculations.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftoAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Fto Analysis Id' ;
    rdfs:comment 'Unique system-generated identifier for each Freedom-to-Operate (FTO) analysis or competitive IP watch record. Primary key for this entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtoAnalysis .

ind:lawFirmBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Law Firm Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: FTO analysis law firms are business partners in the vendor master. Linking enables legal spend tracking, AP payment processing, and outside counsel management. law_firm_name is a denormalized business' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:affectedProductNames rdf:type rdf:Property ;
    rdfs:label 'Affected Product Names' ;
    rdfs:comment 'Comma-separated list of proprietary product names or INNs that are commercially affected by the FTO analysis findings or the competitor IP watch activity. Supports portfolio-level impact assessment and lifecycle management decisions.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'The date on which the FTO analysis was formally conducted or the opinion was rendered by the responsible attorney or firm. Represents the principal business event date for this record.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisNumber rdf:type rdf:Property ;
    rdfs:label 'Analysis Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the FTO analysis or IP watch record, used for tracking across legal, regulatory, and business functions. Format: FTO-YYYY-NNNNN.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisStatus rdf:type rdf:Property ;
    rdfs:label 'Analysis Status' ;
    rdfs:comment 'Current lifecycle state of the FTO analysis record: draft (initiated, not yet reviewed), in_review (under attorney or committee review), completed (final opinion issued), superseded (replaced by a newer analysis), or cancelled.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisTitle rdf:type rdf:Property ;
    rdfs:label 'Analysis Title' ;
    rdfs:comment 'Descriptive title of the Freedom-to-Operate analysis or competitive IP watch record, summarizing the product, technology, or process under assessment.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisType rdf:type rdf:Property ;
    rdfs:label 'Analysis Type' ;
    rdfs:comment 'Classification of the analysis record: FTO assessment (go/no-go commercialization opinion), IP watch (ongoing competitor monitoring), patent landscape (broad mapping), clearance opinion (legal freedom-to-use), or freedom-to-use. Drives workflow and reporting.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorFilingDate rdf:type rdf:Property ;
    rdfs:label 'Competitor Filing Date' ;
    rdfs:comment 'Date on which the competitor filed the patent application, ANDA, biosimilar application, or other regulatory/IP submission being monitored. Critical for calculating response timelines and exclusivity defense windows.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the competitor company whose IP activities are being monitored in this watch record (e.g., generic manufacturer filing an ANDA, biosimilar applicant, or third-party patent filer). Central to competitive intelligence.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Competitor Reference Number' ;
    rdfs:comment 'Official reference number of the competitor\'s filing being monitored, such as an ANDA application number, biosimilar BLA number, patent publication number, or IPR petition number. Enables direct lookup in regulatory and patent databases.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conductingAttorney rdf:type rdf:Property ;
    rdfs:label 'Conducting Attorney' ;
    rdfs:comment 'Name of the internal patent attorney or external legal counsel responsible for conducting and signing off on the FTO analysis. Critical for attorney-client privilege tracking and legal accountability.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level assigned to the FTO analysis record, governing access controls and information sharing: restricted (attorney-client privilege, highly sensitive), confidential (internal legal/IP team only), internal (general internal use), or public. Aligns with enterprise data governance policy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designAroundRequired rdf:type rdf:Property ;
    rdfs:label 'Design Around Required' ;
    rdfs:comment 'Indicates whether the FTO analysis concluded that a design-around strategy is required to avoid infringement of identified blocking patents before commercialization can proceed.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalOpinion rdf:type rdf:Property ;
    rdfs:label 'Final Opinion' ;
    rdfs:comment 'The formal legal opinion rendered by the conducting attorney: clear (free to operate without infringement risk), conditional_clear (free to operate subject to design-arounds or licensing), blocked (cannot commercialize without infringing), inconclusive (insufficient information), or pending (opinion not yet issued).' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingRequired rdf:type rdf:Property ;
    rdfs:label 'Licensing Required' ;
    rdfs:comment 'Indicates whether the FTO analysis concluded that a license must be obtained from a third-party patent holder before the assessed product or technology can be commercialized.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentExpiryRelevanceDate rdf:type rdf:Property ;
    rdfs:label 'Patent Expiry Relevance Date' ;
    rdfs:comment 'The earliest expiry date among the blocking patents identified in the FTO analysis, representing the date after which the primary IP barrier may no longer apply. Critical for lifecycle management and generic/biosimilar entry defense planning.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'Narrative description of recommended next steps arising from the FTO analysis, such as design-around strategies, licensing negotiations, patent challenge (IPR/PGR), freedom-to-use licensing, or further legal investigation. Drives IP strategy execution.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorDepartment rdf:type rdf:Property ;
    rdfs:label 'Requestor Department' ;
    rdfs:comment 'Business department or function that initiated the FTO analysis request (e.g., R&D, Commercial, Regulatory Affairs, Legal). Used for workload tracking and cross-functional reporting.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Scheduled date by which the FTO analysis or IP watch record must be reviewed and updated to reflect changes in the patent landscape, competitor activities, or product development status. Supports proactive IP portfolio management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Overall IP infringement risk level assigned by the conducting attorney following the FTO analysis: high (significant blocking IP identified, commercialization at risk), medium (some risk, mitigation possible), low (minor risk, manageable), or negligible (no material blocking IP found).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRationale rdf:type rdf:Property ;
    rdfs:label 'Risk Rationale' ;
    rdfs:comment 'Narrative explanation supporting the assigned risk level, summarizing the key blocking patents, claim analysis findings, and legal reasoning that led to the risk determination. Supports legal review and business decision-making.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed narrative describing the scope of the FTO analysis, including the specific product features, process steps, formulation parameters, or technology elements assessed for potential third-party IP infringement.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyArea rdf:type rdf:Property ;
    rdfs:label 'Technology Area' ;
    rdfs:comment 'Broad technology or therapeutic area classification of the subject matter under FTO assessment (e.g., oncology, immunology, rare diseases, formulation, manufacturing process, delivery device). Supports portfolio-level IP analytics.' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatAssessment rdf:type rdf:Property ;
    rdfs:label 'Threat Assessment' ;
    rdfs:comment 'Assessment of the competitive threat posed by the monitored competitor activity: critical (immediate commercial impact expected), high (significant risk to market exclusivity), medium (moderate risk requiring active response), low (limited near-term impact), or monitoring (no immediate action required).' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of the FTO analysis document (e.g., 1.0, 2.1), tracking revisions and updates to the analysis over time. Supports document control and audit trail requirements under 21 CFR Part 11.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchType rdf:type rdf:Property ;
    rdfs:label 'Watch Type' ;
    rdfs:comment 'For competitive IP watch records, classifies the type of competitor activity being monitored: patent_filing (new patent applications), anda_submission (Abbreviated New Drug Application), biosimilar_application (biosimilar filing), patent_challenge (IPR/PGR/opposition), regulatory_filing, or trademark. [ENUM-REF-CANDIDATE: patent_filing|anda_submission|biosimilar_application|patent_challenge|regulatory_filing|trademark — promote to reference product]' ;
    rdfs:domain ind:FtoAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentLitigationId rdf:type rdf:Property ;
    rdfs:label 'Patent Litigation Id' ;
    rdfs:comment 'Unique surrogate identifier for each patent litigation case record in the intellectual property portfolio management system.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Patent litigation cases require dedicated legal budgets for outside counsel, expert witnesses, and settlement reserves. Finance links litigation cases to budget records to track actual vs. planned spe' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:defendantLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Defendant Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Patent litigation is filed by or against specific internal legal entities. Legal entity-level litigation exposure reporting and financial provisioning (IAS 37) require knowing which legal entity is th' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.invoice. Business justification: Patent litigation generates outside counsel invoices that must be linked to the specific litigation case for legal spend tracking, budget variance analysis, and SOX-compliant legal cost reporting. Pha' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:actualLegalSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Legal Spend Usd' ;
    rdfs:comment 'Cumulative actual legal fees and costs incurred to date for this litigation matter, expressed in US dollars. Sourced from SAP S/4HANA FI/CO module legal spend tracking. Used for legal budget management and P&L reporting.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appealCourt rdf:type rdf:Property ;
    rdfs:label 'Appeal Court' ;
    rdfs:comment 'Name of the appellate court or tribunal hearing the appeal (e.g., U.S. Court of Appeals for the Federal Circuit, U.S. Supreme Court, EPO Board of Appeal). Null if no appeal has been filed.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiled rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed' ;
    rdfs:comment 'Indicates whether an appeal has been filed following the trial court or PTAB judgment. True if an appeal is pending or has been decided; False if no appeal was filed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assertedPatentNumbers rdf:type rdf:Property ;
    rdfs:label 'Asserted Patent Numbers' ;
    rdfs:comment 'Semicolon-delimited list of patent numbers (e.g., US9,123,456; US10,234,567) asserted or challenged in this litigation. These are the Orange Book-listed or Blue Book-listed patents at issue. Links to the patent portfolio for expiry and claim analysis.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNotes rdf:type rdf:Property ;
    rdfs:label 'Case Notes' ;
    rdfs:comment 'Free-text field for internal legal team notes, strategic observations, and case-specific commentary. May include attorney work product summaries, risk assessments, and strategic recommendations. Classified as confidential due to potential attorney-client privilege content.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Official court-assigned or tribunal-assigned docket number uniquely identifying the litigation case (e.g., civil action number, IPR petition number, PGR petition number). Serves as the primary external business identifier for cross-referencing with legal counsel and court records.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePriority rdf:type rdf:Property ;
    rdfs:label 'Case Priority' ;
    rdfs:comment 'Internal priority classification assigned to the litigation case based on revenue at risk, strategic importance, and likelihood of adverse outcome. Critical cases receive executive-level oversight; high cases are monitored by senior IP counsel; medium and low cases follow standard legal management processes.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the litigation case by legal mechanism. Paragraph IV ANDA challenges arise under Hatch-Waxman; IPR and PGR are USPTO trial proceedings; patent infringement suits are district court actions; declaratory judgment actions are filed by generic/biosimilar challengers; biosimilar patent dance refers to BPCIA exchange proceedings. [ENUM-REF-CANDIDATE: paragraph_iv_anda|inter_partes_review|post_grant_review|patent_infringement|declaratory_judgment|biosimilar_patent_dance — promote to reference product]' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtOrTribunal rdf:type rdf:Property ;
    rdfs:label 'Court Or Tribunal' ;
    rdfs:comment 'Name of the judicial or administrative body presiding over the case (e.g., U.S. District Court for the District of Delaware, USPTO Patent Trial and Appeal Board (PTAB), U.S. Court of Appeals for the Federal Circuit, European Patent Office Opposition Division).' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLiabilityUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Liability Usd' ;
    rdfs:comment 'Management\'s best estimate of the potential financial exposure or liability associated with this litigation case, expressed in US dollars. Used for legal reserve provisioning, financial disclosure under ASC 450 (contingencies), and SOX compliance. Includes potential damages, lost profits, and legal costs.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstFilerStatus rdf:type rdf:Property ;
    rdfs:label 'First Filer Status' ;
    rdfs:comment 'Indicates whether the ANDA challenger is the first filer entitled to 180-day generic exclusivity under the Hatch-Waxman Act. True if the defendant holds first-filer status; False otherwise. Relevant for assessing the competitive landscape and timing of generic entry.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:institutionDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Institution Decision Date' ;
    rdfs:comment 'Date on which the PTAB issued its decision on whether to institute the IPR or PGR trial. A decision to institute means the petition met the threshold for review. Null for non-PTAB proceedings.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:judgmentDate rdf:type rdf:Property ;
    rdfs:label 'Judgment Date' ;
    rdfs:comment 'Date on which the court or tribunal issued its final judgment, final written decision (for PTAB proceedings), or order. Null if the case has not yet reached judgment.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadOutsideCounsel rdf:type rdf:Property ;
    rdfs:label 'Lead Outside Counsel' ;
    rdfs:comment 'Full name of the lead attorney at the outside counsel firm responsible for managing this litigation matter. Used for escalation, communication, and legal budget accountability.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Legal Budget Usd' ;
    rdfs:comment 'Approved annual or total budget allocated for legal fees and costs associated with this litigation matter, expressed in US dollars. Used for variance analysis against actual legal spend and budget reforecasting.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextKeyMilestone rdf:type rdf:Property ;
    rdfs:label 'Next Key Milestone' ;
    rdfs:comment 'Description of the next significant procedural or substantive milestone in the litigation (e.g., claim construction hearing, expert discovery deadline, summary judgment motion, PTAB oral argument, appellate briefing deadline). Used for litigation calendar management.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMilestoneDate rdf:type rdf:Property ;
    rdfs:label 'Next Milestone Date' ;
    rdfs:comment 'Scheduled date for the next key procedural or substantive milestone in the litigation. Used for proactive legal calendar management and escalation triggers.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Final outcome or resolution of the litigation case. Patent upheld means the challenged patent survived; patent invalidated means the patent was found invalid or unenforceable; infringement found or non-infringement found reflects district court rulings; settled indicates out-of-court resolution; dismissed indicates termination without merits ruling; consent judgment reflects agreed court order. Null for active cases. [ENUM-REF-CANDIDATE: patent_upheld|patent_invalidated|infringement_found|non_infringement_found|settled|dismissed|consent_judgment — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paragraphIvNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Paragraph Iv Notice Date' ;
    rdfs:comment 'Date on which the company received the formal Paragraph IV certification notice from the ANDA filer, as required under the Hatch-Waxman Act. Triggers the 45-day window to file suit and the 30-month stay. Null for non-Paragraph IV case types.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plaintiffName rdf:type rdf:Property ;
    rdfs:label 'Plaintiff Name' ;
    rdfs:comment 'Legal name of the party initiating the litigation (typically the innovator/NDA holder asserting patent rights, or the generic/biosimilar applicant filing a declaratory judgment action). May be the company itself or a subsidiary.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAtRiskUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue At Risk Usd' ;
    rdfs:comment 'Estimated annual revenue at risk if the litigation outcome is unfavorable and generic or biosimilar entry occurs earlier than the patent expiry date. Expressed in US dollars. Critical input for lifecycle management decisions and commercial strategy.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date on which a settlement agreement was executed between the parties, if the case was resolved through settlement rather than judgment. Null for cases resolved by judgment or still active.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementEntryDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Entry Date' ;
    rdfs:comment 'Agreed date on which the generic or biosimilar entrant is permitted to launch its product under the terms of the settlement agreement. Critical for lifecycle management and revenue forecasting. Null for non-settlement outcomes.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suitFiledDate rdf:type rdf:Property ;
    rdfs:label 'Suit Filed Date' ;
    rdfs:comment 'Date on which the NDA holder filed the patent infringement suit in response to the Paragraph IV notice, within the 45-day statutory window. Null for case types where the company is the defendant or for non-Hatch-Waxman proceedings.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thirtyMonthStayExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Thirty Month Stay Expiry Date' ;
    rdfs:comment 'Date on which the automatic 30-month stay of FDA approval of the ANDA expires under the Hatch-Waxman Act. Calculated from the date the NDA holder received the Paragraph IV certification notice. Null for non-Hatch-Waxman case types. Critical for generic entry defense strategy.' ;
    rdfs:domain ind:Intellectual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialDate rdf:type rdf:Property ;
    rdfs:label 'Trial Date' ;
    rdfs:comment 'Scheduled or actual date of the trial or oral hearing before the court or tribunal. For PTAB proceedings, this is the oral argument date. Null if trial has not been scheduled or the case settled prior to trial.' ;
    rdfs:domain ind:PatentLitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentProsecutionId rdf:type rdf:Property ;
    rdfs:label 'Patent Prosecution Id' ;
    rdfs:comment 'Unique surrogate identifier for each patent prosecution record in the portfolio management system. Primary key for the patent_prosecution data product.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalOrderId rdf:type rdf:Property ;
    rdfs:label 'Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Patent prosecution costs (annuity fees, filing fees, attorney costs) are tracked against SAP internal orders for IP cost controlling and capitalization decisions. Pharma IP finance teams require this ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:payingAgentBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Paying Agent Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Annuity paying agents are business partners in the vendor master; linking enables automated annuity payment processing and vendor spend analytics. paying_agent_name is a denormalized business_partner.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:abandonmentDate rdf:type rdf:Property ;
    rdfs:label 'Abandonment Date' ;
    rdfs:comment 'Date the application was formally abandoned, either expressly by the applicant or by operation of law (e.g., failure to respond to office action within statutory period or failure to pay issue fee). Null unless prosecution_stage = \'abandoned\'.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annuityDueDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Due Date' ;
    rdfs:comment 'Date by which the annuity or maintenance fee for the current fee year must be paid to maintain the patent in force. Failure to pay by this date (or within the grace period) results in patent lapse. Critical docketing field.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annuityFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annuity Fee Amount' ;
    rdfs:comment 'Base annuity or maintenance fee amount due for the current fee year, in the currency specified by annuity_fee_currency. Used for IP budget forecasting and cost tracking across the patent portfolio.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annuityFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Annuity Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annuity fee amount (e.g., USD, EUR, JPY, GBP, CNY). Required for multi-currency portfolio cost consolidation and budget reporting.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuityFeeYear rdf:type rdf:Property ;
    rdfs:label 'Annuity Fee Year' ;
    rdfs:comment 'The renewal/annuity year number for which the most recent maintenance fee obligation applies (e.g., year 3, year 7, year 12). Annuity years are counted from the filing date in most jurisdictions. Used for fee schedule management and budget forecasting.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annuityGracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Grace Period End Date' ;
    rdfs:comment 'Last date on which the annuity fee can be paid with a surcharge before the patent lapses. Typically 6 months after annuity_due_date in most jurisdictions. After this date, the patent is irrevocably lapsed unless restoration procedures are available.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annuityPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Annuity Payment Date' ;
    rdfs:comment 'Actual date on which the annuity or maintenance fee was paid to the patent office or paying agent. Used to confirm timely payment and to calculate any applicable surcharges.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annuityPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Annuity Payment Status' ;
    rdfs:comment 'Current payment status of the annuity/maintenance fee obligation for the current fee year. Pending = not yet due or awaiting payment; Paid = confirmed payment received; Overdue = past due date, within grace period; Lapsed = grace period expired without payment; Waived = fee waived per applicable rules.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuitySurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Annuity Surcharge Amount' ;
    rdfs:comment 'Late payment surcharge amount applied when the annuity fee is paid after the due date but within the grace period. Tracked separately from the base fee for cost analysis and to identify patterns of late payment.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of the patent application by filing type. Utility = standard non-provisional; Provisional = 12-month placeholder; PCT = Patent Cooperation Treaty international; Continuation/Divisional/CIP = derived from parent application. Determines prosecution rules and term calculations. CIP = Continuation-In-Part.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCount rdf:type rdf:Property ;
    rdfs:label 'Claim Count' ;
    rdfs:comment 'Total number of claims in the current version of the patent application or granted patent, including independent and dependent claims. Affects official filing fees in many jurisdictions and indicates the breadth of IP protection sought.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpcClassification rdf:type rdf:Property ;
    rdfs:label 'Cpc Classification' ;
    rdfs:comment 'Cooperative Patent Classification (CPC) code assigned by USPTO or EPO (e.g., A61K 31/4745). More granular than IPC; used for patent analytics, freedom-to-operate (FTO) searches, and competitive landscape mapping.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinerArtUnit rdf:type rdf:Property ;
    rdfs:label 'Examiner Art Unit' ;
    rdfs:comment 'Patent office art unit or examination division to which the application is assigned (e.g., USPTO Art Unit 1627 for pharmaceutical compositions). Informs prosecution strategy based on art unit allowance rates and examiner tendencies.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinerName rdf:type rdf:Property ;
    rdfs:label 'Examiner Name' ;
    rdfs:comment 'Name of the patent examiner assigned to the application at the patent office. Used for prosecution strategy planning, examiner history analysis, and interview request management.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentClaimCount rdf:type rdf:Property ;
    rdfs:label 'Independent Claim Count' ;
    rdfs:comment 'Number of independent claims in the application or granted patent. Independent claims define the broadest scope of protection and are the primary focus of validity and infringement analyses.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventionType rdf:type rdf:Property ;
    rdfs:label 'Invention Type' ;
    rdfs:comment 'Pharmaceutical classification of the invention being patented. NCE (New Chemical Entity) = novel small molecule; NBE (New Biological Entity) = biologic/biosimilar; formulation = drug product composition; process = manufacturing/synthesis method; method_of_use = therapeutic indication; combination = multi-component therapy. Critical for lifecycle management and generic/biosimilar entry defense strategy.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipcClassification rdf:type rdf:Property ;
    rdfs:label 'Ipc Classification' ;
    rdfs:comment 'International Patent Classification (IPC) code assigned to the application (e.g., A61K 31/00 for pharmaceutical preparations). Used for patent landscape analysis, prior art searches, and competitive intelligence. Multiple codes may be stored as a comma-separated string.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOfficeActionDate rdf:type rdf:Property ;
    rdfs:label 'Last Office Action Date' ;
    rdfs:comment 'Date of the most recent office action received from the patent office. Used to calculate the statutory response deadline and to trigger docketing alerts for prosecution attorneys.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lawFirmName rdf:type rdf:Property ;
    rdfs:label 'Law Firm Name' ;
    rdfs:comment 'Name of the external patent law firm engaged for prosecution of this application, if applicable. Used for vendor management, cost tracking, and conflict-of-interest monitoring across the IP portfolio.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeActionCount rdf:type rdf:Property ;
    rdfs:label 'Office Action Count' ;
    rdfs:comment 'Total number of office actions (rejections, objections, or requirements) received from the patent office during prosecution of this application. Indicates prosecution complexity and is used for cost estimation and strategy assessment.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officeActionType rdf:type rdf:Property ;
    rdfs:label 'Office Action Type' ;
    rdfs:comment 'Classification of the most recent office action received. Restriction = requirement to elect claims; Non-final = first substantive rejection; Final = final rejection after response; Advisory = after final response; Allowance/Notice of Allowance = claims approved for grant.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Application Number' ;
    rdfs:comment 'Application number of the parent patent application from which this application claims priority (applicable for continuation, divisional, or CIP applications). Used to reconstruct the patent family hierarchy and assess claim scope relative to the parent.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentConfirmationReference rdf:type rdf:Property ;
    rdfs:label 'Payment Confirmation Reference' ;
    rdfs:comment 'Official confirmation or receipt reference number issued by the patent office or paying agent upon successful annuity fee payment. Serves as proof of payment for audit and compliance purposes.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prosecutionStage rdf:type rdf:Property ;
    rdfs:label 'Prosecution Stage' ;
    rdfs:comment 'Current stage of the patent application in the prosecution workflow lifecycle. Drives docketing actions, deadline calculations, and portfolio status reporting. Values: filed, examination, office_action_received, response_submitted, allowance, granted, abandoned. [ENUM-REF-CANDIDATE: filed|examination|office_action_received|response_submitted|allowance|granted|abandoned — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prosecutionStrategy rdf:type rdf:Property ;
    rdfs:label 'Prosecution Strategy' ;
    rdfs:comment 'Free-text description of the prosecution strategy adopted for this application, including claim amendment approach, interview strategy, appeal considerations, and alignment with the broader IP lifecycle management plan. Attorney-client privileged content.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date the patent application was published by the patent office, typically 18 months after the earliest priority date. Marks the point at which the application enters the public domain and becomes citable prior art.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationNumber rdf:type rdf:Property ;
    rdfs:label 'Publication Number' ;
    rdfs:comment 'Official publication number assigned by the patent office upon publication of the application (e.g., US20230123456A1, WO2023/012345A1). Distinct from the application number; used for public citation and prior art searches.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'Statutory or extended deadline by which a response to the most recent office action must be filed to avoid abandonment. Calculated from last_office_action_date per jurisdiction-specific rules. Critical docketing field — failure to meet this deadline results in application abandonment.' ;
    rdfs:domain ind:PatentProsecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentTermExtensionId rdf:type rdf:Property ;
    rdfs:label 'Patent Term Extension Id' ;
    rdfs:comment 'Unique surrogate identifier for each patent term extension or supplementary protection certificate record in the intellectual property portfolio. Primary key for this entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentTermExtension .

ind:applicantDelayDays rdf:type rdf:Property ;
    rdfs:label 'Applicant Delay Days' ;
    rdfs:comment 'Number of days deducted from the regulatory review period due to delays attributable to the applicant (e.g., failure to respond to FDA requests within the prescribed period). Reduces the calculated extension duration under 35 U.S.C. § 156(c)(1). Tracked for audit and dispute resolution purposes.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalPhaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Approval Phase Start Date' ;
    rdfs:comment 'For US PTE calculations: the date on which the regulatory approval phase began, typically the date of NDA/BLA submission to the FDA. Used to calculate the approval phase component of the regulatory review period under 35 U.S.C. § 156(g)(1)(B).' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:atcCode rdf:type rdf:Property ;
    rdfs:label 'Atc Code' ;
    rdfs:comment 'The WHO Anatomical Therapeutic Chemical (ATC) classification code assigned to the active substance covered by the extension. Provides standardized classification for cross-portfolio analytics, competitive intelligence, and regulatory reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePatentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Base Patent Expiry Date' ;
    rdfs:comment 'The original expiry date of the underlying base patent before any term extension or adjustment is applied. Used as the baseline for calculating the adjusted expiry date and the duration of the extension period.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:basePatentNumber rdf:type rdf:Property ;
    rdfs:label 'Base Patent Number' ;
    rdfs:comment 'The official patent number of the underlying patent for which the term extension or SPC is sought (e.g., US10,123,456 or EP1234567). For SPC purposes, this is the \'basic patent\' as defined under Article 1(c) of EU Regulation 469/2009. Retained as a denormalized field for direct reference without joining to the patent table.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculatedExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Calculated Extension Days' ;
    rdfs:comment 'The number of days of patent term extension calculated based on the regulatory review period formula. For US PTE: one-half of the testing phase plus the approval phase, capped at 5 years with remaining patent life not exceeding 14 years post-approval. For EU SPC: period between IND filing and MA grant minus 5 years, capped at 5 years.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'Current lifecycle status of the patent term extension or SPC application. Tracks the application from initial drafting through filing, examination, and final decision by the granting authority. Critical for LOE (Loss of Exclusivity) date calculation and portfolio management. [ENUM-REF-CANDIDATE: draft|filed|under_review|granted|refused|withdrawn|appealed|lapsed|invalidated — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselReference rdf:type rdf:Property ;
    rdfs:label 'External Counsel Reference' ;
    rdfs:comment 'Reference identifier or name of the external patent law firm or legal counsel managing this patent term extension or SPC application. Used for coordination of legal strategy, correspondence tracking, and matter management. Marked confidential as it reflects privileged legal relationships.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantedExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Granted Extension Days' ;
    rdfs:comment 'The actual number of days of patent term extension officially granted by the granting authority. May differ from the calculated extension if the authority applies different determinations of the regulatory review period or applicant delay deductions. Null until the extension is formally granted.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loeDate rdf:type rdf:Property ;
    rdfs:label 'Loe Date' ;
    rdfs:comment 'The effective Loss of Exclusivity (LOE) date for the product in this jurisdiction, accounting for all applicable exclusivity mechanisms (PTE/SPC, pediatric extension, orphan drug exclusivity, data exclusivity). This is the single most critical date for commercial planning, generic/biosimilar entry defense, and lifecycle management strategy. Represents the date after which generic or biosimilar competition may legally enter the market.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Authorization Date' ;
    rdfs:comment 'The date on which the first marketing authorization for the product was granted in the relevant jurisdiction. This date is critical for calculating the regulatory review period and the permissible extension duration under Hatch-Waxman PTE and EU SPC frameworks.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Marketing Authorization Number' ;
    rdfs:comment 'The official marketing authorization number (NDA number, BLA number, EU MA number, or national equivalent) that forms the regulatory basis for the extension application. For EU SPC, this is the first authorization to place the product on the market in the Community per Article 3(b) of Regulation 469/2009.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanismType rdf:type rdf:Property ;
    rdfs:label 'Mechanism Type' ;
    rdfs:comment 'Classification of the patent term extension mechanism. PTE = US Hatch-Waxman Patent Term Extension under 35 U.S.C. § 156; SPC = EU/UK Supplementary Protection Certificate under EC Regulation 469/2009; national_equivalent = country-specific analogous mechanisms (e.g., Japan, Canada, Australia); pediatric_extension = additional 6-month pediatric exclusivity; data_exclusivity = regulatory data protection period. [ENUM-REF-CANDIDATE: PTE|SPC|national_equivalent|pediatric_extension|data_exclusivity|regulatory_data_protection — promote to reference product]' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oppositionDate rdf:type rdf:Property ;
    rdfs:label 'Opposition Date' ;
    rdfs:comment 'The date on which a third-party opposition, invalidity action, or equivalent challenge was filed against this patent term extension or SPC. Null if no opposition has been filed. Used to track litigation timelines and coordinate with legal counsel.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oppositionFiled rdf:type rdf:Property ;
    rdfs:label 'Opposition Filed' ;
    rdfs:comment 'Indicates whether a third party (e.g., generic manufacturer, biosimilar applicant) has filed an opposition, invalidity action, or equivalent challenge against this patent term extension or SPC. True triggers escalation to the legal team for litigation management and LOE date reassessment.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orphanDrugExclusivity rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Exclusivity' ;
    rdfs:comment 'Indicates whether the product covered by this extension also benefits from orphan drug exclusivity (7 years in the US under the Orphan Drug Act, 10 years in the EU under Regulation (EC) No 141/2000). Used in conjunction with PTE/SPC to determine the effective exclusivity cliff date.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pediatricExtensionEligible rdf:type rdf:Property ;
    rdfs:label 'Pediatric Extension Eligible' ;
    rdfs:comment 'Indicates whether this patent term extension or SPC is eligible for an additional 6-month pediatric extension under the US Best Pharmaceuticals for Children Act (BPCA) or EU Paediatric Regulation (EC) No 1901/2006. True if a Written Request (US) or Paediatric Investigation Plan (EU) has been completed and accepted.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReviewPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Period Days' ;
    rdfs:comment 'The total number of days of the regulatory review period as determined by the granting authority. For US PTE, this is the period from IND filing to NDA/BLA approval, reduced by any applicant-caused delays. Directly determines the maximum permissible extension duration under 35 U.S.C. § 156.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spcProductDefinition rdf:type rdf:Property ;
    rdfs:label 'Spc Product Definition' ;
    rdfs:comment 'For EU/UK SPC applications only: the definition of the \'product\' as per Article 1(b) of EU Regulation 469/2009, specifying the active ingredient or combination of active ingredients of a medicinal product. This definition determines the scope of SPC protection and is critical for freedom-to-operate analyses and generic entry defense.' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingPhaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Testing Phase Start Date' ;
    rdfs:comment 'For US PTE calculations: the date on which the regulatory review testing phase began, typically the date of IND (Investigational New Drug) application submission. Used to calculate the testing phase component of the regulatory review period under 35 U.S.C. § 156(g)(1).' ;
    rdfs:domain ind:PatentTermExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:andaFirstFilerFlag rdf:type rdf:Property ;
    rdfs:label 'Anda First Filer Flag' ;
    rdfs:comment 'Indicates whether a first-filer ANDA applicant has been identified for this patent listing, triggering the 180-day generic exclusivity period under Hatch-Waxman. True if a first filer has been designated; False otherwise. Affects the timing of subsequent generic approvals.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delistingDate rdf:type rdf:Property ;
    rdfs:label 'Delisting Date' ;
    rdfs:comment 'Date on which the patent or exclusivity was removed from the FDA Orange Book, either voluntarily by the NDA holder or by FDA order. Null if the listing remains active. Relevant for tracking generic entry eligibility changes.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstGenericEligibilityDate rdf:type rdf:Property ;
    rdfs:label 'First Generic Eligibility Date' ;
    rdfs:comment 'Earliest date on which a generic drug product may receive final FDA approval, accounting for both patent expiry and exclusivity expiry dates. Derived from the later of patent expiry, exclusivity expiry, and 30-month stay expiry. Critical for lifecycle management and loss-of-exclusivity (LOE) planning.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingDate rdf:type rdf:Property ;
    rdfs:label 'Listing Date' ;
    rdfs:comment 'Date on which the patent or exclusivity was first listed in the FDA Orange Book by the NDA holder. Establishes the effective date of the listing for Paragraph IV certification and 30-month stay calculations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current status of the Orange Book listing record. \'Active\' indicates the patent or exclusivity is currently listed and enforceable. \'Delisted\' indicates the NDA holder has removed the listing. \'Withdrawn\' indicates FDA-initiated removal. \'Pending\' indicates submission under review. \'Corrected\' indicates an amendment was filed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:market rdf:type rdf:Property ;
    rdfs:label 'Market' ;
    rdfs:comment 'Regulatory market or jurisdiction for which this listing record applies. \'US\' for FDA Orange Book; \'EU\' for EMA Article 10 reference product listing; \'UK\' for MHRA; \'JP\' for PMDA; \'CN\' for NMPA. Enables multi-market IP portfolio management. [ENUM-REF-CANDIDATE: US|EU|UK|JP|CN|CA|AU|BR|IN|KR — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaNumber rdf:type rdf:Property ;
    rdfs:label 'Nda Number' ;
    rdfs:comment 'FDA-assigned application number (NDA, ANDA, or BLA) under which the drug product is approved and listed in the Orange Book. Governs which patents and exclusivities are associated with the approved product.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDrugDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Designation Flag' ;
    rdfs:comment 'Indicates whether the listed drug product holds an FDA Orphan Drug Designation (ODD), conferring 7-year market exclusivity upon approval. True if ODD is active; False otherwise. Relevant for rare disease portfolio strategy and generic entry defense.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paragraphIvDate rdf:type rdf:Property ;
    rdfs:label 'Paragraph Iv Date' ;
    rdfs:comment 'Date on which the first Paragraph IV certification was received by the NDA holder for this listed patent. Initiates the 45-day window to file patent infringement suit and triggers the 30-month stay clock if suit is filed.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paragraphIvFlag rdf:type rdf:Property ;
    rdfs:label 'Paragraph Iv Flag' ;
    rdfs:comment 'Indicates whether a Paragraph IV certification has been filed by an ANDA applicant challenging this listed patent as invalid, unenforceable, or not infringed. True triggers the 45-day notice period and potential 30-month stay of ANDA approval.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Patent Expiry Date' ;
    rdfs:comment 'Date on which the listed patent expires as published in the FDA Orange Book. This date directly governs the earliest date a generic applicant may receive final approval absent a Paragraph IV challenge or court ruling.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentUseCode rdf:type rdf:Property ;
    rdfs:label 'Patent Use Code' ;
    rdfs:comment 'FDA-assigned use code (e.g., U-001) that identifies the specific approved method of use covered by the listed patent. Required for method-of-use patents; determines the scope of Paragraph IV certifications and carve-out labeling eligibility.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pediatricExclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Pediatric Exclusivity Flag' ;
    rdfs:comment 'Indicates whether a 6-month pediatric exclusivity extension has been granted under the Best Pharmaceuticals for Children Act (BPCA), attaching to all existing patents and exclusivities for the listed product. True if pediatric exclusivity is in effect.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceListedDrugFlag rdf:type rdf:Property ;
    rdfs:label 'Reference Listed Drug Flag' ;
    rdfs:comment 'Indicates whether this NDA product is designated as the Reference Listed Drug (RLD) against which ANDA applicants must demonstrate bioequivalence. True if the product is the RLD; False if it is a non-RLD listed product.' ;
    rdfs:domain ind:OrangeBookListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remsFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Flag' ;
    rdfs:comment 'Indicates whether the listed drug product is subject to an FDA-approved Risk Evaluation and Mitigation Strategy (REMS). REMS requirements may affect generic applicant ability to demonstrate shared REMS compliance, impacting generic entry timelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strength rdf:type rdf:Property ;
    rdfs:label 'Strength' ;
    rdfs:comment 'Labeled strength of the drug product as listed in the Orange Book (e.g., \'10 mg\', \'500 mg/5 mL\'). Strength is a key differentiator for therapeutic equivalence and generic substitution eligibility.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticEquivalenceCode rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Equivalence Code' ;
    rdfs:comment 'FDA therapeutic equivalence evaluation code assigned to the drug product in the Orange Book (e.g., AB, AA, BC, BX). \'A\' codes indicate therapeutically equivalent to the RLD; \'B\' codes indicate not therapeutically equivalent. Drives pharmacy substitution decisions and formulary management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionId rdf:type rdf:Property ;
    rdfs:label 'Submission Id' ;
    rdfs:comment 'Unique surrogate identifier for each regulatory submission record in the Pharmaceuticals data lakehouse. Primary key for the submission data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:applicationId rdf:type rdf:Property ;
    rdfs:label 'Application Id' ;
    rdfs:comment 'Reference to the parent regulatory application (e.g., NDA, BLA, MAA, IND) under which this submission sequence is filed. Each submission belongs to exactly one parent application.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Foreign key linking to commercial.brand. Business justification: Submissions are filed for specific commercial brands. Brand_id enables tracking submission activity by brand for lifecycle management, launch planning, and regulatory intelligence reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:croBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Cro Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: CROs are contracted business partners providing regulatory submission preparation and filing services. Tracking the CRO entity is essential for vendor management, quality oversight, and regulatory ins' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:healthAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Health Authority Id' ;
    rdfs:comment 'Reference to the regulatory health authority (e.g., FDA, EMA, PMDA, MHRA, NMPA) to which this submission is directed. Determines jurisdiction-specific requirements and timelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthAuthority .

ind:indicationId rdf:type rdf:Property ;
    rdfs:label 'Indication Id' ;
    rdfs:comment 'Foreign key linking to product.indication. Business justification: Submissions are filed for specific indications (sNDA, label update for indication expansion). submission.indication is a denormalized text field; linking to product.indication normalizes it and enable' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Indication .

ind:innRegistryId rdf:type rdf:Property ;
    rdfs:label 'Inn Registry Id' ;
    rdfs:comment 'Foreign key linking to masterdata.inn_registry. Business justification: INN (International Nonproprietary Name) is the WHO-designated active substance identifier required in all regulatory submissions for global harmonization and pharmacovigilance. Core reference for CTD ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InnRegistry .

ind:investigatorId rdf:type rdf:Property ;
    rdfs:label 'Investigator Id' ;
    rdfs:comment 'Foreign key linking to hcp.investigator. Business justification: IND/NDA submissions require a qualified principal investigator with FDA Form 1572 on file and current GCP training. Regulatory operations teams must verify investigator qualifications (gcp_training_st' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:masterId rdf:type rdf:Property ;
    rdfs:label 'Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.hcp_master. Business justification: IND and NDA submissions must identify the principal investigator or medical expert responsible for clinical data. Regulatory affairs tracks investigator accountability for submission content and respo' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:pricingDecisionId rdf:type rdf:Property ;
    rdfs:label 'Pricing Decision Id' ;
    rdfs:comment 'Foreign key linking to market.pricing_decision. Business justification: Pricing decisions reference the regulatory submission as their regulatory basis (pricing_decision.regulatory_submission_ref is a plain text denormalization). Replacing with FK enables proper join for ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingDecision .

ind:processValidationId rdf:type rdf:Property ;
    rdfs:label 'Process Validation Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.process_validation. Business justification: NDA/BLA/MAA submissions include process validation data in CMC sections as supporting evidence. Regulatory CMC teams must link submissions to the specific process validation studies referenced in the ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessValidation .

ind:responsibleOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Responsible Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: Regulatory affairs teams are organized by org unit; submissions are assigned to specific regulatory units for workload management, resource planning, and performance reporting. A pharma regulatory ope' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.site. Business justification: Regulatory submissions are filed for specific manufacturing sites (CMC sections, PAI triggers, GMP certificates). Regulatory affairs teams must track which manufacturing site each submission covers fo' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:actualDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Decision Date' ;
    rdfs:comment 'Calendar date on which the health authority issued its formal regulatory decision (approval, complete response, refusal, withdrawal). Used to measure review cycle time against PDUFA/EMA target dates and track regulatory performance.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Tracking Number' ;
    rdfs:comment 'Official tracking or docket number assigned by the health authority upon receipt of the submission (e.g., FDA STN number, EMA procedure number). Used for all official correspondence and status inquiries with the regulatory agency.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverLetterTitle rdf:type rdf:Property ;
    rdfs:label 'Cover Letter Title' ;
    rdfs:comment 'Title or subject line of the cover letter accompanying this submission, summarizing the purpose and scope of the filing. Provides a human-readable description of the submission intent for regulatory affairs tracking and correspondence management.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdModulesIncluded rdf:type rdf:Property ;
    rdfs:label 'Ctd Modules Included' ;
    rdfs:comment 'Comma-separated list of ICH CTD modules included in this submission (e.g., \'1,2,3,4,5\' for a full NDA; \'1,2\' for an administrative amendment). Modules: 1=Administrative/Regional; 2=Summaries; 3=Quality (CMC); 4=Nonclinical; 5=Clinical. Supports dossier completeness assessment.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of individual documents included in this submission sequence. Used for dossier completeness assessment, submission quality metrics, and workload estimation for health authority reviewers.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dossierFormat rdf:type rdf:Property ;
    rdfs:label 'Dossier Format' ;
    rdfs:comment 'Technical format of the regulatory dossier submitted to the health authority. eCTD (Electronic Common Technical Document) is the current standard; NeeS (Non-eCTD Electronic Submission) and paper are legacy formats. Determines validation and processing requirements.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdOperation rdf:type rdf:Property ;
    rdfs:label 'Ectd Operation' ;
    rdfs:comment 'eCTD lifecycle operation code indicating how this submission sequence modifies the dossier content relative to the prior sequence. New = first submission of a document; Replace = supersedes a prior document; Append = adds to existing content; Delete = removes prior content. Conforms to ICH M8 eCTD specification.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeWaiverGranted rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Granted' ;
    rdfs:comment 'Indicates whether a regulatory user fee waiver or exemption has been granted for this submission (e.g., orphan drug fee waiver, small business waiver, public health waiver). True = fee waiver approved by the health authority.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current workflow state of the submission within the regulatory review lifecycle. Draft = being prepared; Submitted = transmitted to agency; Under Review = agency actively reviewing; Approved = marketing authorization granted; Complete Response = FDA issued CRL requiring additional data; Refused = EMA/MHRA refusal; Withdrawn = applicant withdrew; On Hold = review paused. [ENUM-REF-CANDIDATE: promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medium rdf:type rdf:Property ;
    rdfs:label 'Medium' ;
    rdfs:comment 'Physical or electronic channel used to transmit the submission to the health authority. Electronic Gateway (e.g., FDA ESG, EMA eSubmission Gateway) is the standard; physical media (CD/DVD/USB) and portal submissions are also tracked.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paiRequired rdf:type rdf:Property ;
    rdfs:label 'Pai Required' ;
    rdfs:comment 'Indicates whether a Pre-Approval Inspection (PAI) of manufacturing facilities is required as part of the review of this submission. PAIs verify GMP compliance and data integrity of manufacturing processes prior to approval. True = PAI required.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityDesignation rdf:type rdf:Property ;
    rdfs:label 'Priority Designation' ;
    rdfs:comment 'Special regulatory designation granted to the submission or parent application that confers expedited review or development benefits. Includes FDA Breakthrough Therapy, Fast Track, Priority Review, Accelerated Approval, Orphan Drug designation. Multiple designations may apply; primary designation recorded here.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Calendar date on which the health authority officially acknowledged receipt of the submission. Triggers the start of the regulatory review clock and PDUFA/EMA review timeline. May differ from submission_date due to gateway processing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryPathway rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pathway' ;
    rdfs:comment 'Regulatory review pathway designation assigned to this submission, determining review timelines and procedural requirements. Examples include FDA Standard, Priority Review, Accelerated Approval, Breakthrough Therapy, Fast Track; EMA Conditional Marketing Authorisation, Rolling Review. [ENUM-REF-CANDIDATE: promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDivision rdf:type rdf:Property ;
    rdfs:label 'Review Division' ;
    rdfs:comment 'Name of the health authority review division or committee responsible for evaluating this submission (e.g., FDA CDER Office of Oncology Products, EMA Committee for Medicinal Products for Human Use (CHMP), PMDA Office of New Drug I). Determines reviewer assignment and procedural rules.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Four-digit zero-padded eCTD sequence number uniquely identifying this submission within the parent application lifecycle (e.g., 0000 for initial submission, 0001 for first amendment). Conforms to ICH M8 eCTD technical specification.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Human-readable external submission reference number assigned by the health authority or internal tracking system (e.g., NDA 123456/S-001, EMA/H/C/000123/0001). Used for correspondence and regulatory tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionType rdf:type rdf:Property ;
    rdfs:label 'Submission Type' ;
    rdfs:comment 'Classification of the submission event within the regulatory application lifecycle. Original = initial filing; Supplement = post-approval change; Amendment = pre-approval change; Annual Report = periodic safety/status update; Response = reply to agency information request; Withdrawal = voluntary withdrawal of application. [ENUM-REF-CANDIDATE: original|supplement|amendment|annual_report|response|withdrawal — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Further classification of the submission type providing regulatory granularity (e.g., Prior Approval Supplement, Changes Being Effected Supplement, Type IA Variation, Type IB Variation, Type II Variation). Jurisdiction-specific categorization used for review timeline determination. [ENUM-REF-CANDIDATE: promote to reference product]' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetActionDate rdf:type rdf:Property ;
    rdfs:label 'Target Action Date' ;
    rdfs:comment 'Regulatory target date by which the health authority is committed to completing its review and issuing a decision. For FDA submissions, this is the Prescription Drug User Fee Act (PDUFA) goal date. For EMA, this is the Day 210 opinion date. Critical milestone for commercial planning.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationErrorCount rdf:type rdf:Property ;
    rdfs:label 'Validation Error Count' ;
    rdfs:comment 'Number of technical validation errors identified during eCTD dossier validation. Zero indicates a clean submission. Used to assess submission quality and track remediation effort prior to resubmission.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Technical validation status of the eCTD dossier as assessed by the health authority\'s automated validation tools (e.g., FDA Validation Criteria, EMA eCTD Validation Criteria). Passed = all technical criteria met; Failed = validation errors requiring correction; Waived = validation requirement formally waived.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressId rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Id' ;
    rdfs:comment 'Foreign key linking to masterdata.address. Business justification: health_authority.mailing_address is a plain-text denormalization of a structured address. Normalizing to masterdata.address supports submission portal management, correspondence tracking, and GMP insp' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:acceptedDossierFormats rdf:type rdf:Property ;
    rdfs:label 'Accepted Dossier Formats' ;
    rdfs:comment 'Comma-separated list of submission dossier formats accepted by the health authority (e.g., \'eCTD\', \'NeeS\', \'paper\', \'eCTD v4.0\'). Drives submission preparation and formatting decisions in Veeva Vault RIM and RIMS.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acronym rdf:type rdf:Property ;
    rdfs:label 'Acronym' ;
    rdfs:comment 'Commonly used abbreviation or acronym for the health authority (e.g., \'FDA\', \'EMA\', \'PMDA\', \'MHRA\', \'NMPA\', \'WHO\'). Used in regulatory correspondence, submission tracking, and reporting.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Official full legal name of the health authority agency (e.g., \'U.S. Food and Drug Administration\', \'European Medicines Agency\'). Used as the primary identity label for the agency across all regulatory activities.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Status' ;
    rdfs:comment 'Current operational lifecycle status of the health authority record. \'active\' indicates the agency is currently operational and accepting submissions; \'inactive\' indicates it is no longer operational; \'merged\' indicates it has been absorbed into another agency; \'dissolved\' indicates it has been formally disbanded; \'under_review\' indicates the record is pending validation.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the health authority by its organizational scope and mandate. Distinguishes between national competent authorities (e.g., FDA, MHRA), supranational agencies (e.g., EMA), international organizations (e.g., WHO), regional authorities, and advisory bodies. [ENUM-REF-CANDIDATE: national_competent_authority|supranational_agency|international_organization|regional_authority|advisory_body — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Agency Website Url' ;
    rdfs:comment 'Official public website URL of the health authority (e.g., https://www.fda.gov, https://www.ema.europa.eu). Used for reference, guidance document retrieval, and regulatory intelligence.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blaAccepted rdf:type rdf:Property ;
    rdfs:label 'Bla Accepted' ;
    rdfs:comment 'Indicates whether the health authority accepts Biologics License Application (BLA) submissions or their local equivalent for marketing authorization of biological products, vaccines, and biosimilars.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakthroughDesignationProgram rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Designation Program' ;
    rdfs:comment 'Indicates whether the health authority offers a breakthrough therapy designation or equivalent expedited development program (e.g., FDA Breakthrough Therapy, EMA PRIME scheme, MHRA Innovative Licensing and Access Pathway). Drives early engagement strategy.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmfAccepted rdf:type rdf:Property ;
    rdfs:label 'Dmf Accepted' ;
    rdfs:comment 'Indicates whether the health authority accepts Drug Master File (DMF) submissions for confidential disclosure of manufacturing, processing, packaging, and storage information for drug substances and excipients.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ectdRequired rdf:type rdf:Property ;
    rdfs:label 'Ectd Required' ;
    rdfs:comment 'Indicates whether the health authority mandates submission in Electronic Common Technical Document (eCTD) format as per ICH M8 guideline. Drives submission formatting and Veeva Vault RIM configuration.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAgencyCode rdf:type rdf:Property ;
    rdfs:label 'External Agency Code' ;
    rdfs:comment 'Official external identifier assigned to the health authority by an industry body or cross-reference system (e.g., DUNS number, ISO organization code, or identifier from a regulatory intelligence database). Supports cross-system reconciliation.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpInspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Gmp Inspection Authority' ;
    rdfs:comment 'Indicates whether the health authority has the mandate and capability to conduct Good Manufacturing Practice (GMP) inspections of pharmaceutical manufacturing facilities. Drives inspection readiness and compliance programs.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichMember rdf:type rdf:Property ;
    rdfs:label 'Ich Member' ;
    rdfs:comment 'Indicates whether the health authority is a full member or observer of the International Council for Harmonisation (ICH). ICH membership signals alignment with harmonized technical guidelines for drug registration.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icsrReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Icsr Reporting Required' ;
    rdfs:comment 'Indicates whether the health authority requires Individual Case Safety Report (ICSR) submissions for pharmacovigilance and adverse event reporting. Drives Argus Safety / Oracle AERS configuration for expedited and periodic safety reporting.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indAccepted rdf:type rdf:Property ;
    rdfs:label 'Ind Accepted' ;
    rdfs:comment 'Indicates whether the health authority accepts Investigational New Drug (IND) applications or their local equivalent for clinical trial authorization. Drives IND filing strategy for global clinical development programs.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Scope of regulatory jurisdiction exercised by the health authority — federal (e.g., FDA within the US), national (e.g., MHRA for UK), regional (e.g., state-level agencies), supranational (e.g., EMA for EU member states), or international (e.g., WHO).' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOfSubmission rdf:type rdf:Property ;
    rdfs:label 'Language Of Submission' ;
    rdfs:comment 'Official language(s) required for regulatory submissions to this health authority (e.g., \'English\' for FDA/EMA/MHRA, \'Japanese\' for PMDA, \'Chinese (Simplified)\' for NMPA). Drives translation and localization planning for global submissions.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localRepresentativeRequired rdf:type rdf:Property ;
    rdfs:label 'Local Representative Required' ;
    rdfs:comment 'Indicates whether the health authority requires a local regulatory representative, marketing authorization holder, or in-country agent to be designated for submissions and post-approval activities. Critical for market access planning in jurisdictions like Japan (PMDA) and China (NMPA).' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mutualRecognitionAgreements rdf:type rdf:Property ;
    rdfs:label 'Mutual Recognition Agreements' ;
    rdfs:comment 'Comma-separated list of Mutual Recognition Agreements (MRA) or equivalence arrangements the health authority has with other regulatory bodies (e.g., \'FDA-EMA MRA\', \'PIC/S Member\'). Impacts GMP inspection reliance and submission strategy.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaAccepted rdf:type rdf:Property ;
    rdfs:label 'Nda Accepted' ;
    rdfs:comment 'Indicates whether the health authority accepts New Drug Application (NDA) submissions or their local equivalent (e.g., MAA for EMA, J-NDA for PMDA) for marketing authorization of small molecule drugs.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orphanDrugProgram rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Program' ;
    rdfs:comment 'Indicates whether the health authority operates an orphan drug designation program providing incentives (e.g., market exclusivity, fee waivers, protocol assistance) for rare disease treatments. Relevant for oncology and rare disease therapeutic areas.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paiConducted rdf:type rdf:Property ;
    rdfs:label 'Pai Conducted' ;
    rdfs:comment 'Indicates whether the health authority conducts Pre-Approval Inspections (PAI) of manufacturing facilities as part of the marketing authorization review process. Drives inspection readiness planning.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Official primary contact email address for regulatory correspondence with the health authority. Used for submission inquiries, meeting requests, and formal communications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Official primary telephone number for the health authority\'s regulatory affairs contact office. Includes country dialing code.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityReviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Priority Review Duration Days' ;
    rdfs:comment 'Expedited or priority review clock duration in calendar days for applications granted priority review designation at this health authority (e.g., 180 days for FDA Priority Review, 150 days for EMA accelerated assessment). Supports regulatory strategy for breakthrough therapies.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:psurRequired rdf:type rdf:Property ;
    rdfs:label 'Psur Required' ;
    rdfs:comment 'Indicates whether the health authority requires Periodic Safety Update Reports (PSUR) or Periodic Benefit-Risk Evaluation Reports (PBRER) as part of post-marketing pharmacovigilance obligations. Aligns with ICH E2C(R2) guideline.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this health authority master record was first created in the system. Supports audit trail and data lineage requirements under 21 CFR Part 11 and GDPR.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this health authority master record was most recently modified. Supports change tracking, audit trail, and data currency validation under 21 CFR Part 11.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geopolitical or regulatory region associated with the health authority (e.g., \'North America\', \'European Union\', \'Asia Pacific\', \'Latin America\', \'Middle East & Africa\'). Supports regional regulatory strategy planning and submission portfolio management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory framework or legislation governing the health authority\'s operations (e.g., \'21 CFR Parts 210/211/312/314\' for FDA, \'Directive 2001/83/EC and Regulation 726/2004\' for EMA, \'Pharmaceutical Affairs Act\' for PMDA). Critical for compliance mapping.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsApplicable rdf:type rdf:Property ;
    rdfs:label 'Rems Applicable' ;
    rdfs:comment 'Indicates whether the health authority has a Risk Evaluation and Mitigation Strategy (REMS) or equivalent risk management program framework applicable to submissions. Relevant for FDA and analogous risk management programs at other agencies.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardReviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Standard Review Duration Days' ;
    rdfs:comment 'Standard regulatory review clock duration in calendar days for a standard marketing authorization application at this health authority (e.g., 365 days for FDA standard NDA review, 210 days for EMA centralized procedure). Used for regulatory timeline planning.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Submission Portal Url' ;
    rdfs:comment 'Official URL of the health authority\'s electronic submission portal (e.g., FDA ESG gateway, EMA CESP portal, PMDA eCTD gateway). Used by regulatory affairs teams to route and track electronic submissions.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Agency Code' ;
    rdfs:comment 'Agency identifier code as configured in Veeva Vault Regulatory Information Management (RIM) system. Used to link this master record to submission tracking, dossier management, and regulatory correspondence workflows in Veeva Vault.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessStrategyId rdf:type rdf:Property ;
    rdfs:label 'Access Strategy Id' ;
    rdfs:comment 'Foreign key linking to market.access_strategy. Business justification: Regulatory applications drive market access strategy development; access teams plan reimbursement pathways, HTA submissions, and launch sequencing based on application status and approval timelines fo' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessStrategy .

ind:atcClassificationId rdf:type rdf:Property ;
    rdfs:label 'Atc Classification Id' ;
    rdfs:comment 'Foreign key linking to masterdata.atc_classification. Business justification: ATC classification in regulatory applications determines therapeutic category for health authority review, pricing negotiations, and reimbursement decisions. Required for CTD Module 1 and health econo' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtcClassification .

ind:financeInternalOrderId rdf:type rdf:Property ;
    rdfs:label 'Finance Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Regulatory applications should link to finance internal orders for regulatory program budget tracking and cost allocation. This enables accurate tracking of regulatory affairs costs by application and' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the health authority formally accepted the application for substantive review (i.e., filing acceptance / validation date). Marks the start of the official review clock.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Application Number' ;
    rdfs:comment 'The official application number assigned by the health authority upon receipt of the submission (e.g., NDA 123456, BLA 761234, EMA/H/C/004321). This is the externally-known business identifier for the application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'The full legal name of the company or entity listed as the applicant/sponsor on the regulatory application as filed with the health authority.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory application as tracked in the regulatory information management system. Drives workflow and reporting across regulatory affairs. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|refused|withdrawn|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakthroughTherapyFlag rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy Flag' ;
    rdfs:comment 'Indicates whether the FDA has granted Breakthrough Therapy Designation (BTD) for this application, enabling intensive FDA guidance and rolling review.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fastTrackFlag rdf:type rdf:Property ;
    rdfs:label 'Fast Track Flag' ;
    rdfs:comment 'Indicates whether the FDA has granted Fast Track Designation for this application, facilitating more frequent interactions with FDA and eligibility for rolling review.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadDivisionCode rdf:type rdf:Property ;
    rdfs:label 'Lead Division Code' ;
    rdfs:comment 'The FDA Office/Division or EMA Committee (e.g., CDER, CBER, CHMP, COMP) responsible for reviewing this application. Determines the review team and applicable guidance documents.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newMolecularEntityFlag rdf:type rdf:Property ;
    rdfs:label 'New Molecular Entity Flag' ;
    rdfs:comment 'Indicates whether the active ingredient in this application is a New Chemical Entity (NCE) or New Molecular Entity (NME) that has not previously been approved by the health authority, conferring 5-year data exclusivity in the US.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orphanDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Orphan Designation Flag' ;
    rdfs:comment 'Indicates whether the drug product has received Orphan Drug Designation (ODD) from the FDA or EMA for the indication covered by this application, conferring market exclusivity and fee waivers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paiOutcome rdf:type rdf:Property ;
    rdfs:label 'Pai Outcome' ;
    rdfs:comment 'The outcome classification of the Pre-Approval Inspection (PAI) conducted at the manufacturing site. VAI = Voluntary Action Indicated; OAI = Official Action Indicated (may delay approval).' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paiRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pai Required Flag' ;
    rdfs:comment 'Indicates whether a Pre-Approval Inspection (PAI) of the manufacturing facility has been required or triggered as part of the review of this application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdufaActionDate rdf:type rdf:Property ;
    rdfs:label 'Pdufa Action Date' ;
    rdfs:comment 'The target action date committed by the FDA under the Prescription Drug User Fee Act (PDUFA), or equivalent agency action deadline (e.g., EMA opinion date, PMDA review deadline). Critical milestone for commercial planning.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postApprovalCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Post Approval Commitment Flag' ;
    rdfs:comment 'Indicates whether the approval of this application is subject to post-approval commitments or post-marketing requirements (PMRs/PMCs) imposed by the health authority.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Review Flag' ;
    rdfs:comment 'Indicates whether the application has been granted Priority Review designation by the health authority, entitling it to a shorter review clock (6 months for FDA vs. standard 10 months).' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceProductName rdf:type rdf:Property ;
    rdfs:label 'Reference Product Name' ;
    rdfs:comment 'For ANDA (generic) or biosimilar applications, the name of the reference listed drug (RLD) or reference biological product against which the application is filed. Null for original NDA/BLA applications.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Required Flag' ;
    rdfs:comment 'Indicates whether the FDA has required a Risk Evaluation and Mitigation Strategy (REMS) program as a condition of approval for this application, due to serious safety concerns.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollingReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Rolling Review Flag' ;
    rdfs:comment 'Indicates whether the health authority has granted rolling review, allowing submission and review of completed dossier sections before the full application is submitted.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Vault Document Reference' ;
    rdfs:comment 'The unique document or object identifier assigned to this application record in Veeva Vault RIM, enabling traceability back to the source system of record for the regulatory dossier.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionSequenceId rdf:type rdf:Property ;
    rdfs:label 'Submission Sequence Id' ;
    rdfs:comment 'Unique surrogate identifier for each eCTD submission sequence record within the regulatory application lifecycle.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rimsSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Rims Submission Id' ;
    rdfs:comment 'The native submission record identifier from the source Regulatory Information Management System (RIMS), specifically Veeva Vault RIM, used for cross-system traceability and reconciliation.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'Date on which the health authority formally acknowledged receipt of the submission sequence. Triggers the start of the regulatory review clock for applicable submission types.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time at which the submission sequence was formally approved for filing by the authorized signatory, capturing the electronic signature event per 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the authorized signatory or regulatory affairs head who approved this submission sequence for filing with the health authority.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:croCmoInvolvement rdf:type rdf:Property ;
    rdfs:label 'Cro Cmo Involvement' ;
    rdfs:comment 'Indicates whether a Contract Research Organization (CRO) or Contract Manufacturing Organization (CMO) contributed data or documents to this submission sequence. Relevant for supply chain transparency and regulatory accountability.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctdModule rdf:type rdf:Property ;
    rdfs:label 'Ctd Module' ;
    rdfs:comment 'The primary Common Technical Document (CTD) module addressed by this submission sequence. M1 = Regional Administrative; M2 = Summaries; M3 = Quality (CMC); M4 = Nonclinical; M5 = Clinical. Used for content classification and routing.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecdtLifecycleOperation rdf:type rdf:Property ;
    rdfs:label 'Ecdt Lifecycle Operation' ;
    rdfs:comment 'The eCTD document lifecycle operation applied in this sequence, indicating how the submitted documents relate to prior sequences. Values: new (first submission of a document), replace (supersedes a prior document), append (adds to a prior document), delete (removes a prior document). Aligns with ICH M8 eCTD lifecycle attribute.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecdtVersion rdf:type rdf:Property ;
    rdfs:label 'Ecdt Version' ;
    rdfs:comment 'The version of the Electronic Common Technical Document (eCTD) specification used to structure and validate this submission sequence (e.g., 3.2.2 for legacy, 4.0 for ICH M8 compliant submissions).' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Gateway Tracking Number' ;
    rdfs:comment 'Unique tracking or acknowledgement number assigned by the health authority\'s electronic submission gateway (e.g., FDA ESG acknowledgement number, EMA CESP submission ID) upon receipt of the eCTD package. Used for submission traceability and correspondence.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informationRequestRef rdf:type rdf:Property ;
    rdfs:label 'Information Request Ref' ;
    rdfs:comment 'Reference identifier for the health authority information request, deficiency letter, or complete response letter (CRL) that this submission sequence is responding to. Null if not a response submission.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isResubmission rdf:type rdf:Property ;
    rdfs:label 'Is Resubmission' ;
    rdfs:comment 'Indicates whether this submission sequence is a formal resubmission following a Complete Response Letter (CRL) or refusal, as opposed to an original or routine amendment filing.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageSizeMb rdf:type rdf:Property ;
    rdfs:label 'Package Size Mb' ;
    rdfs:comment 'Total file size of the eCTD submission package in megabytes. Used for submission logistics planning, gateway transmission monitoring, and compliance with health authority file size limits.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdufaGoalDate rdf:type rdf:Property ;
    rdfs:label 'Pdufa Goal Date' ;
    rdfs:comment 'The target action date committed by the FDA under the Prescription Drug User Fee Act (PDUFA) for completing review of this submission. Applicable to NDA/BLA submissions filed with the FDA. Null for non-FDA or non-PDUFA submissions.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryActionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Date' ;
    rdfs:comment 'The date on which the health authority issued a formal regulatory action (approval, complete response letter, refusal, approvable letter) in response to this submission sequence.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryActionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Type' ;
    rdfs:comment 'The type of formal regulatory decision issued by the health authority for this submission sequence. Approval = marketing authorization granted; Complete Response = FDA letter requesting additional information; Approvable/Not Approvable = legacy FDA designations; Refusal = EMA/MHRA refusal of marketing authorization; Withdrawal = application withdrawn.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProcedureType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Procedure Type' ;
    rdfs:comment 'The regulatory procedure under which this submission is filed, particularly relevant for EMA submissions. Centralized = EMA centralized procedure; Decentralized = DCP across multiple EU member states; Mutual Recognition = MRP; National = single country national procedure. Null for FDA submissions.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewClockStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Clock Start Date' ;
    rdfs:comment 'The date on which the regulatory review clock officially begins for this submission sequence, as determined by the health authority. May differ from acknowledgement_date for submissions requiring filing review or completeness assessment.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDescription rdf:type rdf:Property ;
    rdfs:label 'Submission Description' ;
    rdfs:comment 'Free-text narrative description of the purpose and content of this submission sequence, summarizing the regulatory objective (e.g., \'Response to FDA Complete Response Letter dated 2024-03-15 addressing CMC deficiencies in Module 3\').' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the submission sequence reflecting the health authority\'s processing state. Draft = prepared but not yet transmitted; Submitted = transmitted to health authority; Acknowledged = receipt confirmed; Under Review = active regulatory review; Accepted = approved/validated; Refused = rejected by health authority; Withdrawn = retracted by sponsor. [ENUM-REF-CANDIDATE: draft|submitted|acknowledged|under_review|accepted|refused|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the eCTD sequence package was transmitted to or received by the health authority gateway (e.g., FDA ESG, EMA CESP). Distinct from submission_date which captures only the calendar date.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submissionUnitCount rdf:type rdf:Property ;
    rdfs:label 'Submission Unit Count' ;
    rdfs:comment 'Number of submission units (eCTD submission unit packages) included in this sequence. In eCTD v4.0, a sequence may contain multiple submission units each addressing different regulatory activities.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplementCategory rdf:type rdf:Property ;
    rdfs:label 'Supplement Category' ;
    rdfs:comment 'Regulatory category of a supplement submission indicating the level of change and required review pathway. PAS = Prior Approval Supplement; CBE-30 = Changes Being Effected in 30 Days; CBE-0 = Changes Being Effected immediately; Class I/II per EMA variation classification. Null for non-supplement submissions.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Unique system-generated identifier for each regulatory milestone record. Primary key for the regulatory_milestone data product.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandPlanId rdf:type rdf:Property ;
    rdfs:label 'Brand Plan Id' ;
    rdfs:comment 'Foreign key linking to commercial.brand_plan. Business justification: Regulatory milestones (PDUFA dates, approval dates, submission dates) are critical inputs to brand plan timelines and launch readiness planning. The \'milestone-gated brand plan\' process is a named con' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandPlan .

ind:postApprovalCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Post Approval Commitment Id' ;
    rdfs:comment 'Foreign key linking to regulatory.post_approval_commitment. Business justification: The milestone table has a post_approval_commitment_due_date attribute, indicating milestones are used to track PAC due dates. Normalizing this by adding post_approval_commitment_id FK enables direct n' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PostApprovalCommitment .

ind:productRecallId rdf:type rdf:Property ;
    rdfs:label 'Product Recall Id' ;
    rdfs:comment 'Foreign key linking to supply.product_recall. Business justification: Recall management milestones (recall initiation, health authority notification deadline, effectiveness check, recall closure) are tracked in regulatory milestone systems. Linking milestone to product_' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRecall .

ind:psurId rdf:type rdf:Property ;
    rdfs:label 'Psur Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.psur. Business justification: PSUR submissions are regulatory milestones with defined due dates tracked in submission planning. Real business process: milestone planning includes PSUR data lock points and submission deadlines. Req' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Psur .

ind:rmpId rdf:type rdf:Property ;
    rdfs:label 'Rmp Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.rmp. Business justification: RMP submissions and updates are regulatory milestones tracked in product lifecycle planning. Real business process: milestone tracking for RMP version submissions at approval, variations, and periodic' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rmp .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to commercial.territory. Business justification: Regulatory milestones (approvals, label updates) trigger territory-level commercial activities like launch preparation, sales training, and call plan updates for field force readiness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:validationId rdf:type rdf:Property ;
    rdfs:label 'Validation Id' ;
    rdfs:comment 'Foreign key linking to quality.validation. Business justification: Regulatory milestones track validation completion dates (PPQ, process validation, cleaning validation) critical for submission readiness. Links regulatory timeline management to quality validation exe' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Validation .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The actual date on which the regulatory milestone was achieved or completed. Null if the milestone has not yet been reached. Compared against planned_date and revised_target_date to calculate schedule variance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes documenting the outcome, key decisions, or observations recorded at the time of milestone completion. Captures health authority feedback, meeting outcomes, or approval conditions relevant to this milestone.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crlReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Crl Receipt Date' ;
    rdfs:comment 'Date on which a Complete Response Letter (CRL) was received from the FDA, indicating the agency cannot approve the application in its current form. Null if no CRL has been issued. Critical for tracking resubmission timelines.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Documented reason for any delay in achieving the milestone relative to the planned or revised target date. Captures root cause categories such as health authority information requests, manufacturing issues, clinical data gaps, or strategic reprioritization.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Indicates whether this milestone is on the critical path of the regulatory project plan. True = milestone is critical path; any delay directly impacts the overall regulatory timeline and potential approval date.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'Scheduled or actual date of the health authority meeting (e.g., End-of-Phase 2 meeting, pre-NDA meeting, Advisory Committee meeting). Applicable for meeting-type milestones.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'Classification of the health authority meeting associated with this milestone. FDA meeting types: Type A (dispute resolution/clinical hold), Type B (pre-IND, EOP1, EOP2, pre-NDA/BLA), Type C (other). ADCOM = Advisory Committee Meeting. [ENUM-REF-CANDIDATE: Type_A|Type_B|Type_C|ADCOM|pre_IND|EOP1|EOP2|pre_NDA|pre_BLA|scientific_advice|other — promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Category' ;
    rdfs:comment 'Regulatory lifecycle phase category to which this milestone belongs. Enables grouping and reporting by development phase: pre-IND activities, IND phase, pre-NDA/BLA, NDA/BLA submission and review, MAA, post-approval, or lifecycle management. [ENUM-REF-CANDIDATE: pre_ind|ind|pre_nda_bla|nda_bla|maa|post_approval|lifecycle — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the type of regulatory milestone (e.g., IND_FILING, EOP2_MTG, NDA_FILING, PDUFA_DATE, ADCOM_MTG, CRL_RECEIPT, APPROVAL, PAC_DUE). Used for systematic tracking and reporting across programs.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Detailed narrative description of the regulatory milestone, including scope, deliverables, and any specific health authority requirements or conditions associated with achieving this milestone.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name of the regulatory milestone (e.g., \'IND Filing Date\', \'End-of-Phase 2 Meeting\', \'NDA Filing Date\', \'PDUFA Date\', \'Advisory Committee Meeting\', \'Complete Response Letter Receipt\', \'Approval Date\', \'Post-Approval Commitment Due Date\').' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current completion status of the regulatory milestone. \'planned\' = scheduled but not yet started; \'in_progress\' = activities underway; \'completed\' = milestone achieved; \'delayed\' = past target date without completion; \'cancelled\' = milestone no longer applicable; \'on_hold\' = temporarily suspended.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'High-level classification of the milestone type. \'submission\' = filing of a dossier or amendment; \'meeting\' = health authority meeting (e.g., EOP2, pre-NDA); \'review\' = agency review action; \'decision\' = approval, refusal, or CRL; \'commitment\' = post-approval commitment; \'inspection\' = PAI or GMP inspection; \'correspondence\' = formal regulatory correspondence. [ENUM-REF-CANDIDATE: submission|meeting|review|decision|commitment|inspection|correspondence — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paiDate rdf:type rdf:Property ;
    rdfs:label 'Pai Date' ;
    rdfs:comment 'Date of the Pre-Approval Inspection (PAI) conducted by the health authority at the manufacturing facility prior to granting marketing approval. Applicable for PAI-type milestones. Null for non-inspection milestones.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pdufaDate rdf:type rdf:Property ;
    rdfs:label 'Pdufa Date' ;
    rdfs:comment 'The FDA-assigned Prescription Drug User Fee Act (PDUFA) action date by which the FDA commits to completing its review of an NDA or BLA. Applicable only to FDA submissions. Null for non-FDA applications or non-applicable milestone types.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'The originally planned or target date for achieving this regulatory milestone, as established in the regulatory project plan. Used for baseline tracking and variance analysis against actual completion.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityReviewDesignation rdf:type rdf:Property ;
    rdfs:label 'Priority Review Designation' ;
    rdfs:comment 'FDA or health authority review designation assigned to the application associated with this milestone. Affects review timelines and PDUFA dates. \'priority\' = 6-month review; \'standard\' = 10-month review; \'breakthrough\' = Breakthrough Therapy Designation; \'accelerated\' = Accelerated Approval; \'fast_track\' = Fast Track Designation; \'orphan\' = Orphan Drug Designation. [ENUM-REF-CANDIDATE: standard|priority|breakthrough|accelerated|fast_track|orphan|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOwner rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner' ;
    rdfs:comment 'Name or identifier of the regulatory affairs professional or team lead responsible for managing and delivering this milestone. Used for accountability tracking and workload management in regulatory project plans.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedTargetDate rdf:type rdf:Property ;
    rdfs:label 'Revised Target Date' ;
    rdfs:comment 'Most recently revised target date for the milestone, updated when the original planned date changes due to program delays, strategy shifts, or health authority feedback. Distinct from planned_date (baseline) to enable schedule variance tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Number of calendar days between the planned_date and actual_date (or current date if not yet completed). Positive value indicates delay; negative value indicates early completion. Supports regulatory timeline performance reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veevaVaultRecordReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Record Reference' ;
    rdfs:comment 'The unique record identifier from Veeva Vault RIM (Regulatory Information Management) system for this milestone. Enables bidirectional traceability between the lakehouse silver layer and the source system of record.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalId rdf:type rdf:Property ;
    rdfs:label 'Approval Id' ;
    rdfs:comment 'Unique surrogate identifier for the regulatory approval record. Primary key for the approval data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Approval .

ind:mahLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Mah Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: A Marketing Authorization is granted to a specific legal entity (the MAH). Tracking the MAH legal entity on each approval is fundamental for post-approval compliance, transfer of ownership transaction' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:marketCountryId rdf:type rdf:Property ;
    rdfs:label 'Market Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Market authorization country defines the regulatory jurisdiction, labeling requirements, pharmacovigilance obligations, and commercial rights. Essential for global regulatory strategy and lifecycle ma' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:reimbursementPolicyId rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Policy Id' ;
    rdfs:comment 'Foreign key linking to market.reimbursement_policy. Business justification: Regulatory approval is the direct legal basis for reimbursement policy creation. Reimbursement authorities cite the approval number and conditions when establishing coverage scope. Pharma market acces' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReimbursementPolicy .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Externally-known unique identifier assigned by the health authority for this approval (e.g., NDA 123456, EU/1/20/1234, PMDA approval number). This is the official regulatory reference number.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory approval. Active indicates the approval is in force; withdrawn/revoked indicates the marketing authorization has been removed; suspended indicates temporary halt pending review.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'Classification of the regulatory approval pathway or designation granted. Full approval indicates standard review; accelerated/conditional/provisional indicate expedited pathways with post-approval commitments. [ENUM-REF-CANDIDATE: full|accelerated|conditional|provisional|priority_review|breakthrough|orphan|fast_track — promote to reference product]' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDosageForm rdf:type rdf:Property ;
    rdfs:label 'Approved Dosage Form' ;
    rdfs:comment 'The pharmaceutical dosage form approved for marketing (e.g., tablet, capsule, injection, oral solution, transdermal patch). Corresponds to the Finished Dosage Form (FDF) as specified in the approved label.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedPatientPopulation rdf:type rdf:Property ;
    rdfs:label 'Approved Patient Population' ;
    rdfs:comment 'Description of the patient population for whom the drug is approved, including age group, disease stage, prior treatment requirements, and any biomarker or genetic criteria (e.g., \'adults ≥18 years with EGFR-mutated NSCLC\').' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedRouteOfAdministration rdf:type rdf:Property ;
    rdfs:label 'Approved Route Of Administration' ;
    rdfs:comment 'The approved route by which the drug product is administered to patients (e.g., oral, intravenous, subcutaneous, intramuscular, topical, inhalation). As specified in the approved product label.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedStrength rdf:type rdf:Property ;
    rdfs:label 'Approved Strength' ;
    rdfs:comment 'The approved dose strength(s) of the Active Pharmaceutical Ingredient (API) in the drug product (e.g., \'10 mg\', \'100 mg/5 mL\', \'0.5 mg/mL\'). Multiple strengths may be listed as a delimited string.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Reference' ;
    rdfs:comment 'Document reference number or identifier for the official approval certificate issued by the health authority. Used to locate the physical or electronic certificate in the regulatory document management system (e.g., Veeva Vault RIM).' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditions rdf:type rdf:Property ;
    rdfs:label 'Conditions' ;
    rdfs:comment 'Specific conditions, restrictions, or obligations attached to the approval by the health authority. Includes Risk Evaluation and Mitigation Strategy (REMS) requirements, restricted distribution programs, mandatory monitoring, or other conditions of use.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasRems rdf:type rdf:Property ;
    rdfs:label 'Has Rems' ;
    rdfs:comment 'Indicates whether a Risk Evaluation and Mitigation Strategy (REMS) program is required as a condition of this approval. True if REMS is mandated by FDA; False otherwise.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelVersion rdf:type rdf:Property ;
    rdfs:label 'Label Version' ;
    rdfs:comment 'Version identifier of the approved product label (prescribing information / Summary of Product Characteristics) at the time of approval. Used to track label revisions and ensure current label compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:letterDate rdf:type rdf:Property ;
    rdfs:label 'Letter Date' ;
    rdfs:comment 'Date of the official approval letter issued by the health authority. May differ from the approval_date in cases where the letter is issued after the formal approval decision.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orphanDrugDesignation rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Designation' ;
    rdfs:comment 'Indicates whether the approved drug product holds orphan drug designation for the approved indication. Orphan designation confers market exclusivity and regulatory incentives for rare disease treatments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pediatricIndication rdf:type rdf:Property ;
    rdfs:label 'Pediatric Indication' ;
    rdfs:comment 'Indicates whether the approval includes a pediatric indication or pediatric labeling. Relevant for tracking compliance with Pediatric Research Equity Act (PREA) and Best Pharmaceuticals for Children Act (BPCA) requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postApprovalCommitmentCount rdf:type rdf:Property ;
    rdfs:label 'Post Approval Commitment Count' ;
    rdfs:comment 'Number of post-approval commitments (PACs) or post-marketing requirements (PMRs) imposed by the health authority as conditions of this approval. Drives tracking of outstanding regulatory obligations.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryRegion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region' ;
    rdfs:comment 'Regulatory region or jurisdiction grouping for the approval. Used for regional reporting and portfolio management (US=FDA, EU=EMA, JP=PMDA, CN=NMPA, UK=MHRA, CA=Health Canada, AU=TGA, ROW=Rest of World). [ENUM-REF-CANDIDATE: US|EU|JP|CN|UK|CA|AU|ROW — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haInteractionId rdf:type rdf:Property ;
    rdfs:label 'Ha Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each health authority interaction record in the silver layer lakehouse. Primary key for this data product. Entity role: TRANSACTION_HEADER — represents a discrete formal communication or meeting event with a health authority, with its own lifecycle, participants, and outcomes.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetySignalId rdf:type rdf:Property ;
    rdfs:label 'Safety Signal Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.safety_signal. Business justification: Health authority meetings (Type C, scientific advice) frequently discuss emerging safety signals and required regulatory actions. Real business process: signal detection → request meeting → discuss be' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetySignal .

ind:agencyContactName rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Name' ;
    rdfs:comment 'Name of the primary health authority contact or reviewer assigned to this interaction (e.g., FDA project manager, EMA rapporteur, PMDA reviewer). Enables relationship management and continuity tracking across interactions.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Reference Number' ;
    rdfs:comment 'The official reference or tracking number assigned by the health authority to this specific interaction or correspondence (e.g., FDA meeting request confirmation number, EMA scientific advice case number, MHRA correspondence reference). Distinct from the company\'s internal interaction_reference_number.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreedOutcomesSummary rdf:type rdf:Property ;
    rdfs:label 'Agreed Outcomes Summary' ;
    rdfs:comment 'Summary of agreements, agency positions, commitments, and conclusions reached during or resulting from this health authority interaction. For meetings, captures agreed minutes content. For written correspondence, captures the agency\'s decision or position. Critical for regulatory strategy and post-meeting action tracking.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Briefing Document Reference' ;
    rdfs:comment 'Document reference number or Veeva Vault document ID for the briefing document, background package, or information package submitted to the health authority in preparation for or in response to this interaction. Links to the eTMF/RIM document management system.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates the direction of the communication: inbound (initiated by the health authority, e.g., information request, deficiency letter), outbound (initiated by the company, e.g., meeting request, response letter), or bilateral (mutual, e.g., formal meeting). Essential for tracking response obligations and deadlines.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discussionTopicsSummary rdf:type rdf:Property ;
    rdfs:label 'Discussion Topics Summary' ;
    rdfs:comment 'A structured summary of the key topics, questions, and agenda items discussed or addressed in this health authority interaction. For meetings, captures the agenda items. For written correspondence, summarizes the subject matter. Business-confidential as it contains regulatory strategy information.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions Required' ;
    rdfs:comment 'Indicates whether this interaction generated one or more follow-up action items that require tracking and completion (e.g., additional data requests, protocol amendments, label negotiations, post-approval commitments). Drives workflow routing in the regulatory affairs team.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'The deadline by which all follow-up actions arising from this interaction must be completed. Null if follow_up_actions_required is False or if no specific deadline was established. Used for regulatory affairs workload planning and compliance monitoring.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthAuthorityDivision rdf:type rdf:Property ;
    rdfs:label 'Health Authority Division' ;
    rdfs:comment 'The specific division, office, or committee within the health authority responsible for this interaction (e.g., FDA CDER Office of Oncology Products, EMA Committee for Medicinal Products for Human Use (CHMP), PMDA Office of New Drug I). Enables granular tracking of agency relationships and division-specific regulatory strategies.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'The principal real-world date on which the interaction occurred — the meeting date for in-person/teleconference interactions, or the date a written communication was received or sent. Serves as the BUSINESS_EVENT_TIMESTAMP (date precision) for this transaction. For written correspondence, this is the document date on the letter or communication.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionFormat rdf:type rdf:Property ;
    rdfs:label 'Interaction Format' ;
    rdfs:comment 'The modality or format through which the health authority interaction took place. Distinguishes between in-person meetings, teleconferences, videoconferences, hybrid formats, and written-only communications. Critical for meeting management and regulatory strategy documentation.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Interaction Reference Number' ;
    rdfs:comment 'Externally-known tracking number or correspondence control number assigned to this interaction, either by the health authority (e.g., FDA meeting request number, EMA procedure number) or by the company\'s RIMS/Veeva Vault RIM system. Serves as the BUSINESS_IDENTIFIER for this transaction. Used for cross-referencing with agency correspondence and eCTD submissions.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle state of the health authority interaction record. Tracks the workflow from initial drafting through scheduling, execution, and closure. \'Overdue\' indicates a response deadline has been missed. Serves as the LIFECYCLE_STATUS for this transaction header. [ENUM-REF-CANDIDATE: draft|submitted|scheduled|in_progress|completed|cancelled|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the health authority interaction by formal category. Covers FDA meeting types (Type A, Type B, Type B EOP, Type C), EMA scientific advice, pre-submission meetings, advisory committee meetings, written correspondence types (information request, complete response letter, deficiency letter, acknowledgment letter, approval letter, agency query, general correspondence), and PAI interactions. [ENUM-REF-CANDIDATE: type_a_meeting|type_b_meeting|type_b_eop_meeting|type_c_meeting|scientific_advice|pre_submission_meeting|advisory_committee|information_request|complete_response_letter|deficiency_letter|acknowledgment_letter|approval_letter|agency_query|general_correspondence|pai_interaction — promote to reference product]' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingCategory rdf:type rdf:Property ;
    rdfs:label 'Meeting Category' ;
    rdfs:comment 'For meeting-type interactions, the formal FDA meeting category (Type A: dispute resolution/clinical hold; Type B: pre-IND, end-of-phase, pre-NDA/BLA; Type C: all others) or EMA scientific advice category. Drives PDUFA response timeline obligations. Set to \'not_applicable\' for written correspondence interactions.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Minutes Document Reference' ;
    rdfs:comment 'Document reference number or Veeva Vault document ID for the official meeting minutes or written record of the interaction outcome. For written correspondence, references the agency letter or response document. Null for interactions where minutes are not yet finalized.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paiRelated rdf:type rdf:Property ;
    rdfs:label 'Pai Related' ;
    rdfs:comment 'Indicates whether this interaction is associated with a Pre-Approval Inspection (PAI) by the health authority, including inspection scheduling, outcome discussions, or corrective action follow-up. Enables filtering of PAI-related regulatory communications.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of participants (combined company and agency attendees) in this interaction. Applicable primarily to meeting-type interactions. Used for meeting logistics and engagement analytics.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdufaClockImpact rdf:type rdf:Property ;
    rdfs:label 'Pdufa Clock Impact' ;
    rdfs:comment 'Indicates whether this interaction has an impact on the PDUFA review clock (e.g., a complete response letter resets the clock; an information request may pause it). True if the interaction affects the regulatory review timeline clock. Applicable to FDA interactions only; False or null for non-FDA interactions.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remsRelated rdf:type rdf:Property ;
    rdfs:label 'Rems Related' ;
    rdfs:comment 'Indicates whether this health authority interaction is related to a Risk Evaluation and Mitigation Strategy (REMS) program, including REMS design, modification, assessment, or compliance discussions. Enables filtering of REMS-specific regulatory communications.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Regulatory deadline by which the company must respond to an inbound health authority communication (e.g., information request, deficiency letter, complete response letter). Critical for compliance monitoring and PDUFA/EMA clock management. Null for outbound-only interactions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Actual date on which the company submitted its response to the health authority for inbound communications. Compared against response_due_date to assess timeline compliance. Null if no response has been submitted yet.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseTimelineCompliant rdf:type rdf:Property ;
    rdfs:label 'Response Timeline Compliant' ;
    rdfs:comment 'Indicates whether the company\'s response to this health authority interaction was submitted within the required regulatory deadline (response_due_date). True if response_submitted_date is on or before response_due_date. Null if no response is required or if the response has not yet been submitted.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The originally scheduled or planned date for the interaction, particularly for meetings. Distinct from interaction_date (actual occurrence date) to enable tracking of rescheduling events and planning accuracy. Applicable primarily to meeting-type interactions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'The native record identifier from the source system of record (Veeva Vault RIM correspondence or meeting module document ID) from which this interaction record was ingested. Enables traceability back to the operational system for audit and reconciliation purposes.' ;
    rdfs:domain ind:HaInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmfId rdf:type rdf:Property ;
    rdfs:label 'Dmf Id' ;
    rdfs:comment 'Unique surrogate identifier for the Drug Master File (DMF) record in the regulatory data product. Primary key for the dmf entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dmf .

ind:holderBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Holder Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: DMF holders are often external suppliers or CMOs who are business partners in the ERP/MDM system. Linking DMF to business_partner enables supplier qualification tracking, GMP certificate management, a' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:holderLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Holder Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: DMF holders are legal entities that own drug master files. Regulatory compliance requires tracking the legal entity for authorization letters, annual updates, and cross-referencing in NDAs/ANDAs. Hold' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:manufacturingPlantId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: dmf.manufacturing_site_name is a plain-text denormalization of the plant. DMFs are site-specific regulatory filings; a proper FK to masterdata.plant enables GMP inspection scheduling, PAI readiness tr' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:manufacturingSiteCountryId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: DMF manufacturing site jurisdiction determines applicable GMP standards, inspection authority, and regulatory pathway. Critical for CMC assessment and supply chain risk management. Manufacturing_site_' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of amendments submitted to the health authority for this DMF since the original filing date. Reflects the change history and regulatory maintenance activity for the DMF.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationLetterDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Letter Date' ;
    rdfs:comment 'Date on which the most recent Letter of Authorization (LoA) was issued by the DMF holder to the referencing applicant. Null if no authorization letter has been issued.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationLetterIssued rdf:type rdf:Property ;
    rdfs:label 'Authorization Letter Issued' ;
    rdfs:comment 'Indicates whether the DMF holder has issued a Letter of Authorization (LoA) to the referencing applicant, granting the health authority permission to review the confidential DMF contents in support of an NDA, BLA, or ANDA submission.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmcSection rdf:type rdf:Property ;
    rdfs:label 'Cmc Section' ;
    rdfs:comment 'Identifies the specific Chemistry, Manufacturing, and Controls (CMC) section of the eCTD/CTD dossier (Module 3) to which this DMF contributes. Used to map DMF content to the corresponding CTD section in NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityCommitment rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Commitment' ;
    rdfs:comment 'Indicates whether the DMF holder has provided a formal confidentiality commitment to the referencing company, ensuring that proprietary manufacturing information disclosed in the DMF will not be shared beyond the regulatory review context.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deficiencyLetterReceived rdf:type rdf:Property ;
    rdfs:label 'Deficiency Letter Received' ;
    rdfs:comment 'Indicates whether the health authority has issued a deficiency letter (also known as a Complete Response Letter or information request) identifying gaps or issues in the DMF that must be addressed before the referencing application can be approved.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deficiencyResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Deficiency Response Due Date' ;
    rdfs:comment 'Deadline by which the DMF holder must respond to a deficiency letter issued by the health authority. Null if no deficiency letter has been received. Critical for regulatory timeline management.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalOwner rdf:type rdf:Property ;
    rdfs:label 'Internal Owner' ;
    rdfs:comment 'Name or employee identifier of the internal regulatory affairs professional responsible for managing this DMF relationship, tracking updates, and coordinating authorization letters with the DMF holder.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAnnualUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Annual Update Date' ;
    rdfs:comment 'Date of the most recent annual update submitted to the health authority to confirm the DMF remains current and accurate. FDA requires annual updates under 21 CFR 314.420(c). Failure to update may result in DMF inactivation.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paiStatus rdf:type rdf:Property ;
    rdfs:label 'Pai Status' ;
    rdfs:comment 'Current status of the Pre-Approval Inspection (PAI) for the manufacturing site or process covered by this DMF. PAI is conducted by FDA or other health authorities prior to approval of an NDA/BLA referencing this DMF. [ENUM-REF-CANDIDATE: not_initiated|scheduled|completed|passed|failed|pending_response — promote to reference product]' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Internal classification of the strategic importance of this DMF to the company\'s product portfolio and supply chain. Critical indicates sole-source supplier for a marketed product; high indicates key supplier for pipeline assets; medium/low for non-critical materials.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Detailed description of the subject matter covered by the DMF, such as the specific API, excipient, packaging component, or manufacturing site. Aligns with the \'Subject of DMF\' field in FDA eCTD submissions.' ;
    rdfs:domain ind:Dmf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelId rdf:type rdf:Property ;
    rdfs:label 'Label Id' ;
    rdfs:comment 'Unique surrogate identifier for each approved product label record in the regulatory label management system. Primary key for the label data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Label .

ind:priorVersionLabelId rdf:type rdf:Property ;
    rdfs:label 'Prior Version Label Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding label version that this record supersedes. Enables reconstruction of the complete label amendment history chain for a given product-market-language combination.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Label .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Labels reference approved specifications (strength, dosage form, storage conditions). Ensures label claims match approved quality specifications—critical for regulatory compliance and prevents label/s' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:valueDossierId rdf:type rdf:Property ;
    rdfs:label 'Value Dossier Id' ;
    rdfs:comment 'Foreign key linking to market.value_dossier. Business justification: Value dossiers are built around approved label claims, indications, and clinical data. The label version is the regulatory anchor for value dossier content. Pharma HEOR teams track which label version' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ValueDossier .

ind:affectedSections rdf:type rdf:Property ;
    rdfs:label 'Affected Sections' ;
    rdfs:comment 'Comma-separated list of label sections modified in this version (e.g., \'Warnings and Precautions, Adverse Reactions, Dosage and Administration\'). Enables targeted review of changes and supports regulatory correspondence tracking.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackBoxWarning rdf:type rdf:Property ;
    rdfs:label 'Black Box Warning' ;
    rdfs:comment 'Indicates whether this label version contains an FDA Boxed Warning (Black Box Warning) — the most serious warning required by the FDA for drugs with significant risk of serious or life-threatening adverse effects. True = boxed warning present; False = no boxed warning.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business reason driving the label change for this version. Safety Update: new safety information (e.g., new adverse event, SUSAR); New Indication: addition of a new approved therapeutic indication; Dosage Modification: change to dosing regimen; Contraindication Update: new or revised contraindications; Drug Interaction Update: new drug-drug interaction data; Pediatric/Geriatric/Pregnancy Labeling: population-specific updates; Administrative Update: non-clinical administrative corrections. [ENUM-REF-CANDIDATE: safety_update|new_indication|dosage_modification|contraindication_update|drug_interaction_update|pediatric_labeling|geriatric_labeling|pregnancy_labeling|administrative_update — promote to reference product]' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the type of change that resulted in this label version. Agency-initiated: required by health authority; Company-initiated: proposed by the marketing authorization holder; Labeling Supplement: formal supplement submission; Prior Approval Supplement (PAS): requires FDA approval before implementation; Changes Being Effected (CBE): can be implemented before FDA approval; Annual Report: minor changes reported annually. [ENUM-REF-CANDIDATE: agency_initiated|company_initiated|labeling_supplement|prior_approval_supplement|cbee|annual_report — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDeadline rdf:type rdf:Property ;
    rdfs:label 'Implementation Deadline' ;
    rdfs:comment 'Regulatory or company-mandated deadline by which the new label version must be implemented on marketed product packaging. Critical for compliance tracking, especially for safety-driven label changes with mandatory implementation timelines.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Operational status of the label implementation across markets and packaging lines. Pending: implementation not yet started; In Progress: packaging/artwork updates underway; Implemented: new label in use on marketed product; Overdue: implementation deadline passed without completion; Not Applicable: label change does not require physical implementation.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentVersion rdf:type rdf:Property ;
    rdfs:label 'Is Current Version' ;
    rdfs:comment 'Indicates whether this label record represents the currently approved and active version for the given product, market, language, and label type combination. True = current approved version; False = historical/superseded version. Enables efficient querying of the current label without date-range filtering.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelNumber rdf:type rdf:Property ;
    rdfs:label 'Label Number' ;
    rdfs:comment 'Externally-known unique business identifier for the label document, typically assigned by the regulatory information management system (RIMS) or Veeva Vault RIM (e.g., LBL-2024-00123). Used for cross-system traceability.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelType rdf:type rdf:Property ;
    rdfs:label 'Label Type' ;
    rdfs:comment 'Classification of the label document by its regulatory format and intended audience. Prescribing Information (PI) and Package Insert (PI) are US formats; Summary of Product Characteristics (SmPC) is the EU/EMA format; Patient Information Leaflet (PIL) is the patient-facing EU document; Medication Guide and Instructions for Use (IFU) are FDA-specific formats.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'IETF BCP 47 / ISO 639 language code for the language of this label version (e.g., en, fr, de, ja, zh-CN). Supports multi-language label management across global markets.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Code' ;
    rdfs:comment 'FDA-assigned National Drug Code (NDC) for the drug product associated with this label. The NDC is a unique 10-digit, 3-segment number identifying the labeler, product, and trade package size. Applicable for US market labels only.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Brand/trade name of the drug product as it appears on this label version. Captured directly on the label record to preserve the exact name at the time of approval, which may differ from the current master product name.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Spl Document Reference' ;
    rdfs:comment 'FDA-assigned UUID for the Structured Product Labeling (SPL) document submitted to the FDA DailyMed system. Unique identifier for the SPL XML document in the FDA labeling repository. Applicable for US market labels only.' ;
    rdfs:domain ind:Label ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'Date on which this label version was superseded by a newer approved version. Null for the currently active label. Enables full historical label version tracking and compliance audit trails.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelChangeId rdf:type rdf:Property ;
    rdfs:label 'Label Change Id' ;
    rdfs:comment 'Unique surrogate identifier for each label change record in the regulatory labeling lifecycle management system.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelChange .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_capa. Business justification: Safety-driven label changes often originate from quality issues (deviations, complaints, stability failures) requiring CAPAs. Links pharmacovigilance-driven labeling to root cause corrective actions—c' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:coverageDecisionId rdf:type rdf:Property ;
    rdfs:label 'Coverage Decision Id' ;
    rdfs:comment 'Foreign key linking to market.coverage_decision. Business justification: Safety-driven label changes (black box warnings, contraindications, REMS additions) trigger mandatory payer coverage policy reviews and updates to prior authorization criteria, directly impacting form' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoverageDecision .

ind:mlrReviewId rdf:type rdf:Property ;
    rdfs:label 'Mlr Review Id' ;
    rdfs:comment 'Foreign key linking to commercial.mlr_review. Business justification: Label changes directly trigger MLR re-review of all affected promotional materials. The \'label-change-driven MLR review\' is a named regulatory-commercial compliance process — pharma companies must upd' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MlrReview .

ind:primaryLabelDocumentLabelId rdf:type rdf:Property ;
    rdfs:label 'Primary Label Document Label Id' ;
    rdfs:comment 'Document management system identifier (e.g., Veeva Vault document ID) for the approved label document associated with this change, enabling direct retrieval of the label text from the document management system.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Label .

ind:variationId rdf:type rdf:Property ;
    rdfs:label 'Variation Id' ;
    rdfs:comment 'Foreign key linking to regulatory.variation. Business justification: Post-approval variations (Type IA, IB, II, supplements) frequently mandate label changes. The variation table has an is_labeling_change flag confirming this relationship. Adding variation_id to label_' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Variation .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed narrative description of the specific modifications made to the product label, including the nature of the change, the scientific or safety rationale, and the specific text added, removed, or modified.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'Externally-known business identifier for the label change, used for cross-referencing with regulatory submissions, health authority correspondence, and internal change control systems. Format: LC-YYYY-NNNNNN.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRationale rdf:type rdf:Property ;
    rdfs:label 'Change Rationale' ;
    rdfs:comment 'Scientific, clinical, or regulatory rationale supporting the label change, including references to clinical study data, pharmacovigilance signals, or health authority directives that justify the modification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle status of the label change record, tracking progression from initial drafting through regulatory approval to market implementation. [ENUM-REF-CANDIDATE: draft|pending_approval|submitted|approved|implemented|superseded|withdrawn — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for additional notes, internal commentary, or contextual information related to the label change that does not fit into structured fields, such as negotiation history with health authorities or implementation challenges.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceReference rdf:type rdf:Property ;
    rdfs:label 'Correspondence Reference' ;
    rdfs:comment 'Reference number or identifier for the health authority correspondence (e.g., FDA Complete Response Letter, EMA Day 120 List of Questions) that directed or acknowledged this label change.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorType rdf:type rdf:Property ;
    rdfs:label 'Initiator Type' ;
    rdfs:comment 'Indicates whether the label change was initiated by the company (e.g., based on new clinical data or pharmacovigilance signal) or mandated by a health authority (e.g., FDA, EMA directive or post-approval commitment).' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlackBoxWarning rdf:type rdf:Property ;
    rdfs:label 'Is Black Box Warning' ;
    rdfs:comment 'Indicates whether this label change includes the addition, modification, or removal of a black box warning (boxed warning), which is the FDA\'s most serious warning for drug safety risks.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPvDriven rdf:type rdf:Property ;
    rdfs:label 'Is Pv Driven' ;
    rdfs:comment 'Indicates whether this label change was driven by a pharmacovigilance signal, safety review, or post-market surveillance finding, as opposed to a new clinical indication or administrative update.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemsRelated rdf:type rdf:Property ;
    rdfs:label 'Is Rems Related' ;
    rdfs:comment 'Indicates whether this label change is associated with a Risk Evaluation and Mitigation Strategy (REMS) program requirement, such as a new REMS, REMS modification, or REMS-driven labeling update.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorLabelVersion rdf:type rdf:Property ;
    rdfs:label 'Prior Label Version' ;
    rdfs:comment 'Version number of the product label that was in effect immediately before this change, enabling traceability of label evolution and comparison of changes.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'The date on which the internal cross-functional review of the label change was completed, including sign-off from Regulatory Affairs, Medical Affairs, Pharmacovigilance, and Legal.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sectionsModified rdf:type rdf:Property ;
    rdfs:label 'Sections Modified' ;
    rdfs:comment 'Comma-delimited list of label sections that were modified in this change (e.g., \'Warnings and Precautions, Dosage and Administration, Adverse Reactions\'). Aligned with the Physician Labeling Rule (PLR) section structure for US labels and SmPC sections for EU labels.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Classification of the urgency with which the label change must be processed and implemented, based on the severity of the safety signal or regulatory requirement. Urgent and immediate changes may require expedited health authority notification.' ;
    rdfs:domain ind:LabelChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsId rdf:type rdf:Property ;
    rdfs:label 'Rems Id' ;
    rdfs:comment 'Unique surrogate identifier for the REMS program master record in the Pharmaceuticals data lakehouse.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rems .

ind:patientAccessProgramId rdf:type rdf:Property ;
    rdfs:label 'Patient Access Program Id' ;
    rdfs:comment 'Foreign key linking to market.patient_access_program. Business justification: Patient access programs must integrate REMS enrollment requirements; hub services coordinate REMS patient registration, prescriber certification verification, and pharmacy network compliance alongside' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatientAccessProgram .

ind:assessmentSchedule rdf:type rdf:Property ;
    rdfs:label 'Assessment Schedule' ;
    rdfs:comment 'FDA-mandated schedule for submitting REMS assessments (e.g., \'18 months, 3 years, and 7 years after approval\', or \'annually\'). Defines the cadence of program effectiveness reporting obligations.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecmSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Ecm Submission Reference' ;
    rdfs:comment 'eCTD sequence number or submission reference in Veeva Vault RIM corresponding to the most recent REMS submission or modification filed with FDA. Enables traceability to the regulatory dossier.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etasuElements rdf:type rdf:Property ;
    rdfs:label 'Etasu Elements' ;
    rdfs:comment 'Narrative description of the specific ETASU elements required under this REMS program (e.g., certified prescriber requirement, certified pharmacy requirement, patient enrollment registry, laboratory monitoring, patient agreement form). [ENUM-REF-CANDIDATE: certified_prescriber|certified_pharmacy|patient_registry|lab_monitoring|patient_agreement|safe_use_condition — promote to reference product]' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaContactName rdf:type rdf:Property ;
    rdfs:label 'Fda Contact Name' ;
    rdfs:comment 'Name of the FDA project manager or reviewer assigned to this REMS program. Used for official regulatory correspondence and health authority interactions.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalStatement rdf:type rdf:Property ;
    rdfs:label 'Goal Statement' ;
    rdfs:comment 'Official FDA-approved goal statement for the REMS program describing the specific safety outcome the program is designed to achieve (e.g., \'Mitigate the risk of fetal exposure to isotretinoin\').' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasCommunicationPlan rdf:type rdf:Property ;
    rdfs:label 'Has Communication Plan' ;
    rdfs:comment 'Indicates whether the REMS program includes a Communication Plan element targeting healthcare professionals (HCPs) about serious risks associated with the drug.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasEtasu rdf:type rdf:Property ;
    rdfs:label 'Has Etasu' ;
    rdfs:comment 'Indicates whether the REMS program includes Elements to Assure Safe Use (ETASU), which are the most restrictive REMS requirements such as certified prescriber/pharmacy networks, patient registries, or laboratory testing requirements.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasMedicationGuide rdf:type rdf:Property ;
    rdfs:label 'Has Medication Guide' ;
    rdfs:comment 'Indicates whether the REMS program includes a Medication Guide as a required REMS element to be dispensed to patients at each prescription fill.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Outcome' ;
    rdfs:comment 'FDA\'s determination following review of the most recently submitted REMS assessment report. Indicates whether the program is meeting its goals or requires modification.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessmentSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Submission Date' ;
    rdfs:comment 'Date on which the most recent REMS assessment report was submitted to FDA via eCTD. Used to verify compliance with the assessment schedule.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'Date of the most recent FDA-approved modification to the REMS program. Used to track program currency and trigger downstream label and communication updates.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModificationType rdf:type rdf:Property ;
    rdfs:label 'Last Modification Type' ;
    rdfs:comment 'Classification of the most recent REMS modification as major (substantive change to ETASU or goals), minor (non-substantive change), or administrative (formatting/contact updates).' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationCount rdf:type rdf:Property ;
    rdfs:label 'Modification Count' ;
    rdfs:comment 'Total number of FDA-approved modifications made to the REMS program since initial approval. Tracks program evolution and regulatory change history.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Date by which the next REMS assessment report must be submitted to FDA per the approved assessment schedule. Critical for regulatory compliance tracking.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programAdministrator rdf:type rdf:Property ;
    rdfs:label 'Program Administrator' ;
    rdfs:comment 'Name of the organization or vendor contracted to administer the REMS program operations (e.g., patient enrollment, prescriber certification, pharmacy certification, call center). May be an internal team or a third-party REMS administrator.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Official FDA-approved name of the REMS program as registered in Veeva Vault RIM and the FDA REMS database (e.g., \'iPLEDGE REMS\', \'TIRF REMS ACCESS\').' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the REMS program. \'active\' indicates the program is fully operational; \'under_review\' indicates FDA is evaluating a modification; \'pending_approval\' indicates initial REMS awaiting FDA approval.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programVersion rdf:type rdf:Property ;
    rdfs:label 'Program Version' ;
    rdfs:comment 'Version identifier of the current approved REMS program document, incremented with each FDA-approved modification (e.g., v1.0, v2.3). Aligns with eCTD submission versioning in Veeva Vault RIM.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsNumber rdf:type rdf:Property ;
    rdfs:label 'Rems Number' ;
    rdfs:comment 'FDA-assigned unique program identifier for the REMS, used for official correspondence and regulatory submissions. Serves as the externally-known business identifier.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCertifiedPharmacy rdf:type rdf:Property ;
    rdfs:label 'Requires Certified Pharmacy' ;
    rdfs:comment 'Indicates whether pharmacies must be certified or enrolled in the REMS program before they are authorized to dispense the drug. Restricts dispensing to a controlled pharmacy network.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCertifiedPrescriber rdf:type rdf:Property ;
    rdfs:label 'Requires Certified Prescriber' ;
    rdfs:comment 'Indicates whether prescribers must be certified or enrolled in the REMS program before they are authorized to prescribe the drug. A key ETASU element for high-risk products.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresLabMonitoring rdf:type rdf:Property ;
    rdfs:label 'Requires Lab Monitoring' ;
    rdfs:comment 'Indicates whether the REMS program mandates specific laboratory tests (e.g., pregnancy tests, liver function tests, blood counts) as a condition of prescribing or dispensing the drug.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPatientEnrollment rdf:type rdf:Property ;
    rdfs:label 'Requires Patient Enrollment' ;
    rdfs:comment 'Indicates whether patients must be enrolled in the REMS program (e.g., patient registry or patient agreement) before receiving the drug. Enables tracking of patient exposure and outcomes.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Summary description of the serious risk(s) that necessitate the REMS program (e.g., teratogenicity, QT prolongation, severe hepatotoxicity, opioid addiction and overdose). Derived from the FDA-approved REMS document.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharedRemsIndicator rdf:type rdf:Property ;
    rdfs:label 'Shared Rems Indicator' ;
    rdfs:comment 'Indicates whether this is a shared REMS program administered jointly by multiple sponsors (e.g., brand and generic manufacturers) under a single FDA-approved REMS. Relevant for interoperability with generic entrants.' ;
    rdfs:domain ind:Rems ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcoMasterId rdf:type rdf:Property ;
    rdfs:label 'Hco Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.hco_master. Business justification: Post-approval commitment studies are conducted at specific healthcare organizations (academic medical centers, research hospitals). Regulatory operations track the primary study institution for site q' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HcoMaster .

ind:heorStudyId rdf:type rdf:Property ;
    rdfs:label 'Heor Study Id' ;
    rdfs:comment 'Foreign key linking to market.market_heor_study. Business justification: Post-approval commitments frequently mandate HEOR studies (budget impact, cost-effectiveness updates). The PAC is the regulatory obligation that initiates the HEOR study. Pharma HEOR teams track which' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HeorStudy .

ind:htaSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Hta Submission Id' ;
    rdfs:comment 'Foreign key linking to market.hta_submission. Business justification: Post-approval commitments (RWE studies, registries, outcome studies) are submitted to HTA bodies as evidence updates for reassessment. The PAC is the regulatory basis for the HTA evidence update submi' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HtaSubmission .

ind:annualReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Report Due Date' ;
    rdfs:comment 'The due date for the next annual progress report to the health authority on the status of this post-approval commitment, as required under 21 CFR Part 314.81 for FDA and equivalent EMA reporting cycles.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalTrialRegistryNumber rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Registry Number' ;
    rdfs:comment 'Public registry identifier for the clinical study associated with this commitment (e.g., ClinicalTrials.gov NCT number, EudraCT number). Required for Phase IV and pediatric studies under FDAAA and EU CTR.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentCategory rdf:type rdf:Property ;
    rdfs:label 'Commitment Category' ;
    rdfs:comment 'Broad scientific or operational category of the commitment: Clinical (clinical studies), Non-Clinical (preclinical/toxicology), CMC (Chemistry Manufacturing and Controls), Pharmacovigilance, Labeling, or Risk Management. Used for portfolio analytics and resource planning.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the post-approval commitment as reported to the health authority. Aligns with FDA PMR/PMC status categories: Pending (not yet started), Ongoing (in progress), Submitted (deliverable submitted to agency), Fulfilled (agency confirmed completion), Released (agency released from requirement), Delayed, or Terminated. [ENUM-REF-CANDIDATE: Pending|Ongoing|Submitted|Fulfilled|Released|Delayed|Terminated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Classification of the commitment type: PMR (Post-Marketing Requirement — legally required under FDAAA), PMC (Post-Marketing Commitment — voluntarily agreed), Phase IV Study, Label Update, Stability Study, or Risk Management measure. [ENUM-REF-CANDIDATE: PMR|PMC|Phase IV Study|Label Update|Stability Study|Risk Management|REMS|Pediatric Study|Pharmacovigilance Study|Registry Study — promote to reference product]' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedMilestoneCount rdf:type rdf:Property ;
    rdfs:label 'Completed Milestone Count' ;
    rdfs:comment 'Number of individual action-level milestones or tasks that have been completed for this commitment. Used alongside milestone_count to calculate progress percentage for executive dashboards.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'The type of document or output required to fulfill this commitment: Protocol (study protocol submission), Interim Report, Final Study Report, Label Update, Annual Report, or Safety Update (e.g., PSUR/PBRER). [ENUM-REF-CANDIDATE: Protocol|Interim Report|Final Study Report|Label Update|Annual Report|Safety Update|Risk Management Plan|Registry Report|Pharmacovigilance Plan — promote to reference product]' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'The date on which the health authority confirmed that this post-approval commitment has been fulfilled or released. Null if not yet fulfilled.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPediatricCommitment rdf:type rdf:Property ;
    rdfs:label 'Is Pediatric Commitment' ;
    rdfs:comment 'Indicates whether this commitment was issued under pediatric legislation (PREA in the US, PDCO/PIP in the EU). True if the commitment is a pediatric study or measure required under PREA or EU Pediatric Regulation.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAgency rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency' ;
    rdfs:comment 'The regulatory health authority that issued or mandated this post-approval commitment (e.g., FDA, EMA, PMDA, MHRA, NMPA). Determines the applicable regulatory framework and reporting obligations. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|NMPA|WHO|Health Canada|TGA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReportedStatusDate rdf:type rdf:Property ;
    rdfs:label 'Last Reported Status Date' ;
    rdfs:comment 'The date on which the most recent status update for this commitment was reported to the health authority (e.g., in an annual report or ad hoc correspondence). Used to track reporting currency and compliance.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalDueDate rdf:type rdf:Property ;
    rdfs:label 'Original Due Date' ;
    rdfs:comment 'The original due date for fulfillment of this post-approval commitment as specified in the approval letter or agency correspondence. Preserved for compliance tracking and variance analysis against revised due dates.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postApprovalCommitmentDescription rdf:type rdf:Property ;
    rdfs:label 'Post Approval Commitment Description' ;
    rdfs:comment 'Full narrative description of the post-approval commitment as stated in the approval letter, labeling, or agency correspondence. Captures the scope, objective, and specific deliverable required.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Internal priority classification assigned to this commitment based on regulatory risk, patient safety implications, and business impact. Drives resource allocation and escalation decisions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleFunction rdf:type rdf:Property ;
    rdfs:label 'Responsible Function' ;
    rdfs:comment 'The internal business function or department accountable for executing and delivering this post-approval commitment (e.g., Clinical Development, Regulatory Affairs, Pharmacovigilance, CMC, Medical Affairs).' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedDueDate rdf:type rdf:Property ;
    rdfs:label 'Revised Due Date' ;
    rdfs:comment 'The most current agreed-upon due date for fulfillment, reflecting any agency-approved extensions or renegotiations. Null if no revision has been made to the original due date.' ;
    rdfs:domain ind:PostApprovalCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyNumber rdf:type rdf:Property ;
    rdfs:label 'Study Number' ;
    rdfs:comment 'Internal or sponsor-assigned study number for the clinical or non-clinical study associated with this commitment (e.g., Phase IV study protocol number). Null for non-study commitments such as label updates.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyId rdf:type rdf:Property ;
    rdfs:label 'Strategy Id' ;
    rdfs:comment 'Unique surrogate identifier for the regulatory strategy record within the Pharmaceuticals data lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Strategy .

ind:leadHealthAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Lead Health Authority Id' ;
    rdfs:comment 'Foreign key linking to regulatory.health_authority. Business justification: Regulatory strategy identifies the lead health authority for the global filing sequence (e.g., FDA for US-first strategy, EMA for EU-first). The lead_agency STRING should be replaced with a FK to heal' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthAuthority .

ind:acceleratedApprovalPathway rdf:type rdf:Property ;
    rdfs:label 'Accelerated Approval Pathway' ;
    rdfs:comment 'Indicates whether the regulatory strategy includes pursuit of FDA Accelerated Approval or EMA Conditional Marketing Authorization based on surrogate or intermediate clinical endpoints.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agencyEngagementPlan rdf:type rdf:Property ;
    rdfs:label 'Agency Engagement Plan' ;
    rdfs:comment 'Summary of planned formal and informal interactions with health authorities (e.g., Pre-IND meetings, Type B meetings with FDA, Scientific Advice with EMA, PMDA consultations). Defines the cadence and objectives of regulatory agency engagement.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakthroughTherapyDesignation rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy Designation' ;
    rdfs:comment 'Indicates whether the company is pursuing or has received FDA Breakthrough Therapy Designation (BTD) for this program. BTD enables intensive FDA guidance and rolling review to expedite development.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveLandscapeNotes rdf:type rdf:Property ;
    rdfs:label 'Competitive Landscape Notes' ;
    rdfs:comment 'Summary of the competitive regulatory landscape including approved products in the same indication, precedent-setting approvals, and competitor pipeline programs that may influence the regulatory strategy or review standards.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPhase rdf:type rdf:Property ;
    rdfs:label 'Development Phase' ;
    rdfs:comment 'Current clinical development phase of the drug program at the time this regulatory strategy is authored. Determines the regulatory interactions and submission milestones applicable. [ENUM-REF-CANDIDATE: preclinical|phase_1|phase_2|phase_3|phase_3b|pre_submission|post_approval — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdModuleReference rdf:type rdf:Property ;
    rdfs:label 'Ectd Module Reference' ;
    rdfs:comment 'Reference to the eCTD module and section where the regulatory strategy documentation is filed within the submission dossier (e.g., Module 1.2 - Product Overview). Aligns strategy to the ICH eCTD structure.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastTrackDesignation rdf:type rdf:Property ;
    rdfs:label 'Fast Track Designation' ;
    rdfs:comment 'Indicates whether FDA Fast Track Designation is being pursued or has been granted for this program. Fast Track facilitates development and expedites review of drugs treating serious conditions with unmet medical need.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalFilingSequence rdf:type rdf:Property ;
    rdfs:label 'Global Filing Sequence' ;
    rdfs:comment 'Ordered sequence of regulatory agency submissions planned globally, describing the order in which dossiers will be filed across jurisdictions (e.g., FDA first, then EMA, then PMDA). Supports launch sequencing and resource planning.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRegulatoryRisks rdf:type rdf:Property ;
    rdfs:label 'Key Regulatory Risks' ;
    rdfs:comment 'Narrative description of the principal regulatory risks identified for this program, including data gaps, safety signals, manufacturing concerns, or precedent-setting issues that could delay or prevent approval.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Date and time when the regulatory strategy record was most recently updated in the source system. Tracks document revision history for compliance and version control purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primeDesignation rdf:type rdf:Property ;
    rdfs:label 'Prime Designation' ;
    rdfs:comment 'Indicates whether EMA PRIority MEdicines (PRIME) designation is being pursued or has been granted. PRIME provides enhanced EMA support for medicines that offer a major therapeutic advantage over existing treatments.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityMarkets rdf:type rdf:Property ;
    rdfs:label 'Priority Markets' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the priority markets targeted for initial regulatory submissions (e.g., USA, GBR, DEU, JPN). Drives global filing sequence planning.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPathwayType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pathway Type' ;
    rdfs:comment 'The planned regulatory approval pathway for the drug program (e.g., NDA 505(b)(1), NDA 505(b)(2), BLA, MAA, Abbreviated NDA, 510(k)). Determines the submission type and data package requirements. [ENUM-REF-CANDIDATE: NDA_505b1|NDA_505b2|ANDA|BLA|MAA|NDS|JNDA|sNDA|sBLA|sMAA — promote to reference product]' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sakigakeDesignation rdf:type rdf:Property ;
    rdfs:label 'Sakigake Designation' ;
    rdfs:comment 'Indicates whether PMDA Sakigake designation is being pursued for this program in Japan. Sakigake provides priority review and early consultation for innovative drugs addressing serious diseases.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicRationale rdf:type rdf:Property ;
    rdfs:label 'Strategic Rationale' ;
    rdfs:comment 'Narrative explanation of the strategic reasoning behind the chosen regulatory pathway, filing sequence, and expedited program designations. Documents the decision-making basis for regulatory governance review.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyNumber rdf:type rdf:Property ;
    rdfs:label 'Strategy Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the regulatory strategy document as assigned in Veeva Vault RIM. Used for cross-functional referencing and regulatory correspondence tracking.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyStatus rdf:type rdf:Property ;
    rdfs:label 'Strategy Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory strategy document within Veeva Vault RIM. Drives workflow routing and version control. [ENUM-REF-CANDIDATE: draft|under_review|approved|active|superseded|retired — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Target Approval Date' ;
    rdfs:comment 'Anticipated date of regulatory approval from the lead agency based on standard or priority review timelines. Drives commercial launch planning and supply chain readiness.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Target Submission Date' ;
    rdfs:comment 'Planned date for the primary regulatory submission (e.g., NDA, BLA, MAA) to the lead agency. Used for milestone tracking and commercial launch timeline planning.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tppSummary rdf:type rdf:Property ;
    rdfs:label 'Tpp Summary' ;
    rdfs:comment 'Narrative summary of the Target Product Profile (TPP) describing the desired label claims, patient population, dosing regimen, safety profile, and differentiation from existing therapies. Anchors the regulatory strategy to commercial objectives.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the regulatory strategy document following major.minor versioning convention. Tracks document evolution through review and approval cycles in Veeva Vault RIM.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationId rdf:type rdf:Property ;
    rdfs:label 'Designation Id' ;
    rdfs:comment 'Unique surrogate identifier for each regulatory designation record in the lakehouse Silver layer.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designation .

ind:agencyMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Agency Meeting Date' ;
    rdfs:comment 'Date of the most recent or scheduled health authority meeting (e.g., Type B meeting with FDA, PRIME scientific advice meeting with EMA) related to this designation.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefits rdf:type rdf:Property ;
    rdfs:label 'Benefits' ;
    rdfs:comment 'Free-text summary of the regulatory and commercial benefits conferred by this designation (e.g., rolling review, priority review voucher, tax credits, market exclusivity, fee waivers, intensive FDA guidance).' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmatoryTrialRequired rdf:type rdf:Property ;
    rdfs:label 'Confirmatory Trial Required' ;
    rdfs:comment 'Indicates whether a post-approval confirmatory clinical trial is required as a condition of the designation or associated approval pathway (e.g., Accelerated Approval post-market requirement).' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designationNumber rdf:type rdf:Property ;
    rdfs:label 'Designation Number' ;
    rdfs:comment 'Official reference number assigned by the health authority upon granting the designation (e.g., FDA Orphan Drug Designation number, Breakthrough Therapy designation reference). Serves as the externally-known business identifier for this designation.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationStatus rdf:type rdf:Property ;
    rdfs:label 'Designation Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory designation, tracking progression from initial request through grant, potential withdrawal, revocation, or expiry.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationType rdf:type rdf:Property ;
    rdfs:label 'Designation Type' ;
    rdfs:comment 'Category of the special regulatory designation or expedited program. Covers FDA and international agency programs. [ENUM-REF-CANDIDATE: Breakthrough Therapy|Fast Track|Accelerated Approval|Priority Review|Orphan Drug Designation|Rare Pediatric Disease|Qualified Infectious Disease Product|EMA PRIME|PMDA Sakigake|Conditional Marketing Authorization|Exceptional Circumstances — promote to reference product]' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Period Years' ;
    rdfs:comment 'Duration in years of market exclusivity conferred by the designation upon approval (e.g., 7 years for FDA Orphan Drug, 10 years for EMA Orphan). Null if no exclusivity is associated with this designation type.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obligations rdf:type rdf:Property ;
    rdfs:label 'Obligations' ;
    rdfs:comment 'Free-text summary of post-grant obligations and commitments associated with the designation (e.g., pediatric study requirements, annual prevalence reporting for orphan drugs, post-market confirmatory trials for accelerated approval).' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDiseasePrevalence rdf:type rdf:Property ;
    rdfs:label 'Orphan Disease Prevalence' ;
    rdfs:comment 'Reported prevalence of the orphan condition per 10,000 population as submitted in the Orphan Drug Designation (ODD) request. Applicable only when designation_type is Orphan Drug Designation or Rare Pediatric Disease.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityReviewVoucherEligible rdf:type rdf:Property ;
    rdfs:label 'Priority Review Voucher Eligible' ;
    rdfs:comment 'Indicates whether this designation confers eligibility for a Priority Review Voucher (PRV) upon approval (applicable to Rare Pediatric Disease and Tropical Disease designations under FDA).' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date on which the company formally submitted the designation request to the health authority.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rollingReviewEnabled rdf:type rdf:Property ;
    rdfs:label 'Rolling Review Enabled' ;
    rdfs:comment 'Indicates whether the designation enables rolling review of the marketing application (i.e., submission of completed dossier modules before the full application is ready), as applicable for Fast Track and EMA PRIME designations.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voucherRedeemed rdf:type rdf:Property ;
    rdfs:label 'Voucher Redeemed' ;
    rdfs:comment 'Indicates whether the Priority Review Voucher (PRV) associated with this designation has been redeemed or sold. Applicable only when priority_review_voucher_eligible is True.' ;
    rdfs:domain ind:Designation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: Post-approval changes (variations) require comparability data from specific validation lots. Health authorities review batch analysis from designated lots to approve manufacturing changes, site transf' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:masterBatchRecordId rdf:type rdf:Property ;
    rdfs:label 'Master Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.master_batch_record. Business justification: Variations document manufacturing process changes requiring regulatory approval. Critical for Type II variations (EU) and PAS submissions (US) linking regulatory change control to updated MBRs, ensuri' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterBatchRecord .

ind:affectedCtdSections rdf:type rdf:Property ;
    rdfs:label 'Affected Ctd Sections' ;
    rdfs:comment 'Comma-separated list of eCTD Common Technical Document (CTD) module and section references impacted by this variation (e.g., 3.2.S.2.2, 3.2.P.3.3, 2.7.1). Sourced from Veeva Vault RIM dossier mapping.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'High-level business category of the change being submitted, used for portfolio analytics and workload management across regulatory affairs. [ENUM-REF-CANDIDATE: manufacturing|quality|clinical|labeling|administrative|safety|pharmacovigilance|packaging — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockStopDays rdf:type rdf:Property ;
    rdfs:label 'Clock Stop Days' ;
    rdfs:comment 'Total number of days the regulatory review clock was stopped due to requests for supplementary information (List of Questions / List of Outstanding Issues) from the health authority, used for accurate timeline tracking.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Group Reference Number' ;
    rdfs:comment 'Reference identifier linking this variation to a grouped variation package when multiple changes are submitted together under EMA grouping or FDA bundling provisions.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Date on which the approved change was operationally implemented in manufacturing, labeling, or other affected business processes.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isGrouped rdf:type rdf:Property ;
    rdfs:label 'Is Grouped' ;
    rdfs:comment 'Indicates whether this variation is submitted as part of a grouped variation package (multiple changes submitted together in a single application under EMA grouping rules).' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLabelingChange rdf:type rdf:Property ;
    rdfs:label 'Is Labeling Change' ;
    rdfs:comment 'Indicates whether this variation includes a change to the approved product labeling (SmPC, PIL, or US prescribing information), triggering label management workflows.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyDriven rdf:type rdf:Property ;
    rdfs:label 'Is Safety Driven' ;
    rdfs:comment 'Indicates whether this variation was initiated as a result of a pharmacovigilance signal, safety review, or post-market safety commitment, triggering expedited regulatory processing.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:questionsReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Questions Received Date' ;
    rdfs:comment 'Date on which the health authority issued a List of Questions (LoQ) or Request for Information (RFI) during the review of this variation, initiating a clock stop.' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:variationNumber rdf:type rdf:Property ;
    rdfs:label 'Variation Number' ;
    rdfs:comment 'Externally-known unique identifier assigned to the variation or supplement by the health authority or internal regulatory tracking system (e.g., EMA variation number, FDA supplement number, or internal RIMS reference).' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationStatus rdf:type rdf:Property ;
    rdfs:label 'Variation Status' ;
    rdfs:comment 'Current lifecycle status of the variation or supplement from initial drafting through health authority decision and implementation. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|refused|withdrawn|implemented — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variationType rdf:type rdf:Property ;
    rdfs:label 'Variation Type' ;
    rdfs:comment 'Regulatory classification of the variation or supplement. EMA categories include Type IA (minor, immediate notification), Type IAIN (immediate notification), Type IB (minor, 30-day review), and Type II (major). FDA categories include CBE-0 (Changes Being Effected immediately), CBE-30 (Changes Being Effected in 30 days), and PAS (Prior Approval Supplement). [ENUM-REF-CANDIDATE: Type_IA|Type_IAIN|Type_IB|Type_II|CBE_0|CBE_30|PAS|Minor|Major — promote to reference product]' ;
    rdfs:domain ind:Variation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Product Registration Id' ;
    rdfs:comment 'Unique surrogate identifier for each country-level product registration record. Primary key of the product_registration data product.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagingConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration Id' ;
    rdfs:comment 'Foreign key linking to product.packaging_configuration. Business justification: Product registrations in many markets (EU, emerging markets) are specific to approved packaging configurations (pack size, container type). Regulatory teams track which packaging configurations are re' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingConfiguration .

ind:serializationRecordId rdf:type rdf:Property ;
    rdfs:label 'Serialization Record Id' ;
    rdfs:comment 'Foreign key linking to supply.serialization_record. Business justification: Product registration defines market-specific serialization requirements (e.g., EU FMD, DSCSA). Serialization records must comply with the registration that authorizes the product in that market. Linki' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SerializationRecord .

ind:approvedIndication rdf:type rdf:Property ;
    rdfs:label 'Approved Indication' ;
    rdfs:comment 'Full text of the approved therapeutic indication(s) as granted by the health authority and reflected in the current product label/SmPC. Defines the authorized use of the product in this market.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstCommercialDate rdf:type rdf:Property ;
    rdfs:label 'First Commercial Date' ;
    rdfs:comment 'Date on which the product was first commercially launched and placed on the market in this country following registration. Used to track sunset clause compliance and commercial launch timelines.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Approval Date' ;
    rdfs:comment 'Date on which the health authority granted approval of the renewal application, extending the validity of the marketing authorization.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Calendar date by which the renewal application must be submitted to the health authority to prevent registration lapse. Critical for renewal calendar management and commercial continuity planning.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Amount' ;
    rdfs:comment 'Monetary amount of the regulatory renewal fee payable to the health authority for this registration renewal. Expressed in the local currency of the health authority jurisdiction.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the renewal fee amount (e.g., USD, EUR, GBP, JPY, CNY).' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFeeStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Status' ;
    rdfs:comment 'Payment status of the regulatory renewal fee due to the health authority for this registration renewal cycle. Unpaid or overdue fees can result in registration lapse.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOutcome rdf:type rdf:Property ;
    rdfs:label 'Renewal Outcome' ;
    rdfs:comment 'Outcome of the most recent renewal application for this registration. Approved = renewal granted; Refused = health authority denied renewal; Withdrawn by Holder = MAH withdrew the renewal application; Pending = renewal submitted and under review; Not Submitted = renewal not yet submitted.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Submission Date' ;
    rdfs:comment 'Actual date on which the renewal application dossier was submitted to the health authority. Used to confirm timely submission and calculate submission lead time against the renewal due date.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Type of renewal cycle applicable to this registration as defined by the health authority. Five-year = standard EU/ICH 5-year renewal; Annual = annual renewal required (e.g., certain PMDA registrations); Sunset Clause = registration lapses if product not marketed within defined period; Indefinite = no renewal required after initial grant; Not Applicable = renewal not applicable in this jurisdiction.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunsetClauseDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Clause Date' ;
    rdfs:comment 'Date by which the product must be placed on the market in the registered country to avoid automatic lapse of the registration under the sunset clause provision. Applicable in EU and certain other jurisdictions where a registration lapses if the product is not marketed within 3 years of grant.' ;
    rdfs:domain ind:ProductRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:molecularTargetId rdf:type rdf:Property ;
    rdfs:label 'Molecular Target Id' ;
    rdfs:comment 'Unique surrogate identifier for the molecular target record in the discovery data product. Primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MolecularTarget .

ind:owningOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Owning Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: Target ownership by research org unit drives portfolio reporting, resource allocation, and therapeutic area governance. Pharma domain experts expect molecular targets to be formally assigned to a depa' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryPatentClaimId rdf:type rdf:Property ;
    rdfs:label 'Primary Patent Claim Id' ;
    rdfs:comment 'Foreign key linking to intellectual.patent_claim. Business justification: Specific patent claims cover target modulation methods; claim-level tracking required for FTO clearance, licensing negotiations, and assessing blocking IP in target validation stage gates.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentClaim .

ind:therapeuticAreaId rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Id' ;
    rdfs:comment 'Foreign key linking to product.therapeutic_area. Business justification: Molecular targets are classified and prioritized within therapeutic area programs. Linking to the master therapeutic_area entity enables TA-level target portfolio reporting, competitive landscape anal' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TherapeuticArea .

ind:competitiveLandscapeSummary rdf:type rdf:Property ;
    rdfs:label 'Competitive Landscape Summary' ;
    rdfs:comment 'Summary of known competitive programs targeting this molecular target, including approved drugs, clinical-stage compounds, and disclosed research programs from competitor organizations. Business-confidential intelligence used for portfolio strategy.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryProgramCode rdf:type rdf:Property ;
    rdfs:label 'Discovery Program Code' ;
    rdfs:comment 'Internal program or project code under which this target is being investigated. Links the target to the broader drug discovery program for portfolio management, resource allocation, and P&L tracking.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseAssociation rdf:type rdf:Property ;
    rdfs:label 'Disease Association' ;
    rdfs:comment 'Specific disease or condition(s) associated with this molecular target, as supported by published literature or internal research data. May reference ICD-10/ICD-11 disease codes or MeSH disease terms.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:druggabilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Druggability Assessment' ;
    rdfs:comment 'Scientific assessment of the target\'s amenability to small molecule or biologic modulation based on structural, biochemical, and computational analyses. Key input to portfolio prioritization and NCE/NBE strategy decisions.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elnNotebookReference rdf:type rdf:Property ;
    rdfs:label 'Eln Notebook Reference' ;
    rdfs:comment 'Reference identifier to the primary Electronic Lab Notebook (ELN) experiment record in IDBS E-WorkBook or Dotmatics that documents the original target identification and characterization data. Provides full scientific audit trail.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ensemblGeneCode rdf:type rdf:Property ;
    rdfs:label 'Ensembl Gene Code' ;
    rdfs:comment 'Ensembl stable gene identifier (e.g., ENSG00000146648) for the gene encoding the molecular target. Used for genomic cross-referencing, variant analysis, and bioinformatics pipelines.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expressionTissue rdf:type rdf:Property ;
    rdfs:label 'Expression Tissue' ;
    rdfs:comment 'Primary tissue(s) or cell type(s) where this molecular target is expressed at therapeutically relevant levels, as determined by transcriptomic or proteomic profiling (e.g., liver, lung epithelium, T-cells). Informs tissue selectivity and delivery strategy.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstDisclosedDate rdf:type rdf:Property ;
    rdfs:label 'First Disclosed Date' ;
    rdfs:comment 'Date on which this molecular target was first formally disclosed or documented in the internal ELN or target identification database. Establishes the scientific priority date for IP purposes.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geneName rdf:type rdf:Property ;
    rdfs:label 'Gene Name' ;
    rdfs:comment 'Official HGNC (HUGO Gene Nomenclature Committee) approved gene symbol encoding the molecular target (e.g., EGFR, TP53, BRCA1). Standard identifier used in regulatory submissions and scientific publications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneticAssociationScore rdf:type rdf:Property ;
    rdfs:label 'Genetic Association Score' ;
    rdfs:comment 'Quantitative score (0.0000–1.0000) representing the strength of genetic evidence linking this target to the associated disease, derived from GWAS, Mendelian randomization, or Open Targets Platform data. Higher scores indicate stronger genetic validation.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date of the most recent scientific or portfolio review of this target record. Ensures data currency and supports periodic target triage processes.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moaDescription rdf:type rdf:Property ;
    rdfs:label 'Moa Description' ;
    rdfs:comment 'Narrative description of the molecular mechanism by which modulation of this target is expected to produce a therapeutic effect. Captures agonism, antagonism, inhibition, activation, or allosteric modulation details as documented in ELN.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moaType rdf:type rdf:Property ;
    rdfs:label 'Moa Type' ;
    rdfs:comment 'Categorical classification of the pharmacological mechanism of action for compounds acting on this target. Used to group targets by intervention strategy in SAR analysis and portfolio reporting. [ENUM-REF-CANDIDATE: agonist|antagonist|inhibitor|activator|allosteric_modulator|degrader|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modality rdf:type rdf:Property ;
    rdfs:label 'Modality' ;
    rdfs:comment 'Preferred drug modality for targeting this molecular target based on its structural and biochemical properties. Determines the NCE (New Chemical Entity) or NBE (New Biological Entity) classification of resulting compounds. [ENUM-REF-CANDIDATE: small_molecule|biologic|antibody|peptide|oligonucleotide|cell_therapy|gene_therapy|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noveltyStatus rdf:type rdf:Property ;
    rdfs:label 'Novelty Status' ;
    rdfs:comment 'Classification of the target\'s novelty relative to the competitive landscape. Novel targets represent first-in-class opportunities; established targets have existing approved drugs; repurposed targets are being explored in new indications.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organism rdf:type rdf:Property ;
    rdfs:label 'Organism' ;
    rdfs:comment 'Biological organism in which the molecular target is expressed and studied. Typically Homo sapiens for human targets, but may include model organisms used in preclinical validation studies.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentLandscapeSummary rdf:type rdf:Property ;
    rdfs:label 'Patent Landscape Summary' ;
    rdfs:comment 'High-level summary of the patent landscape around this molecular target, including freedom-to-operate (FTO) considerations and known composition-of-matter or method-of-use patents. Supports IP strategy decisions.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathwayName rdf:type rdf:Property ;
    rdfs:label 'Pathway Name' ;
    rdfs:comment 'Name of the primary biological signaling or metabolic pathway in which this target participates (e.g., PI3K/AKT/mTOR, RAS/MAPK, JAK/STAT). Supports pathway-based target clustering and polypharmacology analysis.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdbCode rdf:type rdf:Property ;
    rdfs:label 'Pdb Code' ;
    rdfs:comment 'RCSB Protein Data Bank accession code for the primary 3D structure of this molecular target. Used by computational chemistry and structure-based drug design (SBDD) teams for molecular docking and virtual screening.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prioritizationTier rdf:type rdf:Property ;
    rdfs:label 'Prioritization Tier' ;
    rdfs:comment 'Portfolio prioritization tier assigned to this target by the Target Selection Committee, reflecting strategic importance, scientific confidence, and commercial potential. Tier 1 targets receive maximum resource allocation.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proteinStructureAvailable rdf:type rdf:Property ;
    rdfs:label 'Protein Structure Available' ;
    rdfs:comment 'Indicates whether a resolved 3D protein structure (X-ray crystallography, cryo-EM, or NMR) is available for this target in the Protein Data Bank (PDB) or internal structural biology repository. Directly impacts structure-based drug design (SBDD) feasibility.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyConcernDescription rdf:type rdf:Property ;
    rdfs:label 'Safety Concern Description' ;
    rdfs:comment 'Narrative description of identified safety liabilities associated with modulation of this target (e.g., hERG channel activity, hepatotoxicity risk, immunosuppression). Populated only when safety_concern_flag is True.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyConcernFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Concern Flag' ;
    rdfs:comment 'Indicates whether known safety liabilities or toxicological concerns have been identified for this target based on literature, genetic association studies, or internal preclinical data. Triggers mandatory safety review before progression.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:selectivityProfile rdf:type rdf:Property ;
    rdfs:label 'Selectivity Profile' ;
    rdfs:comment 'Assessment of the target\'s selectivity relative to related family members or off-target proteins. Informs compound design strategy to minimize off-target toxicity and maximize therapeutic index.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClass rdf:type rdf:Property ;
    rdfs:label 'Target Class' ;
    rdfs:comment 'Pharmacological class of the molecular target based on its biochemical function and structural family. Drives druggability assessment strategy and compound screening cascade design. [ENUM-REF-CANDIDATE: GPCR|kinase|nuclear_receptor|ion_channel|protease|phosphatase|epigenetic_regulator|transcription_factor|transporter|other — promote to reference product]' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Internally assigned alphanumeric business identifier for the molecular target, used as the externally-known unique code across systems (ELN, LIMS, CTMS). Distinct from the surrogate PK and from external database accession numbers.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEngagementAssay rdf:type rdf:Property ;
    rdfs:label 'Target Engagement Assay' ;
    rdfs:comment 'Name or identifier of the primary biochemical or biophysical assay used to measure compound engagement with this target (e.g., HTRF binding assay, SPR, ITC, NanoBRET). Registered in LIMS (LabWare/SampleManager) and ELN.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable scientific name of the molecular target (e.g., EGFR, BRAF, PD-L1, CDK4/6). Serves as the primary identity label used by research scientists and in ELN records within IDBS/Dotmatics.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Biological molecule type of the target (e.g., protein, enzyme, receptor, ion channel, nucleic acid). Determines the modality of drug intervention and screening assay design. [ENUM-REF-CANDIDATE: protein|enzyme|receptor|ion_channel|nucleic_acid|lipid|carbohydrate|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniprotAccession rdf:type rdf:Property ;
    rdfs:label 'Uniprot Accession' ;
    rdfs:comment 'Universal Protein Resource (UniProt) accession number uniquely identifying the protein target in the global UniProtKB database. Enables cross-referencing with external biological databases and regulatory submissions.' ;
    rdfs:domain ind:MolecularTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Validation Completion Date' ;
    rdfs:comment 'Date on which target validation studies were completed and the target was formally declared validated (in vitro or in vivo). Marks the transition from target identification to hit-to-lead progression stage.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compoundId rdf:type rdf:Property ;
    rdfs:label 'Compound Id' ;
    rdfs:comment 'Unique system-generated surrogate key for each compound record in the discovery compound library. Primary key for the compound master data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:vendorBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Vendor Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Vendor qualification and approved vendor list (AVL) compliance requires linking purchased/sourced compounds to their business partner record. \'vendor_name\' is denormalized; the FK enables vendor audit' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:compoundClass rdf:type rdf:Property ;
    rdfs:label 'Compound Class' ;
    rdfs:comment 'Broad classification of the compound by molecular modality. Drives regulatory pathway selection (NDA vs BLA), manufacturing strategy (chemical synthesis vs biologics), and analytical method requirements. [ENUM-REF-CANDIDATE: small_molecule|biologic|peptide|adc|oligonucleotide|cell_therapy|rna_therapy|gene_therapy — promote to reference product]' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundName rdf:type rdf:Property ;
    rdfs:label 'Compound Name' ;
    rdfs:comment 'Internal working name or code name assigned to the compound during discovery (e.g., project code name such as \'ABC-1234\'). Used as the primary human-readable label in ELN, LIMS, and CTMS systems before an INN or USAN is assigned.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundStatus rdf:type rdf:Property ;
    rdfs:label 'Compound Status' ;
    rdfs:comment 'Current lifecycle status of the compound within the discovery pipeline. \'Active\' indicates the compound is under active research; \'promoted\' indicates advancement to preclinical or clinical development; \'discontinued\' indicates the compound has been deprioritized or terminated.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Schedule' ;
    rdfs:comment 'U.S. Drug Enforcement Administration (DEA) controlled substance schedule classification for the compound (Schedule I–V or not controlled). Determines handling, storage, procurement, and regulatory reporting requirements under the Controlled Substances Act.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryStage rdf:type rdf:Property ;
    rdfs:label 'Discovery Stage' ;
    rdfs:comment 'Current stage of the compound within the drug discovery pipeline. Tracks progression from target identification through hit identification, hit-to-lead, lead optimization, and candidate selection before IND filing. Used for portfolio reporting and stage-gate decision making.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elnReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Eln Reference Code' ;
    rdfs:comment 'Reference identifier linking this compound record to the originating experiment or notebook entry in the Electronic Lab Notebook (ELN) system (IDBS E-WorkBook or Dotmatics). Provides traceability from the compound master record back to the primary research data and synthesis records.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Regulatory classification of the compound as a New Chemical Entity (NCE), New Biological Entity (NBE), biosimilar, fixed-dose combination, or prodrug. Determines regulatory exclusivity periods, patent strategy, and submission pathway under FDA, EMA, and ICH guidelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glpCompliant rdf:type rdf:Property ;
    rdfs:label 'Glp Compliant' ;
    rdfs:comment 'Indicates whether the compound and its associated research data have been generated under Good Laboratory Practice (GLP) conditions as required for regulatory submissions. GLP compliance is mandatory for safety pharmacology and toxicology studies supporting IND applications.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Globally Harmonized System (GHS) hazard classification for the compound covering health, physical, and environmental hazards (e.g., \'Acute Toxicity Cat. 2, Carcinogen Cat. 1A\'). Required for Safety Data Sheet (SDS) preparation, occupational health risk assessment, and EHS compliance.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hbaCount rdf:type rdf:Property ;
    rdfs:label 'Hba Count' ;
    rdfs:comment 'Number of hydrogen bond acceptors (HBA) in the compound structure. Key Lipinski Rule of Five parameter (threshold: ≤ 10 HBAs) used in drug-likeness assessment and oral bioavailability prediction during hit-to-lead and lead optimization.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hbdCount rdf:type rdf:Property ;
    rdfs:label 'Hbd Count' ;
    rdfs:comment 'Number of hydrogen bond donors (HBD) in the compound structure. Key Lipinski Rule of Five parameter (threshold: ≤ 5 HBDs) used in drug-likeness assessment and oral bioavailability prediction during hit-to-lead and lead optimization.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inchi rdf:type rdf:Property ;
    rdfs:label 'Inchi' ;
    rdfs:comment 'IUPAC International Chemical Identifier (InChI) string providing a standardized, layered representation of the compound\'s chemical structure. Used for cross-system compound deduplication, registry lookups, and interoperability with external databases (PubChem, ChEMBL). Classified confidential as it encodes proprietary structural IP.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inchiKey rdf:type rdf:Property ;
    rdfs:label 'Inchi Key' ;
    rdfs:comment 'Fixed-length 27-character hashed representation of the InChI string (InChIKey). Used as a compact, searchable identifier for compound lookup in external databases (PubChem, ChEMBL, CAS SciFinder) and for deduplication across compound registries.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iupacName rdf:type rdf:Property ;
    rdfs:label 'Iupac Name' ;
    rdfs:comment 'Systematic chemical name of the compound following International Union of Pure and Applied Chemistry (IUPAC) nomenclature rules. Provides an unambiguous, internationally recognized chemical identity for regulatory submissions and scientific publications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryMembership rdf:type rdf:Property ;
    rdfs:label 'Library Membership' ;
    rdfs:comment 'Designation of the compound library or collection to which this compound belongs within the corporate compound library management system. Drives screening campaign design, compound availability, and resource allocation in HTS and fragment-based drug discovery programs.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logp rdf:type rdf:Property ;
    rdfs:label 'Logp' ;
    rdfs:comment 'Logarithm of the octanol-water partition coefficient (LogP), a measure of the compound\'s lipophilicity. Critical SAR and ADME parameter used to predict membrane permeability, oral bioavailability, and CNS penetration. Lipinski Rule of Five threshold: LogP ≤ 5.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mechanismOfAction rdf:type rdf:Property ;
    rdfs:label 'Mechanism Of Action' ;
    rdfs:comment 'Described mechanism of action (MOA) of the compound — the biochemical interaction through which the compound produces its pharmacological effect (e.g., \'selective inhibitor of EGFR tyrosine kinase\'). Critical for target validation, patent claims, and regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:molecularFormula rdf:type rdf:Property ;
    rdfs:label 'Molecular Formula' ;
    rdfs:comment 'Empirical molecular formula of the compound expressed using Hill notation (e.g., C21H30N2O5). Represents the elemental composition and is used in regulatory submissions, analytical method development, and structural verification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:molecularWeight rdf:type rdf:Property ;
    rdfs:label 'Molecular Weight' ;
    rdfs:comment 'Average molecular weight of the compound expressed in grams per mole (g/mol). Critical physicochemical property used in SAR analysis, ADME profiling, formulation development, and Lipinski Rule of Five drug-likeness assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalState rdf:type rdf:Property ;
    rdfs:label 'Physical State' ;
    rdfs:comment 'Physical state of the compound at standard conditions (solid, liquid, gas, semi-solid). Determines handling procedures, formulation approach, and storage requirements. Captured in the ELN and LIMS at time of compound registration.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purityPercent rdf:type rdf:Property ;
    rdfs:label 'Purity Percent' ;
    rdfs:comment 'Measured chemical purity of the compound expressed as a percentage (0.00–100.00%). Determined by analytical methods such as HPLC or NMR. Critical quality attribute (CQA) for assay reliability, GLP compliance, and advancement decisions in hit-to-lead progression.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotatableBondCount rdf:type rdf:Property ;
    rdfs:label 'Rotatable Bond Count' ;
    rdfs:comment 'Number of rotatable bonds in the compound structure. Veber rule parameter (threshold: ≤ 10) used alongside TPSA to predict oral bioavailability and molecular flexibility in SAR and lead optimization analyses.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:smiles rdf:type rdf:Property ;
    rdfs:label 'Smiles' ;
    rdfs:comment 'Canonical SMILES (Simplified Molecular Input Line Entry System) string representing the two-dimensional chemical structure of the compound. Used in cheminformatics, HTS data analysis, SAR modeling, and AI/ML-based drug discovery workflows. Classified confidential as it encodes proprietary structural IP.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solubilityAqueousUm rdf:type rdf:Property ;
    rdfs:label 'Solubility Aqueous Um' ;
    rdfs:comment 'Measured or predicted aqueous solubility of the compound expressed in micromolar (µM). Key ADME physicochemical property used in SAR analysis, formulation feasibility assessment, and drug-likeness profiling (Lipinski, Veber rules).' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Origin classification of the compound indicating how it was obtained. Synthesized compounds are produced in-house; purchased compounds are acquired from external vendors or CROs; natural products are derived from biological sources. Impacts IP strategy and CMC documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Recommended storage conditions for the compound (e.g., \'-20°C, under nitrogen, protected from light, desiccated\'). Ensures compound stability and integrity in the compound library. Derived from stability data and referenced in CoA and compound library management SOPs.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tpsaAngstrom2 rdf:type rdf:Property ;
    rdfs:label 'Tpsa Angstrom2' ;
    rdfs:comment 'Topological Polar Surface Area (TPSA) of the compound expressed in square angstroms (Å²). Used to predict intestinal absorption, blood-brain barrier penetration, and oral bioavailability. Veber rule threshold: TPSA ≤ 140 Å² for oral drugs.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usan rdf:type rdf:Property ;
    rdfs:label 'Usan' ;
    rdfs:comment 'United States Adopted Name (USAN) assigned by the USAN Council for the compound. Used in US regulatory submissions (NDA/BLA) and US commercial labeling. May differ slightly from INN.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCatalogNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Catalog Number' ;
    rdfs:comment 'Vendor-assigned catalog or product number for purchased compounds. Used for reorder, procurement traceability, and cross-referencing with vendor CoA and SDS documentation. Applicable only when source_type is \'purchased\'.' ;
    rdfs:domain ind:Compound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayId rdf:type rdf:Property ;
    rdfs:label 'Assay Id' ;
    rdfs:comment 'Unique surrogate identifier for the assay master record in the discovery domain. Primary key for the assay data product. Role classification: MASTER_RESOURCE.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assay .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to masterdata.cost_center. Business justification: Assay development and validation costs are tracked against cost centers for R&D budget reporting and financial controlling. Pharma finance teams require assay-level cost center assignment separate fro' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:assayCode rdf:type rdf:Property ;
    rdfs:label 'Assay Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to the assay within the ELN or LIMS (e.g., ASY-HTS0042). Serves as the BUSINESS_IDENTIFIER category for MASTER_RESOURCE role. Used for cross-system referencing between IDBS/Dotmatics, LabWare LIMS, and SAP QM.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayName rdf:type rdf:Property ;
    rdfs:label 'Assay Name' ;
    rdfs:comment 'Full descriptive name of the assay as registered in the ELN (e.g., \'EGFR Kinase Inhibition HTRF Assay\'). Serves as the IDENTITY_LABEL category for MASTER_RESOURCE role. Used in scientific reports, regulatory submissions, and compound screening dashboards.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayType rdf:type rdf:Property ;
    rdfs:label 'Assay Type' ;
    rdfs:comment 'Primary scientific classification of the assay based on its biological or chemical mode of measurement. Serves as the CLASSIFICATION_OR_TYPE category for MASTER_RESOURCE role. Drives downstream SAR analysis workflows and compound triage decisions. [ENUM-REF-CANDIDATE: biochemical|cell_based|phenotypic|ADME|toxicity|binding|functional — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationCompatible rdf:type rdf:Property ;
    rdfs:label 'Automation Compatible' ;
    rdfs:comment 'Indicates whether the assay has been adapted and validated for automated liquid handling platforms (e.g., Hamilton, Tecan, Beckman Coulter). Determines eligibility for inclusion in HTS screening campaigns and impacts throughput capacity planning.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cellLine rdf:type rdf:Property ;
    rdfs:label 'Cell Line' ;
    rdfs:comment 'Name of the cell line used in cell-based assays (e.g., HEK293, HeLa, Jurkat, A549, MCF-7). Null for biochemical or cell-free assays. Required for assay reproducibility and cross-site comparability. Cell line authentication records are maintained in the ELN.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coefficientOfVariationPct rdf:type rdf:Property ;
    rdfs:label 'Coefficient Of Variation Pct' ;
    rdfs:comment 'Percentage coefficient of variation (%CV) of the assay signal across replicate measurements, representing assay precision and reproducibility. Typically required to be ≤ 15% for HTS assays and ≤ 20% for bioanalytical assays per ICH Q2(R1). Stored from the assay validation run.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measurement for compound concentrations used in the assay (e.g., nM, µM, mM). Standardizes concentration reporting across compound screening results and SAR analysis. Required for dose-response curve fitting and IC50/EC50 calculations. [ENUM-REF-CANDIDATE: nM|uM|mM|mg_mL|ug_mL|ng_mL|pM — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerWellUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Well Usd' ;
    rdfs:comment 'Estimated reagent and consumable cost per assay well in US dollars. Used for screening campaign cost modeling, budget planning, and make-vs-buy decisions for outsourcing to CROs. Sourced from SAP S/4HANA MM procurement data and lab supply records.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Physical or chemical detection principle used to measure the assay signal (e.g., fluorescence, luminescence, radioactivity, mass spectrometry). Distinct from technology_platform — platform is the instrument system, detection_method is the underlying measurement principle. Used for assay validation documentation and GLP compliance records. [ENUM-REF-CANDIDATE: fluorescence|luminescence|absorbance|radioactivity|mass_spectrometry|NMR|SPR|calorimetry — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstUsedDate rdf:type rdf:Property ;
    rdfs:label 'First Used Date' ;
    rdfs:comment 'Date when the assay was first deployed for compound screening or profiling activities. Marks the operational start of the assay lifecycle. Used for assay age tracking, periodic revalidation scheduling, and portfolio lifecycle management.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Operational format describing how the assay is run in the screening workflow (e.g., High-Throughput Screening (HTS) primary screen, dose-response, selectivity panel). Determines throughput capacity planning and compound consumption requirements.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hitThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Hit Threshold Unit' ;
    rdfs:comment 'Unit of measurement for the hit_threshold_value (e.g., percent inhibition, nM IC50). Ensures unambiguous interpretation of the hit-calling criterion across different assay types and readout formats.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hitThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Hit Threshold Value' ;
    rdfs:comment 'Numerical threshold used to classify a compound as a \'hit\' in primary screening (e.g., ≥ 50% inhibition at 10 µM). Defined during assay validation and used by automated hit-calling algorithms in the HTS data analysis pipeline. Critical for hit-to-lead progression decisions.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incubationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Incubation Time Hours' ;
    rdfs:comment 'Standard incubation duration in hours for the assay reaction or cell treatment step. Critical for assay reproducibility and scheduling of automated liquid handling workflows. Stored from the validated assay protocol.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastValidatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Validated Date' ;
    rdfs:comment 'Date of the most recent formal validation or requalification of the assay per ICH Q2(R1) or fit-for-purpose qualification criteria. Used to trigger periodic revalidation workflows and to assess whether assay data is current for regulatory submissions.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limsAssayCode rdf:type rdf:Property ;
    rdfs:label 'Lims Assay Code' ;
    rdfs:comment 'Cross-reference identifier for this assay in the Laboratory Information Management System (LIMS) — LabWare or Thermo Fisher SampleManager. Enables bidirectional traceability between the discovery data product and the LIMS assay execution records.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplexed rdf:type rdf:Property ;
    rdfs:label 'Multiplexed' ;
    rdfs:comment 'Indicates whether the assay measures multiple analytes or endpoints simultaneously in a single well or reaction (multiplexed assay). Multiplexed assays increase data density per compound and reduce reagent consumption. Relevant for assay cost modeling and data analysis pipeline configuration.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outsourcedToCro rdf:type rdf:Property ;
    rdfs:label 'Outsourced To Cro' ;
    rdfs:comment 'Indicates whether this assay is currently outsourced to an external Contract Research Organization (CRO) for execution. When true, the cro_vendor_name field captures the CRO identity. Impacts data governance, IP ownership, and regulatory audit trail requirements.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plateFormat rdf:type rdf:Property ;
    rdfs:label 'Plate Format' ;
    rdfs:comment 'Microplate format used in the assay (e.g., 96-well, 384-well, 1536-well). Determines reagent volumes, automation compatibility, and throughput capacity. Critical for liquid handling robot programming and compound dispensing protocols.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolReference rdf:type rdf:Property ;
    rdfs:label 'Protocol Reference' ;
    rdfs:comment 'Document identifier or URL reference to the Standard Operating Procedure (SOP) or assay protocol document stored in the ELN (IDBS/Dotmatics) or document management system (Veeva Vault QualityDocs). Ensures traceability from assay execution to the governing protocol version.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolVersion rdf:type rdf:Property ;
    rdfs:label 'Protocol Version' ;
    rdfs:comment 'Version number of the assay protocol document in effect at the time of assay execution (e.g., v1.0, v2.3). Required for GLP audit trails and regulatory submission traceability. Distinct from protocol_reference which is the document identifier.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readoutType rdf:type rdf:Property ;
    rdfs:label 'Readout Type' ;
    rdfs:comment 'Primary quantitative output metric reported by the assay (e.g., IC50, EC50, Ki, Kd, percent inhibition, percent activation). Determines how compound activity data is interpreted in SAR analysis and hit-to-lead progression decisions. [ENUM-REF-CANDIDATE: IC50|EC50|Ki|Kd|percent_inhibition|percent_activation|ratio|count|viability_pct — promote to reference product]' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionEligible rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Eligible' ;
    rdfs:comment 'Indicates whether assay results generated using this assay are eligible for inclusion in regulatory submissions (IND, NDA, BLA, MAA). Eligibility requires full validation per ICH Q2(R1) and GLP compliance where applicable. Governs data governance workflows for regulatory data packages.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the assay was formally retired and removed from active use. Null for active assays. Retirement is triggered by target deprioritization, supersession by a superior assay, or platform decommissioning. Required for data governance and historical data archival.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signalWindow rdf:type rdf:Property ;
    rdfs:label 'Signal Window' ;
    rdfs:comment 'Ratio of the maximum signal (positive control) to the minimum signal (negative control), quantifying the dynamic range of the assay. A signal window ≥ 2 is typically required for HTS qualification. Used in assay validation reports and Z-factor calculations.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speciesOrigin rdf:type rdf:Property ;
    rdfs:label 'Species Origin' ;
    rdfs:comment 'Biological species from which the assay target, cells, or biological material is derived (e.g., human, mouse, rat, recombinant). Critical for translational relevance assessment and cross-species selectivity profiling. Impacts regulatory acceptability of preclinical data for IND submissions. [ENUM-REF-CANDIDATE: human|mouse|rat|rabbit|dog|monkey|in_vitro_recombinant — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyPlatform rdf:type rdf:Property ;
    rdfs:label 'Technology Platform' ;
    rdfs:comment 'Detection technology or instrument platform used to execute the assay (e.g., HTRF, AlphaScreen, Surface Plasmon Resonance (SPR), NMR, FRET, TR-FRET, Luminescence, Flow Cytometry). Critical for assay reproducibility assessment and equipment scheduling. [ENUM-REF-CANDIDATE: HTRF|AlphaScreen|SPR|NMR|FRET|TR-FRET|luminescence|flow_cytometry|mass_spectrometry|fluorescence_polarization — promote to reference product]' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Standard incubation or reaction temperature in degrees Celsius for the assay. Critical for assay reproducibility across sites and instruments. Deviations from this value are flagged as out-of-specification (OOS) events in the LIMS.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputCapacity rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity' ;
    rdfs:comment 'Maximum number of compounds or samples that can be processed per day using this assay under standard HTS conditions. Serves as the MEASUREMENT_OR_VALUE category for MASTER_RESOURCE role. Used for compound library screening campaign planning and resource scheduling in the discovery lab.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zPrimeFactor rdf:type rdf:Property ;
    rdfs:label 'Z Prime Factor' ;
    rdfs:comment 'Statistical measure of assay quality (Z\') calculated from positive and negative control variability. Values ≥ 0.5 indicate an excellent assay suitable for HTS. Stored as the validated Z\' from the assay qualification run. Used to gate assay deployment for compound screening campaigns.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:htsCampaignId rdf:type rdf:Property ;
    rdfs:label 'Hts Campaign Id' ;
    rdfs:comment 'Unique surrogate identifier for the HTS campaign record in the discovery data product. Primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HtsCampaign .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Reference to the parent drug discovery project under which this HTS campaign is executed. Links the campaign to the broader target identification and hit-to-lead program for portfolio tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:screeningPlantId rdf:type rdf:Property ;
    rdfs:label 'Screening Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: HTS campaigns are executed at specific screening facilities/plants; facility tracking is required for GMP compliance, capacity planning, and regulatory audit trails. Role prefix \'screening_\' distingui' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Date on which the HTS campaign screening execution was completed. Used to calculate campaign duration, throughput metrics, and to trigger downstream hit confirmation workflows.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Date on which the HTS campaign screening execution actually commenced. Compared against planned_start_date to measure schedule variance and operational efficiency.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assayFormat rdf:type rdf:Property ;
    rdfs:label 'Assay Format' ;
    rdfs:comment 'Scientific format of the assay used in the campaign, indicating whether the screen measures biochemical activity (purified protein), cellular response, whole-organism phenotype, direct binding (biophysical), or fragment-based interactions. Critical for interpreting hit quality and SAR analysis.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayTechnology rdf:type rdf:Property ;
    rdfs:label 'Assay Technology' ;
    rdfs:comment 'Specific detection technology or instrumentation platform used in the assay (e.g., HTRF, AlphaScreen, FRET, TR-FRET, FP, luminescence, absorbance, imaging). Determines data interpretation rules and quality thresholds. [ENUM-REF-CANDIDATE: HTRF|AlphaScreen|FRET|TR-FRET|FP|luminescence|absorbance|imaging|SPR|ITC — promote to reference product]' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the HTS campaign, assigned by the ELN or LIMS system (e.g., HTS-EGFR-2024). Used for cross-system referencing in Dotmatics, LabWare, and project management tools.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Free-text scientific description of the HTS campaign objectives, biological rationale, assay design, and any special conditions or deviations from standard protocols. Provides context for data interpretation and scientific review.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable descriptive name of the HTS campaign, typically including the target name and campaign purpose (e.g., \'EGFR Kinase Primary Screen Q1 2024\'). Used in reports, dashboards, and scientific communications.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the HTS campaign, tracking progression from planning through execution to completion or cancellation. Drives operational dashboards and resource allocation decisions.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coefficientOfVariationPercent rdf:type rdf:Property ;
    rdfs:label 'Coefficient Of Variation Percent' ;
    rdfs:comment 'Percentage coefficient of variation of the neutral control wells across all campaign plates, measuring intra- and inter-plate reproducibility. Acceptable CV% thresholds are defined per assay type and are a key quality acceptance criterion.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compoundsScreenedCount rdf:type rdf:Property ;
    rdfs:label 'Compounds Screened Count' ;
    rdfs:comment 'Total number of unique compounds tested in this HTS campaign. Key operational metric for campaign scope, resource planning, and hit rate denominator calculation.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:croInvolved rdf:type rdf:Property ;
    rdfs:label 'Cro Involved' ;
    rdfs:comment 'Indicates whether a Contract Research Organization (CRO) was engaged to execute or support this HTS campaign. Drives vendor management, data transfer agreement requirements, and IP ownership tracking.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Overall data quality assessment for the HTS campaign based on Z\' factor, CV%, plate failure rate, and control performance. Determines whether campaign data is accepted for hit identification and downstream SAR analysis.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedPlateCount rdf:type rdf:Property ;
    rdfs:label 'Failed Plate Count' ;
    rdfs:comment 'Number of assay plates that failed quality control criteria and were excluded from hit identification analysis. High failed plate counts may trigger campaign re-screening decisions.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hitCount rdf:type rdf:Property ;
    rdfs:label 'Hit Count' ;
    rdfs:comment 'Number of compounds that met or exceeded the hit threshold criteria in this campaign. Used to calculate hit rate and to scope confirmatory screening workload.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hitRatePercent rdf:type rdf:Property ;
    rdfs:label 'Hit Rate Percent' ;
    rdfs:comment 'Percentage of screened compounds that qualified as hits (hit_count / compounds_screened_count × 100). Key campaign quality metric used to assess assay selectivity, library quality, and target druggability. Stored as a raw business measurement, not a derived KPI.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hitThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Hit Threshold Percent' ;
    rdfs:comment 'Percentage inhibition or activation threshold used to define a \'hit\' in this campaign (e.g., ≥50% inhibition at screening concentration). Determines the stringency of hit identification and directly impacts hit count and hit rate.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsBatchCode rdf:type rdf:Property ;
    rdfs:label 'Lims Batch Code' ;
    rdfs:comment 'Batch or run identifier assigned by the LIMS (LabWare or Thermo Fisher SampleManager) for the sample processing associated with this HTS campaign. Enables traceability of compound samples, plate preparation, and analytical results.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled start date for the HTS campaign as defined in the project plan. Used for resource scheduling, capacity planning, and tracking schedule adherence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plateCount rdf:type rdf:Property ;
    rdfs:label 'Plate Count' ;
    rdfs:comment 'Total number of assay plates processed during the campaign. Used for capacity planning, reagent consumption tracking, and quality control review scope.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positiveControlCompound rdf:type rdf:Property ;
    rdfs:label 'Positive Control Compound' ;
    rdfs:comment 'Name or identifier of the reference compound used as the positive control in the assay (known active compound). Defines the 100% inhibition/activation benchmark for data normalization and Z\' factor calculation.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenType rdf:type rdf:Property ;
    rdfs:label 'Screen Type' ;
    rdfs:comment 'Classification of the screening campaign by its scientific purpose in the HTS funnel. Primary screens test the full compound library; confirmatory screens re-test hits; counter-screens eliminate false positives; dose-response screens establish potency; selectivity screens assess off-target activity.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningConcentrationUm rdf:type rdf:Property ;
    rdfs:label 'Screening Concentration Um' ;
    rdfs:comment 'Single-point screening concentration in micromolar (µM) at which compounds are tested in the primary screen. Defines the activity threshold context for hit identification and is a critical parameter for hit rate comparability across campaigns.' ;
    rdfs:domain ind:HtsCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signalToBackgroundRatio rdf:type rdf:Property ;
    rdfs:label 'Signal To Background Ratio' ;
    rdfs:comment 'Ratio of the positive control signal to the background (negative control) signal, measuring the dynamic range of the assay. A higher S/B ratio indicates a more robust assay window. Complementary to Z\' factor for assay quality assessment.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screeningResultId rdf:type rdf:Property ;
    rdfs:label 'Screening Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual screening result record in the HTS or dose-response assay campaign. Primary key for the screening_result data product in the discovery domain.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryScreeningCompoundId rdf:type rdf:Property ;
    rdfs:label 'Primary Screening Compound Id' ;
    rdfs:comment 'Reference to the compound (NCE or NBE) that was screened in this assay run. Links to the compound master record in the compound library.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:compoundConcentrationUm rdf:type rdf:Property ;
    rdfs:label 'Compound Concentration Um' ;
    rdfs:comment 'Concentration of the compound tested in the assay well, expressed in micromolar (µM). Critical for dose-response curve fitting and potency determination.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:curveFitRSquared rdf:type rdf:Property ;
    rdfs:label 'Curve Fit R Squared' ;
    rdfs:comment 'Coefficient of determination (R²) from the dose-response curve fitting model. Values close to 1.0 indicate a high-quality fit. Used as a data quality gate for potency value acceptance.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ec50Nm rdf:type rdf:Property ;
    rdfs:label 'Ec50 Nm' ;
    rdfs:comment 'Half-maximal effective concentration (EC50) derived from dose-response curve fitting, expressed in nanomolar (nM). Key potency metric for agonist/activator compounds.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elnNotebookRef rdf:type rdf:Property ;
    rdfs:label 'Eln Notebook Ref' ;
    rdfs:comment 'Reference identifier linking this screening result to the corresponding experiment entry in the Electronic Lab Notebook (ELN) system (IDBS E-WorkBook or Dotmatics). Provides traceability to the original experimental record.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hillSlope rdf:type rdf:Property ;
    rdfs:label 'Hill Slope' ;
    rdfs:comment 'Hill slope (cooperativity coefficient) from the four-parameter logistic (4PL) dose-response curve fit. Values near 1 indicate simple binding; values significantly different from 1 may indicate cooperativity, aggregation, or assay artifacts.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ic50Nm rdf:type rdf:Property ;
    rdfs:label 'Ic50 Nm' ;
    rdfs:comment 'Half-maximal inhibitory concentration (IC50) derived from dose-response curve fitting, expressed in nanomolar (nM). Key potency metric for inhibitory compounds in SAR analysis and hit-to-lead progression.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Identifier of the laboratory instrument (e.g., plate reader, liquid handler, mass spectrometer) used to generate the raw signal. Supports instrument qualification tracking and systematic error investigation per GLP.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHitToLeadEligible rdf:type rdf:Property ;
    rdfs:label 'Is Hit To Lead Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this compound result meets the predefined criteria for progression into the hit-to-lead (H2L) phase, based on potency, selectivity, and data quality thresholds.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kiNm rdf:type rdf:Property ;
    rdfs:label 'Ki Nm' ;
    rdfs:comment 'Inhibition constant (Ki) representing the binding affinity of the compound to the target, expressed in nanomolar (nM). Derived from competitive binding or enzyme kinetics assays. Used in mechanistic SAR studies.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsResultRef rdf:type rdf:Property ;
    rdfs:label 'Lims Result Ref' ;
    rdfs:comment 'Reference identifier from the Laboratory Information Management System (LIMS) for this screening result record. Enables bidirectional traceability between the lakehouse silver layer and the operational LIMS source system.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxResponsePercent rdf:type rdf:Property ;
    rdfs:label 'Max Response Percent' ;
    rdfs:comment 'Maximum observed response (top asymptote) from the dose-response curve, expressed as a percentage of control. Indicates the efficacy ceiling of the compound at the target.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minResponsePercent rdf:type rdf:Property ;
    rdfs:label 'Min Response Percent' ;
    rdfs:comment 'Minimum observed response (bottom asymptote) from the dose-response curve, expressed as a percentage of control. Used to assess baseline signal and curve quality.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panAssayInterferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Pan Assay Interference Flag' ;
    rdfs:comment 'Boolean flag indicating whether the compound has been identified as a Pan-Assay Interference Compound (PAINS) — a compound that produces artifactual activity signals across multiple assays due to non-specific mechanisms. PAINS compounds are deprioritized in hit-to-lead.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:percentActivation rdf:type rdf:Property ;
    rdfs:label 'Percent Activation' ;
    rdfs:comment 'Calculated percentage activation of the target relative to controls. Primary activity metric for agonist/activator HTS campaigns. Null for inhibition assays.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentInhibition rdf:type rdf:Property ;
    rdfs:label 'Percent Inhibition' ;
    rdfs:comment 'Calculated percentage inhibition of the target activity relative to positive and negative controls on the same plate. Primary activity metric for inhibitory HTS campaigns. Null for activation assays.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plateBarcode rdf:type rdf:Property ;
    rdfs:label 'Plate Barcode' ;
    rdfs:comment 'Unique barcode identifier of the physical assay plate on which the compound was tested. Used for traceability back to the physical plate in the LIMS and for QC investigations.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plateColumn rdf:type rdf:Property ;
    rdfs:label 'Plate Column' ;
    rdfs:comment 'Numeric column designation (1–24) of the well on the assay plate. Used for spatial analysis of plate effects and systematic error detection.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plateRow rdf:type rdf:Property ;
    rdfs:label 'Plate Row' ;
    rdfs:comment 'Row designation (A–P) of the well on the assay plate. Used for spatial analysis of plate effects and edge-effect QC.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityFlagReason rdf:type rdf:Property ;
    rdfs:label 'Quality Flag Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why a data quality flag was applied (e.g., \'edge well effect\', \'reagent lot failure\', \'instrument malfunction\', \'outlier replicate\'). Required when data_quality_flag is \'flagged\' or \'rejected\'.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawSignalValue rdf:type rdf:Property ;
    rdfs:label 'Raw Signal Value' ;
    rdfs:comment 'Unprocessed instrument signal reading from the assay detector (e.g., fluorescence units, luminescence counts, absorbance). Preserved as the primary measurement for audit and reanalysis.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentLotNumber rdf:type rdf:Property ;
    rdfs:label 'Reagent Lot Number' ;
    rdfs:comment 'Lot identifier of the key assay reagent (e.g., enzyme, antibody, cell line passage) used in this assay run. Enables reagent lot correlation analysis for systematic variability investigation.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicateNumber rdf:type rdf:Property ;
    rdfs:label 'Replicate Number' ;
    rdfs:comment 'Sequential replicate index for this compound-assay combination within the same run (e.g., 1, 2, 3). Enables statistical aggregation across replicates and assessment of intra-assay variability.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultClassification rdf:type rdf:Property ;
    rdfs:label 'Result Classification' ;
    rdfs:comment 'Scientific classification of the screening result based on activity thresholds and confirmatory data. Drives hit-to-lead progression decisions. [ENUM-REF-CANDIDATE: active|inactive|inconclusive|toxic|hit|confirmed_hit|false_positive|pan_assay_interference — promote to reference product]' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'Calendar date on which the assay run was executed. Used for temporal trending, reagent lot correlation, and GLP audit trail compliance.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'Precise date and time when the assay instrument reading was captured. Supports intra-day sequencing, instrument log correlation, and 21 CFR Part 11 electronic record compliance.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:selectivityScore rdf:type rdf:Property ;
    rdfs:label 'Selectivity Score' ;
    rdfs:comment 'Quantitative selectivity score measuring the compound\'s specificity for the primary target versus off-target activities in a selectivity panel. Higher scores indicate greater selectivity. Used in SAR-driven lead optimization.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellPosition rdf:type rdf:Property ;
    rdfs:label 'Well Position' ;
    rdfs:comment 'Alphanumeric well position on the assay plate (e.g., A01, H12, P24) indicating the exact location of the compound in the plate layout. Standard SBS/ANSI plate format.' ;
    rdfs:domain ind:ScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarStudyId rdf:type rdf:Property ;
    rdfs:label 'Sar Study Id' ;
    rdfs:comment 'Unique system-generated identifier for the SAR study record. Primary key for this entity.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SarStudy .

ind:bestCompoundId rdf:type rdf:Property ;
    rdfs:label 'Best Compound Id' ;
    rdfs:comment 'Reference to the single best-performing compound identified from this SAR study, based on the combination of potency, selectivity, and ADME profile. Candidate for progression to the next discovery stage.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:leadSeriesId rdf:type rdf:Property ;
    rdfs:label 'Lead Series Id' ;
    rdfs:comment 'Reference to the lead chemical series under investigation in this SAR study. Links to the compound series master record in the compound library.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeadSeries .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date on which the SAR study was actually completed and final data locked in the ELN. Compared against target completion date for schedule variance analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:admeImpactSummary rdf:type rdf:Property ;
    rdfs:label 'Adme Impact Summary' ;
    rdfs:comment 'Narrative summary of how structural modifications in this SAR study impacted ADME properties including metabolic stability, permeability, solubility, plasma protein binding, and CYP inhibition. Sourced from LIMS and ELN data.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analogsSynthesizedCount rdf:type rdf:Property ;
    rdfs:label 'Analogs Synthesized Count' ;
    rdfs:comment 'Total count of chemical analogs synthesized and tested within this SAR study. Key productivity metric for medicinal chemistry resource planning and portfolio reporting.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Numeric score (0–100) reflecting the completeness and reliability of the experimental data captured in this SAR study, based on assay reproducibility, data completeness, and ELN audit trail integrity. Used for data governance and AI/ML model training quality gates.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyStructuralFeatures rdf:type rdf:Property ;
    rdfs:label 'Key Structural Features' ;
    rdfs:comment 'Free-text or structured description of the key chemical structural features (pharmacophores, functional groups, scaffolds, substituents) analyzed in this SAR study to drive potency, selectivity, or ADME properties.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metabolicStabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Metabolic Stability Flag' ;
    rdfs:comment 'Indicates whether the lead compounds in this SAR study met the predefined metabolic stability criteria (e.g., microsomal half-life threshold). True = criteria met; False = criteria not met.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nceNbeType rdf:type rdf:Property ;
    rdfs:label 'Nce Nbe Type' ;
    rdfs:comment 'Classification of the compound series as a New Chemical Entity (NCE, small molecule) or New Biological Entity (NBE, biologic/large molecule) or hybrid. Determines regulatory pathway and IP strategy.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentFilingFlag rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Flag' ;
    rdfs:comment 'Indicates whether a patent application has been initiated for compounds or methods arising from this SAR study. True = patent filing in progress or completed; False = no patent action taken.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permeabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Permeability Flag' ;
    rdfs:comment 'Indicates whether the lead compounds demonstrated acceptable membrane permeability (e.g., Caco-2 or PAMPA assay thresholds). True = acceptable permeability achieved; False = not achieved.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:potencyMetricType rdf:type rdf:Property ;
    rdfs:label 'Potency Metric Type' ;
    rdfs:comment 'Type of biochemical potency measurement used to characterize compound activity in this SAR study (e.g., IC50 for inhibitory concentration, Ki for inhibition constant, EC50 for effective concentration).' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potencyRangeMaxNm rdf:type rdf:Property ;
    rdfs:label 'Potency Range Max Nm' ;
    rdfs:comment 'Highest (least potent) IC50 or Ki value observed across all analogs in this SAR study, expressed in nanomolar (nM). Together with the minimum, defines the potency range of the series.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potencyRangeMinNm rdf:type rdf:Property ;
    rdfs:label 'Potency Range Min Nm' ;
    rdfs:comment 'Lowest (most potent) IC50 or Ki value observed across all analogs in this SAR study, expressed in nanomolar (nM). Represents the best-in-series potency achieved.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressionDecision rdf:type rdf:Property ;
    rdfs:label 'Progression Decision' ;
    rdfs:comment 'Outcome decision made at the conclusion of the SAR study regarding whether the lead series should progress to the next stage of drug discovery (e.g., lead optimization, candidate selection) or be deprioritized.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarHypothesis rdf:type rdf:Property ;
    rdfs:label 'Sar Hypothesis' ;
    rdfs:comment 'Scientific hypothesis describing the proposed relationship between structural features of the compound series and the observed or expected biological activity. Captured from the ELN study plan.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectivityFindings rdf:type rdf:Property ;
    rdfs:label 'Selectivity Findings' ;
    rdfs:comment 'Summary of selectivity data for the lead compounds against off-target proteins or related family members. Describes selectivity ratios, panel screening results, and any observed off-target liabilities.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectivityRatio rdf:type rdf:Property ;
    rdfs:label 'Selectivity Ratio' ;
    rdfs:comment 'Quantitative ratio of the compound\'s potency against the primary target versus the most relevant off-target (e.g., 100-fold selective over related kinase). Key metric for candidate progression decisions.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date on which the SAR study was formally initiated, corresponding to the first experimental activity recorded in the ELN. Used for timeline tracking and portfolio planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'Descriptive title of the SAR study, typically including the lead series name and therapeutic target (e.g., \'Series-7 EGFR Kinase Inhibitor Optimization\'). Used for display and search in ELN and project management tools.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyPhase rdf:type rdf:Property ;
    rdfs:label 'Study Phase' ;
    rdfs:comment 'Stage of the drug discovery funnel at which this SAR study is conducted. Aligns with the hit-to-lead and lead optimization progression framework used in medicinal chemistry.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyReportReference rdf:type rdf:Property ;
    rdfs:label 'Study Report Reference' ;
    rdfs:comment 'Document identifier or Veeva Vault reference for the formal SAR study report summarizing findings, conclusions, and progression recommendations. Provides traceability to the official scientific record.' ;
    rdfs:domain ind:SarStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle state of the SAR study. Drives workflow routing and portfolio reporting. \'terminated\' indicates early discontinuation; \'archived\' indicates data locked in ELN.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the SAR study is expected to be completed and key findings reported. Used for project milestone tracking and resource scheduling.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bestInClassCompoundId rdf:type rdf:Property ;
    rdfs:label 'Best In Class Compound Id' ;
    rdfs:comment 'Reference to the compound record representing the best-performing compound within this lead series at the current stage, used as the benchmark for potency, selectivity, and ADME profiling comparisons.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:admeProfileSummary rdf:type rdf:Property ;
    rdfs:label 'Adme Profile Summary' ;
    rdfs:comment 'Summary of the Absorption, Distribution, Metabolism, and Excretion (ADME) profile for the lead series, including key in vitro ADME data such as microsomal stability, permeability (Caco-2/PAMPA), plasma protein binding, and CYP inhibition flags.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundCount rdf:type rdf:Property ;
    rdfs:label 'Compound Count' ;
    rdfs:comment 'Total number of discrete compounds synthesized and registered within this lead series. Indicates the breadth of SAR exploration and medicinal chemistry effort invested in the series.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentStage rdf:type rdf:Property ;
    rdfs:label 'Current Stage' ;
    rdfs:comment 'Current stage of the lead series within the drug discovery pipeline, from hit confirmation through candidate nomination. Distinct from series_status in that it reflects the scientific progression stage rather than the governance lifecycle state.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprioritizationDate rdf:type rdf:Property ;
    rdfs:label 'Deprioritization Date' ;
    rdfs:comment 'Date on which the lead series was formally deprioritized or stopped. Null if the series is still active. Used for portfolio analytics and resource reallocation tracking.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugLikenessScore rdf:type rdf:Property ;
    rdfs:label 'Drug Likeness Score' ;
    rdfs:comment 'Composite drug-likeness score for the best-in-class compound in the series, typically based on Lipinski Rule of Five parameters or QED (Quantitative Estimate of Drug-likeness). Ranges from 0 to 1; higher values indicate better drug-likeness.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipLandscapeAssessment rdf:type rdf:Property ;
    rdfs:label 'Ip Landscape Assessment' ;
    rdfs:comment 'Narrative assessment of the Intellectual Property (IP) landscape for the lead series, including freedom-to-operate (FTO) status, known competitor patents covering the scaffold, and patentability assessment. Classified as confidential due to competitive sensitivity.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Status' ;
    rdfs:comment 'Current IP status of the lead series scaffold, indicating whether freedom-to-operate has been established, patents have been filed, or IP encumbrances exist. Classified as confidential.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:molecularWeightDa rdf:type rdf:Property ;
    rdfs:label 'Molecular Weight Da' ;
    rdfs:comment 'Molecular weight of the core scaffold or best-in-class compound in Daltons (Da). Key physicochemical property used in drug-likeness assessment (Lipinski Rule of Five: MW ≤ 500 Da for oral drugs).' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nceNbeClassification rdf:type rdf:Property ;
    rdfs:label 'Nce Nbe Classification' ;
    rdfs:comment 'Classification of the lead series as a New Chemical Entity (NCE), New Biological Entity (NBE), or New Molecular Entity (NME). Determines regulatory pathway, IP strategy, and data exclusivity eligibility.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationDate rdf:type rdf:Property ;
    rdfs:label 'Nomination Date' ;
    rdfs:comment 'Date on which the lead series was formally nominated as a development candidate, marking the transition from discovery to preclinical development. Null if the series has not yet been nominated.' ;
    rdfs:domain ind:Discovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oralBioavailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Oral Bioavailability Pct' ;
    rdfs:comment 'Best-in-class oral bioavailability percentage (%F) for the lead series from preclinical in vivo PK studies. Key ADME metric for assessing drug-likeness and oral dosing feasibility.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pkProfileSummary rdf:type rdf:Property ;
    rdfs:label 'Pk Profile Summary' ;
    rdfs:comment 'Summary of in vivo Pharmacokinetics (PK) data for the lead series, including key parameters such as oral bioavailability (%F), half-life (t½), clearance (CL), and volume of distribution (Vd) from preclinical species studies.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potencyAssayType rdf:type rdf:Property ;
    rdfs:label 'Potency Assay Type' ;
    rdfs:comment 'Type of biochemical or cellular assay used to determine the potency benchmark value (e.g., IC50, Ki, EC50, Kd). Provides context for interpreting the potency_benchmark_nm value.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potencyBenchmarkNm rdf:type rdf:Property ;
    rdfs:label 'Potency Benchmark Nm' ;
    rdfs:comment 'Best-in-class potency value (IC50 or Ki) for the lead series expressed in nanomolar (nM) concentration. Represents the principal quantitative performance metric for the series and is used in stage-gate go/no-go decisions.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Flag' ;
    rdfs:comment 'Indicates whether any significant safety liabilities (e.g., genotoxicity, hERG inhibition, reactive metabolites, phototoxicity) have been identified for compounds in this lead series. True = known safety liability requiring mitigation.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyLiabilityNotes rdf:type rdf:Property ;
    rdfs:label 'Safety Liability Notes' ;
    rdfs:comment 'Narrative description of identified safety liabilities for the lead series, including the nature of the liability, affected compounds, and proposed mitigation strategies. Populated when safety_flag is True.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarMaturityLevel rdf:type rdf:Property ;
    rdfs:label 'Sar Maturity Level' ;
    rdfs:comment 'Qualitative assessment of the maturity of the Structure-Activity Relationship (SAR) understanding for the lead series, from early (limited data) to mature (well-defined SAR with predictive models). Used in stage-gate assessments.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaffoldDescription rdf:type rdf:Property ;
    rdfs:label 'Scaffold Description' ;
    rdfs:comment 'Textual description of the core chemical scaffold or chemotype defining the lead series, including key structural features relevant to Structure-Activity Relationship (SAR) analysis. Captured from ELN records.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectivityProfileSummary rdf:type rdf:Property ;
    rdfs:label 'Selectivity Profile Summary' ;
    rdfs:comment 'Narrative summary of the selectivity profile for the lead series, describing off-target activity, selectivity ratios against related targets, and any known liabilities identified through selectivity panels (e.g., kinase selectivity panel, GPCR panel).' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesCode rdf:type rdf:Property ;
    rdfs:label 'Series Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the lead series within the compound governance system (e.g., ONCO-SER-00042). Used as the business identifier across ELN, LIMS, and medicinal chemistry platforms.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesName rdf:type rdf:Property ;
    rdfs:label 'Series Name' ;
    rdfs:comment 'Human-readable name assigned to the lead series, typically reflecting the chemotype or scaffold class (e.g., \'Pyrimidine Kinase Inhibitor Series A\'). Used in medicinal chemistry reports and stage-gate presentations.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesStartDate rdf:type rdf:Property ;
    rdfs:label 'Series Start Date' ;
    rdfs:comment 'Date on which the lead series was formally initiated following hit confirmation from the originating HTS campaign. Marks the beginning of the hit-to-lead phase and is used for timeline and cycle-time analytics.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seriesStatus rdf:type rdf:Property ;
    rdfs:label 'Series Status' ;
    rdfs:comment 'Current lifecycle status of the lead series within the drug discovery pipeline. Governs stage-gate decisions and resource allocation. Values: hit_to_lead (active hit confirmation and early profiling), lead_optimization (active medicinal chemistry optimization), deprioritized (paused or stopped), nominated (candidate nominated for development), on_hold (temporarily paused pending decision).' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smilesScaffold rdf:type rdf:Property ;
    rdfs:label 'Smiles Scaffold' ;
    rdfs:comment 'Simplified Molecular Input Line Entry System (SMILES) string representing the core scaffold structure of the lead series. Enables cheminformatics analysis, substructure searching, and computational chemistry workflows.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageGateDate rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Date' ;
    rdfs:comment 'Date on which the most recent stage-gate committee decision was made for this lead series. Used for tracking progression timelines and portfolio reporting.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageGateDecision rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Decision' ;
    rdfs:comment 'Most recent stage-gate committee decision for the lead series, indicating whether the series has been approved to progress (go), stopped (no_go), placed on hold, or conditionally approved pending specific criteria.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageGateRationale rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Rationale' ;
    rdfs:comment 'Documented rationale for the most recent stage-gate decision, capturing the scientific, strategic, and risk-based reasoning of the decision committee. Supports audit trail and portfolio governance.' ;
    rdfs:domain ind:LeadSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundSynthesisId rdf:type rdf:Property ;
    rdfs:label 'Compound Synthesis Id' ;
    rdfs:comment 'Unique surrogate identifier for each compound synthesis record in the discovery domain. Primary key for the compound_synthesis data product. Entity role: TRANSACTION_HEADER — a discrete synthesis event with its own lifecycle, reagents, conditions, and outcomes.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to masterdata.storage_location. Business justification: Synthesized compound storage location tracking is required for chain of custody, GMP compliance, and controlled substance scheduling. \'storage_location\' plain attribute is a denormalized reference to ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:synthesisCroBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Synthesis Cro Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Contract synthesis outsourced to CROs/CMOs requires linking synthesis records to the qualified business partner for vendor management, GMP audit trails, and regulatory batch record requirements. Disti' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:synthesisPlantId rdf:type rdf:Property ;
    rdfs:label 'Synthesis Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: GMP batch records and regulatory submissions require knowing which plant performed compound synthesis. Role prefix \'synthesis_\' distinguishes from manufacturing plant context. No existing plant FK on ' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Alphanumeric batch identifier assigned to the synthesized compound lot. Used for inventory tracking, biological testing assignment, and downstream traceability through the discovery pipeline. Aligns with SAP MM batch management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalyst rdf:type rdf:Property ;
    rdfs:label 'Catalyst' ;
    rdfs:comment 'Name and loading of the catalyst or catalytic system used in the reaction (e.g., Pd(PPh3)4, Pd2(dba)3/XPhos, DMAP). Null if the reaction is uncatalysed. Critical for SAR and process chemistry knowledge management.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundType rdf:type rdf:Property ;
    rdfs:label 'Compound Type' ;
    rdfs:comment 'Classification of the synthesized compound by modality. Distinguishes New Chemical Entities (NCE), New Biological Entities (NBE), peptides, oligonucleotides, PROTACs, fragments, and natural product derivatives. Drives downstream development pathway and regulatory strategy. [ENUM-REF-CANDIDATE: NCE|NBE|peptide|oligonucleotide|PROTAC|fragment|natural_product_derivative — promote to reference product]' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elnExperimentRef rdf:type rdf:Property ;
    rdfs:label 'Eln Experiment Ref' ;
    rdfs:comment 'Unique experiment identifier from the Electronic Lab Notebook system (IDBS E-WorkBook or Dotmatics) that documents the full experimental procedure, observations, and raw data for this synthesis. Provides traceability back to the authoritative source record.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Free-text description of the reason for synthesis failure or cancellation when synthesis_status is \'failed\' or \'cancelled\'. Captures root cause information (e.g., no reaction observed, product decomposition, purification failure, starting material unavailable) to support process learning and SAR knowledge management.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hplcPurityPercent rdf:type rdf:Property ;
    rdfs:label 'Hplc Purity Percent' ;
    rdfs:comment 'Purity of the synthesized compound as determined by High-Performance Liquid Chromatography (HPLC), expressed as area percentage. A Critical Quality Attribute (CQA) for compound registration and screening eligibility. Compounds typically require ≥95% purity for HTS submission.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nmrPurityPercent rdf:type rdf:Property ;
    rdfs:label 'Nmr Purity Percent' ;
    rdfs:comment 'Purity of the synthesized compound as determined by quantitative Nuclear Magnetic Resonance (NMR) spectroscopy, expressed as percentage. Orthogonal purity assessment to HPLC; used for structural confirmation and identity verification per GLP requirements.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productMassMg rdf:type rdf:Property ;
    rdfs:label 'Product Mass Mg' ;
    rdfs:comment 'Actual mass of isolated compound product in milligrams. Used to determine availability for biological screening, ADME assays, and compound library registration. Directly linked to synthesis scale and yield.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purificationMethod rdf:type rdf:Property ;
    rdfs:label 'Purification Method' ;
    rdfs:comment 'Method used to purify the crude reaction product to achieve the required purity specification (e.g., column chromatography, preparative HPLC, recrystallisation, trituration). Influences final yield and purity outcomes and informs process development decisions.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Reaction Duration Hours' ;
    rdfs:comment 'Total elapsed time of the synthesis reaction in hours. A Critical Process Parameter (CPP) used in reaction optimization and SAR/process correlation studies.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reactionTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Reaction Temperature C' ;
    rdfs:comment 'Temperature at which the synthesis reaction was conducted, expressed in degrees Celsius. A Critical Process Parameter (CPP) that directly influences reaction selectivity, yield, and purity. Captured from ELN experimental conditions.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentsDescription rdf:type rdf:Property ;
    rdfs:label 'Reagents Description' ;
    rdfs:comment 'Free-text or structured description of the key reagents and their stoichiometric equivalents used in the synthesis (e.g., \'K2CO3 (2.0 eq), Pd(OAc)2 (5 mol%), SPhos (10 mol%)\'). Supports reproducibility and GLP documentation requirements.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredInLibrary rdf:type rdf:Property ;
    rdfs:label 'Registered In Library' ;
    rdfs:comment 'Indicates whether the synthesized compound has been registered in the corporate compound library for HTS and biological screening. True = registered and available for screening; False = not yet registered or failed registration criteria (e.g., purity < 95%).' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smilesNotation rdf:type rdf:Property ;
    rdfs:label 'Smiles Notation' ;
    rdfs:comment 'Canonical SMILES (Simplified Molecular-Input Line-Entry System) string representing the two-dimensional chemical structure of the synthesized compound. Machine-readable format used for cheminformatics, SAR analysis, and compound database registration in Dotmatics.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solvent rdf:type rdf:Property ;
    rdfs:label 'Solvent' ;
    rdfs:comment 'Name of the primary solvent or solvent system used in the synthesis reaction (e.g., DMF, THF, DCM, EtOH, water). Influences reaction kinetics, selectivity, and downstream purification strategy. Relevant to ICH Q3C solvent classification for later-stage development.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuralConfirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Structural Confirmation Method' ;
    rdfs:comment 'Analytical technique(s) used to confirm the chemical structure of the synthesized compound (e.g., 1H-NMR, 13C-NMR, LCMS, HRMS, IR, X-ray crystallography). Structural confirmation is mandatory for compound registration and GLP compliance. [ENUM-REF-CANDIDATE: 1H-NMR|13C-NMR|LCMS|HRMS|IR|X-ray|multiple — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synthesisDate rdf:type rdf:Property ;
    rdfs:label 'Synthesis Date' ;
    rdfs:comment 'Calendar date on which the synthesis reaction was initiated. Principal business event date for this transaction record. Used for timeline tracking, GLP compliance dating, and SAR trend analysis.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:synthesisNumber rdf:type rdf:Property ;
    rdfs:label 'Synthesis Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for this synthesis event, typically assigned by the ELN (IDBS E-WorkBook or Dotmatics). Follows site-specific numbering conventions (e.g., MED-SYN-000123). Used for cross-referencing in lab notebooks, SAR databases, and regulatory submissions.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synthesisPurpose rdf:type rdf:Property ;
    rdfs:label 'Synthesis Purpose' ;
    rdfs:comment 'Scientific purpose for which this compound was synthesized. Classifies the synthesis within the drug discovery workflow (e.g., hit confirmation from HTS, lead optimisation, SAR exploration, ADME probe, tool compound, library synthesis). Enables portfolio analytics and resource allocation reporting.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synthesisScaleMmol rdf:type rdf:Property ;
    rdfs:label 'Synthesis Scale Mmol' ;
    rdfs:comment 'Molar scale of the synthesis reaction expressed in millimoles (mmol). Determines reagent quantities, expected yield mass, and suitability for downstream biological screening (e.g., HTS vs. focused assay).' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:synthesisStatus rdf:type rdf:Property ;
    rdfs:label 'Synthesis Status' ;
    rdfs:comment 'Current lifecycle state of the synthesis experiment. Tracks progression from planned through execution to completion or failure. Drives workflow routing in the medicinal chemistry pipeline.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syntheticMethod rdf:type rdf:Property ;
    rdfs:label 'Synthetic Method' ;
    rdfs:comment 'Name or classification of the synthetic methodology applied (e.g., Suzuki coupling, reductive amination, Buchwald-Hartwig amination, solid-phase synthesis). Enables SAR analysis by correlating method with yield and purity outcomes.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Percent' ;
    rdfs:comment 'Isolated yield of the target compound expressed as a percentage of the theoretical maximum based on the limiting reagent. A primary quantitative outcome metric for synthesis efficiency and SAR optimization. Range: 0.00–100.00.' ;
    rdfs:domain ind:CompoundSynthesis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:admeProfileId rdf:type rdf:Property ;
    rdfs:label 'Adme Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for each ADME profiling record in the discovery domain. Primary key for the adme_profile data product. Entity role: TRANSACTION_HEADER — captures a discrete ADME assay event with its own lifecycle and results.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdmeProfile .

ind:methodValidationId rdf:type rdf:Property ;
    rdfs:label 'Method Validation Id' ;
    rdfs:comment 'Foreign key linking to quality.method_validation. Business justification: ICH M3 and FDA BMV guidance require ADME data submitted in IND/NDA to reference validated bioanalytical methods. adme_profile already has submission_id; linking to method_validation enables regulatory' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MethodValidation .

ind:admeRiskScore rdf:type rdf:Property ;
    rdfs:label 'Adme Risk Score' ;
    rdfs:comment 'Composite numerical risk score (e.g., 0–100) summarizing overall ADME liability across solubility, permeability, metabolic stability, and DDI risk dimensions. Used for compound ranking and portfolio prioritization in discovery.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayConcentrationUm rdf:type rdf:Property ;
    rdfs:label 'Assay Concentration Um' ;
    rdfs:comment 'Concentration of the compound used in the ADME assay incubation, expressed in micromolar (µM). Required for result interpretation and inter-assay comparability; standard concentrations are typically 1–10 µM.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayDate rdf:type rdf:Property ;
    rdfs:label 'Assay Date' ;
    rdfs:comment 'Calendar date on which the ADME assay panel was executed in the laboratory. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category (day-level precision for assay scheduling and trending).' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bbbKpUu rdf:type rdf:Property ;
    rdfs:label 'Bbb Kp Uu' ;
    rdfs:comment 'Unbound brain-to-plasma concentration ratio (Kp,uu,brain), the quantitative measure of CNS penetration accounting for plasma protein binding. Values >0.3 indicate meaningful CNS exposure; used in CNS drug discovery programs.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bbbPenetration rdf:type rdf:Property ;
    rdfs:label 'Bbb Penetration' ;
    rdfs:comment 'Indicates whether the compound demonstrates blood-brain barrier penetration based on in vitro BBB assay (e.g., MDCK-MDR1, hCMEC/D3) or in vivo brain-to-plasma ratio. Critical for CNS-targeted and CNS-safety assessments.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bioavailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Bioavailability Pct' ;
    rdfs:comment 'Estimated oral bioavailability percentage (%F) derived from permeability, solubility, and metabolic stability data using predictive ADME models. Key compound progression criterion for oral drug candidates.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearanceMlMinKg rdf:type rdf:Property ;
    rdfs:label 'Clearance Ml Min Kg' ;
    rdfs:comment 'Predicted in vivo hepatic clearance in mL/min/kg, scaled from in vitro microsomal intrinsic clearance using the well-stirred liver model. Used to estimate dose and dosing interval in early drug discovery.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyp2c9InhibitionIc50Um rdf:type rdf:Property ;
    rdfs:label 'Cyp2c9 Inhibition Ic50 Um' ;
    rdfs:comment 'Half-maximal inhibitory concentration (IC50) for CYP2C9 enzyme inhibition in µM. CYP2C9 metabolizes warfarin and NSAIDs; inhibition is a critical DDI safety signal for regulatory submissions.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyp2d6InhibitionIc50Um rdf:type rdf:Property ;
    rdfs:label 'Cyp2d6 Inhibition Ic50 Um' ;
    rdfs:comment 'Half-maximal inhibitory concentration (IC50) for CYP2D6 enzyme inhibition in µM. CYP2D6 metabolizes ~25% of marketed drugs; inhibition is a major DDI liability assessed by FDA and EMA.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyp3a4InhibitionIc50Um rdf:type rdf:Property ;
    rdfs:label 'Cyp3a4 Inhibition Ic50 Um' ;
    rdfs:comment 'Half-maximal inhibitory concentration (IC50) for CYP3A4 enzyme inhibition in µM. CYP3A4 metabolizes ~50% of marketed drugs; inhibition predicts drug-drug interaction (DDI) liability. Key regulatory safety flag.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cypInhibitionFlag rdf:type rdf:Property ;
    rdfs:label 'Cyp Inhibition Flag' ;
    rdfs:comment 'Composite boolean flag indicating whether the compound exhibits significant CYP inhibition risk (any CYP isoform IC50 below the regulatory concern threshold, typically <10 µM). Used for rapid compound triage and progression gating.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effluxRatio rdf:type rdf:Property ;
    rdfs:label 'Efflux Ratio' ;
    rdfs:comment 'Ratio of basolateral-to-apical (B→A) over apical-to-basolateral (A→B) permeability in Caco-2 assay. Values >2 indicate active efflux transport (e.g., P-gp substrate), impacting oral bioavailability and CNS penetration.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:halfLifeH rdf:type rdf:Property ;
    rdfs:label 'Half Life H' ;
    rdfs:comment 'Predicted or measured plasma half-life of the compound in hours, derived from in vitro microsomal clearance data using allometric scaling or measured directly in in vivo PK studies. Informs dosing frequency predictions.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hlmClintUlMinMg rdf:type rdf:Property ;
    rdfs:label 'Hlm Clint Ul Min Mg' ;
    rdfs:comment 'Intrinsic metabolic clearance measured in human liver microsomes (HLM), expressed as µL/min/mg protein. Used to predict in vivo hepatic clearance and half-life via well-stirred liver model. Critical for dose prediction.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsSampleCode rdf:type rdf:Property ;
    rdfs:label 'Lims Sample Code' ;
    rdfs:comment 'Sample identifier assigned by the LIMS (LabWare or Thermo Fisher SampleManager) for the compound sample used in this ADME assay. Enables traceability from ADME result back to physical sample chain of custody.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metabolicStabilityClass rdf:type rdf:Property ;
    rdfs:label 'Metabolic Stability Class' ;
    rdfs:comment 'Categorical classification of compound metabolic stability based on microsomal half-life thresholds (e.g., low: t½ <30 min, medium: 30–60 min, high: >60 min). Used in compound progression scoring and SAR triage.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microsomalHalfLifeMin rdf:type rdf:Property ;
    rdfs:label 'Microsomal Half Life Min' ;
    rdfs:comment 'In vitro half-life of the compound in liver microsome incubation (human or rat), expressed in minutes. Derived from substrate depletion kinetics; used to classify metabolic stability as low/medium/high.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permeabilityCaco2NmS rdf:type rdf:Property ;
    rdfs:label 'Permeability Caco2 Nm S' ;
    rdfs:comment 'Apparent permeability coefficient (Papp A→B) measured in Caco-2 cell monolayer assay, expressed in nm/s. Predicts intestinal absorption and oral bioavailability. Key ADME parameter for BCS classification.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permeabilityPampaNmS rdf:type rdf:Property ;
    rdfs:label 'Permeability Pampa Nm S' ;
    rdfs:comment 'Passive transcellular permeability measured by PAMPA assay in nm/s. Complements Caco-2 data by isolating passive diffusion component, informing SAR optimization for membrane permeability.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pgpSubstrate rdf:type rdf:Property ;
    rdfs:label 'Pgp Substrate' ;
    rdfs:comment 'Indicates whether the compound is identified as a P-glycoprotein (P-gp / MDR1) efflux transporter substrate based on Caco-2 bidirectional permeability or dedicated P-gp inhibition assay. Impacts CNS penetration and oral bioavailability predictions.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plasmaProteinBindingPct rdf:type rdf:Property ;
    rdfs:label 'Plasma Protein Binding Pct' ;
    rdfs:comment 'Percentage of compound bound to plasma proteins (albumin, alpha-1-acid glycoprotein) measured by equilibrium dialysis or ultrafiltration. Determines free fraction available for pharmacological activity and clearance.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppbMethod rdf:type rdf:Property ;
    rdfs:label 'Ppb Method' ;
    rdfs:comment 'Analytical method used to determine plasma protein binding percentage. Rapid equilibrium dialysis (RED) is the industry standard; method choice affects result interpretation and cross-study comparability.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this ADME profiling run, used in ELN (IDBS/Dotmatics) and LIMS cross-referencing. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current workflow state of the ADME profile record from data entry through scientific review and approval. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS category. [ENUM-REF-CANDIDATE: draft|in_progress|completed|reviewed|approved|invalidated — promote to reference product if additional states are needed]' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Progression Recommendation' ;
    rdfs:comment 'Scientific recommendation for compound progression based on the overall ADME profile assessment. Drives hit-to-lead and lead optimization decisions. Assigned by the ADME scientist upon profile review and approval.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rlmClintUlMinMg rdf:type rdf:Property ;
    rdfs:label 'Rlm Clint Ul Min Mg' ;
    rdfs:comment 'Intrinsic metabolic clearance measured in rat liver microsomes (RLM), expressed as µL/min/mg protein. Supports cross-species PK scaling and preclinical-to-clinical translation of metabolic stability data.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solubilityMethod rdf:type rdf:Property ;
    rdfs:label 'Solubility Method' ;
    rdfs:comment 'Analytical method used to determine aqueous solubility, distinguishing kinetic from thermodynamic measurements which have different interpretive implications for drug development.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solubilityUm rdf:type rdf:Property ;
    rdfs:label 'Solubility Um' ;
    rdfs:comment 'Measured aqueous solubility of the compound in micromolar (µM), typically from kinetic or thermodynamic solubility assay. Critical for assessing oral bioavailability and formulation feasibility. Satisfies TRANSACTION_HEADER QUANTITATIVE_RESULT category.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:species rdf:type rdf:Property ;
    rdfs:label 'Species' ;
    rdfs:comment 'Biological species from which the biological matrix (microsomes, plasma, cells) was derived for this ADME assay. Enables cross-species PK comparison and allometric scaling for preclinical-to-clinical translation.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeOfDistributionLKg rdf:type rdf:Property ;
    rdfs:label 'Volume Of Distribution L Kg' ;
    rdfs:comment 'Predicted or measured apparent volume of distribution (Vd) in L/kg, reflecting the extent of compound distribution into tissues versus plasma. Informs PK/PD modeling and dose prediction.' ;
    rdfs:domain ind:AdmeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCandidateNominationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Candidate Nomination Date' ;
    rdfs:comment 'Date on which the development candidate was formally nominated and the project transitioned to preclinical development. Nullable until nomination occurs. Used for cycle time analytics and portfolio performance measurement.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collaborationPartnerName rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partner Name' ;
    rdfs:comment 'Name of the primary external collaboration partner (CRO, academic institution, or partner pharma company) if external_collaboration_flag is true. Classified confidential as it reveals strategic partnership information.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationType rdf:type rdf:Property ;
    rdfs:label 'Collaboration Type' ;
    rdfs:comment 'Classification of the external collaboration arrangement. Determines applicable contractual, IP, and regulatory frameworks governing data sharing and compound rights.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elnProjectCode rdf:type rdf:Property ;
    rdfs:label 'Eln Project Code' ;
    rdfs:comment 'Reference identifier for this discovery project in the IDBS E-WorkBook or Dotmatics ELN system. Enables traceability from the lakehouse silver layer back to the authoritative source system for raw experimental data.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCollaborationFlag rdf:type rdf:Property ;
    rdfs:label 'External Collaboration Flag' ;
    rdfs:comment 'Indicates whether the project involves external partners such as CROs, academic institutions, or other pharmaceutical companies. Triggers additional data governance, IP agreement, and confidentiality controls.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Glp Compliance Flag' ;
    rdfs:comment 'Indicates whether the project\'s studies are conducted under GLP regulations as required for regulatory submission. GLP-compliant studies are required for safety data submitted in IND applications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:htsCampaignCount rdf:type rdf:Property ;
    rdfs:label 'Hts Campaign Count' ;
    rdfs:comment 'Number of HTS campaigns executed under this discovery project. Provides a summary indicator of screening activity volume for portfolio reporting and resource utilization analysis.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd10 Code' ;
    rdfs:comment 'Standardized ICD-10 disease classification code for the primary disease indication. Enables cross-domain linkage to clinical, regulatory, and medical affairs data and supports regulatory submissions.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipStrategyNote rdf:type rdf:Property ;
    rdfs:label 'Ip Strategy Note' ;
    rdfs:comment 'Brief description of the IP strategy for the project, including patentability assessment, freedom-to-operate (FTO) status, and filing intentions. Classified confidential as it contains pre-filing IP strategy.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current stage of the drug discovery workflow. Progresses from target identification through candidate nomination, representing the standard industry gate-based progression model. Used for portfolio stage-gate reporting and resource planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioDecision rdf:type rdf:Property ;
    rdfs:label 'Portfolio Decision' ;
    rdfs:comment 'Most recent portfolio governance committee decision for the project. Recorded at each stage-gate review and drives resource reallocation and pipeline reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Portfolio Decision Date' ;
    rdfs:comment 'Date of the most recent portfolio governance committee decision. Used for audit trail and decision history tracking in conjunction with portfolio_decision.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known alphanumeric project identifier assigned by the portfolio governance office (e.g., DISC-20240001). Used as the business key across IDBS/Dotmatics ELN, SAP project structures, and regulatory submissions. Aligns with the BUSINESS_IDENTIFIER canonical category.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name of the drug discovery project (e.g., \'KRAS G12C Inhibitor Program\'). Classified confidential as it may reveal pipeline strategy prior to public disclosure. Aligns with the IDENTITY_LABEL canonical category.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the discovery project as managed in the portfolio governance system. Drives portfolio dashboards and resource allocation decisions. Aligns with the LIFECYCLE_STATUS canonical category.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the discovery project by the nature of the entity being developed. NCE (New Chemical Entity) and NBE (New Biological Entity) drive distinct regulatory and IP strategies. Aligns with CLASSIFICATION_OR_TYPE canonical category.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedCandidateNominationDate rdf:type rdf:Property ;
    rdfs:label 'Projected Candidate Nomination Date' ;
    rdfs:comment 'Target date by which a development candidate is expected to be nominated and handed off to preclinical development. Key milestone for pipeline planning, IND filing timelines, and portfolio forecasting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP Project System WBS element code that maps this discovery project to the financial controlling structure in SAP S/4HANA. Enables cost allocation, budget tracking, and financial reporting at the project level.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsor rdf:type rdf:Property ;
    rdfs:label 'Sponsor' ;
    rdfs:comment 'Senior executive or therapeutic area head who sponsors and champions the project at the portfolio governance level. Distinct from the project leader who manages day-to-day execution.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Tier' ;
    rdfs:comment 'Portfolio governance classification indicating the strategic importance of the project (Tier 1 = highest priority, Tier 3 = exploratory). Drives resource allocation, budget prioritization, and executive reporting. Classified confidential as it reflects pipeline strategy.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOrganism rdf:type rdf:Property ;
    rdfs:label 'Target Organism' ;
    rdfs:comment 'Primary biological system or organism used in discovery assays and preclinical models. Relevant for GLP study design, species selection justification in IND applications, and ADME/PK modeling.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Documented reason for project termination or discontinuation (e.g., safety signal, lack of efficacy, strategic reprioritization, IP conflict). Nullable for active projects. Critical for lessons-learned analysis and portfolio retrospectives. [ENUM-REF-CANDIDATE: safety_signal|lack_of_efficacy|strategic_reprioritization|ip_conflict|resource_constraints|competitive_landscape|regulatory_concern — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateNominationId rdf:type rdf:Property ;
    rdfs:label 'Candidate Nomination Id' ;
    rdfs:comment 'Unique system-generated identifier for the development candidate (DC) nomination record. Primary key for this transactional milestone event in the discovery-to-preclinical pipeline.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CandidateNomination .

ind:cmcFeasibilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Cmc Feasibility Assessment' ;
    rdfs:comment 'Assessment of the Chemistry, Manufacturing, and Controls (CMC) feasibility for the nominated compound, evaluating synthetic accessibility, scalability, and formulation developability. Informs manufacturing strategy and go/no-go decision.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date on which the nomination committee rendered its formal decision (approved, deferred, or rejected) on the development candidate nomination. May differ from nomination_date if committee review takes multiple sessions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deferralReason rdf:type rdf:Property ;
    rdfs:label 'Deferral Reason' ;
    rdfs:comment 'Documented rationale for deferral or rejection of the development candidate nomination, capturing the scientific, safety, CMC, IP, or strategic basis for the committee\'s decision. Required for governance records and future re-nomination consideration.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficacySummary rdf:type rdf:Property ;
    rdfs:label 'Efficacy Summary' ;
    rdfs:comment 'Narrative summary of key in vitro and in vivo efficacy data supporting the nomination, including primary pharmacology results from High-Throughput Screening (HTS) and lead optimization assays. Sourced from LIMS and ELN records.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedIndDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Ind Date' ;
    rdfs:comment 'Projected target date for filing the Investigational New Drug (IND) application with the FDA (or equivalent CTA with EMA/MHRA) based on the approved nomination and preclinical development plan. Key pipeline milestone for portfolio planning.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstInClass rdf:type rdf:Property ;
    rdfs:label 'First In Class' ;
    rdfs:comment 'Indicates whether the nominated development candidate represents a first-in-class mechanism of action with no approved drugs acting on the same molecular target. Informs competitive positioning, IP strategy, and regulatory designation eligibility.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoffDate rdf:type rdf:Property ;
    rdfs:label 'Handoff Date' ;
    rdfs:comment 'Date on which the nominated development candidate was formally handed off to the preclinical development team. Marks the transition from discovery to preclinical and initiates IND-enabling studies planning.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moaSummary rdf:type rdf:Property ;
    rdfs:label 'Moa Summary' ;
    rdfs:comment 'Narrative summary of the compound\'s Mechanism of Action (MOA) — how it interacts with the molecular target to produce the desired pharmacological effect. Sourced from ELN (IDBS/Dotmatics) and used in IND applications and regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationCommittee rdf:type rdf:Property ;
    rdfs:label 'Nomination Committee' ;
    rdfs:comment 'Name or identifier of the governance committee responsible for reviewing and rendering the nomination decision (e.g., Drug Discovery Committee, Portfolio Review Board, R&D Leadership Team). Supports governance traceability.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationNumber rdf:type rdf:Property ;
    rdfs:label 'Nomination Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the development candidate nomination (e.g., DC-ONCO-2024-0042). Used in cross-functional communications, regulatory filings, and portfolio tracking systems such as IDBS/Dotmatics ELN.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationStatus rdf:type rdf:Property ;
    rdfs:label 'Nomination Status' ;
    rdfs:comment 'Current lifecycle status of the development candidate nomination decision made by the nomination committee. Drives pipeline progression and resource allocation decisions. [ENUM-REF-CANDIDATE: approved|deferred|rejected|pending_review|withdrawn — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDrugEligible rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Eligible' ;
    rdfs:comment 'Indicates whether the nominated development candidate is potentially eligible for Orphan Drug Designation (ODD) based on the proposed indication affecting fewer than 200,000 patients in the US (or equivalent EU criteria). Triggers early regulatory strategy planning.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioPriority rdf:type rdf:Property ;
    rdfs:label 'Portfolio Priority' ;
    rdfs:comment 'Strategic priority classification assigned to the nominated development candidate by the R&D portfolio governance committee, reflecting unmet medical need, competitive landscape, commercial potential, and scientific confidence. Drives resource allocation.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySummary rdf:type rdf:Property ;
    rdfs:label 'Safety Summary' ;
    rdfs:comment 'Narrative summary of early safety and tolerability findings from in vitro toxicology screens, genotoxicity assays, and any preliminary in vivo safety studies conducted under Good Laboratory Practice (GLP). Informs risk assessment for IND-enabling studies.' ;
    rdfs:domain ind:CandidateNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPatientPopulation rdf:type rdf:Property ;
    rdfs:label 'Target Patient Population' ;
    rdfs:comment 'Description of the intended patient population for the proposed indication, including relevant biomarker stratification, disease stage, or demographic characteristics (e.g., adult patients with EGFR-mutant NSCLC, pediatric patients with SMA). Informs clinical trial design.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialId rdf:type rdf:Property ;
    rdfs:label 'Trial Id' ;
    rdfs:comment 'Unique surrogate identifier for each clinical trial (study) record in the Pharmaceuticals data lakehouse. Primary key for the trial master record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trial .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.demand_plan. Business justification: Commercial supply planning uses Phase 3 trial enrollment forecasts and launch timelines to model post-approval demand. S&OP process requires linking trial data to demand planning for manufacturing cap' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlan .

ind:indSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Ind Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.submission. Business justification: The specific IND or CTA submission that authorized a clinical trial is a named regulatory operations record. Regulatory affairs teams must trace which submission enabled each trial for inspection read' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: Trials are owned by specific R&D or clinical operations org units for budget allocation, headcount reporting, and internal governance. Pharma domain experts expect every trial to be assigned to a spon' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryCountryId rdf:type rdf:Property ;
    rdfs:label 'Primary Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Trials have primary regulatory jurisdiction countries. Required for regulatory authority mapping, submission planning (FDA, EMA, PMDA), country-specific compliance requirements, and trial registry sel' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:regulatoryApplicationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Application Id' ;
    rdfs:comment 'Foreign key linking to regulatory.application. Business justification: Clinical trials must link to regulatory applications (IND) to track regulatory authorization. This is mandatory for GCP compliance and regulatory inspection readiness. No visible redundant columns to ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:sponsorLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Trials are sponsored by legal entities. Essential for financial consolidation, regulatory submissions (sponsor identification in CTD), contract management, and liability tracking. Core business relati' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:actualEnrollment rdf:type rdf:Property ;
    rdfs:label 'Actual Enrollment' ;
    rdfs:comment 'Actual number of patients enrolled (consented and randomized or assigned to treatment) as tracked in Oracle/Siebel CTMS and Medidata Rave EDC. Updated in real-time during trial execution. Used for enrollment rate monitoring and milestone tracking.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPrimaryCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Primary Completion Date' ;
    rdfs:comment 'Actual date on which the last patient completed the primary endpoint assessment (LPLV). Recorded in CTMS and Medidata Rave. Triggers database lock procedures and Clinical Study Report (CSR) preparation.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisPopulation rdf:type rdf:Property ;
    rdfs:label 'Analysis Population' ;
    rdfs:comment 'Statistical analysis population used for the primary endpoint analysis. Intent-to-Treat (ITT) is the regulatory gold standard for confirmatory trials. Per Protocol (PP) is used as a sensitivity analysis. Defined in the Statistical Analysis Plan (SAP).' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingType rdf:type rdf:Property ;
    rdfs:label 'Blinding Type' ;
    rdfs:comment 'Level of blinding applied to the trial to minimize bias. Double-blind is the gold standard for Phase 3 confirmatory trials. Open-label is common in oncology and rare disease studies. Impacts GCP compliance requirements and unblinding procedures.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Type of control arm used in the trial. Placebo-controlled is standard for regulatory approval; active comparator is required when placebo is unethical. Historical control is used in rare disease single-arm studies.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Csr Completion Date' ;
    rdfs:comment 'Date on which the Clinical Study Report (CSR) was finalized and approved per ICH E3 guidelines. The CSR is a mandatory component of NDA/BLA/MAA regulatory submissions. Tracked in Veeva Vault eTMF.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctaReference rdf:type rdf:Property ;
    rdfs:label 'Cta Reference' ;
    rdfs:comment 'Regulatory authority-assigned Clinical Trial Authorisation reference number for trials conducted in EU/EEA, UK (MHRA), or other ex-US jurisdictions. Supports multi-regional trial tracking.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:databaseLockDate rdf:type rdf:Property ;
    rdfs:label 'Database Lock Date' ;
    rdfs:comment 'Date on which the clinical trial database was locked in Medidata Rave EDC following data cleaning, query resolution, and medical review sign-off. Marks the point after which no further data changes are permitted without formal unblinding procedures. Critical milestone for regulatory submissions.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eclinicalSystemStudyReference rdf:type rdf:Property ;
    rdfs:label 'Eclinical System Study Reference' ;
    rdfs:comment 'Study identifier assigned in Medidata Rave EDC system. Used to cross-reference clinical data collected in Rave with CTMS records and the trial master record. Enables data lineage tracing from source EDC to the Silver layer.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etmfVaultReference rdf:type rdf:Property ;
    rdfs:label 'Etmf Vault Reference' ;
    rdfs:comment 'Veeva Vault eTMF study-level document identifier linking this trial master record to the corresponding eTMF study folder. Enables direct navigation to trial documentation for regulatory inspection readiness.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudractNumber rdf:type rdf:Property ;
    rdfs:label 'Eudract Number' ;
    rdfs:comment 'Unique identifier assigned by the European Clinical Trials Database (EudraCT / CTIS) for trials conducted in the European Economic Area. Required for EMA regulatory submissions and MAA dossiers.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Status' ;
    rdfs:comment 'Current GCP compliance status of the trial based on internal quality oversight, audit findings, and regulatory inspection outcomes. Critical findings may trigger clinical holds. Tracked in MasterControl/TrackWise QMS and Veeva Vault.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indNumber rdf:type rdf:Property ;
    rdfs:label 'Ind Number' ;
    rdfs:comment 'FDA-assigned IND application number under which this trial is conducted. Links the trial to the regulatory submission record. Required for all Phase I–III trials in the US. May reference multiple INDs for combination studies.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Date' ;
    rdfs:comment 'Planned date for the pre-specified interim efficacy or futility analysis reviewed by the Data Safety Monitoring Board (DSMB). Relevant for adaptive trials and trials with early stopping rules. Defined in the Statistical Analysis Plan.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irbApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Status' ;
    rdfs:comment 'Status of IRB/Independent Ethics Committee (IEC) approval for the trial protocol. Mandatory before any patient enrollment. Tracked per jurisdiction. Suspension triggers immediate halt of enrollment per GCP requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdaptiveDesign rdf:type rdf:Property ;
    rdfs:label 'Is Adaptive Design' ;
    rdfs:comment 'Indicates whether the trial employs a pre-specified adaptive design allowing modifications to the trial or statistical procedures based on interim data analysis. Requires additional FDA/EMA guidance compliance per ICH E20.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPediatricStudy rdf:type rdf:Property ;
    rdfs:label 'Is Pediatric Study' ;
    rdfs:comment 'Indicates whether the trial includes a pediatric population (patients under 18 years). Triggers Pediatric Study Plan (PIP/PSP) requirements under FDA PREA and EMA Paediatric Regulation. Impacts regulatory strategy and labeling.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nctNumber rdf:type rdf:Property ;
    rdfs:label 'Nct Number' ;
    rdfs:comment 'Unique public registry identifier assigned by ClinicalTrials.gov (U.S. National Library of Medicine). Mandatory for trials subject to FDAAA 801 registration requirements. Used in regulatory submissions and public disclosure.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEnrollment rdf:type rdf:Property ;
    rdfs:label 'Planned Enrollment' ;
    rdfs:comment 'Target number of patients to be enrolled in the trial as specified in the approved protocol and IND/CTA. Basis for site activation planning, supply chain forecasting, and budget allocation in SAP.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedPrimaryCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Primary Completion Date' ;
    rdfs:comment 'Planned date for Last Patient Last Visit (LPLV) for the primary endpoint assessment. Registered in ClinicalTrials.gov as the Primary Completion Date. Drives regulatory submission timeline planning for NDA/BLA/MAA.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryEndpoint rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint' ;
    rdfs:comment 'The principal clinical outcome measure that the trial is powered to demonstrate (e.g., \'Overall Survival (OS)\', \'Progression-Free Survival (PFS)\', \'Objective Response Rate (ORR)\', \'Complete Remission Rate\'). Defined in the protocol and statistical analysis plan. Drives regulatory approval decisions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Type' ;
    rdfs:comment 'Type of regulatory submission associated with this trial\'s data package. IND for US investigational studies; NDA/BLA for US marketing applications; MAA for EU; CTA for clinical trial authorisation. Links to the regulatory.submission domain. [ENUM-REF-CANDIDATE: IND|NDA|BLA|MAA|sNDA|sBLA|CTA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortTitle rdf:type rdf:Property ;
    rdfs:label 'Short Title' ;
    rdfs:comment 'Abbreviated or acronym-based title used for internal operational reference, CTMS displays, and cross-functional communications (e.g., \'MONARCH-3\', \'KEYNOTE-522\').' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsor Protocol Number' ;
    rdfs:comment 'Internal protocol identifier assigned by Pharmaceuticals as the trial sponsor. Used as the primary cross-system reference in Oracle/Siebel CTMS, Medidata Rave EDC, Veeva Vault eTMF, and SAP. Serves as the BUSINESS_IDENTIFIER for this master record.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDesignType rdf:type rdf:Property ;
    rdfs:label 'Study Design Type' ;
    rdfs:comment 'Fundamental design classification of the clinical trial. Determines statistical analysis plan requirements, randomization procedures, and regulatory acceptability. Adaptive designs require additional ICH E20 compliance documentation. [ENUM-REF-CANDIDATE: randomized|non_randomized|single_arm|crossover|adaptive|basket|umbrella — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialStatus rdf:type rdf:Property ;
    rdfs:label 'Trial Status' ;
    rdfs:comment 'Current lifecycle state of the clinical trial. Drives operational workflows, regulatory reporting obligations, and eTMF archival triggers. \'on_hold\' indicates a clinical hold per 21 CFR 312.42. Serves as the LIFECYCLE_STATUS for this master record.' ;
    rdfs:domain ind:Trial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolId rdf:type rdf:Property ;
    rdfs:label 'Protocol Id' ;
    rdfs:comment 'Unique surrogate identifier for each versioned clinical trial protocol record in the Silver Layer lakehouse. Primary key for the protocol data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Protocol .

ind:allocationRatio rdf:type rdf:Property ;
    rdfs:label 'Allocation Ratio' ;
    rdfs:comment 'Ratio of subjects assigned to each treatment arm (e.g., 1:1, 2:1, 1:1:1). Directly impacts sample size calculations and statistical power. Documented in the randomization section of the protocol.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential integer counter for protocol amendments. Zero (0) indicates the original protocol; each subsequent amendment increments by one. Supports amendment history tracking and regulatory submission traceability.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentRationale rdf:type rdf:Property ;
    rdfs:label 'Amendment Rationale' ;
    rdfs:comment 'Documented justification for protocol changes introduced in this amendment version. Required by regulatory agencies to assess the impact of changes on subject safety, data integrity, and study validity. Null for original protocol (amendment_number = 0).' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment\'s regulatory significance. \'Substantial\' amendments require prior regulatory authority approval; \'non_substantial\' require notification only; \'administrative\' are minor corrections. Determines regulatory submission pathway.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingMethod rdf:type rdf:Property ;
    rdfs:label 'Blinding Method' ;
    rdfs:comment 'Level of masking applied to the trial to prevent bias. Double-blind masks both subject and investigator; open-label has no masking. Critical for GCP compliance and regulatory acceptance of efficacy data.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicaltrialsGovNumber rdf:type rdf:Property ;
    rdfs:label 'Clinicaltrials Gov Number' ;
    rdfs:comment 'National Clinical Trial (NCT) identifier assigned by ClinicalTrials.gov upon trial registration. Mandatory for FDA-regulated trials under FDAAA 801 and required for publication in peer-reviewed journals per ICMJE policy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designType rdf:type rdf:Property ;
    rdfs:label 'Design Type' ;
    rdfs:comment 'Structural design of the clinical trial. Determines how treatment arms are organized and how subjects are allocated. Informs statistical analysis plan and regulatory review strategy. [ENUM-REF-CANDIDATE: parallel|crossover|factorial|single_arm|basket|umbrella|platform — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosingRegimen rdf:type rdf:Property ;
    rdfs:label 'Dosing Regimen' ;
    rdfs:comment 'Description of the investigational product dose, route of administration, frequency, and duration for each treatment arm (e.g., Drug X 200mg IV Q3W for 12 cycles). Directly linked to CMC and IND/NDA/BLA submissions.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Conditions or characteristics that disqualify a subject from enrollment (e.g., prior therapy, comorbidities, contraindications). Complements inclusion criteria to define the eligible study population.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exploratoryObjectives rdf:type rdf:Property ;
    rdfs:label 'Exploratory Objectives' ;
    rdfs:comment 'Hypothesis-generating objectives not powering the study, such as biomarker analyses, translational research endpoints, or health economics and outcomes research (HEOR) assessments. Supports future study design and RWE generation.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpComplianceAttestation rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Attestation' ;
    rdfs:comment 'Boolean flag indicating whether this protocol version has been formally attested as compliant with ICH E6(R2) Good Clinical Practice guidelines. Required for regulatory submissions and audit readiness.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Inclusion Criteria' ;
    rdfs:comment 'Eligibility criteria that subjects must meet to be enrolled in the trial (e.g., age range, diagnosis, performance status, biomarker positivity). Defines the Intent-to-Treat (ITT) population. Stored as structured free text per protocol.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Date' ;
    rdfs:comment 'Date on which the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) granted approval for this protocol version. Milestone date for site activation and GCP compliance documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irbApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the IRB/IEC approval for this protocol version. Required for GCP compliance and site activation. Tracked in Veeva Vault eTMF under the Trial Master File structure.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSampleSize rdf:type rdf:Property ;
    rdfs:label 'Planned Sample Size' ;
    rdfs:comment 'Total number of subjects planned for enrollment as determined by the sample size justification in the protocol. Based on statistical power calculations for the primary endpoint. Drives site activation and enrollment planning.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryObjective rdf:type rdf:Property ;
    rdfs:label 'Primary Objective' ;
    rdfs:comment 'The principal scientific and clinical objective of the trial as stated in the protocol. Defines the primary endpoint and the key question the study is designed to answer (e.g., demonstrate superiority in Overall Survival).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolNumber rdf:type rdf:Property ;
    rdfs:label 'Protocol Number' ;
    rdfs:comment 'Sponsor-assigned unique protocol identifier used across all regulatory submissions, eTMF filings, and CTMS records. Externally known identifier referenced in IND/NDA/BLA/MAA dossiers.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolStatus rdf:type rdf:Property ;
    rdfs:label 'Protocol Status' ;
    rdfs:comment 'Current lifecycle state of this protocol version. \'draft\' indicates work-in-progress; \'under_review\' indicates IRB/IEC or sponsor review; \'approved\' indicates fully authorized for use; \'superseded\' indicates replaced by a newer amendment; \'retired\' indicates withdrawn.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationScheme rdf:type rdf:Property ;
    rdfs:label 'Randomization Scheme' ;
    rdfs:comment 'Method used to randomly allocate subjects to treatment arms. Stratified randomization accounts for prognostic factors; adaptive randomization adjusts allocation ratios based on accumulating data. Documented in the protocol and statistical analysis plan.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeJustification rdf:type rdf:Property ;
    rdfs:label 'Sample Size Justification' ;
    rdfs:comment 'Narrative description of the statistical assumptions and power calculations supporting the planned sample size, including assumed effect size, alpha level, power, and dropout rate. Required by ICH E9(R1) and regulatory agencies.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapReference rdf:type rdf:Property ;
    rdfs:label 'Sap Reference' ;
    rdfs:comment 'Document identifier or version reference for the Statistical Analysis Plan (SAP) associated with this protocol version. The SAP details the pre-specified statistical methods for analyzing primary and secondary endpoints per ICH E9(R1).' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactors rdf:type rdf:Property ;
    rdfs:label 'Stratification Factors' ;
    rdfs:comment 'Clinical or demographic variables used to stratify randomization to ensure balanced treatment arms (e.g., disease stage, ECOG performance status, geographic region, biomarker status). Stored as free text per protocol specification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Broad classification of the study design indicating whether the trial involves an active intervention, passive observation, or special access program. Aligns with ClinicalTrials.gov and EudraCT registration categories.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitScheduleSummary rdf:type rdf:Property ;
    rdfs:label 'Visit Schedule Summary' ;
    rdfs:comment 'High-level description of the Schedule of Assessments (SoA) including number of study visits, key assessment windows, and follow-up duration. Detailed SoA is maintained in the protocol appendix and Medidata Rave EDC configuration.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationalSiteId rdf:type rdf:Property ;
    rdfs:label 'Investigational Site Id' ;
    rdfs:comment 'Unique surrogate identifier for the investigational site record in the clinical data lakehouse. Primary key for this master record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestigationalSite .

ind:distributionNetworkId rdf:type rdf:Property ;
    rdfs:label 'Distribution Network Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_network. Business justification: Sites receive IMP through specific distribution nodes (depots/warehouses); GDP compliance requires documented supply chain routing. Clinical supply management uses this for shipment planning, temperat' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionNetwork .

ind:managingOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Managing Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: Investigational sites are managed by regional or country clinical operations org units responsible for site monitoring, budget oversight, and performance reporting. Pharma clinical ops teams require t' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:masterdataAddressId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Address Id' ;
    rdfs:comment 'Foreign key linking to masterdata.address. Business justification: Sites have standardized physical addresses. Required for site management, investigational product shipments, monitoring visit planning, regulatory documentation (site lists in submissions), and geoloc' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:siteBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Site Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Investigational sites are registered as business partners (vendors) in pharma masterdata for site fee payments, investigator grant processing, and vendor qualification audits. This is a standard accou' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:siteInternalOrderId rdf:type rdf:Property ;
    rdfs:label 'Site Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Sites incur costs tracked via internal orders for site activation, monitoring, patient recruitment, and investigator fees. Essential for trial budget management, site payment processing, and cost-per-' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:siteLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Site Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: Sites are owned/operated by legal entities (hospitals, research institutions, private practices). Required for clinical trial agreements (CTAs), payment processing, insurance/liability coverage, and r' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date on which the site close-out visit was completed and the site was formally closed. All essential documents must be archived in eTMF (Veeva Vault) by this date.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrolledSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Subject Count' ;
    rdfs:comment 'Actual number of subjects who have been randomized and enrolled at this site to date. Compared against enrollment_target to assess site performance and trigger enrollment support actions.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentTarget rdf:type rdf:Property ;
    rdfs:label 'Enrollment Target' ;
    rdfs:comment 'Planned number of subjects to be enrolled at this site as agreed between the sponsor and principal investigator. Used for enrollment forecasting, site performance benchmarking, and IMP supply planning.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etmfSiteFolderReference rdf:type rdf:Property ;
    rdfs:label 'Etmf Site Folder Reference' ;
    rdfs:comment 'Reference identifier for the site-level folder in the Veeva Vault eTMF system. Links the site master record to its essential document archive for GCP inspection readiness and regulatory submission support.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feasibilityDate rdf:type rdf:Property ;
    rdfs:label 'Feasibility Date' ;
    rdfs:comment 'Date on which the site feasibility assessment was completed, confirming the site\'s capability, patient population, and infrastructure to conduct the trial. First milestone in the site activation timeline tracked in CTMS.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fpfvActualDate rdf:type rdf:Property ;
    rdfs:label 'Fpfv Actual Date' ;
    rdfs:comment 'Actual date on which the first patient first visit (FPFV) occurred at this site. Compared against fpfv_target_date to measure site activation performance and enrollment timeline adherence.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fpfvTargetDate rdf:type rdf:Property ;
    rdfs:label 'Fpfv Target Date' ;
    rdfs:comment 'Planned date for the first patient first visit (FPFV) at this site, representing the target enrollment start. Used for enrollment forecasting and site performance tracking against the clinical development timeline.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Gcp Inspection Status' ;
    rdfs:comment 'Current GCP inspection status of the investigational site by a regulatory authority (FDA, EMA, MHRA, PMDA). Critical for site risk assessment, regulatory submission support, and pre-approval inspection (PAI) readiness.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationalSiteStatus rdf:type rdf:Property ;
    rdfs:label 'Investigational Site Status' ;
    rdfs:comment 'Current operational lifecycle status of the investigational site within the clinical program. Drives CRA monitoring schedules, IMP shipment eligibility, and enrollment reporting. Values: selected (identified for participation), activated (SIV complete, ready to enroll), enrolling (actively screening/randomizing subjects), on_hold (enrollment paused), closed (no further activity), terminated (early discontinuation).' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecApprovalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Expiry Date' ;
    rdfs:comment 'Date on which the current IRB/IEC approval for the trial protocol at this site expires. Triggers renewal workflow; enrollment must be suspended if approval lapses without renewal.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irbIecApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Number' ;
    rdfs:comment 'Official approval reference number issued by the IRB/IEC for the clinical trial protocol at this site. Mandatory for site activation and must be filed in the eTMF (Veeva Vault) prior to first patient first visit (FPFV).' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecName rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Name' ;
    rdfs:comment 'Name of the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) of record responsible for ethical oversight of clinical trial activities at this site. Required for GCP compliance and eTMF documentation in Veeva Vault.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGcpTrained rdf:type rdf:Property ;
    rdfs:label 'Is Gcp Trained' ;
    rdfs:comment 'Indicates whether all required site staff have completed GCP training as documented in the eTMF (Veeva Vault) prior to site activation. Mandatory pre-condition for site initiation per ICH E6(R2).' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadSite rdf:type rdf:Property ;
    rdfs:label 'Is Lead Site' ;
    rdfs:comment 'Indicates whether this site is designated as the lead or coordinating site for a multi-center trial. Lead sites often host the coordinating investigator and serve as the primary regulatory contact.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastGcpInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Gcp Inspection Date' ;
    rdfs:comment 'Date of the most recent GCP inspection conducted at this site by a regulatory authority. Used to assess inspection recency and site compliance history for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lplvActualDate rdf:type rdf:Property ;
    rdfs:label 'Lplv Actual Date' ;
    rdfs:comment 'Actual date on which the last patient last visit (LPLV) occurred at this site, marking the end of active patient participation. Triggers site close-out visit scheduling and IMP reconciliation.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthorityJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Jurisdiction' ;
    rdfs:comment 'Primary regulatory authority with jurisdiction over the investigational site\'s clinical trial activities. Determines applicable GCP guidelines, inspection readiness requirements, and submission standards (IND/NDA/BLA/MAA). [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|OTHER — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenFailureCount rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Count' ;
    rdfs:comment 'Number of subjects who were screened but failed to meet eligibility criteria at this site. Used to calculate screen failure rate and assess protocol feasibility and patient population fit.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selectionDate rdf:type rdf:Property ;
    rdfs:label 'Selection Date' ;
    rdfs:comment 'Date on which the sponsor formally selected the site for participation in the clinical trial, following feasibility review. Marks transition to site status \'selected\' in CTMS.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the investigational site by institutional category, used for site selection strategy, feasibility analysis, and enrollment benchmarking. [ENUM-REF-CANDIDATE: academic_medical_center|community_hospital|private_clinic|research_center|cro_managed|veterans_affairs|pediatric_center — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sivDate rdf:type rdf:Property ;
    rdfs:label 'Siv Date' ;
    rdfs:comment 'Date on which the Site Initiation Visit (SIV) was conducted by the Clinical Research Associate (CRA). Confirms site readiness, staff training, and IMP accountability procedures. Required before first patient enrollment.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the investigational site (e.g., America/New_York, Europe/London). Used for accurate timestamp alignment of EDC data from Medidata Rave, adverse event reporting timelines, and CRA scheduling.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Id' ;
    rdfs:comment 'Unique surrogate identifier for the principal investigator or sub-investigator master record in the clinical domain. Serves as the primary key for this entity across all downstream clinical data products.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrincipalInvestigator .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to hcp.contract. Business justification: Each principal investigator\'s trial participation is governed by a signed investigator agreement (contract). Direct FK enables financial disclosure tracking, FMV compliance validation, and OIG/SAM scr' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:ctmsInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Ctms Investigator Id' ;
    rdfs:comment 'Source system identifier for this investigator as recorded in Oracle Clinical / Siebel CTMS. Used for cross-system reconciliation and lineage tracing back to the operational CTMS record.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:hcpMasterId rdf:type rdf:Property ;
    rdfs:label 'Hcp Master Id' ;
    rdfs:comment 'FK to hcp.hcp_master.hcp_master_id — Principal investigators are HCPs — linking PI records to HCP master enables unified view of an HCPs relationship with the company across clinical, commercial, and medical affairs activities.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:investigatorBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Investigator Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Principal investigators receive investigator grants and honoraria requiring registration as business partners for payment processing, financial disclosure compliance (Sunshine Act), and vendor qualifi' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:licenseCountryId rdf:type rdf:Property ;
    rdfs:label 'License Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: PIs hold medical licenses in specific countries. Required for regulatory compliance verification, license validation against country-specific medical boards, Form FDA 1572 validation, and investigator' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:reporterId rdf:type rdf:Property ;
    rdfs:label 'Reporter Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.reporter. Business justification: Principal Investigators are primary reporters of trial SAEs/SUSARs to sponsors. Linking PI identity to PV reporter records enables causality assessment tracking, follow-up correspondence, and regulato' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reporter .

ind:country rdf:type rdf:Property ;
    rdfs:label 'Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the investigator primarily practices and conducts clinical trial activities. Determines applicable regulatory framework (FDA, EMA, PMDA, NMPA, etc.).' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Cv Document Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the investigator\'s current curriculum vitae stored in Veeva Vault eTMF. The CV is a mandatory eTMF document (TMF Reference Model artifact 01.01) required for regulatory submissions and site qualification.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationLogReference rdf:type rdf:Property ;
    rdfs:label 'Delegation Log Reference' ;
    rdfs:comment 'Reference identifier pointing to the investigator\'s delegation of authority log stored in Veeva Vault eTMF or site trial master file. The delegation log documents which trial tasks have been assigned to sub-investigators and site staff, as required by GCP.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary professional email address of the investigator used for trial-related communications, protocol amendments, and safety notifications. Distinct from personal email; should be institutional or practice-based.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaDebarmentCheckDate rdf:type rdf:Property ;
    rdfs:label 'Fda Debarment Check Date' ;
    rdfs:comment 'Date on which the investigator was last verified against the FDA Debarment List and the Office of Inspector General (OIG) exclusion database. Mandatory pre-engagement check and periodic re-verification per sponsor SOPs.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Financial Disclosure Date' ;
    rdfs:comment 'Date on which the investigator\'s financial disclosure form (FDA Form 3454 or 3455) was most recently submitted or updated. Required for NDA/BLA submissions to FDA.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialDisclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Disclosure Status' ;
    rdfs:comment 'Status of the investigator\'s financial disclosure form (FDA Form 3454/3455) as required under 21 CFR Part 54. Indicates whether the investigator has disclosed financial interests that could affect trial integrity. \'Disclosed\' means the form has been submitted and reviewed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal given name of the principal investigator or sub-investigator as it appears on their medical license and regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:form1572Date rdf:type rdf:Property ;
    rdfs:label 'Form 1572 Date' ;
    rdfs:comment 'Date on which the investigator signed FDA Form 1572 (Statement of Investigator) for the most recent trial engagement. Form 1572 is a legal commitment by the investigator to comply with FDA regulations and GCP. Required for all IND-regulated trials in the US.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Date' ;
    rdfs:comment 'Date on which the investigator most recently completed GCP training as required by ICH E6(R2). Mandatory for trial participation; triggers re-training alerts when approaching the validity window (typically 2-3 years).' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Expiry Date' ;
    rdfs:comment 'Date on which the current GCP training certification expires. Investigators with expired GCP training must not conduct trial activities. Drives compliance monitoring and site qualification workflows.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingProvider rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Provider' ;
    rdfs:comment 'Name of the organization or platform that delivered the GCP training (e.g., CITI Program, TransCelerate, sponsor-internal training). Supports audit trail for regulatory inspections.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorRole rdf:type rdf:Property ;
    rdfs:label 'Investigator Role' ;
    rdfs:comment 'GCP-defined role of the individual at the investigational site: Principal Investigator (PI) who bears overall responsibility, Sub-Investigator (sub-I) who assists under PI supervision, or Coordinating Investigator who coordinates multi-site activities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorStatus rdf:type rdf:Property ;
    rdfs:label 'Investigator Status' ;
    rdfs:comment 'Current lifecycle status of the investigator record. \'Active\' indicates the investigator is qualified and currently engaged in trial conduct. \'Disqualified\' reflects FDA or regulatory authority debarment or disqualification actions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Registration Number' ;
    rdfs:comment 'Registration number of the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) with which the investigator\'s site is registered. Required for FDA-regulated trials under 21 CFR Part 56 and ICH E6(R2).' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDebarred rdf:type rdf:Property ;
    rdfs:label 'Is Debarred' ;
    rdfs:comment 'Indicates whether the investigator is currently listed on the FDA Debarment List or OIG exclusion database. A value of True immediately disqualifies the investigator from participating in any FDA-regulated clinical trial.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal family name of the principal investigator or sub-investigator as it appears on their medical license and regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date on which the investigator\'s medical license expires. Triggers re-qualification workflows to ensure continued GCP-compliant trial conduct. Null if the license has no expiry.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'License Issuing Authority' ;
    rdfs:comment 'Name of the regulatory or professional body that issued the medical license (e.g., California Medical Board, General Medical Council UK, Ordre des Médecins France). Required for cross-border trial conduct verification.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Medical License Number' ;
    rdfs:comment 'State or national medical license number issued by the relevant licensing authority. Required for regulatory submissions and site qualification. Uniquely identifies the investigator\'s right to practice medicine.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalSpecialty rdf:type rdf:Property ;
    rdfs:label 'Medical Specialty' ;
    rdfs:comment 'Primary board-certified or recognized medical specialty of the investigator (e.g., Oncology, Immunology, Cardiology, Neurology). Used to match investigator expertise to trial therapeutic area and protocol requirements.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the investigator as recorded on official credentials. Used for disambiguation when first and last names are not unique.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npiNumber rdf:type rdf:Property ;
    rdfs:label 'Npi Number' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) assigned by CMS to US-based healthcare providers. Used for US-specific investigator identification, cross-referencing with HCP databases, and commercial engagement separation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orcidIdentifier rdf:type rdf:Property ;
    rdfs:label 'Orcid Identifier' ;
    rdfs:comment 'Persistent digital identifier (ORCID iD) assigned to the investigator by the ORCID registry. Used to uniquely identify researchers across publications, grant applications, and clinical trial registries (e.g., ClinicalTrials.gov).' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary professional phone number for the investigator, used for urgent safety communications, protocol queries, and site monitoring contact. Includes country code for international trials.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorTrialCount rdf:type rdf:Property ;
    rdfs:label 'Prior Trial Count' ;
    rdfs:comment 'Total number of GCP-regulated clinical trials in which the investigator has previously served as PI or sub-investigator. Key feasibility metric used by sponsors and CROs during site selection.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:professionalTitle rdf:type rdf:Property ;
    rdfs:label 'Professional Title' ;
    rdfs:comment 'Highest relevant professional or academic degree held by the investigator (e.g., MD, PhD, PharmD). Used in regulatory submissions and delegation logs. [ENUM-REF-CANDIDATE: MD|DO|PhD|MD-PhD|PharmD|MBBS|MBChB|DVM|Other — promote to reference product]' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Verified Date' ;
    rdfs:comment 'Date on which the sponsor or CRO last verified the investigator\'s qualifications, credentials, and GCP training as part of the site qualification or re-qualification process. Supports audit trail for regulatory inspections.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthorityRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Registration Number' ;
    rdfs:comment 'Identifier assigned by a national regulatory authority for the investigator\'s registration to conduct clinical trials (e.g., FDA investigator registration number, EudraCT investigator ID, MHRA registration). Required for IND/NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subSpecialty rdf:type rdf:Property ;
    rdfs:label 'Sub Specialty' ;
    rdfs:comment 'Secondary or sub-specialty area of clinical expertise (e.g., Hematologic Oncology, Pediatric Immunology). Provides finer-grained matching for complex or rare disease trials.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfClinicalTrialExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Clinical Trial Experience' ;
    rdfs:comment 'Number of years the investigator has been conducting GCP-regulated clinical trials. Used during site feasibility assessments to evaluate investigator experience relative to protocol complexity.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinicalEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Clinical Enrollment Id' ;
    rdfs:comment 'Unique surrogate identifier for each subject enrollment and randomization record within a clinical trial. Primary key for the enrollment data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalEnrollment .

ind:dispensedInventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Dispensed Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: Subject-level IMP accountability requires knowing which inventory lot was dispensed to each enrolled subject. GCP IMP accountability logs and pharmacovigilance lot traceability per subject are regulat' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:investigationalProductId rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Id' ;
    rdfs:comment 'Foreign key linking to clinical.investigational_product. Business justification: Enrolled subjects are assigned to specific investigational product kits at randomization. While enrollment has treatment_arm_code, linking to investigational_product provides the actual IMP kit assign' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestigationalProduct .

ind:patientId rdf:type rdf:Property ;
    rdfs:label 'Patient Id' ;
    rdfs:comment 'Reference to the clinical trial subject (patient) record. Links to the subject master record sourced from Medidata Rave EDC.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patient .

ind:blindingStatus rdf:type rdf:Property ;
    rdfs:label 'Blinding Status' ;
    rdfs:comment 'Indicates the current blinding state of the subject\'s treatment assignment. \'blinded\' = treatment assignment concealed; \'open_label\' = treatment known from outset; \'unblinded\' = previously blinded assignment has been revealed. Critical for data integrity and regulatory compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockSize rdf:type rdf:Property ;
    rdfs:label 'Block Size' ;
    rdfs:comment 'The number of subjects per randomization block used in the blocked randomization scheme. Confidential as knowledge of block size could compromise blinding. Sourced from Medidata Rave RTSM randomization parameters.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date on which the subject completed all protocol-required study procedures and follow-up visits. Populated only when enrollment_status = completed. Used for study close-out and final analysis datasets.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctmsSubjectKey rdf:type rdf:Property ;
    rdfs:label 'Ctms Subject Key' ;
    rdfs:comment 'The natural/business key for this subject enrollment record as assigned by Oracle Clinical / Siebel CTMS. Used for cross-system reconciliation between CTMS and Medidata Rave EDC. Supports data lineage and audit trail requirements.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLockFlag rdf:type rdf:Property ;
    rdfs:label 'Data Lock Flag' ;
    rdfs:comment 'Flag indicating whether the subject\'s enrollment and randomization data has been locked for analysis (database lock). True = data locked and frozen for statistical analysis; False = data still open for query resolution or updates. Critical for regulatory submission readiness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityConfirmed rdf:type rdf:Property ;
    rdfs:label 'Eligibility Confirmed' ;
    rdfs:comment 'Flag indicating whether the subject has been confirmed as meeting all inclusion criteria and none of the exclusion criteria as defined in the trial protocol. True = eligible; False = not eligible or assessment pending. Drives enrollment decision in RTSM.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date on which the subject was formally enrolled into the clinical trial following eligibility confirmation. Represents the principal business event timestamp for the enrollment transaction. Sourced from Medidata Rave RTSM.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the subject within the enrollment and randomization workflow. Drives Intent-to-Treat (ITT), modified ITT, and Per-Protocol (PP) population definitions. Sourced from Medidata Rave RTSM and Oracle CTMS. [ENUM-REF-CANDIDATE: screened|screen_failed|enrolled|randomized|withdrawn|completed|discontinued — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentConfirmed rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Confirmed' ;
    rdfs:comment 'Flag indicating whether a valid, signed Informed Consent Form (ICF) has been confirmed for this subject prior to any study procedures. True = ICF confirmed; False = ICF not confirmed or pending. Mandatory GCP compliance check.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:informedConsentDate rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Date' ;
    rdfs:comment 'Date on which the subject signed the Informed Consent Form (ICF), confirming voluntary participation in the trial. Must precede any study-specific procedures per GCP requirements. Critical for regulatory submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ittPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Itt Population Flag' ;
    rdfs:comment 'Flag indicating whether the subject is included in the Intent-to-Treat (ITT) analysis population. True = subject is part of the ITT population (all randomized subjects regardless of protocol adherence). Drives primary efficacy analysis per ICH E9.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mittPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Mitt Population Flag' ;
    rdfs:comment 'Flag indicating whether the subject is included in the modified Intent-to-Treat (mITT) analysis population. Criteria for mITT inclusion are protocol-defined (e.g., received at least one dose). Supports secondary efficacy analyses.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Pp Population Flag' ;
    rdfs:comment 'Flag indicating whether the subject is included in the Per-Protocol (PP) analysis population. True = subject completed the trial per protocol without major deviations. Used for sensitivity analyses in NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationCode rdf:type rdf:Property ;
    rdfs:label 'Randomization Code' ;
    rdfs:comment 'Unique alphanumeric code assigned by the RTSM system at the point of randomization, linking the subject to their treatment arm assignment within the randomization schedule. Confidential during blinded phase; revealed only upon unblinding. Sourced from Medidata Rave RTSM.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationDate rdf:type rdf:Property ;
    rdfs:label 'Randomization Date' ;
    rdfs:comment 'Date on which the subject was randomized and assigned to a treatment arm via the RTSM system. May differ from enrollment_date in trials with a run-in period. Null for screen-failed or non-randomized subjects.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:raveSubjectKey rdf:type rdf:Property ;
    rdfs:label 'Rave Subject Key' ;
    rdfs:comment 'The natural/business key for this subject enrollment record as assigned by Medidata Rave EDC/RTSM. Used for cross-system reconciliation and data lineage tracing back to the authoritative EDC source system.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenFailureReason rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Reason' ;
    rdfs:comment 'Coded or free-text reason why a subject failed screening and was not enrolled. Populated only when enrollment_status = screen_failed. Used for protocol feasibility analysis and site performance monitoring. Sourced from Medidata Rave EDC screen failure CRF.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'Date on which the subject first presented at the investigational site for screening assessments. Marks the start of the eligibility evaluation period. Sourced from Medidata Rave EDC.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Number' ;
    rdfs:comment 'Unique alphanumeric identifier assigned to a subject at the point of screening, prior to eligibility confirmation. Format is site-specific and assigned sequentially by the RTSM system in Medidata Rave. Used to track screen failures and pre-enrollment activity.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactor1 rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 1' ;
    rdfs:comment 'Value of the first stratification factor used to balance treatment arm assignments across key prognostic variables (e.g., disease stage, geographic region, biomarker status). Defined in the trial protocol and captured at randomization in RTSM.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactor2 rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 2' ;
    rdfs:comment 'Value of the second stratification factor used to balance treatment arm assignments (e.g., prior therapy, performance status, age group). Null if the trial uses fewer than two stratification factors. Captured at randomization in RTSM.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactor3 rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 3' ;
    rdfs:comment 'Value of the third stratification factor used to balance treatment arm assignments (e.g., country, mutation status, weight band). Null if the trial uses fewer than three stratification factors. Captured at randomization in RTSM.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectNumber rdf:type rdf:Property ;
    rdfs:label 'Subject Number' ;
    rdfs:comment 'Unique identifier assigned to a subject upon successful enrollment into the trial. Typically formatted as site-number-sequential-ID (e.g., 001-001). Assigned by Medidata Rave RTSM upon eligibility confirmation and enrollment confirmation.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentArmCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Code' ;
    rdfs:comment 'Code identifying the treatment arm (e.g., active drug, placebo, comparator, dose level) to which the subject was assigned at randomization. Confidential in blinded trials. Sourced from Medidata Rave RTSM randomization schedule.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentArmDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Description' ;
    rdfs:comment 'Human-readable description of the treatment arm assignment (e.g., \'Drug A 100mg QD\', \'Placebo\', \'Drug B 200mg BID\'). Confidential in blinded trials. Complements treatment_arm_code for reporting and analysis.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindingDate rdf:type rdf:Property ;
    rdfs:label 'Unblinding Date' ;
    rdfs:comment 'Date on which the subject\'s treatment assignment was unblinded. Populated only when blinding_status = unblinded. Emergency unblinding events must be documented per GCP. Null for blinded or open-label subjects.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unblindingReason rdf:type rdf:Property ;
    rdfs:label 'Unblinding Reason' ;
    rdfs:comment 'Coded reason for the unblinding of the subject\'s treatment assignment. Emergency unblinding (e.g., for medical management of a Serious Adverse Event) must be documented and reported per GCP and pharmacovigilance requirements. Null for blinded or open-label subjects.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Coded or free-text reason for subject withdrawal or discontinuation from the trial (e.g., adverse event, consent withdrawal, lost to follow-up, protocol deviation, investigator decision). Null for active or completed subjects. [ENUM-REF-CANDIDATE: adverse_event|consent_withdrawal|lost_to_follow_up|protocol_deviation|investigator_decision|sponsor_decision|death|other — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitId rdf:type rdf:Property ;
    rdfs:label 'Visit Id' ;
    rdfs:comment 'Unique surrogate identifier for each patient visit record within the clinical trial data product on the Databricks Silver Layer. Primary key.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Visit .

ind:clinicalSupplyOrderId rdf:type rdf:Property ;
    rdfs:label 'Clinical Supply Order Id' ;
    rdfs:comment 'Foreign key linking to supply.clinical_supply_order. Business justification: At each dispensing visit, the IRT system fulfills a clinical supply order. Linking visit to clinical_supply_order supports per-visit IMP dispensation accountability logs required under GCP and IMP acc' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalSupplyOrder .

ind:aeReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Ae Reported Flag' ;
    rdfs:comment 'Indicates whether one or more Adverse Events (AEs) were reported at or since the previous visit (True) or not (False). Triggers downstream pharmacovigilance workflows in Argus Safety / Oracle AERS.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:armName rdf:type rdf:Property ;
    rdfs:label 'Arm Name' ;
    rdfs:comment 'The name of the treatment arm or study arm to which the subject was assigned at the time of this visit (e.g., \'Drug A 100mg\', \'Placebo\', \'Drug A + Drug B Combination\'). Sourced from CTMS and EDC randomization records.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPct rdf:type rdf:Property ;
    rdfs:label 'Completion Pct' ;
    rdfs:comment 'The percentage of protocol-required assessments and procedures that were completed at this visit (0.00–100.00). Supports partial visit analysis and data completeness reporting for regulatory submissions.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conmedUpdatedFlag rdf:type rdf:Property ;
    rdfs:label 'Conmed Updated Flag' ;
    rdfs:comment 'Indicates whether the subject\'s concomitant medication list was reviewed and updated at this visit (True) or not (False). Supports safety and drug-drug interaction analysis.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Entry Timestamp' ;
    rdfs:comment 'The date and time when the visit data was first entered into the EDC system (Medidata Rave) by the site staff. Supports audit trail requirements under 21 CFR Part 11 and ICH E6(R2).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataLockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Lock Timestamp' ;
    rdfs:comment 'The date and time when the visit record was locked in the EDC (Medidata Rave), preventing further data entry or modification without an authorized unlock. Null if the record has not yet been locked.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dayFromReference rdf:type rdf:Property ;
    rdfs:label 'Day From Reference' ;
    rdfs:comment 'The study day number calculated from the subject\'s reference date (typically first dose date or randomization date) to the actual visit date. Corresponds to the CDISC VISITDY variable. Negative values indicate pre-dose visits.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationCategory rdf:type rdf:Property ;
    rdfs:label 'Deviation Category' ;
    rdfs:comment 'Classification of the protocol deviation severity at this visit: major (could affect subject safety or data integrity), minor (unlikely to affect safety or data integrity), or administrative (procedural/documentation only).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Free-text description of the protocol deviation(s) noted at this visit, as recorded by the site in the EDC or CTMS. Null when deviation_flag is False.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Indicates whether one or more protocol deviations were recorded for this visit (True) or not (False). A True value triggers linkage to the protocol deviation register in the CTMS or eTMF (Veeva Vault).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationReason rdf:type rdf:Property ;
    rdfs:label 'Early Termination Reason' ;
    rdfs:comment 'The reason the subject discontinued the study at or before this visit, if applicable. Null for non-termination visits. [ENUM-REF-CANDIDATE: adverse_event|withdrawal_of_consent|lost_to_follow_up|protocol_violation|sponsor_decision|death|other — promote to reference product]' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcVisitOid rdf:type rdf:Property ;
    rdfs:label 'Edc Visit Oid' ;
    rdfs:comment 'The unique object identifier (OID) assigned to this visit record within the Medidata Rave EDC system. Used for traceability and reconciliation between the Silver Layer and the source EDC system.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epoch rdf:type rdf:Property ;
    rdfs:label 'Epoch' ;
    rdfs:comment 'The trial epoch during which this visit occurred, as defined in the CDISC SDTM Trial Design model (e.g., Screening, Run-In, Treatment, Follow-Up, Post-Study). Supports epoch-level analysis.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Verified' ;
    rdfs:comment 'Indicates whether the subject\'s current informed consent form (ICF) was verified as valid and current at the time of this visit (True) or not (False). Critical for GCP compliance and regulatory inspection readiness.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queryOpenCount rdf:type rdf:Property ;
    rdfs:label 'Query Open Count' ;
    rdfs:comment 'The number of data queries (discrepancies) currently open against this visit record in the EDC (Medidata Rave). A non-zero value indicates outstanding data cleaning actions required before database lock.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:randomizationNumber rdf:type rdf:Property ;
    rdfs:label 'Randomization Number' ;
    rdfs:comment 'The unique randomization number assigned to the subject at the time of randomization, as recorded in the Interactive Response Technology (IRT) system. Confidential as it may reveal treatment assignment in blinded trials.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saeReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Sae Reported Flag' ;
    rdfs:comment 'Indicates whether one or more Serious Adverse Events (SAEs) were reported at this visit (True) or not (False). SAEs require expedited reporting to health authorities per ICH E2A and 21 CFR Part 312.32.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Source Verified Flag' ;
    rdfs:comment 'Indicates whether Source Data Verification (SDV) has been completed for this visit by the Clinical Research Associate (CRA) or monitor (True) or not (False). Critical for GCP compliance and regulatory inspection readiness.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitName rdf:type rdf:Property ;
    rdfs:label 'Visit Name' ;
    rdfs:comment 'Human-readable label for the visit as defined in the protocol Schedule of Assessments (e.g., \'Screening\', \'Cycle 1 Day 1\', \'Week 12 Follow-Up\', \'End of Study\'). Sourced from Medidata Rave EDC visit folder name.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitNumber rdf:type rdf:Property ;
    rdfs:label 'Visit Number' ;
    rdfs:comment 'Sequential numeric identifier for the visit as defined in the protocol Schedule of Assessments (SoA). Unscheduled visits may carry a non-integer or supplemental numbering convention captured separately.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitStatus rdf:type rdf:Property ;
    rdfs:label 'Visit Status' ;
    rdfs:comment 'Current lifecycle status of the visit record indicating whether the visit was completed, missed, partially completed, cancelled, or rescheduled. Sourced from Medidata Rave EDC and CTMS.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitType rdf:type rdf:Property ;
    rdfs:label 'Visit Type' ;
    rdfs:comment 'Classification of the visit according to its role in the trial timeline. [ENUM-REF-CANDIDATE: screening|baseline|treatment|follow_up|end_of_study|unscheduled|early_termination — promote to reference product]' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowLowerDay rdf:type rdf:Property ;
    rdfs:label 'Window Lower Day' ;
    rdfs:comment 'The number of days before the planned visit date that defines the lower boundary of the acceptable visit window per the protocol. Used to assess visit window compliance.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowUpperDay rdf:type rdf:Property ;
    rdfs:label 'Window Upper Day' ;
    rdfs:comment 'The number of days after the planned visit date that defines the upper boundary of the acceptable visit window per the protocol. Used to assess visit window compliance.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withinWindowFlag rdf:type rdf:Property ;
    rdfs:label 'Within Window Flag' ;
    rdfs:comment 'Indicates whether the actual visit date fell within the protocol-defined visit window (True) or outside it (False). Derived at ingestion from planned_date, actual_date, window_lower_day, and window_upper_day; stored for analytical efficiency.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crfFormId rdf:type rdf:Property ;
    rdfs:label 'Crf Form Id' ;
    rdfs:comment 'Unique surrogate identifier for each CRF form definition record in the Medidata Rave electronic data capture system. Primary key for the crf_form data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrfForm .

ind:annotationText rdf:type rdf:Property ;
    rdfs:label 'Annotation Text' ;
    rdfs:comment 'Annotated CRF text describing the SDTM variable mappings, derivation rules, and coding instructions associated with each field on this form. Used by data management and programming teams for SDTM dataset creation.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this CRF form definition received formal GCP-compliant approval. Recorded in ISO 8601 format with timezone offset. Required for audit trail under 21 CFR Part 11.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cdashDomain rdf:type rdf:Property ;
    rdfs:label 'Cdash Domain' ;
    rdfs:comment 'CDISC CDASH domain code indicating the data collection standard this form adheres to (e.g., \'AE\', \'VS\', \'CM\'). Ensures harmonized data collection aligned with CDASH implementation guides.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionInstructions rdf:type rdf:Property ;
    rdfs:label 'Completion Instructions' ;
    rdfs:comment 'Detailed instructions for site staff on how to complete this CRF form, including definitions, coding conventions, and data source guidance. Embedded in the EDC and printed CRF booklet.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRequirement rdf:type rdf:Property ;
    rdfs:label 'Completion Requirement' ;
    rdfs:comment 'Specifies whether completion of this CRF form is mandatory for all subjects, optional, or conditional on specific criteria (e.g., only if a prior form field triggers it). Drives data completeness monitoring and query generation.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEntryMode rdf:type rdf:Property ;
    rdfs:label 'Data Entry Mode' ;
    rdfs:comment 'Specifies the data entry mode configured for this CRF form in Medidata Rave. \'single\' requires one entry; \'double\' requires independent dual entry for critical data; \'auto\' is populated programmatically from device or lab feeds.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editCheckCount rdf:type rdf:Property ;
    rdfs:label 'Edit Check Count' ;
    rdfs:comment 'Total number of programmed edit checks (validation rules) configured for this CRF form in Medidata Rave. Provides a measure of form complexity and data quality control coverage.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which this CRF form version was retired or superseded. Null for currently active versions. Supports version lifecycle management and historical data traceability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this CRF form version is active and available for data entry at investigational sites. Supports version management and ensures sites use the correct form version.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldCount rdf:type rdf:Property ;
    rdfs:label 'Field Count' ;
    rdfs:comment 'Total number of data fields (questions/items) defined on this CRF form. Used for form complexity assessment, site burden estimation, and data management planning.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formLabel rdf:type rdf:Property ;
    rdfs:label 'Form Label' ;
    rdfs:comment 'Short display label for the CRF form used in the EDC user interface and printed CRF booklets. May differ from form_name for brevity in UI contexts.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formName rdf:type rdf:Property ;
    rdfs:label 'Form Name' ;
    rdfs:comment 'Human-readable name of the CRF form as displayed in Medidata Rave and study documentation. Examples: \'Adverse Event Form\', \'Vital Signs\', \'Concomitant Medications\'.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOid rdf:type rdf:Property ;
    rdfs:label 'Form Oid' ;
    rdfs:comment 'Unique Object Identifier (OID) for the CRF form as defined in Medidata Rave and conforming to CDISC ODM standards. Used for cross-system referencing and SDTM mapping. Example: \'AE_FORM_V2\'.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOrder rdf:type rdf:Property ;
    rdfs:label 'Form Order' ;
    rdfs:comment 'Numeric sequence order of this form within its associated visit or study schedule of events. Determines the display order in the EDC and printed CRF booklet.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formType rdf:type rdf:Property ;
    rdfs:label 'Form Type' ;
    rdfs:comment 'Classification of the CRF form by its data collection pattern in Medidata Rave. \'scheduled\' forms appear at predefined visits; \'unscheduled\' are event-driven; \'common\' appear across all visits; \'log\' forms capture repeating events (e.g., AE log); \'repeating\' forms allow multiple instances per visit.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formVersion rdf:type rdf:Property ;
    rdfs:label 'Form Version' ;
    rdfs:comment 'Version identifier of the CRF form definition, following semantic versioning (e.g., \'1.0\', \'2.1\', \'3.0.1\'). Tracks design changes over the trial lifecycle and supports audit trail requirements.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlinded rdf:type rdf:Property ;
    rdfs:label 'Is Blinded' ;
    rdfs:comment 'Indicates whether this CRF form contains blinded data (e.g., treatment assignment, randomization code) that must be restricted from unblinded personnel during the trial. Supports GCP-compliant blinding controls.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeating rdf:type rdf:Property ;
    rdfs:label 'Is Repeating' ;
    rdfs:comment 'Indicates whether this CRF form allows multiple instances per subject per visit (e.g., an Adverse Event log form where each AE is a separate instance). Drives EDC configuration in Medidata Rave.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSdvRequired rdf:type rdf:Property ;
    rdfs:label 'Is Sdv Required' ;
    rdfs:comment 'Indicates whether Source Data Verification (SDV) is required for data entered on this CRF form. Critical forms (e.g., primary endpoints, safety data) typically require 100% SDV; others may be risk-based.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Is Signature Required' ;
    rdfs:comment 'Indicates whether an electronic signature (e-signature) is required on this CRF form by the investigator or site staff upon completion, as mandated by 21 CFR Part 11 and GCP requirements.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when this CRF form definition record was last modified. Recorded in ISO 8601 format with timezone offset. Supports audit trail, change control, and GCP compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryEndpointFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Flag' ;
    rdfs:comment 'Indicates whether this CRF form captures data for the trial\'s primary efficacy or safety endpoint (e.g., ORR, PFS, OS). Primary endpoint forms receive heightened monitoring, SDV, and data review scrutiny.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:raveFormDraftVersion rdf:type rdf:Property ;
    rdfs:label 'Rave Form Draft Version' ;
    rdfs:comment 'The internal Medidata Rave draft version number for this CRF form, distinct from the business version. Tracks incremental design changes within the Rave study build environment prior to promotion to production.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raveStudyName rdf:type rdf:Property ;
    rdfs:label 'Rave Study Name' ;
    rdfs:comment 'The study name as configured in Medidata Rave EDC system, used to identify the parent study context for this CRF form. Supports cross-referencing between the data lakehouse and the source EDC system.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether data collected on this CRF form is included in regulatory submissions (NDA/BLA/MAA/IND). Drives SDTM dataset inclusion and eCTD packaging requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyFormFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Form Flag' ;
    rdfs:comment 'Indicates whether this CRF form is designated as a safety-critical form (e.g., Adverse Event, Serious Adverse Event, SUSAR reporting). Safety forms trigger expedited review workflows and pharmacovigilance data feeds.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdtmDomain rdf:type rdf:Property ;
    rdfs:label 'Sdtm Domain' ;
    rdfs:comment 'Two-letter CDISC SDTM domain code to which this CRF form maps for regulatory submission (e.g., \'AE\' for Adverse Events, \'VS\' for Vital Signs, \'CM\' for Concomitant Medications, \'LB\' for Laboratory). Drives SDTM dataset generation for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvPercentage rdf:type rdf:Property ;
    rdfs:label 'Sdv Percentage' ;
    rdfs:comment 'The percentage of data points on this CRF form subject to Source Data Verification (SDV) under the risk-based monitoring plan. Ranges from 0.00 (no SDV) to 100.00 (full SDV). Supports risk-based monitoring strategy.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemFormCode rdf:type rdf:Property ;
    rdfs:label 'Source System Form Code' ;
    rdfs:comment 'Native identifier of this CRF form record in the source EDC system (Medidata Rave). Enables lineage tracing from the Silver Layer back to the operational system of record.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRuleSet rdf:type rdf:Property ;
    rdfs:label 'Validation Rule Set' ;
    rdfs:comment 'Identifier or name of the edit check / validation rule set applied to this CRF form in Medidata Rave. References the programmed edit checks that enforce data quality, range checks, and cross-form consistency rules.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitOid rdf:type rdf:Property ;
    rdfs:label 'Visit Oid' ;
    rdfs:comment 'CDISC ODM-compliant OID of the study visit to which this form is assigned, as defined in Medidata Rave. Supports cross-system visit-form linkage without requiring a resolved FK at this stage.' ;
    rdfs:domain ind:CrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectObservationId rdf:type rdf:Property ;
    rdfs:label 'Subject Observation Id' ;
    rdfs:comment 'Unique surrogate identifier for each subject observation record in the EDC (Medidata Rave). Represents the atomic unit of clinical trial data collected per subject per visit per Case Report Form (CRF) field.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityDeviationId rdf:type rdf:Property ;
    rdfs:label 'Quality Deviation Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_deviation. Business justification: Protocol deviations identified in subject observations (protocol_deviation_flag=true) must be formally escalated to quality deviation records per GCP requirements. This FK enables direct traceability ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityDeviation .

ind:unitOfMeasureId rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure Id' ;
    rdfs:comment 'Foreign key linking to masterdata.unit_of_measure. Business justification: Subject observations record numeric clinical measurements requiring standardized UoM for CDISC/SDTM regulatory submissions and cross-trial data analysis. unit and standard_unit are denormalized plain-' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitOfMeasure .

ind:analysisPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Analysis Population Flag' ;
    rdfs:comment 'Indicates the analysis population(s) to which this observation contributes: Intent-to-Treat (ITT), Per Protocol (PP), Safety population, or excluded. Drives statistical analysis dataset (ADaM) construction and primary/secondary endpoint derivation.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this observation to its complete audit trail record in the EDC system (Medidata Rave). Enables traceability of all data changes, user actions, and timestamps per 21 CFR Part 11 electronic records requirements.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'The calendar date on which the observation was collected from the subject at the investigational site. Corresponds to SDTM --DTC variable. Critical for visit window compliance, protocol deviation assessment, and time-to-event endpoint calculations.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'The precise date and time at which the observation was collected, including time zone offset. Required for time-sensitive measurements (e.g., PK sampling, ECG) and for accurate SDTM --STDTC derivation.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crfFieldName rdf:type rdf:Property ;
    rdfs:label 'Crf Field Name' ;
    rdfs:comment 'The name of the specific CRF field (data point) within the form from which this observation was collected (e.g., SYSBP, WEIGHT, AESTDTC). Corresponds to the EDC field label in Medidata Rave.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcRecordReference rdf:type rdf:Property ;
    rdfs:label 'Edc Record Reference' ;
    rdfs:comment 'Native record identifier assigned by the EDC system (Medidata Rave) for this observation. Used for source system traceability, audit trail reconciliation, and data migration validation.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The date and time at which the data was first entered into the EDC system (Medidata Rave) by the site user. Used for data entry timeliness monitoring, audit trail compliance, and GCP inspection readiness per ICH E6(R2).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Baseline' ;
    rdfs:comment 'Indicates whether this observation represents the baseline measurement for the subject, used as the reference value for change-from-baseline calculations in efficacy endpoint derivation (e.g., tumor size at baseline for ORR). Corresponds to SDTM ABLFL flag in ADaM datasets.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnscheduled rdf:type rdf:Property ;
    rdfs:label 'Is Unscheduled' ;
    rdfs:comment 'Indicates whether this observation was collected during an unscheduled visit (not defined in the protocol schedule of assessments). Unscheduled observations may be excluded from primary efficacy analyses per the statistical analysis plan.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:normalRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Normal Range High' ;
    rdfs:comment 'The upper bound of the reference (normal) range for this observation type as defined by the central laboratory or clinical standard. Used for out-of-range flagging, safety signal detection, and SDTM STNRHI derivation.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:normalRangeLow rdf:type rdf:Property ;
    rdfs:label 'Normal Range Low' ;
    rdfs:comment 'The lower bound of the reference (normal) range for this observation type as defined by the central laboratory or clinical standard. Used for out-of-range flagging, safety signal detection, and SDTM STNRLO derivation.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numericValue rdf:type rdf:Property ;
    rdfs:label 'Numeric Value' ;
    rdfs:comment 'The numeric representation of the observation value after unit standardization, corresponding to the SDTM STRESN variable. Used for quantitative analyses, endpoint derivation (ORR, PFS, OS), and statistical modeling in ADaM datasets.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observationStatus rdf:type rdf:Property ;
    rdfs:label 'Observation Status' ;
    rdfs:comment 'Current workflow status of the observation record within the EDC system lifecycle. Drives data cleaning workflows, lock readiness assessment, and database lock milestones. [ENUM-REF-CANDIDATE: entered|verified|locked|queried|resolved|deleted — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfRangeFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Range Flag' ;
    rdfs:comment 'Indicates whether the numeric observation value falls outside the defined normal reference range (low or high). Triggers safety review workflows, potential AE/SAE reporting, and DSMB notification processes.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Flag' ;
    rdfs:comment 'Indicates whether this observation is associated with a protocol deviation (e.g., collected outside the visit window, wrong procedure performed). Flagged observations may be excluded from Per Protocol (PP) analysis populations.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queryStatus rdf:type rdf:Property ;
    rdfs:label 'Query Status' ;
    rdfs:comment 'Status of any data query (discrepancy) raised against this observation in the EDC system. Open queries must be resolved prior to database lock. Supports data cleaning metrics and site performance monitoring.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryText rdf:type rdf:Property ;
    rdfs:label 'Query Text' ;
    rdfs:comment 'The text of the most recent data query raised against this observation, describing the discrepancy or clarification required from the site. Supports data management review and site communication workflows.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawValue rdf:type rdf:Property ;
    rdfs:label 'Raw Value' ;
    rdfs:comment 'The verbatim data value as entered by the site user in the EDC system (Medidata Rave), prior to any derivation or standardization. Stored as STRING to accommodate all data types (numeric, text, coded). Represents the source data for SDV and audit trail purposes.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonForChange rdf:type rdf:Property ;
    rdfs:label 'Reason For Change' ;
    rdfs:comment 'The documented reason provided by the site user when modifying a previously entered observation value in the EDC system. Mandatory per 21 CFR Part 11 and GCP requirements for any post-entry data correction. Stored as the most recent change reason.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVariable rdf:type rdf:Property ;
    rdfs:label 'Sdtm Variable' ;
    rdfs:comment 'The specific CDISC SDTM variable name to which this CRF field maps (e.g., VSSTRESN, LBORRES, AEDECOD). Enables automated SDTM dataset generation and submission-ready data transformation.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvDate rdf:type rdf:Property ;
    rdfs:label 'Sdv Date' ;
    rdfs:comment 'The date on which Source Data Verification (SDV) was completed for this observation. Used for monitoring visit planning, SDV coverage reporting, and GCP audit trail documentation.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdvStatus rdf:type rdf:Property ;
    rdfs:label 'Sdv Status' ;
    rdfs:comment 'Status of Source Data Verification (SDV) for this observation, indicating whether the EDC-entered value has been verified against the original source document (e.g., medical record, lab report) by the CRA or site monitor. Critical for GCP compliance and regulatory inspection readiness.' ;
    rdfs:domain ind:SubjectObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toxicityGrade rdf:type rdf:Property ;
    rdfs:label 'Toxicity Grade' ;
    rdfs:comment 'The NCI CTCAE toxicity grade assigned to this observation when it represents an adverse finding (Grade 1=Mild, Grade 2=Moderate, Grade 3=Severe, Grade 4=Life-threatening, Grade 5=Death). Critical for safety endpoint reporting, dose modification decisions, and regulatory safety narratives.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'The username or identifier of the Clinical Research Associate (CRA) or monitor who performed Source Data Verification (SDV) for this observation. Supports GCP compliance documentation and monitoring visit reports.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialAdverseEventId rdf:type rdf:Property ;
    rdfs:label 'Trial Adverse Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each adverse event record reported by a subject during a clinical trial. Primary key for this transactional entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aeAccountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Ae Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: SAE processing triggers vendor invoices for emergency labs, imaging, hospitalization, and specialist consultations. Required for trial cost reconciliation, safety budget tracking, and sponsor financia' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:icsrId rdf:type rdf:Property ;
    rdfs:label 'Icsr Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.icsr. Business justification: EDC-to-safety reconciliation (ICH E2B, FDA 21 CFR 312.32) requires linking each trial AE to its corresponding ICSR in the PV system. argus_case_reference is a denormalized text reference to the ICSR t' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Icsr .

ind:labelingId rdf:type rdf:Property ;
    rdfs:label 'Labeling Id' ;
    rdfs:comment 'Foreign key linking to product.labeling. Business justification: Unexpected SAEs and SUSARs trigger label update workflows — the AE must be assessed against the current approved labeling to determine if it is \'unexpected\'. Pharmacovigilance and regulatory affairs r' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Labeling .

ind:patientAdverseEventId rdf:type rdf:Property ;
    rdfs:label 'Patient Adverse Event Id' ;
    rdfs:comment 'Foreign key linking to patient.adverse_event. Business justification: Pharmacovigilance reconciliation requires linking trial CRF-captured AEs (trial_adverse_event) to patient safety database records (patient.adverse_event) for SUSAR/SAE reporting, signal detection, and' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdverseEvent .

ind:productComplaintId rdf:type rdf:Property ;
    rdfs:label 'Product Complaint Id' ;
    rdfs:comment 'Foreign key linking to quality.complaint. Business justification: Product complaints reported during clinical trials (packaging defects, appearance issues, administration problems) are tracked in quality complaint system per 21 CFR 820.198. Enables trend analysis an' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Complaint .

ind:pvAdverseReactionId rdf:type rdf:Property ;
    rdfs:label 'Pv Adverse Reaction Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.pv_adverse_reaction. Business justification: EDC-safety reconciliation (GVP Module VI) requires matching each trial AE verbatim term to its MedDRA-coded pv_adverse_reaction. meddra_preferred_term, meddra_pt_code, meddra_system_organ_class on tri' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PvAdverseReaction .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.submission. Business justification: Serious unexpected adverse events (SUSARs) trigger mandatory expedited regulatory reporting obligations. Pharmacovigilance teams must track which AEs resulted in expedited safety reports (15-day alert' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:reportingInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Reporting Investigator Id' ;
    rdfs:comment 'Foreign key linking to hcp.investigator. Business justification: Regulatory AE reporting (MedWatch, EudraVigilance) requires identifying the reporting investigator by role, not just the HCP master. This FK enables investigator-level safety signal tracking, GCP comp' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Action taken with the investigational medicinal product (IMP) in response to the adverse event (e.g., Dose not changed, Dose reduced, Drug interrupted, Drug withdrawn, Not applicable). [ENUM-REF-CANDIDATE: Dose not changed|Dose reduced|Drug interrupted|Drug withdrawn|Not applicable|Unknown — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeNumber rdf:type rdf:Property ;
    rdfs:label 'Ae Number' ;
    rdfs:comment 'Externally-known, human-readable identifier for the adverse event as assigned in the EDC system (Medidata Rave). Used for cross-referencing in CRFs, safety narratives, and regulatory submissions.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Ae Reporting Category' ;
    rdfs:comment 'Regulatory reporting classification of the adverse event: AE (non-serious), SAE (Serious Adverse Event), SUSAR (Suspected Unexpected Serious Adverse Reaction), or AESI (Adverse Event of Special Interest). Drives reporting timelines and workflows.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeSeverity rdf:type rdf:Property ;
    rdfs:label 'Ae Severity' ;
    rdfs:comment 'Descriptive severity classification of the adverse event as recorded in the CRF. Corresponds to CTCAE grade but expressed as a categorical label for reporting and filtering.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeStatus rdf:type rdf:Property ;
    rdfs:label 'Ae Status' ;
    rdfs:comment 'Current lifecycle status of the adverse event, indicating whether it is still ongoing, has resolved, resolved with residual effects, or resulted in death.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeTermVerbatim rdf:type rdf:Property ;
    rdfs:label 'Ae Term Verbatim' ;
    rdfs:comment 'The exact verbatim term as reported by the investigator or subject in the CRF prior to MedDRA coding. Preserved for audit and coding reconciliation purposes.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aesiFlag rdf:type rdf:Property ;
    rdfs:label 'Aesi Flag' ;
    rdfs:comment 'Indicates whether the adverse event has been designated as an Adverse Event of Special Interest (AESI) per the trial protocol or regulatory guidance, requiring enhanced monitoring and reporting.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:causalityAssessment rdf:type rdf:Property ;
    rdfs:label 'Causality Assessment' ;
    rdfs:comment 'Investigator\'s assessment of the causal relationship between the adverse event and the investigational medicinal product (IMP). Used in safety reporting and benefit-risk evaluation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concomitantMedication rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication' ;
    rdfs:comment 'Name or description of any concomitant medication administered to treat or manage the adverse event. Free-text field as captured in the CRF.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctcaeGrade rdf:type rdf:Property ;
    rdfs:label 'Ctcae Grade' ;
    rdfs:comment 'Severity grade of the adverse event per NCI CTCAE grading scale (1=Mild, 2=Moderate, 3=Severe, 4=Life-threatening, 5=Death). Mandatory for oncology trials and widely used across therapeutic areas.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dechallengeResult rdf:type rdf:Property ;
    rdfs:label 'Dechallenge Result' ;
    rdfs:comment 'Result of withdrawing or reducing the investigational product dose in response to the adverse event. Positive dechallenge (AE improved on withdrawal) supports causal relationship.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Ha Report Due Date' ;
    rdfs:comment 'The regulatory deadline by which the SAE or SUSAR must be reported to the relevant health authority (e.g., FDA 7-day or 15-day, EMA 7-day or 15-day). Calculated from sponsor_aware_date.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:haReportedDate rdf:type rdf:Property ;
    rdfs:label 'Ha Reported Date' ;
    rdfs:comment 'The actual date on which the SAE or SUSAR was submitted to the health authority. Used to assess compliance with regulatory reporting timelines.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialReportDate rdf:type rdf:Property ;
    rdfs:label 'Initial Report Date' ;
    rdfs:comment 'The date on which the adverse event was first reported by the investigator or site to the sponsor. Day 0 for regulatory reporting clock calculations (7-day/15-day timelines).' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isSerious rdf:type rdf:Property ;
    rdfs:label 'Is Serious' ;
    rdfs:comment 'Indicates whether the adverse event meets the regulatory definition of a Serious Adverse Event (SAE) per ICH E2A criteria (death, life-threatening, hospitalization, disability, congenital anomaly, or other medically important condition).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSusar rdf:type rdf:Property ;
    rdfs:label 'Is Susar' ;
    rdfs:comment 'Indicates whether this adverse event has been classified as a Suspected Unexpected Serious Adverse Reaction (SUSAR), triggering expedited 7-day or 15-day regulatory reporting obligations to health authorities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnexpected rdf:type rdf:Property ;
    rdfs:label 'Is Unexpected' ;
    rdfs:comment 'Indicates whether the adverse event is unexpected — i.e., not listed in the current Investigator\'s Brochure (IB) or Reference Safety Information (RSI). A serious, unexpected, related AE constitutes a SUSAR requiring expedited reporting.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledToDiscontinuation rdf:type rdf:Property ;
    rdfs:label 'Led To Discontinuation' ;
    rdfs:comment 'Indicates whether the adverse event led to the subject\'s permanent discontinuation from the clinical trial. Critical for ITT and safety analysis populations.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Review Status' ;
    rdfs:comment 'Current status of the medical monitor\'s review of the adverse event record. Tracks the safety review workflow from initial entry through medical sign-off.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalReviewer rdf:type rdf:Property ;
    rdfs:label 'Medical Reviewer' ;
    rdfs:comment 'Name or identifier of the sponsor medical monitor or physician who reviewed and assessed the adverse event record.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Free-text medical narrative describing the adverse event, its clinical course, management, and outcome. Used in ICSR submissions and clinical study reports (CSR).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onsetDate rdf:type rdf:Property ;
    rdfs:label 'Onset Date' ;
    rdfs:comment 'The date on which the adverse event first began or was first observed by the subject or investigator. Principal real-world event date for the AE lifecycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rechallengeResult rdf:type rdf:Property ;
    rdfs:label 'Rechallenge Result' ;
    rdfs:comment 'Result of re-administering the investigational product after the adverse event resolved, to assess causality. Positive rechallenge strengthens causal relationship.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date on which the adverse event resolved or returned to baseline. Null if the event is ongoing at the time of data cut.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saeCriteria rdf:type rdf:Property ;
    rdfs:label 'Sae Criteria' ;
    rdfs:comment 'The specific ICH E2A seriousness criterion or criteria met by this SAE (e.g., Death, Life-threatening, Hospitalization required, Persistent disability, Congenital anomaly, Medically significant). Multiple criteria may apply. [ENUM-REF-CANDIDATE: Death|Life-threatening|Hospitalization required|Persistent disability|Congenital anomaly|Medically significant|Other — promote to reference product]' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorAwareDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Aware Date' ;
    rdfs:comment 'The date on which the sponsor first became aware of the serious adverse event. Starts the regulatory reporting clock for SAE/SUSAR expedited reporting to health authorities.' ;
    rdfs:domain ind:TrialAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentGiven rdf:type rdf:Property ;
    rdfs:label 'Treatment Given' ;
    rdfs:comment 'Indicates whether concomitant medication or other treatment was administered to manage or treat the adverse event.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trialConsentId rdf:type rdf:Property ;
    rdfs:label 'Trial Consent Id' ;
    rdfs:comment 'Unique surrogate identifier for each informed consent event record in the clinical trial. Primary key for the trial_consent data product.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:informedConsentId rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Id' ;
    rdfs:comment 'Foreign key linking to patient.informed_consent. Business justification: GCP compliance and GDPR/HIPAA data privacy audits require reconciliation between trial CRF consent records (trial_consent in eTMF/EDC) and patient-level consent management records (patient.informed_co' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InformedConsent .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the subject (or LAR) signed and dated the informed consent form, confirming voluntary agreement to participate in the trial. This is the principal business event date for the consent transaction.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentFormVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Form Version' ;
    rdfs:comment 'Version identifier of the Informed Consent Form (ICF) used for this consent event, as approved by the Institutional Review Board (IRB) or Independent Ethics Committee (IEC). Critical for regulatory traceability when protocol amendments trigger re-consent.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) of the language in which the ICF was presented and signed by the subject, ensuring the subject received information in their native language per GCP requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this consent event, used for regulatory traceability and audit purposes. Typically generated by the CTMS or EDC system (e.g., Medidata Rave or Oracle Clinical).' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle state of the consent record. \'Active\' indicates valid consent in force; \'withdrawn\' indicates subject has revoked consent; \'superseded\' indicates replaced by a newer consent version; \'pending\' indicates awaiting subject signature; \'expired\' indicates consent period has lapsed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Precise date and time at which the consent was electronically captured or recorded in the EDC/CTMS system (e.g., Medidata Rave), supporting 21 CFR Part 11 electronic records compliance.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Classification of the consent event: initial consent at enrollment, re-consent triggered by protocol amendment, assent from a minor subject, consent by a Legally Authorized Representative (LAR), or withdrawal of consent.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:econsentPlatform rdf:type rdf:Property ;
    rdfs:label 'Econsent Platform' ;
    rdfs:comment 'Name or identifier of the eConsent platform used to capture electronic consent (e.g., Medidata Rave eConsent, Veeva Vault). Populated only when electronic_consent is True.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicConsent rdf:type rdf:Property ;
    rdfs:label 'Electronic Consent' ;
    rdfs:comment 'Indicates whether the consent was obtained via an electronic consent (eConsent) platform rather than a traditional paper-based process. Relevant for 21 CFR Part 11 compliance and audit trail requirements.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:etmfDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Etmf Document Reference' ;
    rdfs:comment 'Document identifier in the Electronic Trial Master File (eTMF) system (e.g., Veeva Vault) for the scanned or electronically captured consent form. Enables direct linkage between the consent record and the regulatory-compliant document archive.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorSigned rdf:type rdf:Property ;
    rdfs:label 'Investigator Signed' ;
    rdfs:comment 'Indicates whether the Principal Investigator (PI) or delegated sub-investigator has signed the informed consent form, confirming the consent discussion was conducted per GCP requirements.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Date' ;
    rdfs:comment 'Date on which the IRB or IEC approved the ICF version referenced in this consent event. Consent must not be obtained prior to this date to maintain GCP compliance.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ittFlag rdf:type rdf:Property ;
    rdfs:label 'Itt Flag' ;
    rdfs:comment 'Indicates whether the subject is included in the Intent-to-Treat (ITT) analysis population. Subjects who consented and received at least one dose of investigational product are typically included in the ITT population.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:larName rdf:type rdf:Property ;
    rdfs:label 'Lar Name' ;
    rdfs:comment 'Full legal name of the Legally Authorized Representative (LAR) who provided consent on behalf of the subject. Populated only when lar_required is True.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:larRelationship rdf:type rdf:Property ;
    rdfs:label 'Lar Relationship' ;
    rdfs:comment 'Relationship of the Legally Authorized Representative (LAR) to the trial subject (e.g., parent, legal guardian, spouse). Required when lar_required is True to establish legal authority to consent.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:larRequired rdf:type rdf:Property ;
    rdfs:label 'Lar Required' ;
    rdfs:comment 'Indicates whether a Legally Authorized Representative (LAR) was required to provide consent on behalf of the subject, applicable for minors, cognitively impaired subjects, or other legally incapacitated individuals.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:larSigned rdf:type rdf:Property ;
    rdfs:label 'Lar Signed' ;
    rdfs:comment 'Indicates whether the Legally Authorized Representative (LAR) has signed and dated the informed consent form. Applicable only when lar_required is True.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionalConsentBiobank rdf:type rdf:Property ;
    rdfs:label 'Optional Consent Biobank' ;
    rdfs:comment 'Indicates whether the subject provided optional consent for long-term storage and future use of biological samples in a biobank. This is a separate optional consent element from the main trial consent.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionalConsentGenetic rdf:type rdf:Property ;
    rdfs:label 'Optional Consent Genetic' ;
    rdfs:comment 'Indicates whether the subject provided optional consent for genetic or genomic research using their biological samples. Separate from the main trial consent and biobank consent.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconsentDate rdf:type rdf:Property ;
    rdfs:label 'Reconsent Date' ;
    rdfs:comment 'Date on which the subject provided re-consent following a protocol amendment or updated ICF version. Null if no re-consent has been required for this subject.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconsentReason rdf:type rdf:Property ;
    rdfs:label 'Reconsent Reason' ;
    rdfs:comment 'Reason that triggered the re-consent requirement, such as a protocol amendment, new safety information identified during the trial, or a regulatory authority request. Null if no re-consent was required.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentLocation rdf:type rdf:Property ;
    rdfs:label 'Source Document Location' ;
    rdfs:comment 'Location reference for the original signed consent form source document, such as the eTMF folder path in Veeva Vault or physical file location at the investigational site. Supports GCP source data verification (SDV) and audit trail requirements.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectSigned rdf:type rdf:Property ;
    rdfs:label 'Subject Signed' ;
    rdfs:comment 'Indicates whether the subject has personally signed and dated the informed consent form. False if consent was provided solely by a Legally Authorized Representative (LAR) without subject co-signature.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:witnessRequired rdf:type rdf:Property ;
    rdfs:label 'Witness Required' ;
    rdfs:comment 'Indicates whether an impartial witness was required to be present during the consent process, applicable when the subject or LAR is unable to read or when a short-form consent is used.' ;
    rdfs:domain ind:TrialConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billOfMaterialsId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Materials Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.bill_of_materials. Business justification: The BOM defines the exact composition of the investigational product including API, excipients, and packaging components. Regulatory submissions (IND, IMPD) and clinical supply management require BOM ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfMaterials .

ind:manufacturingBatchRecordId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.batch_record. Business justification: Investigational products used in clinical trials must link to manufacturing batch records for traceability, GMP compliance, and clinical supply chain management. This is critical for regulatory submis' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:manufacturingSiteId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.site. Business justification: Regulatory submissions (IND, IMPD, CTA) require identifying the GMP-certified manufacturing site for each investigational product. manufacturing.site is the GMP-regulated facility entity; the existing' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_plan. Business justification: Clinical supply planning aligns IMP production schedules with trial enrollment rates, site activation dates, and dosing regimens. Direct operational dependency for ensuring adequate IMP availability w' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_order. Business justification: Clinical supply management requires direct traceability from each investigational product lot to the production order that manufactured it. GMP compliance, regulatory submissions (IND/IMPD), and clini' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:pvProductId rdf:type rdf:Property ;
    rdfs:label 'Pv Product Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.pv_product. Business justification: Investigational products must map to authorized PV products for listedness determination (expected vs unexpected AE classification), SUSAR assessment, and RSI reference. Critical for regulatory expect' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PvProduct .

ind:rawMaterialInventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Raw Material Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: IMP manufacturing consumes raw material lots; regulatory traceability (21 CFR Part 312.57) requires linking clinical products to source inventory lots for safety reporting, recalls, and batch genealog' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:stabilityStudyId rdf:type rdf:Property ;
    rdfs:label 'Stability Study Id' ;
    rdfs:comment 'Foreign key linking to quality.stability_study. Business justification: IMPs undergo stability testing to establish expiry dates and storage conditions for clinical use. Links clinical supply planning to ongoing stability data, critical for protocol amendments and supply ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StabilityStudy .

ind:transferPriceId rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Id' ;
    rdfs:comment 'Foreign key linking to finance.transfer_price. Business justification: IMP shipped across legal entity boundaries (e.g., manufactured in EU, used in US trials) requires transfer pricing for intercompany billing and tax compliance. Pharma tax and supply finance teams must' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferPrice .

ind:accountabilityLogReference rdf:type rdf:Property ;
    rdfs:label 'Accountability Log Reference' ;
    rdfs:comment 'Document reference number or system identifier for the IMP accountability log maintained at the investigational site or centrally. Links to the eTMF document in Veeva Vault per ICH E6(R2) Section 8.3.15.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether this IMP requires cold-chain logistics (temperature-controlled storage and transport) throughout the supply chain from manufacturer to investigational site. Drives GDP-compliant distribution planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispensationUnit rdf:type rdf:Property ;
    rdfs:label 'Dispensation Unit' ;
    rdfs:comment 'Unit of measure used for IMP dispensation, return, and destruction quantities (e.g., tablet, capsule, vial, mL). Ensures consistent accountability across all quantity fields. [ENUM-REF-CANDIDATE: tablet|capsule|vial|ampoule|mL|mg|patch|sachet|unit — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Gmp Certificate Reference' ;
    rdfs:comment 'Reference to the GMP certificate or Qualified Person (QP) release certificate confirming the IMP batch was manufactured in compliance with current Good Manufacturing Practice (cGMP). Required for EU CTA and IND.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impCode rdf:type rdf:Property ;
    rdfs:label 'Imp Code' ;
    rdfs:comment 'Sponsor-assigned alphanumeric code uniquely identifying this IMP or comparator within the trial supply system. Used for dispensation tracking and accountability logs in Oracle CTMS and SAP MM.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impdReference rdf:type rdf:Property ;
    rdfs:label 'Impd Reference' ;
    rdfs:comment 'Reference number or document identifier for the Investigational Medicinal Product Dossier (IMPD) submitted to EU competent authorities. Supports EMA/MHRA CTA submissions.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitNumber rdf:type rdf:Property ;
    rdfs:label 'Kit Number' ;
    rdfs:comment 'Unique identifier for the IMP dispensation kit as labeled and shipped to the investigational site. Used for kit-level accountability tracking and IWRS-driven dispensation in Oracle CTMS.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date on which the IMP batch was manufactured. Used to calculate shelf life, retest dates, and to verify GMP compliance of the batch at time of dispensation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchingPlaceboCode rdf:type rdf:Property ;
    rdfs:label 'Matching Placebo Code' ;
    rdfs:comment 'IMP code of the matching placebo formulated to be indistinguishable from the active investigational product in appearance, taste, and smell. Required for double-blind trial integrity and IMP accountability.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of the product role in the trial: investigational (test article), comparator (active control), placebo (matching or non-matching), rescue medication, or auxiliary medicinal product per ICH E6(R2) definitions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDestroyed rdf:type rdf:Property ;
    rdfs:label 'Quantity Destroyed' ;
    rdfs:comment 'Total quantity of this IMP destroyed at site or centrally, expressed in the dispensation unit. Required for complete IMP accountability reconciliation and destruction certificate documentation.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed' ;
    rdfs:comment 'Total quantity of this IMP dispensed to trial subjects from this batch, expressed in the dispensation unit (e.g., tablets, vials, mL). Core field for IMP accountability log per ICH E6(R2) Section 8.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'Total quantity of this IMP returned by trial subjects or sites, expressed in the dispensation unit. Used to calculate compliance rates and reconcile IMP accountability per GCP requirements.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Date by which the IMP batch must be retested to confirm continued suitability for use, particularly for drug substances with defined retest periods rather than expiry dates. Supports stability management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyStatus rdf:type rdf:Property ;
    rdfs:label 'Supply Status' ;
    rdfs:comment 'Current status of this IMP record in the trial supply lifecycle: available (at site, ready for dispensation), dispensed (issued to subject), returned (received back from subject), destroyed, quarantine (hold pending investigation), or expired.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialEndpointId rdf:type rdf:Property ;
    rdfs:label 'Trial Endpoint Id' ;
    rdfs:comment 'Unique surrogate identifier for each trial endpoint assessment record in the clinical lakehouse silver layer.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjudicationDate rdf:type rdf:Property ;
    rdfs:label 'Adjudication Date' ;
    rdfs:comment 'Date on which the independent adjudication committee completed its review and issued a final determination for this endpoint assessment.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjudicationRequired rdf:type rdf:Property ;
    rdfs:label 'Adjudication Required' ;
    rdfs:comment 'Indicates whether this endpoint assessment requires review by an independent adjudication committee (e.g., BICR, DSMB, IRC) due to discordance between investigator and central read, or per protocol mandate.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjudicationResult rdf:type rdf:Property ;
    rdfs:label 'Adjudication Result' ;
    rdfs:comment 'Final response category or concordance determination issued by the independent adjudication committee after review. Overrides investigator assessment when discordant, per protocol rules. [ENUM-REF-CANDIDATE: CR|PR|SD|PD|NE|concordant|discordant — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjudicationStatus rdf:type rdf:Property ;
    rdfs:label 'Adjudication Status' ;
    rdfs:comment 'Current status of the independent adjudication committee review for this endpoint assessment. Tracks workflow from pending through completed adjudication, supporting BICR and IRC processes.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Calendar date on which the endpoint assessment was performed. This is the principal real-world event date for the endpoint record, distinct from data entry or audit timestamps.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Standardized methodology used to evaluate the endpoint (e.g., RECIST 1.1 for solid tumor response, iRECIST for immunotherapy, BICR for blinded independent central review, RANO for CNS tumors). Critical for regulatory submission credibility. [ENUM-REF-CANDIDATE: RECIST_1.1|iRECIST|BICR|investigator|RANO|mRECIST|PCWG3|Cheson|IWG — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current workflow status of the endpoint assessment record: planned (scheduled but not yet performed), completed (data captured and verified), missed (visit occurred but assessment not done), not_done (subject not available), or invalid (data quality issue).' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'Baseline measurement value for the endpoint at study entry (e.g., sum of longest diameters at baseline for RECIST). Used to calculate percent change from baseline and determine response categories.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bestOverallResponse rdf:type rdf:Property ;
    rdfs:label 'Best Overall Response' ;
    rdfs:comment 'Best overall response achieved by the subject across all assessment timepoints up to and including this assessment, per RECIST or applicable criteria. Used in ORR and DOR calculations for regulatory submissions.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:censoringReason rdf:type rdf:Property ;
    rdfs:label 'Censoring Reason' ;
    rdfs:comment 'Reason for censoring a subject in time-to-event analyses when the endpoint event has not occurred (e.g., lost to follow-up, withdrawal of consent, initiation of new anticancer therapy, end of study). Required for regulatory-grade survival analyses. [ENUM-REF-CANDIDATE: lost_to_followup|withdrawal|new_anticancer_therapy|end_of_study|administrative|death_other_cause — promote to reference product]' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedResponse rdf:type rdf:Property ;
    rdfs:label 'Confirmed Response' ;
    rdfs:comment 'Indicates whether the response (CR or PR) has been confirmed by a subsequent assessment at least 4 weeks later, as required by RECIST 1.1 for ORR determination in regulatory submissions.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endpointCategory rdf:type rdf:Property ;
    rdfs:label 'Endpoint Category' ;
    rdfs:comment 'Classification of the endpoint as primary, secondary, exploratory, or safety per the study protocol. Primary endpoints drive the primary efficacy analysis for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointCode rdf:type rdf:Property ;
    rdfs:label 'Endpoint Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the endpoint definition within the study (e.g., EP001, PFS_PRIMARY). Sourced from the study protocol and EDC configuration in Medidata Rave.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointName rdf:type rdf:Property ;
    rdfs:label 'Endpoint Name' ;
    rdfs:comment 'Full descriptive name of the clinical endpoint being assessed (e.g., Objective Response Rate, Progression-Free Survival, Overall Survival, Duration of Response, Quality of Life). Aligns with protocol-defined endpoint nomenclature.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointType rdf:type rdf:Property ;
    rdfs:label 'Endpoint Type' ;
    rdfs:comment 'Functional type of the endpoint indicating the nature of the measurement: efficacy (ORR, PFS, OS), safety (AE rate), pharmacokinetic (PK), pharmacodynamic (PD), biomarker, or patient-reported outcome (PRO/QoL). [ENUM-REF-CANDIDATE: efficacy|safety|pharmacokinetic|pharmacodynamic|biomarker|patient_reported|composite — promote to reference product]' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluableFlag rdf:type rdf:Property ;
    rdfs:label 'Evaluable Flag' ;
    rdfs:comment 'Indicates whether the subject is considered evaluable for this specific endpoint at this timepoint, based on protocol-defined evaluability criteria (e.g., minimum number of prior assessments, no major protocol deviations).' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Date on which the endpoint event (progression, death, response) occurred. For censored subjects, this is the last known event-free date. Used in time-to-event analyses for PFS and OS.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventOccurred rdf:type rdf:Property ;
    rdfs:label 'Event Occurred' ;
    rdfs:comment 'Indicates whether the endpoint event (e.g., disease progression, death) has occurred for time-to-event endpoints such as PFS and OS. False indicates censoring. Critical for Kaplan-Meier and Cox regression analyses.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nadirValue rdf:type rdf:Property ;
    rdfs:label 'Nadir Value' ;
    rdfs:comment 'Lowest (nadir) measurement value recorded for the subject across all prior assessments. Used in RECIST PD determination (≥20% increase from nadir) and DOR calculations.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentChangeFromBaseline rdf:type rdf:Property ;
    rdfs:label 'Percent Change From Baseline' ;
    rdfs:comment 'Percentage change in the endpoint measurement from the baseline value to the current assessment value. Directly used in waterfall plots and response determination per RECIST criteria.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppFlag rdf:type rdf:Property ;
    rdfs:label 'Pp Flag' ;
    rdfs:comment 'Indicates whether this subject\'s endpoint assessment is included in the Per Protocol (PP) analysis population, used as a sensitivity analysis alongside ITT in regulatory submissions.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queryOpen rdf:type rdf:Property ;
    rdfs:label 'Query Open' ;
    rdfs:comment 'Indicates whether there is an open data query (discrepancy) raised against this endpoint record in the EDC system (Medidata Rave). Open queries must be resolved before database lock.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseCategory rdf:type rdf:Property ;
    rdfs:label 'Response Category' ;
    rdfs:comment 'Categorical tumor response classification per the applicable assessment criteria: Complete Response (CR), Partial Response (PR), Stable Disease (SD), Progressive Disease (PD), or Not Evaluable (NE). Directly feeds ORR calculation for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'Numeric result of the endpoint assessment (e.g., tumor size in mm, PFS duration in months, QoL score). This is the principal quantitative outcome for the endpoint record. Null for categorical-only endpoints.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeToEventDays rdf:type rdf:Property ;
    rdfs:label 'Time To Event Days' ;
    rdfs:comment 'Duration in days from the study reference date (e.g., randomization date) to the endpoint event or censoring date. Used directly in PFS, OS, and DOR analyses for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:TrialEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labResultId rdf:type rdf:Property ;
    rdfs:label 'Lab Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each laboratory test result record in the clinical trial data product. Primary key for the lab_result entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biospecimenId rdf:type rdf:Property ;
    rdfs:label 'Biospecimen Id' ;
    rdfs:comment 'Foreign key linking to clinical.biospecimen. Business justification: Laboratory results are derived from biological specimens. Both tables have specimen_type, but the authoritative source is biospecimen. Linking lab_result to biospecimen enables traceability from test ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Biospecimen .

ind:labBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Lab Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Central labs are registered business partners in pharma masterdata for vendor qualification, payment, and GLP/GCP audit trails. lab_name and lab_accreditation_number are denormalized plain-text attrib' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:clinicallySignificantFlag rdf:type rdf:Property ;
    rdfs:label 'Clinically Significant Flag' ;
    rdfs:comment 'Boolean flag indicating whether the laboratory result has been assessed by the investigator as clinically significant. Corresponds to CDISC CDASH/SDTM LBCLSIG. A clinically significant abnormal result may trigger an adverse event report or protocol-defined action.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Data Entry Status' ;
    rdfs:comment 'Status of the Case Report Form (CRF) data entry for this laboratory result in Medidata Rave EDC. Tracks the data management workflow from initial entry through verification and database lock. Used for data cleaning and trial master file completeness tracking.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enteredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entered Timestamp' ;
    rdfs:comment 'Date and time when the laboratory result was entered or imported into the Medidata Rave EDC system. Used for audit trail compliance per 21 CFR Part 11 and ICH E6(R2) to demonstrate timely data entry and GCP compliance.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fastingStatus rdf:type rdf:Property ;
    rdfs:label 'Fasting Status' ;
    rdfs:comment 'Indicates whether the subject was fasting at the time of specimen collection. Relevant for metabolic panels (glucose, lipids) where fasting status affects reference ranges and result interpretation. Corresponds to CDISC SDTM LBFAST.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labType rdf:type rdf:Property ;
    rdfs:label 'Lab Type' ;
    rdfs:comment 'Indicates whether the laboratory result was generated by a central laboratory (contracted central lab with standardized methods across all sites) or a local laboratory (site-specific lab). Central lab results are preferred for primary efficacy and safety endpoints due to standardization.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loincCode rdf:type rdf:Property ;
    rdfs:label 'Loinc Code' ;
    rdfs:comment 'Standardized LOINC code identifying the laboratory test or observation. Enables cross-study, cross-site, and cross-system harmonization of lab test definitions. Required for regulatory submissions and interoperability with central lab data transfers.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalFlag rdf:type rdf:Property ;
    rdfs:label 'Normal Flag' ;
    rdfs:comment 'Flag indicating whether the result is within, below, or above the laboratory\'s normal reference range. Corresponds to CDISC SDTM LBNRIND. Values: normal, low, high, critically_low, critically_high. Used in safety data listings and shift tables for regulatory submissions.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panicValueFlag rdf:type rdf:Property ;
    rdfs:label 'Panic Value Flag' ;
    rdfs:comment 'Boolean flag indicating whether the result meets the laboratory\'s criteria for a panic (critical) value requiring immediate notification to the investigator or site. Supports GCP-compliant safety monitoring and timely SAE/AE reporting obligations.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queryFlag rdf:type rdf:Property ;
    rdfs:label 'Query Flag' ;
    rdfs:comment 'Boolean flag indicating whether an open data query (discrepancy) exists for this laboratory result record in Medidata Rave EDC. Used by data managers to track unresolved data issues requiring site clarification before database lock.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:raveRecordReference rdf:type rdf:Property ;
    rdfs:label 'Rave Record Reference' ;
    rdfs:comment 'Source system record identifier from Medidata Rave EDC for this laboratory result entry. Used for data lineage, reconciliation, and audit trail back to the originating EDC system.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Reference Range High' ;
    rdfs:comment 'Upper bound of the laboratory\'s normal reference range for this test, applicable to the subject\'s demographic group (age, sex). Corresponds to CDISC SDTM LBSTNRHI. Used for normal/abnormal flagging and shift table generation.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceRangeLow rdf:type rdf:Property ;
    rdfs:label 'Reference Range Low' ;
    rdfs:comment 'Lower bound of the laboratory\'s normal reference range for this test, applicable to the subject\'s demographic group (age, sex). Corresponds to CDISC SDTM LBSTNRLO. Used for normal/abnormal flagging and shift table generation.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the laboratory result was officially reported and transmitted by the laboratory to the sponsor or EDC system. Used for turnaround time monitoring, GCP compliance (timely reporting of critical values), and data transfer reconciliation.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current status of the laboratory result record reflecting its lifecycle in the EDC and central lab workflow. Values: preliminary (initial result), final (verified and released), corrected (amended after initial release), cancelled (result voided), pending (awaiting analysis). Corresponds to HL7 observation status.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultUnitStandard rdf:type rdf:Property ;
    rdfs:label 'Result Unit Standard' ;
    rdfs:comment 'Standardized unit of measure for the laboratory result after conversion to a common unit for cross-site and cross-study comparability. Corresponds to CDISC SDTM LBSTRESU. Enables pooled analyses and regulatory submission datasets.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValueNumeric rdf:type rdf:Property ;
    rdfs:label 'Result Value Numeric' ;
    rdfs:comment 'Numeric representation of the laboratory result value after standardization and unit conversion. Corresponds to CDISC SDTM LBSTRESN. Used for quantitative statistical analyses, shift tables, and outlier detection. Null for non-numeric results.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyDay rdf:type rdf:Property ;
    rdfs:label 'Study Day' ;
    rdfs:comment 'Relative study day of specimen collection calculated from the subject\'s first dose date (Day 1). Negative values indicate pre-dose assessments. Corresponds to CDISC SDTM LBDY. Used for time-course analyses, PK/PD modeling, and protocol compliance assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCategory rdf:type rdf:Property ;
    rdfs:label 'Test Category' ;
    rdfs:comment 'Broad classification of the laboratory test panel or category (e.g., hematology, chemistry, urinalysis, coagulation). Corresponds to CDISC SDTM LBCAT variable. Used for grouping and filtering in safety data review and regulatory submissions. [ENUM-REF-CANDIDATE: hematology|chemistry|urinalysis|coagulation|immunology|microbiology|pharmacokinetics|other — promote to reference product]' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testName rdf:type rdf:Property ;
    rdfs:label 'Test Name' ;
    rdfs:comment 'Human-readable name of the laboratory test performed (e.g., Hemoglobin, Serum Creatinine, ALT, White Blood Cell Count). Sourced from the central lab data transfer file and mapped to the CRF lab panel definition in Medidata Rave.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSubcategory rdf:type rdf:Property ;
    rdfs:label 'Test Subcategory' ;
    rdfs:comment 'More granular sub-classification of the laboratory test within its category (e.g., liver function tests within chemistry, CBC within hematology). Corresponds to CDISC SDTM LBSCAT variable.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Date and time when the laboratory result was verified (source data verified, SDV) by the clinical monitor or data manager in Medidata Rave. Required for GCP audit trail and trial master file completeness.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trialMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Trial Milestone Id' ;
    rdfs:comment 'Unique surrogate identifier for each trial milestone record in the clinical trial management system. Primary key for the trial_milestone data product.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Id' ;
    rdfs:comment 'Foreign key linking to product.lifecycle. Business justification: Trial milestones (FPFV, DBL, CSR completion, NDA submission) are the primary triggers for product lifecycle stage-gate decisions. Portfolio governance and R&D leadership use this link to automatically' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lifecycle .

ind:completionEvidenceType rdf:type rdf:Property ;
    rdfs:label 'Completion Evidence Type' ;
    rdfs:comment 'Type of documentation used to confirm milestone completion (e.g., signed memo, system-generated log from Medidata Rave, regulatory authority letter, DSMB report). Required for GCP inspection readiness and audit trail completeness.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:databaseLockType rdf:type rdf:Property ;
    rdfs:label 'Database Lock Type' ;
    rdfs:comment 'Specifies the type of database lock associated with this milestone, where applicable: interim (for interim analysis), final (for primary analysis), or partial (for a subset of sites or data). Populated only for database lock milestones. Supports data management planning.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'The current best estimate of when the milestone will be achieved, updated dynamically as the trial progresses. Distinct from planned_date (baseline) and actual_date (confirmed completion). Supports rolling forecast and portfolio timeline management.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthAuthority rdf:type rdf:Property ;
    rdfs:label 'Health Authority' ;
    rdfs:comment 'The regulatory health authority to which this milestone is committed or reported (e.g., FDA, EMA, MHRA, PMDA, NMPA). Relevant when is_regulatory_commitment is True. Supports multi-regional regulatory commitment tracking. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Number' ;
    rdfs:comment 'Sequential number identifying which interim analysis this milestone represents (e.g., 1 for IA1, 2 for IA2). Populated only when is_interim_analysis is True. Supports tracking of multiple pre-specified interim analyses within a single trial.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isInterimAnalysis rdf:type rdf:Property ;
    rdfs:label 'Is Interim Analysis' ;
    rdfs:comment 'Indicates whether this milestone represents an interim analysis event (e.g., a pre-specified interim efficacy or futility analysis). When True, additional blinding and DSMB (Data Safety Monitoring Board) governance controls apply.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryCommitment rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Commitment' ;
    rdfs:comment 'Indicates whether this milestone represents a formal commitment made to a health authority (e.g., FDA, EMA, PMDA) as part of an approval condition, post-approval commitment, or REMS requirement. When True, triggers mandatory regulatory commitment tracking workflows.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneSequence rdf:type rdf:Property ;
    rdfs:label 'Milestone Sequence' ;
    rdfs:comment 'Integer defining the chronological order of this milestone within the trial\'s project plan. Used to enforce milestone sequencing logic, detect out-of-order completions, and render Gantt-style timeline visualizations.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether stakeholder notifications (e.g., to regulatory affairs, clinical operations leadership, CRO partners) have been dispatched upon milestone completion or delay detection. Supports automated workflow orchestration.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorMilestoneCode rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Code' ;
    rdfs:comment 'The milestone_code of the immediately preceding milestone that must be completed before this milestone can begin. Enables dependency-aware critical path analysis and automated scheduling in the CTMS.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceCommentary rdf:type rdf:Property ;
    rdfs:label 'Variance Commentary' ;
    rdfs:comment 'Free-text narrative explaining the reason for any deviation between planned and actual/forecast milestone dates. Captures context not covered by variance_reason_code, including mitigation actions taken. Required for regulatory commitment reporting to FDA/EMA.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Signed integer representing the difference in calendar days between the actual (or forecast) date and the planned date. Positive values indicate delay; negative values indicate early completion. Stored as a business field to support regulatory commitment reporting without requiring runtime calculation.' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standardized code categorizing the root cause of any milestone variance. Used for portfolio-level trend analysis and process improvement. [ENUM-REF-CANDIDATE: site_activation_delay|enrollment_shortfall|protocol_amendment|regulatory_hold|safety_event|data_quality|resource_constraint|vendor_delay|other — promote to reference product]' ;
    rdfs:domain ind:TrialMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalTrialId rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Id' ;
    rdfs:comment 'Reference to the clinical trial record when report_type = \'clinical_trial\'. Links the ICSR to the sponsoring study for SAE reconciliation with the EDC (Medidata Rave), CTMS, and eTMF. Supports IND safety reporting obligations under 21 CFR Part 312.32.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trial .

ind:investigationalCompoundId rdf:type rdf:Property ;
    rdfs:label 'Investigational Compound Id' ;
    rdfs:comment 'Foreign key linking to discovery.compound. Business justification: ICSRs for investigational products in clinical trials must reference the specific discovery compound for IND safety reporting, causality assessment, and DSUR preparation. FDA and EMA require traceabil' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:processingOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Processing Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: ICSR cases are assigned to specific PV org units (regional safety teams) for case processing and regulatory submission. PV case management systems track org unit ownership for workload reporting, GCP ' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:reporterCountryId rdf:type rdf:Property ;
    rdfs:label 'Reporter Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Reporter country determines regulatory reporting obligations, timelines (15-day vs 90-day rules), and format requirements (E2B versions). Critical for pharmacovigilance compliance and case routing to ' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:salesRepId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to commercial.sales_rep. Business justification: ICSRs collected by field sales reps must reference the reporting rep for follow-up management, training compliance tracking, and sunshine act reporting. Field force AE reporting is a standard pharma w' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesRep .

ind:submittingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Submitting Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: ICSRs are submitted by a specific MAH legal entity — a core E2B(R3) regulatory requirement. The sender_organisation plain-text field is a denormalization of legal_entity. A proper FK enables regulator' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:aeOnsetDate rdf:type rdf:Property ;
    rdfs:label 'Ae Onset Date' ;
    rdfs:comment 'Date of onset of the adverse event/reaction as reported by the reporter. Corresponds to ICH E2B(R3) E.i.4. Used for time-to-onset analysis, dechallenge/rechallenge assessment, and signal detection.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeOutcome rdf:type rdf:Property ;
    rdfs:label 'Ae Outcome' ;
    rdfs:comment 'Outcome of the adverse event at the time of reporting. Corresponds to ICH E2B(R3) E.i.7. Fatal outcome triggers mandatory expedited reporting and mortality signal analysis.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNarrative rdf:type rdf:Property ;
    rdfs:label 'Case Narrative' ;
    rdfs:comment 'Free-text medical narrative summarizing the adverse event, patient history, suspect drug details, clinical course, and outcome. Authored by the medical reviewer. Corresponds to ICH E2B(R3) H.1. Classified confidential as it may contain de-identified but sensitive clinical information.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNullificationFlag rdf:type rdf:Property ;
    rdfs:label 'Case Nullification Flag' ;
    rdfs:comment 'Indicates whether this case version represents a nullification (retraction) of a previously submitted ICSR. True = nullification report submitted to health authorities. Corresponds to ICH E2B(R3) C.1.11.1.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current workflow state of the ICSR within the pharmacovigilance case management system (Argus Safety). Drives SLA monitoring for 7-day and 15-day regulatory reporting deadlines. [ENUM-REF-CANDIDATE: new|in_triage|in_processing|pending_review|closed|archived|nullified — promote to reference product]' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Case Version Number' ;
    rdfs:comment 'Sequential version counter for the ICSR record. Version 1 = initial report; subsequent integers represent follow-up reports with new or amended information. Nullification reports are tracked via case_nullification_flag. Supports full version history per ICH E2B(R3) C.1.2 and 21 CFR Part 11 audit trail requirements.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:duplicateAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Duplicate Assessment Outcome' ;
    rdfs:comment 'Result of the duplicate case detection assessment performed during intake triage. Duplicate cases are linked to the master case and suppressed from regulatory submission counts. Critical for accurate signal detection and aggregate reporting.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Edc Reconciliation Status' ;
    rdfs:comment 'Status of SAE reconciliation between the pharmacovigilance database (Argus Safety) and the clinical trial EDC system (Medidata Rave). Applicable when report_type = \'clinical_trial\'. Ensures consistency between safety database and clinical database per ICH E6(R2) GCP requirements.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listednessAssessment rdf:type rdf:Property ;
    rdfs:label 'Listedness Assessment' ;
    rdfs:comment 'Assessment of whether the adverse drug reaction is listed (expected) in the current Reference Safety Information (RSI) — Company Core Data Sheet (CCDS) or approved product labeling. Unlisted + serious = SUSAR (Suspected Unexpected Serious Adverse Reaction), triggering expedited reporting. Corresponds to ICH E2B(R3) G.k.9.i.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:literatureReference rdf:type rdf:Property ;
    rdfs:label 'Literature Reference' ;
    rdfs:comment 'PubMed Identifier (PMID) or Digital Object Identifier (DOI) for literature-sourced ICSRs. Populated when report_type = \'literature\'. Corresponds to ICH E2B(R3) C.4.r.1. Supports systematic literature review (SLR) traceability.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCriteriaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Minimum Criteria Met Flag' ;
    rdfs:comment 'Indicates whether the ICSR meets the four ICH E2B minimum criteria for a valid case: (1) identifiable reporter, (2) identifiable patient, (3) suspect drug, (4) adverse event. Cases not meeting minimum criteria are tracked but not submitted. Corresponds to ICH E2D minimum information requirements.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mostRecentInfoDate rdf:type rdf:Property ;
    rdfs:label 'Most Recent Info Date' ;
    rdfs:comment 'Date of the most recent follow-up information received for this case, resetting the regulatory clock for follow-up submissions. Corresponds to ICH E2B(R3) C.1.5.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientAgeUnit rdf:type rdf:Property ;
    rdfs:label 'Patient Age Unit' ;
    rdfs:comment 'Unit of measurement for patient_age_value. Corresponds to ICH E2B(R3) D.2.2b. Supports neonatal and pediatric cases where age is expressed in days, weeks, or months.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientAgeValue rdf:type rdf:Property ;
    rdfs:label 'Patient Age Value' ;
    rdfs:comment 'De-identified patient age at the time of the adverse event onset, expressed as a numeric value. Must be used in conjunction with patient_age_unit. Stored per GDPR/HIPAA de-identification standards. Corresponds to ICH E2B(R3) D.2.2a.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientSex rdf:type rdf:Property ;
    rdfs:label 'Patient Sex' ;
    rdfs:comment 'Biological sex of the patient as reported. De-identified demographic field per GDPR/HIPAA. Corresponds to ICH E2B(R3) D.5. Used in signal detection and benefit-risk assessment stratification.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientWeightKg rdf:type rdf:Property ;
    rdfs:label 'Patient Weight Kg' ;
    rdfs:comment 'Patient body weight in kilograms at the time of the adverse event, as reported. De-identified per GDPR/HIPAA. Corresponds to ICH E2B(R3) D.3. Used for dose-weight relationship analysis in signal detection.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryAeMeddraPt rdf:type rdf:Property ;
    rdfs:label 'Primary Ae Meddra Pt' ;
    rdfs:comment 'MedDRA (Medical Dictionary for Regulatory Activities) Preferred Term (PT) coding for the primary adverse event/reaction reported. Corresponds to ICH E2B(R3) E.i.2.1b. Standardized coding enables cross-case signal detection and regulatory submission.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAeMeddraSoc rdf:type rdf:Property ;
    rdfs:label 'Primary Ae Meddra Soc' ;
    rdfs:comment 'MedDRA System Organ Class (SOC) for the primary adverse event, derived from the MedDRA PT hierarchy. Supports aggregate signal detection by organ system and PSUR/PBRER tabulation requirements.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Deadline' ;
    rdfs:comment 'Calculated deadline date by which the ICSR must be submitted to the relevant health authority (FDA, EMA, PMDA, NMPA, TGA). Derived from receipt_date plus applicable reporting window (7 or 15 calendar days for expedited reports; 90 days for non-expedited). SLA-critical field for compliance monitoring.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Status' ;
    rdfs:comment 'Current submission status of the ICSR to the applicable health authority. Tracks compliance against 7-day and 15-day expedited reporting deadlines. Overdue status triggers escalation per PV SLA management procedures.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the ICSR source channel per ICH E2B(R3) C.1.3. Drives regulatory reporting obligations and processing workflows. Spontaneous reports from HCPs/patients, literature-sourced cases (PMID/DOI), clinical trial SAEs, solicited reports from patient support programs, and other sources.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Sender Case Number' ;
    rdfs:comment 'Internal case number assigned by the company (MAH/sponsor) in the source system (Argus Safety / Oracle AERS). Corresponds to ICH E2B(R3) C.1.8.1. Used for internal tracking and reconciliation with the worldwide unique case ID.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousFlag rdf:type rdf:Property ;
    rdfs:label 'Serious Flag' ;
    rdfs:comment 'Indicates whether the adverse event meets ICH E2A seriousness criteria (death, life-threatening, hospitalization, disability, congenital anomaly, or medically significant). True = Serious Adverse Event (SAE). Drives expedited 7-day or 15-day regulatory reporting obligation. Corresponds to ICH E2B(R3) E.i.3.2.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteria rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria' ;
    rdfs:comment 'Specific ICH E2A seriousness criterion or criteria met by the adverse event. Multiple criteria may apply. Corresponds to ICH E2B(R3) E.i.3.2a-f. [ENUM-REF-CANDIDATE: death|life_threatening|hospitalization|disability|congenital_anomaly|medically_significant — promote to reference product]' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Source Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the adverse event occurred. Corresponds to ICH E2B(R3) C.1.17.1. Determines applicable regulatory authority for submission routing (FDA, EMA, PMDA, NMPA, TGA, MHRA).' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:susarFlag rdf:type rdf:Property ;
    rdfs:label 'Susar Flag' ;
    rdfs:comment 'Indicates whether the case qualifies as a Suspected Unexpected Serious Adverse Reaction (SUSAR) — i.e., serious, unexpected (unlisted), and with a reasonable causal relationship to the investigational medicinal product. True = SUSAR requiring 7-day (fatal/life-threatening) or 15-day expedited reporting to health authorities and ethics committees.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:worldwideUniqueCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Worldwide Unique Case Number' ;
    rdfs:comment 'Globally unique case identifier assigned at intake, conforming to ICH E2B(R3) C.1.1 format (sender identifier + case number). Used for cross-regional deduplication and regulatory submission tracking across FDA MedWatch, EudraVigilance, J-ICSR, and NMPA.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adverseEventId rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Id' ;
    rdfs:comment 'Foreign key linking to patient.adverse_event. Business justification: PV-coded adverse reactions must be reconciled against EDC-captured adverse events per GVP Module VI. A direct FK from pv_adverse_reaction to patient.adverse_event enables reaction-level EDC reconcilia' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdverseEvent .

ind:causalityMethod rdf:type rdf:Property ;
    rdfs:label 'Causality Method' ;
    rdfs:comment 'The methodology or algorithm used to perform the causality assessment (e.g., WHO-UMC scale, Naranjo algorithm, company-specific algorithm). Supports audit trail and methodological consistency across cases.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codedBy rdf:type rdf:Property ;
    rdfs:label 'Coded By' ;
    rdfs:comment 'User identifier of the medical coder or system process that performed or confirmed the MedDRA coding. Required for audit trail under 21 CFR Part 11 electronic records compliance. Stores the user login or system account name.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingDate rdf:type rdf:Property ;
    rdfs:label 'Coding Date' ;
    rdfs:comment 'Date on which the MedDRA coding was completed for this adverse reaction. Used for coding turnaround time metrics, audit trail, and compliance with regulatory submission timelines.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:codingMethod rdf:type rdf:Property ;
    rdfs:label 'Coding Method' ;
    rdfs:comment 'Indicates whether the MedDRA coding was performed automatically by the safety system (auto-coded), manually by a medical coder (manual review), or auto-coded and subsequently confirmed by manual review. Supports coding quality metrics and audit trail requirements.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listednessDetermination rdf:type rdf:Property ;
    rdfs:label 'Listedness Determination' ;
    rdfs:comment 'Determination of whether this adverse reaction is listed (expected) or unlisted (unexpected) in the current Reference Safety Information (RSI), such as the Company Core Data Sheet (CCDS) or Investigator Brochure (IB). Unlisted serious reactions in clinical trials constitute Suspected Unexpected Serious Adverse Reactions (SUSARs) requiring expedited reporting.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraHlgtCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Hlgt Code' ;
    rdfs:comment 'MedDRA High Level Group Term (HLGT) code, one level above HLT in the MedDRA hierarchy. Supports broader therapeutic area grouping for signal detection and regulatory submissions.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraHltCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Hlt Code' ;
    rdfs:comment 'MedDRA High Level Term (HLT) code representing the grouping level above the Preferred Term. Used for aggregate signal detection and periodic safety update report (PSUR) tabulations.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraPtCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Pt Code' ;
    rdfs:comment 'MedDRA Preferred Term (PT) numeric code assigned to this adverse reaction after coding. The PT is the primary level used for regulatory reporting, signal detection, and line listing generation. Mandatory for ICSR submissions to FDA and EMA.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraPtName rdf:type rdf:Property ;
    rdfs:label 'Meddra Pt Name' ;
    rdfs:comment 'Human-readable MedDRA Preferred Term (PT) label corresponding to the meddra_pt_code. Stored denormalized for reporting and line listing generation without requiring a join to the MedDRA reference table.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraSocCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Soc Code' ;
    rdfs:comment 'MedDRA System Organ Class (SOC) code representing the highest level of the MedDRA hierarchy. Used for regulatory line listings, PSUR summary tabulations, and risk management plan (RMP) categorization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraVersion rdf:type rdf:Property ;
    rdfs:label 'Meddra Version' ;
    rdfs:comment 'Version of the MedDRA dictionary used to code this adverse reaction (e.g., 26.0, 26.1). Critical for regulatory submissions and recoding exercises when MedDRA versions are updated. Required for reproducibility of signal detection analyses.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalConfirmation rdf:type rdf:Property ;
    rdfs:label 'Medical Confirmation' ;
    rdfs:comment 'Indicates whether the adverse reaction has been medically confirmed by a healthcare professional (HCP). Medically confirmed cases carry greater weight in signal detection and regulatory reporting. Corresponds to ICH E2B(R3) field A.1.7.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeCode rdf:type rdf:Property ;
    rdfs:label 'Outcome Code' ;
    rdfs:comment 'Standardized outcome of the adverse reaction at the time of reporting. Values align with ICH E2B(R3) outcome codes: recovered/resolved, recovering/resolving, not recovered/not resolved, fatal, unknown, recovered with sequelae. Mandatory for regulatory submissions.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Reaction Duration Days' ;
    rdfs:comment 'Duration of the adverse reaction in days, calculated from onset to resolution. Stored as a business attribute when explicitly reported by the reporter or calculated during case processing. Supports time-to-resolution analytics and benefit-risk assessments.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reactionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reaction Sequence Number' ;
    rdfs:comment 'Sequential line number of this adverse reaction within the parent ICSR, enabling ordering and identification of multiple events within a single case. Corresponds to the reaction/event sequence in ICH E2B(R3) message structure.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reactionStatus rdf:type rdf:Property ;
    rdfs:label 'Reaction Status' ;
    rdfs:comment 'Current workflow processing status of this adverse reaction record within the pharmacovigilance case management system: new (received, not yet processed), under review, coded (MedDRA coding complete), medically reviewed, closed (finalized), or deleted (voided). Drives case management workflow in Argus Safety.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Type' ;
    rdfs:comment 'Classification of the regulatory reporting obligation triggered by this adverse reaction: 7-day expedited (unexpected fatal/life-threatening SUSAR), 15-day expedited (other serious unexpected), periodic (PSUR/PBRER), non-expedited, or not reportable. Drives submission workflow and deadline tracking.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSourceType rdf:type rdf:Property ;
    rdfs:label 'Reporting Source Type' ;
    rdfs:comment 'Classification of the original source from which this adverse reaction was reported: spontaneous (unsolicited), clinical trial, published literature, regulatory authority, or other. Determines applicable reporting timelines and regulatory obligations. Corresponds to ICH E2B(R3) field A.1.4.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityDescription rdf:type rdf:Property ;
    rdfs:label 'Severity Description' ;
    rdfs:comment 'Narrative severity classification of the adverse reaction using standard WHO/ICH terminology: mild, moderate, severe, life-threatening, or fatal. Complements CTCAE grade for non-oncology cases and post-market surveillance where CTCAE grading is not used.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalDetectionFlag rdf:type rdf:Property ;
    rdfs:label 'Signal Detection Flag' ;
    rdfs:comment 'Indicates whether this adverse reaction record has been flagged as contributing to a potential pharmacovigilance signal under review. Set by the signal detection process in the safety database. Supports signal management workflow and regulatory signal reporting obligations.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeToOnsetDays rdf:type rdf:Property ;
    rdfs:label 'Time To Onset Days' ;
    rdfs:comment 'Number of days from the first dose of the suspect drug to the onset of the adverse reaction. A key pharmacovigilance metric used in signal detection, causality assessment, and benefit-risk evaluation. Derived from drug start date and reaction onset date during case processing.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verbatimTerm rdf:type rdf:Property ;
    rdfs:label 'Verbatim Term' ;
    rdfs:comment 'The exact adverse event term as reported by the original reporter (patient, healthcare professional, or literature source) before MedDRA coding. Preserved verbatim for coding audit trail and signal detection. Required per ICH E2B(R3) field B.2.i.1.' ;
    rdfs:domain ind:PvAdverseReaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:susarId rdf:type rdf:Property ;
    rdfs:label 'Susar Id' ;
    rdfs:comment 'Unique surrogate identifier for the SUSAR record in the pharmacovigilance data product. Primary key for the silver-layer lakehouse entity.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Susar .

ind:argusCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Argus Case Number' ;
    rdfs:comment 'The unique case number assigned by the Argus Safety / Oracle AERS pharmacovigilance system for this SUSAR. Serves as the system-of-record identifier for cross-system traceability.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTreatmentArm rdf:type rdf:Property ;
    rdfs:label 'Assigned Treatment Arm' ;
    rdfs:comment 'The treatment arm to which the subject was assigned (e.g., investigational product, comparator, placebo), populated after unblinding. Required for causality assessment and regulatory reporting when unblinding has occurred.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaEudravigilanceSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Ema Eudravigilance Submission Date' ;
    rdfs:comment 'The date on which the SUSAR was submitted to the EMA via the EudraVigilance Clinical Trial Module (EVCTM). Null if not yet submitted or not applicable.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectednessDetermination rdf:type rdf:Property ;
    rdfs:label 'Expectedness Determination' ;
    rdfs:comment 'The sponsor\'s determination of whether the adverse reaction is expected or unexpected based on comparison against the current Investigator\'s Brochure (IB) or Reference Safety Information (RSI). An \'unexpected\' determination is a prerequisite for SUSAR classification.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaIndSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Fda Ind Submission Date' ;
    rdfs:comment 'The date on which the SUSAR was submitted to the FDA as an IND safety report under 21 CFR Part 312.32. Null if not yet submitted or not applicable. Used for SLA compliance tracking.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpNumber rdf:type rdf:Property ;
    rdfs:label 'Follow Up Number' ;
    rdfs:comment 'Sequential number of the follow-up report for this SUSAR (e.g., 1 for first follow-up, 2 for second). Zero or null for initial reports. Used to track the version history of regulatory submissions.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Initial Receipt Date' ;
    rdfs:comment 'The date on which the sponsor first received valid minimum information about the adverse reaction, triggering the start of the expedited reporting clock. Day 0 for 7-day and 15-day SLA calculations per ICH E2A.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigatorCausality rdf:type rdf:Property ;
    rdfs:label 'Investigator Causality' ;
    rdfs:comment 'The treating investigator\'s assessment of the causal relationship between the investigational product and the adverse reaction, as reported on the Case Report Form (CRF). Captured separately from sponsor causality per ICH E2A requirements.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFatal rdf:type rdf:Property ;
    rdfs:label 'Is Fatal' ;
    rdfs:comment 'Indicates whether the adverse reaction resulted in the death of the subject. A fatal outcome triggers the 7-day expedited reporting clock and is a primary driver of reporting urgency.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLifeThreatening rdf:type rdf:Property ;
    rdfs:label 'Is Life Threatening' ;
    rdfs:comment 'Indicates whether the adverse reaction was life-threatening at the time of occurrence (i.e., the subject was at immediate risk of death). Together with is_fatal, determines applicability of the 7-day reporting clock.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Medical Review Date' ;
    rdfs:comment 'The date on which the qualified medical reviewer completed the medical assessment of this SUSAR. Part of the audit trail for regulatory compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mhraSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Mhra Submission Date' ;
    rdfs:comment 'The date on which the SUSAR was submitted to the UK Medicines and Healthcare products Regulatory Agency (MHRA). Null if not applicable.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:narrativeText rdf:type rdf:Property ;
    rdfs:label 'Narrative Text' ;
    rdfs:comment 'The free-text clinical narrative describing the SUSAR, including the sequence of events, medical history, treatment, and outcome. Required for all regulatory submissions per ICH E2B(R3). Classified as confidential due to sensitive clinical content.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmdaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Pmda Submission Date' ;
    rdfs:comment 'The date on which the SUSAR was submitted to the Japan Pharmaceuticals and Medical Devices Agency (PMDA). Null if not applicable.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reactionMeddraPtCode rdf:type rdf:Property ;
    rdfs:label 'Reaction Meddra Pt Code' ;
    rdfs:comment 'The MedDRA (Medical Dictionary for Regulatory Activities) Preferred Term code representing the primary adverse reaction. Mandatory for regulatory submissions to FDA, EMA, MHRA, and PMDA.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionMeddraPtName rdf:type rdf:Property ;
    rdfs:label 'Reaction Meddra Pt Name' ;
    rdfs:comment 'The human-readable MedDRA Preferred Term name corresponding to the reaction_meddra_pt_code. Stored for reporting clarity and to avoid repeated lookups against the MedDRA dictionary.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionMeddraSocName rdf:type rdf:Property ;
    rdfs:label 'Reaction Meddra Soc Name' ;
    rdfs:comment 'The MedDRA System Organ Class (SOC) under which the primary adverse reaction is classified. Used for signal detection, aggregate analysis, and PSUR/PBRER reporting by therapeutic area.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionOnsetDate rdf:type rdf:Property ;
    rdfs:label 'Reaction Onset Date' ;
    rdfs:comment 'The date on which the suspected unexpected serious adverse reaction first manifested in the subject. Used for temporal causality assessment and time-to-onset analysis.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reactionOutcome rdf:type rdf:Property ;
    rdfs:label 'Reaction Outcome' ;
    rdfs:comment 'The outcome of the adverse reaction at the time of reporting. [ENUM-REF-CANDIDATE: recovered|recovering|not_recovered|recovered_with_sequelae|fatal|unknown — promote to reference product]' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the SUSAR record within the pharmacovigilance workflow. Drives workflow routing in Argus Safety and regulatory submission tracking. [ENUM-REF-CANDIDATE: draft|under_review|submitted|follow_up_pending|closed|invalidated — promote to reference product]' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingClockType rdf:type rdf:Property ;
    rdfs:label 'Reporting Clock Type' ;
    rdfs:comment 'Indicates whether this SUSAR is subject to a 7-day expedited reporting clock (fatal or life-threatening) or a 15-day reporting clock (all other serious unexpected reactions). Drives SLA enforcement and regulatory deadline calculation.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Date' ;
    rdfs:comment 'The calculated calendar date by which the SUSAR must be submitted to all applicable health authorities, derived from initial_receipt_date plus the applicable reporting clock (7 or 15 calendar days). SLA-critical field with criminal liability for non-compliance.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorCausality rdf:type rdf:Property ;
    rdfs:label 'Sponsor Causality' ;
    rdfs:comment 'The sponsor\'s assessment of the causal relationship between the investigational product and the adverse reaction. A causality of \'related\' or \'not assessable\' (where benefit of doubt applies) is required for SUSAR classification.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAge rdf:type rdf:Property ;
    rdfs:label 'Subject Age' ;
    rdfs:comment 'The age of the clinical trial subject in years at the time the adverse reaction occurred. Required for regulatory submissions and demographic analysis. Classified as restricted PHI.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectSex rdf:type rdf:Property ;
    rdfs:label 'Subject Sex' ;
    rdfs:comment 'The biological sex of the clinical trial subject as recorded in the case report. Required for ICH E2B(R3) regulatory submissions and demographic safety analysis. Classified as restricted PHI.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPhase rdf:type rdf:Property ;
    rdfs:label 'Trial Phase' ;
    rdfs:comment 'The phase of the clinical trial in which the SUSAR occurred (Phase I through Phase IV). Influences regulatory reporting obligations and signal assessment context.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saeReportId rdf:type rdf:Property ;
    rdfs:label 'Sae Report Id' ;
    rdfs:comment 'Unique surrogate identifier for the SAE report record in the pharmacovigilance safety database. Primary key for this entity.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SaeReport .

ind:edcCaseReference rdf:type rdf:Property ;
    rdfs:label 'Edc Case Reference' ;
    rdfs:comment 'Case or subject reference number from the clinical trial EDC system (e.g., Medidata Rave subject ID or AE sequence number) used to reconcile the SAE record between the safety database and the clinical database.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listedness rdf:type rdf:Property ;
    rdfs:label 'Listedness' ;
    rdfs:comment 'Assessment of whether the adverse reaction is listed (expected) in the current Reference Safety Information (RSI) such as the Investigator Brochure or SmPC. Determines whether the event qualifies as unexpected for SUSAR classification.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientAgeAtOnset rdf:type rdf:Property ;
    rdfs:label 'Patient Age At Onset' ;
    rdfs:comment 'Age of the patient in years at the time the serious adverse event began. Used for demographic analysis, signal detection, and population-specific risk assessment.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Actual date on which the ICSR/SUSAR was submitted to the health authority. Compared against regulatory_submission_due_date to assess compliance with reporting timelines.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Due Date' ;
    rdfs:comment 'Deadline by which the SAE/SUSAR must be submitted to the relevant health authority (FDA, EMA, etc.). Calculated from receipt_date based on applicable reporting timeline (7-day for fatal/life-threatening SUSAR; 15-day for other SUSARs; 30-day for non-expedited).' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteAwarenessDate rdf:type rdf:Property ;
    rdfs:label 'Site Awareness Date' ;
    rdfs:comment 'Date on which the investigational site or sponsor first became aware of the SAE. Used to calculate the 24-hour initial notification SLA and the 7/15-day regulatory reporting clock per ICH E2A and GCP requirements.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Description' ;
    rdfs:comment 'Free-text description of the treatment(s) administered to manage the SAE, including concomitant medications, procedures, or interventions. Captured in the case narrative.' ;
    rdfs:domain ind:SaeReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Pv Submission Id' ;
    rdfs:comment 'Unique surrogate identifier for each pharmacovigilance regulatory submission record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalSubmissionPvSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Original Submission Pv Submission Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original pv_submission_id when this record represents a resubmission, follow-up, or amendment. Null for original submissions. Enables reconstruction of the full resubmission history chain.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PvSubmission .

ind:primaryPvIcsrId rdf:type rdf:Property ;
    rdfs:label 'Primary Pv Icsr Id' ;
    rdfs:comment 'Reference to the Individual Case Safety Report (ICSR) that is the subject of this submission, when submission_type is an ICSR variant. Links to the source safety case record in Argus Safety / Oracle AERS. Null for aggregate report submissions (PSUR, PBRER, DSUR).' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Icsr .

ind:submissionCountryId rdf:type rdf:Property ;
    rdfs:label 'Submission Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Submission target country determines format (E2B R2/R3, CIOMS), gateway (EudraVigilance, FDA ESG, MHRA Yellow Card), and timelines. Operational requirement for submission routing and compliance tracki' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:acknowledgementCode rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Code' ;
    rdfs:comment 'Technical acknowledgement code returned by the health authority gateway per HL7 v2 / E2B messaging standards. AA = Application Accept; AE = Application Error; CA = Commit Accept; CE = Commit Error; TA = Technical Accept; TE = Technical Error. Drives automated error handling and resubmission workflows.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Authority Case Number' ;
    rdfs:comment 'The case or report reference number assigned by the receiving health authority upon acceptance of the submission (e.g., EudraVigilance case number, FDA FAERS case ID). Used for follow-up queries and regulatory correspondence. Populated after authority acceptance.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfFirstReceipt rdf:type rdf:Property ;
    rdfs:label 'Date Of First Receipt' ;
    rdfs:comment 'The date the company first received the minimum valid safety information constituting a reportable case (Day 0 for regulatory clock purposes). This is the anchor date from which the 7-day or 15-day expedited reporting deadline is calculated for ICSRs. Corresponds to ICH E2B(R3) C.1.4.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysToDeadline rdf:type rdf:Property ;
    rdfs:label 'Days To Deadline' ;
    rdfs:comment 'Number of calendar days remaining between the current date and the regulatory_deadline at the time of last record update. Negative values indicate overdue submissions. Used for SLA monitoring dashboards and automatic escalation triggers. Note: this is a snapshot value captured at record update time, not a live calculation.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Structured error code returned by the health authority gateway or E2B validation engine upon rejection or technical failure (e.g., EudraVigilance business rule error code, FAERS conformance error code). Enables automated error categorisation and routing to the appropriate remediation team.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayPortal rdf:type rdf:Property ;
    rdfs:label 'Gateway Portal' ;
    rdfs:comment 'The specific electronic gateway or web portal used to transmit this submission to the health authority. Determines technical format and protocol requirements. EudraVigilance Gateway and EVWEB are EMA channels; FAERS Gateway is the FDA channel for ICSRs; MHRA Sentinel is the UK post-Brexit channel. [ENUM-REF-CANDIDATE: EUDRAVIGILANCE_GATEWAY|EUDRAVIGILANCE_EVWEB|FAERS_GATEWAY|MHRA_SENTINEL|PMDA_GATEWAY|NMPA_GATEWAY|VIGIBASE_WHO|DIRECT_EMAIL|PAPER — promote to reference product]' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'Indicates whether this submission is subject to expedited regulatory reporting requirements (7-day or 15-day clock). True = expedited; False = periodic/non-expedited. Drives SLA escalation logic and compliance monitoring.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnTime rdf:type rdf:Property ;
    rdfs:label 'Is On Time' ;
    rdfs:comment 'Indicates whether the submission was transmitted on or before the regulatory_deadline. True = submitted on time; False = submitted late. Key compliance KPI field populated at time of submission. Used for regulatory compliance reporting and CAPA tracking.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:messageFormat rdf:type rdf:Property ;
    rdfs:label 'Message Format' ;
    rdfs:comment 'The technical format standard used for the submission message. E2B_R2_XML = ICH E2B(R2) XML format (used by some national authorities); E2B_R3_XML = ICH E2B(R3) XML format (required by EMA EudraVigilance and FDA from 2022); ECTD = Electronic Common Technical Document format (for aggregate reports); PDF = portable document format for ad-hoc communications; PAPER = legacy paper submission.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline' ;
    rdfs:comment 'The mandatory regulatory deadline date by which this submission must be transmitted to the health authority, calculated from the date of first receipt (Day 0) of the safety information. For expedited ICSRs: Day 7 (fatal/life-threatening) or Day 15 (serious). For PSURs/PBRERs: per approved data lock point schedule. SLA-critical field used for automatic escalation.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Free-text or structured description of the reason(s) for rejection returned by the health authority gateway or authority reviewer when submission_status is REJECTED. Includes E2B validation error codes and human-readable explanations. Used for root cause analysis and CAPA.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Report Period End' ;
    rdfs:comment 'End date of the data collection period (Data Lock Point, DLP) for aggregate reports (PSUR, PBRER, PADER, DSUR). Defines the cut-off date for safety data included in the report. Null for individual case (ICSR) submissions.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Report Period Start' ;
    rdfs:comment 'Start date of the data collection period covered by this submission. Applicable primarily to aggregate reports (PSUR, PBRER, PADER, DSUR) defining the International Birth Date (IBD) or period start. Null for individual case (ICSR) submissions.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportTypeQualifier rdf:type rdf:Property ;
    rdfs:label 'Report Type Qualifier' ;
    rdfs:comment 'Qualifier indicating whether this is an initial report, a follow-up update to a previously submitted case, or a nullification (withdrawal) of a previously submitted report. Corresponds directly to ICH E2B(R3) C.1.2 field.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleQppv rdf:type rdf:Property ;
    rdfs:label 'Responsible Qppv' ;
    rdfs:comment 'Name or identifier of the Qualified Person for Pharmacovigilance (QPPV) responsible for this submission under EU GVP regulations. The QPPV bears legal accountability for the completeness and accuracy of pharmacovigilance submissions to the EMA and EU member states.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'Number of times this submission has been resubmitted to the health authority following a rejection or technical error. Zero indicates the original submission was accepted without resubmission. Used to track submission quality and identify systemic data quality issues.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionVersion rdf:type rdf:Property ;
    rdfs:label 'Submission Version' ;
    rdfs:comment 'Sequential version number of this submission for a given safety case or aggregate report. Version 1 = initial submission; Version 2+ = follow-up or amendment submissions. Corresponds to ICH E2B(R3) C.1.2 (report type: initial/follow-up/nullification).' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionReference rdf:type rdf:Property ;
    rdfs:label 'Transmission Reference' ;
    rdfs:comment 'Unique message transmission identifier assigned by the health authority gateway at the point of receipt (e.g., EudraVigilance message ID, FAERS transmission reference). Distinct from the authority_case_number; this is the technical envelope identifier used for gateway-level tracing and acknowledgement matching.' ;
    rdfs:domain ind:PvSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestonePaymentId rdf:type rdf:Property ;
    rdfs:label 'Milestone Payment Id' ;
    rdfs:comment 'Foreign key linking to finance.milestone_payment. Business justification: In pharma licensing and co-development agreements, PSUR data lock points or favorable benefit-risk conclusions trigger contractual milestone payments. Finance milestone_payment tracks these triggering' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MilestonePayment .

ind:benefitRiskConclusion rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Conclusion' ;
    rdfs:comment 'Overall benefit-risk evaluation conclusion for the product as determined by the medical reviewer for this PSUR period. A finding of unfavourable or inconclusive may trigger regulatory action, label update, or risk management plan revision.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeCaseCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Case Count' ;
    rdfs:comment 'Total number of Individual Case Safety Reports (ICSRs) received from the IBD through the data lock point across all reporting intervals, providing the full post-marketing safety case history for the product.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeExposurePatientYears rdf:type rdf:Property ;
    rdfs:label 'Cumulative Exposure Patient Years' ;
    rdfs:comment 'Total cumulative patient-years of exposure to the product from IBD through data lock point, calculated from treatment duration data. Used as the primary denominator for incidence rate calculations in benefit-risk assessment.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeExposurePatients rdf:type rdf:Property ;
    rdfs:label 'Cumulative Exposure Patients' ;
    rdfs:comment 'Estimated cumulative number of patients exposed to the product from the IBD through the data lock point, derived from post-marketing surveillance, clinical trials, and sales data. Used as denominator for cumulative incidence rate calculations.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataLockPoint rdf:type rdf:Property ;
    rdfs:label 'Data Lock Point' ;
    rdfs:comment 'The cut-off date up to which all safety data (adverse events, literature, clinical studies) are included in this PSUR. No new data arising after this date is incorporated into the current report period.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:draftCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Draft Completion Date' ;
    rdfs:comment 'Date on which the initial draft of the PSUR was completed by the lead author and made available for internal review. Used to track preparation milestones against the submission deadline.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:haAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Ha Assessment Outcome' ;
    rdfs:comment 'Outcome of the health authority\'s assessment of this PSUR, indicating any regulatory action required. [ENUM-REF-CANDIDATE: pending|no_action|label_update|rmp_update|referral|suspension|withdrawal — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalBirthDate rdf:type rdf:Property ;
    rdfs:label 'International Birth Date' ;
    rdfs:comment 'The date of first marketing authorisation for the product in any country worldwide, used as the anchor date for calculating PSUR submission deadlines and reporting intervals per ICH E2C(R2). SLA-critical field.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intervalCaseCount rdf:type rdf:Property ;
    rdfs:label 'Interval Case Count' ;
    rdfs:comment 'Total number of Individual Case Safety Reports (ICSRs) received during the current reporting interval (between interval_start_date and data_lock_point), including both spontaneous and solicited reports.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intervalEndDate rdf:type rdf:Property ;
    rdfs:label 'Interval End Date' ;
    rdfs:comment 'End date of the current PSUR reporting interval, which is typically equal to the data lock point. Defines the close of the reporting window for interval case counts and exposure data.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intervalSaeCount rdf:type rdf:Property ;
    rdfs:label 'Interval Sae Count' ;
    rdfs:comment 'Number of Serious Adverse Events (SAEs) reported during the current reporting interval. SAEs include fatal, life-threatening, hospitalisation-requiring, or permanently disabling events per ICH E2A criteria.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intervalStartDate rdf:type rdf:Property ;
    rdfs:label 'Interval Start Date' ;
    rdfs:comment 'Start date of the current PSUR reporting interval (the period covered by this report). Together with interval_end_date defines the reporting window for interval case counts and exposure data.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intervalSusarCount rdf:type rdf:Property ;
    rdfs:label 'Interval Susar Count' ;
    rdfs:comment 'Number of Suspected Unexpected Serious Adverse Reactions (SUSARs) identified during the current reporting interval. SUSARs require expedited reporting and are tracked separately for signal detection purposes.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelUpdateRequired rdf:type rdf:Property ;
    rdfs:label 'Label Update Required' ;
    rdfs:comment 'Indicates whether the safety findings in this PSUR require an update to the product label (SmPC, Package Insert, or Patient Information Leaflet). A True value initiates a label change management workflow.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newSafetySignalsCount rdf:type rdf:Property ;
    rdfs:label 'New Safety Signals Count' ;
    rdfs:comment 'Number of new safety signals identified during the reporting interval through signal detection activities (disproportionality analysis, literature review, spontaneous reports). Drives benefit-risk re-evaluation.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:psusaProcedureNumber rdf:type rdf:Property ;
    rdfs:label 'Psusa Procedure Number' ;
    rdfs:comment 'EMA-assigned procedure number for the PSUR Single Assessment (PSUSA) process applicable to centrally authorised products in the EU. Used to track the PSUSA workflow and outcome in Veeva Vault RIM and RIMS.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qc Completion Date' ;
    rdfs:comment 'Date on which quality control review of the PSUR was completed, verifying accuracy of case counts, exposure data, and regulatory formatting prior to QPPV approval and submission.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier assigned to this PSUR/PBRER/PADER/DSUR submission, used in regulatory correspondence and tracking systems such as Argus Safety and Veeva Vault RIM.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Regulatory-mandated submission frequency for this PSUR, which varies by product age, risk profile, and authority requirements. Drives automated SLA deadline calculation from the IBD.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Number' ;
    rdfs:comment 'Sequential ordinal number of this PSUR reporting period for the product (e.g., 1st, 2nd, 3rd PSUR), enabling chronological tracking of the full PSUR history for a product.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmpUpdateRequired rdf:type rdf:Property ;
    rdfs:label 'Rmp Update Required' ;
    rdfs:comment 'Indicates whether the benefit-risk findings in this PSUR necessitate an update to the product\'s Risk Management Plan (RMP). A True value triggers a formal RMP revision workflow in the pharmacovigilance system.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Native record identifier from the originating pharmacovigilance system (Argus Safety, Oracle AERS, or Veeva Vault RIM) for this PSUR record, enabling traceability and reconciliation between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'Mandatory regulatory deadline by which this PSUR must be submitted to the applicable health authority, calculated from the IBD and reporting frequency. SLA-critical field monitored for compliance.' ;
    rdfs:domain ind:Psur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorityCountryId rdf:type rdf:Property ;
    rdfs:label 'Authority Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: RMPs are approved by health authorities in specific countries. Country of the approving authority is a core RMP tracking attribute per EU GVP Module V. A proper FK enables country-specific RMP version' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:previousVersionRmpId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Rmp Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding version of this RMP, enabling full version chain reconstruction and audit trail for regulatory inspections.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rmp .

ind:argusRmpCode rdf:type rdf:Property ;
    rdfs:label 'Argus Rmp Code' ;
    rdfs:comment 'Source system identifier for this RMP record as stored in Argus Safety / Oracle AERS, used for data lineage, reconciliation, and integration with the pharmacovigilance safety database.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Authority Approval Date' ;
    rdfs:comment 'Date on which the health authority formally approved or accepted this version of the RMP. Null if not yet approved.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessEvaluationPlan rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Evaluation Plan' ;
    rdfs:comment 'Description of the plan to evaluate the effectiveness of risk minimization measures, including key performance indicators, data sources, and evaluation timelines as required by EU GVP Module XVI.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedRiskCount rdf:type rdf:Property ;
    rdfs:label 'Identified Risk Count' ;
    rdfs:comment 'Number of important identified risks documented in the safety specification of this RMP version. An identified risk is one for which there is adequate evidence of an association with the medicinal product.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:missingInformationCount rdf:type rdf:Property ;
    rdfs:label 'Missing Information Count' ;
    rdfs:comment 'Number of missing information items documented in the safety specification, representing gaps in knowledge about the safety of the medicinal product (e.g., use in pregnancy, pediatric use).' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Planned date for the next periodic review and potential update of the RMP, as agreed with the health authority or per internal PV schedule.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passCommitmentCount rdf:type rdf:Property ;
    rdfs:label 'Pass Commitment Count' ;
    rdfs:comment 'Number of Post-Authorization Safety Study (PASS) commitments included in this RMP version, representing studies imposed as conditions of marketing authorization or undertaken voluntarily.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:potentialRiskCount rdf:type rdf:Property ;
    rdfs:label 'Potential Risk Count' ;
    rdfs:comment 'Number of important potential risks documented in the safety specification of this RMP version. A potential risk is one for which there is some basis for suspicion but insufficient evidence to confirm.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pvPlanType rdf:type rdf:Property ;
    rdfs:label 'Pv Plan Type' ;
    rdfs:comment 'Indicates whether the pharmacovigilance plan for this RMP includes only routine PV activities (spontaneous reporting, PSUR/PBRER) or also includes additional PV activities such as PASS studies, registries, or enhanced surveillance.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsProgramName rdf:type rdf:Property ;
    rdfs:label 'Rems Program Name' ;
    rdfs:comment 'Official name of the FDA-approved REMS program associated with this RMP, if applicable (e.g., iPLEDGE for isotretinoin, TIRF REMS Access Program).' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMinimizationType rdf:type rdf:Property ;
    rdfs:label 'Risk Minimization Type' ;
    rdfs:comment 'Indicates whether risk minimization measures in this RMP are limited to routine measures (product labeling, SmPC, PIL) or also include additional risk minimization measures (educational materials, controlled access programs, REMS for US).' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmpNumber rdf:type rdf:Property ;
    rdfs:label 'Rmp Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the RMP document, used in regulatory submissions and authority correspondence (e.g., RMP-2024-001).' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmpType rdf:type rdf:Property ;
    rdfs:label 'Rmp Type' ;
    rdfs:comment 'Classification of the RMP format based on the regulatory authority template: EU GVP Module V (EMA/MHRA), FDA Risk Evaluation and Mitigation Strategy (REMS), PMDA RMP (Japan), or WHO RMP. [ENUM-REF-CANDIDATE: EU_RMP|FDA_REMS|PMDA_RMP|MHRA_RMP|WHO_RMP — promote to reference product]' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySpecificationSummary rdf:type rdf:Property ;
    rdfs:label 'Safety Specification Summary' ;
    rdfs:comment 'Narrative summary of the safety specification section of the RMP, covering the epidemiology of the indication, non-clinical safety findings, clinical trial safety data, and post-marketing experience.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeIndication rdf:type rdf:Property ;
    rdfs:label 'Scope Indication' ;
    rdfs:comment 'The approved or proposed therapeutic indication(s) covered by this RMP, as defined in the marketing authorization or clinical development program (e.g., treatment of relapsed/refractory multiple myeloma).' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopePopulation rdf:type rdf:Property ;
    rdfs:label 'Scope Population' ;
    rdfs:comment 'Description of the target patient population covered by this RMP, including age groups, special populations (pediatric, geriatric, renal/hepatic impairment), and any population restrictions.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalDetectionReference rdf:type rdf:Property ;
    rdfs:label 'Signal Detection Reference' ;
    rdfs:comment 'Reference identifier(s) to pharmacovigilance signal detection records or PRAC signal assessments that triggered or informed this RMP version update.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionChangeRationale rdf:type rdf:Property ;
    rdfs:label 'Version Change Rationale' ;
    rdfs:comment 'Documented rationale for updating this RMP version, including the trigger (e.g., new safety signal, PSUR outcome, authority request, new indication, PASS completion) and summary of changes from the previous version.' ;
    rdfs:domain ind:Rmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Period End Date' ;
    rdfs:comment 'End date of the data analysis period used for signal detection. Together with analysis_period_start_date, defines the cumulative or interval data window reviewed.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Period Start Date' ;
    rdfs:comment 'Start date of the data analysis period used for signal detection. Defines the temporal window of adverse event data reviewed to identify the signal.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Assessment Summary' ;
    rdfs:comment 'Narrative summary of the formal signal assessment findings, including methodology applied, data sources reviewed, clinical interpretation, and conclusions. Supports regulatory dossier preparation and PRAC submissions.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitRiskImpact rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Impact' ;
    rdfs:comment 'Overall benefit-risk impact determination resulting from the signal assessment. Indicates whether the signal changes the benefit-risk balance of the product as favorable, unfavorable, uncertain, or neutral.' ;
    rdfs:domain ind:Pharmacovigilance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceDatabase rdf:type rdf:Property ;
    rdfs:label 'Data Source Database' ;
    rdfs:comment 'Name of the specific pharmacovigilance database or data source from which the signal was detected (e.g., FDA FAERS, WHO VigiBase, EudraVigilance, company spontaneous database, published literature). Supports traceability of signal origin.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the safety signal was first detected or identified, representing the principal real-world event time. Critical for SLA tracking of PRAC rapporteur notification timelines and regulatory reporting deadlines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ebgmValue rdf:type rdf:Property ;
    rdfs:label 'Ebgm Value' ;
    rdfs:comment 'Empirical Bayes Geometric Mean (EBGM) — a Bayesian disproportionality metric used in the FDA FAERS database analysis. EBGM ≥2 is a commonly applied threshold for signal detection.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fatalCaseCount rdf:type rdf:Property ;
    rdfs:label 'Fatal Case Count' ;
    rdfs:comment 'Number of fatal outcome cases among the cases contributing to this safety signal. Fatal cases receive highest priority in signal triage and may trigger expedited regulatory notification.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icValue rdf:type rdf:Property ;
    rdfs:label 'Ic Value' ;
    rdfs:comment 'Information Component (IC) — a Bayesian disproportionality metric used by the WHO Uppsala Monitoring Centre (UMC) VigiBase. Positive IC values indicate a drug-event association stronger than expected by chance.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelChangeRecommended rdf:type rdf:Property ;
    rdfs:label 'Label Change Recommended' ;
    rdfs:comment 'Indicates whether the signal assessment has resulted in a formal recommendation to update the product label (SmPC, USPI, or equivalent). Triggers regulatory submission activities.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pracNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Prac Notification Date' ;
    rdfs:comment 'Actual date on which the PRAC rapporteur was notified of the safety signal. Compared against prac_notification_due_date to assess SLA compliance.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pracNotificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Prac Notification Due Date' ;
    rdfs:comment 'SLA-critical deadline by which the PRAC rapporteur must be notified of the validated safety signal per EMA regulatory requirements. Drives escalation workflows and compliance monitoring.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prrValue rdf:type rdf:Property ;
    rdfs:label 'Prr Value' ;
    rdfs:comment 'Proportional Reporting Ratio (PRR) — a disproportionality analysis metric quantifying the ratio of the proportion of reports for a drug-event combination versus all other drugs. Values >2 with chi-squared >4 and ≥3 cases typically indicate a signal.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:psurReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Psur Referral Flag' ;
    rdfs:comment 'Indicates whether this safety signal has been referred for inclusion and evaluation in the next Periodic Safety Update Report (PSUR) / Periodic Benefit-Risk Evaluation Report (PBRER).' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryActionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Required' ;
    rdfs:comment 'Indicates whether the safety signal assessment has determined that a regulatory action is required (e.g., label update, DHPC, REMS modification, product withdrawal). Drives downstream regulatory affairs workflows.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rorValue rdf:type rdf:Property ;
    rdfs:label 'Ror Value' ;
    rdfs:comment 'Reporting Odds Ratio (ROR) — a disproportionality analysis metric representing the odds of a specific adverse event being reported for a drug versus all other drugs. Complements PRR in signal detection.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seriousCaseCount rdf:type rdf:Property ;
    rdfs:label 'Serious Case Count' ;
    rdfs:comment 'Number of Serious Adverse Event (SAE) cases among the total cases contributing to this signal. Serious cases include fatal, life-threatening, hospitalization, disability, or congenital anomaly outcomes per ICH E2A.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalDescription rdf:type rdf:Property ;
    rdfs:label 'Signal Description' ;
    rdfs:comment 'Detailed narrative description of the safety signal including the nature of the concern, clinical context, patient population affected, and initial evidence summary. Supports signal triage and assessment documentation.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalNumber rdf:type rdf:Property ;
    rdfs:label 'Signal Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier assigned to the safety signal upon creation in Argus Safety / Oracle AERS. Used for cross-system referencing, regulatory correspondence, and PRAC rapporteur notifications.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalSourceType rdf:type rdf:Property ;
    rdfs:label 'Signal Source Type' ;
    rdfs:comment 'Classification of the data source from which the safety signal was detected. [ENUM-REF-CANDIDATE: spontaneous_database|literature|clinical_trial|real_world_data|social_media|health_authority — promote to reference product]' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStatus rdf:type rdf:Property ;
    rdfs:label 'Signal Status' ;
    rdfs:comment 'Current lifecycle state of the safety signal per GVP Module IX workflow: new (detected, not yet triaged), under_evaluation (active assessment in progress), validated (confirmed as a genuine safety concern), refuted (assessed and dismissed), closed (final disposition reached and documented).' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalTitle rdf:type rdf:Property ;
    rdfs:label 'Signal Title' ;
    rdfs:comment 'Concise, human-readable title describing the safety signal, typically formatted as [Drug Name] and [Adverse Event Term]. Used in regulatory correspondence, PRAC submissions, and internal safety committee communications.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalType rdf:type rdf:Property ;
    rdfs:label 'Signal Type' ;
    rdfs:comment 'Classification of the signal as new (not previously known), strengthened (existing signal with increased evidence), weakened (existing signal with decreased evidence), or refuted (previously identified signal now dismissed).' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Reference number or identifier from the originating data source (e.g., FAERS case number, EudraVigilance report ID, literature PubMed ID, clinical trial NCT number) that triggered or contributed to the signal detection.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageDate rdf:type rdf:Property ;
    rdfs:label 'Triage Date' ;
    rdfs:comment 'Date on which the safety signal was formally triaged by the pharmacovigilance team to determine priority and assign for full assessment. Marks the transition from detection to active evaluation.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the safety signal was formally validated as a genuine safety concern following initial assessment. Triggers downstream regulatory notification and benefit-risk evaluation activities.' ;
    rdfs:domain ind:SafetySignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationCountryId rdf:type rdf:Property ;
    rdfs:label 'Authorization Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Product authorization country determines regulatory jurisdiction, reporting requirements (expedited timelines, formats), and applicable safety regulations. Essential for routing ICSRs to correct healt' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:currentLabelId rdf:type rdf:Property ;
    rdfs:label 'Current Label Id' ;
    rdfs:comment 'Foreign key linking to regulatory.label. Business justification: The current approved label is the reference document for listedness assessments across all PV activities. Linking pv_product to the current label version enables centralized listedness reference manag' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Label .

ind:discoveryCompoundId rdf:type rdf:Property ;
    rdfs:label 'Discovery Compound Id' ;
    rdfs:comment 'Foreign key linking to discovery.compound. Business justification: Core traceability for safety signal investigation. When adverse events emerge, pharmacovigilance teams must access the original discovery compound structure, preclinical safety data, and SAR to assess' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:argusProductCode rdf:type rdf:Property ;
    rdfs:label 'Argus Product Code' ;
    rdfs:comment 'Native product identifier from the Argus Safety / Oracle AERS pharmacovigilance system. Used for cross-system reconciliation and traceability between the Silver Layer PV product master and the operational PV case processing system.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationType rdf:type rdf:Property ;
    rdfs:label 'Authorization Type' ;
    rdfs:comment 'Type of regulatory marketing authorisation application under which the product is approved (e.g., NDA — New Drug Application, BLA — Biologics License Application, MAA — Marketing Authorisation Application). Determines submission pathway and reporting requirements. [ENUM-REF-CANDIDATE: NDA|BLA|MAA|ANDA|NDS|other — promote to reference product]' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Flag' ;
    rdfs:comment 'Indicates whether the product contains a controlled substance subject to DEA scheduling requirements. True = controlled substance; False = not a controlled substance. Impacts PV reporting and distribution controls.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emaProductNumber rdf:type rdf:Property ;
    rdfs:label 'Ema Product Number' ;
    rdfs:comment 'EMA-assigned product number for centrally authorised products in the EU. Used for EudraVigilance submissions, PSUR repository submissions, and EU regulatory correspondence.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudravigilanceMpCode rdf:type rdf:Property ;
    rdfs:label 'Eudravigilance Mp Code' ;
    rdfs:comment 'EudraVigilance Medicinal Product Dictionary (EVMPD) identifier assigned by EMA for the product. Required for electronic ICSR submissions to EudraVigilance and EU regulatory reporting.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Expedited Reporting Required' ;
    rdfs:comment 'Indicates whether this product is subject to expedited (7-day or 15-day) Individual Case Safety Report (ICSR) reporting obligations to health authorities. Drives case processing timelines in Argus Safety.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:psmfReference rdf:type rdf:Property ;
    rdfs:label 'Psmf Reference' ;
    rdfs:comment 'Reference identifier linking this product to the applicable Pharmacovigilance System Master File (PSMF) that describes the PV system governing this product. Mandatory for EU GVP Module II compliance.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psurDueDate rdf:type rdf:Property ;
    rdfs:label 'Psur Due Date' ;
    rdfs:comment 'Next scheduled due date for submission of the Periodic Safety Update Report (PSUR) or Periodic Benefit-Risk Evaluation Report (PBRER) to the relevant health authority. Calculated from IBD and submission frequency.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:psurFrequency rdf:type rdf:Property ;
    rdfs:label 'Psur Frequency' ;
    rdfs:comment 'Regulatory-mandated frequency for Periodic Safety Update Report (PSUR) / Periodic Benefit-Risk Evaluation Report (PBRER) submission for this product. Drives the PSUR scheduling calendar.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvStatus rdf:type rdf:Property ;
    rdfs:label 'Pv Status' ;
    rdfs:comment 'Current lifecycle status of the product within the pharmacovigilance system. Drives case processing eligibility, signal detection inclusion, and PSUR scheduling. Active = currently under PV surveillance; Suspended = temporarily halted; Withdrawn = marketing authorisation withdrawn; Under_review = under regulatory review; Archived = historical record only.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmpRequired rdf:type rdf:Property ;
    rdfs:label 'Rmp Required' ;
    rdfs:comment 'Indicates whether a Risk Management Plan (RMP) is required for this product by the applicable health authority. True = RMP is mandated; False = RMP not required. Drives risk minimisation activity tracking.' ;
    rdfs:domain ind:PvProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspectDrugId rdf:type rdf:Property ;
    rdfs:label 'Suspect Drug Id' ;
    rdfs:comment 'Unique surrogate identifier for the suspect or concomitant drug record within an Individual Case Safety Report (ICSR). Primary key of this entity.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentExposureId rdf:type rdf:Property ;
    rdfs:label 'Treatment Exposure Id' ;
    rdfs:comment 'Foreign key linking to patient.treatment_exposure. Business justification: Batch/lot-level safety investigations require tracing a PV suspect drug record to the specific treatment_exposure (lot_number, dose_administered, administration_date). This link is essential for batch' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentExposure .

ind:codingStatus rdf:type rdf:Property ;
    rdfs:label 'Coding Status' ;
    rdfs:comment 'Status of the WHO Drug Dictionary coding process for this drug record: coded (coding complete), pending (awaiting coding), not coded (unable to code), auto-coded (coded by automated system), or manually coded (coded by a pharmacovigilance specialist).' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfAdministration rdf:type rdf:Property ;
    rdfs:label 'Country Of Administration' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the drug was administered to the patient. Used for regional signal detection and regulatory reporting stratification.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeDoseAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Dose Amount' ;
    rdfs:comment 'Total cumulative dose of the drug received by the patient from start to stop date (or to the date of the adverse event). Used in dose-response analyses and exposure-based signal detection. Maps to ICH E2B(R3) element G.k.5a.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeDoseUnit rdf:type rdf:Property ;
    rdfs:label 'Cumulative Dose Unit' ;
    rdfs:comment 'Unit of measurement for the cumulative dose amount (e.g., mg, g, IU). Must be interpreted in conjunction with cumulative_dose_amount. Maps to ICH E2B(R3) element G.k.5b.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseAmount rdf:type rdf:Property ;
    rdfs:label 'Dose Amount' ;
    rdfs:comment 'Numeric quantity of the drug administered per dose as reported. Must be interpreted in conjunction with dose_unit. Maps to ICH E2B(R3) element G.k.4.r.1a.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doseUnit rdf:type rdf:Property ;
    rdfs:label 'Dose Unit' ;
    rdfs:comment 'Unit of measurement for the dose amount (e.g., mg, mcg, g, mg/kg, IU, mL). Maps to ICH E2B(R3) element G.k.4.r.1b. [ENUM-REF-CANDIDATE: mg|mcg|g|mg/kg|IU|mL|mg/mL|% — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosingFrequency rdf:type rdf:Property ;
    rdfs:label 'Dosing Frequency' ;
    rdfs:comment 'Frequency at which the drug was administered (e.g., once daily, twice daily, weekly). Maps to ICH E2B(R3) element G.k.4.r.3. [ENUM-REF-CANDIDATE: once daily|twice daily|three times daily|four times daily|weekly|biweekly|monthly|as needed|continuous|every 8 hours — promote to reference product]' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugRole rdf:type rdf:Property ;
    rdfs:label 'Drug Role' ;
    rdfs:comment 'Role of the drug in the adverse event case: suspect (primary drug under investigation), concomitant (taken alongside but not suspected), interacting (suspected drug-drug interaction), or treatment (used to treat the adverse event). Maps to ICH E2B(R3) element G.k.1.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Drug Sequence Number' ;
    rdfs:comment 'Sequential number identifying the position of this drug record within the parent ICSR, used for ordering and referencing multiple drugs in a single case (e.g., drug 1, drug 2). Maps to ICH E2B(R3) element G.k.1.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indicationVerbatim rdf:type rdf:Property ;
    rdfs:label 'Indication Verbatim' ;
    rdfs:comment 'Indication for drug use as reported verbatim by the reporter, prior to MedDRA coding. Preserved for traceability and coding audit. Maps to ICH E2B(R3) element G.k.7.r.2a.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCompanyProduct rdf:type rdf:Property ;
    rdfs:label 'Is Company Product' ;
    rdfs:comment 'Indicates whether the drug is a product owned or marketed by the reporting company (True) or a competitor/third-party product (False). Determines regulatory reporting obligations and case ownership.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentDrugCode rdf:type rdf:Property ;
    rdfs:label 'Parent Drug Code' ;
    rdfs:comment 'WHO Drug Dictionary parent drug code representing the active moiety or parent compound, used to group drug products sharing the same active substance for aggregate signal detection and PSUR analyses.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemDrugCode rdf:type rdf:Property ;
    rdfs:label 'Source System Drug Code' ;
    rdfs:comment 'Identifier of this drug record in the originating pharmacovigilance source system (e.g., Argus Safety case drug ID or Oracle AERS drug sequence identifier). Supports data lineage, reconciliation, and audit traceability between the lakehouse silver layer and the system of record.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopDate rdf:type rdf:Property ;
    rdfs:label 'Stop Date' ;
    rdfs:comment 'Date on which the patient stopped taking the drug. Nullable if the drug was ongoing at the time of the report. Used to calculate exposure duration and assess dechallenge timing. Maps to ICH E2B(R3) element G.k.4.r.5.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verbatimDrugName rdf:type rdf:Property ;
    rdfs:label 'Verbatim Drug Name' ;
    rdfs:comment 'Drug name exactly as reported by the reporter (patient, healthcare professional, or other source) before any coding or standardization. Preserved for traceability and audit. Maps to ICH E2B(R3) element G.k.2.2.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whoDrugCode rdf:type rdf:Property ;
    rdfs:label 'Who Drug Code' ;
    rdfs:comment 'Unique alphanumeric code assigned by the WHO Drug Dictionary (WHO-DD) to the coded medicinal product. Used for product-level case aggregation, line listing, and signal detection analytics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whoDrugName rdf:type rdf:Property ;
    rdfs:label 'Who Drug Name' ;
    rdfs:comment 'Standardized drug name as coded against the WHO Drug Dictionary (WHO-DD), representing the preferred term for the medicinal product. Enables cross-case aggregation and signal detection.' ;
    rdfs:domain ind:SuspectDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterReporterId rdf:type rdf:Property ;
    rdfs:label 'Master Reporter Id' ;
    rdfs:comment 'Reference to the canonical/master reporter record when this record has been identified as a duplicate. Null if this record is itself the master. Supports deduplication and case re-linking workflows in the PV system.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reporter .

ind:anonymizedReporterCode rdf:type rdf:Property ;
    rdfs:label 'Anonymized Reporter Code' ;
    rdfs:comment 'Privacy-compliant pseudonymous identifier assigned to the reporter in lieu of personal identifiers, enabling case aggregation and follow-up management without exposing PII. Mandatory under GDPR and HIPAA for PV processing.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusReporterCode rdf:type rdf:Property ;
    rdfs:label 'Argus Reporter Code' ;
    rdfs:comment 'Source system identifier for the reporter as assigned by Argus Safety / Oracle AERS. Used for lineage tracing and deduplication against the operational PV system.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentToContact rdf:type rdf:Property ;
    rdfs:label 'Consent To Contact' ;
    rdfs:comment 'Indicates whether the reporter has provided explicit consent to be contacted for follow-up queries regarding the adverse event report. Mandatory consent gate under GDPR Article 7 before any follow-up communication is initiated.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactPreference rdf:type rdf:Property ;
    rdfs:label 'Contact Preference' ;
    rdfs:comment 'Preferred channel for follow-up communication as indicated by the reporter. Drives the follow-up workflow in Argus Safety. \'no_contact\' indicates the reporter has declined further contact, which must be respected per GDPR consent obligations.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Department or unit within the reporter\'s organization (e.g., Oncology Ward, Clinical Pharmacology, Drug Safety). Supports routing of follow-up queries to the correct organizational unit.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duplicateFlag rdf:type rdf:Property ;
    rdfs:label 'Duplicate Flag' ;
    rdfs:comment 'Indicates whether this reporter record has been identified as a potential or confirmed duplicate of another reporter record. Duplicate reporters must be resolved before case processing to prevent double-counting in aggregate safety analyses.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fax rdf:type rdf:Property ;
    rdfs:label 'Fax' ;
    rdfs:comment 'Fax number of the reporter or their institution, used for formal follow-up correspondence in jurisdictions where fax remains a regulatory-accepted communication channel (e.g., Japan PMDA submissions).' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstReportDate rdf:type rdf:Property ;
    rdfs:label 'First Report Date' ;
    rdfs:comment 'Date on which the reporter submitted their first adverse event report to the company. Used for longitudinal reporter relationship analysis and tenure-based reliability assessment.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpDeadline rdf:type rdf:Property ;
    rdfs:label 'Follow Up Deadline' ;
    rdfs:comment 'Target date by which a follow-up response from the reporter is required to meet regulatory submission timelines (e.g., 15-day expedited reporting for SUSARs and SAEs). Calculated based on initial receipt date and applicable regulatory clock.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether outstanding follow-up queries have been sent to this reporter and a response is pending. Drives the follow-up management workflow in Argus Safety to ensure timely case completion within regulatory timeframes.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprErasureDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Erasure Date' ;
    rdfs:comment 'Date on which the GDPR Right to Erasure request was processed and PII fields were anonymized. Null if no erasure request has been received. Required for GDPR compliance audit trail.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprErasureRequested rdf:type rdf:Property ;
    rdfs:label 'Gdpr Erasure Requested' ;
    rdfs:comment 'Indicates whether the reporter has submitted a Right to Erasure (Right to be Forgotten) request under GDPR Article 17. When true, PII fields must be anonymized while retaining the anonymized case record for pharmacovigilance regulatory obligations under GDPR Article 17(3)(c).' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'First/given name of the individual reporter. Stored in restricted classification per GDPR and HIPAA. Used for follow-up correspondence and duplicate detection. May be withheld or anonymized per reporter consent.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHcp rdf:type rdf:Property ;
    rdfs:label 'Is Hcp' ;
    rdfs:comment 'Indicates whether the reporter is a qualified Healthcare Professional (HCP). HCP-reported cases carry higher regulatory weight and may trigger expedited 15-day reporting obligations to FDA, EMA, and other health authorities.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Date' ;
    rdfs:comment 'Date of the most recent adverse event report submitted by this reporter. Used to identify active versus dormant reporters and to support follow-up prioritization.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Professional license or registration number of the HCP reporter (e.g., medical license, pharmacy registration). Used to verify reporter qualification and credibility. Stored as confidential business data.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Name of the institution, hospital, clinic, regulatory authority, or company from which the reporter submitted the adverse event report. Relevant for institutional reporters and regulatory authority submissions.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualification rdf:type rdf:Property ;
    rdfs:label 'Qualification' ;
    rdfs:comment 'Professional qualification of the reporter, particularly relevant for Healthcare Professional (HCP) reporters. Determines the clinical credibility weighting of the report and regulatory classification. ICH E2B(R3) field A.2.1.2. [ENUM-REF-CANDIDATE: physician|pharmacist|nurse|dentist|other_health_professional|consumer|unknown — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Code' ;
    rdfs:comment 'Identifier of the regulatory authority (e.g., FDA, EMA, MHRA, PMDA, NMPA) when the reporter is a regulatory body. Used to route mandatory ICSR submissions and track authority-initiated follow-up requests.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityScore rdf:type rdf:Property ;
    rdfs:label 'Reliability Score' ;
    rdfs:comment 'Internal PV team assessment of the reporter\'s historical reliability based on completeness and accuracy of prior submissions. Used to weight signal detection analysis and prioritize follow-up resources. Assigned by the PV case processor.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterStatus rdf:type rdf:Property ;
    rdfs:label 'Reporter Status' ;
    rdfs:comment 'Current operational status of the reporter record within the PV system. Inactive or blocked reporters are excluded from new case assignments. Supports duplicate detection and data quality management.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterType rdf:type rdf:Property ;
    rdfs:label 'Reporter Type' ;
    rdfs:comment 'Classification of the reporter by their relationship to the adverse event. Drives regulatory reporting obligations and follow-up workflows. ICH E2B(R3) field A.2.1.1. [ENUM-REF-CANDIDATE: healthcare_professional|patient_consumer|lawyer|regulatory_authority|literature|other — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialty rdf:type rdf:Property ;
    rdfs:label 'Specialty' ;
    rdfs:comment 'Medical or clinical specialty of the HCP reporter (e.g., Oncology, Cardiology, Neurology). Supports signal detection analysis by therapeutic area and enables targeted follow-up by medically qualified personnel.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReportsSubmitted rdf:type rdf:Property ;
    rdfs:label 'Total Reports Submitted' ;
    rdfs:comment 'Cumulative count of Individual Case Safety Reports (ICSRs) submitted by this reporter. Used for duplicate detection, reporter profiling, and reliability assessment. Updated upon each new case linkage.' ;
    rdfs:domain ind:Reporter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pvActionId rdf:type rdf:Property ;
    rdfs:label 'Pv Action Id' ;
    rdfs:comment 'Unique surrogate identifier for the pharmacovigilance action record. Primary key for this entity. Entity role: TRANSACTION_HEADER — represents a discrete regulatory/safety action with a defined lifecycle triggered by a validated signal, PSUR finding, RMP update, or health authority request.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionCountryId rdf:type rdf:Property ;
    rdfs:label 'Action Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: PV actions (DHPC distributions, label updates) are scoped to specific markets/countries. The market_scope field is a plain-text denormalization of country. A proper FK enables country-specific regulat' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:copayProgramId rdf:type rdf:Property ;
    rdfs:label 'Copay Program Id' ;
    rdfs:comment 'Foreign key linking to commercial.copay_program. Business justification: PV actions implementing REMS or restricted distribution requirements can mandate suspension or modification of copay programs for restricted drugs. Commercial operations teams need this link to execut' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CopayProgram .

ind:patientSupportProgramId rdf:type rdf:Property ;
    rdfs:label 'Patient Support Program Id' ;
    rdfs:comment 'Foreign key linking to commercial.patient_support_program. Business justification: PV actions can mandate updates to patient support programs — e.g., adding new safety monitoring requirements or updating patient information materials following a REMS change. PSP managers need this l' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatientSupportProgram .

ind:promoMaterialId rdf:type rdf:Property ;
    rdfs:label 'Promo Material Id' ;
    rdfs:comment 'Foreign key linking to commercial.promo_material. Business justification: PV actions of type \'promotional material withdrawal\' or \'labeling update\' directly reference specific promo materials requiring recall or revision. Regulatory affairs and medical affairs teams use thi' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoMaterial .

ind:pvAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pv Agreement Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.pv_agreement. Business justification: PV actions include partner notification actions (notified_authorities field, dhpc_distribution_scope) that are governed by PV agreements. When a safety action requires notifying a partner (licensee, c' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PvAgreement .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative description of the pharmacovigilance action, including the specific risk minimization measures to be implemented, rationale, and expected patient safety impact. Captured from Argus Safety case narrative or Veeva Vault RIM action record.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Externally-known business identifier for the PV action, formatted as PVA-{YYYY}-{NNNNNN}. Used in regulatory correspondence, authority notifications, and cross-system tracking within Argus Safety/Oracle AERS and Veeva Vault RIM.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle state of the pharmacovigilance action, tracking progression from initiation through completion or cancellation. Drives workflow routing in safety management systems.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the regulatory or safety action being taken. Includes labeling updates (CCDS/SmPC/USPI changes), Dear Healthcare Professional Communication (DHPC), restricted indication, market suspension/withdrawal, Risk Evaluation and Mitigation Strategy (REMS) modification, Risk Management Plan (RMP) update trigger, and Post-Authorization Safety Study (PASS) initiation. [ENUM-REF-CANDIDATE: labeling_update|dhpc|restricted_indication|market_suspension|market_withdrawal|rems_modification|rmp_update|pass_initiation — promote to reference product]' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Authority Notification Date' ;
    rdfs:comment 'Date on which the relevant health authority (FDA, EMA, MHRA, PMDA, NMPA, etc.) was formally notified of this pharmacovigilance action. Nullable when notification is not required or not yet submitted.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorityNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Authority Notification Required' ;
    rdfs:comment 'Indicates whether this pharmacovigilance action requires formal notification to one or more health authorities (FDA, EMA, MHRA, PMDA, etc.) prior to or upon implementation. Drives regulatory submission workflows.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dhpcDistributionScope rdf:type rdf:Property ;
    rdfs:label 'Dhpc Distribution Scope' ;
    rdfs:comment 'Geographic scope of the Dear Healthcare Professional Communication (DHPC) distribution when action_type is dhpc. Indicates whether the communication is national, regional, or global. Not applicable for non-DHPC actions.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Assessment Date' ;
    rdfs:comment 'Date on which the effectiveness assessment of this pharmacovigilance action was completed or is scheduled. Supports periodic benefit-risk evaluation and regulatory reporting cycles.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Assessment Outcome' ;
    rdfs:comment 'Outcome of the post-implementation effectiveness assessment, indicating whether the pharmacovigilance action successfully minimized the identified risk. Informs subsequent signal management and RMP update decisions.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Assessment Status' ;
    rdfs:comment 'Status of the post-implementation effectiveness assessment for this pharmacovigilance action. Tracks whether the action achieved its intended risk minimization objective, as required by EMA GVP Module XVI and FDA REMS assessment requirements.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date on which this pharmacovigilance action was escalated to senior management or the QPPV. Nullable when escalation_flag is false. Supports governance and oversight reporting.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this pharmacovigilance action has been escalated due to missed deadlines, critical safety findings, or authority pressure. Triggers executive and QPPV notification workflows.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationEvidenceRef rdf:type rdf:Property ;
    rdfs:label 'Implementation Evidence Ref' ;
    rdfs:comment 'Document reference number or Veeva Vault document ID for the evidence package demonstrating that the pharmacovigilance action has been implemented (e.g., updated label version, DHPC distribution confirmation, REMS modification approval letter).' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date on which the pharmacovigilance action was formally initiated or triggered. Represents the principal real-world business event timestamp (day-level precision) for regulatory timeline tracking and compliance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelingDocumentType rdf:type rdf:Property ;
    rdfs:label 'Labeling Document Type' ;
    rdfs:comment 'Type of labeling document affected when action_type is labeling_update. Identifies whether the Company Core Data Sheet (CCDS), Summary of Product Characteristics (SmPC), US Prescribing Information (USPI), Patient Information Leaflet (PIL), or package insert is being updated. Null or not_applicable for non-labeling actions.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingSectionAffected rdf:type rdf:Property ;
    rdfs:label 'Labeling Section Affected' ;
    rdfs:comment 'Specific section(s) of the labeling document being updated (e.g., Section 4.4 Special Warnings, Section 4.8 Undesirable Effects, Boxed Warning, Contraindications). Applicable only for labeling_update action type.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifiedAuthorities rdf:type rdf:Property ;
    rdfs:label 'Notified Authorities' ;
    rdfs:comment 'Comma-separated list of health authority codes (e.g., FDA, EMA, MHRA, PMDA, NMPA) that have been or must be notified of this action. Supports multi-jurisdictional regulatory tracking.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline Date' ;
    rdfs:comment 'Mandatory deadline imposed by a health authority (FDA, EMA, MHRA, PMDA, NMPA) for completion or notification of this pharmacovigilance action. Distinct from the internally-set target_completion_date. Non-compliance may result in regulatory sanctions.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringEventReference rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Reference' ;
    rdfs:comment 'Free-text or structured reference number identifying the specific triggering event (e.g., signal case number, PSUR submission number, authority correspondence reference). Provides cross-system traceability.' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventType rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Type' ;
    rdfs:comment 'Classification of the upstream event or finding that necessitated this PV action. Distinguishes between signal validation outcomes, PSUR/PBRER findings, RMP periodic reviews, health authority requests, SUSAR clusters, out-of-specification (OOS) trends, and literature review findings. [ENUM-REF-CANDIDATE: signal_validation|psur_finding|rmp_review|authority_request|susar_cluster|oos_trend|literature_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PvAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: The counterparty in a PV agreement is a registered business partner in the MDM system (licensee, co-marketing partner, CRO). Linking to business_partner enables counterparty data quality management, a' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:argusAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Argus Agreement Ref' ;
    rdfs:comment 'Reference identifier used in Argus Safety / Oracle AERS to link this pharmacovigilance agreement to the partner configuration for automated ICSR routing and exchange. Enables traceability between the agreement record and the operational safety system configuration.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance monitoring status of the pharmacovigilance agreement based on periodic reviews, audits, and KPI tracking. COMPLIANT = all obligations met; NON_COMPLIANT = one or more obligations breached; UNDER_REVIEW = compliance assessment in progress; PENDING_AUDIT = scheduled for compliance audit. Supports GVP Module I oversight requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyPvContactEmail rdf:type rdf:Property ;
    rdfs:label 'Counterparty Pv Contact Email' ;
    rdfs:comment 'Email address of the designated pharmacovigilance contact at the counterparty organisation. Used for operational safety data exchange communications and escalation notifications.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyPvContactName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Pv Contact Name' ;
    rdfs:comment 'Name of the designated pharmacovigilance contact person at the counterparty organisation responsible for safety data exchange under this agreement. Required for operational communication and escalation.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the counterparty by their operational role in the pharmaceutical value chain. CRO = Contract Research Organization; CMO = Contract Manufacturing Organization; CDMO = Contract Development and Manufacturing Organization; LICENSEE = product licensee; CO_PROMOTER = co-promotion partner; AFFILIATE = local affiliate entity; DISTRIBUTOR = distribution partner. Drives applicable GVP obligations. [ENUM-REF-CANDIDATE: CRO|CMO|CDMO|LICENSEE|CO_PROMOTER|AFFILIATE|DISTRIBUTOR — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExchangeFormat rdf:type rdf:Property ;
    rdfs:label 'Data Exchange Format' ;
    rdfs:comment 'Specifies the technical format used for exchanging Individual Case Safety Reports (ICSRs) between parties. E2B_R2 = ICH E2B(R2) XML format; E2B_R3 = ICH E2B(R3) FHIR-based format; PAPER = paper-based exchange; PROPRIETARY = system-specific format; NOT_SPECIFIED = format not yet defined. Drives technical integration requirements with Argus Safety/Oracle AERS.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExchangeMethod rdf:type rdf:Property ;
    rdfs:label 'Data Exchange Method' ;
    rdfs:comment 'Technical transmission method used for exchanging safety data between parties. EVWEB = EMA EudraVigilance Web Trader; GATEWAY = automated gateway-to-gateway; SFTP = secure file transfer; EMAIL = encrypted email; MANUAL = manual entry; API = direct API integration. Determines system configuration in Argus Safety.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icsrExchangeDays rdf:type rdf:Property ;
    rdfs:label 'Icsr Exchange Days' ;
    rdfs:comment 'Number of calendar days within which Individual Case Safety Reports (ICSRs) must be exchanged between the MAH and the counterparty following initial receipt. Typically 7 days for fatal/life-threatening SUSARs and 15 days for other serious cases per GVP Module VI. Drives compliance monitoring and SLA tracking.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isGdprDpaInPlace rdf:type rdf:Property ;
    rdfs:label 'Is Gdpr Dpa In Place' ;
    rdfs:comment 'Indicates whether a GDPR-compliant Data Processing Agreement (DPA) is in place with the counterparty covering the personal data exchanged as part of pharmacovigilance activities. Mandatory for EU-based safety data exchange under GDPR Article 28.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code of the governing language of the pharmacovigilance agreement document (e.g., EN for English, DE for German, FR for French). Relevant for legal interpretation and translation obligations.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date of the most recent periodic compliance review conducted for this pharmacovigilance agreement. Used to track review frequency and identify overdue reviews per GVP Module I requirements for oversight of outsourced PV activities.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'Date on which the next periodic compliance review of this pharmacovigilance agreement is scheduled. Drives workflow scheduling and resource planning for the PV compliance team.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:psurResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Psur Responsible Party' ;
    rdfs:comment 'Designates which party bears primary responsibility for authoring and submitting Periodic Safety Update Reports (PSURs) / Periodic Benefit-Risk Evaluation Reports (PBRERs) to regulatory authorities. MAH = Marketing Authorisation Holder; COUNTERPARTY = partner organisation; JOINT = shared responsibility; NOT_APPLICABLE = PSURs not in scope of this agreement.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qppvContactName rdf:type rdf:Property ;
    rdfs:label 'Qppv Contact Name' ;
    rdfs:comment 'Name of the Qualified Person Responsible for Pharmacovigilance (QPPV) designated by the MAH under this agreement. The QPPV is a mandatory regulatory role under EU GVP legislation responsible for the PV system. Captured for regulatory compliance and audit purposes.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Responsible Party' ;
    rdfs:comment 'Designates which party is responsible for submitting safety reports (ICSRs, SUSARs, PSURs, RMPs) to national competent authorities (FDA, EMA, MHRA, PMDA, etc.) for products in scope. Determines accountability in regulatory inspections and audits.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Days' ;
    rdfs:comment 'Number of calendar days before the agreement expiry date that a renewal notification must be issued to the counterparty. Drives automated alerting in the PV agreement management system to prevent lapses in safety data exchange coverage.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmpResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Rmp Responsible Party' ;
    rdfs:comment 'Designates which party is responsible for maintaining and updating the Risk Management Plan (RMP) for products covered under this agreement. Relevant for EU-authorised products where RMP is mandatory per GVP Module V.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalManagementResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Signal Management Responsible Party' ;
    rdfs:comment 'Designates which party is responsible for signal detection, assessment, and management activities for products covered under this agreement. MAH = Marketing Authorisation Holder; COUNTERPARTY = partner; JOINT = shared; NOT_APPLICABLE = signal management not in scope. Aligns with GVP Module IX obligations.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:susarExchangeDays rdf:type rdf:Property ;
    rdfs:label 'Susar Exchange Days' ;
    rdfs:comment 'Number of calendar days within which Suspected Unexpected Serious Adverse Reactions (SUSARs) must be exchanged between parties. Typically 7 days for fatal/life-threatening and 15 days for non-fatal/non-life-threatening SUSARs per GVP Module VI and ICH E2D. Separate from general ICSR exchange timelines.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Description of the geographic territories or regulatory jurisdictions covered by this agreement (e.g., specific countries, regions, or global). Determines which national competent authorities are in scope for regulatory reporting obligations under this agreement.' ;
    rdfs:domain ind:PvAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessBarrierSeverity rdf:type rdf:Property ;
    rdfs:label 'Access Barrier Severity' ;
    rdfs:comment 'Overall severity rating of the identified access barriers for this strategy: low (minor hurdles), medium (manageable barriers), high (significant barriers requiring targeted remediation), or critical (barriers that may prevent market access).' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessBarrierSummary rdf:type rdf:Property ;
    rdfs:label 'Access Barrier Summary' ;
    rdfs:comment 'Narrative summary of the primary identified access barriers for this product in the target geography and payer segment (e.g., lack of comparative clinical evidence, high ICER, step therapy requirements, prior authorization burden). Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessObjective rdf:type rdf:Property ;
    rdfs:label 'Access Objective' ;
    rdfs:comment 'Overarching strategic access objective statement for this product in the target geography and payer segment (e.g., \'Achieve preferred formulary tier 1 placement in 80% of commercial plans within 12 months of launch\'). Confidential strategic business information.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'Actual date on which the product was commercially launched in the specified geography and payer segment. Compared against planned_launch_date to measure launch execution performance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:copayAssistanceFlag rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Flag' ;
    rdfs:comment 'Indicates whether a copay assistance or copay card program is included in this access strategy to reduce patient out-of-pocket costs and improve commercial insurance access.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this market access strategy becomes operative and binding for downstream access activities including HTA submissions, payer contracting, and patient support programs.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which this market access strategy expires or is superseded. Nullable for open-ended strategies. Used to manage strategy lifecycle and trigger renewal workflows.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossToNetTargetPct rdf:type rdf:Property ;
    rdfs:label 'Gross To Net Target Pct' ;
    rdfs:comment 'Target gross-to-net revenue reduction percentage for this access strategy, representing the expected aggregate discount, rebate, and allowance burden relative to gross list price. Critical for P&L planning and net revenue forecasting. Confidential financial data.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heorStudyPlan rdf:type rdf:Property ;
    rdfs:label 'Heor Study Plan' ;
    rdfs:comment 'Summary of the Health Economics and Outcomes Research (HEOR) study plan, including cost-effectiveness models, budget impact analyses, and quality-of-life studies planned to support payer value dossiers and HTA submissions. Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaBodyCode rdf:type rdf:Property ;
    rdfs:label 'Hta Body Code' ;
    rdfs:comment 'Code identifying the primary HTA body responsible for evaluating this product in the target geography (e.g., NICE, G-BA, HAS, PBAC, CADTH, AIFA). [ENUM-REF-CANDIDATE: NICE|G-BA|HAS|PBAC|CADTH|AIFA|SMC|NCPE|TLV|ZIN — promote to reference product]' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaOutcome rdf:type rdf:Property ;
    rdfs:label 'Hta Outcome' ;
    rdfs:comment 'Outcome of the HTA review by the primary HTA body: pending (under review), positive (recommended), positive_with_restriction (recommended with clinical/population restrictions), negative (not recommended), withdrawn (submission withdrawn), or not_applicable.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaStrategy rdf:type rdf:Property ;
    rdfs:label 'Hta Strategy' ;
    rdfs:comment 'Description of the Health Technology Assessment (HTA) strategy including target HTA bodies (e.g., NICE, G-BA, HAS, PBAC), submission sequencing, evidence package approach, and comparator selection rationale. Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaSubmissionActualDate rdf:type rdf:Property ;
    rdfs:label 'Hta Submission Actual Date' ;
    rdfs:comment 'Actual date on which the HTA dossier was submitted to the primary HTA body. Compared against hta_submission_planned_date to track submission timeliness.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:htaSubmissionPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Hta Submission Planned Date' ;
    rdfs:comment 'Planned date for submission of the HTA dossier or value dossier to the primary HTA body. Used for launch sequencing and access readiness milestone tracking.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icerThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Icer Threshold Amount' ;
    rdfs:comment 'Payer or HTA body willingness-to-pay threshold per quality-adjusted life year (QALY) or other health outcome unit in the target geography. Used to assess pricing headroom and value-based pricing strategy. Confidential strategic financial data.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:icerThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Icer Threshold Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the ICER willingness-to-pay threshold applicable in the target geography (e.g., GBP for NICE, EUR for G-BA/HAS, USD for ICER US).' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPriceAmount rdf:type rdf:Property ;
    rdfs:label 'List Price Amount' ;
    rdfs:comment 'Gross list price (WAC — Wholesale Acquisition Cost in the US, or equivalent list price in other geographies) for the product in the target geography. Confidential commercial pricing data.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'List Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the gross list price of the product in the target geography (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientSupportProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Support Program Flag' ;
    rdfs:comment 'Indicates whether a patient support program (copay assistance, patient assistance program, hub services) is included as a component of this access strategy to improve patient access and adherence.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerSegment rdf:type rdf:Property ;
    rdfs:label 'Payer Segment' ;
    rdfs:comment 'Specific payer segment or channel targeted by this access strategy (e.g., Commercial, Medicare Part D, Medicaid, VA/DoD, Private Insurance, NHS, Statutory Health Insurance). [ENUM-REF-CANDIDATE: Commercial|Medicare Part D|Medicaid|VA/DoD|NHS|Statutory Health Insurance|Private Insurance|Integrated Delivery Network — promote to reference product]' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Planned Launch Date' ;
    rdfs:comment 'Target date for commercial product launch in the specified geography and payer segment, as defined in the launch sequencing plan. Drives milestone planning and access readiness timelines.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementPathway rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Pathway' ;
    rdfs:comment 'Regulatory and payer reimbursement pathway pursued for this product: standard (routine formulary review), accelerated (expedited review), managed_entry (conditional coverage), risk_sharing (payer-manufacturer risk agreement), outcomes_based (payment linked to clinical outcomes), named_patient, or compassionate_use. [ENUM-REF-CANDIDATE: standard|accelerated|managed_entry|risk_sharing|outcomes_based|named_patient|compassionate_use — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Description of planned remediation actions to address identified access barriers, including evidence generation plans, payer engagement activities, managed entry agreement negotiations, and patient support program design. Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweRwdPlan rdf:type rdf:Property ;
    rdfs:label 'Rwe Rwd Plan' ;
    rdfs:comment 'Description of the Real-World Evidence (RWE) and Real-World Data (RWD) generation plan supporting payer negotiations, HTA submissions, and outcomes-based contracting. Includes study designs, data sources, and timelines. Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyCode rdf:type rdf:Property ;
    rdfs:label 'Strategy Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the access strategy, used in cross-functional communications, HTA submissions, and payer contracting documents. Format: MAS-<ProductCode>-<Year>.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyName rdf:type rdf:Property ;
    rdfs:label 'Strategy Name' ;
    rdfs:comment 'Human-readable name of the market access strategy, typically including the product name, indication, and geography (e.g., \'Oncology Product X — US Formulary Access Strategy 2025\').' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyOwner rdf:type rdf:Property ;
    rdfs:label 'Strategy Owner' ;
    rdfs:comment 'Name or employee identifier of the Market Access lead or director accountable for developing and executing this access strategy.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyType rdf:type rdf:Property ;
    rdfs:label 'Strategy Type' ;
    rdfs:comment 'Classification of the access strategy by its business purpose: launch (initial market entry), lifecycle (ongoing management), indication_expansion (new indication), line_extension (new formulation/dosage), or biosimilar_defense (protecting market share against biosimilar entry).' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyVersion rdf:type rdf:Property ;
    rdfs:label 'Strategy Version' ;
    rdfs:comment 'Version number of the access strategy document following major.minor versioning convention (e.g., 1.0, 2.3). Supports document lifecycle management and audit trail requirements.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFormularyTier rdf:type rdf:Property ;
    rdfs:label 'Target Formulary Tier' ;
    rdfs:comment 'Desired formulary tier placement targeted by this access strategy for the specified payer segment. Tier 1 represents preferred/lowest cost-share; specialty and non_formulary represent restricted access positions.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueProposition rdf:type rdf:Property ;
    rdfs:label 'Value Proposition' ;
    rdfs:comment 'Narrative summary of the clinical, economic, and humanistic value proposition communicated to payers and HTA bodies to justify formulary placement and reimbursement. Confidential strategic content.' ;
    rdfs:domain ind:AccessStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerAccountId rdf:type rdf:Property ;
    rdfs:label 'Payer Account Id' ;
    rdfs:comment 'Unique surrogate identifier for the payer account record within the market access domain. Serves as the primary key and system-of-record identifier for all downstream joins and references.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayerAccount .

ind:businessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Payer accounts are registered as business partners in MDM (SAP BP) for master data governance, deduplication, and financial settlement. Linking enables contract-to-payment reconciliation, credit limit' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:parentPayerAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Payer Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent payer organization in a payer hierarchy (e.g., a regional health plan rolling up to a national parent). Enables hierarchical covered-lives aggregation and enterprise-level contracting.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayerAccount .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the payer account record. Drives eligibility for contracting, rebate processing, and formulary negotiations. Active accounts are eligible for all market access activities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsPayerCode rdf:type rdf:Property ;
    rdfs:label 'Cms Payer Code' ;
    rdfs:comment 'Official CMS-assigned payer identifier used in Medicare and Medicaid claims processing and enrollment data. Enables cross-referencing with CMS plan finder, Part D enrollment, and government reimbursement data.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Type of commercial arrangement governing the relationship with this payer. Determines the financial model for gross-to-net deductions and market access obligations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractingAuthority rdf:type rdf:Property ;
    rdfs:label 'Contracting Authority' ;
    rdfs:comment 'Indicates whether this payer account holds direct contracting authority (True) or operates under a parent/umbrella contract managed by another payer entity. Determines whether a direct rebate or pricing agreement can be executed.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copayAccumulatorPolicy rdf:type rdf:Property ;
    rdfs:label 'Copay Accumulator Policy' ;
    rdfs:comment 'Indicates whether this payer has implemented a copay accumulator adjustment program that prevents manufacturer copay assistance from counting toward patient deductibles and out-of-pocket maximums. Impacts gross-to-net and patient affordability.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copayAssistanceAccepted rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Accepted' ;
    rdfs:comment 'Indicates whether this payer accepts manufacturer copay assistance cards or patient support programs for its commercially insured members. Government payers (Medicare, Medicaid) are prohibited from accepting copay assistance under Anti-Kickback Statute.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coveredLives rdf:type rdf:Property ;
    rdfs:label 'Covered Lives' ;
    rdfs:comment 'Total number of beneficiaries or members covered under the payer\'s health plan(s). Key metric for assessing payer reach and prioritizing market access investment. Sourced from CMS enrollment data or payer-reported figures.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formularyDecisionCycle rdf:type rdf:Property ;
    rdfs:label 'Formulary Decision Cycle' ;
    rdfs:comment 'Frequency at which the payer\'s pharmacy and therapeutics (P&T) committee reviews and updates formulary coverage decisions. Critical for planning HTA submission and contracting timelines.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyInfluenceScore rdf:type rdf:Property ;
    rdfs:label 'Formulary Influence Score' ;
    rdfs:comment 'Proprietary numeric score (0–100) reflecting the payer\'s ability to drive formulary adoption and steer prescribing behavior across its covered lives. Used in payer prioritization and contracting strategy.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formularyTierPosition rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier Position' ;
    rdfs:comment 'Current formulary tier placement of the company\'s lead product(s) on this payer\'s formulary. Reflects the outcome of market access negotiations and directly impacts patient access and copay levels.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Scope' ;
    rdfs:comment 'Scope of the payer\'s geographic coverage indicating whether the plan operates nationally, regionally, at state/province level, locally, or across multiple countries. Informs market access strategy and contracting jurisdiction.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpoMembership rdf:type rdf:Property ;
    rdfs:label 'Gpo Membership' ;
    rdfs:comment 'Name of the Group Purchasing Organization (GPO) to which this payer or its affiliated health system belongs (e.g., Vizient, Premier, HealthTrust). Relevant for hospital and institutional formulary contracting.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaBody rdf:type rdf:Property ;
    rdfs:label 'Hta Body' ;
    rdfs:comment 'Name of the Health Technology Assessment (HTA) body associated with this payer\'s reimbursement decision-making process (e.g., NICE, HAS, G-BA, AIFA, SMC). Drives value dossier format and HEOR evidence requirements.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContractReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Contract Review Date' ;
    rdfs:comment 'Date of the most recent formal contract or rebate agreement review with this payer. Used to track contracting cycle compliance and trigger renewal workflows.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:naicCode rdf:type rdf:Property ;
    rdfs:label 'Naic Code' ;
    rdfs:comment 'Five-digit NAIC company code assigned to licensed insurance entities in the United States. Used for regulatory identification, state insurance filings, and cross-referencing with insurance regulatory databases.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerAccountCode rdf:type rdf:Property ;
    rdfs:label 'Payer Account Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned to the payer organization, used in contracting, SAP SD customer master, and Veeva CRM account records for cross-system reconciliation.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerName rdf:type rdf:Property ;
    rdfs:label 'Payer Name' ;
    rdfs:comment 'Full legal name of the payer organization as registered with regulatory or governmental authorities (e.g., \'UnitedHealthcare Insurance Company\', \'Centers for Medicare & Medicaid Services\'). Used as the primary identity label for the payer.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerSubtype rdf:type rdf:Property ;
    rdfs:label 'Payer Subtype' ;
    rdfs:comment 'Further granular classification within the payer type (e.g., Medicare Advantage, Medicaid Managed Care, Part D Plan Sponsor, NHS England, Statutory Health Insurer, PBM Formulary Manager). [ENUM-REF-CANDIDATE: medicare_advantage|medicaid_managed_care|part_d_sponsor|fee_for_service|nhs|statutory_health_insurer|pbm_formulary — promote to reference product]' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerType rdf:type rdf:Property ;
    rdfs:label 'Payer Type' ;
    rdfs:comment 'Classification of the payer organization by business model. Drives contracting strategy, rebate structure, and market access approach. [ENUM-REF-CANDIDATE: commercial_health_plan|government_payer|pbm|gpo|integrated_delivery_network|managed_care_organization — promote to reference product]' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pbmAffiliation rdf:type rdf:Property ;
    rdfs:label 'Pbm Affiliation' ;
    rdfs:comment 'Name of the Pharmacy Benefit Manager (PBM) affiliated with or contracted by this payer to manage drug benefit administration, formulary design, and rebate negotiations (e.g., Express Scripts, CVS Caremark, OptumRx).' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the payer organization (e.g., Director of Pharmacy, VP of Formulary Management). Used for relationship management and contracting communications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTherapeuticFocus rdf:type rdf:Property ;
    rdfs:label 'Primary Therapeutic Focus' ;
    rdfs:comment 'The primary therapeutic area(s) or disease categories that the payer\'s formulary and coverage policies emphasize (e.g., oncology, immunology, rare diseases, cardiovascular). Informs product-specific formulary positioning strategy.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Required' ;
    rdfs:comment 'Indicates whether this payer requires prior authorization (PA) for coverage of the company\'s products. PA requirements create patient access barriers and are tracked for market access strategy and REMS compliance.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptCommitteeMeetingMonth rdf:type rdf:Property ;
    rdfs:label 'Pt Committee Meeting Month' ;
    rdfs:comment 'Calendar month (1–12) in which the payer\'s Pharmacy and Therapeutics (P&T) committee typically convenes for formulary review. Used to time value dossier submissions and contracting negotiations.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rebateEligible rdf:type rdf:Property ;
    rdfs:label 'Rebate Eligible' ;
    rdfs:comment 'Indicates whether this payer account is eligible to participate in pharmaceutical rebate programs. Drives gross-to-net revenue calculations and rebate contract eligibility in SAP SD.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reimbursementAuthority rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Authority' ;
    rdfs:comment 'Name of the governmental or statutory body that holds formal authority over reimbursement listing decisions for this payer (e.g., CMS, NHS England, GKV-Spitzenverband, CNAM). Distinct from HTA body which assesses clinical value.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweDataSharingAgreement rdf:type rdf:Property ;
    rdfs:label 'Rwe Data Sharing Agreement' ;
    rdfs:comment 'Indicates whether a Real-World Evidence (RWE) or Real-World Data (RWD) data sharing agreement is in place with this payer. RWE partnerships support value-based contracting, outcomes-based agreements, and payer negotiations.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepTherapyRequired rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Required' ;
    rdfs:comment 'Indicates whether this payer mandates step therapy (fail-first) protocols before approving coverage of the company\'s products. Step therapy requirements are key barriers tracked in market access and patient support programs.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Strategic tier classification assigned by the market access team reflecting the payer\'s relative importance based on covered lives, formulary influence, and revenue impact. Tier 1 represents highest-priority national accounts.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueBasedContractEligible rdf:type rdf:Property ;
    rdfs:label 'Value Based Contract Eligible' ;
    rdfs:comment 'Indicates whether this payer has the infrastructure and willingness to enter into outcomes-based or value-based contracting arrangements. Drives HEOR evidence generation strategy and RWE data requirements.' ;
    rdfs:domain ind:PayerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formularyPositionId rdf:type rdf:Property ;
    rdfs:label 'Formulary Position Id' ;
    rdfs:comment 'Unique surrogate identifier for a formulary position record representing the placement status of a pharmaceutical product within a specific payer formulary at a point in time.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormularyPosition .

ind:formularyId rdf:type rdf:Property ;
    rdfs:label 'Formulary Id' ;
    rdfs:comment 'Foreign key linking to market.formulary. Business justification: Market formulary positions track where a drug is placed within a specific formulary. Currently market_formulary_position has payer_account_id but no direct link to the formulary master table. Adding f' ;
    rdfs:domain ind:Market ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulary .

ind:payerContractId rdf:type rdf:Property ;
    rdfs:label 'Payer Contract Id' ;
    rdfs:comment 'Reference to the payer or PBM contract under which this formulary position was negotiated. Links formulary placement to rebate obligations and gross-to-net revenue commitments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayerContract .

ind:accessRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Type' ;
    rdfs:comment 'The primary type of utilization management restriction applied to this formulary position. Enables systematic access gap analysis and identification of patient access barriers across payer segments. [ENUM-REF-CANDIDATE: none|prior_auth|step_therapy|quantity_limit|specialty_pharmacy|age_restriction|diagnosis_restriction|combination — promote to reference product]' ;
    rdfs:domain ind:FormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coinsuranceRate rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Rate' ;
    rdfs:comment 'The patient coinsurance rate (expressed as a decimal, e.g., 0.20 for 20%) applicable to this formulary tier position. Used when the plan applies percentage-based cost-sharing rather than a fixed copay.' ;
    rdfs:domain ind:FormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'The fixed patient copay amount in USD applicable to this formulary tier position. Used in gross-to-net revenue modeling and patient affordability analysis. Null if the plan uses coinsurance rather than a fixed copay.' ;
    rdfs:domain ind:FormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'The originating system or data feed from which this formulary position record was sourced. Supports data lineage tracking and reconciliation across Salesforce Health Cloud/Veeva CRM, PBM data feeds, and third-party market intelligence providers. [ENUM-REF-CANDIDATE: salesforce_crm|veeva_crm|payer_portal|pbm_feed|iqvia|symphony_health|manual_entry — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyPositionCode rdf:type rdf:Property ;
    rdfs:label 'Formulary Position Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this formulary position record, used in payer communications, contracting systems, and gross-to-net reconciliation workflows.' ;
    rdfs:domain ind:FormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Formulary Review Date' ;
    rdfs:comment 'The scheduled or actual date of the next payer formulary review cycle for this product. Used by market access teams to plan payer engagement, evidence submissions, and contracting activities.' ;
    rdfs:domain ind:FormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:livesCovered rdf:type rdf:Property ;
    rdfs:label 'Lives Covered' ;
    rdfs:comment 'The estimated number of covered lives (plan members) under the payer formulary associated with this position. Used to weight formulary access metrics and estimate revenue impact of tier placement changes.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketShareImpactPct rdf:type rdf:Property ;
    rdfs:label 'Market Share Impact Pct' ;
    rdfs:comment 'The estimated percentage of total addressable market share attributable to this formulary position, based on covered lives and payer segment weight. Used in market access scenario modeling and launch readiness assessments.' ;
    rdfs:domain ind:FormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'The benefit plan year (e.g., 2024) to which this formulary position applies. Payer formularies are typically updated annually and this field enables year-over-year access trend analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityLimitDays rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Days' ;
    rdfs:comment 'The number of days supply over which the quantity_limit_value applies. For example, a limit of 30 units per 30 days. Enables precise modeling of dispensing restrictions for patient access programs.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Flag' ;
    rdfs:comment 'Indicates whether the payer imposes a quantity limit on dispensing of this product under this formulary position. When True, the quantity_limit_value and quantity_limit_days fields define the specific restriction.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityLimitValue rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Value' ;
    rdfs:comment 'The maximum quantity (in dispensing units) of the product that the payer will cover within the quantity limit period defined by quantity_limit_days. Used for access gap and utilization management analysis.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'The contractually agreed rebate percentage (expressed as a decimal, e.g., 0.15 for 15%) payable to the payer or PBM for this formulary position. A key input to gross-to-net revenue calculations and P&L reporting.' ;
    rdfs:domain ind:FormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateTier rdf:type rdf:Property ;
    rdfs:label 'Rebate Tier' ;
    rdfs:comment 'The rebate tier designation associated with this formulary position as negotiated in the payer or PBM contract. Determines the rebate percentage or per-unit rebate amount owed to the payer in exchange for preferred formulary placement. [ENUM-REF-CANDIDATE: base|preferred|exclusive|performance|supplemental — promote to reference product]' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyDrugFlag rdf:type rdf:Property ;
    rdfs:label 'Specialty Drug Flag' ;
    rdfs:comment 'Indicates whether the payer classifies this product as a specialty drug under this formulary, which typically triggers specialty tier placement, specialty pharmacy channel requirements, and higher patient cost-sharing.' ;
    rdfs:domain ind:FormularyPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyPharmacyRequired rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Required' ;
    rdfs:comment 'Indicates whether the payer mandates dispensing through a designated specialty pharmacy network for this formulary position. Impacts patient access and distribution channel strategy.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepTherapyCriteria rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Criteria' ;
    rdfs:comment 'Narrative description of the step therapy requirements imposed by the payer, including which agents must be tried first and the duration or failure criteria required before this product is covered.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolReviewerMasterId rdf:type rdf:Property ;
    rdfs:label 'Kol Reviewer Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.master. Business justification: HTA submissions in pharma involve KOL/clinical expert reviewers who validate the clinical evidence package before submission. Tracking the KOL reviewer is standard in market access operations for subm' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:actualSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Submission Date' ;
    rdfs:comment 'Date on which the HTA dossier was formally submitted to the HTA body. This is the principal real-world business event timestamp for the submission transaction, used to calculate review timelines and clock-start for statutory deadlines.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Outcome of the formal appeal filed against the HTA body\'s initial decision. Populated only when appeal_filed is True. Drives revision of the decision_type and downstream contracting actions.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitRating rdf:type rdf:Property ;
    rdfs:label 'Benefit Rating' ;
    rdfs:comment 'The HTA body\'s formal rating of the added therapeutic benefit of the drug compared to the appropriate comparator. Terminology varies by body: G-BA uses \'major/considerable/minor/non-quantifiable/no added benefit\'; NICE uses \'highly clinically effective/clinically effective\'; HAS uses ASMR grades I-V. [ENUM-REF-CANDIDATE: major|considerable|minor|non_quantifiable|no_added_benefit|asmr_i|asmr_ii|asmr_iii|asmr_iv|asmr_v — promote to reference product]' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comparatorDescription rdf:type rdf:Property ;
    rdfs:label 'Comparator Description' ;
    rdfs:comment 'Description of the comparator treatment(s) used in the clinical evidence package submitted to the HTA body. HTA bodies require comparison against the current standard of care or the most appropriate comparator (e.g., best supportive care, existing first-line therapy). Critical for benefit assessment.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionType rdf:type rdf:Property ;
    rdfs:label 'Decision Type' ;
    rdfs:comment 'The formal recommendation type issued by the HTA body following review of the submission: positive (recommended for reimbursement), negative (not recommended), restricted (recommended for a subset of the indicated population), conditional (recommended subject to managed access or further evidence), deferred (decision postponed), or not recommended.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicModelType rdf:type rdf:Property ;
    rdfs:label 'Economic Model Type' ;
    rdfs:comment 'Type of health economic model included in the HTA submission dossier. Cost-utility analysis (CUA) using QALYs is standard for NICE; cost-effectiveness analysis (CEA) is used by other bodies. Determines the analytical framework for reimbursement recommendation.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidencePackageType rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Type' ;
    rdfs:comment 'Classification of the primary clinical evidence package submitted to the HTA body: randomised controlled trial (RCT), observational study, indirect treatment comparison (ITC), mixed treatment comparison (MTC), single-arm trial, or real-world evidence (RWE). Influences the HTA body\'s confidence in the benefit assessment.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgency rdf:type rdf:Property ;
    rdfs:label 'External Agency' ;
    rdfs:comment 'Name of any external agency, health economics consultancy, or contract research organisation (CRO) engaged to support dossier preparation, economic modelling, or submission management for this HTA engagement.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icerCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Icer Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the ICER value submitted (e.g., GBP for NICE, EUR for HAS/G-BA, CAD for CADTH, AUD for PBAC). Required to interpret the submitted ICER in the correct monetary context.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icerSubmitted rdf:type rdf:Property ;
    rdfs:label 'Icer Submitted' ;
    rdfs:comment 'The incremental cost-effectiveness ratio (ICER) as submitted by the company in the economic model, expressed in cost per quality-adjusted life year (QALY) gained or cost per life year gained. Confidential as it reflects internal pricing and modelling assumptions used in payer negotiations.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managedAccessScheme rdf:type rdf:Property ;
    rdfs:label 'Managed Access Scheme' ;
    rdfs:comment 'Indicates whether the HTA decision is conditional on a managed access scheme (MAS), such as NICE\'s Managed Access Agreements (MAA) or Cancer Drugs Fund (CDF) arrangements, requiring further real-world evidence collection during the access period.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientAccessProgram rdf:type rdf:Property ;
    rdfs:label 'Patient Access Program' ;
    rdfs:comment 'Indicates whether a patient access program (PAP) or copay assistance program has been established in conjunction with this HTA submission to support patient affordability and access pending or following the reimbursement decision.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Submission Date' ;
    rdfs:comment 'Target date on which the completed HTA dossier is planned to be formally submitted to the HTA body. Used for project planning, resource allocation, and commercial launch timeline alignment.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Price Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the recommended price range values (e.g., GBP, EUR, CAD, AUD). Required to interpret price bounds in the correct monetary context for each jurisdiction.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedPriceLower rdf:type rdf:Property ;
    rdfs:label 'Recommended Price Lower' ;
    rdfs:comment 'Lower bound of the price range recommended or implied by the HTA body\'s decision, expressed in the local currency. Used in payer contracting and gross-to-net revenue management. Confidential as it reflects sensitive pricing negotiation data.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedPriceUpper rdf:type rdf:Property ;
    rdfs:label 'Recommended Price Upper' ;
    rdfs:comment 'Upper bound of the price range recommended or implied by the HTA body\'s decision, expressed in the local currency. Used alongside the lower bound to define the acceptable price corridor for payer negotiations and contracting.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date on which the marketing authorisation (MA) was granted by the relevant regulatory authority (FDA, EMA, MHRA, etc.) for the indication covered by this HTA submission. HTA submissions typically follow regulatory approval; this date anchors the HTA timeline.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementConditions rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Conditions' ;
    rdfs:comment 'Free-text description of any conditions, restrictions, or requirements attached to the HTA body\'s reimbursement recommendation (e.g., restricted to second-line use, mandatory prior authorisation, patient registry requirement, managed access scheme). Drives contracting and access program design.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweRequired rdf:type rdf:Property ;
    rdfs:label 'Rwe Required' ;
    rdfs:comment 'Indicates whether the HTA body\'s decision requires the generation and submission of real-world evidence (RWE) or real-world data (RWD) as a condition of continued reimbursement or as part of a managed access arrangement.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionLead rdf:type rdf:Property ;
    rdfs:label 'Submission Lead' ;
    rdfs:comment 'Name or identifier of the internal market access lead or HTA manager responsible for coordinating and owning this submission. Used for accountability, escalation, and stakeholder communication.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDossierVersion rdf:type rdf:Property ;
    rdfs:label 'Value Dossier Version' ;
    rdfs:comment 'Version identifier of the global value dossier (GVD) used as the basis for this HTA submission. Tracks which version of the evidence synthesis and value story was submitted, enabling audit trail and version control across multiple country submissions.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willingnessToPayThreshold rdf:type rdf:Property ;
    rdfs:label 'Willingness To Pay Threshold' ;
    rdfs:comment 'The HTA body\'s published or applied willingness-to-pay threshold per QALY (or equivalent outcome unit) for the relevant jurisdiction at the time of submission. Used to assess whether the submitted ICER falls within the acceptable range for reimbursement recommendation.' ;
    rdfs:domain ind:HtaSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorMasterId rdf:type rdf:Property ;
    rdfs:label 'Author Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.master. Business justification: Value dossiers in pharma are authored or medically reviewed by KOL/HCP experts. Tracking the KOL author is standard in HEOR/medical affairs operations for publication attribution, compliance, and KOL ' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:budgetImpactModelRef rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Model Ref' ;
    rdfs:comment 'Reference identifier or document name for the budget impact model (BIM) associated with this dossier, enabling traceability to the underlying economic model file stored in Veeva Vault or equivalent document management system.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'Outcome of the HTA or payer review of this dossier. Positive indicates full reimbursement recommended; positive_with_restrictions indicates conditional coverage; negative indicates rejection.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierCode rdf:type rdf:Property ;
    rdfs:label 'Dossier Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the value dossier across market access systems and payer submissions. Follows the pattern GVD-<PRODUCT_CODE>-<YEAR>-v<VERSION>.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierOwner rdf:type rdf:Property ;
    rdfs:label 'Dossier Owner' ;
    rdfs:comment 'Name or identifier of the internal market access team member or function responsible for authoring, maintaining, and updating this value dossier.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierStatus rdf:type rdf:Property ;
    rdfs:label 'Dossier Status' ;
    rdfs:comment 'Current lifecycle state of the value dossier. Draft indicates work-in-progress; approved indicates internal sign-off; published indicates submission to payer or HTA body; superseded indicates replaced by a newer version.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierType rdf:type rdf:Property ;
    rdfs:label 'Dossier Type' ;
    rdfs:comment 'Classification of the dossier by its intended use and audience. Global dossiers serve as the master template; local adaptations are country-specific derivatives. [ENUM-REF-CANDIDATE: global|local_adaptation|payer_specific|hta_submission|reimbursement_dossier|formulary_submission — promote to reference product]' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this version of the value dossier is considered active and valid for use in payer negotiations, HTA submissions, or formulary discussions.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date after which this version of the value dossier is no longer considered current and should be superseded by a newer version. Nullable for currently active dossiers.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formularyTierTarget rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier Target' ;
    rdfs:comment 'Desired formulary tier placement being sought from the payer or pharmacy benefit manager (PBM) based on the evidence presented in the dossier.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heorEvidenceSummary rdf:type rdf:Property ;
    rdfs:label 'Heor Evidence Summary' ;
    rdfs:comment 'Summary of the Health Economics and Outcomes Research (HEOR) evidence included in the dossier, covering cost-effectiveness analyses, cost-utility analyses, budget impact models, and quality-of-life (QoL) data.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htaBodyName rdf:type rdf:Property ;
    rdfs:label 'Hta Body Name' ;
    rdfs:comment 'Name of the specific Health Technology Assessment (HTA) body or payer organization to which this dossier is submitted or targeted (e.g., NICE, G-BA, HAS, PBAC, ICER).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdCode rdf:type rdf:Property ;
    rdfs:label 'Icd Code' ;
    rdfs:comment 'ICD-10 or ICD-11 code corresponding to the target indication, used for standardized disease classification in HTA submissions and payer negotiations.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icurCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Icur Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the Incremental Cost-Utility Ratio (ICUR) is expressed (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icurValue rdf:type rdf:Property ;
    rdfs:label 'Icur Value' ;
    rdfs:comment 'Incremental Cost-Utility Ratio (ICUR) expressed as cost per Quality-Adjusted Life Year (QALY) gained, representing the primary health economic outcome submitted to HTA bodies. Classified as confidential due to commercial sensitivity in payer negotiations.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalReviewed rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewed' ;
    rdfs:comment 'Indicates whether the Legal and Compliance function has reviewed this dossier version for regulatory compliance, IP considerations, and promotional material standards.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineOfTherapy rdf:type rdf:Property ;
    rdfs:label 'Line Of Therapy' ;
    rdfs:comment 'Intended line of therapy for which the product is being positioned in the dossier (e.g., first-line, second-line). Directly impacts formulary tier placement and reimbursement scope.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalAffairsReviewed rdf:type rdf:Property ;
    rdfs:label 'Medical Affairs Reviewed' ;
    rdfs:comment 'Indicates whether the Medical Affairs function has completed a formal scientific review and sign-off of the clinical evidence sections of this dossier version.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Patient Population Size' ;
    rdfs:comment 'Estimated number of eligible patients in the target market who could benefit from the treatment, as used in the budget impact model and payer negotiations.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qalyGain rdf:type rdf:Property ;
    rdfs:label 'Qaly Gain' ;
    rdfs:comment 'Estimated Quality-Adjusted Life Year (QALY) gain attributed to the treatment versus the comparator, as reported in the health economic model submitted in the dossier.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementScope rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Scope' ;
    rdfs:comment 'Scope of reimbursement coverage achieved or sought for the product based on the dossier submission, indicating whether full, restricted, or conditional reimbursement applies.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rweIncluded rdf:type rdf:Property ;
    rdfs:label 'Rwe Included' ;
    rdfs:comment 'Indicates whether Real-World Evidence (RWE) or Real-World Data (RWD) is included as supporting evidence in this dossier version, in addition to randomized controlled trial data.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetPayerType rdf:type rdf:Property ;
    rdfs:label 'Target Payer Type' ;
    rdfs:comment 'Classification of the primary payer audience for whom the dossier is tailored. Determines the evidence framing and economic model emphasis. [ENUM-REF-CANDIDATE: national_hta|regional_hta|commercial_payer|pbm|gpo|government_formulary|hospital_formulary — promote to reference product]' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionDate rdf:type rdf:Property ;
    rdfs:label 'Version Date' ;
    rdfs:comment 'Calendar date on which the current version of the dossier was finalized and approved for use.' ;
    rdfs:domain ind:ValueDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Payer contracts generate receivables through administrative fees, upfront payments, and contract settlements. Finance must track AR by contract for reconciliation, payment collection, and revenue reco' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:adminFeePct rdf:type rdf:Property ;
    rdfs:label 'Admin Fee Pct' ;
    rdfs:comment 'Administrative fee percentage charged by the PBM or GPO for contract administration, data services, and formulary management, expressed as a percentage of net sales. Deducted in gross-to-net calculations.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether the contract automatically renews at the end of the effective period unless either party provides notice of termination within the specified notice period.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRebatePct rdf:type rdf:Property ;
    rdfs:label 'Base Rebate Pct' ;
    rdfs:comment 'The unconditional base rebate percentage of Wholesale Acquisition Cost (WAC) or Average Manufacturer Price (AMP) owed to the payer regardless of performance metrics. Core input to gross-to-net revenue accrual calculations.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookOfBusinessLives rdf:type rdf:Property ;
    rdfs:label 'Book Of Business Lives' ;
    rdfs:comment 'The number of covered lives (plan members) within the payer\'s book of business that are subject to this contract. Used for rebate volume estimation, market access analytics, and payer segmentation.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive business name of the payer contract (e.g., \'CVS Caremark National Formulary Rebate Agreement FY2025\'), used for identification in reporting and gross-to-net management.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier assigned to this payer contract, used for cross-referencing with the payer, PBM, or GPO and in SAP SD/FI rebate agreement records.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'Name or identifier of the internal Market Access or Managed Care team member responsible for managing and maintaining this payer contract relationship.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the payer contract. Governs whether rebate accruals are active, whether the contract is eligible for payment processing, and whether formulary positioning obligations are in effect. [ENUM-REF-CANDIDATE: draft|pending_execution|active|suspended|terminated|expired|under_renegotiation — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copayAssistanceAllowed rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Allowed' ;
    rdfs:comment 'Indicates whether the contract permits the manufacturer to offer copay assistance or patient support programs to members covered under this payer\'s plan. Some commercial contracts restrict copay card use.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingRequired rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Required' ;
    rdfs:comment 'Indicates whether the contract includes a data sharing provision requiring the payer or PBM to provide claims data, utilization data, or outcomes data to the manufacturer. Relevant for outcomes-based and value-based contracts.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingScope rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Scope' ;
    rdfs:comment 'Specifies the type of data the payer or PBM is contractually obligated to share with the manufacturer under the data sharing provision. Null if data_sharing_required is False.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Rebate Amount' ;
    rdfs:comment 'The estimated total rebate liability for a full contract year based on projected sales volume and contracted rebate rates. Used for gross-to-net accrual budgeting and financial planning. Not a calculated aggregate — represents the contractually agreed estimate.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityProvision rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Provision' ;
    rdfs:comment 'Indicates whether the contract grants the contracted product exclusive or preferred formulary positioning within its therapeutic class, excluding or restricting competitor products.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formularyTier rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier' ;
    rdfs:comment 'The formulary tier position secured for the contracted product under this payer agreement. Directly impacts patient access, copay levels, and rebate obligations. Central to PBM formulary management mechanics.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction (ISO 3166-1 alpha-2 or alpha-3 country/state code) whose laws govern the interpretation and enforcement of this contract (e.g., US-DE for Delaware, USA).' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalRebatePct rdf:type rdf:Property ;
    rdfs:label 'Incremental Rebate Pct' ;
    rdfs:comment 'Additional rebate percentage earned above the base rebate upon achievement of performance or formulary tier thresholds. Used in tiered and performance-based contract structures.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mostFavoredNationClause rdf:type rdf:Property ;
    rdfs:label 'Most Favored Nation Clause' ;
    rdfs:comment 'Indicates whether the contract contains a Most Favored Nation (MFN) clause requiring the manufacturer to offer this payer terms no less favorable than those offered to any other payer. Has significant pricing and compliance implications.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceMetricType rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Type' ;
    rdfs:comment 'The type of performance metric used to determine eligibility for incremental or performance-based rebates. Applicable for performance rebate, outcomes-based, and value-based contract types.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Performance Threshold Value' ;
    rdfs:comment 'The numeric threshold that must be achieved on the performance metric to trigger incremental rebate payments (e.g., minimum market share percentage, minimum formulary tier position, minimum adherence rate).' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceProtectionClause rdf:type rdf:Property ;
    rdfs:label 'Price Protection Clause' ;
    rdfs:comment 'Indicates whether the contract includes a price protection provision that triggers additional rebates if the manufacturer raises the list price (WAC) above a specified threshold, typically tied to CPI or a fixed percentage.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceProtectionThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Price Protection Threshold Pct' ;
    rdfs:comment 'The maximum allowable annual WAC price increase percentage before price protection rebates are triggered under the contract. Null if price_protection_clause is False.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Rebate Payment Frequency' ;
    rdfs:comment 'The agreed schedule for rebate payment remittance from the manufacturer to the payer or PBM. Drives rebate accrual timing and cash flow planning in SAP FI.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebatePaymentLagDays rdf:type rdf:Property ;
    rdfs:label 'Rebate Payment Lag Days' ;
    rdfs:comment 'The number of days after the close of a rebate period within which the rebate invoice must be paid. Used for cash flow forecasting and accrual true-up calculations.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'The number of days prior to the effective end date by which either party must provide written notice of intent not to renew the contract. Applicable when auto_renewal is True.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemContractCode rdf:type rdf:Property ;
    rdfs:label 'Source System Contract Code' ;
    rdfs:comment 'The native contract identifier from the originating system of record (e.g., SAP S/4HANA SD rebate agreement number, Salesforce Health Cloud contract record ID). Enables traceability back to the operational source system.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationManagementRestrictions rdf:type rdf:Property ;
    rdfs:label 'Utilization Management Restrictions' ;
    rdfs:comment 'Specifies the utilization management restrictions applied to the contracted product on the payer\'s formulary (e.g., prior authorization, step therapy, quantity limits). Impacts patient access and market share performance metrics.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateClaimId rdf:type rdf:Property ;
    rdfs:label 'Rebate Claim Id' ;
    rdfs:comment 'Unique system-generated identifier for the rebate claim record. Primary key for the rebate_claim data product in the market domain.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RebateClaim .

ind:financeAccountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Finance Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Market rebate claims should link to finance accounts receivable for rebate accrual and revenue recognition. This enables accurate gross-to-net calculations and financial reporting for pharmaceutical r' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:accrualPeriod rdf:type rdf:Property ;
    rdfs:label 'Accrual Period' ;
    rdfs:comment 'Financial reporting quarter (e.g., 2024-Q3) in which the rebate liability or receivable is accrued in the general ledger. Aligns rebate expense recognition with the period of sale per ASC 606 and gross-to-net accounting policies.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimDirection rdf:type rdf:Property ;
    rdfs:label 'Claim Direction' ;
    rdfs:comment 'Indicates whether the rebate claim represents an amount payable by the manufacturer to the payer (outbound rebate) or receivable from a payer/GPO (inbound credit). Drives gross-to-net accounting treatment.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period End Date' ;
    rdfs:comment 'Last day of the measurement period for which eligible units and rebate amounts are being claimed. Together with claim_period_start_date defines the rebate accrual window.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period Start Date' ;
    rdfs:comment 'First day of the measurement period (quarter or month) for which eligible units and rebate amounts are being claimed. Aligns with the contractual reporting period.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle state of the rebate claim. Tracks progression from initial draft through submission, payer review, approval or dispute, and final payment settlement. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|disputed|paid|voided — promote to reference product]' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP cost center to which the rebate expense is allocated for internal management reporting and P&L attribution by therapeutic area or brand.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any dispute raised against this rebate claim by the payer, PBM, or manufacturer. Tracks the dispute lifecycle from initiation through resolution for audit and accrual adjustment purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Monetary value of the portion of the rebate claim currently under dispute. May be less than or equal to net_rebate_amount. Used to calculate the undisputed payable amount and to set dispute reserves.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleUnits rdf:type rdf:Property ;
    rdfs:label 'Eligible Units' ;
    rdfs:comment 'Total number of units (prescriptions, unit doses, or pack equivalents) dispensed during the claim period that qualify for rebate under the contract terms. Basis for rebate amount calculation.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Rebate Amount' ;
    rdfs:comment 'Total calculated rebate amount before any adjustments, offsets, or administrative fees. Computed as eligible_units × wac_price × rebate_rate. Primary input to gross-to-net revenue deduction accounting.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketSharePct rdf:type rdf:Property ;
    rdfs:label 'Market Share Pct' ;
    rdfs:comment 'Product market share within the payer\'s covered lives during the claim period, expressed as a percentage. Used to validate performance tier achievement and to support market share rebate calculations.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicaidRebateFlag rdf:type rdf:Property ;
    rdfs:label 'Medicaid Rebate Flag' ;
    rdfs:comment 'Indicates whether this claim is subject to the CMS Medicaid Drug Rebate Program (MDRP) reporting and payment obligations. Drives separate regulatory reporting workflows and AMP/Best Price calculations.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Net Rebate Amount' ;
    rdfs:comment 'Final rebate amount after applying all adjustments and administrative fee deductions. Represents the actual liability or receivable recorded in the finance domain for rebate accrual and payment settlement.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Contractually stipulated date by which the rebate payment must be made or received. Used to calculate days-past-due for outstanding claims and to trigger payment reminders.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Bank or ERP payment reference number (e.g., SAP payment document number or wire transfer reference) associated with the settlement of this rebate claim. Used for cash application and bank reconciliation.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Period Adjustment Flag' ;
    rdfs:comment 'Indicates whether this rebate claim includes a true-up or correction for a prior reporting period. When true, the adjustment_amount field captures the prior period correction value for audit trail purposes.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebateRate rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate' ;
    rdfs:comment 'Contractually agreed rebate rate expressed as a percentage of WAC or net price applicable to this claim. May reflect a base rate, a performance tier rate, or a blended rate depending on claim type.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit in which eligible_units are expressed for this rebate claim (e.g., prescription, unit dose, pack). Must align with the unit of measure defined in the underlying managed care contract.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wacPrice rdf:type rdf:Property ;
    rdfs:label 'Wac Price' ;
    rdfs:comment 'Wholesale Acquisition Cost (WAC) per unit at the time of the claim period. Serves as the base price from which rebate percentages are calculated for gross-to-net revenue deduction accounting.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossToNetAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Gross To Net Adjustment Id' ;
    rdfs:comment 'Primary key for gross_to_net_adjustment' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualFlag rdf:type rdf:Property ;
    rdfs:label 'Accrual Flag' ;
    rdfs:comment 'Indicates whether this GTN adjustment record represents an accrual estimate (True) or an actual settled/invoiced amount (False). Distinguishes estimated deductions from confirmed payments for financial close accuracy.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentRatePct rdf:type rdf:Property ;
    rdfs:label 'Adjustment Rate Pct' ;
    rdfs:comment 'Contractual or regulatory rate (as a percentage of gross sales or WAC) used to calculate the adjustment amount. Derived from the applicable contract tier, Medicaid best price calculation, or statutory rebate formula.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this GTN adjustment record, used for reconciliation with payer remittances, SAP SD condition records, and financial close processes. Maps to the document number in SAP S/4HANA FI.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the gross-to-net adjustment record, tracking its workflow from initial creation through financial posting or reversal.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentSubtype rdf:type rdf:Property ;
    rdfs:label 'Adjustment Subtype' ;
    rdfs:comment 'Further classification within an adjustment type, enabling granular deduction analysis (e.g., within performance rebates: market share tier, volume threshold, outcomes-based). Supports detailed GTN waterfall reporting.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Category of gross-to-net deduction applied to gross sales. Classifies the revenue deduction by its contractual or regulatory basis. [ENUM-REF-CANDIDATE: base_rebate|performance_rebate|medicaid_best_price|340b|chargeback|copay_assistance|gpo_fee|distribution_fee|patient_assistance|managed_care_rebate|medicare_part_d|state_supplemental_rebate — promote to reference product]' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Commercial distribution channel through which the drug product was dispensed or sold, determining applicable GTN deduction rates and program eligibility (e.g., 340B, Medicaid, specialty pharmacy). [ENUM-REF-CANDIDATE: retail|specialty|mail_order|hospital|government|long_term_care|340b|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimDate rdf:type rdf:Property ;
    rdfs:label 'Claim Date' ;
    rdfs:comment 'Date on which the copay assistance claim was adjudicated at the pharmacy. Populated only for copay_assistance adjustment type. Used for copay program spend timing analysis.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:copayAssistancePaidAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Paid Amount' ;
    rdfs:comment 'Dollar amount of copay assistance paid by the manufacturer on behalf of the patient for a specific claim. Equals the adjustment_amount for copay_assistance type records. Drives copay program financial tracking.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA cost center to which this GTN adjustment is allocated for internal management reporting and P&L attribution by business unit or therapeutic area.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether this GTN adjustment record is currently under dispute with the payer, PBM, or government agency. Triggers dispute management workflow and prevents premature financial settlement.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter within the fiscal year in which this GTN adjustment is recognized. Enables quarterly GTN deduction trend analysis and earnings reporting.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year in which this GTN adjustment is recognized for financial reporting purposes. Supports annual GTN waterfall analysis and SOX-compliant revenue reconciliation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossCopayAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Copay Amount' ;
    rdfs:comment 'Total patient copay obligation before application of copay assistance for a specific claim. Populated only for copay_assistance adjustment type. Used to calculate patient affordability metrics.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicaidBestPriceFlag rdf:type rdf:Property ;
    rdfs:label 'Medicaid Best Price Flag' ;
    rdfs:comment 'Indicates whether this GTN adjustment was considered in the Medicaid Best Price calculation for the applicable reporting period. Critical for CMS Medicaid Drug Rebate Program compliance and AMP/Best Price reporting.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'Net revenue after application of this GTN adjustment (gross_sales_amount minus adjustment_amount). Represents the recognized revenue for ASC 606 reporting purposes.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientDeidentifiedCode rdf:type rdf:Property ;
    rdfs:label 'Patient Deidentified Code' ;
    rdfs:comment 'De-identified patient token for copay assistance claim records, enabling patient-level program utilization analysis while maintaining HIPAA compliance. Populated only for copay_assistance adjustment type. Never contains direct patient PII.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientRemainingLiability rdf:type rdf:Property ;
    rdfs:label 'Patient Remaining Liability' ;
    rdfs:comment 'Residual out-of-pocket cost borne by the patient after copay assistance is applied (gross_copay_amount minus copay_assistance_paid_amount). Measures patient affordability program effectiveness.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'Last day of the reporting or contract period to which this GTN adjustment applies. Defines the close of the accrual or settlement window.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'First day of the reporting or contract period to which this GTN adjustment applies. Used for period-based accrual accounting and rebate calculation windows.' ;
    rdfs:domain ind:GrossToNetAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Date on which this GTN adjustment was posted to the general ledger in SAP S/4HANA FI. Determines the accounting period for revenue recognition and financial reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'The date by which the manufacturer must file an appeal or request for reconsideration of a negative or restricted coverage decision, critical for market access operations and legal timelines.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageRestrictionDetail rdf:type rdf:Property ;
    rdfs:label 'Coverage Restriction Detail' ;
    rdfs:comment 'Free-text narrative providing additional detail on the coverage restriction, including specific specialty pharmacy networks, prescriber certification requirements, or REMS program elements.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Coverage Restriction Type' ;
    rdfs:comment 'Type of coverage restriction applied by the payer: specialty pharmacy requirement, restricted distribution program, age restriction, prescriber specialty restriction, site-of-care restriction, or Risk Evaluation and Mitigation Strategy (REMS) requirement. [ENUM-REF-CANDIDATE: specialty_pharmacy|restricted_distribution|age_restriction|prescriber_restriction|site_of_care|rems — promote to reference product]' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionCode rdf:type rdf:Property ;
    rdfs:label 'Decision Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this coverage decision by the payer or health authority, used for cross-system reconciliation and audit trails.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Narrative summary of the clinical, economic, or policy rationale provided by the payer or HTA body for the coverage determination, used for appeal preparation and value dossier updates.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innName rdf:type rdf:Property ;
    rdfs:label 'Inn Name' ;
    rdfs:comment 'WHO-assigned International Nonproprietary Name (INN) of the active pharmaceutical ingredient (API), providing a globally recognized non-proprietary identifier for the drug substance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managedEntryAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Managed Entry Agreement Flag' ;
    rdfs:comment 'Indicates whether this coverage decision is contingent on a managed entry agreement (MEA) or outcomes-based contract between the manufacturer and the payer, such as a performance-based rebate or risk-sharing arrangement.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorAuthorizationCriteria rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Criteria' ;
    rdfs:comment 'Narrative description of the clinical and administrative criteria that must be met to obtain prior authorization, including diagnosis requirements, prescriber qualifications, and supporting documentation.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitDescription rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Description' ;
    rdfs:comment 'Narrative description of the quantity limit imposed by the payer, including the maximum units, dosage, or days supply allowed per dispensing event or coverage period.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Sub-national region, state, or province to which this coverage decision applies, for decisions issued at a regional rather than national level (e.g., US state Medicaid programs, German Länder).' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review or renewal of this coverage decision by the payer or HTA body, used for proactive market access planning and evidence generation timelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rweRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rwe Required Flag' ;
    rdfs:comment 'Indicates whether the payer or HTA body has required the submission of real-world evidence (RWE) or real-world data (RWD) as a condition of this coverage decision or for future coverage renewal.' ;
    rdfs:domain ind:CoverageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hubBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Hub Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Hub service providers for patient support programs are registered as business partners in MDM for contract management, payment processing, and vendor qualification. hub_service_provider is a plain den' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:annualProgramBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Program Budget' ;
    rdfs:comment 'Total approved annual budget allocated to fund this patient access program, inclusive of benefit payouts and administrative costs. Used for financial planning, P&L management, and gross-to-net revenue forecasting.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitCapAmount rdf:type rdf:Property ;
    rdfs:label 'Benefit Cap Amount' ;
    rdfs:comment 'Maximum monetary benefit amount that a single patient may receive under this program per benefit period (e.g., annual cap of $25,000 for copay assistance). Used for gross-to-net revenue management and program budget forecasting.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitCapCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Benefit Cap Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the benefit cap amount (e.g., USD, EUR, GBP). Required for multi-country program management and financial reporting.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitPeriod rdf:type rdf:Property ;
    rdfs:label 'Benefit Period' ;
    rdfs:comment 'Time period over which the benefit cap applies and resets. Determines how program utilization is tracked and reported for gross-to-net revenue deductions.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitType rdf:type rdf:Property ;
    rdfs:label 'Benefit Type' ;
    rdfs:comment 'Nature of the financial or product benefit provided to the patient under this program. Includes copay reduction, free drug supply, premium support, deductible support, and out-of-pocket cap benefits.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date of the most recent compliance review of this patient access program, covering OIG, anti-kickback, GDPR, HIPAA, and local regulatory requirements. Required for audit readiness and SOX reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityCriteriaSummary rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria Summary' ;
    rdfs:comment 'Narrative summary of the patient eligibility criteria for program enrollment, including insurance status requirements, income thresholds, diagnosis requirements, and prior treatment conditions. Sourced from the program design document.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Primary channel through which patients or HCPs enroll in the program. Includes hub services, specialty pharmacy, HCP portal, patient portal, phone, and field reimbursement manager (FRM) channels. Drives operational routing and analytics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Entity or mechanism funding the patient access program. Manufacturer-funded programs have direct gross-to-net revenue impact; foundation-funded programs may have different OIG compliance implications.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeThresholdRequired rdf:type rdf:Property ;
    rdfs:label 'Income Threshold Required' ;
    rdfs:comment 'Indicates whether the program requires patients to meet a defined income or financial need threshold as part of eligibility screening. True for patient assistance programs (PAP); typically False for copay assistance programs.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceStatusRequirement rdf:type rdf:Property ;
    rdfs:label 'Insurance Status Requirement' ;
    rdfs:comment 'Specifies the insurance coverage status required for patient eligibility. Copay assistance programs typically require commercially insured patients; PAPs typically target uninsured or underinsured populations.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientPopulationDescription rdf:type rdf:Property ;
    rdfs:label 'Patient Population Description' ;
    rdfs:comment 'Narrative description of the target patient population for this program, including disease stage, line of therapy, age group, and any biomarker or diagnostic requirements. Informs HTA submissions and payer value dossiers.' ;
    rdfs:domain ind:Market ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programNotes rdf:type rdf:Property ;
    rdfs:label 'Program Notes' ;
    rdfs:comment 'Free-text field for additional operational notes, special conditions, or exceptions associated with this patient access program. Used by market access and hub operations teams for case-by-case documentation.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwner rdf:type rdf:Property ;
    rdfs:label 'Program Owner' ;
    rdfs:comment 'Name or identifier of the internal business owner (e.g., Market Access Director, Brand Team Lead) accountable for the design, governance, and performance of this patient access program.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the program by its access mechanism. Covers copay assistance, free drug programs, patient assistance programs (PAP), named patient programs, compassionate use, expanded access programs (EAP), managed access agreements, hub services, and specialty pharmacy support. [ENUM-REF-CANDIDATE: copay_assistance|free_drug|patient_assistance|named_patient|compassionate_use|expanded_access|managed_access|hub_services|specialty_pharmacy_support — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorizationRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authorization Ref' ;
    rdfs:comment 'Reference number or identifier for the regulatory authorization underpinning this program (e.g., FDA Expanded Access IND number, EMA compassionate use authorization, named patient program reference). Links to the regulatory submission record.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Program Flag' ;
    rdfs:comment 'Indicates whether this patient access program is associated with or operates under an FDA-mandated Risk Evaluation and Mitigation Strategy (REMS). REMS programs have additional compliance and reporting obligations.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyTerms rdf:type rdf:Property ;
    rdfs:label 'Supply Terms' ;
    rdfs:comment 'Description of the product supply terms under this program, including dispensing quantity, supply duration, dosage form, and whether supply is provided directly by the manufacturer or through a specialty pharmacy or CMO/CDMO partner.' ;
    rdfs:domain ind:PatientAccessProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precedingDecisionId rdf:type rdf:Property ;
    rdfs:label 'Preceding Decision Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately prior pricing decision that this record supersedes or amends. Enables full price history chain reconstruction for audit and IRP analysis.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingDecision .

ind:primaryPricingCountryId rdf:type rdf:Property ;
    rdfs:label 'Primary Pricing Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Pricing decisions require country-specific regulatory constraints, international reference pricing baskets, reimbursement frameworks, and market access tier classifications for compliant pricing strat' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or designation of the internal governance body or individual (e.g., Global Pricing Committee, Regional Pricing Board, CFO, VP Market Access) that formally approved this pricing decision.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceilingPrice rdf:type rdf:Property ;
    rdfs:label 'Ceiling Price' ;
    rdfs:comment 'Maximum approved price within the authorized price corridor above which the product must not be priced in this market. Prevents excessive pricing relative to IRP basket and regulatory constraints. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Distribution or sales channel to which this pricing decision applies, such as retail pharmacy, hospital formulary, government procurement, tender, specialty pharmacy, or direct-to-payer.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorBreachThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Corridor Breach Threshold Pct' ;
    rdfs:comment 'Percentage deviation from the target price that triggers an automated corridor breach alert for proactive price erosion monitoring. For example, a value of 5.00 means a 5% deviation from target_price triggers an alert.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorPrice rdf:type rdf:Property ;
    rdfs:label 'Floor Price' ;
    rdfs:comment 'Minimum approved price within the authorized price corridor below which the product must not be sold in this market. Used for IRP management and cross-country price erosion prevention. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governmentReferencePrice rdf:type rdf:Property ;
    rdfs:label 'Government Reference Price' ;
    rdfs:comment 'Officially approved or regulated price set by a government authority (e.g., NHS reference price, ASMR-based French price, German AMNOG price). Applicable in markets with statutory price regulation. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossToNetPct rdf:type rdf:Property ;
    rdfs:label 'Gross To Net Pct' ;
    rdfs:comment 'Estimated gross-to-net adjustment percentage representing the aggregate deduction from WAC list price to net realized price, inclusive of all rebates, chargebacks, and mandatory discounts. Used for revenue forecasting and P&L management.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irpBasketCountries rdf:type rdf:Property ;
    rdfs:label 'Irp Basket Countries' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes that constitute the IRP reference basket monitored for this pricing decision (e.g., \'DEU|FRA|GBR|ESP|ITA\'). Used to assess cross-country price erosion risk and inform launch sequencing.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irpConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Irp Constraint Flag' ;
    rdfs:comment 'Indicates whether this pricing decision is constrained by International Reference Pricing (IRP) rules in the target market. True = IRP constraint applies; False = no IRP constraint.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irpReferencePrice rdf:type rdf:Property ;
    rdfs:label 'Irp Reference Price' ;
    rdfs:comment 'The IRP-derived price constraint calculated from the basket countries at the time of this decision. Represents the maximum price permissible under IRP rules for this market. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:launchSequencePriority rdf:type rdf:Property ;
    rdfs:label 'Launch Sequence Priority' ;
    rdfs:comment 'Numeric priority rank assigned to this market in the global launch sequencing plan, where lower values indicate earlier launch. Used to optimize IRP risk by controlling the order of country launches.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listPriceWac rdf:type rdf:Property ;
    rdfs:label 'List Price Wac' ;
    rdfs:comment 'Approved Wholesale Acquisition Cost (WAC) or ex-factory list price per unit for the product in the specified market and channel. This is the gross list price before any rebates, discounts, or government adjustments. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Frequency at which the IRP basket and price corridor compliance are reviewed for this pricing decision. Drives scheduling of automated IRP monitoring workflows.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Approved net price after application of mandatory rebates, statutory discounts, and government-mandated deductions. Represents the effective realized price per unit. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packSizeDescription rdf:type rdf:Property ;
    rdfs:label 'Pack Size Description' ;
    rdfs:comment 'Human-readable description of the pack configuration to which this pricing decision applies (e.g., \'30 tablets x 10mg\', \'1 vial x 100mg/10mL\'). Ensures unambiguous identification of the priced SKU.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangePct rdf:type rdf:Property ;
    rdfs:label 'Price Change Pct' ;
    rdfs:comment 'Percentage change in list price (WAC) relative to the immediately preceding approved pricing decision for the same product, market, and channel. Positive values indicate a price increase; negative values indicate a price decrease.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerUnitType rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit Type' ;
    rdfs:comment 'Defines the unit basis on which all price values in this decision are expressed (e.g., per pack, per tablet, per vial, per mg of active pharmaceutical ingredient, per mL, per dose).' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingRationale rdf:type rdf:Property ;
    rdfs:label 'Pricing Rationale' ;
    rdfs:comment 'Narrative justification for the pricing decision, documenting the strategic, clinical, health-economic, and competitive factors considered. Supports regulatory transparency requirements and internal audit.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Ref' ;
    rdfs:comment 'Reference number of the regulatory submission (e.g., NDA, BLA, MAA, eCTD sequence) associated with this pricing decision. Links pricing to the regulatory approval that enables commercialization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPrice rdf:type rdf:Property ;
    rdfs:label 'Target Price' ;
    rdfs:comment 'Optimal or target price within the approved price corridor, representing the commercially preferred price point balancing access, revenue, and IRP risk. Expressed in currency_code.' ;
    rdfs:domain ind:PricingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piMasterId rdf:type rdf:Property ;
    rdfs:label 'Pi Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.master. Business justification: HEOR/RWE studies in pharma are led by principal investigator HCPs. Linking the study to the PI is standard in HEOR operations for publication attribution, compliance reporting, and KOL engagement trac' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:budgetImpactYear1 rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Year1' ;
    rdfs:comment 'Projected net budget impact to the payer in Year 1 of the budget impact model, expressed in the currency defined by icur_currency_code. Key output for payer affordability assessments.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetImpactYear3 rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Year3' ;
    rdfs:comment 'Projected net budget impact to the payer in Year 3 of the budget impact model, expressed in the currency defined by icur_currency_code. Represents the standard 3-year horizon used in US payer budget impact analyses.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataUseAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Data Use Agreement Ref' ;
    rdfs:comment 'Reference number or identifier for the Data Use Agreement (DUA) governing the use of the real-world dataset, ensuring compliance with data licensing and privacy obligations.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketShareAssumptionPct rdf:type rdf:Property ;
    rdfs:label 'Market Share Assumption Pct' ;
    rdfs:comment 'Assumed market share percentage for the drug product used as the base case input in the budget impact model, reflecting expected uptake within the eligible patient population.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier for the economic model or study protocol, tracking iterative updates submitted to payers or HTA bodies over the product lifecycle.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelVersionDate rdf:type rdf:Property ;
    rdfs:label 'Model Version Date' ;
    rdfs:comment 'Date on which the current model version was finalized and approved for use in payer submissions or HTA dossiers.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationReference rdf:type rdf:Property ;
    rdfs:label 'Publication Reference' ;
    rdfs:comment 'Citation or DOI reference for the peer-reviewed publication, congress abstract, or technical report associated with this HEOR study, enabling traceability from payer submissions to published evidence.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwdDataSourceType rdf:type rdf:Property ;
    rdfs:label 'Rwd Data Source Type' ;
    rdfs:comment 'Type of real-world data source used in the study (e.g., claims database, EHR, registry, patient-reported outcomes). Applicable for retrospective RWD studies and RWE generation. Null for purely modeled studies.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwdDataVendor rdf:type rdf:Property ;
    rdfs:label 'Rwd Data Vendor' ;
    rdfs:comment 'Name of the external data vendor or data provider supplying the real-world dataset (e.g., IQVIA, Optum, Truven, Flatiron Health). Relevant for data use agreement tracking and data provenance.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rwdDataVintage rdf:type rdf:Property ;
    rdfs:label 'Rwd Data Vintage' ;
    rdfs:comment 'Date range or vintage period of the real-world dataset used in the study (e.g., \'2018-2022\'), indicating the temporal coverage of the underlying data and its currency for payer submissions.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the HEOR study or evidence asset, used in payer submissions, HTA dossiers, and cross-functional references.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Study Completion Date' ;
    rdfs:comment 'Date on which the HEOR study or model was completed and results were finalized, marking the end of the primary evidence generation phase.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyOwner rdf:type rdf:Property ;
    rdfs:label 'Study Owner' ;
    rdfs:comment 'Name or employee identifier of the HEOR team member or function responsible for the study, accountable for quality, timelines, and payer submission readiness.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'Date on which the HEOR study or model development was formally initiated, used for project tracking and timeline management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyTitle rdf:type rdf:Property ;
    rdfs:label 'Study Title' ;
    rdfs:comment 'Full descriptive title of the HEOR study, model, or RWD/RWE dataset as it appears in publications, HTA submissions, or value dossiers.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPayerAudience rdf:type rdf:Property ;
    rdfs:label 'Target Payer Audience' ;
    rdfs:comment 'Primary payer segment or audience for whom the HEOR evidence asset is designed, guiding value messaging and submission strategy. [ENUM-REF-CANDIDATE: commercial_payer|medicare|medicaid|pbm|gpo|hta_body|integrated_delivery_network|self_insured_employer — promote to reference product]' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeHorizon rdf:type rdf:Property ;
    rdfs:label 'Time Horizon' ;
    rdfs:comment 'Duration over which the economic model projects costs and outcomes (e.g., \'5 years\', \'lifetime\', \'10 years\'). A key structural assumption in cost-effectiveness and budget impact models.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentCostInput rdf:type rdf:Property ;
    rdfs:label 'Treatment Cost Input' ;
    rdfs:comment 'Annual per-patient treatment cost used as the primary cost input in the economic model, expressed in the currency defined by icur_currency_code. Reflects WAC, net price, or negotiated price as specified in the model assumptions.' ;
    rdfs:domain ind:HeorStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerEngagementId rdf:type rdf:Property ;
    rdfs:label 'Payer Engagement Id' ;
    rdfs:comment 'Unique surrogate identifier for each payer engagement record in the market access domain. Primary key for this transactional entity.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayerEngagement .

ind:commitmentsMade rdf:type rdf:Property ;
    rdfs:label 'Commitments Made' ;
    rdfs:comment 'Description of any formal or informal commitments made by either party during the engagement (e.g., data provision, follow-up analysis, contract term adjustments). Confidential negotiation record.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discussionTopics rdf:type rdf:Property ;
    rdfs:label 'Discussion Topics' ;
    rdfs:comment 'Structured summary of the key topics discussed during the engagement, such as formulary positioning, rebate terms, outcomes-based contract parameters, HEOR evidence, or RWE data sharing.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementChannel rdf:type rdf:Property ;
    rdfs:label 'Engagement Channel' ;
    rdfs:comment 'Mode of interaction through which the engagement was conducted. Supports channel analytics and compliance documentation requirements.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCode rdf:type rdf:Property ;
    rdfs:label 'Engagement Code' ;
    rdfs:comment 'Externally referenceable business identifier for the engagement, formatted as PE-{YYYY}-{NNNNNN}. Used in correspondence, CRM records, and meeting minutes.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Date' ;
    rdfs:comment 'The actual calendar date on which the engagement took place (or is scheduled to take place). Principal real-world event date for this transaction.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementEndTime rdf:type rdf:Property ;
    rdfs:label 'Engagement End Time' ;
    rdfs:comment 'Precise date and time when the engagement session concluded. Used together with start time to compute meeting duration.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementLocation rdf:type rdf:Property ;
    rdfs:label 'Engagement Location' ;
    rdfs:comment 'Physical or virtual location of the engagement (e.g., payer headquarters city, conference venue name, or virtual platform name such as Teams or Zoom).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementOutcome rdf:type rdf:Property ;
    rdfs:label 'Engagement Outcome' ;
    rdfs:comment 'Overall qualitative outcome assessment of the engagement from the market access team\'s perspective. Used for pipeline scoring and account strategy adjustment.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStartTime rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Time' ;
    rdfs:comment 'Precise date and time when the engagement session began, in ISO 8601 format with timezone offset. Used for scheduling, duration calculation, and audit.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle state of the engagement record, tracking progression from planning through completion or cancellation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Classification of the engagement by its primary business purpose. Drives workflow, required documentation, and follow-up obligations. [ENUM-REF-CANDIDATE: formulary_committee_meeting|medical_policy_review|rebate_negotiation|outcomes_based_contract_discussion|advisory_board|account_planning_meeting|value_dossier_presentation|hta_discussion|copay_program_review — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActions rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions' ;
    rdfs:comment 'Documented list of action items arising from the engagement, including owner, description, and target completion date. Drives post-engagement workflow.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpCompleted rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed' ;
    rdfs:comment 'Indicates whether all follow-up actions arising from this engagement have been completed. True = all actions closed; False = open actions remain.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formularyTierDiscussed rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier Discussed' ;
    rdfs:comment 'The formulary tier position (e.g., Tier 1, Tier 2, Preferred Specialty) that was discussed or targeted during this engagement. Supports formulary access tracking.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heorEvidencePresentedFlag rdf:type rdf:Property ;
    rdfs:label 'Heor Evidence Presented Flag' ;
    rdfs:comment 'Indicates whether Health Economics and Outcomes Research (HEOR) evidence (e.g., cost-effectiveness models, budget impact analyses, QoL data) was formally presented during the engagement.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalAttendees rdf:type rdf:Property ;
    rdfs:label 'Internal Attendees' ;
    rdfs:comment 'Comma-separated list of company-side attendees including market access managers, medical science liaisons (MSL), HEOR leads, and account directors.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyMessagesDelivered rdf:type rdf:Property ;
    rdfs:label 'Key Messages Delivered' ;
    rdfs:comment 'Summary of the approved value messages and clinical/economic evidence presented to the payer during the engagement. Supports message tracking and compliance review.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingMinutesRef rdf:type rdf:Property ;
    rdfs:label 'Meeting Minutes Ref' ;
    rdfs:comment 'Reference identifier or URL to the formal meeting minutes document stored in the document management system (e.g., Veeva Vault). Supports audit trail and compliance documentation.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationStage rdf:type rdf:Property ;
    rdfs:label 'Negotiation Stage' ;
    rdfs:comment 'Current stage of the payer negotiation lifecycle associated with this engagement. Supports pipeline tracking and forecasting of gross-to-net revenue impact. [ENUM-REF-CANDIDATE: pre_engagement|initial_discussion|proposal_presented|counter_proposal|final_negotiation|agreement_reached|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextEngagementPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Next Engagement Planned Date' ;
    rdfs:comment 'Planned date for the next scheduled engagement with this payer account, as agreed or anticipated at the close of this engagement.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomesContractDiscussedFlag rdf:type rdf:Property ;
    rdfs:label 'Outcomes Contract Discussed Flag' ;
    rdfs:comment 'Indicates whether an outcomes-based or value-based contract arrangement was discussed during this engagement. Supports value-based contracting pipeline tracking.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerAttendees rdf:type rdf:Property ;
    rdfs:label 'Payer Attendees' ;
    rdfs:comment 'Comma-separated list of names and titles of payer-side attendees (e.g., P&T committee members, medical directors, pharmacy directors). Stored as free text; structured attendee data managed in CRM.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerPositionSummary rdf:type rdf:Property ;
    rdfs:label 'Payer Position Summary' ;
    rdfs:comment 'Narrative summary of the payer\'s stated position, concerns, or feedback expressed during the engagement. Confidential negotiation intelligence used for account strategy.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateDiscussedFlag rdf:type rdf:Property ;
    rdfs:label 'Rebate Discussed Flag' ;
    rdfs:comment 'Indicates whether rebate terms or rebate structures were a topic of discussion during this engagement. True = rebate discussed; False = not discussed.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rweDataDiscussedFlag rdf:type rdf:Property ;
    rdfs:label 'Rwe Data Discussed Flag' ;
    rdfs:comment 'Indicates whether Real-World Evidence (RWE) or Real-World Data (RWD) was presented or discussed as part of the payer engagement. Supports RWE utilization tracking.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemEngagementCode rdf:type rdf:Property ;
    rdfs:label 'Source System Engagement Code' ;
    rdfs:comment 'Original identifier of this engagement record in the upstream CRM or market access system (e.g., Salesforce Health Cloud activity ID or Veeva CRM call record ID). Supports data lineage and reconciliation.' ;
    rdfs:domain ind:PayerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByPolicyReimbursementPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Reimbursement Policy Id' ;
    rdfs:comment 'Reference to the newer reimbursement policy record that replaces this one when a policy is revised or superseded. Enables policy lineage tracking and coverage change audit trails.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReimbursementPolicy .

ind:appealDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision Date' ;
    rdfs:comment 'The date on which the payer or health authority issued a final decision on the appeal of this reimbursement policy. Null if no appeal has been filed or if the appeal is still pending.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Current status of any formal appeal filed against a negative or restrictive coverage decision under this policy. Tracks the appeal lifecycle for coverage decision audit trails and access gap remediation.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current coverage determination status of the pharmaceutical product under this policy. Indicates whether the product is reimbursed, excluded, conditionally covered, or under review by the payer or health authority.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthority rdf:type rdf:Property ;
    rdfs:label 'Decision Authority' ;
    rdfs:comment 'Name of the body, committee, or organization that issued the coverage decision (e.g., CMS, NICE, G-BA, HAS, AIFA, P&T Committee). Identifies the authoritative source of the reimbursement determination.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedPopulation rdf:type rdf:Property ;
    rdfs:label 'Excluded Population' ;
    rdfs:comment 'Description of patient subgroups or clinical scenarios explicitly excluded from coverage under this policy (e.g., \'pediatric patients under 18\', \'patients with prior EGFR mutation therapy\'). Critical for access gap analysis.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic level at which this reimbursement policy applies. Distinguishes national coverage determinations from regional, state/provincial, or plan-level policies for coverage landscape analysis.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientAccessProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Access Program Flag' ;
    rdfs:comment 'Indicates whether a patient access program (e.g., copay assistance, free drug program, hub services) is available to support patients subject to restrictions under this reimbursement policy.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name or title of the reimbursement policy as issued by the payer or health authority (e.g., \'Medicare Part D Coverage Policy for Oncology Agents\').' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned by the payer or health authority to uniquely identify this reimbursement policy. Used for cross-referencing with payer portals and regulatory submissions.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle state of the reimbursement policy record. Distinguishes active policies governing current reimbursement from superseded, expired, or draft policies.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the reimbursement policy by its scope and mechanism. Distinguishes national coverage determinations, regional policies, plan-level formulary decisions, prior authorization criteria, step therapy requirements, and quantity limit policies. [ENUM-REF-CANDIDATE: national_coverage|regional_coverage|plan_level_coverage|formulary_decision|individual_coverage_determination|prior_authorization|step_therapy|quantity_limit — promote to reference product]' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version identifier for this reimbursement policy, used to track revisions and amendments over time. Enables policy change monitoring and historical coverage decision audit trails.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementRate rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Rate' ;
    rdfs:comment 'The reimbursement rate or allowed amount established by this policy, expressed as a percentage of list price, a fixed fee schedule amount, or an ASP-based rate. Confidential commercial data used for gross-to-net revenue management.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementRateBasis rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Rate Basis' ;
    rdfs:comment 'The pricing methodology or benchmark used to calculate the reimbursement rate under this policy (e.g., ASP+6%, WAC-based, fee schedule, negotiated price). Critical for gross-to-net revenue management and payer contracting.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Source System Policy Code' ;
    rdfs:comment 'The native identifier for this reimbursement policy record in the originating operational system (e.g., Veeva Vault RIM, RIMS, or payer portal). Supports data lineage and reconciliation with source systems.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Unique surrogate identifier for each general ledger account balance record in the Silver layer. Serves as the primary key for this data product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to masterdata.chart_of_accounts. Business justification: GL accounts are defined within a chart of accounts — fundamental master data relationship for account maintenance, financial statement mapping, and SOX compliance reporting in pharma ERP systems.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to masterdata.profit_center. Business justification: GL accounts are assigned to profit centers for segment P&L reporting by therapeutic area in pharma. The plain profit_center column is a denormalized code; proper FK enables segment reporting and manag' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Account group code that controls the number range and field selection for the GL account (e.g., \'OPEX\', \'CAPX\', \'COGS\', \'RDEX\'). Used to segment accounts by business function such as R&D expense, COGS, or capital expenditure in pharmaceutical reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'SAP account type classification: A=Assets, D=Customers (Accounts Receivable), K=Vendors (Accounts Payable), M=Materials, S=General Ledger. Determines posting rules and balance sheet/income statement classification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetAccount rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account' ;
    rdfs:comment 'Indicates whether the GL account is a balance sheet account (True) or a profit and loss (P&L) income statement account (False). Balance sheet accounts carry forward balances; P&L accounts are reset at year-end. Critical for financial statement classification.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP business area code used for internal segment reporting across legal entities. Supports cross-company-code P&L and balance sheet reporting by business division (e.g., Pharmaceuticals, Consumer Health, Vaccines).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Identifier for the chart of accounts framework applied to this GL account (e.g., \'INT1\' for international, \'USGP\' for US GAAP). Supports multi-GAAP reporting across the pharmaceutical group.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'The GL account balance at the end of the fiscal period in transaction currency, calculated as opening balance plus debits minus credits (or vice versa depending on account type). Authoritative balance for trial balance, balance sheet, and income statement reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBalanceGc rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Gc' ;
    rdfs:comment 'The GL account closing balance translated into the group consolidation currency. Used for consolidated financial statements, group P&L reporting, and multi-entity consolidation eliminations.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBalanceLc rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Lc' ;
    rdfs:comment 'The GL account closing balance translated into the company code local currency. Used for statutory reporting and local GAAP compliance in each legal entity\'s jurisdiction.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity or organizational unit for which the ledger balance is recorded. Aligns with the legal entity structure of the pharmaceutical group for statutory and consolidated reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Company Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the local (company code) currency in which balances are reported for statutory purposes. Distinct from transaction currency to support currency translation and consolidation eliminations.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Total credit postings to the GL account during the fiscal period in transaction currency. Sourced from aggregated journal entry postings in SAP FI. Used in trial balance and double-entry bookkeeping validation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'Total debit postings to the GL account during the fiscal period in transaction currency. Sourced from aggregated journal entry postings in SAP FI. Used in trial balance and double-entry bookkeeping validation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period number (1–16, where periods 13–16 are special closing periods) within the fiscal year for which the balance is recorded. Supports period-end close, monthly P&L reporting, and SOX-compliant financial close tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsItem rdf:type rdf:Property ;
    rdfs:label 'Fs Item' ;
    rdfs:comment 'Financial statement item code mapping the GL account to a specific line in the balance sheet or income statement (e.g., P&L by therapeutic area, balance sheet line). Supports multi-GAAP consolidation and statutory reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area code classifying the GL account balance by business function (e.g., \'MFGC\' for manufacturing/COGS, \'RDEX\' for R&D expense, \'SELL\' for selling expense, \'GADM\' for general and administrative). Supports cost-of-goods-sold (COGS) and P&L by function reporting. [ENUM-REF-CANDIDATE: MFGC|RDEX|SELL|GADM|CLIN|REGL|PROC — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapStandard rdf:type rdf:Property ;
    rdfs:label 'Gaap Standard' ;
    rdfs:comment 'The accounting standard under which this ledger balance is reported (US_GAAP, IFRS, LOCAL_GAAP, or IFRS_AND_US_GAAP for dual-reporting ledgers). Supports multi-GAAP reporting requirements for the pharmaceutical group\'s global legal entities.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountName rdf:type rdf:Property ;
    rdfs:label 'Gl Account Name' ;
    rdfs:comment 'Short descriptive name of the GL account as defined in the chart of accounts (e.g., \'Research and Development Expense\', \'API Inventory\', \'Accrued Clinical Trial Costs\'). Used in financial reports and trial balance outputs.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:comment 'The chart-of-accounts account number uniquely identifying the GL account within the company code. Used as the primary business identifier for account lookup, trial balance, and financial statement mapping.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the group (consolidation) currency used in consolidated financial statements (e.g., USD for a US-headquartered pharmaceutical group). Supports group-level P&L and balance sheet consolidation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this GL account balance contains intercompany transactions (True) that require elimination during group consolidation. Supports consolidation eliminations for the pharmaceutical group\'s multi-entity structure.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPostedDate rdf:type rdf:Property ;
    rdfs:label 'Last Posted Date' ;
    rdfs:comment 'The most recent date on which a journal entry posting was made to this GL account within the fiscal period. Used for account activity monitoring, dormant account identification, and period-end close validation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The GL account balance at the start of the fiscal period in transaction currency. Represents the carried-forward closing balance from the prior period. Used in trial balance preparation and period-end close processes.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodCloseStatus rdf:type rdf:Property ;
    rdfs:label 'Period Close Status' ;
    rdfs:comment 'Current status of the financial period close process for this GL account balance: open (period active), in_progress (close activities underway), closed (period-end close completed), or locked (period locked against further postings). Supports SOX-compliant financial close tracking.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlock rdf:type rdf:Property ;
    rdfs:label 'Posting Block' ;
    rdfs:comment 'Indicates whether postings to this GL account are currently blocked (True) at the company code level. A blocked account prevents new journal entries, used during period-end close or account restructuring.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rdCapitalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Rd Capitalization Flag' ;
    rdfs:comment 'Indicates whether the GL account balance is subject to R&D capitalization rules under IFRS IAS 38 (True) or expensed as incurred under US GAAP ASC 730 (False). Critical for pharmaceutical companies managing the boundary between R&D expense and intangible asset capitalization.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconAccountType rdf:type rdf:Property ;
    rdfs:label 'Recon Account Type' ;
    rdfs:comment 'Indicates if this GL account is a reconciliation account and its type: D=Accounts Receivable (Customers), K=Accounts Payable (Vendors), A=Assets, or empty for non-reconciliation accounts. Reconciliation accounts aggregate subledger balances into the GL.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Segment identifier for IFRS 8 / ASC 280 segment reporting (e.g., \'Oncology\', \'Immunology\', \'Rare Disease\', \'Consumer Health\'). Enables disaggregated P&L and asset reporting by operating segment for external financial disclosures.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRelevant rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant' ;
    rdfs:comment 'Indicates whether this GL account is in scope for SOX Section 302/404 internal controls over financial reporting (ICFR). SOX-relevant accounts require documented controls, testing, and sign-off during the annual audit cycle.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'SAP tax code associated with the GL account for VAT/GST and withholding tax determination. Relevant for pharmaceutical entities operating across multiple tax jurisdictions. Supports indirect tax reporting and compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartner rdf:type rdf:Property ;
    rdfs:label 'Trading Partner' ;
    rdfs:comment 'Company code of the intercompany trading partner for balances involving intercompany transactions. Used to identify and eliminate intercompany balances during group consolidation. Populated only when intercompany_flag is True.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: Journal entries generated by AP postings should reference the source AP document. This is a nullable FK since not all journal entries are AP-related. Strengthens accounts_payable connections to journa' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Journal entries related to fixed asset transactions (acquisition, depreciation, disposal, impairment) should reference the specific asset. This is a nullable FK since not all journal entries are asset' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'Monetary amount of the journal entry translated into the corporate group reporting currency (typically USD or EUR) for consolidated P&L reporting by therapeutic area, brand, and geography.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'Monetary amount of the journal entry translated into the company code\'s local (functional) currency using the applicable exchange rate. Used for statutory financial reporting and local tax compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'Gross monetary amount of the journal entry in the original transaction currency. For debit entries this is positive; for credit entries this is negative (SAP sign convention). Core monetary fact for the posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'SAP assignment field (ZUONR) used for sorting and matching open items in accounts payable, accounts receivable, and bank reconciliation. Typically populated with invoice number, payment reference, or contract number for automated clearing.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'SAP indicator specifying whether the line item is a debit (S=Soll/Debit) or credit (H=Haben/Credit) posting. Fundamental double-entry bookkeeping attribute required for GL balance validation and trial balance generation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the original source document (invoice date, payment date, contract date) that triggered the journal entry. May differ from posting_date; used for aging analysis and vendor/customer terms calculation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'SAP-assigned unique accounting document number within the company code and fiscal year. Serves as the externally-known business identifier for the journal entry, used in audit trails and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'SAP document type code classifying the nature of the journal entry (e.g., SA=General Ledger, KR=Vendor Invoice, DR=Customer Invoice, AA=Asset Posting, ZP=Payment Clearing, ML=Material Ledger). Drives posting rules and account determination. [ENUM-REF-CANDIDATE: SA|KR|DR|AA|ZP|ML|AB|KZ|DZ|WA|WE|RE — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'SAP GL account number to which the journal entry line is posted. Determines the financial statement line item (P&L or balance sheet). Supports COGS by product, R&D capitalization, and therapeutic area P&L analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text description at the journal entry header level explaining the business purpose of the posting (e.g., \'Q3 R&D accrual – Oncology Phase III\', \'API procurement – CMO settlement\'). Supports audit review and financial close documentation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Indicates whether this journal entry is itself a reversal of a prior posting (True) or an original entry (False). Used to filter reversals from net financial reporting and to identify accrual reversal patterns in period-end close.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'The date and time when the journal entry was last modified or reversed. Supports change audit trail requirements under SOX Section 404 and 21 CFR Part 11 for electronic records integrity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line item number within the journal entry document (e.g., 001, 002). Uniquely identifies each debit/credit line within the document for reconciliation, audit, and subledger matching.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-text description at the individual line item level providing context for the specific debit or credit posting (e.g., \'API batch #XYZ123 – COGS\', \'Phase III trial accrual – CRO milestone\'). Supports granular audit review.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency. Used for statutory reporting in the country of the legal entity.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current workflow state of the journal entry in the general ledger lifecycle. \'posted\' = fully committed to GL; \'parked\' = saved but not posted; \'held\' = incomplete draft; \'reversed\' = offset entry created; \'cleared\' = matched against open items; \'blocked\' = pending approval.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number from the source document (e.g., vendor invoice number, purchase order number, contract reference, or regulatory submission reference). Enables cross-system reconciliation and audit traceability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Document number of the reversing journal entry if this posting has been reversed. Populated only for reversed entries; null otherwise. Supports audit trail completeness and period-end close validation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerType rdf:type rdf:Property ;
    rdfs:label 'Subledger Type' ;
    rdfs:comment 'Identifies the subledger from which the journal entry originates: AP (Accounts Payable), AR (Accounts Receivable), asset accounting, tax accounting, material ledger, or none (direct GL posting). Enables subledger-to-GL reconciliation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The calculated tax amount (VAT, GST, sales tax) in local currency for the journal entry line. Supports indirect tax return filing, tax provision calculations, and multi-jurisdiction tax compliance reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Base Amount' ;
    rdfs:comment 'The taxable base amount in local currency on which the tax is calculated. Required for indirect tax return preparation and multi-jurisdiction VAT/GST compliance reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction (country, state, county, city) applicable to the transaction for multi-jurisdiction indirect tax reporting. Required for US sales tax (Vertex/Avalara integration) and international VAT compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Return Period' ;
    rdfs:comment 'The reporting period (YYYY-MM) to which this tax posting belongs for indirect tax return filing purposes. May differ from the accounting fiscal period; used for VAT/GST return preparation across multiple tax jurisdictions.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the original transaction (e.g., USD, EUR, JPY, GBP). The currency in which the business transaction was originally denominated, before conversion to local or group currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatClassification rdf:type rdf:Property ;
    rdfs:label 'Vat Classification' ;
    rdfs:comment 'Classification of the tax posting type for indirect tax reporting: input VAT (recoverable on purchases), output VAT (collected on sales), deferred VAT (timing difference), exempt, zero-rated, or not applicable. Supports multi-jurisdiction VAT compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryInternalResponsibleCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Internal Responsible Cost Center Id' ;
    rdfs:comment 'Reference to the cost center organizationally responsible for managing and monitoring this internal order. Corresponds to KOSTV in SAP AUFK. Used for P&L reporting by therapeutic area and organizational unit.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Cumulative actual costs posted to this internal order to date in the controlling area currency. Sourced from SAP CO actual cost line items (COEP table). Used for budget vs. actual reporting, R&D spend tracking, and CAPEX lifecycle governance.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFinishDate rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Date' ;
    rdfs:comment 'Actual date on which the internal order activity was completed (technically completed or closed). Used for variance analysis between planned and actual project duration and for R&D capitalization period determination.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total approved budget allocated to this internal order in the controlling area currency. Represents the authorized spending limit for the R&D program, capital project, or overhead activity. Used for budget vs. actual variance analysis and availability control.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetProfile rdf:type rdf:Property ;
    rdfs:label 'Budget Profile' ;
    rdfs:comment 'SAP CO budget profile code assigned to this internal order, defining the budgeting rules, availability control tolerance levels, and fiscal year distribution method. Corresponds to PROFL in SAP AUFK.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligible' ;
    rdfs:comment 'Indicates whether costs accumulated on this internal order are eligible for capitalization as an intangible asset under IAS 38 or ASC 350. Typically set to True for Phase 3 clinical development orders meeting the six IAS 38 criteria. Drives R&D capitalization tracking and CAPEX lifecycle governance.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'Total open commitment value (purchase orders, contracts, and reservations) posted against this internal order but not yet invoiced. Represents future obligated spend. Sourced from SAP CO commitment management (COOI table). Critical for total exposure reporting.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP CO controlling area code that defines the organizational unit within which cost accounting is performed. Determines the currency and fiscal year variant applicable to this internal order. Corresponds to KOKRS in SAP AUFK.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether this internal order has been flagged for deletion in SAP CO. Deletion-flagged orders are excluded from active reporting but retained for audit trail purposes. Corresponds to LOEKZ in SAP AUFK.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant code defining the fiscal year and period structure applicable to this internal order (e.g., K4 for calendar year, V3 for April–March). Determines period-end processing and budget distribution. Corresponds to PERIV in SAP AUFK.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentMeasureType rdf:type rdf:Property ;
    rdfs:label 'Investment Measure Type' ;
    rdfs:comment 'Classifies the internal order as a capital expenditure (CAPEX), operating expense (OPEX), R&D expense (RD_EXPENSE), or capitalizable R&D (RD_CAPITAL) measure. Drives balance sheet vs. P&L treatment and supports CAPEX lifecycle governance and ROI analysis.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Extended narrative description of the internal order providing full business context, scope, and objectives. Supports R&D capitalization documentation and audit trail requirements under SOX and 21 CFR Part 11.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCategory rdf:type rdf:Property ;
    rdfs:label 'Order Category' ;
    rdfs:comment 'SAP internal order category code distinguishing overhead orders (01), investment orders (04), accrual orders (02), and statistical orders (10/20). Drives settlement and budget management behavior in SAP CO.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderName rdf:type rdf:Property ;
    rdfs:label 'Order Name' ;
    rdfs:comment 'Human-readable short description of the internal order, typically identifying the R&D program, clinical trial phase, capital project, or overhead activity being tracked. Corresponds to KTEXT in SAP AUFK.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'SAP-assigned alphanumeric identifier for the internal order, used as the externally-known business key across finance, R&D, and project management systems. Corresponds to the AUFNR field in SAP CO table AUFK.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current system status of the internal order in SAP CO. CRTD=Created, REL=Released (costs can be posted), TECO=Technically Completed (no further postings), CLSD=Closed (settled and locked), DLT=Deletion Flagged, LKD=Locked. Governs cost posting eligibility and settlement processing.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'SAP order type code classifying the purpose of the internal order (e.g., R&D expense, capital expenditure, overhead, clinical trial cost collection, manufacturing overhead). Corresponds to AUART in SAP AUFK. [ENUM-REF-CANDIDATE: RD01|CAPEX|OVHD|CLIN|MFG|MKTG — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadKey rdf:type rdf:Property ;
    rdfs:label 'Overhead Key' ;
    rdfs:comment 'SAP CO overhead key assigned to this internal order, determining the overhead surcharge rates applied during overhead calculation (costing sheet). Used for allocating indirect manufacturing or R&D overhead costs to the order. Corresponds to ZUONR in SAP AUFK.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCostAmount rdf:type rdf:Property ;
    rdfs:label 'Plan Cost Amount' ;
    rdfs:comment 'Total planned cost amount for this internal order in the controlling area currency, as entered in SAP CO planning. Supports budget vs. plan vs. actual three-way variance analysis for R&D program financial governance.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFinishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Date' ;
    rdfs:comment 'Planned completion date for the activity or project represented by this internal order. Used for R&D program milestone tracking, CAPEX project scheduling, and budget period governance. Corresponds to PLSEZ in SAP AUFK.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programPhase rdf:type rdf:Property ;
    rdfs:label 'Program Phase' ;
    rdfs:comment 'Drug development lifecycle phase associated with this internal order. Drives R&D capitalization eligibility (costs may be capitalized from Phase 3 under IAS 38 criteria), ROI analysis, and budget governance. Aligns with ICH M4 eCTD structure.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the internal order was released in SAP CO (status changed to REL), enabling cost postings to begin. Marks the start of the active cost collection period. Corresponds to IDAT2 in SAP AUFK.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementReceiverType rdf:type rdf:Property ;
    rdfs:label 'Settlement Receiver Type' ;
    rdfs:comment 'Category of the primary settlement receiver for this internal order. CTR=Cost Center, AUC=Asset Under Construction, WBS=WBS Element, PSG=Profitability Segment, GL=G/L Account, ORD=Internal Order. Determines the accounting treatment of settled costs.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRuleType rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule Type' ;
    rdfs:comment 'Defines how costs accumulated on this internal order are settled to receivers (cost centers, G/L accounts, assets, WBS elements, profitability segments). FUL=Full settlement, PER=Periodic settlement, MAN=Manual settlement. Governs period-end cost allocation and R&D capitalization postings.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Statistical Order Flag' ;
    rdfs:comment 'Indicates whether this internal order is a statistical order (costs posted in parallel for reporting purposes only, without affecting the primary cost object). Statistical orders are used for management reporting overlays such as therapeutic area P&L without impacting actual cost flows.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'The identifier of the vendor bank account used for payment execution, referencing the SAP FI-AP bank details record. Sensitive financial data subject to PCI and SOX controls.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:warehouseReceiptId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Receipt Id' ;
    rdfs:comment 'Foreign key linking to supply.warehouse_receipt. Business justification: Three-way match (PO/GR/Invoice) is mandatory in pharma procure-to-pay. AP invoices are verified against goods receipts for quantity/quality confirmation before payment approval. Regulatory and SOX con' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseReceipt .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The SAP FI clearing document number (AUGBL) that offsets the open payable item upon payment or credit memo application. Used for open item management and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'The cash discount amount captured if payment is made within the discount period defined in the payment terms (e.g., 2% discount for payment within 10 days). Supports working capital optimization analytics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The last date by which payment must be made to qualify for the early payment discount defined in the payment terms. Used by treasury for dynamic discounting and supply chain finance decisions.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The SAP MM goods receipt document number (MBLNR) confirming receipt of goods or services against the purchase order. Required for three-way match (PO-GR-Invoice) in GMP-compliant pharmaceutical procurement.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total gross amount of the vendor invoice before deduction of discounts, withholding tax, or other adjustments, as stated on the invoice document. Represents the full obligation amount.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date printed on the vendor invoice document (BLDAT in SAP), representing the principal business event date for the payable obligation. Used for aging analysis and payment term calculation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the goods or services invoiced, as provided by the vendor or entered during invoice processing in SAP FI-AP. Supports spend categorization and audit review.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the vendor invoice by business nature. Milestone and royalty types are specific to pharmaceutical licensing and CRO/CMO contracts. [ENUM-REF-CANDIDATE: standard|credit_memo|debit_memo|milestone|royalty|advance|recurring — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this payable is an intercompany transaction between legal entities within the pharmaceutical group, requiring elimination in consolidated financial statements per IFRS 10.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRdCapitalized rdf:type rdf:Property ;
    rdfs:label 'Is Rd Capitalized' ;
    rdfs:comment 'Indicates whether the expenditure represented by this payable has been capitalized as an intangible asset under IAS 38 (development phase costs meeting capitalization criteria), as opposed to expensed immediately as R&D.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net amount payable to the vendor after deducting withholding tax and applicable discounts from the gross invoice amount. Represents the actual cash outflow obligation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'SAP payment block key (ZLSPR) indicating whether the invoice is blocked from automatic payment processing. Common values: R=Manual review required, B=Blocked by purchasing, A=Blocked for audit, V=Verified/released, blank=Not blocked.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'The SAP FI document number of the outgoing payment transaction that cleared this invoice (AUGBL). Populated upon payment execution; null for open/blocked invoices.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The SAP payment terms key (ZTERM) defining the agreed payment schedule, discount conditions, and due date calculation rules (e.g., NT30 = Net 30 days, 2/10NT30 = 2% discount if paid within 10 days).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'The internal SAP FI document number (BELNR) assigned upon posting of the vendor invoice in the general ledger. Serves as the primary system-of-record identifier within SAP.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Category' ;
    rdfs:comment 'Pharmaceutical industry classification of the vendor type. Enables spend analytics by vendor category (e.g., CRO spend for clinical operations, CMO/CDMO spend for outsourced manufacturing, licensor for royalty and milestone obligations). [ENUM-REF-CANDIDATE: CRO|CMO|CDMO|raw_material_supplier|licensor|service_provider|logistics|other — promote to reference product]' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: AR in pharma tracks revenue by SKU for gross-to-net calculations, chargeback processing, and revenue recognition by product. product_ndc is a denormalized text field on AR; replacing with sku_id FK en' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:arStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Status' ;
    rdfs:comment 'Current lifecycle status of the receivable. \'open\' = outstanding balance; \'partially_cleared\' = partial payment received; \'cleared\' = fully paid or offset; \'disputed\' = customer dispute raised; \'written_off\' = bad debt write-off applied; \'in_dunning\' = active dunning process initiated. [ENUM-REF-CANDIDATE: open|partially_cleared|cleared|disputed|written_off|in_dunning — promote to reference product]' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'Date on which the customer invoice was issued (billing document date). Used as the principal business event date for revenue recognition under ASC 606 / IFRS 15. Corresponds to SAP BLDAT.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Amount' ;
    rdfs:comment 'Total chargeback deductions claimed by wholesalers or distributors against this invoice, representing the difference between the contract price and the wholesale acquisition cost (WAC). Critical for pharmaceutical gross-to-net revenue calculations.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date on which this AR item was fully cleared (settled) in SAP FI-AR. Corresponds to SAP AUGDT. Null for open or partially cleared items. Used for DSO and cash flow reporting.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Business segment classification of the customer for this receivable. Supports P&L analysis by channel and revenue recognition reporting under ASC 606 / IFRS 15. [ENUM-REF-CANDIDATE: wholesaler|distributor|hospital_network|government_payer|retail_pharmacy|specialty_pharmacy — promote to reference product]' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days this AR item is past its due date as of the last refresh date. Calculated as (refresh_date - due_date) for open items. Used for aging bucket classification and credit risk assessment.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date on which the most recent dunning notice was issued to the customer for this overdue AR item. Corresponds to SAP MAHND. Used to track collections activity and avoid duplicate dunning.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning escalation level (0–4) assigned to this AR item by the SAP dunning program. Level 0 = no dunning; higher levels indicate increasing overdue severity. Drives collections escalation for wholesalers and distributors.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Net invoice amount translated into the company code local currency (e.g., USD for US entity) using the SAP exchange rate at posting date. Required for consolidated P&L reporting and SOX compliance.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the company code local currency used for translation of the AR document amount (e.g., USD for US legal entity).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Remaining unpaid balance on this AR document at the time of last update. Equals gross_amount minus all clearing payments and credit memos applied. Used for aging reports and collections management.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Payment Receipt Date' ;
    rdfs:comment 'Date on which the incoming customer payment was received and applied against this AR document. Null if no payment has been received. Used for Days Sales Outstanding (DSO) calculation.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'Accounting period (01–12 for regular months, 13–16 for special closing periods) within the fiscal year in which this AR document was posted. Aligns with SAP FI period control.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Contractual rebate amount accrued or applied against this AR document for government payers (Medicaid, Medicare) or commercial payer contracts. Part of gross-to-net revenue deductions under ASC 606.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'Date on which revenue was or is scheduled to be recognized in the income statement per ASC 606 / IFRS 15 performance obligation criteria. May differ from billing date for deferred or accrued revenue entries.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionType rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Type' ;
    rdfs:comment 'Classification of the revenue treatment for this AR record under ASC 606 / IFRS 15: \'recognized\' = revenue fully recognized at point of sale; \'deferred\' = revenue deferred pending performance obligation fulfillment; \'accrued\' = period-end accrual entry; \'reversed\' = accrual reversal.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date on which a period-end revenue accrual entry is scheduled to be automatically reversed in SAP FI. Applicable only to accrual-type AR documents. Null for standard invoices and payments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesTerritory rdf:type rdf:Property ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Geographic or organizational sales territory associated with this receivable. Used for P&L reporting by geography and market access analysis. Sourced from SAP SD sales area configuration.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual expenditure posted against this budget line item to date, sourced from SAP FI actuals. Used to compute budget variance (planned minus actual) for management reporting and SOX compliance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level functional category of the budget line item within the pharmaceutical value chain. Enables cross-functional spend analysis and allocation reporting. [ENUM-REF-CANDIDATE: clinical_trials|manufacturing|commercial|medical_affairs|regulatory|rd_discovery|general_admin|supply_chain — promote to reference product]' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Human-readable descriptive name for the budget plan (e.g., \'FY2025 Oncology R&D Operating Budget\', \'Phase III Clinical Trial Budget - Program X\'). Used in reporting and stakeholder communications.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the budget plan, used in financial reporting, approval workflows, and cross-system references. Follows the enterprise budget numbering convention (e.g., BUD-2025-ONCOL001).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle state of the budget record within the approval workflow. Transitions from draft through submission, review, and approval to locked (frozen for actuals comparison) or closed (period end). [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|locked|closed — promote to reference product]' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget by expenditure category: opex (operating expenditure), capex (capital expenditure), rd (research and development), headcount, contingency, or other. Drives P&L treatment and financial reporting. [ENUM-REF-CANDIDATE: opex|capex|rd|headcount|contingency|other — promote to reference product]' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationStage rdf:type rdf:Property ;
    rdfs:label 'Capitalization Stage' ;
    rdfs:comment 'Indicates the R&D stage for capitalization accounting purposes: research (expensed under IFRS IAS 38), development (potentially capitalizable once technical feasibility is established), or not_applicable. Drives correct accounting treatment for pharmaceutical R&D spend.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount encumbered by open purchase orders, contracts, or obligations not yet invoiced. Represents funds committed but not yet expensed. Supports available budget calculation (planned minus actual minus committed).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costElementCode rdf:type rdf:Property ;
    rdfs:label 'Cost Element Code' ;
    rdfs:comment 'SAP CO cost element code that categorizes the nature of the expenditure (e.g., personnel costs, material costs, external services, depreciation). Provides granular cost classification for management accounting and COGS analysis.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The last date of the period covered by this budget plan. For annual budgets, typically the last day of the fiscal year. Nullable for open-ended multi-year plans.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographyCode rdf:type rdf:Property ;
    rdfs:label 'Geography Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country or region code indicating the geographic scope of this budget (e.g., USA, GBR, DEU, JPN). Supports P&L planning by geography and market access financial analysis.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCapitalized rdf:type rdf:Property ;
    rdfs:label 'Is Capitalized' ;
    rdfs:comment 'Indicates whether this budget line relates to R&D expenditure that is subject to capitalization under IFRS IAS 38 or US GAAP ASC 730 (True = capitalized; False = expensed). Critical for R&D capitalization accounting in pharmaceutical development programs.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or employee identifier of the business owner accountable for managing and reporting against this budget. Typically the cost center manager or program lead responsible for spend governance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'The total planned budget amount for this line item in the transaction currency. Represents the approved or forecasted spend for the associated cost center, GL account, and period. Core field for variance analysis against actuals.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Indicates the time horizon covered by this budget plan: annual (single fiscal year), multi_year (2–5 year strategic plan), quarterly (quarterly rolling forecast), or rolling_12m (12-month rolling forecast). Supports both short-term operational and long-term R&D investment planning.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Internal code identifying the R&D drug development program or commercial brand to which this budget is allocated (e.g., a compound code, IND number reference, or brand identifier). Supports R&D investment planning and program-level ROI tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The difference between planned amount and actual amount (planned minus actual) for this budget line. A positive value indicates underspend; negative indicates overspend. Stored as a pre-computed field from SAP CO variance reports to support management reporting without recalculation.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'The budget variance expressed as a percentage of the planned amount ((planned minus actual) / planned × 100). Sourced from SAP CO variance reporting. Supports threshold-based exception reporting and management dashboards.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation charged against the asset from the capitalization date to the current reporting period. Expressed as a negative value in SAP FI-AA. Used to calculate net book value and supports IAS 16 / ASC 360 balance sheet disclosures.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original historical cost of the fixed asset at the time of acquisition, including purchase price, import duties, installation costs, and directly attributable costs to bring the asset to its intended use. Expressed in the company code currency. Corresponds to SAP FI-AA \'Acquisition and Production Costs (APC)\'.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date on which the fixed asset was acquired or placed in service. Used as the start date for depreciation calculations and CAPEX reporting. Corresponds to the \'Asset Value Date\' in SAP FI-AA for the initial acquisition posting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'SAP FI-AA asset class code that categorizes the asset for depreciation, accounting, and reporting purposes (e.g., manufacturing equipment, laboratory instruments, IT infrastructure, leasehold improvements, vehicles, furniture). Drives default depreciation key and useful life.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassName rdf:type rdf:Property ;
    rdfs:label 'Asset Class Name' ;
    rdfs:comment 'Descriptive name of the SAP FI-AA asset class (e.g., \'Manufacturing Equipment\', \'Laboratory Instruments\', \'IT Infrastructure\', \'Leasehold Improvements\', \'Right-of-Use Assets\'). Supports reporting and analytics without requiring a join to a reference table.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Human-readable description of the fixed asset as recorded in the SAP FI-AA asset master (e.g., \'HPLC Analytical Instrument - QC Lab Building 4\', \'Bioreactor 2000L - API Manufacturing\'). Used for identification and reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique asset number assigned in SAP FI-AA (Asset Master record number). Used as the primary business identifier for the asset across finance, operations, and audit processes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset within the enterprise asset register. Drives inclusion in depreciation runs, CAPEX reporting, and balance sheet presentation. \'under_construction\' maps to Assets Under Construction (AuC) in SAP FI-AA.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubnumber rdf:type rdf:Property ;
    rdfs:label 'Asset Subnumber' ;
    rdfs:comment 'SAP FI-AA sub-number used to track components or additions to a main asset (e.g., a capital improvement to a piece of manufacturing equipment). Enables component-level tracking under a parent asset number.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical asset tag or barcode number affixed to the asset for inventory tracking and physical verification purposes. Used during annual physical asset counts and GMP equipment identification audits.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP FI business area code used to segment the asset for internal financial reporting by therapeutic area, product line, or business division (e.g., Oncology, Immunology, Rare Diseases, Consumer Health). Supports P&L reporting by therapeutic area.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexProjectNumber rdf:type rdf:Property ;
    rdfs:label 'Capex Project Number' ;
    rdfs:comment 'Capital expenditure (CAPEX) project or appropriation request number under which the asset was approved and funded. Links the asset to the approved capital budget and supports CAPEX tracking and variance reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date on which the asset was formally capitalized and transferred from Assets Under Construction (AuC) to a productive asset class in SAP FI-AA. Marks the start of the depreciation period. May differ from acquisition_date for self-constructed assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the asset was retired, disposed of, or deactivated in the SAP FI-AA asset register. Marks the end of the asset\'s productive life and triggers the retirement posting to remove the asset from the balance sheet.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area Code' ;
    rdfs:comment 'SAP FI-AA depreciation area identifier that specifies the valuation basis for the asset (e.g., \'01\' for book depreciation per local GAAP, \'15\' for IFRS, \'20\' for tax depreciation, \'30\' for cost accounting). Supports parallel accounting under IAS 16 and US GAAP ASC 360.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'SAP FI-AA depreciation key that defines the depreciation method and calculation rules for the asset (e.g., LINR for straight-line, DGRV for declining balance, MANU for manual). Determines how periodic depreciation amounts are computed.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Insurance policy number under which the fixed asset is covered. Required for insurance valuation, claims processing, and risk management reporting. Particularly relevant for high-value manufacturing equipment and laboratory instruments.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuredValue rdf:type rdf:Property ;
    rdfs:label 'Insured Value' ;
    rdfs:comment 'Replacement or insured value of the fixed asset as declared to the insurer. May differ from net book value and is used for insurance premium calculation and claims settlement. Stored in SAP FI-AA insurance data fields.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGmpCritical rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Critical' ;
    rdfs:comment 'Indicates whether the asset is classified as GMP-critical equipment subject to qualification (IQ/OQ/PQ), periodic requalification, and regulatory inspection under 21 CFR Part 211, EU GMP, or PIC/S guidelines. True = GMP-critical; False = non-GMP.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRdEquipment rdf:type rdf:Property ;
    rdfs:label 'Is Rd Equipment' ;
    rdfs:comment 'Indicates whether the asset is classified as R&D equipment for the purpose of R&D capitalization analysis, tax credit eligibility, and ASC 730 / IAS 38 accounting treatment. True = R&D equipment; False = non-R&D.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPhysicalVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Verification Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or asset verification exercise confirming the asset\'s existence and location. Required for SOX compliance and GMP equipment audit readiness. Corresponds to SAP FI-AA \'Last Inventory Date\'.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Specific physical location code within the plant or facility where the asset is installed or stored (e.g., building, room, floor, warehouse location). Used for physical asset verification, GMP equipment mapping, and insurance purposes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer\'s model or part number for the fixed asset. Used for equipment qualification, spare parts identification, and procurement of replacement units in GMP-regulated manufacturing and laboratory environments.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying amount of the fixed asset, calculated as acquisition cost less accumulated depreciation and any accumulated impairment losses. Represents the asset\'s value on the balance sheet as of the last depreciation posting period. Corresponds to SAP FI-AA \'Book Value\'.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'Remaining useful economic life of the asset in years as of the last review date. Calculated as useful_life_years minus elapsed depreciation periods. Used for impairment testing and residual value assessments under IAS 36 and ASC 360.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'Estimated amount the enterprise would currently obtain from disposal of the asset at the end of its useful life, after deducting estimated disposal costs. Used in the depreciable amount calculation. Corresponds to SAP FI-AA \'Scrap Value\'.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer\'s serial number of the fixed asset. Critical for GMP equipment qualification (IQ/OQ/PQ), maintenance tracking, warranty management, and regulatory inspection readiness. Stored in SAP FI-AA \'Serial Number\' field.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful economic life of the asset in years, as defined in the SAP FI-AA asset master. Used to calculate the annual depreciation charge under straight-line method. Must be reviewed periodically per IAS 16.51 and ASC 360-10-35-21.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governingLawCountryId rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Royalty agreements specify governing law jurisdiction for dispute resolution and withholding tax rate determination. The plain governing_law_country is denormalized; FK enables country-level tax treat' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:licensedCompoundId rdf:type rdf:Property ;
    rdfs:label 'Licensed Compound Id' ;
    rdfs:comment 'Reference to the specific compound, drug substance (DS), or active pharmaceutical ingredient (API) that is the subject of the royalty agreement. Links to the compound master record in the discovery domain for IP cost tracking of in-licensed compounds.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compound .

ind:licensorBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Licensor Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Licensor is a business_partner (bp_role=\'Licensor\'). Essential for royalty payment processing, withholding tax calculation, audit rights enforcement, and vendor master data integration. Role-prefixed ' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:agreementDescription rdf:type rdf:Property ;
    rdfs:label 'Agreement Description' ;
    rdfs:comment 'Free-text description of the royalty agreement summarizing the key commercial terms, licensed rights, and strategic context. Used for business user reference and reporting narratives. Not a substitute for the legal agreement document.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyYears rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Years' ;
    rdfs:comment 'Maximum frequency (in years) at which the licensor may exercise audit rights under the agreement (e.g., once every 2 years). Null when audit_rights_flag is False. Used to schedule and track audit obligations.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether the licensor has the contractual right to audit the licensee\'s books and records to verify royalty calculations and net sales reporting. True if audit rights are granted; False otherwise. Relevant for SOX compliance and royalty audit defense.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRoyaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Base Royalty Rate Pct' ;
    rdfs:comment 'The primary or base royalty rate expressed as a percentage of net sales applicable to the first tier or flat rate structure. For tiered agreements, this represents the lowest tier rate. Stored with five decimal places to accommodate fractional rates common in pharmaceutical licensing (e.g., 3.50000%). Used as the default rate in accrual calculations.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which the royalty agreement is scheduled to expire and royalty obligations cease. Nullable for perpetual or open-ended agreements. Used for accrual cutoff and renewal planning. Maps to EFFECTIVE_UNTIL category for MASTER_AGREEMENT role.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseeName rdf:type rdf:Property ;
    rdfs:label 'Licensee Name' ;
    rdfs:comment 'Legal name of the entity receiving the license rights (licensee). For in-license agreements, this is typically the pharmaceutical company itself or a subsidiary. For out-license agreements, this is the external partner receiving rights.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAnnualRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Annual Royalty Amount' ;
    rdfs:comment 'Contractually guaranteed minimum royalty payment due to the licensor per calendar or contract year, regardless of actual net sales. If actual royalties calculated on net sales fall below this floor, the minimum amount is payable. Critical for accrual adequacy assessment and cash flow planning.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSalesDefinition rdf:type rdf:Property ;
    rdfs:label 'Net Sales Definition' ;
    rdfs:comment 'Contractual definition of net sales as the royalty base, specifying which deductions are permitted (e.g., trade discounts, chargebacks, returns, freight, taxes, gross-to-net adjustments). Critical for accurate royalty calculation and audit defense. Stored as free text capturing the contractual language or a standardized reference code.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDays rdf:type rdf:Property ;
    rdfs:label 'Payment Due Days' ;
    rdfs:comment 'Number of calendar days after the close of each reporting period within which the royalty payment must be remitted to the licensor (e.g., 45 days after quarter end). Used to calculate payment due dates for each accrual period and to assess timeliness of settlements.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Contractual frequency at which royalty payments must be remitted to the licensor. Drives the accrual period schedule and payment due date calculation in SAP FI accounts payable. Quarterly is the most common frequency in pharmaceutical licensing agreements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRateType rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Type' ;
    rdfs:comment 'Structure of the royalty rate calculation methodology. Flat applies a single fixed percentage to all net sales; tiered applies different rates to different net sales bands; stepped changes the rate at defined cumulative thresholds; running is a continuous percentage; milestone_based triggers payments upon achievement of defined development or commercial milestones.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicenseRoyaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Sublicense Royalty Rate Pct' ;
    rdfs:comment 'Royalty rate percentage applicable to sublicense revenues received by the licensee, payable to the original licensor. Applicable only when sublicensing_rights_flag is True. May differ from the standard net sales royalty rate. Null when sublicensing is not permitted.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sublicensingRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Rights Flag' ;
    rdfs:comment 'Indicates whether the licensee has the contractual right to grant sublicenses to third parties under this agreement. True if sublicensing is permitted; False if rights are non-sublicensable. Impacts royalty flow-through obligations and sublicense revenue sharing calculations.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days of advance written notice required by either party to terminate the agreement for convenience or material breach. Used for contract lifecycle management and accrual wind-down planning.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic scope of the royalty agreement defining the countries or regions where the licensee has rights to commercialize the licensed compound. Expressed as ISO 3166-1 alpha-3 country codes (comma-separated for multi-country) or a named region (e.g., WORLDWIDE, EU, USA). Drives territory-specific royalty rate application and net sales calculation.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier1ThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tier1 Threshold Amount' ;
    rdfs:comment 'Net sales threshold amount (in the agreement currency) at which the royalty rate transitions from the base rate to the tier 2 rate. For tiered agreements, net sales up to this amount are subject to base_royalty_rate_pct. Null for flat-rate agreements.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2RoyaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Tier2 Royalty Rate Pct' ;
    rdfs:comment 'Royalty rate percentage applicable to the second net sales tier for tiered or stepped royalty structures. Null for flat-rate agreements. Applied when cumulative or annual net sales exceed the tier 1 threshold defined in tier1_threshold_amount.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2ThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tier2 Threshold Amount' ;
    rdfs:comment 'Net sales threshold amount (in the agreement currency) at which the royalty rate transitions from tier 2 to tier 3 rate. Null if the agreement has only two tiers or is flat-rate. Supports up to three-tier royalty structures common in pharmaceutical licensing.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3RoyaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Tier3 Royalty Rate Pct' ;
    rdfs:comment 'Royalty rate percentage applicable to net sales exceeding the tier 2 threshold for three-tier royalty structures. Null for flat-rate or two-tier agreements. Typically the highest rate in escalating structures or lowest in de-escalating structures.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontLicenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Upfront License Fee Amount' ;
    rdfs:comment 'One-time non-refundable upfront payment made to the licensor upon execution of the agreement, separate from ongoing running royalties. Relevant for R&D capitalization assessment under FASB ASC 730 and IP cost tracking for in-licensed compounds.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRatePct rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate Pct' ;
    rdfs:comment 'Applicable withholding tax rate percentage on royalty payments as determined by the governing tax treaty between the licensor and licensee jurisdictions. Used for net payment calculation and tax reporting. Zero if no withholding tax applies under a treaty exemption.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountingTreatment rdf:type rdf:Property ;
    rdfs:label 'Accounting Treatment' ;
    rdfs:comment 'Accounting classification applied to this milestone payment per applicable accounting standards: rd_expense (expensed as R&D), capitalize (capitalized as intangible asset), cogs (recognized as cost of goods sold), deferred_revenue (deferred until performance obligation met), contingent_liability (disclosed as contingent liability until triggered).' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualAmount rdf:type rdf:Property ;
    rdfs:label 'Contractual Amount' ;
    rdfs:comment 'The gross payment amount as specified in the partnership or licensing agreement for this milestone, in the contract currency. This is the base obligation before any adjustments, withholding taxes, or FX conversion.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentStage rdf:type rdf:Property ;
    rdfs:label 'Development Stage' ;
    rdfs:comment 'Development stage of the associated drug program at the time the milestone is triggered (e.g., preclinical, Phase 1, Phase 2, Phase 3, NDA/BLA Filed). Used for R&D capitalization assessment and program tracking. [ENUM-REF-CANDIDATE: discovery|preclinical|phase_1|phase_2|phase_3|nda_bla_filed|approved|commercial — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Expected Trigger Date' ;
    rdfs:comment 'Projected date by which the triggering event is expected to occur, based on current program timelines. Used for contingent liability forecasting and cash flow planning.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the company\'s functional currency used in the functional_currency_amount field (e.g., USD).' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'Exchange rate applied to convert the contractual_amount from contract currency to functional currency at the time of recognition or payment. Sourced from SAP FI treasury rates.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isContingentLiability rdf:type rdf:Property ;
    rdfs:label 'Is Contingent Liability' ;
    rdfs:comment 'Indicates whether this milestone payment represents a contingent liability that must be disclosed in financial statements prior to the triggering event occurring. True if the payment obligation is contingent on a future uncertain event.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneNumber rdf:type rdf:Property ;
    rdfs:label 'Milestone Number' ;
    rdfs:comment 'Externally-known business identifier for this milestone payment, typically referenced in the partnership agreement schedule. Format: MS-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Actual net amount paid or received after deducting withholding taxes and any other contractual adjustments from the contractual_amount. Represents the cash flow impact.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggeringEvent rdf:type rdf:Property ;
    rdfs:label 'Triggering Event' ;
    rdfs:comment 'Description of the specific contractual event that triggers this milestone payment (e.g., \'IND Filing Accepted by FDA\', \'Phase II Primary Endpoint Met\', \'NDA Approval Received\', \'First Commercial Sale in US\', \'Annual Net Sales Exceed $500M\').' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventDate rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Date' ;
    rdfs:comment 'The actual date on which the contractual triggering event occurred, confirming the milestone has been achieved and the payment obligation is activated. Null if the milestone has not yet been triggered.' ;
    rdfs:domain ind:MilestonePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryTransferLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Transfer Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity that is the seller or supplier in the intercompany transaction (the entity transferring the product, API, or service).' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:priorVersionTransferPriceId rdf:type rdf:Property ;
    rdfs:label 'Prior Version Transfer Price Id' ;
    rdfs:comment 'Reference to the immediately preceding version of this transfer price record (self-referential). Enables reconstruction of the full price history chain for audit and tax authority documentation purposes.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferPrice .

ind:sendingCountryId rdf:type rdf:Property ;
    rdfs:label 'Sending Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Transfer pricing rules are country-pair specific; the sending country determines applicable tax treaties, APA requirements, and documentation standards. The plain sending_country_code is denormalized;' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:apaReference rdf:type rdf:Property ;
    rdfs:label 'Apa Reference' ;
    rdfs:comment 'Reference to an Advance Pricing Agreement (APA) or bilateral APA (BAPA) concluded with one or more tax authorities that pre-approves the transfer pricing methodology and price range for this transaction. Null if no APA is in place.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedPrice rdf:type rdf:Property ;
    rdfs:label 'Approved Price' ;
    rdfs:comment 'The arm\'s-length intercompany price approved for the transfer of the product or service per unit, expressed in the transaction currency. This is the operative price used in intercompany invoicing.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:armLengthRangeMax rdf:type rdf:Property ;
    rdfs:label 'Arm Length Range Max' ;
    rdfs:comment 'The upper bound of the arm\'s-length price range (interquartile range) established through benchmarking analysis. The approved transfer price must fall within this range to satisfy OECD and local tax authority requirements.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:armLengthRangeMin rdf:type rdf:Property ;
    rdfs:label 'Arm Length Range Min' ;
    rdfs:comment 'The lower bound of the arm\'s-length price range (interquartile range) established through benchmarking analysis. The approved transfer price must fall within this range to satisfy OECD and local tax authority requirements.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkingStudyRef rdf:type rdf:Property ;
    rdfs:label 'Benchmarking Study Ref' ;
    rdfs:comment 'Document reference number or identifier for the economic benchmarking study (comparables analysis) that supports the arm\'s-length determination for this transfer price. Links to the transfer pricing documentation file.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Base Amount' ;
    rdfs:comment 'The total cost base (direct manufacturing cost, overhead, and allocated R&D) used as the starting point for cost-plus or TNMM pricing method calculations. Expressed in the transaction currency.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markupPct rdf:type rdf:Property ;
    rdfs:label 'Markup Pct' ;
    rdfs:comment 'The arm\'s-length markup percentage applied to the cost base to arrive at the approved transfer price under cost-plus or TNMM methodology. Expressed as a decimal percentage (e.g., 15.0000 = 15%).' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit Of Measure' ;
    rdfs:comment 'The unit of measure to which the approved transfer price applies (e.g., per kg of API, per vial of drug product, per batch). Aligns with SAP S/4HANA base unit of measure on the material master. [ENUM-REF-CANDIDATE: kg|g|mg|L|mL|unit|vial|tablet|capsule|batch — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingMethod rdf:type rdf:Property ;
    rdfs:label 'Pricing Method' ;
    rdfs:comment 'OECD-recognized transfer pricing methodology applied to determine the arm\'s-length price. CUP = Comparable Uncontrolled Price; TNMM = Transactional Net Margin Method; RPM = Resale Price Method; PSM = Profit Split Method; cost_plus = Cost-Plus Method.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Stage' ;
    rdfs:comment 'The commercial lifecycle stage of the pharmaceutical product at the time this transfer price is established. Influences the pricing methodology and markup applied (e.g., pre-launch products may use cost-plus; commercial products may use CUP).' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordNumber rdf:type rdf:Property ;
    rdfs:label 'Record Number' ;
    rdfs:comment 'Externally-known business identifier for the transfer pricing record, used in intercompany agreements, tax authority documentation, and OECD compliance filings. Format: TP-YYYY-NNNNNN.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle state of the transfer pricing record. Active records govern live intercompany transactions; superseded records have been replaced by a newer version. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|superseded|expired|cancelled — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDocRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Doc Ref' ;
    rdfs:comment 'Reference to the formal transfer pricing documentation package (local file, master file, or country-by-country report) filed with tax authorities in accordance with OECD BEPS Action 13 requirements. May reference a Veeva Vault document ID or SAP document number.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'The scheduled frequency at which this transfer price is reviewed and potentially revised to ensure continued arm\'s-length compliance. Annual review is the OECD standard minimum.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRulingRef rdf:type rdf:Property ;
    rdfs:label 'Tax Ruling Ref' ;
    rdfs:comment 'Reference to any binding tax ruling, private letter ruling, or competent authority agreement issued by a tax authority that specifically governs or validates this transfer pricing arrangement.' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Nature of the intercompany transaction governed by this transfer price: tangible goods (products/APIs), services (manufacturing, R&D, distribution), IP licensing, cost-sharing arrangements, or intercompany loans.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxApplicable rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Applicable' ;
    rdfs:comment 'Indicates whether withholding tax applies to the intercompany transaction governed by this transfer price (e.g., royalty payments or service fees may be subject to withholding tax under bilateral tax treaties).' ;
    rdfs:domain ind:TransferPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustedForecastQty rdf:type rdf:Property ;
    rdfs:label 'Adjusted Forecast Qty' ;
    rdfs:comment 'Demand quantity after commercial, medical affairs, or supply chain planner adjustments to the statistical baseline. Reflects market intelligence, launch events, tender wins, or clinical trial enrollment changes applied on top of the baseline.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineForecastQty rdf:type rdf:Property ;
    rdfs:label 'Baseline Forecast Qty' ;
    rdfs:comment 'Statistically generated baseline demand quantity for the SKU in the forecast period, produced by the statistical forecasting engine (Kinaxis/Blue Yonder) using historical sales, shipment, or consumption data without manual override.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consensus Approved Timestamp' ;
    rdfs:comment 'Date and time when the demand plan was formally approved through the S&OP consensus process. Marks the transition to frozen/authoritative demand signal for supply execution. Compliant with 21 CFR Part 11 electronic record requirements.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consensusForecastQty rdf:type rdf:Property ;
    rdfs:label 'Consensus Forecast Qty' ;
    rdfs:comment 'Final consensus-approved demand quantity agreed upon during the S&OP/IBP consensus meeting, representing the authoritative demand signal used for supply planning and inventory positioning. Populated only after plan_status reaches consensus_approved.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandClassification rdf:type rdf:Property ;
    rdfs:label 'Demand Classification' ;
    rdfs:comment 'Classification of the demand signal by supply chain purpose: commercial (market sales), clinical (investigational product for trials), compassionate use (expanded access programs), sample (promotional/medical samples), or launch (pre-launch inventory build). Drives planning rules and inventory segmentation.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSignalSource rdf:type rdf:Property ;
    rdfs:label 'Demand Signal Source' ;
    rdfs:comment 'Origin of the primary demand signal used to generate or adjust this forecast (e.g., Kinaxis RapidResponse statistical engine, Blue Yonder, SAP APO, manual planner input, CRM pipeline, market research, or tender/contract data). [ENUM-REF-CANDIDATE: kinaxis|blue_yonder|sap_apo|manual|crm|market_research|tender — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'The trade channel through which the pharmaceutical product reaches the end customer (e.g., wholesale distributor, direct hospital supply, retail pharmacy, specialty pharmacy, government/tender, export). Influences demand pattern and supply routing. [ENUM-REF-CANDIDATE: wholesale|direct|hospital|retail_pharmacy|specialty_pharmacy|government|export|e_commerce — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Pct' ;
    rdfs:comment 'Measured forecast accuracy for the prior equivalent period, expressed as a percentage (0–100). Calculated as 1 minus the Mean Absolute Percentage Error (MAPE) for the SKU-period. Used to assess planning reliability and trigger model recalibration.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastBias rdf:type rdf:Property ;
    rdfs:label 'Forecast Bias' ;
    rdfs:comment 'Systematic directional error in the forecast for the prior equivalent period, measured as actual minus forecast quantity. Positive bias indicates under-forecasting; negative bias indicates over-forecasting. Used for continuous improvement of demand planning accuracy.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastGranularity rdf:type rdf:Property ;
    rdfs:label 'Forecast Granularity' ;
    rdfs:comment 'The time granularity at which the demand forecast quantities are expressed (weekly, monthly, or quarterly buckets). Determines how forecast_period_date is interpreted.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Date' ;
    rdfs:comment 'The specific time bucket (month, week, or quarter start date) to which the demand quantities in this record apply. Each row represents one SKU-period combination within the planning horizon.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizeQty rdf:type rdf:Property ;
    rdfs:label 'Lot Size Qty' ;
    rdfs:comment 'Standard manufacturing lot or batch size quantity for the SKU, used to convert demand quantities into production orders and assess capacity requirements. Expressed in the same UOM as forecast quantities.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the adjusted forecast deviates from the statistical baseline (e.g., new tender win, product launch, competitor entry, clinical trial enrollment change, market withdrawal). Required when adjusted_forecast_qty differs from baseline_forecast_qty. [ENUM-REF-CANDIDATE: tender_win|product_launch|competitor_entry|clinical_enrollment|market_withdrawal|promotional_event|regulatory_change — promote to reference product]' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Created Timestamp' ;
    rdfs:comment 'Timestamp when this demand plan record was first created in the system, providing the audit trail start point for the planning record lifecycle.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this demand plan record, supporting audit trail requirements and change management tracking per 21 CFR Part 11 and ICH Q10.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known business identifier for the demand plan, used for cross-system reference in Kinaxis RapidResponse, Blue Yonder, and SAP S/4HANA. Follows the enterprise demand plan numbering convention.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the demand plan record, tracking progression from initial statistical generation through consensus approval and freeze for supply execution. [ENUM-REF-CANDIDATE: draft|submitted|under_review|consensus_approved|frozen|superseded — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the demand plan, enabling tracking of iterative revisions within a planning cycle (e.g., v1.0, v2.1). Supports version-controlled consensus planning workflows.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text notes entered by the demand planner documenting assumptions, market intelligence, adjustment rationale, or risk factors influencing the forecast. Supports S&OP review and audit trail documentation.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'The cadence of the demand planning cycle in which this plan was generated (e.g., monthly S&OP cycle, quarterly business review, weekly rolling horizon). Determines the review and approval schedule.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'The last date of the demand planning horizon covered by this plan. Defines the end of the forecast period, typically 12–24 months for pharmaceutical commercial planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'The first date of the demand planning horizon covered by this plan. Defines the start of the forecast period for supply planning and inventory positioning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Inventory level at which a replenishment order should be triggered for this SKU, calculated from lead time demand plus safety stock. Used in SAP S/4HANA MRP and Kinaxis supply planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Minimum buffer inventory quantity maintained to protect against demand variability and supply disruptions for this SKU in the planning period. Expressed in the same UOM as forecast quantities. Sourced from SAP S/4HANA MM or Kinaxis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Approved shelf life of the pharmaceutical SKU in days from the date of manufacture. Critical for demand planning to ensure inventory is consumed within expiry, minimizing write-offs and ensuring patient safety compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statisticalModelType rdf:type rdf:Property ;
    rdfs:label 'Statistical Model Type' ;
    rdfs:comment 'The statistical forecasting algorithm applied to generate the baseline forecast (e.g., exponential smoothing, ARIMA, Croston, moving average, machine learning ensemble). Sourced from Kinaxis RapidResponse or Blue Yonder model configuration. [ENUM-REF-CANDIDATE: exponential_smoothing|arima|croston|moving_average|holt_winters|ml_ensemble — promote to reference product]' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum permitted storage temperature in degrees Celsius for this pharmaceutical SKU. Used in conjunction with minimum storage temperature to define the acceptable temperature range for GDP-compliant cold chain management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum required storage temperature in degrees Celsius for this pharmaceutical SKU. Used for cold chain planning, GDP compliance, and distribution network configuration (e.g., -80°C for mRNA vaccines, 2–8°C for biologics).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyChainTier rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Tier' ;
    rdfs:comment 'Identifies the supply chain tier to which this demand plan applies: Drug Substance (DS/API), Drug Product (DP/FDF), Finished Goods (packaged product), or Packaging Components. Enables multi-tier demand disaggregation from finished goods back to API and raw materials.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planSiteId rdf:type rdf:Property ;
    rdfs:label 'Plan Site Id' ;
    rdfs:comment 'Reference to the manufacturing site (internal or CMO/CDMO) responsible for producing the planned quantity. Links to the site master data record. Supports GDP compliance and site-level capacity planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:sourceSiteId rdf:type rdf:Property ;
    rdfs:label 'Source Site Id' ;
    rdfs:comment 'Reference to the originating site for transfer supply type plans. Identifies the site from which material will be transferred to the receiving/destination site. Relevant for inter-site and inter-company supply transfers.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Standard or planned batch size for the manufacturing run, expressed in the quantity UOM. Critical for GMP compliance, batch record generation, and capacity utilization calculations. Aligns with the validated batch size in the manufacturing process.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Capacity Constraint Flag' ;
    rdfs:comment 'Indicates whether this supply plan record is constrained by manufacturing capacity limitations (True) or represents an unconstrained theoretical plan (False). Distinguishes constrained from unconstrained plan scenarios.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Pct' ;
    rdfs:comment 'Percentage of available manufacturing capacity consumed by this supply plan at the designated manufacturing site. Used for capacity management, bottleneck identification, and CMO contract utilization tracking.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gdp Compliance Flag' ;
    rdfs:comment 'Indicates whether the supply plan has been reviewed and confirmed as compliant with Good Distribution Practice (GDP) requirements for the planned distribution lanes and storage conditions.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Total planned lead time in calendar days from production start (or purchase order placement) to material availability at the destination site. Includes manufacturing, QC release, and logistics transit time. Used for MRP scheduling.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the pharmaceutical material covered by this supply plan: Drug Substance (DS), Drug Product (DP), Finished Dosage Form (FDF), Active Pharmaceutical Ingredient (API), excipient, or packaging component. Aligns with CMC categorization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfBatches rdf:type rdf:Property ;
    rdfs:label 'Number Of Batches' ;
    rdfs:comment 'Total number of manufacturing batches planned within the planning horizon for this supply plan record. Used for capacity loading, CMO scheduling, and GMP batch record planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the supply plan indicating whether it reflects capacity and material constraints (constrained) or theoretical demand without constraints (unconstrained). Consensus plan represents the agreed S&OP output. [ENUM-REF-CANDIDATE: constrained|unconstrained|consensus|rough_cut|master — promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedProductionQty rdf:type rdf:Property ;
    rdfs:label 'Planned Production Qty' ;
    rdfs:comment 'Total planned production or procurement quantity for the material within the planning horizon, expressed in the base unit of measure (e.g., kg for DS/API, units for FDF/DP). Core quantitative output of the supply plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Production Start Date' ;
    rdfs:comment 'The scheduled start date for the manufacturing or procurement activity. Used for capacity planning, CMO scheduling, and lead time management. Derived from planned receipt date minus production lead time.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'The date on which the planned quantity is expected to be received at the destination site or made available in inventory. Used for inventory availability calculations and demand fulfillment scheduling.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scenario rdf:type rdf:Property ;
    rdfs:label 'Scenario' ;
    rdfs:comment 'Scenario classification for the supply plan, supporting what-if analysis and risk planning. Base is the primary plan; optimistic and pessimistic reflect demand upside/downside; risk_adjusted incorporates supply risk mitigations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainSegment rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Segment' ;
    rdfs:comment 'Indicates whether the supply plan pertains to the commercial supply chain or the clinical trial supply chain. Clinical supply plans are subject to IND/CTA requirements and GCP; commercial plans are subject to GMP and GDP.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyType rdf:type rdf:Property ;
    rdfs:label 'Supply Type' ;
    rdfs:comment 'Indicates the sourcing strategy for the planned supply: make (internal manufacturing), buy (external procurement from CMO/CDMO), or transfer (inter-site or inter-company stock transfer). Drives MRP logic in SAP PP and Kinaxis.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Supplier Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Pharma GMP requires traceability of each inventory lot to its supplier for quality investigations, CAPA management, and supplier qualification audits. inventory_lot.supplier_lot_number implies a suppl' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:capaReference rdf:type rdf:Property ;
    rdfs:label 'Capa Reference' ;
    rdfs:comment 'Reference number of the associated Corrective and Preventive Action (CAPA) record in the Quality Management System (QMS) if this lot is subject to an active quality investigation or deviation. Links to MasterControl or TrackWise QMS.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Number' ;
    rdfs:comment 'Reference number of the Certificate of Analysis (CoA) issued by the manufacturer or supplier for this lot, confirming that the lot meets all specified quality attributes and release criteria. Required for GMP compliance and regulatory inspections.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainBreakDate rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Break Date' ;
    rdfs:comment 'Date on which a cold chain break or temperature excursion was first detected for this lot. Populated only when temperature_excursion_flag is True. Used to initiate quality impact assessment and determine lot disposition.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysUntilExpiry rdf:type rdf:Property ;
    rdfs:label 'Days Until Expiry' ;
    rdfs:comment 'Number of days remaining until the lot\'s expiry date, calculated at the time of data extraction. Used for near-expiry inventory alerts, FEFO prioritization, and supply chain risk management. Negative values indicate expired lots.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deaSchedule rdf:type rdf:Property ;
    rdfs:label 'Dea Schedule' ;
    rdfs:comment 'DEA controlled substance schedule classification (I through V) for this lot, if applicable. Determines the level of security, storage, and record-keeping requirements. Null for non-controlled substances.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClinicalSupply rdf:type rdf:Property ;
    rdfs:label 'Is Clinical Supply' ;
    rdfs:comment 'Flag indicating whether this lot is designated for use in clinical trials (investigational product supply) rather than commercial distribution. Clinical supply lots are subject to additional regulatory controls under GCP and IND/CTA requirements.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isControlledSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Substance' ;
    rdfs:comment 'Flag indicating whether this lot contains a DEA-scheduled controlled substance requiring additional security, storage, and regulatory reporting obligations under the Controlled Substances Act.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGdpCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Gdp Compliant' ;
    rdfs:comment 'Flag indicating whether this lot\'s storage and handling at the current location is confirmed compliant with Good Distribution Practice (GDP) requirements, including temperature monitoring, security, and documentation standards.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date of the most recent inventory movement (goods receipt, goods issue, transfer posting, or stock transfer) recorded for this lot in SAP. Used for slow-moving inventory analysis and supply chain performance monitoring.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturer-assigned alphanumeric identifier for the production lot or batch. Enables full lot/batch traceability from raw material receipt through finished goods distribution. Corresponds to SAP batch number (CHARG field). Required for GMP compliance and recall management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current quality and disposition status of the lot in the inventory management system. Drives whether the lot is available for use, shipment, or must be held pending quality review. Maps to SAP batch status (unrestricted-use, quality inspection, blocked). [ENUM-REF-CANDIDATE: unrestricted|quality_hold|quarantine|rejected|released|destroyed — promote to reference product]' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP purchase order number associated with the procurement of this lot from an external supplier. Enables financial reconciliation, goods receipt matching, and procurement traceability.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Net quantity of the lot available for new allocations, calculated as quantity_on_hand minus quantity_reserved minus quantity_on_quality_hold. Represents the actionable inventory for supply planning and order fulfillment.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Total physical quantity of the lot currently in stock at the storage location, expressed in the base unit of measure. Represents the gross inventory position before reservations. Sourced from SAP inventory management (MARD/MCHB tables).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnQualityHold rdf:type rdf:Property ;
    rdfs:label 'Quantity On Quality Hold' ;
    rdfs:comment 'Quantity of the lot currently blocked due to quality inspection, Out-of-Specification (OOS) investigation, or quality hold pending Corrective and Preventive Action (CAPA) resolution. Not available for use or shipment.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity of the lot that has been reserved for specific production orders, sales orders, or clinical trial supply requests but not yet physically consumed or shipped. Reduces available quantity for new allocations.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Code identifying the manufacturing site, distribution center, or third-party logistics (3PL) location where this lot is physically held. Enables multi-site inventory visibility and GDP compliance tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'Original lot or batch number assigned by the external supplier, Contract Manufacturing Organization (CMO), or Contract Development and Manufacturing Organization (CDMO). Enables traceability back to the supplier\'s manufacturing records and Certificate of Analysis (CoA).' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureExcursionFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Flag' ;
    rdfs:comment 'Flag indicating whether this lot has experienced a documented temperature excursion during storage or transit that may impact product quality and requires quality impact assessment per GDP and cold-chain management procedures.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard or moving average cost per unit of measure for this lot as recorded in SAP. Used for inventory valuation, COGS calculation, and financial reporting. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:InventoryLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'SAP inventory valuation method applied to this lot for financial costing purposes. Determines how the lot\'s value is calculated in the general ledger (standard price, moving average price, or actual cost). Relevant for COGS reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.shipment. Business justification: A warehouse receipt is the physical confirmation of an inbound shipment arriving at a pharmaceutical manufacturing site, warehouse, or distribution center. Linking warehouse_receipt.shipment_id → ship' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:stockTransferOrderId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Order Id' ;
    rdfs:comment 'Foreign key linking to supply.stock_transfer_order. Business justification: A warehouse receipt at the receiving plant is the completion event for a stock transfer order. Linking warehouse_receipt.stock_transfer_order_id → stock_transfer_order.stock_transfer_order_id enables ' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockTransferOrder .

ind:actualReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Timestamp' ;
    rdfs:comment 'The actual date and time the physical materials arrived at the receiving dock or facility. Distinct from the SAP posting date; captures the real-world event time for GDP compliance, cold-chain monitoring, and traceability. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'The carrier\'s bill of lading number for the inbound shipment. Provides the legal transport document reference linking the receipt to the logistics carrier record. Used for freight claims, GDP transport documentation, and supply chain traceability.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'The name of the logistics carrier or third-party logistics provider (3PL) responsible for transporting the materials to the receiving site. Used for GDP carrier qualification tracking and freight performance management.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalSupplyFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Supply Flag' ;
    rdfs:comment 'Indicates whether the received material is designated for clinical trial supply (investigational product) rather than commercial supply. True = clinical trial supply subject to IND/GCP requirements; False = commercial supply. Determines applicable regulatory framework and handling procedures.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaReference rdf:type rdf:Property ;
    rdfs:label 'Coa Reference' ;
    rdfs:comment 'The document reference number or identifier for the vendor\'s Certificate of Analysis (CoA) accompanying the shipment. The CoA confirms the material meets specification. Required for GMP compliance and regulatory traceability. Stored in Veeva Vault or LIMS document management.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cocReference rdf:type rdf:Property ;
    rdfs:label 'Coc Reference' ;
    rdfs:comment 'The document reference number for the vendor\'s Certificate of Compliance (CoC), confirming the material was manufactured in accordance with GMP and applicable regulatory requirements. Distinct from the CoA which covers analytical test results.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'The vendor\'s delivery note or packing slip number accompanying the shipment. Used for physical receipt verification, discrepancy identification, and document archiving per GMP requirements.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gdp Compliance Status' ;
    rdfs:comment 'The GDP compliance check status for this receipt, confirming that the material was transported and received in accordance with Good Distribution Practice guidelines. \'compliant\' = all GDP checks passed; \'non_compliant\' = one or more GDP deviations identified; \'pending_review\' = GDP review in progress.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The SAP Material Document number generated upon posting the goods receipt in SAP S/4HANA MIGO (transaction MIGO/MB01). Serves as the primary business identifier linking this receipt to the source ERP transaction. Format follows SAP material document numbering (e.g., 5000012345).' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Gr Document Year' ;
    rdfs:comment 'The fiscal year associated with the SAP GR material document number. Required because SAP material document numbers are unique only within a fiscal year. Combined with gr_document_number to form the unique SAP key.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundDeliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Inbound Delivery Number' ;
    rdfs:comment 'SAP inbound delivery document number (transaction VL31N/VL32N) associated with this goods receipt, if applicable. Used when the receipt is triggered by an advance shipping notice (ASN) from the vendor. May be null for direct PO-based receipts.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'The SAP Quality Management (QM) inspection lot number automatically created upon goods receipt posting for materials subject to quality inspection. Links the warehouse receipt to the quality inspection process in SAP QM and LIMS. Null if no inspection is required.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poLineItem rdf:type rdf:Property ;
    rdfs:label 'Po Line Item' ;
    rdfs:comment 'The specific line item number within the purchase order against which this goods receipt is posted. A single PO may have multiple line items for different materials or delivery schedules.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poQuantity rdf:type rdf:Property ;
    rdfs:label 'Po Quantity' ;
    rdfs:comment 'The ordered quantity as specified in the purchase order line item. Used to calculate receipt variance (received vs. ordered) and to identify over/under deliveries requiring vendor notification or tolerance check.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the received material has been placed in quarantine status pending quality inspection or investigation. True = material is quarantined and not available for use; False = material is not in quarantine. Triggers quality inspection workflow in LIMS and QMS.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the warehouse receipt. \'posted\' = GR document successfully posted in SAP; \'reversed\' = GR has been reversed/cancelled; \'blocked\' = receipt blocked pending resolution; \'under_inspection\' = quality inspection in progress; \'released\' = inspection complete and stock released for use.' ;
    rdfs:domain ind:WarehouseReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The actual quantity of material physically received and counted at the receiving dock, expressed in the base unit of measure. Used for inventory posting, three-way matching, and discrepancy reporting against the PO quantity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'The SAP stock type assigned to the received material upon posting. \'unrestricted\' = available for use/sale; \'quality_inspection\' = held pending QC inspection (default for GMP materials); \'blocked\' = blocked stock due to quality issue or hold; \'returns\' = returned goods stock.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Id' ;
    rdfs:comment 'Unique surrogate primary key for the goods issue record in the Databricks Silver Layer. Serves as the system-generated identifier for each material outbound movement or consumption event.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Id' ;
    rdfs:comment 'Foreign key linking to supply.delivery_order. Business justification: Goods issue documents are created as part of delivery order fulfillment. The delivery_document_number (STRING) should be replaced with a proper FK to delivery_order.delivery_order_id. This establishes' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryOrder .

ind:issuingStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Issuing Storage Location Id' ;
    rdfs:comment 'Foreign key linking to masterdata.storage_location. Business justification: goods_issue.issuing_storage_location is a denormalized plain-text field. Linking to masterdata.storage_location enables GMP-compliant goods issue posting from validated storage zones and supports GDP ' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:receivingPlantId rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Material issuances to receiving plants require plant master data for GMP status, capacity, regulatory authorization. Receiving_plant is denormalized code; FK enables plant qualification verification a' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:destructionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Destruction Certificate Number' ;
    rdfs:comment 'The certificate of destruction document number issued by a licensed waste disposal or pharmaceutical destruction contractor when materials are scrapped or destroyed (movement type 551/552). Required for GMP compliance, DEA controlled substance destruction reporting, and environmental regulatory compliance. Populated only for destruction goods issues.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gi Document Number' ;
    rdfs:comment 'The externally-known SAP material document number assigned to the goods issue posting (e.g., 4900012345). This is the primary business identifier referenced in GMP batch records, cost accounting entries, and supply chain traceability. Corresponds to MBLNR in SAP MSEG/MKPF tables.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Gi Document Year' ;
    rdfs:comment 'The fiscal year in which the goods issue material document was posted in SAP (MJAHR). Required in combination with gi_document_number to uniquely identify a material document in SAP MM.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:giStatus rdf:type rdf:Property ;
    rdfs:label 'Gi Status' ;
    rdfs:comment 'Current lifecycle status of the goods issue document. \'posted\' indicates the GI is active and inventory has been reduced; \'reversed\' indicates a reversal document has been posted (movement type 262/552/602); \'blocked\' indicates the document is on quality hold; \'cancelled\' indicates the document was voided prior to posting.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGmpRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Relevant' ;
    rdfs:comment 'Indicates whether this goods issue is subject to Good Manufacturing Practice (GMP) documentation and traceability requirements. True for materials used in GMP-regulated manufacturing, clinical trial supply, or quality testing. False for non-GMP materials such as office supplies, maintenance items, or non-regulated consumables. Drives GMP batch record inclusion and regulatory audit scope.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedQuantity rdf:type rdf:Property ;
    rdfs:label 'Issued Quantity' ;
    rdfs:comment 'The quantity of material issued in the base unit of measure (ERFMG in SAP MSEG). Represents the actual amount consumed, shipped, scrapped, or transferred. Drives inventory reduction, cost accounting entries, and GMP batch record material consumption documentation. Must reconcile with production order component requirements or delivery quantities.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCostAmount rdf:type rdf:Property ;
    rdfs:label 'Material Cost Amount' ;
    rdfs:comment 'The total cost value of the goods issue calculated as issued_quantity multiplied by the material valuation price at time of posting (DMBTR in SAP MSEG in local currency). Represents the COGS or cost allocation amount posted to the consuming cost center or production order. Critical for financial reporting, profitability analysis, and manufacturing cost tracking.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP MM movement type code that classifies the nature of the goods issue (BWART in MSEG). Drives inventory valuation, account determination, and GMP documentation requirements. Key values: 261=Goods issue to production order (consumption), 551=Scrapping/destruction, 601=Goods issue for delivery/customer shipment, 311=Transfer posting within plant. [ENUM-REF-CANDIDATE: 261|262|551|552|601|602|311|312|901|902 — promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Movement Type Description' ;
    rdfs:comment 'Human-readable description of the SAP movement type (e.g., \'Goods Issue to Production Order\', \'Goods Issue for Delivery\', \'Scrapping\', \'Sample Withdrawal\', \'Transfer Posting\'). Supports business reporting and GMP batch record documentation without requiring SAP configuration knowledge.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Order Reference Number' ;
    rdfs:comment 'The reference number of the consuming or receiving order associated with the goods issue. For production consumption (movement type 261), this is the SAP production order number (AUFNR). For clinical supply, this is the clinical trial supply order number. For customer delivery, this is the SAP sales order number (VBELN). Central to GMP batch record traceability and cost allocation.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'The SAP reason code (GRUND) providing additional classification for the goods issue movement, particularly for scrapping, destruction, or non-standard consumption. Examples include: expired material destruction, quality rejection scrap, clinical trial sample, regulatory submission sample, stability testing sample. Supports GMP deviation tracking and regulatory reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location' ;
    rdfs:comment 'For intra-plant transfer postings (movement type 311), the destination storage location within the same plant. Tracks material movement between warehouse zones, e.g., from quarantine to released stock, from bulk storage to dispensing area, or from cold-chain to ambient staging.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'SAP special stock indicator (SOBKZ) identifying whether the issued material belongs to a special stock category. Key values: E=Sales order stock (customer-specific), Q=Project stock, K=Consignment stock at customer, W=Vendor consignment stock. Empty value indicates standard own stock. Critical for clinical trial supply (project stock) and consignment management.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingDistributionNetworkId rdf:type rdf:Property ;
    rdfs:label 'Sending Distribution Network Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_network. Business justification: Stock transfer orders move materials between distribution network nodes. The sending_plant_code (STRING) should be replaced with sending_distribution_network_id FK to distribution_network.distribution' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionNetwork .

ind:sendingStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Sending Storage Location Id' ;
    rdfs:comment 'Foreign key linking to masterdata.storage_location. Business justification: stock_transfer_order.sending_storage_location is a denormalized plain-text field. Linking to masterdata.storage_location ensures the sending location is a validated GMP/GDP storage zone, required for ' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text or coded reason for cancellation of the stock transfer order. Populated only when transfer_status is \'cancelled\'. Supports root cause analysis and supply chain performance improvement.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'SAP outbound delivery document number (transaction VL10) created from the stock transfer order for goods issue processing. Links the STO to the physical shipment execution in SAP WM/SD.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdp Compliant' ;
    rdfs:comment 'Indicates whether the stock transfer order has been executed in full compliance with Good Distribution Practice (GDP) requirements, including qualified carrier use, temperature monitoring, chain of custody documentation, and deviation management.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Date' ;
    rdfs:comment 'Actual date on which goods issue was posted at the sending plant, marking the departure of materials from the source location. Triggers inventory reduction at the sending plant and initiates in-transit stock.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'Actual date on which goods receipt was posted at the receiving plant, confirming arrival and acceptance of the transferred materials. Triggers inventory increase at the receiving plant and closes the in-transit stock.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the receiving plant requires the materials to arrive. Used for supply chain planning, scheduling goods issue, and measuring on-time delivery performance. Corresponds to the SAP STO delivery date field.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingCondition rdf:type rdf:Property ;
    rdfs:label 'Shipping Condition' ;
    rdfs:comment 'Shipping service level or condition required for the transfer. Determines carrier selection, transit time expectations, and special handling requirements. Corresponds to SAP SD shipping condition configuration.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sto Creation Timestamp' ;
    rdfs:comment 'Date and time when the stock transfer order was created in the source system (SAP MM). Represents the business event timestamp of order initiation. Used for lead time analysis and supply chain performance reporting.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stoNumber rdf:type rdf:Property ;
    rdfs:label 'Sto Number' ;
    rdfs:comment 'Externally-known business document number assigned by SAP MM for the inter-plant or inter-site stock transfer order. Corresponds to the SAP Purchase Order number used for STO processing (document type UB or NB).' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainType rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Type' ;
    rdfs:comment 'Distinguishes whether the stock transfer is part of the commercial supply chain or the clinical trial supply chain. Clinical trial transfers require additional traceability and compliance controls per GCP and IND/CTA requirements.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-assigned tracking number or waybill number for the shipment associated with this stock transfer order. Enables real-time shipment visibility and chain of custody documentation for GDP compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferCategory rdf:type rdf:Property ;
    rdfs:label 'Transfer Category' ;
    rdfs:comment 'Classifies the nature of the transfer based on the sending and receiving location types: plant-to-plant, distribution center to plant, plant to distribution center, DC-to-DC, or involving a third-party logistics (3PL) provider. Supports network-level supply chain analytics.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'Quantity of the pharmaceutical material ordered for transfer in the base unit of measure. Represents the planned transfer quantity as specified in the STO line item.' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the stock transfer order. Tracks progression from creation through goods issue, in-transit, goods receipt, and closure or cancellation. [ENUM-REF-CANDIDATE: draft|open|goods_issued|in_transit|partially_received|received|cancelled|blocked — promote to reference product]' ;
    rdfs:domain ind:StockTransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Indicates whether the transfer is a one-step transfer (goods issue and receipt posted simultaneously) or a two-step transfer (goods issue posted at sending plant, goods receipt posted separately at receiving plant). Aligns with SAP MM movement types 301/303/305.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryId rdf:type rdf:Property ;
    rdfs:label 'Destination Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: shipment.destination_country_code is a denormalized plain-text field. Linking to masterdata.country enables import permit validation, serialization requirement checks (DSCSA/EU FMD), and customs compl' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:originDistributionNetworkId rdf:type rdf:Property ;
    rdfs:label 'Origin Distribution Network Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_network. Business justification: Shipments originate from distribution network nodes (plants, warehouses, DCs). The origin_location_code (STRING) should be replaced with origin_distribution_network_id FK to distribution_network.distr' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionNetwork .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Confirmed date the goods were received and accepted at the destination. Populated upon proof-of-delivery (POD) confirmation. Used for on-time delivery performance measurement and GDP compliance documentation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Official customs entry or export declaration number assigned by the customs authority for cross-border shipments. Required for import/export compliance tracking and regulatory audit trails. Null for domestic shipments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Required' ;
    rdfs:comment 'Indicates whether this shipment crosses international borders and requires customs import/export documentation (commercial invoice, packing list, import license, health certificate). True for cross-border shipments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Business identifier (SAP Plant code, DC code, customer account, or clinical site number) of the destination receiving the shipment. Used for delivery confirmation and traceability.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationType rdf:type rdf:Property ;
    rdfs:label 'Destination Location Type' ;
    rdfs:comment 'Classifies the type of destination receiving the shipment. Drives GDP compliance requirements, cold-chain monitoring thresholds, and customs documentation needs. [ENUM-REF-CANDIDATE: plant|distribution_center|3pl_warehouse|distributor|wholesaler|hospital|pharmacy|clinical_trial_site — promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Planned or carrier-confirmed estimated date of arrival at the destination. Used for supply chain planning, cold-chain monitoring window calculations, and customer service commitments. Corresponds to SAP planned delivery date (LFDAT).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms, including packaging and pallets. Required for carrier freight billing, dangerous goods declarations (IATA/IMDG), and customs documentation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Goods Flag' ;
    rdfs:comment 'Indicates whether the shipment contains dangerous goods (e.g., flammable solvents, cytotoxic agents, radioactive materials) subject to IATA Dangerous Goods Regulations (DGR) or IMDG Code. Triggers mandatory DG documentation and packaging requirements.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) defining the transfer of risk and responsibility between shipper and consignee. Determines who bears cost and risk during transit. Corresponds to SAP SD Incoterms (INCO1). Critical for customs valuation and insurance. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port associated with the Incoterms code, specifying the exact point of risk/cost transfer (e.g., \'Rotterdam\' for FOB Rotterdam). Corresponds to SAP SD Incoterms Part 2 (INCO2).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country from which the shipment originates. Used for customs documentation, import/export compliance, and GDP lane qualification.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationType rdf:type rdf:Property ;
    rdfs:label 'Origin Location Type' ;
    rdfs:comment 'Classifies the type of origin location from which the shipment departs. Supports routing logic and GDP compliance tracking across the pharmaceutical distribution network.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned Progressive (PRO) number or airway bill number (AWB) / bill of lading (BOL) number used to track the shipment within the carrier\'s system. Primary reference for carrier communication and proof-of-delivery retrieval.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationVerified rdf:type rdf:Property ;
    rdfs:label 'Serialization Verified' ;
    rdfs:comment 'Indicates whether the drug product serialization data (2D DataMatrix barcodes at unit/case level) has been verified and reported to the applicable track-and-trace system (DSCSA in US, FMD in EU) prior to shipment. Required for commercial pharmaceutical distribution.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Actual date the goods were physically dispatched from the origin location. The principal business event date for this transaction. Corresponds to SAP goods issue posting date (WADAT_IST). Used for GDP compliance, shelf-life calculations, and delivery performance KPIs.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known business identifier for the shipment, sourced from SAP SD (transaction VT01N/VT02N). Used for cross-system traceability and carrier communication. Corresponds to SAP Shipment Number (TKNUM).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment. \'planned\' = shipment created but not yet dispatched; \'in_transit\' = goods picked up by carrier; \'delivered\' = confirmed receipt at destination; \'cancelled\' = shipment voided; \'on_hold\' = blocked pending resolution (e.g., GDP deviation, customs hold); \'returned\' = goods returned to origin.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Quantity of goods dispatched in this shipment, expressed in the base unit of measure (UoM). For finished goods, typically in units (EA) or cases. For API/DS, typically in kg. Must reconcile with delivery document quantity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum acceptable storage and transit temperature in degrees Celsius for this shipment. Defined by the drug product\'s approved storage conditions (e.g., 8°C for refrigerated, 25°C for controlled room temperature). Exceedances trigger GDP deviation investigations.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum acceptable storage and transit temperature in degrees Celsius for this shipment. Defined by the drug product\'s approved storage conditions (e.g., 2°C for refrigerated products, -20°C for frozen biologics). Used to configure temperature monitoring device alarms.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMonitorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitor Device Code' ;
    rdfs:comment 'Unique identifier of the temperature data logger or monitoring device (e.g., Sensitech TempTale, Berlinger ELPRO) placed within the shipment packaging. Used to retrieve temperature excursion data post-delivery for GDP compliance review.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Primary mode of transport used for this shipment. Drives cold-chain packaging requirements, transit time expectations, and customs documentation. \'air\' = air freight; \'road\' = truck/van; \'sea\' = ocean freight; \'rail\' = rail freight; \'courier\' = express parcel; \'multimodal\' = combination of modes.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'United Nations (UN) four-digit number identifying the hazardous substance or article being shipped (e.g., UN3373 for Biological Substance Category B, UN1170 for ethanol). Required on dangerous goods declarations when hazardous_goods_flag is True.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume M3' ;
    rdfs:comment 'Total volumetric measurement of the shipment in cubic metres. Used for freight cost calculation (chargeable weight), container/truck capacity planning, and cold-chain packaging validation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialContractAccountId rdf:type rdf:Property ;
    rdfs:label 'Commercial Contract Account Id' ;
    rdfs:comment 'Foreign key linking to commercial.contract_account. Business justification: Supply delivery orders should link to commercial contract accounts for customer shipments and order fulfillment. This enables integrated order-to-cash process and customer account management across co' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAccount .

ind:actualGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Actual Goods Issue Date' ;
    rdfs:comment 'The actual date on which goods issue was posted in SAP, representing the physical departure of pharmaceutical goods from the warehouse. Critical for lot traceability and GDP compliance.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Externally-known SAP outbound delivery document number (e.g., 80XXXXXXXX) generated by SAP SD VL01N. Used as the primary business reference across warehouse, logistics, and customer-facing communications.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPriority rdf:type rdf:Property ;
    rdfs:label 'Delivery Priority' ;
    rdfs:comment 'Priority classification for warehouse and logistics execution of this delivery. Emergency and clinical priorities trigger expedited picking, packing, and carrier assignment for patient safety or clinical trial continuity.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivery Quantity' ;
    rdfs:comment 'Quantity of pharmaceutical product to be delivered as specified in the delivery order. Expressed in the base unit of measure (e.g., EA for each, BT for bottle, VL for vial).' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the delivery order reflecting warehouse execution progress. Progresses from created through picking, packing, and goods issue posting. [ENUM-REF-CANDIDATE: created|picking_in_progress|picked|packing_in_progress|packed|goods_issue_posted|cancelled — promote to reference product]' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery document indicating the nature of the movement: outbound (commercial sale), returns (reverse logistics), stock_transfer (inter-site or inter-DC), clinical_supply (investigational product for clinical trials), or sample (promotional/medical samples). Aligns with SAP delivery type (LF, LR, NL, etc.).' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoCompliant rdf:type rdf:Property ;
    rdfs:label 'Fefo Compliant' ;
    rdfs:comment 'Indicates whether the batch/lot selected for this delivery complies with FEFO (First Expiry First Out) inventory rotation policy, ensuring the earliest-expiring stock is shipped first. Mandatory for pharmaceutical GDP compliance.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsIssueQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Quantity' ;
    rdfs:comment 'Actual quantity for which goods issue has been posted in SAP, representing the confirmed shipped quantity. Used for inventory reconciliation and revenue recognition.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Status' ;
    rdfs:comment 'Status of the SAP goods issue (GI) posting for this delivery, which triggers inventory reduction and revenue recognition. Fully posted indicates stock has been legally transferred to the customer.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Timestamp' ;
    rdfs:comment 'Precise date and time when goods issue was posted in SAP SD, capturing the exact moment of inventory transfer. Required for cold-chain time-in-transit calculations and GDP audit trails.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:handlingUnitCount rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Count' ;
    rdfs:comment 'Number of handling units (pallets, cartons, shipper boxes) packed for this delivery. Used for freight cost calculation, carrier booking, and GDP packing documentation.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the pharmaceutical product in this delivery is classified as a hazardous material (e.g., cytotoxic, controlled substance, radioactive pharmaceutical) requiring special handling, labeling, and transport documentation.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packingStatus rdf:type rdf:Property ;
    rdfs:label 'Packing Status' ;
    rdfs:comment 'Packing execution status indicating whether the picked pharmaceutical goods have been packed into shipping units (cartons, pallets, shipper boxes) for this delivery.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'Actual quantity of pharmaceutical product physically picked from warehouse storage bins. May differ from delivery quantity in cases of partial picks or stock discrepancies.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickingStatus rdf:type rdf:Property ;
    rdfs:label 'Picking Status' ;
    rdfs:comment 'Warehouse picking execution status indicating whether stock has been physically selected from storage bins for this delivery. Corresponds to SAP WM transfer order status.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'The scheduled date on which the pharmaceutical goods are planned to be delivered to the ship-to party. Used for supply chain planning and customer service level monitoring.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Foreign key linking to masterdata.address. Business justification: distribution_network has denormalized address, city, latitude, longitude plain-text fields. Linking to masterdata.address enforces 3NF and enables validated address master data for GDP site qualificat' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:operatorBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Operator Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Distribution network nodes operated by 3PL providers must be linked to the operator business_partner for GDP qualification management, contract compliance, and 3PL performance reporting. distribution_' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:clinicalSupplyCapable rdf:type rdf:Property ;
    rdfs:label 'Clinical Supply Capable' ;
    rdfs:comment 'Indicates whether the node is qualified and authorized to handle clinical trial investigational medicinal products (IMPs) in addition to commercial supply. Clinical supply nodes must comply with GCP and GMP requirements.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainCertified rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Certified' ;
    rdfs:comment 'Indicates whether the node holds a valid cold chain certification from a recognized body (e.g., IATA CEIV Pharma, GDP cold chain qualification). Required for handling temperature-sensitive biologics, vaccines, and specialty medicines.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlledSubstanceAuthorized rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Authorized' ;
    rdfs:comment 'Indicates whether the node is authorized by the DEA (or equivalent national authority) to store and distribute controlled substances. Nodes without this authorization cannot be assigned to controlled substance distribution lanes.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Dea Registration Number' ;
    rdfs:comment 'DEA registration number authorizing the node to handle Schedule I–V controlled substances. Required for US-based nodes handling controlled pharmaceutical products. Null for non-US nodes or nodes not handling controlled substances.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpAuthorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gdp Authorization Expiry Date' ;
    rdfs:comment 'Date on which the GDP wholesale distribution authorization expires. Supply planning systems must alert when expiry is approaching to prevent distribution through unauthorized nodes.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdpAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Gdp Authorization Number' ;
    rdfs:comment 'Official GDP wholesale distribution authorization number issued by the competent regulatory authority (e.g., MHRA, national competent authority). Required for regulatory traceability and audit purposes.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Gdp Authorization Status' ;
    rdfs:comment 'Current GDP authorization status of the node as required by EU GDP Guidelines (2013/C 343/01) and equivalent national regulations. Authorized nodes are eligible to handle medicinal products. Expired or suspended nodes must be excluded from active distribution lanes.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Handling Time Days' ;
    rdfs:comment 'Number of calendar days required for internal processing activities at the node (receiving, quality inspection, pick/pack, dispatch preparation). Added to lead times in supply planning calculations.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatCapable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Capable' ;
    rdfs:comment 'Indicates whether the node is certified to store and handle hazardous materials including cytotoxic compounds, flammable solvents, and other regulated substances. Relevant for oncology API and certain excipient handling.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inboundLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Inbound Lead Time Days' ;
    rdfs:comment 'Standard number of calendar days required for inbound shipments to arrive at this node from its upstream supply source. Used as a planning parameter in Kinaxis RapidResponse and SAP APO/IBP for replenishment scheduling.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiTemperatureCapable rdf:type rdf:Property ;
    rdfs:label 'Multi Temperature Capable' ;
    rdfs:comment 'Indicates whether the node can simultaneously handle multiple temperature zones (e.g., both ambient and refrigerated storage). Enables assignment of mixed-temperature product portfolios to a single node in supply network planning.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkTier rdf:type rdf:Property ;
    rdfs:label 'Network Tier' ;
    rdfs:comment 'Hierarchical tier classification of the node within the distribution network topology. Tier 1 = primary manufacturing/central DC; Tier 2 = regional DC; Tier 3 = local/last-mile node. Drives network optimization and replenishment hierarchy in supply planning.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this distribution network node across supply chain planning systems (Kinaxis RapidResponse, Blue Yonder, SAP APO/IBP). Used as the business key for cross-system integration and network lane definitions.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name of the distribution network node (e.g., \'Frankfurt Regional DC\', \'Chicago 3PL Hub\', \'Singapore Manufacturing Site\'). Used in supply chain planning dashboards and network topology reports.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of the distribution network node. Inactive or suspended nodes are excluded from supply planning runs. Nodes under qualification are pending GDP or regulatory authorization review.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the network node by its functional role in the pharmaceutical supply chain. Drives planning logic, GDP compliance requirements, and lane eligibility in Kinaxis RapidResponse and SAP APO/IBP. [ENUM-REF-CANDIDATE: manufacturing_site|distribution_center|3pl_node|wholesaler|direct_to_pharmacy|clinical_depot|hospital_pharmacy|specialty_pharmacy — promote to reference product]' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorType rdf:type rdf:Property ;
    rdfs:label 'Operator Type' ;
    rdfs:comment 'Classification of the entity operating the distribution node. Distinguishes between internally operated sites and third-party operators such as 3PL (Third-Party Logistics), CMO (Contract Manufacturing Organization), CDMO (Contract Development and Manufacturing Organization), or wholesalers.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Outbound Lead Time Days' ;
    rdfs:comment 'Standard number of calendar days required for outbound shipments to depart this node and reach the next downstream node or customer. Used for delivery commitment and supply planning in Kinaxis RapidResponse.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:palletCapacity rdf:type rdf:Property ;
    rdfs:label 'Pallet Capacity' ;
    rdfs:comment 'Maximum number of standard pallets (EUR/ISO pallet) the node can accommodate simultaneously. Used for operational capacity planning and inbound/outbound throughput modeling in supply network planning tools.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quarantineZoneAvailable rdf:type rdf:Property ;
    rdfs:label 'Quarantine Zone Available' ;
    rdfs:comment 'Indicates whether the node has a dedicated physical quarantine zone for holding materials pending quality release, investigation, or returns processing. Required for GDP-compliant nodes handling pharmaceutical products.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sap Plant Code' ;
    rdfs:comment 'Four-character SAP plant code assigned to this distribution network node in SAP S/4HANA MM/WM/PP modules. Used for cross-system integration between supply planning tools (Kinaxis, Blue Yonder) and SAP ERP for inventory and production order management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapStorageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Sap Storage Location Code' ;
    rdfs:comment 'SAP storage location code within the plant, representing the primary storage location for this node in SAP S/4HANA WM. Used for inventory posting, goods receipt, and goods issue transactions.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationCapable rdf:type rdf:Property ;
    rdfs:label 'Serialization Capable' ;
    rdfs:comment 'Indicates whether the node is equipped to scan, verify, and process serialized pharmaceutical packaging as required by DSCSA (US) and EU FMD (Falsified Medicines Directive) track-and-trace regulations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity M3' ;
    rdfs:comment 'Total physical storage capacity of the node measured in cubic meters. Used for capacity planning, network optimization, and inventory allocation decisions in Kinaxis RapidResponse and SAP WM.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Primary temperature storage zone capability of the node. Defines the cold-chain handling classification: ambient (15–25°C), CRT (Controlled Room Temperature, 15–30°C), refrigerated (2–8°C), frozen (-20°C), or ultra-low temperature (-80°C). Critical for product-to-node assignment in supply planning.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseZoneCount rdf:type rdf:Property ;
    rdfs:label 'Warehouse Zone Count' ;
    rdfs:comment 'Number of distinct storage zones configured within the node (e.g., quarantine zone, approved stock zone, returns zone, controlled substance vault). Reflects the physical warehouse layout complexity in SAP WM.' ;
    rdfs:domain ind:DistributionNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.batch_record. Business justification: QP release for clinical trial supplies requires the batch record to be directly referenced on the clinical supply order. EU GMP Annex 13 and FDA 21 CFR Part 312 mandate batch record traceability for i' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:courierBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Courier Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: clinical_supply_order.courier_name is a denormalized plain-text field. Linking to masterdata.business_partner enables courier qualification tracking, GDP compliance verification, and clinical supply c' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:patientEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Patient Enrollment Id' ;
    rdfs:comment 'Foreign key linking to patient.patient_enrollment. Business justification: Supply orders must verify enrollment status (active, consented) before shipping investigational product. Links order to specific trial enrollment context (site, protocol version, treatment arm) requir' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatientEnrollment .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'The quantity of IMP or ancillary supply formally approved for fulfilment after clinical supply review. May differ from ordered_quantity due to stock availability, protocol amendments, or QP release constraints.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispensingUnit rdf:type rdf:Property ;
    rdfs:label 'Dispensing Unit' ;
    rdfs:comment 'Description of the dispensing unit configuration for the IMP as packaged for clinical trial use (e.g., \'Blinded kit of 28 tablets\', \'1 vial 10mg/mL\'). Supports site pharmacist dispensing and accountability records.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Export Permit Number' ;
    rdfs:comment 'Reference number of the export permit or authorisation issued by the originating country\'s regulatory authority for the shipment of IMP across international borders for clinical trial purposes.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Import Permit Number' ;
    rdfs:comment 'Reference number of the import permit issued by the relevant national regulatory authority (e.g., FDA, EMA member state, PMDA) authorising the importation of the IMP into the destination country for clinical trial use.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indCtaNumber rdf:type rdf:Property ;
    rdfs:label 'Ind Cta Number' ;
    rdfs:comment 'The regulatory filing reference number (IND number in the US per 21 CFR Part 312, or CTA number in the EU per Regulation 536/2014) under which this clinical supply order is authorised. Required for import/export permit applications and regulatory compliance.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtSystemReference rdf:type rdf:Property ;
    rdfs:label 'Irt System Reference' ;
    rdfs:comment 'Reference number or transaction ID from the Interactive Response Technology (IRT) / Interactive Web Response System (IWRS) that triggered or confirmed this supply order. Links the supply event to the randomization and drug management system.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The calendar date on which the clinical supply order was formally placed or submitted by the clinical supply team. This is the principal business event date for the order.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of IMP or ancillary supply units requested in this order, expressed in the unit of measure defined on the IMP material master (e.g., vials, tablets, kits).' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qpReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Qp Release Date' ;
    rdfs:comment 'The date on which the Qualified Person (QP) formally certified and released the IMP batch for clinical use. Required for EU GMP Annex 13 compliance and batch disposition records.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifiedPersonRelease rdf:type rdf:Property ;
    rdfs:label 'Qualified Person Release' ;
    rdfs:comment 'Indicates whether the IMP batch included in this order has been certified and released by a Qualified Person (QP) as required by EU GMP Annex 13 and Directive 2001/20/EC before dispatch to the clinical site.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationKitNumber rdf:type rdf:Property ;
    rdfs:label 'Randomization Kit Number' ;
    rdfs:comment 'The unique kit number assigned by the Interactive Response Technology (IRT) or randomization system to the blinded supply kit. Links the physical supply to the randomization schedule and subject assignment. Critical for blinded trial integrity.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'The date by which the clinical supply must arrive at the investigational site to support the trial schedule. Used for supply chain planning and lead-time management in Kinaxis RapidResponse.' ;
    rdfs:domain ind:ClinicalSupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country from which the clinical supply is dispatched. Used for import/export compliance, customs documentation, and GDP route planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.line. Business justification: Recalls are frequently scoped to a specific manufacturing line (e.g., contamination event on Line 3). FDA recall scope definition and effectiveness checks require direct line-level scoping on the reca' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:manufacturingDeviationId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Deviation Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.manufacturing_deviation. Business justification: Manufacturing deviations are a primary trigger for product recalls. Regulatory CAPA closure and FDA/EMA recall submissions require direct linkage between the causative deviation and the resulting reca' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingDeviation .

ind:affectedMarkets rdf:type rdf:Property ;
    rdfs:label 'Affected Markets' ;
    rdfs:comment 'Comma-separated list of ISO 3-letter country codes (e.g., USA, GBR, DEU) identifying the countries or markets where the recalled product was distributed and where recall actions must be executed.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'The date on which direct customers (wholesalers, distributors, hospitals, pharmacies) were formally notified of the recall via recall notification letters or electronic communications.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Status' ;
    rdfs:comment 'Current status of the customer notification process indicating whether recall notification letters have been sent to all affected customers in the distribution chain.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionLevel rdf:type rdf:Property ;
    rdfs:label 'Distribution Level' ;
    rdfs:comment 'The level in the distribution chain to which the recall extends. Consumer: product reached end patients/consumers; Retail: product at retail pharmacy level; Wholesale: product at wholesale distributor level; Hospital: product at hospital/clinic level; User: product at healthcare professional level.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckLevel rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Level' ;
    rdfs:comment 'FDA-defined effectiveness check level indicating the depth and percentage of consignees to be audited to verify recall notification receipt and product return. Level A: 100% of consignees; Level B: some percentage; Level C: 10% of consignees; Level D: 2% of consignees; Not Required: for certain recall types.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDateRange rdf:type rdf:Property ;
    rdfs:label 'Expiration Date Range' ;
    rdfs:comment 'The expiration date range (e.g., \'2024-01 to 2025-06\') covering all affected lot numbers included in the recall. Assists customers and distributors in identifying recalled product on shelves and in inventory.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthHazardAssessment rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Assessment' ;
    rdfs:comment 'Summary of the health hazard evaluation conducted by the company\'s medical and regulatory teams to assess the risk to patients from the defective product. Supports recall classification and regulatory submission under 21 CFR Part 7.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingAgency rdf:type rdf:Property ;
    rdfs:label 'Initiating Agency' ;
    rdfs:comment 'The regulatory authority or company entity that initiated or mandated the recall. Identifies whether the recall was company-initiated (voluntary) or directed by a specific regulatory body such as FDA, EMA, MHRA, PMDA, or NMPA. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|Company — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Press Release Date' ;
    rdfs:comment 'The date on which the company issued a public press release or public notification regarding the recall. Required for Class I and certain Class II recalls to inform consumers and healthcare professionals.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productDisposition rdf:type rdf:Property ;
    rdfs:label 'Product Disposition' ;
    rdfs:comment 'The approved method for disposing of recovered recalled product. Options include destruction, return to manufacturer, reprocessing, relabeling (where permitted), or quarantine pending further evaluation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDistributed rdf:type rdf:Property ;
    rdfs:label 'Quantity Distributed' ;
    rdfs:comment 'Total quantity of the affected product that was distributed to the market prior to the recall initiation, expressed in the standard unit of measure (e.g., units, bottles, vials). Used to calculate recall effectiveness and track recovery progress.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRecovered rdf:type rdf:Property ;
    rdfs:label 'Quantity Recovered' ;
    rdfs:comment 'Total quantity of the recalled product that has been physically returned, destroyed, or otherwise accounted for as of the last update. Used to calculate recall effectiveness percentage and support regulatory reporting.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure applicable to quantity_distributed and quantity_recovered fields (e.g., EA=Each, BT=Bottle, VL=Vial, AMP=Ampoule, PKG=Package, KG=Kilogram, L=Liter). [ENUM-REF-CANDIDATE: EA|BT|VL|AMP|PKG|KG|L — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClass rdf:type rdf:Property ;
    rdfs:label 'Recall Class' ;
    rdfs:comment 'FDA-defined classification indicating the severity of the health hazard associated with the recalled product. Class I: serious adverse health consequences or death; Class II: temporary or medically reversible adverse health consequences; Class III: unlikely to cause adverse health consequences.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClosureDate rdf:type rdf:Property ;
    rdfs:label 'Recall Closure Date' ;
    rdfs:comment 'The date on which the recall was formally closed or terminated by the regulatory authority or the company after all recall activities, effectiveness checks, and documentation requirements were completed.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallEffectivenessPct rdf:type rdf:Property ;
    rdfs:label 'Recall Effectiveness Pct' ;
    rdfs:comment 'Percentage of distributed product that has been successfully recovered or accounted for, calculated as (quantity_recovered / quantity_distributed) * 100. Key metric for FDA recall effectiveness checks and regulatory reporting under 21 CFR Part 7.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated Date' ;
    rdfs:comment 'The date on which the recall was formally initiated by the company or ordered by the regulatory authority. Represents the principal business event timestamp for the recall lifecycle.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallNotes rdf:type rdf:Property ;
    rdfs:label 'Recall Notes' ;
    rdfs:comment 'Free-text field for additional operational notes, regulatory correspondence summaries, or contextual information relevant to the recall event that is not captured in structured fields.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'Externally-assigned recall identification number issued by the regulatory authority (e.g., FDA recall number) or internally assigned by the company for voluntary recalls. Serves as the primary business identifier for tracking and referencing the recall event across regulatory submissions and communications.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallReasonCode rdf:type rdf:Property ;
    rdfs:label 'Recall Reason Code' ;
    rdfs:comment 'Standardized code categorizing the root cause or reason for the recall (e.g., contamination, labeling error, sub-potency, sterility failure, foreign particulate). Aligns with FDA recall reason taxonomy for regulatory reporting and trend analysis. [ENUM-REF-CANDIDATE: Contamination|Labeling Error|Sub-Potency|Super-Potency|Sterility Failure|Foreign Particulate|Stability Failure|Packaging Defect|Microbial Contamination|Other — promote to reference product]' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Recall Reason Description' ;
    rdfs:comment 'Detailed narrative description of the specific defect, violation, or safety concern that triggered the recall. Provides the full technical and regulatory context beyond the recall reason code, including root cause findings from CAPA investigations.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScope rdf:type rdf:Property ;
    rdfs:label 'Recall Scope' ;
    rdfs:comment 'Geographic scope of the recall indicating whether the recall covers the entire national market, specific regions, international markets, or is limited to a specific manufacturing or distribution site.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Status' ;
    rdfs:comment 'Current lifecycle status of the recall event. Pending: recall initiated but not yet active; Active: recall in progress with field corrections underway; Monitoring: recall effectiveness checks ongoing; Terminated: FDA has terminated the recall; Closed: all recall activities completed and documented.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStrategy rdf:type rdf:Property ;
    rdfs:label 'Recall Strategy' ;
    rdfs:comment 'Description of the recall strategy approved by the regulatory authority or company, including the depth of recall, communication methods, effectiveness check methodology, and disposition instructions for recovered product.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallType rdf:type rdf:Property ;
    rdfs:label 'Recall Type' ;
    rdfs:comment 'Categorization of the recall initiation type. Voluntary recalls are company-initiated; Mandatory recalls are ordered by a regulatory authority; Market Withdrawal involves minor violations not subject to legal action; Stock Recovery involves products not yet distributed to the market.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'The date on which the company formally notified the relevant regulatory authority (e.g., FDA, EMA) of the recall initiation. Critical compliance milestone tracked under 21 CFR Part 7 and equivalent international regulations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commissioningPlantId rdf:type rdf:Property ;
    rdfs:label 'Commissioning Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Serialization commissioning occurs at plants; plant master data provides GMP certification, FDA establishment identifier, regulatory market authorization. Distinct from manufacturing_site_id (manufact' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:dispensingHcpMasterId rdf:type rdf:Property ;
    rdfs:label 'Dispensing Hcp Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.master. Business justification: DSCSA track-and-trace and anti-diversion programs require serialized units to be traceable to the dispensing or administering HCP. Role-prefix \'dispensing_\' distinguishes from patient_id already on th' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:primarySerializationCommissioningSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Serialization Commissioning Site Id' ;
    rdfs:comment 'Reference to the manufacturing or packaging site where the serial number was commissioned. Used for GDP compliance, site-level traceability, and regulatory reporting to FDA/EMA.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Foreign key linking to commercial.sales_order. Business justification: DSCSA (Drug Supply Chain Security Act) compliance requires tracing serialized pharmaceutical units to the sales transaction. Pharma serialization teams link serial numbers to sales orders for transact' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:commissioningEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Commissioning Event Timestamp' ;
    rdfs:comment 'Date and time when the serial number was commissioned (activated and associated with a physical product unit) at the manufacturing or packaging site. Marks the start of the serialized unit\'s lifecycle. Required for DSCSA and EU FMD event reporting.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decommissioningReason rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Reason' ;
    rdfs:comment 'Reason code for decommissioning the serialized unit. Required for EU FMD decommissioning event reporting to the European Medicines Verification System (EMVS). Supports pharmacovigilance and recall management workflows. [ENUM-REF-CANDIDATE: recall|destruction|sample|theft|damage|dispensed|exported|other — promote to reference product]' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissioningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Timestamp' ;
    rdfs:comment 'Date and time when the serialized unit was decommissioned (removed from the active supply chain). Populated when serialization_status transitions to \'decommissioned\' or \'destroyed\'. Required for EU FMD and DSCSA event reporting.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epcisEventCode rdf:type rdf:Property ;
    rdfs:label 'Epcis Event Code' ;
    rdfs:comment 'Unique identifier of the most recent GS1 EPCIS event associated with this serialized unit. Links to the EPCIS event repository for full event history (ObjectEvent, AggregationEvent, TransactionEvent). Used for DSCSA and EU FMD interoperability.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment '14-digit GS1 Global Trade Item Number identifying the pharmaceutical product at the trade item level. Encoded in the 2D DataMatrix barcode on the package. Used for product identification in DSCSA transaction data and EU FMD verification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verification Timestamp' ;
    rdfs:comment 'Date and time of the most recent verification event performed against the medicines verification system (NMVS/EMVS). Used to track verification frequency and identify units that have not been recently verified.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'Quantity and unit of the pharmaceutical product contained in the individual saleable unit (e.g., \'30 tablets\', \'10 mL vial\', \'1 pre-filled syringe\'). Used for dispensing verification and supply chain planning.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingLevel rdf:type rdf:Property ;
    rdfs:label 'Packaging Level' ;
    rdfs:comment 'Level of the packaging hierarchy this serialization record represents. \'unit\' is the individual saleable unit (SGTIN); \'bundle\' is a multi-pack; \'case\' is a shipping case (SSCC); \'pallet\' is a pallet-level aggregation (SSCC). Drives aggregation hierarchy logic.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Serial Number' ;
    rdfs:comment 'Serial number of the immediate parent container in the aggregation hierarchy (e.g., the case serial number for a unit, or the pallet serial number for a case). Enables reconstruction of the full unit→case→pallet aggregation tree for DSCSA and EU FMD compliance.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this serialized unit is subject to an active product recall. Set to TRUE when the unit\'s lot number is included in a recall notification. Enables rapid identification and quarantine of affected units across the supply chain.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryMarketCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market Code' ;
    rdfs:comment 'Regulatory market authorization code or product registration number applicable to the market country. Links the serialized unit to the specific marketing authorization (NDA/BLA/MAA) under which it was released for that market.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleableReturnFlag rdf:type rdf:Property ;
    rdfs:label 'Saleable Return Flag' ;
    rdfs:comment 'Indicates whether this serialized unit has been returned from the market and assessed as eligible for re-entry into the saleable supply chain. Requires verification against the NMVS/EMVS and GDP assessment before re-release.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serializationStatus rdf:type rdf:Property ;
    rdfs:label 'Serialization Status' ;
    rdfs:comment 'Current lifecycle status of the serialized unit within the track-and-trace system. \'commissioned\' = activated at manufacturing; \'active\' = in supply chain; \'shipped\' = dispatched to trading partner; \'returned\' = returned from market; \'decommissioned\' = intentionally removed; \'destroyed\' = physically destroyed.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifier of the originating serialization system or track-and-trace platform (e.g., SAP Advanced Track and Trace for Pharmaceuticals, Tracelink, Serialized Inventory Management System) that generated this record. Used for data lineage and system reconciliation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatementFlag rdf:type rdf:Property ;
    rdfs:label 'Transaction Statement Flag' ;
    rdfs:comment 'Indicates whether a valid DSCSA Transaction Statement has been received and verified for this serialized unit from the upstream trading partner. Required under DSCSA Section 582 for each change of ownership in the pharmaceutical supply chain.' ;
    rdfs:domain ind:SerializationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Result of the most recent verification check of the serialized unit against the national or European medicines verification system (NMVS/EMVS). \'verified\' = authentication passed; \'failed\' = authentication failed (potential falsification); \'pending\' = verification in progress; \'not_verified\' = not yet checked.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMarketCountryId rdf:type rdf:Property ;
    rdfs:label 'Primary Market Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Brands are approved and launched in a primary market country; this drives launch sequencing, market access strategy, and regulatory tracking. primary_market is a denormalized country name. A pharma co' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the brand across commercial systems including Veeva CRM, SAP SD, and Salesforce Health Cloud. Used as the business key for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current operational status of the brand within the commercial organization. Controls whether the brand is eligible for promotional spend, sales force detailing, and market access activities.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalBrandOwner rdf:type rdf:Property ;
    rdfs:label 'Global Brand Owner' ;
    rdfs:comment 'The legal entity name of the global brand owner responsible for the NDA/BLA/MAA and global P&L accountability. Relevant for intercompany transfer pricing, royalty agreements, and IP ownership tracking.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalLaunchSequence rdf:type rdf:Property ;
    rdfs:label 'Global Launch Sequence' ;
    rdfs:comment 'Numeric sequence indicating the order in which this brand was launched globally relative to other brands in the portfolio. Used for portfolio prioritization, resource allocation, and launch excellence benchmarking.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFlagshipBrand rdf:type rdf:Property ;
    rdfs:label 'Is Flagship Brand' ;
    rdfs:comment 'Indicates whether this brand is designated as a flagship or priority brand by commercial leadership, warranting elevated promotional investment, dedicated sales force, and executive-level performance reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date on which the brand was first commercially available in its primary market following regulatory approval. Used as the anchor date for launch performance tracking, market share ramp analysis, and P&L reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossOfExclusivityDate rdf:type rdf:Property ;
    rdfs:label 'Loss Of Exclusivity Date' ;
    rdfs:comment 'The projected or confirmed date on which the brand\'s market exclusivity expires, enabling generic or biosimilar competition. Critical for long-range financial planning, patent strategy, and lifecycle management decisions.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plCostCenter rdf:type rdf:Property ;
    rdfs:label 'Pl Cost Center' ;
    rdfs:comment 'The SAP cost center code to which all brand-level revenues, promotional spend, and COGS are allocated for P&L reporting. Enables brand-level financial performance tracking and budget variance analysis.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCompetitorBrands rdf:type rdf:Property ;
    rdfs:label 'Primary Competitor Brands' ;
    rdfs:comment 'Comma-separated list of key competitor brand names in the same therapeutic class. Used for competitive intelligence, market share benchmarking, and sales force training. Classified as confidential competitive intelligence.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'The SAP profit center assigned to the brand for internal management accounting and brand-level P&L reporting. Distinct from cost center; used for contribution margin analysis and brand portfolio performance reporting.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleEligible rdf:type rdf:Property ;
    rdfs:label 'Sample Eligible' ;
    rdfs:comment 'Indicates whether the brand is eligible for distribution of drug samples to healthcare professionals (HCPs) by the sales force. Controlled by PDMA regulations and PhRMA code. DEA scheduled products and REMS products may have restrictions.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Number' ;
    rdfs:comment 'The SAP material master number assigned to the brand\'s primary commercial SKU in SAP S/4HANA MM/SD modules. Used for order management, COGS tracking, and supply chain integration.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyStatement rdf:type rdf:Property ;
    rdfs:label 'Strategy Statement' ;
    rdfs:comment 'The overarching commercial strategy statement for the brand, capturing positioning, differentiation, and value proposition relative to competitors. Classified as confidential business strategy. Sourced from the brand plan approved by commercial leadership.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunshineActReportable rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Reportable' ;
    rdfs:comment 'Indicates whether transfers of value associated with this brand (samples, speaker fees, meals, educational grants) are subject to Open Payments (Sunshine Act) reporting to CMS. Drives compliance workflows in Veeva CRM and SAP.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaCrmProductCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Product Code' ;
    rdfs:comment 'The product identifier assigned to this brand in Veeva CRM (Salesforce Health Cloud), used to link brand records to HCP call activity, sample transactions, promotional material approvals (PromoMats), and speaker program events.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBrandId rdf:type rdf:Property ;
    rdfs:label 'Primary Brand Id' ;
    rdfs:comment 'FK to commercial.brand' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:alignmentVersion rdf:type rdf:Property ;
    rdfs:label 'Alignment Version' ;
    rdfs:comment 'Version identifier of the territory alignment cycle that produced this territory definition (e.g., \'FY2024-Q1\', \'ALIGN-2024-H2\'). Enables tracking of territory changes across realignment cycles and supports historical performance attribution.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'Code identifying the sales area (highest-level geographic grouping above region) to which this territory belongs. Supports national-level roll-up reporting and executive P&L attribution.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brickCount rdf:type rdf:Property ;
    rdfs:label 'Brick Count' ;
    rdfs:comment 'Number of geographic \'bricks\' (smallest geographic unit used in pharmaceutical territory alignment, typically a ZIP+4 or sub-ZIP unit) assigned to this territory. Used to measure territory size and workload balance during alignment planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callPlanFrequency rdf:type rdf:Property ;
    rdfs:label 'Call Plan Frequency' ;
    rdfs:comment 'Target number of calls (HCP visits) per representative per cycle (typically quarterly) for this territory as defined in the call plan. Used for field force productivity measurement and compliance tracking in Veeva CRM.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countyList rdf:type rdf:Property ;
    rdfs:label 'County List' ;
    rdfs:comment 'Semicolon-delimited list of county names or FIPS county codes included within this territory\'s geographic boundary. Complements ZIP code alignment for rural territory definitions and Sunshine Act county-level reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Crm Territory Code' ;
    rdfs:comment 'Native territory identifier from the source CRM system (Veeva CRM or Salesforce Health Cloud). Used for cross-system reconciliation, data lineage tracing, and integration with call activity and sample distribution records.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decileRank rdf:type rdf:Property ;
    rdfs:label 'Decile Rank' ;
    rdfs:comment 'Decile ranking (1–10) of the territory based on market potential or historical sales performance relative to all territories in the same alignment. Decile 1 represents the highest-potential territories. Used for resource allocation and call frequency prioritization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicAreaSqMiles rdf:type rdf:Property ;
    rdfs:label 'Geographic Area Sq Miles' ;
    rdfs:comment 'Total geographic area of the territory in square miles. Used to assess travel burden for field representatives and to balance territory workload during alignment planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOpenTerritory rdf:type rdf:Property ;
    rdfs:label 'Is Open Territory' ;
    rdfs:comment 'Indicates whether the territory is currently unassigned (open) with no active field representative. Open territories require coverage planning and may be temporarily covered by adjacent representatives or district managers.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpecialtyOverlay rdf:type rdf:Property ;
    rdfs:label 'Is Specialty Overlay' ;
    rdfs:comment 'Indicates whether this territory is a specialty overlay territory that operates in conjunction with a primary territory (e.g., an oncology specialist overlay on top of a primary care territory). Used to manage co-promotion and dual-rep call planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRealignmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Realignment Date' ;
    rdfs:comment 'Date on which this territory\'s boundaries, targets, or assignments were last modified as part of a formal territory realignment exercise. Used to track alignment cycle history and assess the currency of territory definitions.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketPotentialIndex rdf:type rdf:Property ;
    rdfs:label 'Market Potential Index' ;
    rdfs:comment 'Normalized index score (typically 0.0000–9.9999) representing the estimated prescribing potential of the territory based on IQVIA/IQVIA data, patient population, and payer mix. Used for territory sizing, quota setting, and alignment optimization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 state or province code for the primary state/province covered by this territory (e.g., \'NY\', \'CA\', \'ON\'). Used for geographic boundary definition, Sunshine Act state-level reporting, and call planning.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunshineActReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Reporting Required' ;
    rdfs:comment 'Indicates whether HCP engagement activities within this territory are subject to mandatory Open Payments (Sunshine Act) transparency reporting to CMS. Typically true for US territories; false for territories outside US jurisdiction.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAccountCount rdf:type rdf:Property ;
    rdfs:label 'Target Account Count' ;
    rdfs:comment 'Number of institutional accounts (hospitals, clinics, group practices, IDNs) designated as call targets within this territory. Used for key account planning and workload analysis.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetHcpCount rdf:type rdf:Property ;
    rdfs:label 'Target Hcp Count' ;
    rdfs:comment 'Number of Healthcare Professionals (HCPs) designated as call targets within this territory for the current alignment cycle. Used for workload balancing, call planning, and field force sizing analysis.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the territory within the field force alignment system. Used as the business key in Veeva CRM and Salesforce Health Cloud for call planning and target assignment.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the sales territory (e.g., \'Northeast Oncology Zone 3\'). Used for display in CRM dashboards, call planning tools, and performance reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory record. Active territories are in use for call planning and performance attribution; inactive territories have been decommissioned; pending territories are awaiting activation in a future alignment cycle; archived territories are retained for historical reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory by its role in the field force structure. Primary territories are standard rep assignments; secondary territories represent overlapping coverage; specialty territories cover specific therapeutic areas; managed_care and key_account types address payer and institutional customers.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urbanRuralClassification rdf:type rdf:Property ;
    rdfs:label 'Urban Rural Classification' ;
    rdfs:comment 'Classification of the territory\'s geographic character as urban, suburban, rural, or mixed. Influences call planning strategy, travel time estimates, and field force resource allocation decisions.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workloadIndex rdf:type rdf:Property ;
    rdfs:label 'Workload Index' ;
    rdfs:comment 'Composite index score measuring the estimated field representative workload for this territory, factoring in target HCP count, call frequency, geographic travel burden, and account complexity. Used for territory balancing during alignment cycles.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zipCodeList rdf:type rdf:Property ;
    rdfs:label 'Zip Code List' ;
    rdfs:comment 'Semicolon-delimited list of US ZIP codes (or equivalent postal codes) that define the geographic boundary of this territory. Used for HCP target assignment, call planning, and territory alignment in Veeva CRM. Stored as a delimited string per Silver Layer conventions; spatial decomposition occurs in the Gold Layer.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualCallTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Call Target' ;
    rdfs:comment 'Target number of HCP sales calls (details) the representative is expected to complete within the fiscal year, as set by the commercial operations team. Used for field force productivity tracking and performance management in Veeva CRM.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callPlanFrequencyTarget rdf:type rdf:Property ;
    rdfs:label 'Call Plan Frequency Target' ;
    rdfs:comment 'Target number of HCP calls per cycle for this specific rep-territory assignment. Differs by rep role and territory type — an overlay rep may have a lower target than the primary rep for the same territory. Identified in detection phase as relationship-level data.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date on which the sales representative\'s current product or compliance certification expires. Triggers re-certification workflows and may restrict sample distribution or promotional activity if expired.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment lifecycle status of the sales representative. Drives CRM access provisioning, territory assignment eligibility, sample authorization, and Sunshine Act reporting inclusion. Active = currently employed and field-active; On Leave = temporary absence (FMLA, medical, parental); Terminated = employment ended; Suspended = temporarily restricted from field activity; Pending Start = hired but not yet active.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpCertified rdf:type rdf:Property ;
    rdfs:label 'Gcp Certified' ;
    rdfs:comment 'Indicates whether the sales representative holds a current Good Clinical Practice (GCP) certification. Required for MSLs and reps supporting clinical trial site engagement or investigator-initiated study discussions. Sourced from the Learning Management System (LMS).' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcpEngagementTier rdf:type rdf:Property ;
    rdfs:label 'Hcp Engagement Tier' ;
    rdfs:comment 'Classification of the sales representative\'s HCP engagement level based on the complexity and strategic importance of their account portfolio. Tier 1 = high-value specialist/KOL accounts; Tier 2 = mid-level specialist accounts; Tier 3 = primary care/general accounts. Drives call frequency targets and resource allocation.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Official date on which the sales representative was hired by the organization, as recorded in the HR system of record (SAP S/4HANA). Used for tenure calculations, vesting schedules, and compliance reporting.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title of the sales representative as recorded in the HR system (e.g., \'Senior Specialty Sales Representative\', \'Oncology Territory Manager\', \'Medical Science Liaison\'). Used for organizational reporting and external business card / signature purposes.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Product Certification Status' ;
    rdfs:comment 'Current status of the sales representative\'s product knowledge certification for their assigned brand(s). Reps must be certified before being authorized to promote a product or distribute samples. Sourced from the LMS or MasterControl/TrackWise training records.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repRole rdf:type rdf:Property ;
    rdfs:label 'Rep Role' ;
    rdfs:comment 'Commercial field force role classification defining the rep\'s function and engagement model. Territory Manager (TM) handles primary care accounts; Specialty Rep focuses on specialist HCPs; Key Account Manager (KAM) manages institutional/payer accounts; Medical Science Liaison (MSL) provides scientific exchange; Managed Care Specialist handles formulary access; National Account Manager handles national-level payer/GPO relationships. [ENUM-REF-CANDIDATE: territory_manager|specialty_rep|key_account_manager|medical_science_liaison|managed_care_specialist|national_account_manager — promote to reference product]' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Authorization Status' ;
    rdfs:comment 'Current authorization status of the sales representative to distribute drug samples to HCPs. Governed by the Prescription Drug Marketing Act (PDMA) and PhRMA Code. Suspended or revoked status prevents sample transactions in Veeva CRM.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speakerProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Speaker Program Eligible' ;
    rdfs:comment 'Indicates whether the sales representative is authorized to organize or facilitate HCP speaker programs on behalf of the company. Eligibility requires completion of speaker program compliance training and manager approval. Governed by PhRMA Code and OIG guidelines.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaCrmUserCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm User Code' ;
    rdfs:comment 'Unique user identifier assigned to the sales representative within Veeva CRM (Salesforce Health Cloud / Veeva CRM). Used to link field activity records, call logs, HCP interactions, and sample transactions back to the rep. Critical for CRM data lineage and compliance reporting.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaPromomatsAccess rdf:type rdf:Property ;
    rdfs:label 'Veeva Promomats Access' ;
    rdfs:comment 'Indicates whether the sales representative has active access to Veeva PromoMats for retrieving approved promotional materials. Access is role-based and tied to brand assignment and certification status. Ensures only MLR-approved content is used in HCP interactions.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'Corporate email address of the sales representative used for official business communications, Veeva CRM login, and system notifications. Sourced from the enterprise directory (e.g., Active Directory / SAP S/4HANA).' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'Primary corporate mobile or desk phone number assigned to the sales representative for field communications and HCP engagement. Sourced from HR or CRM system.' ;
    rdfs:domain ind:SalesRep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpTargetId rdf:type rdf:Property ;
    rdfs:label 'Hcp Target Id' ;
    rdfs:comment 'Unique surrogate identifier for the HCP targeting and call planning record within the commercial segmentation and planning layer.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HcpTarget .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the targeting plan record was formally approved by the authorized sales manager or commercial operations team. Marks the transition from planning to execution.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callTypeMixPctF2f rdf:type rdf:Property ;
    rdfs:label 'Call Type Mix Pct F2f' ;
    rdfs:comment 'Percentage of total planned calls that are designated as face-to-face interactions (0.00–100.00). Used to monitor adherence to brand-level call mix strategy and field force deployment guidelines.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorPrescriber rdf:type rdf:Property ;
    rdfs:label 'Competitor Prescriber' ;
    rdfs:comment 'Indicates whether the HCP is known to prescribe a competing product in the same therapeutic class. Used to prioritize conversion-focused engagement strategies and messaging.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentBrandPrescriber rdf:type rdf:Property ;
    rdfs:label 'Current Brand Prescriber' ;
    rdfs:comment 'Indicates whether the HCP is currently an active prescriber of the targeted brand based on the most recent prescribing data. Distinguishes new-to-brand targets from existing prescribers for tailored engagement strategies.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCallCount rdf:type rdf:Property ;
    rdfs:label 'Cycle Call Count' ;
    rdfs:comment 'Number of completed sales calls made to this HCP for the targeted brand within the current cycle plan period. Used to measure in-cycle execution progress against planned_call_frequency.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Indicates that this HCP has requested no promotional contact or has been placed on a do-not-contact list. When true, field force must not initiate promotional calls. Critical for compliance with HCP opt-out preferences and applicable privacy regulations.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementChannelPreference rdf:type rdf:Property ;
    rdfs:label 'Engagement Channel Preference' ;
    rdfs:comment 'HCP\'s preferred channel for sales representative engagement as captured in Veeva CRM or Salesforce Health Cloud. Informs call type mix planning and omnichannel engagement strategy.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKol rdf:type rdf:Property ;
    rdfs:label 'Is Kol' ;
    rdfs:comment 'Indicates whether this HCP is designated as a Key Opinion Leader (KOL) for the targeted brand or therapeutic area. KOL status influences engagement strategy, speaker program eligibility, and medical affairs coordination.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSampleEligible rdf:type rdf:Property ;
    rdfs:label 'Is Sample Eligible' ;
    rdfs:comment 'Indicates whether this HCP is eligible to receive drug samples for the targeted brand. Governed by the Prescription Drug Marketing Act (PDMA) and internal sample distribution policies.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpeakerEligible rdf:type rdf:Property ;
    rdfs:label 'Is Speaker Eligible' ;
    rdfs:comment 'Indicates whether this HCP is eligible to participate in brand speaker programs. Eligibility is governed by PhRMA Code compliance, Sunshine Act reporting requirements, and internal speaker bureau criteria.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDetailDate rdf:type rdf:Property ;
    rdfs:label 'Last Detail Date' ;
    rdfs:comment 'Date of the most recent promotional detail (sales call) made to this HCP for the targeted brand. Used to monitor call recency, identify lapsed targets, and prioritize field force scheduling.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketPotentialSegment rdf:type rdf:Property ;
    rdfs:label 'Market Potential Segment' ;
    rdfs:comment 'Categorical assessment of the HCP\'s overall market potential for the brand, derived from prescribing volume, patient panel size, and payer mix. Used alongside prescribing_potential_decile for targeting decisions.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCallFrequency rdf:type rdf:Property ;
    rdfs:label 'Planned Call Frequency' ;
    rdfs:comment 'Target number of sales calls (details) planned for this HCP during the cycle plan period. Drives field force scheduling and activity quotas in Veeva CRM.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedF2fCalls rdf:type rdf:Property ;
    rdfs:label 'Planned F2f Calls' ;
    rdfs:comment 'Number of planned in-person (face-to-face) sales calls for this HCP within the cycle. Part of the call type mix alongside remote calls. Supports field force activity planning and compliance with call mix targets.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedRemoteCalls rdf:type rdf:Property ;
    rdfs:label 'Planned Remote Calls' ;
    rdfs:comment 'Number of planned remote (virtual/telephone) sales calls for this HCP within the cycle. Complements planned_f2f_calls to define the full call type mix for the planning period.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescribingPotentialDecile rdf:type rdf:Property ;
    rdfs:label 'Prescribing Potential Decile' ;
    rdfs:comment 'Decile ranking (1–10) of the HCP\'s estimated prescribing potential for the targeted brand\'s therapeutic area, derived from claims data or market research. Decile 10 = highest prescribing potential. Key input to target tier assignment.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric rank of this HCP target within the territory for the given brand and cycle plan. Lower rank = higher priority. Used to sequence call planning when field force capacity is constrained.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialtySegment rdf:type rdf:Property ;
    rdfs:label 'Specialty Segment' ;
    rdfs:comment 'Medical specialty segment of the HCP as used for commercial targeting purposes (e.g., Oncology, Cardiology, Immunology, Primary Care). May differ from the HCP master specialty if the brand targets a sub-specialty. [ENUM-REF-CANDIDATE: oncology|cardiology|immunology|primary_care|neurology|endocrinology|rheumatology|hematology|gastroenterology|pulmonology — promote to reference product]' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Target Record Number' ;
    rdfs:comment 'Business-facing unique identifier for this HCP target record, used in Veeva CRM and downstream reporting. Distinct from the surrogate hcp_target_id.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTier rdf:type rdf:Property ;
    rdfs:label 'Target Tier' ;
    rdfs:comment 'Segmentation tier assigned to the HCP for this brand and cycle, reflecting strategic priority for field force engagement. Tier A = highest priority, Tier D = lowest. Drives call frequency and resource allocation.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingRationale rdf:type rdf:Property ;
    rdfs:label 'Targeting Rationale' ;
    rdfs:comment 'Free-text or structured justification for why this HCP has been selected and tiered for this brand and cycle. May reference prescribing behavior, patient population, KOL status, or market development opportunity.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingStatus rdf:type rdf:Property ;
    rdfs:label 'Targeting Status' ;
    rdfs:comment 'Current lifecycle status of this HCP target record within the planning cycle. Active = currently targeted; Inactive = de-prioritized; Pending = awaiting approval; Suspended = temporarily paused; Removed = excluded from targeting.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaCrmRecordCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Record Code' ;
    rdfs:comment 'Source system record identifier from Veeva CRM corresponding to this HCP target record. Used for data lineage, reconciliation, and integration with the Veeva CRM operational system.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ytdCallCount rdf:type rdf:Property ;
    rdfs:label 'Ytd Call Count' ;
    rdfs:comment 'Number of completed sales calls (details) made to this HCP for the targeted brand in the current year-to-date period. Tracks field force execution against planned call frequency targets.' ;
    rdfs:domain ind:HcpTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callActivityId rdf:type rdf:Property ;
    rdfs:label 'Call Activity Id' ;
    rdfs:comment 'Unique surrogate identifier for each field force call activity record in the Databricks Silver layer. Primary key for the call_activity data product.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CallActivity .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Foreign key linking to hcp.consent_record. Business justification: GDPR/HIPAA compliance requires call records to reference a valid HCP consent record. Pharma CRM audit trails must prove consent was active at time of engagement. A pharma compliance officer would expe' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentRecord .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'The calendar date on which the field force interaction (detail call) took place. Principal business event date used for field force effectiveness reporting and Sunshine Act transparency reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call End Timestamp' ;
    rdfs:comment 'Precise date and time when the call interaction concluded, as recorded in Veeva CRM. Used together with call_start_timestamp to derive call duration for field force effectiveness analytics.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callNotes rdf:type rdf:Property ;
    rdfs:label 'Call Notes' ;
    rdfs:comment 'Free-text narrative entered by the sales representative summarizing the content and outcome of the interaction. Classified as confidential due to potential inclusion of commercially sensitive HCP engagement details.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callObjective rdf:type rdf:Property ;
    rdfs:label 'Call Objective' ;
    rdfs:comment 'Pre-call stated objective or purpose of the interaction as entered by the sales representative in Veeva CRM. Supports pre-call planning analytics and coaching.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callOutcome rdf:type rdf:Property ;
    rdfs:label 'Call Outcome' ;
    rdfs:comment 'Result of the call attempt as recorded by the sales representative. \'No_see\' indicates the HCP was unavailable. Used for field force effectiveness and access rate analytics.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Start Timestamp' ;
    rdfs:comment 'Precise date and time when the call interaction began, as recorded in Veeva CRM. Used for call duration calculation and scheduling compliance.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callStatus rdf:type rdf:Property ;
    rdfs:label 'Call Status' ;
    rdfs:comment 'Current lifecycle state of the call activity record within Veeva CRM workflow. \'Submitted\' indicates the rep has locked the record; \'Approved\' indicates manager sign-off has been completed.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callType rdf:type rdf:Property ;
    rdfs:label 'Call Type' ;
    rdfs:comment 'Classification of the interaction channel used for the detail call. Drives field force effectiveness segmentation and PhRMA code compliance checks. [ENUM-REF-CANDIDATE: face_to_face|remote_video|phone|email|congress|group_meeting|medical_education_event — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMixCode rdf:type rdf:Property ;
    rdfs:label 'Channel Mix Code' ;
    rdfs:comment 'Categorizes the call within the omnichannel engagement model (field, inside sales, digital, or hybrid). Supports channel mix optimization analytics and commercial strategy reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Crm Sync Timestamp' ;
    rdfs:comment 'Timestamp when the call record was last synchronized from Veeva CRM into the Databricks Silver layer. Used for data freshness monitoring and pipeline audit.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detailPriority1Product rdf:type rdf:Property ;
    rdfs:label 'Detail Priority 1 Product' ;
    rdfs:comment 'Brand name of the first-priority product detailed during the call, as recorded in Veeva CRM. Retained as a denormalized field for reporting convenience and Sunshine Act submission.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detailPriority2Product rdf:type rdf:Property ;
    rdfs:label 'Detail Priority 2 Product' ;
    rdfs:comment 'Brand name of the second-priority product detailed during the call, if applicable. Supports multi-product detailing analysis and share-of-voice reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detailPriority3Product rdf:type rdf:Property ;
    rdfs:label 'Detail Priority 3 Product' ;
    rdfs:comment 'Brand name of the third-priority product detailed during the call, if applicable. Supports multi-product detailing analysis and share-of-voice reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpReaction rdf:type rdf:Property ;
    rdfs:label 'Hcp Reaction' ;
    rdfs:comment 'Sales representative\'s assessment of the Healthcare Professional\'s reaction to the product detail during the call. Used for HCP engagement scoring and brand sentiment analytics.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolFlag rdf:type rdf:Property ;
    rdfs:label 'Kol Flag' ;
    rdfs:comment 'Indicates whether the HCP visited during this call is classified as a Key Opinion Leader (KOL). Used for KOL engagement tracking and Medical Affairs coordination.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealCostUsd rdf:type rdf:Property ;
    rdfs:label 'Meal Cost Usd' ;
    rdfs:comment 'Actual cost in US dollars of the meal or refreshment provided during the call. Used for PhRMA Code per-person meal cap compliance monitoring and Sunshine Act reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Provided Flag' ;
    rdfs:comment 'Indicates whether a meal or refreshment was provided to the HCP or HCO staff during this call. Required for PhRMA Code compliance and Sunshine Act transfer-of-value reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextBestAction rdf:type rdf:Property ;
    rdfs:label 'Next Best Action' ;
    rdfs:comment 'Recommended follow-up action for the sales representative as determined by the CRM system or rep input (e.g., schedule follow-up call, send clinical reprint, invite to speaker program). Supports field force coaching and CRM-driven engagement planning.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offLabelDiscussionFlag rdf:type rdf:Property ;
    rdfs:label 'Off Label Discussion Flag' ;
    rdfs:comment 'Indicates whether any off-label (unapproved indication) discussion occurred during the call. Classified as confidential due to regulatory sensitivity. Triggers compliance review workflow when True.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phrmaCodeCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Phrma Code Compliant Flag' ;
    rdfs:comment 'Indicates whether the call activity was conducted in full compliance with the PhRMA Code on Interactions with Healthcare Professionals. Used for internal compliance monitoring and audit reporting.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promoMaterialVersion rdf:type rdf:Property ;
    rdfs:label 'Promo Material Version' ;
    rdfs:comment 'Version identifier of the promotional material presented during the call, as tracked in Veeva PromoMats. Ensures only current, approved versions are used in the field.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleLotNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Lot Number' ;
    rdfs:comment 'Manufacturing lot number of the drug samples distributed during the call. Required for PDMA sample accountability and product recall traceability.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Total number of drug sample units distributed to the HCP during this call. Used for PDMA sample accountability reconciliation and Sunshine Act transfer-of-value reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplesDroppedFlag rdf:type rdf:Property ;
    rdfs:label 'Samples Dropped Flag' ;
    rdfs:comment 'Indicates whether drug samples were distributed to the HCP during this call. Drives sample accountability reporting and Prescription Drug Marketing Act (PDMA) compliance.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Captured Flag' ;
    rdfs:comment 'Indicates whether the HCP\'s electronic signature was captured during this call, as required for sample distribution under PDMA. A value of True confirms regulatory signature compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:speakerProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Speaker Program Flag' ;
    rdfs:comment 'Indicates whether this call activity is associated with or resulted from a speaker program event. Links commercial call data to speaker program compliance and Sunshine Act reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Timestamp when the sales representative locked and submitted the call record in Veeva CRM, transitioning it from draft to submitted status. Key lifecycle event for field force compliance monitoring.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sunshineActReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Reportable Flag' ;
    rdfs:comment 'Indicates whether this call activity constitutes a reportable transfer of value under the Physician Payments Sunshine Act (Open Payments). Drives inclusion in the annual CMS Open Payments submission.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferOfValueUsd rdf:type rdf:Property ;
    rdfs:label 'Transfer Of Value Usd' ;
    rdfs:comment 'Monetary value in US dollars of any transfer of value (e.g., meals, samples, educational materials) provided to the HCP during this call, as required for Sunshine Act Open Payments reporting.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veevaCallCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Call Code' ;
    rdfs:comment 'Source system identifier for the call record as assigned by Veeva CRM. Used for lineage tracing and deduplication against the operational system of record.' ;
    rdfs:domain ind:CallActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleManagementId rdf:type rdf:Property ;
    rdfs:label 'Sample Management Id' ;
    rdfs:comment 'Primary key for sample_management' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseId rdf:type rdf:Property ;
    rdfs:label 'License Id' ;
    rdfs:comment 'Foreign key linking to hcp.license. Business justification: DEA and state regulations require verifying HCP license validity before dispensing samples. sample_management stores hcp_license_number as a denormalized string; linking to hcp.license.license_id enab' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:License .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Reason code for a sample inventory adjustment. Required for PDMA compliance when quantity_adjusted is non-zero. [ENUM-REF-CANDIDATE: expired|damaged|lost|stolen|count_correction|returned_to_warehouse|destroyed — promote to reference product]' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyQuantity rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Quantity' ;
    rdfs:comment 'Net difference between the physical count and the system-recorded quantity on hand during reconciliation. Non-zero values trigger a PDMA compliance investigation. Positive = overage; Negative = shortage.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hcpDeaNumber rdf:type rdf:Property ;
    rdfs:label 'Hcp Dea Number' ;
    rdfs:comment 'DEA registration number of the HCP, required when distributing controlled substance samples. Validates prescribing authority for scheduled drug samples per DEA regulations.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Hcp Signature Captured' ;
    rdfs:comment 'Indicates whether the HCP\'s electronic signature was captured at the time of sample disbursement, as required by PDMA. True = signature obtained; False = signature not obtained (requires justification).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcpSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hcp Signature Timestamp' ;
    rdfs:comment 'Date and time when the HCP\'s electronic signature was captured for the sample disbursement. Required for 21 CFR Part 11 electronic records compliance and PDMA audit trail.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryNumber rdf:type rdf:Property ;
    rdfs:label 'Inventory Number' ;
    rdfs:comment 'Externally-known business identifier for this sample inventory position record. Used for PDMA audit trails, reconciliation reports, and regulatory submissions. Generated by the sample management system (Veeva CRM or SAP MM).' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle state of the sample inventory position. Active = open and in use; Reconciled = periodic reconciliation completed; Closed = inventory position closed; Suspended = temporarily frozen pending investigation; Pending Review = flagged for compliance review.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'Number of units (tablets, capsules, vials, etc.) contained in each sample package. Used to calculate total units disbursed and for PDMA annual accountability reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdmaCompliant rdf:type rdf:Property ;
    rdfs:label 'Pdma Compliant' ;
    rdfs:comment 'Indicates whether this sample transaction meets all PDMA compliance requirements (HCP signature captured, valid license verified, request form on file, quantity within limits). True = compliant; False = non-compliant, requires remediation.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityAdjusted rdf:type rdf:Property ;
    rdfs:label 'Quantity Adjusted' ;
    rdfs:comment 'Net quantity adjustment applied to the inventory position (positive = increase, negative = decrease). Used for inventory corrections, expired sample write-offs, and reconciliation discrepancy resolution.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityDisbursed rdf:type rdf:Property ;
    rdfs:label 'Quantity Disbursed' ;
    rdfs:comment 'Number of sample units disbursed to a Healthcare Professional (HCP) in this transaction. Zero for non-disbursement transaction types. Used for PDMA annual sample accountability and Sunshine Act reporting.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Number of sample units received by the sales representative from the warehouse, CMO, or another rep in this transaction. Zero for non-receipt transaction types.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationPeriod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period' ;
    rdfs:comment 'The fiscal quarter (e.g., \'2024-Q1\') to which this inventory reconciliation record belongs. PDMA requires periodic reconciliation of sample inventories. Used for compliance reporting and audit.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleFormType rdf:type rdf:Property ;
    rdfs:label 'Sample Form Type' ;
    rdfs:comment 'Finished dosage form (FDF) type of the sample product (e.g., tablet, capsule, injectable). Used for inventory categorization, storage planning, and regulatory reporting. [ENUM-REF-CANDIDATE: tablet|capsule|injectable|topical|inhaler|liquid|patch|other — promote to reference product]' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequestFormNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Request Form Number' ;
    rdfs:comment 'Reference number of the HCP\'s written or electronic sample request form (SRF) associated with this disbursement. PDMA requires a signed request for each sample disbursement. Links to the eTMF or Veeva Vault document.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The real-world business date on which the sample transaction (disbursement, receipt, transfer, etc.) occurred. Used as the principal event date for PDMA reporting and Sunshine Act transparency reporting.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Precise date and time when the sample transaction was recorded in the system (Veeva CRM or SAP). Provides sub-day precision for audit trail and compliance investigations.' ;
    rdfs:domain ind:SampleManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aggregateDecision rdf:type rdf:Property ;
    rdfs:label 'Aggregate Decision' ;
    rdfs:comment 'Overall consolidated MLR committee decision for the current review cycle, reflecting the combined outcome of medical, legal, and regulatory reviewer decisions. Drives the approval_status field transition.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentOwner rdf:type rdf:Property ;
    rdfs:label 'Content Owner' ;
    rdfs:comment 'Name or employee identifier of the brand team member or marketing manager who owns and is accountable for the promotional material content, including initiating the MLR submission and managing the approval lifecycle.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairBalanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Fair Balance Included' ;
    rdfs:comment 'Indicates whether the promotional material includes the required fair balance statement (risk information) as mandated by FDA 21 CFR Part 202.1 for prescription drug advertising. Must be True for all HCP-directed materials.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isiIncluded rdf:type rdf:Property ;
    rdfs:label 'Isi Included' ;
    rdfs:comment 'Indicates whether the Important Safety Information (ISI) section is included in the promotional material, as required for HCP-directed promotional pieces under FDA promotional regulations.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastResubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Resubmission Date' ;
    rdfs:comment 'Date of the most recent resubmission of this promotional material to the MLR committee after a prior rejection or change request. Null if the material has never been resubmitted.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalDecision rdf:type rdf:Property ;
    rdfs:label 'Legal Decision' ;
    rdfs:comment 'Individual decision rendered by the Legal reviewer for the current MLR review cycle. All three reviewer decisions must be \'approved\' for aggregate approval.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewer rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer' ;
    rdfs:comment 'Name or employee identifier of the assigned Legal reviewer responsible for evaluating legal risk, intellectual property, and fair balance claims in the promotional material during the MLR review.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the promotional material across commercial operations, field force systems, and print/digital distribution. Used on physical materials and in Veeva CRM detailing records.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalDecision rdf:type rdf:Property ;
    rdfs:label 'Medical Decision' ;
    rdfs:comment 'Individual decision rendered by the Medical Affairs reviewer for the current MLR review cycle. All three reviewer decisions (medical, legal, regulatory) must be \'approved\' for aggregate approval.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlrSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Mlr Submission Date' ;
    rdfs:comment 'Date on which the promotional material was formally submitted to the MLR review committee for the current review cycle. Triggers the review SLA clock.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piReferenceIncluded rdf:type rdf:Property ;
    rdfs:label 'Pi Reference Included' ;
    rdfs:comment 'Indicates whether a reference to the full Prescribing Information (PI) or a brief summary thereof is included in the promotional material, as required by FDA 21 CFR Part 202.1(e).' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryDecision rdf:type rdf:Property ;
    rdfs:label 'Regulatory Decision' ;
    rdfs:comment 'Individual decision rendered by the Regulatory Affairs reviewer for the current MLR review cycle. All three reviewer decisions must be \'approved\' for aggregate approval.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReviewer rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reviewer' ;
    rdfs:comment 'Name or employee identifier of the assigned Regulatory Affairs reviewer responsible for evaluating compliance with FDA labeling, 21 CFR Part 202, and applicable EMA/MHRA promotional guidelines during the MLR review.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Consolidated reviewer comments and required changes from the current MLR review cycle. Captured from Veeva PromoMats annotations and used to guide content revisions prior to resubmission.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Number' ;
    rdfs:comment 'Sequential integer indicating which review cycle this version of the material is in. Increments with each resubmission following a rejection or request for changes. Cycle 1 is the initial submission.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplePiece rdf:type rdf:Property ;
    rdfs:label 'Sample Piece' ;
    rdfs:comment 'Indicates whether this material is a sample or specimen piece used for internal review, training, or regulatory submission purposes, as opposed to a commercially distributed piece.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Intended recipient audience for the promotional material. Drives compliance review requirements — HCP-directed materials require full MLR review; patient materials require additional plain-language review.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Vault Document Code' ;
    rdfs:comment 'The native document identifier assigned by Veeva Vault PromoMats, used to cross-reference the record in the source system of record.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionLineage rdf:type rdf:Property ;
    rdfs:label 'Version Lineage' ;
    rdfs:comment 'Pipe-delimited or comma-separated list of predecessor material numbers and version identifiers representing the full version history chain for this material. Supports audit trail and content genealogy tracking in Veeva PromoMats.' ;
    rdfs:domain ind:PromoMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlId rdf:type rdf:Property ;
    rdfs:label 'Change Control Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_change_control. Business justification: MLR reviews must be re-initiated when a change control modifies product labeling, approved claims, or promotional content. Regulatory requirement: labeling changes trigger mandatory MLR re-review. Pha' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeControl .

ind:priorSubmissionMlrReviewId rdf:type rdf:Property ;
    rdfs:label 'Prior Submission Mlr Review Id' ;
    rdfs:comment 'Reference to the previous MLR review record for the same promotional material, enabling resubmission history tracking and cycle lineage. Null for initial submissions (review_cycle_number = 1).' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MlrReview .

ind:approvalDecision rdf:type rdf:Property ;
    rdfs:label 'Approval Decision' ;
    rdfs:comment 'Final consolidated approval decision rendered by the MLR committee upon completion of all three review streams (medical, legal, regulatory). Null until the review is concluded.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairBalanceVerified rdf:type rdf:Property ;
    rdfs:label 'Fair Balance Verified' ;
    rdfs:comment 'Indicates whether the promotional material includes adequate fair balance presentation of risks and benefits as required by FDA regulations for prescription drug advertising.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date on which the legal reviewer completed their review and rendered a decision for this review cycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Review Status' ;
    rdfs:comment 'Current decision status from the legal reviewer for this review cycle. Tracks the legal component of the MLR tripartite review process.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phramaCodeCompliant rdf:type rdf:Property ;
    rdfs:label 'Phrama Code Compliant' ;
    rdfs:comment 'Indicates whether the promotional material has been assessed and confirmed as compliant with the PhRMA Code on Interactions with Healthcare Professionals. Set to True upon successful regulatory review.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReviewDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Date' ;
    rdfs:comment 'Date on which the regulatory affairs reviewer completed their review and rendered a decision for this review cycle.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Status' ;
    rdfs:comment 'Current decision status from the regulatory affairs reviewer for this review cycle. Tracks the regulatory component of the MLR tripartite review process.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Resubmission Deadline' ;
    rdfs:comment 'Date by which a revised version of the rejected promotional material must be resubmitted for the next review cycle. Populated when approval_decision is \'rejected\' or \'approved_with_changes\'.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle state of the MLR review workflow. Tracks progression from initial submission through final approval or rejection decision. [ENUM-REF-CANDIDATE: draft|submitted|in_review|approved|rejected|withdrawn|expired — promote to reference product]' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunshineActApplicable rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Applicable' ;
    rdfs:comment 'Indicates whether the promotional activity associated with this material is subject to Open Payments (Sunshine Act) reporting requirements under 42 CFR Part 403.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaVaultDocCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Doc Code' ;
    rdfs:comment 'The document identifier assigned by Veeva Vault PromoMats to the promotional material record. Used for cross-system traceability between the lakehouse silver layer and the source system of record.' ;
    rdfs:domain ind:MlrReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandPositioning rdf:type rdf:Property ;
    rdfs:label 'Brand Positioning' ;
    rdfs:comment 'The core brand positioning statement that defines how the brand is differentiated in the market and the value proposition communicated to Healthcare Professionals (HCPs) and patients.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for all financial amounts in this brand plan (e.g., \'USD\', \'EUR\', \'JPY\').' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStrategy rdf:type rdf:Property ;
    rdfs:label 'Channel Strategy' ;
    rdfs:comment 'The multi-channel engagement strategy defining how the brand will reach HCPs and patients through field force, digital channels, medical science liaisons, patient support programs, and market access initiatives.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveLandscape rdf:type rdf:Property ;
    rdfs:label 'Competitive Landscape' ;
    rdfs:comment 'Summary of the competitive environment, including key competitor brands, market share dynamics, and competitive threats or opportunities identified for the planning period.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'The date when the brand plan was last reviewed or updated. Brand plans are typically reviewed quarterly or semi-annually to assess progress and adjust tactics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:launchPhase rdf:type rdf:Property ;
    rdfs:label 'Launch Phase' ;
    rdfs:comment 'The current phase of the product launch lifecycle covered by this brand plan: pre-launch (preparation before regulatory approval), launch (initial market introduction), post-launch (ongoing commercialization), or not applicable (for established brands).' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketShareTarget rdf:type rdf:Property ;
    rdfs:label 'Market Share Target' ;
    rdfs:comment 'The target market share percentage (by volume or value) that the brand aims to achieve in its therapeutic category during the plan period. Expressed as a percentage (e.g., 25.50 for 25.5%).' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Unique business identifier or code for the brand plan used in financial and commercial systems (e.g., \'BP-2024-ONCX-US\').' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'The date when the brand plan period concludes. For annual plans, typically one year from start date. May be extended for multi-year plans.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'The official name or title of the brand plan, typically including brand name, year, and geography (e.g., \'Oncology Brand X US Commercial Plan 2024\').' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'The date when the brand plan becomes effective and execution begins. Typically aligns with fiscal year start or product launch date.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prescriptionVolumeTarget rdf:type rdf:Property ;
    rdfs:label 'Prescription Volume Target' ;
    rdfs:comment 'The target number of prescriptions (Total Prescriptions or TRx) or New-to-Brand (NTB) prescriptions the brand aims to generate during the plan period. Sourced from prescription data providers (e.g., IQVIA).' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalMixStrategy rdf:type rdf:Property ;
    rdfs:label 'Promotional Mix Strategy' ;
    rdfs:comment 'Description of the promotional mix strategy, including the balance and integration of personal promotion (field force), non-personal promotion (advertising, digital), medical education, congress participation, and speaker programs.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDependency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Dependency' ;
    rdfs:comment 'Description of any regulatory approval milestones or dependencies that impact the brand plan execution, such as pending New Drug Application (NDA), Biologics License Application (BLA), or Marketing Authorization Application (MAA) approvals, or supplemental indication approvals.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTarget rdf:type rdf:Property ;
    rdfs:label 'Revenue Target' ;
    rdfs:comment 'The target revenue or net sales goal for the brand during the plan period. Key Performance Indicator (KPI) for commercial success and P&L performance.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'The overarching strategic goal or objective for the brand during this plan period (e.g., \'Achieve market leadership in NSCLC\', \'Maximize peak sales before LOE\', \'Establish brand in rare disease segment\').' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetHcpSegment rdf:type rdf:Property ;
    rdfs:label 'Target Hcp Segment' ;
    rdfs:comment 'The primary Healthcare Professional (HCP) segment or specialty targeted by this brand plan (e.g., \'Oncologists\', \'Rheumatologists\', \'Primary Care Physicians\'). May include sub-segmentation by prescribing behavior or Key Opinion Leader (KOL) status.' ;
    rdfs:domain ind:BrandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolEngagementId rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Id' ;
    rdfs:comment 'Unique identifier for the KOL engagement record. Primary key for tracking longitudinal relationships with Key Opinion Leaders across commercial and medical affairs activities.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementCountryId rdf:type rdf:Property ;
    rdfs:label 'Engagement Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: KOL engagements are country-specific for global transparency reporting (Sunshine Act equivalents, EMA disclosure requirements). engagement_country is a denormalized country name. A medical affairs com' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:kolProfileId rdf:type rdf:Property ;
    rdfs:label 'Kol Profile Id' ;
    rdfs:comment 'Foreign key linking to hcp.hcp_kol_profile. Business justification: KOL engagement activities must reference the HCP\'s KOL profile to align engagement strategy with tier, publication history, and MSL interaction count. Pharma medical affairs KOL mapping reports depend' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KolProfile .

ind:advisoryBoardName rdf:type rdf:Property ;
    rdfs:label 'Advisory Board Name' ;
    rdfs:comment 'The name or identifier of the advisory board if the engagement type is advisory board participation. Used to group multiple KOL engagements under a single advisory board event.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Approval Date' ;
    rdfs:comment 'The date on which compliance approval was granted for this KOL engagement. Required for audit trail and regulatory inspection readiness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Approval Status' ;
    rdfs:comment 'The approval status from the compliance and legal review process. All KOL engagements must receive compliance approval before execution per PhRMA Code and internal policies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceApprover rdf:type rdf:Property ;
    rdfs:label 'Compliance Approver' ;
    rdfs:comment 'Name or identifier of the compliance officer who approved this KOL engagement. Maintains accountability for compliance decisions.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressName rdf:type rdf:Property ;
    rdfs:label 'Congress Name' ;
    rdfs:comment 'The name of the medical congress or scientific conference associated with this engagement, if applicable. Relevant for congress presentation and advisory board engagements held at conferences.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDurationHours rdf:type rdf:Property ;
    rdfs:label 'Engagement Duration Hours' ;
    rdfs:comment 'The total duration of the KOL engagement activity measured in hours. Used for fair market value assessment and resource planning.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementTopic rdf:type rdf:Property ;
    rdfs:label 'Engagement Topic' ;
    rdfs:comment 'The specific subject matter or agenda topic discussed during the KOL engagement. Provides context for the scientific or clinical focus of the interaction.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairMarketValueAssessment rdf:type rdf:Property ;
    rdfs:label 'Fair Market Value Assessment' ;
    rdfs:comment 'Assessment status indicating whether the honorarium and engagement terms comply with fair market value guidelines per PhRMA Code and internal policies.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honorariumAmount rdf:type rdf:Property ;
    rdfs:label 'Honorarium Amount' ;
    rdfs:comment 'The monetary compensation paid to the KOL for their participation in this engagement activity. Subject to fair market value assessment and transparency reporting.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:honorariumCurrency rdf:type rdf:Property ;
    rdfs:label 'Honorarium Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the honorarium payment (e.g., USD, EUR, GBP). Required for multi-country operations and financial reporting.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Identifier of the user or system that last modified this KOL engagement record. Maintains accountability for data changes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationTitle rdf:type rdf:Property ;
    rdfs:label 'Publication Title' ;
    rdfs:comment 'The title of the scientific publication or manuscript being reviewed by the KOL, if the engagement type is publication review. Links engagement to publication planning activities.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicRelationshipTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Relationship Tier' ;
    rdfs:comment 'Classification of the KOL\'s strategic importance to the organization. Tier 1 represents national/international thought leaders, Tier 2 regional influencers, Tier 3 local experts, and Emerging represents developing relationships.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transparencyReportDate rdf:type rdf:Property ;
    rdfs:label 'Transparency Report Date' ;
    rdfs:comment 'The date on which this KOL engagement was reported to the applicable transparency reporting system or regulatory authority.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transparencyReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Transparency Reporting Required' ;
    rdfs:comment 'Boolean flag indicating whether this KOL engagement must be reported under transparency regulations such as the Sunshine Act (US), EFPIA Code (EU), or similar country-specific requirements.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaCrmActivityCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Activity Code' ;
    rdfs:comment 'The unique activity identifier from Veeva CRM system linking this KOL engagement to the source system record. Enables traceability to operational CRM data.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeEnrolledPatients rdf:type rdf:Property ;
    rdfs:label 'Active Enrolled Patients' ;
    rdfs:comment 'Current count of patients with active enrollment status in the program.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adherenceRateActual rdf:type rdf:Property ;
    rdfs:label 'Adherence Rate Actual' ;
    rdfs:comment 'Actual medication adherence rate (as percentage) achieved among enrolled patients, measured using prescription refill data or patient-reported outcomes.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adherenceRateTarget rdf:type rdf:Property ;
    rdfs:label 'Adherence Rate Target' ;
    rdfs:comment 'Target medication adherence rate (as percentage) that the program aims to achieve among enrolled patients.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerEnrollment rdf:type rdf:Property ;
    rdfs:label 'Cost Per Enrollment' ;
    rdfs:comment 'Average cost to the program per patient enrollment, calculated as total spend divided by total enrollments.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Detailed description of the criteria patients must meet to qualify for enrollment in the program, including income thresholds, insurance status, and clinical requirements.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Compliant Flag' ;
    rdfs:comment 'Indicates whether the program operations and vendor have been certified as compliant with HIPAA Privacy and Security Rules.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incomeThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Income Threshold Amount' ;
    rdfs:comment 'Maximum annual household income level for patient eligibility in financial assistance programs. Null if program does not have income restrictions.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Income Threshold Currency' ;
    rdfs:comment 'Currency code for the income threshold amount using ISO 4217 three-letter codes.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Max Benefit Amount' ;
    rdfs:comment 'Maximum financial benefit amount per patient per year for co-pay assistance or free drug programs. Null if program does not have a cap.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBenefitCurrency rdf:type rdf:Property ;
    rdfs:label 'Max Benefit Currency' ;
    rdfs:comment 'Currency code for the maximum benefit amount using ISO 4217 three-letter codes.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programBudgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Program Budget Currency' ;
    rdfs:comment 'Currency code for the program budget amount using ISO 4217 three-letter codes.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory approval or notification for the patient support program where required by local health authorities.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEnrolledPatients rdf:type rdf:Property ;
    rdfs:label 'Total Enrolled Patients' ;
    rdfs:comment 'Cumulative count of unique patients who have enrolled in the program since launch.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Score' ;
    rdfs:comment 'Composite performance score (0-100 scale) for the administering vendor based on service level agreement (SLA) metrics including enrollment processing time, patient satisfaction, and compliance.' ;
    rdfs:domain ind:PatientSupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pspEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Psp Enrollment Id' ;
    rdfs:comment 'Unique identifier for the patient support program enrollment record. Primary key.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:administeringVendor rdf:type rdf:Property ;
    rdfs:label 'Administering Vendor' ;
    rdfs:comment 'Name of the third-party vendor or Contract Research Organization (CRO) administering the patient support program on behalf of the pharmaceutical company.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCurrency rdf:type rdf:Property ;
    rdfs:label 'Benefit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the benefit amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEndDate rdf:type rdf:Property ;
    rdfs:label 'Benefit End Date' ;
    rdfs:comment 'Date when the patient support program benefits expire or are scheduled to terminate. May be null for open-ended programs.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitStartDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Start Date' ;
    rdfs:comment 'Date when the patient support program benefits become active and available for use by the patient.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether patient consent for program participation and data usage was obtained in compliance with HIPAA and privacy regulations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Date' ;
    rdfs:comment 'Date when patient eligibility for the program was verified or determined.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Status' ;
    rdfs:comment 'Status of the eligibility verification process to determine if patient qualifies for program benefits based on income, insurance, or other criteria.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing enrollment confirmation number provided to patient and HCP for reference and tracking purposes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source Record Reference' ;
    rdfs:comment 'Unique identifier of the enrollment record in the source system for traceability and reconciliation.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source System' ;
    rdfs:comment 'Source system or application from which the enrollment record originated (e.g., Veeva CRM, Salesforce Health Cloud, vendor portal).' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitDate rdf:type rdf:Property ;
    rdfs:label 'Exit Date' ;
    rdfs:comment 'Date when the patient exited or was terminated from the patient support program. Null if enrollment is still active.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'Reason for patient exit from the support program. Supports program retention and adherence analysis.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescribingNpi rdf:type rdf:Property ;
    rdfs:label 'Prescribing Npi' ;
    rdfs:comment 'National Provider Identifier of the prescribing healthcare professional. Used for Sunshine Act transparency reporting.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Benefit Amount' ;
    rdfs:comment 'Remaining financial benefit amount available to the patient under this enrollment.' ;
    rdfs:domain ind:PspEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractAccountId rdf:type rdf:Property ;
    rdfs:label 'Contract Account Id' ;
    rdfs:comment 'Unique identifier for the commercial contract account. Primary key for institutional customer accounts including hospital systems, IDNs, GPOs, specialty pharmacies, and retail pharmacy chains.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAccount .

ind:billingAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Id' ;
    rdfs:comment 'Foreign key linking to masterdata.address. Business justification: Contract accounts have structured billing addresses used for invoice generation, tax determination, and regulatory compliance. The five billing address columns are denormalized masterdata.address fiel' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:billingCountryId rdf:type rdf:Property ;
    rdfs:label 'Billing Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Contract accounts (GPOs, hospitals, pharmacies) have a billing country that determines VAT, tax treatment, and regulatory compliance for invoicing. billing_country_code is a denormalized country refer' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:parentAccountContractAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Contract Account Id' ;
    rdfs:comment 'Reference to the parent contract account for hierarchical account structures. Used for IDN systems where individual hospitals roll up to a corporate parent. Null for top-level accounts.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAccount .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Legal or trading name of the institutional customer account. Primary human-readable identifier for the account.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-known unique business identifier for the contract account. Used in commercial operations, invoicing, and customer communications. Typically assigned by ERP system (SAP SD module).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenuePotential rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Potential' ;
    rdfs:comment 'Estimated annual revenue opportunity for this account based on market analysis, historical performance, and account size. Used for territory planning and resource allocation.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Business unit or division responsible for managing this account. Used for P&L reporting and organizational alignment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiration date of the current contract agreement. Triggers contract renewal workflow. Null for evergreen contracts without fixed expiration.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the current contract agreement with this institutional account. Pricing and terms become active on this date.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTier rdf:type rdf:Property ;
    rdfs:label 'Contract Tier' ;
    rdfs:comment 'Pricing and service tier assigned to the account based on volume commitments, GPO affiliation, and negotiated terms. Determines discount levels, rebate structures, and service level agreements.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit exposure allowed for this account. Enforced during order processing to manage financial risk. Set by credit management team based on financial assessment.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the credit limit amount. Typically matches the accounts primary transaction currency.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deaNumber rdf:type rdf:Property ;
    rdfs:label 'Dea Number' ;
    rdfs:comment 'DEA registration number for accounts authorized to handle controlled substances. Required for distribution of Schedule II-V medications. Format: 2 letters followed by 7 digits.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpoAffiliation rdf:type rdf:Property ;
    rdfs:label 'Gpo Affiliation' ;
    rdfs:comment 'Name of the Group Purchasing Organization (GPO) that this account is affiliated with, if applicable. GPO affiliation determines contract pricing tier and rebate eligibility. Null if account is not GPO-affiliated.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hinNumber rdf:type rdf:Property ;
    rdfs:label 'Hin Number' ;
    rdfs:comment 'Health Industry Number assigned by GS1 for healthcare supply chain identification. Used for EDI transactions and supply chain traceability.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms negotiated with the account. Defines invoice due date calculation and early payment discount eligibility. Format examples: net_30 (payment due in 30 days), 2_10_net_30 (2% discount if paid within 10 days, otherwise net 30).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'First line of the primary shipping address for product deliveries. May differ from billing address for multi-site organizations.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line2' ;
    rdfs:comment 'Second line of the shipping address (dock, receiving department). Optional field for delivery instructions.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'City name for the primary shipping address of the institutional account.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the shipping address. Used for freight calculation and delivery routing.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'State or province code for the shipping address. Used for logistics planning and distribution compliance.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicClassification rdf:type rdf:Property ;
    rdfs:label 'Strategic Classification' ;
    rdfs:comment 'Strategic importance tier of the account based on revenue potential, market influence, and relationship depth. Tier 1 accounts receive dedicated account management and customized engagement programs.' ;
    rdfs:domain ind:ContractAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identification number (TIN, VAT number, or equivalent) for the institutional account. Required for tax-compliant invoicing and regulatory reporting.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Sales Performance Id' ;
    rdfs:comment 'Unique identifier for the sales performance record. Primary key for the sales performance data product.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Commercial sales performance should link to finance budgets for sales budget tracking and variance analysis. This enables integrated financial planning and performance management across commercial and' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:actualPerformanceAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Performance Amount' ;
    rdfs:comment 'Actual sales performance achieved during the period, measured in the same units as quota (prescription volume or revenue).' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callAttainmentPercent rdf:type rdf:Property ;
    rdfs:label 'Call Attainment Percent' ;
    rdfs:comment 'Percentage of target call frequency achieved, calculated as (call_frequency_achieved / call_frequency_target) * 100.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callFrequencyAchieved rdf:type rdf:Property ;
    rdfs:label 'Call Frequency Achieved' ;
    rdfs:comment 'Actual number of Healthcare Professional (HCP) calls completed by the sales representative during the performance period.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callFrequencyTarget rdf:type rdf:Property ;
    rdfs:label 'Call Frequency Target' ;
    rdfs:comment 'Target number of Healthcare Professional (HCP) calls planned for the sales representative during the performance period.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Compensation Amount' ;
    rdfs:comment 'Calculated incentive compensation earned by the sales representative for the performance period based on quota attainment.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveCompensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Incentive Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the incentive compensation amount.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSharePercent rdf:type rdf:Property ;
    rdfs:label 'Market Share Percent' ;
    rdfs:comment 'Brand market share as a percentage of total prescriptions in the therapeutic category within the territory during the performance period.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newPrescriptions rdf:type rdf:Property ;
    rdfs:label 'New Prescriptions' ;
    rdfs:comment 'Number of new prescriptions (NRx) written for the brand during the performance period, excluding refills.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performancePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period End Date' ;
    rdfs:comment 'End date of the performance measurement period (weekly, monthly, or quarterly cycle).' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performancePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period Start Date' ;
    rdfs:comment 'Start date of the performance measurement period (weekly, monthly, or quarterly cycle).' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Current status of the sales performance record in the review and approval workflow.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Type of performance measurement period: weekly, monthly, quarterly, or annual.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'Sales quota or target assigned to the sales representative for the brand during the performance period, typically measured in prescription volume or revenue.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaAttainmentPercent rdf:type rdf:Property ;
    rdfs:label 'Quota Attainment Percent' ;
    rdfs:comment 'Percentage of quota achieved, calculated as (actual_performance_amount / quota_amount) * 100. Used for incentive compensation calculation.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaCurrency rdf:type rdf:Property ;
    rdfs:label 'Quota Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quota amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDropRate rdf:type rdf:Property ;
    rdfs:label 'Sample Drop Rate' ;
    rdfs:comment 'Average number of sample units distributed per HCP call during the performance period.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleUnitsDistributed rdf:type rdf:Property ;
    rdfs:label 'Sample Units Distributed' ;
    rdfs:comment 'Total number of product sample units distributed by the sales representative during the performance period.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPrescriptions rdf:type rdf:Property ;
    rdfs:label 'Total Prescriptions' ;
    rdfs:comment 'Total number of prescriptions (TRx) written for the brand during the performance period, including both new and refill prescriptions.' ;
    rdfs:domain ind:SalesPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commercialInsuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Insurance Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether patients must have commercial insurance coverage to be eligible for the co-pay program.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of legal and compliance review for the co-pay program to ensure adherence to Anti-Kickback Statute, PhRMA Code, and promotional regulations.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusion340bFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion 340b Flag' ;
    rdfs:comment 'Boolean flag indicating whether prescriptions filled through 340B covered entities are excluded from this co-pay program to maintain compliance with federal regulations.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionGovernmentPayerFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Government Payer Flag' ;
    rdfs:comment 'Boolean flag indicating whether patients with government-funded insurance (Medicare, Medicaid, TRICARE, VA) are excluded from program eligibility per Anti-Kickback Statute compliance.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossToNetCategory rdf:type rdf:Property ;
    rdfs:label 'Gross To Net Category' ;
    rdfs:comment 'Gross-to-net deduction category for financial reporting, used to classify co-pay program costs in revenue reconciliation and brand P&L analysis.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAnnualBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Max Annual Benefit Amount' ;
    rdfs:comment 'Maximum dollar amount of co-pay assistance a patient can receive per calendar year under this program.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBenefitPerPrescription rdf:type rdf:Property ;
    rdfs:label 'Max Benefit Per Prescription' ;
    rdfs:comment 'Maximum dollar amount of co-pay assistance available per individual prescription fill or claim.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedemptionsCount rdf:type rdf:Property ;
    rdfs:label 'Total Redemptions Count' ;
    rdfs:comment 'Cumulative count of co-pay card or voucher redemptions processed under this program since launch.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transparencyReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Transparency Reporting Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether co-pay program benefits must be reported under Physician Payments Sunshine Act or other transparency regulations.' ;
    rdfs:domain ind:CopayProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copayRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Copay Redemption Id' ;
    rdfs:comment 'Unique identifier for each co-pay card or voucher redemption transaction. Primary key for the copay_redemption product.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketGrossToNetAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Market Gross To Net Adjustment Id' ;
    rdfs:comment 'Foreign key linking to market.gross_to_net_adjustment. Business justification: Copay redemptions drive gross-to-net adjustments for manufacturer copay contributions. Financial reconciliation process requires linking redemption transactions to GTN accruals for revenue recognition' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GrossToNetAdjustment .

ind:prescriberMasterId rdf:type rdf:Property ;
    rdfs:label 'Prescriber Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.master. Business justification: Copay redemptions must be linked to the prescribing HCP for Sunshine Act gross-to-net reporting and prescriber-level analytics. copay_redemption stores prescriber_npi as a denormalized string; role-pr' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:daysSupply rdf:type rdf:Property ;
    rdfs:label 'Days Supply' ;
    rdfs:comment 'Number of days the dispensed quantity is intended to last based on the prescribed dosing regimen.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insurancePaidAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Paid Amount' ;
    rdfs:comment 'The amount paid by the patients insurance plan or pharmacy benefit manager toward the prescription cost.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientOutOfPocketAmount rdf:type rdf:Property ;
    rdfs:label 'Patient Out Of Pocket Amount' ;
    rdfs:comment 'The amount the patient paid out-of-pocket after applying insurance coverage and manufacturer co-pay assistance.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerAdjudicationStatus rdf:type rdf:Property ;
    rdfs:label 'Payer Adjudication Status' ;
    rdfs:comment 'Status of the insurance claim adjudication by the pharmacy benefit manager or payer, indicating whether the claim was approved, denied, or partially approved.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyChainCode rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Chain Code' ;
    rdfs:comment 'Code identifying the pharmacy chain or network to which the dispensing pharmacy belongs (e.g., CVS, Walgreens, independent).' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyName rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Name' ;
    rdfs:comment 'Name of the pharmacy or retail location where the co-pay card was redeemed.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyNpi rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Npi' ;
    rdfs:comment 'The 10-digit National Provider Identifier of the pharmacy where the redemption occurred. NPI is the unique identifier for healthcare providers in the United States.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriberSpecialty rdf:type rdf:Property ;
    rdfs:label 'Prescriber Specialty' ;
    rdfs:comment 'Medical specialty of the prescribing healthcare professional (e.g., oncologist, rheumatologist, endocrinologist).' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Prescription Number' ;
    rdfs:comment 'Pharmacy-assigned prescription number for the dispensed medication associated with this redemption.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programUtilizationCount rdf:type rdf:Property ;
    rdfs:label 'Program Utilization Count' ;
    rdfs:comment 'Sequential count of how many times this patient has utilized the co-pay program, used to track adherence and program engagement.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionDate rdf:type rdf:Property ;
    rdfs:label 'Redemption Date' ;
    rdfs:comment 'The date on which the patient redeemed the co-pay card or voucher at the pharmacy. This is the principal business event date for this transaction.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Number' ;
    rdfs:comment 'Externally-known unique transaction number assigned to this redemption event by the co-pay program administrator or pharmacy benefit manager.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the redemption transaction indicating whether the claim has been submitted, approved, rejected, reversed, or paid.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Precise timestamp when the redemption transaction was processed at the pharmacy point-of-sale or submitted to the pharmacy benefit manager.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Code' ;
    rdfs:comment 'Standard rejection code returned by the pharmacy benefit manager if the claim was denied, indicating the reason for rejection (e.g., prior authorization required, plan limitations exceeded).' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Retail Price Amount' ;
    rdfs:comment 'The full retail price of the prescription before any discounts, insurance, or co-pay assistance.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Boolean indicator of whether this redemption transaction has been reversed or voided due to prescription return, billing correction, or other adjustment.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province where the pharmacy is located and the redemption occurred.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Amount' ;
    rdfs:comment 'The total amount paid for the prescription, including patient out-of-pocket, manufacturer contribution, and insurance payment.' ;
    rdfs:domain ind:CopayRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceProductId rdf:type rdf:Property ;
    rdfs:label 'Reference Product Id' ;
    rdfs:comment 'For biosimilar products only: the medicinal_product_id of the reference biologic (originator product) to which this biosimilar has demonstrated similarity. Null for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicinalProduct .

ind:registrationCountryId rdf:type rdf:Property ;
    rdfs:label 'Registration Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Products registered in specific countries/markets for regulatory compliance (market authorization tracking), commercial operations (launch planning), pharmacovigilance (country-specific safety reporti' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:analyticalSimilarityOutcome rdf:type rdf:Property ;
    rdfs:label 'Analytical Similarity Outcome' ;
    rdfs:comment 'For biosimilar products only: the outcome of the analytical similarity assessment comparing the biosimilar to the reference product across structural, functional, and physicochemical characteristics. Not Applicable for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'The date on which the medicinal product was discontinued or withdrawn from the market. Null if the product is still active.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discontinuationReason rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Reason' ;
    rdfs:comment 'The primary reason for discontinuation or withdrawal of the medicinal product from the market. Not Applicable if the product is still active.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extrapolationStatus rdf:type rdf:Property ;
    rdfs:label 'Extrapolation Status' ;
    rdfs:comment 'For biosimilar products only: indicates the extent to which clinical data from one indication of the reference product has been extrapolated to support approval for other indications of the biosimilar. Not Applicable for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstApprovalDate rdf:type rdf:Property ;
    rdfs:label 'First Approval Date' ;
    rdfs:comment 'The date on which the medicinal product received its first regulatory approval from any major regulatory authority (FDA, EMA, PMDA, etc.).' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interchangeabilityDesignation rdf:type rdf:Property ;
    rdfs:label 'Interchangeability Designation' ;
    rdfs:comment 'For biosimilar products only: indicates whether the FDA has designated this biosimilar as interchangeable with the reference product, allowing automatic substitution at the pharmacy level. Not Applicable for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moa rdf:type rdf:Property ;
    rdfs:label 'Moa' ;
    rdfs:comment 'The biochemical or physiological mechanism by which the medicinal product produces its therapeutic effect (e.g., TNF-alpha inhibitor, PD-1 inhibitor, HMG-CoA reductase inhibitor).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorBlaNumber rdf:type rdf:Property ;
    rdfs:label 'Originator Bla Number' ;
    rdfs:comment 'For biosimilar products only: the FDA BLA number of the reference biologic product (e.g., BLA125057 for Humira). Null for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorMaaNumber rdf:type rdf:Property ;
    rdfs:label 'Originator Maa Number' ;
    rdfs:comment 'For biosimilar products only: the EMA Marketing Authorization Application number of the reference biologic product. Null for non-biosimilar products.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionRequired rdf:type rdf:Property ;
    rdfs:label 'Prescription Required' ;
    rdfs:comment 'Indicates whether the medicinal product requires a prescription from a licensed healthcare professional for dispensing (true for Rx products, false for OTC products).' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qbdApproach rdf:type rdf:Property ;
    rdfs:label 'Qbd Approach' ;
    rdfs:comment 'Indicates whether the medicinal product was developed using Quality by Design (QbD) principles with defined design space, critical quality attributes (CQAs), and critical process parameters (CPPs).' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Designation' ;
    rdfs:comment 'Special regulatory designations granted to the medicinal product (e.g., Orphan Drug, Breakthrough Therapy, Fast Track, Priority Review, Accelerated Approval, PRIME designation). Multiple designations may be concatenated.' ;
    rdfs:domain ind:MedicinalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Months' ;
    rdfs:comment 'The approved shelf life of the medicinal product under specified storage conditions, expressed in months from date of manufacture.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'The required storage conditions for the medicinal product to maintain stability and quality (e.g., Store at 2-8°C, Store below 25°C, Protect from light, Do not freeze).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: API manufacturer legal entity required for Drug Master File (DMF) holder identification, supplier qualification, regulatory filings (CTD Module 3), GMP compliance tracking. Replaces denormalized manuf' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:originCountryId rdf:type rdf:Property ;
    rdfs:label 'Origin Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Country of origin for drug substances is a regulatory requirement under ICH Q11 and import/export regulations. FDA and EMA require declaration of the country where the API is manufactured. Pharma doma' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:bcsClassification rdf:type rdf:Property ;
    rdfs:label 'Bcs Classification' ;
    rdfs:comment 'BCS classification of the drug substance based on solubility and permeability characteristics (Class I: high solubility/high permeability, Class II: low solubility/high permeability, Class III: high solubility/low permeability, Class IV: low solubility/low permeability).' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casRegistryNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Registry Number' ;
    rdfs:comment 'Unique numerical identifier assigned by the Chemical Abstracts Service to the drug substance for unambiguous chemical identification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalName rdf:type rdf:Property ;
    rdfs:label 'Chemical Name' ;
    rdfs:comment 'Systematic IUPAC chemical name describing the molecular structure of the drug substance according to international nomenclature standards.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the drug substance master record is currently active and available for use in formulation, manufacturing, and regulatory activities.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nceDesignation rdf:type rdf:Property ;
    rdfs:label 'Nce Designation' ;
    rdfs:comment 'Indicates whether the drug substance has been designated as a New Chemical Entity by regulatory authorities, qualifying for extended data exclusivity periods.' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:particleSizeSpecification rdf:type rdf:Property ;
    rdfs:label 'Particle Size Specification' ;
    rdfs:comment 'Defined particle size distribution range or specification for the drug substance, critical for dissolution and bioavailability (e.g., D50 < 10 microns).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacopoeialMonograph rdf:type rdf:Property ;
    rdfs:label 'Pharmacopoeial Monograph' ;
    rdfs:comment 'Reference to the official pharmacopoeial monograph (USP, EP, JP, or other) that defines quality standards for the drug substance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalForm rdf:type rdf:Property ;
    rdfs:label 'Physical Form' ;
    rdfs:comment 'Physical state or form of the drug substance at standard conditions (e.g., crystalline solid, liquid, lyophilized powder).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polymorphicForm rdf:type rdf:Property ;
    rdfs:label 'Polymorphic Form' ;
    rdfs:comment 'Specific crystalline or amorphous form of the drug substance, identifying the polymorph used in manufacturing (e.g., Form I, Form II, anhydrous, hydrate).' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Summary of regulatory approval status across major markets (FDA, EMA, PMDA, etc.), indicating where the drug substance has received marketing authorization.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Retest Period Months' ;
    rdfs:comment 'Time period in months after which the drug substance should be re-examined to ensure it still meets specifications before use in manufacturing.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saltForm rdf:type rdf:Property ;
    rdfs:label 'Salt Form' ;
    rdfs:comment 'Chemical salt form of the drug substance if applicable (e.g., hydrochloride, sodium, sulfate), or \'free base\' or \'free acid\' if not a salt.' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solubilityProfile rdf:type rdf:Property ;
    rdfs:label 'Solubility Profile' ;
    rdfs:comment 'Aqueous solubility characteristics of the drug substance across physiologically relevant pH ranges, critical for formulation development and bioavailability.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version identifier for the current quality specification document defining acceptance criteria for the drug substance.' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityProfile rdf:type rdf:Property ;
    rdfs:label 'Stability Profile' ;
    rdfs:comment 'Summary of the drug substance\'s stability characteristics under various storage conditions, including temperature and humidity sensitivity.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stereochemistry rdf:type rdf:Property ;
    rdfs:label 'Stereochemistry' ;
    rdfs:comment 'Three-dimensional spatial arrangement of atoms in the drug substance molecule, including chirality and isomeric configuration (e.g., R/S designation, E/Z configuration).' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synthesisRouteVersion rdf:type rdf:Property ;
    rdfs:label 'Synthesis Route Version' ;
    rdfs:comment 'Version identifier for the chemical synthesis route or manufacturing process used to produce the drug substance, enabling change control and traceability.' ;
    rdfs:domain ind:DrugSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usanName rdf:type rdf:Property ;
    rdfs:label 'Usan Name' ;
    rdfs:comment 'United States Adopted Name assigned by the USAN Council, representing the official generic name used in the United States for the drug substance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalCountryId rdf:type rdf:Property ;
    rdfs:label 'Approval Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Drug products approved in specific jurisdictions for market authorization tracking, regulatory submissions (country-specific dossiers), supply planning (market-specific manufacturing), labeling (count' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:contractManufacturerBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Contract Manufacturer Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Contract manufacturing organizations (CMOs) are a core business partner type in pharma. Drug products manufactured by CMOs require quality agreements, batch release authorization, and regulatory site ' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:developmentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Development Cost Center Id' ;
    rdfs:comment 'Foreign key linking to masterdata.cost_center. Business justification: Drug products assigned to cost centers for R&D capitalization (IAS 38), portfolio accounting, project costing. Enables financial tracking of development costs by product, capitalization decisions (tec' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:rldProductId rdf:type rdf:Property ;
    rdfs:label 'Rld Product Id' ;
    rdfs:comment 'Reference to the RLD drug product if this product is a generic or biosimilar requiring bioequivalence demonstration.' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugProduct .

ind:blackBoxWarningFlag rdf:type rdf:Property ;
    rdfs:label 'Black Box Warning Flag' ;
    rdfs:comment 'Indicates whether the drug product labeling includes a black box warning (boxed warning) for serious or life-threatening risks.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmcSummary rdf:type rdf:Property ;
    rdfs:label 'Cmc Summary' ;
    rdfs:comment 'High-level summary of the chemistry, manufacturing, and controls information for the drug product, including formulation composition and manufacturing process overview.' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipients rdf:type rdf:Property ;
    rdfs:label 'Excipients' ;
    rdfs:comment 'List of inactive ingredients (excipients) used in the drug product formulation, such as binders, fillers, preservatives, and colorants.' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationType rdf:type rdf:Property ;
    rdfs:label 'Formulation Type' ;
    rdfs:comment 'Classification of the drug product formulation based on release characteristics (e.g., immediate release, extended release, delayed release, modified release, controlled release).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'The primary packaging configuration for the drug product (e.g., bottle, blister pack, vial, ampule, prefilled syringe, tube).' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Prescription Status' ;
    rdfs:comment 'Indicates whether the drug product requires a prescription (Rx), is available over-the-counter (OTC), or is behind-the-counter.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Internal product code assigned to the drug product for identification across manufacturing, regulatory, and commercial systems. Typically alphanumeric and unique within the organization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbdFlag rdf:type rdf:Property ;
    rdfs:label 'Qbd Flag' ;
    rdfs:comment 'Indicates whether the drug product was developed using Quality by Design principles as defined by ICH Q8.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rldFlag rdf:type rdf:Property ;
    rdfs:label 'Rld Flag' ;
    rdfs:comment 'Indicates whether this drug product is designated as a Reference Listed Drug by the FDA for bioequivalence studies.' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strengthValue rdf:type rdf:Property ;
    rdfs:label 'Strength Value' ;
    rdfs:comment 'Numeric value of the active pharmaceutical ingredient strength for computational and analytical purposes.' ;
    rdfs:domain ind:DrugProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentPlantId rdf:type rdf:Property ;
    rdfs:label 'Development Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Formulation development site tracking for technology transfer documentation, scale-up studies, process validation, site-specific design space. Critical for CMC regulatory submissions (CTD Module 3), m' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:apiCount rdf:type rdf:Property ;
    rdfs:label 'Api Count' ;
    rdfs:comment 'Number of distinct active pharmaceutical ingredients (APIs) in the formulation. Most formulations have 1 API; combination products have 2 or more.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Batch Size Target' ;
    rdfs:comment 'Planned or standard batch size for manufacturing this formulation, expressed in the unit specified by batch_size_uom. Used for scale-up calculations and manufacturing planning.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUom rdf:type rdf:Property ;
    rdfs:label 'Batch Size Uom' ;
    rdfs:comment 'Unit of measure for the batch size (e.g., kg for bulk powder, L for liquid, units for finished dosage forms). [ENUM-REF-CANDIDATE: kg|L|units|tablets|capsules|vials|syringes — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bioequivalenceReference rdf:type rdf:Property ;
    rdfs:label 'Bioequivalence Reference' ;
    rdfs:comment 'Reference to bioequivalence or bioavailability studies conducted for this formulation, particularly relevant for generic formulations or formulation changes requiring bridging studies.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositionDescription rdf:type rdf:Property ;
    rdfs:label 'Composition Description' ;
    rdfs:comment 'Detailed textual description of the formulation composition, including all active and inactive ingredients, their roles, and quantities. Supports CMC Module 3 documentation and regulatory submissions.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cppSummary rdf:type rdf:Property ;
    rdfs:label 'Cpp Summary' ;
    rdfs:comment 'Summary of critical process parameters (CPPs) identified for this formulation. CPPs are process parameters whose variability has an impact on a critical quality attribute (CQA) and therefore should be monitored or controlled.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cqaSummary rdf:type rdf:Property ;
    rdfs:label 'Cqa Summary' ;
    rdfs:comment 'Summary of critical quality attributes (CQAs) for this formulation. CQAs are physical, chemical, biological, or microbiological properties that should be within an appropriate limit, range, or distribution to ensure the desired product quality.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when this formulation record was first created in the system. Part of audit trail for formulation lifecycle management.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designSpaceDescription rdf:type rdf:Property ;
    rdfs:label 'Design Space Description' ;
    rdfs:comment 'Textual summary of the QbD design space, including key input variables, process parameters, and their acceptable ranges. References supporting studies and risk assessments.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipientCount rdf:type rdf:Property ;
    rdfs:label 'Excipient Count' ;
    rdfs:comment 'Number of distinct inactive ingredients (excipients) in the formulation. Includes fillers, binders, disintegrants, lubricants, coatings, preservatives, and other functional excipients.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formulationCode rdf:type rdf:Property ;
    rdfs:label 'Formulation Code' ;
    rdfs:comment 'Business identifier for the formulation, used across manufacturing, regulatory, and quality systems. Typically follows internal coding conventions for Chemistry Manufacturing and Controls (CMC) documentation.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationName rdf:type rdf:Property ;
    rdfs:label 'Formulation Name' ;
    rdfs:comment 'Human-readable name or title of the formulation, often including the drug product name, strength, and dosage form (e.g., \'Compound XYZ 50mg Tablet Formulation\').' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationStatus rdf:type rdf:Property ;
    rdfs:label 'Formulation Status' ;
    rdfs:comment 'Current lifecycle status of the formulation. Tracks progression from early development through commercial manufacturing and potential discontinuation.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpGradeRequired rdf:type rdf:Property ;
    rdfs:label 'Gmp Grade Required' ;
    rdfs:comment 'Indicates the GMP grade required for manufacturing this formulation: clinical (for investigational products), commercial (for marketed products), or both (for formulations used in both contexts).' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier or name of the person who last modified this formulation record. Part of audit trail for compliance and quality management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when this formulation record was last modified. Tracks changes to formulation specifications, status, or metadata.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingProcessType rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Process Type' ;
    rdfs:comment 'Primary manufacturing process or technology used to produce this formulation (e.g., wet granulation for tablets, aseptic filling for injectables). Influences equipment selection and process validation strategy. [ENUM-REF-CANDIDATE: wet_granulation|dry_granulation|direct_compression|coating|lyophilization|aseptic_filling|emulsification|spray_drying — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentProtected rdf:type rdf:Property ;
    rdfs:label 'Patent Protected' ;
    rdfs:comment 'Indicates whether this formulation is covered by one or more patents, providing intellectual property protection. Links to patent records in the intellectual property domain.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pharmacopoeialStandard rdf:type rdf:Property ;
    rdfs:label 'Pharmacopoeial Standard' ;
    rdfs:comment 'Primary pharmacopoeial standard to which this formulation conforms (USP = United States Pharmacopeia, EP = European Pharmacopoeia, JP = Japanese Pharmacopoeia, BP = British Pharmacopoeia, IP = Indian Pharmacopoeia, ChP = Chinese Pharmacopoeia).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbdDesignSpaceDefined rdf:type rdf:Property ;
    rdfs:label 'Qbd Design Space Defined' ;
    rdfs:comment 'Indicates whether a Quality by Design (QbD) design space has been established for this formulation, defining the multidimensional combination of input variables and process parameters that ensure quality.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Reference' ;
    rdfs:comment 'Reference to the regulatory submission (IND, NDA, BLA, MAA) in which this formulation was described or approved. Links formulation records to regulatory dossiers in RIMS.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleUpFactor rdf:type rdf:Property ;
    rdfs:label 'Scale Up Factor' ;
    rdfs:comment 'Ratio of commercial batch size to development batch size, indicating the degree of scale-up achieved. Used to assess scale-up risk and process robustness.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stabilityProfileSummary rdf:type rdf:Property ;
    rdfs:label 'Stability Profile Summary' ;
    rdfs:comment 'Summary of stability characteristics for this formulation, including storage conditions, shelf life, and key degradation pathways. References formal stability studies conducted per ICH Q1A guidelines.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyTransferStatus rdf:type rdf:Property ;
    rdfs:label 'Technology Transfer Status' ;
    rdfs:comment 'Status of technology transfer activities for this formulation, tracking the transfer of manufacturing knowledge and processes from development to commercial manufacturing sites or to CMOs/CDMOs.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitDoseStrength rdf:type rdf:Property ;
    rdfs:label 'Unit Dose Strength' ;
    rdfs:comment 'Quantity of active pharmaceutical ingredient (API) per unit dose (e.g., 50 mg per tablet, 100 mg/mL for solution). Expressed in the unit specified by unit_dose_strength_uom.' ;
    rdfs:domain ind:Formulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or name of the person who created this formulation record. Part of audit trail for compliance and quality management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationIngredientId rdf:type rdf:Property ;
    rdfs:label 'Formulation Ingredient Id' ;
    rdfs:comment 'Unique identifier for each ingredient record within a formulation. Primary key for the formulation ingredient entity.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excipientId rdf:type rdf:Property ;
    rdfs:label 'Excipient Id' ;
    rdfs:comment 'Foreign key linking to product.excipient. Business justification: formulation_ingredient contains excipient-related attributes that should be normalized to the excipient master table. When an ingredient is an excipient (not an API), this FK allows retrieval of autho' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Excipient .

ind:batchQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Batch Quantity Uom' ;
    rdfs:comment 'Unit of measure for the batch quantity: kilograms (kg), grams (g), liters (L), milliliters (mL), or units.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Reference to the change control or deviation record that authorized the addition or modification of this ingredient in the formulation. Required for audit trail and regulatory inspection readiness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Required Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis must be obtained and reviewed for each lot of this ingredient before use in manufacturing. Critical for Good Manufacturing Practice (GMP) compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalQualityAttributeFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Quality Attribute Flag' ;
    rdfs:comment 'Indicates whether this ingredient is designated as a Critical Quality Attribute under Quality by Design (QbD) principles, requiring enhanced control and monitoring.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingredientFunction rdf:type rdf:Property ;
    rdfs:label 'Ingredient Function' ;
    rdfs:comment 'Specific functional role of the ingredient in the formulation such as binder, filler, disintegrant, lubricant, coating agent, or flavoring agent. Critical for Quality by Design (QbD) and regulatory submissions.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientName rdf:type rdf:Property ;
    rdfs:label 'Ingredient Name' ;
    rdfs:comment 'Common or trade name of the ingredient as used in manufacturing documentation and internal systems.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ingredient Sequence Number' ;
    rdfs:comment 'Sequential ordering of ingredients within the formulation, used for manufacturing instructions and regulatory documentation.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingredientType rdf:type rdf:Property ;
    rdfs:label 'Ingredient Type' ;
    rdfs:comment 'Classification of the ingredient role in the formulation: Active Pharmaceutical Ingredient (API), excipient, solvent, preservative, stabilizer, or colorant.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overageJustification rdf:type rdf:Property ;
    rdfs:label 'Overage Justification' ;
    rdfs:comment 'Business and scientific rationale for the overage percentage, including stability data, manufacturing loss studies, or regulatory requirements. Required for regulatory submissions and quality documentation.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overagePercentage rdf:type rdf:Property ;
    rdfs:label 'Overage Percentage' ;
    rdfs:comment 'Percentage of additional ingredient added beyond the theoretical quantity to compensate for manufacturing losses, degradation, or potency variations. Critical for API stability and shelf-life management.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityPerBatch rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Batch' ;
    rdfs:comment 'Total amount of the ingredient required for a standard manufacturing batch. Used for batch record generation, material planning, and manufacturing execution.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityPerUnitDose rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Unit Dose' ;
    rdfs:comment 'Amount of the ingredient present in a single unit dose (e.g., one tablet, one capsule, one vial). Used for labeling, regulatory submissions, and quality control.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retestPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retest Period Days' ;
    rdfs:comment 'Number of days after which the ingredient must be retested to confirm it still meets specifications before use in manufacturing. Part of stability and quality management programs.' ;
    rdfs:domain ind:FormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specificationReference rdf:type rdf:Property ;
    rdfs:label 'Specification Reference' ;
    rdfs:comment 'Reference to the detailed quality specification document or standard operating procedure (SOP) governing acceptance criteria for this ingredient.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketAuthorizationCountryId rdf:type rdf:Property ;
    rdfs:label 'Market Authorization Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: Packaging configurations are approved per country by regulatory authorities. The market_authorization_country plain-text column is a denormalized reference to the country master. Normalizing to a FK s' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:packagingPlantId rdf:type rdf:Property ;
    rdfs:label 'Packaging Plant Id' ;
    rdfs:comment 'Foreign key linking to masterdata.plant. Business justification: Packaging operations site assignment for capacity planning, serialization compliance (plant-level aggregation), secondary packaging operations, distribution planning. Required for Track & Trace regula' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:aggregationHierarchy rdf:type rdf:Property ;
    rdfs:label 'Aggregation Hierarchy' ;
    rdfs:comment 'Description of the parent-child aggregation structure for serialized units (e.g., unit > case > pallet) used in track-and-trace systems.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childResistantPackaging rdf:type rdf:Property ;
    rdfs:label 'Child Resistant Packaging' ;
    rdfs:comment 'Indicates whether the packaging meets child-resistant standards to prevent accidental ingestion by children.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureType rdf:type rdf:Property ;
    rdfs:label 'Closure Type' ;
    rdfs:comment 'Type of closure used to seal the primary container, ensuring product integrity and preventing contamination. [ENUM-REF-CANDIDATE: rubber_stopper|screw_cap|flip_off_cap|child_resistant_cap|tamper_evident_seal|heat_seal|crimp_seal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Unique business identifier for the packaging configuration used across manufacturing, supply chain, and commercial systems.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Human-readable name describing the packaging configuration, typically including container type, pack size, and market designation.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationType rdf:type rdf:Property ;
    rdfs:label 'Configuration Type' ;
    rdfs:comment 'Classification of the packaging configuration based on its intended use and distribution channel.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Fill Volume Ml' ;
    rdfs:comment 'Volume of drug product filled into the primary container, measured in milliliters. Critical for dosing accuracy and overfill calculations.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headspaceVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Headspace Volume Ml' ;
    rdfs:comment 'Volume of air or inert gas in the primary container above the drug product, important for stability and oxidation control.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lightProtectionRequired rdf:type rdf:Property ;
    rdfs:label 'Light Protection Required' ;
    rdfs:comment 'Indicates whether the packaging must protect the drug product from light exposure to prevent photodegradation.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moistureProtectionRequired rdf:type rdf:Property ;
    rdfs:label 'Moisture Protection Required' ;
    rdfs:comment 'Indicates whether the packaging must provide moisture barrier protection to prevent hygroscopic degradation.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nominalFillVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Nominal Fill Volume Ml' ;
    rdfs:comment 'Labeled or declared fill volume on the packaging, which may differ from actual fill volume due to overfill requirements.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageInsertVersion rdf:type rdf:Property ;
    rdfs:label 'Package Insert Version' ;
    rdfs:comment 'Version identifier of the package insert or patient information leaflet included with this packaging configuration.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContainerMaterial rdf:type rdf:Property ;
    rdfs:label 'Primary Container Material' ;
    rdfs:comment 'Material composition of the primary container, critical for stability and compatibility with the drug substance. [ENUM-REF-CANDIDATE: glass_type_i|glass_type_ii|glass_type_iii|plastic_hdpe|plastic_ldpe|plastic_pet|plastic_pp|aluminum|laminate — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContainerType rdf:type rdf:Property ;
    rdfs:label 'Primary Container Type' ;
    rdfs:comment 'Type of primary container that is in direct contact with the drug product, part of the container closure system (CCS). [ENUM-REF-CANDIDATE: vial|ampoule|blister|bottle|syringe|cartridge|pen|inhaler|sachet|tube|pouch — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationLevel rdf:type rdf:Property ;
    rdfs:label 'Serialization Level' ;
    rdfs:comment 'Level at which unique serialization is applied for track-and-trace compliance (unit, pack, case, or pallet level).' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Description' ;
    rdfs:comment 'Detailed textual description of storage conditions including temperature range, humidity, light protection, and orientation requirements.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamperEvidentFeature rdf:type rdf:Property ;
    rdfs:label 'Tamper Evident Feature' ;
    rdfs:comment 'Type of tamper-evident feature incorporated into the packaging to ensure product integrity and patient safety.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tertiaryPackagingType rdf:type rdf:Property ;
    rdfs:label 'Tertiary Packaging Type' ;
    rdfs:comment 'Type of tertiary or shipper packaging used for bulk distribution and logistics, containing multiple secondary packs.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPerPrimaryPack rdf:type rdf:Property ;
    rdfs:label 'Units Per Primary Pack' ;
    rdfs:comment 'Number of individual dosage units (tablets, capsules, vials) contained in the primary packaging.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsPerSecondaryPack rdf:type rdf:Property ;
    rdfs:label 'Units Per Secondary Pack' ;
    rdfs:comment 'Number of primary containers included in one secondary package unit.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsPerTertiaryPack rdf:type rdf:Property ;
    rdfs:label 'Units Per Tertiary Pack' ;
    rdfs:comment 'Number of secondary packages contained in one tertiary shipper or case for distribution.' ;
    rdfs:domain ind:PackagingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commercialStatus rdf:type rdf:Property ;
    rdfs:label 'Commercial Status' ;
    rdfs:comment 'Current lifecycle status of the SKU in the market. Active indicates commercially available; discontinued indicates no longer manufactured but may have remaining inventory; withdrawn indicates removed from market for safety or regulatory reasons.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genericName rdf:type rdf:Property ;
    rdfs:label 'Generic Name' ;
    rdfs:comment 'International Nonproprietary Name (INN) or United States Adopted Name (USAN) for the active pharmaceutical ingredient (API) in this SKU.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Manufacturer\'s suggested retail price or wholesale acquisition cost (WAC) for the SKU in the local currency. Used for pricing strategy, contracting, and financial planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or name of the person who last modified the SKU master record. Required for audit trail and compliance with 21 CFR Part 11.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'Market-specific regulatory approval or authorization number (e.g., NDA number in US, MA number in EU, approval number in Japan). Links the SKU to its regulatory dossier.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementCode rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Code' ;
    rdfs:comment 'Market-specific reimbursement or pricing code used by payers and health authorities (e.g., HCPCS code in US, PZN in Germany). Enables claims processing and market access.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsProgram rdf:type rdf:Property ;
    rdfs:label 'Rems Program' ;
    rdfs:comment 'Name or identifier of the FDA-mandated REMS program if applicable. Null if no REMS required. REMS programs impose additional safety requirements for high-risk products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationRequired rdf:type rdf:Property ;
    rdfs:label 'Serialization Required' ;
    rdfs:comment 'Indicates whether the SKU is subject to serialization and track-and-trace requirements under DSCSA (US), FMD (EU), or other regional regulations. True if unique serial numbers must be applied at unit level.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Commercial brand name or trade name under which the SKU is marketed and sold. May differ by market or therapeutic indication.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productNdcCodeId rdf:type rdf:Property ;
    rdfs:label 'Product Ndc Code Id' ;
    rdfs:comment 'Unique identifier for the NDC registry record. Primary key for the product NDC code entity.' ;
    rdfs:domain ind:ProductNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelerLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Labeler Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to masterdata.legal_entity. Business justification: NDC labeler code must map to legal entity for FDA establishment registration, labeling compliance, product listing. Replaces denormalized labeler_name with FK for regulatory reporting (FDA SPL submiss' ;
    rdfs:domain ind:ProductNdcCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:activeIngredient rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient' ;
    rdfs:comment 'The substance or substances in the drug product responsible for the therapeutic effect. May list multiple active ingredients for combination products.' ;
    rdfs:domain ind:ProductNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelerCode rdf:type rdf:Property ;
    rdfs:label 'Labeler Code' ;
    rdfs:comment 'The first segment of the NDC identifying the labeler (manufacturer, repackager, or distributor). Assigned by FDA to the firm that manufactures, repacks, or distributes the drug product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Listing Expiration Date' ;
    rdfs:comment 'The date the FDA listing expires or was terminated. Null for active listings. Populated when a product is discontinued or delisted.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingEndDate rdf:type rdf:Property ;
    rdfs:label 'Marketing End Date' ;
    rdfs:comment 'The date the drug product was withdrawn from the market or discontinued. Null for products still being marketed.' ;
    rdfs:domain ind:ProductNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingStartDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Start Date' ;
    rdfs:comment 'The date the drug product was first commercially marketed in the United States. This is the date the product became available for sale.' ;
    rdfs:domain ind:ProductNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ndcNumber rdf:type rdf:Property ;
    rdfs:label 'Ndc Number' ;
    rdfs:comment 'The 10-digit or 11-digit FDA National Drug Code in standard format with hyphens separating labeler code, product code, and package code segments. This is the authoritative FDA-assigned identifier for the drug product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonProprietaryName rdf:type rdf:Property ;
    rdfs:label 'Non Proprietary Name' ;
    rdfs:comment 'The established or generic name of the drug product, typically the active pharmaceutical ingredient (API) name. May be the INN (International Nonproprietary Name) or USAN (United States Adopted Name).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'The third segment of the NDC identifying the package size and type for the drug product.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proprietaryName rdf:type rdf:Property ;
    rdfs:label 'Proprietary Name' ;
    rdfs:comment 'The trademarked brand name under which the drug product is marketed. Also known as the trade name or brand name.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxOtcIndicator rdf:type rdf:Property ;
    rdfs:label 'Rx Otc Indicator' ;
    rdfs:comment 'Indicates whether the drug product requires a prescription (Rx) or is available over-the-counter (OTC) without a prescription.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCriteriaMet rdf:type rdf:Property ;
    rdfs:label 'Gate Criteria Met' ;
    rdfs:comment 'Boolean flag indicating whether all predefined gate criteria for the current lifecycle stage have been successfully met. Used in stage-gate governance processes to authorize progression to next stage.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gateDecision rdf:type rdf:Property ;
    rdfs:label 'Gate Decision' ;
    rdfs:comment 'Formal decision outcome from the gate review committee. \'Go\' authorizes progression, \'conditional_go\' requires specific actions, \'hold\' pauses development, \'kill\' terminates the program, \'recycle\' returns to previous stage for additional work.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Gate Review Date' ;
    rdfs:comment 'Date when the formal gate review was conducted to assess readiness for stage transition. Part of the governance process ensuring disciplined portfolio management.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investmentToDate rdf:type rdf:Property ;
    rdfs:label 'Investment To Date' ;
    rdfs:comment 'Cumulative investment amount (in USD) spent on the product from inception through the current lifecycle stage. Includes R&D costs, clinical trial expenses, regulatory submission costs, and manufacturing setup. Used for ROI analysis and portfolio valuation.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Date' ;
    rdfs:comment 'Date when the milestone event occurred. May differ from stage_entry_date if there is administrative lag between milestone achievement and formal stage transition recording.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneEvent rdf:type rdf:Property ;
    rdfs:label 'Milestone Event' ;
    rdfs:comment 'Description of the key milestone event that triggered the current lifecycle stage transition (e.g., \'IND Submission Accepted\', \'Phase III Primary Endpoint Met\', \'FDA Approval Granted\', \'Commercial Launch Completed\'). Provides business context for stage changes.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPlannedStage rdf:type rdf:Property ;
    rdfs:label 'Next Planned Stage' ;
    rdfs:comment 'The anticipated next lifecycle stage based on current development plans. Used for forward-looking portfolio planning and resource forecasting. May be null for discontinued or terminated products. [ENUM-REF-CANDIDATE: discovery|preclinical|phase_i|phase_ii|phase_iii|nda_bla_submission|maa_submission|approved|launched|loe|discontinued — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStage rdf:type rdf:Property ;
    rdfs:label 'Previous Stage' ;
    rdfs:comment 'The immediately preceding lifecycle stage before the current stage. Enables tracking of stage transitions and identification of products that have been moved backward (e.g., from Phase III back to Phase II due to protocol amendments). [ENUM-REF-CANDIDATE: discovery|preclinical|phase_i|phase_ii|phase_iii|nda_bla_submission|maa_submission|approved|launched|loe|discontinued — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfSuccess rdf:type rdf:Property ;
    rdfs:label 'Probability Of Success' ;
    rdfs:comment 'Estimated probability (as percentage, 0.00 to 100.00) that the product will successfully progress through all remaining lifecycle stages to commercial launch. Based on historical success rates, clinical data, and competitive landscape. Used in risk-adjusted portfolio valuation (rNPV).' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedPeakSales rdf:type rdf:Property ;
    rdfs:label 'Projected Peak Sales' ;
    rdfs:comment 'Forecasted annual peak sales revenue (in USD) for the product at market maturity. Used for portfolio prioritization, resource allocation, and commercial planning. Updated as market intelligence and clinical data evolve.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage of the medicinal product in its development and commercial lifecycle. Tracks progression from early research through regulatory approval, market launch, loss of exclusivity (LOE), and eventual discontinuation. Critical for portfolio planning and resource allocation. [ENUM-REF-CANDIDATE: discovery|preclinical|phase_i|phase_ii|phase_iii|nda_bla_submission|maa_submission|approved|launched|loe|discontinued — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageEntryDate rdf:type rdf:Property ;
    rdfs:label 'Stage Entry Date' ;
    rdfs:comment 'Date when the product entered the current lifecycle stage. Used to calculate time-in-stage metrics and track development velocity against portfolio benchmarks.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageExitDate rdf:type rdf:Property ;
    rdfs:label 'Stage Exit Date' ;
    rdfs:comment 'Date when the product exited or is expected to exit the current lifecycle stage. Nullable for products still in active stage. Critical for forecasting and resource planning.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'Strategic importance ranking assigned by portfolio management based on alignment with corporate strategy, unmet medical need, commercial potential, and competitive positioning.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Target Launch Date' ;
    rdfs:comment 'Planned or forecasted commercial launch date for the product. Updated as development progresses and regulatory timelines become clearer. Critical for commercial planning and supply chain readiness.' ;
    rdfs:domain ind:Lifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryIdentifierId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Identifier Id' ;
    rdfs:comment 'Unique identifier for the regulatory identifier record. Primary key.' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusivityExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Expiration Date' ;
    rdfs:comment 'The date on which the regulatory exclusivity period expires, after which generic or biosimilar versions may be approved.' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identifierNumber rdf:type rdf:Property ;
    rdfs:label 'Identifier Number' ;
    rdfs:comment 'The actual regulatory identifier or listing code assigned by the health authority (e.g., NDA number, BLA number, MAA number, NDC code, JNDA number, PMDA approval number, NMPA registration number).' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'The type or category of regulatory identifier (e.g., NDA for New Drug Application, ANDA for Abbreviated New Drug Application, BLA for Biologics License Application, MAA for Marketing Authorization Application, NDC for National Drug Code). [ENUM-REF-CANDIDATE: NDA|ANDA|BLA|MAA|JNDA|PMDA Approval Number|NMPA Registration Number|NDC|EMA Product Number|Other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The regulatory health authority or governing body that issued this identifier (e.g., FDA, EMA, MHRA, PMDA, NMPA, WHO). [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCategory rdf:type rdf:Property ;
    rdfs:label 'Marketing Category' ;
    rdfs:comment 'The marketing category or classification of the product as defined by the regulatory authority (e.g., NDA, ANDA, BLA, OTC Monograph).' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcLabelerCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Labeler Code' ;
    rdfs:comment 'The labeler segment of the 10-digit NDC code, identifying the manufacturer or distributor. Applicable for US FDA NDC identifiers.' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcPackageCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Package Code' ;
    rdfs:comment 'The package segment of the 10-digit NDC code, identifying the package size and type. Applicable for US FDA NDC identifiers.' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcProductCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Product Code' ;
    rdfs:comment 'The product segment of the 10-digit NDC code, identifying the specific strength, dosage form, and formulation. Applicable for US FDA NDC identifiers.' ;
    rdfs:domain ind:RegulatoryIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerRequirement rdf:type rdf:Property ;
    rdfs:label 'Biomarker Requirement' ;
    rdfs:comment 'Description of any required biomarker, genetic marker, or diagnostic test result that must be present for the patient to be eligible for this indication. Examples include specific gene mutations, protein expression levels, or companion diagnostic test results. Null if no biomarker requirement exists.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakthroughDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Designation Flag' ;
    rdfs:comment 'Boolean indicator of whether this product-indication combination has received breakthrough therapy designation from FDA, indicating preliminary clinical evidence of substantial improvement over existing therapies for serious conditions. True indicates breakthrough designation granted; False indicates not designated.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalTrialIdentifier rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Identifier' ;
    rdfs:comment 'Primary clinical trial registry identifier for the pivotal study that supported approval of this product-indication combination. Format examples: NCT########, EUCTR####-######-##, ISRCTN########. Null for indications not yet in clinical trials or approved without trial data.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationPartners rdf:type rdf:Property ;
    rdfs:label 'Combination Partners' ;
    rdfs:comment 'List or description of other drugs, biologics, or therapeutic modalities that are approved or recommended for use in combination with this product for this indication. Null if monotherapy or combination_therapy_flag is False.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationTherapyFlag rdf:type rdf:Property ;
    rdfs:label 'Combination Therapy Flag' ;
    rdfs:comment 'Boolean indicator of whether this indication requires or recommends the product be used in combination with other therapeutic agents. True indicates combination therapy; False indicates monotherapy or therapy-agnostic indication.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contraindicationSummary rdf:type rdf:Property ;
    rdfs:label 'Contraindication Summary' ;
    rdfs:comment 'Summary of absolute contraindications or patient populations for whom this product-indication is not recommended or is prohibited due to safety concerns. Includes conditions, co-medications, or patient characteristics that preclude use.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseSeverity rdf:type rdf:Property ;
    rdfs:label 'Disease Severity' ;
    rdfs:comment 'The severity classification of the disease or condition for which this indication applies. Mild indicates minor symptoms; moderate indicates significant symptoms; severe indicates major impact on function; critical indicates immediate life risk; life_threatening indicates high mortality risk; not_applicable for preventive indications.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd 10 Code' ;
    rdfs:comment 'ICD-10 diagnosis code representing the disease or condition for which the product is indicated.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10Description rdf:type rdf:Property ;
    rdfs:label 'Icd 10 Description' ;
    rdfs:comment 'Full text description of the ICD-10 code representing the disease or condition.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationName rdf:type rdf:Property ;
    rdfs:label 'Indication Name' ;
    rdfs:comment 'The common or clinical name of the therapeutic indication or disease state that the product is approved or being investigated to treat.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationType rdf:type rdf:Property ;
    rdfs:label 'Indication Type' ;
    rdfs:comment 'The therapeutic purpose or clinical use category of the product for this indication. Treatment is active disease management; prevention is disease avoidance; diagnosis is disease detection; prophylaxis is pre-exposure prevention; palliation is symptom relief; risk_reduction is lowering disease probability.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelClaimText rdf:type rdf:Property ;
    rdfs:label 'Label Claim Text' ;
    rdfs:comment 'The exact verbatim text from the approved product label or package insert describing the indication, including any limitations, patient population specifics, or conditional use statements. This is the regulatory-approved language for marketing and prescribing.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientPopulation rdf:type rdf:Property ;
    rdfs:label 'Patient Population' ;
    rdfs:comment 'The age-based patient population segment for which this indication is approved or being studied. Adult typically 18-64 years; pediatric under 18 years; geriatric 65+ years; neonatal under 1 month; adolescent 12-17 years; all_ages indicates no age restriction.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adverseReactionsText rdf:type rdf:Property ;
    rdfs:label 'Adverse Reactions Text' ;
    rdfs:comment 'Full text of the Adverse Reactions section from the label, summarizing the most common and serious adverse events observed in clinical trials and post-marketing surveillance.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalPharmacologyText rdf:type rdf:Property ;
    rdfs:label 'Clinical Pharmacology Text' ;
    rdfs:comment 'Full text of the Clinical Pharmacology section from the label, describing the mechanism of action (MOA), pharmacokinetics (PK), and pharmacodynamics (PD) of the drug product.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contraindicationsText rdf:type rdf:Property ;
    rdfs:label 'Contraindications Text' ;
    rdfs:comment 'Full text of the Contraindications section from the label, listing situations where the drug product should not be used due to risk of harm.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosageAdministrationText rdf:type rdf:Property ;
    rdfs:label 'Dosage Administration Text' ;
    rdfs:comment 'Full text of the Dosage and Administration section from the label, providing instructions on how to prescribe, prepare, and administer the drug product.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugInteractionsText rdf:type rdf:Property ;
    rdfs:label 'Drug Interactions Text' ;
    rdfs:comment 'Full text of the Drug Interactions section from the label, describing known interactions with other drugs, foods, or substances that may affect efficacy or safety.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedName rdf:type rdf:Property ;
    rdfs:label 'Established Name' ;
    rdfs:comment 'The non-proprietary or generic name of the drug product, typically the International Nonproprietary Name (INN) or United States Adopted Name (USAN).' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationsText rdf:type rdf:Property ;
    rdfs:label 'Indications Text' ;
    rdfs:comment 'Full text of the Indications and Usage section from the label, describing the approved therapeutic uses and patient populations for the drug product.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Label Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the label is written (e.g., en for English, es for Spanish, ja for Japanese).' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelStatus rdf:type rdf:Property ;
    rdfs:label 'Label Status' ;
    rdfs:comment 'Current lifecycle status of the label. Draft = under development, Submitted = filed with regulatory authority, Approved = authorized but not yet effective, Active = currently in use, Superseded = replaced by newer version, Withdrawn = removed from use.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pregnancyCategory rdf:type rdf:Property ;
    rdfs:label 'Pregnancy Category' ;
    rdfs:comment 'Legacy FDA pregnancy category (A, B, C, D, X) for products approved before the Pregnancy and Lactation Labeling Rule (PLLR). Not Applicable for products approved after PLLR implementation.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxOtcStatus rdf:type rdf:Property ;
    rdfs:label 'Rx Otc Status' ;
    rdfs:comment 'Indicates whether the product requires a prescription (Rx), is available over-the-counter (OTC), or is behind-the-counter (BTC) requiring pharmacist consultation.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useInSpecificPopulationsText rdf:type rdf:Property ;
    rdfs:label 'Use In Specific Populations Text' ;
    rdfs:comment 'Full text of the Use in Specific Populations section from the label, providing information on use in pregnancy, lactation, pediatric, geriatric, and patients with renal or hepatic impairment.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningsPrecautionsText rdf:type rdf:Property ;
    rdfs:label 'Warnings Precautions Text' ;
    rdfs:comment 'Full text of the Warnings and Precautions section from the label, describing serious adverse reactions, potential safety hazards, and steps to prevent or manage them.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationProductId rdf:type rdf:Property ;
    rdfs:label 'Combination Product Id' ;
    rdfs:comment 'Unique identifier for the combination product record. Primary key.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceManufacturerBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Device Manufacturer Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Combination products involve a device constituent typically manufactured by a device company partner. Managing the device manufacturer as a business partner is required for quality agreements, design ' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:biologicConstituentClassification rdf:type rdf:Property ;
    rdfs:label 'Biologic Constituent Classification' ;
    rdfs:comment 'Regulatory status of the biologic constituent under BLA (Biologics License Application) or biosimilar pathway.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biologicConstituentName rdf:type rdf:Property ;
    rdfs:label 'Biologic Constituent Name' ;
    rdfs:comment 'Name of the biological product component if the combination product includes a biologic (e.g., monoclonal antibody, vaccine antigen, cell therapy).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmcDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Cmc Documentation Reference' ;
    rdfs:comment 'Reference identifier to the CMC section of regulatory submissions documenting manufacturing processes, specifications, and controls for both drug and device constituents.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationProductCode rdf:type rdf:Property ;
    rdfs:label 'Combination Product Code' ;
    rdfs:comment 'Business identifier code assigned to the combination product for internal tracking and regulatory submissions.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationType rdf:type rdf:Property ;
    rdfs:label 'Combination Type' ;
    rdfs:comment 'Classification of the combination product based on constituent components (e.g., drug-device for auto-injectors, drug-biologic for antibody-drug conjugates).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossLabelingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Labeling Requirement Flag' ;
    rdfs:comment 'Indicates whether the combination product requires coordinated labeling across drug and device constituents to ensure consistent safety and efficacy information.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceConstituentClassification rdf:type rdf:Property ;
    rdfs:label 'Device Constituent Classification' ;
    rdfs:comment 'FDA device classification and regulatory pathway for the device constituent (510k=premarket notification, PMA=premarket approval, De Novo=novel device classification).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceConstituentName rdf:type rdf:Property ;
    rdfs:label 'Device Constituent Name' ;
    rdfs:comment 'Name or description of the device component of the combination product (e.g., auto-injector, prefilled syringe, transdermal patch delivery system, drug-eluting stent).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceDesignHistoryFileReference rdf:type rdf:Property ;
    rdfs:label 'Device Design History File Reference' ;
    rdfs:comment 'Reference identifier to the Design History File documenting the device constituent design, development, and verification activities per Quality System Regulation (QSR).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugConstituentClassification rdf:type rdf:Property ;
    rdfs:label 'Drug Constituent Classification' ;
    rdfs:comment 'Regulatory status of the drug constituent (NDA=New Drug Application, ANDA=Abbreviated New Drug Application, BLA=Biologics License Application, IND=Investigational New Drug).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugConstituentStrength rdf:type rdf:Property ;
    rdfs:label 'Drug Constituent Strength' ;
    rdfs:comment 'Quantitative composition of the drug constituent expressed with unit of measure (e.g., 50 mg, 0.3 mL of 1 mg/mL solution).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Status' ;
    rdfs:comment 'Current GMP compliance status for the combination product manufacturing operations based on FDA inspection outcomes.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanFactorsStudyStatus rdf:type rdf:Property ;
    rdfs:label 'Human Factors Study Status' ;
    rdfs:comment 'Status of human factors engineering and usability validation studies required for the device constituent to demonstrate safe and effective use by intended users.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadCenter rdf:type rdf:Property ;
    rdfs:label 'Lead Center' ;
    rdfs:comment 'FDA center assigned primary jurisdiction for premarket review and regulation (CDER=Center for Drug Evaluation and Research, CDRH=Center for Devices and Radiological Health, CBER=Center for Biologics Evaluation and Research).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryModeOfAction rdf:type rdf:Property ;
    rdfs:label 'Primary Mode Of Action' ;
    rdfs:comment 'The single mode of action that provides the most important therapeutic action of the combination product, used to determine lead center assignment.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbdApproachFlag rdf:type rdf:Property ;
    rdfs:label 'Qbd Approach Flag' ;
    rdfs:comment 'Indicates whether the combination product was developed using Quality by Design principles with defined design space and control strategy.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Number' ;
    rdfs:comment 'FDA-assigned submission number for the combination product application (NDA, BLA, PMA, or 510k number).' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Requirement Flag' ;
    rdfs:comment 'Indicates whether the combination product is subject to a Risk Evaluation and Mitigation Strategy to ensure benefits outweigh risks.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rldAssignmentDate rdf:type rdf:Property ;
    rdfs:label 'Rld Assignment Date' ;
    rdfs:comment 'Date when the FDA assigned the lead center designation for this combination product following RLD submission.' ;
    rdfs:domain ind:CombinationProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Board Certification Date' ;
    rdfs:comment 'Date when the HCP achieved board certification in their primary specialty.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardCertificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Board Certification Expiration Date' ;
    rdfs:comment 'Expiration date of the current board certification. Requires renewal to maintain certified status.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Board Certification Status' ;
    rdfs:comment 'Current status of board certification for the HCP in their primary specialty.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the healthcare professional. Used for identity verification and credential validation.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Dea Expiration Date' ;
    rdfs:comment 'Expiration date of the DEA controlled substance registration. Requires renewal every three years.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deaStatus rdf:type rdf:Property ;
    rdfs:label 'Dea Status' ;
    rdfs:comment 'Current status of the DEA controlled substance registration.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSourceCode rdf:type rdf:Property ;
    rdfs:label 'External Source Code' ;
    rdfs:comment 'Unique identifier for this HCP in the external source system (e.g., IQVIA OneKey ID, Veeva CRM Account ID). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Gender identity of the healthcare professional as self-reported or registered.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpStatus rdf:type rdf:Property ;
    rdfs:label 'Hcp Status' ;
    rdfs:comment 'Current lifecycle status of the HCP record in the master data system. Active indicates the HCP is currently practicing and eligible for engagement.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolStatus rdf:type rdf:Property ;
    rdfs:label 'Kol Status' ;
    rdfs:comment 'Classification indicating whether the HCP is recognized as a Key Opinion Leader in their therapeutic area. KOLs are influential practitioners engaged for medical education, advisory boards, and clinical research.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolTier rdf:type rdf:Property ;
    rdfs:label 'Kol Tier' ;
    rdfs:comment 'Tiered classification of KOL influence level. Tier 1 represents national/international thought leaders, Tier 2 regional influencers, Tier 3 local experts.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescribingAuthority rdf:type rdf:Property ;
    rdfs:label 'Prescribing Authority' ;
    rdfs:comment 'Boolean flag indicating whether the HCP has legal authority to prescribe medications. True for physicians, nurse practitioners, and physician assistants with prescribing privileges.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Primary Email Address' ;
    rdfs:comment 'Primary email address for professional communication with the HCP.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Primary License Expiration Date' ;
    rdfs:comment 'Expiration date of the primary medical license. Requires renewal to maintain active practice authority.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryLicenseIssueDate rdf:type rdf:Property ;
    rdfs:label 'Primary License Issue Date' ;
    rdfs:comment 'Date when the primary medical license was originally issued by the state medical board.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Primary License Number' ;
    rdfs:comment 'Primary state medical license number issued by the state medical board. Authoritative credential for legal practice authority.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseState rdf:type rdf:Property ;
    rdfs:label 'Primary License State' ;
    rdfs:comment 'Two-letter US state code for the jurisdiction that issued the primary medical license (e.g., CA, NY, TX).' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseStatus rdf:type rdf:Property ;
    rdfs:label 'Primary License Status' ;
    rdfs:comment 'Current status of the primary medical license as reported by the state medical board.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Primary Phone Number' ;
    rdfs:comment 'Primary contact phone number for the HCP at their practice location.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Address Line1' ;
    rdfs:comment 'First line of the primary practice address where the HCP sees patients (street address, building number).' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Address Line2' ;
    rdfs:comment 'Second line of the primary practice address (suite, floor, department).' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeCity rdf:type rdf:Property ;
    rdfs:label 'Primary Practice City' ;
    rdfs:comment 'City of the primary practice location.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeCountry rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Country' ;
    rdfs:comment 'Three-letter ISO country code for the primary practice location (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticePostalCode rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Postal Code' ;
    rdfs:comment 'ZIP code or postal code of the primary practice location. Format: 5 digits or 5+4 digits.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPracticeState rdf:type rdf:Property ;
    rdfs:label 'Primary Practice State' ;
    rdfs:comment 'Two-letter US state code for the primary practice location (e.g., CA, NY, TX).' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySpecialty rdf:type rdf:Property ;
    rdfs:label 'Primary Specialty' ;
    rdfs:comment 'Primary medical specialty or therapeutic area of practice for the HCP (e.g., Oncology, Cardiology, Immunology). Aligned with AMA specialty taxonomy.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalDesignation rdf:type rdf:Property ;
    rdfs:label 'Professional Designation' ;
    rdfs:comment 'Professional designation or degree type of the healthcare professional (e.g., MD for Medical Doctor, DO for Doctor of Osteopathic Medicine, PharmD for Doctor of Pharmacy). [ENUM-REF-CANDIDATE: MD|DO|PharmD|RN|NP|PA|DDS|DVM|PhD|Other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suffix rdf:type rdf:Property ;
    rdfs:label 'Suffix' ;
    rdfs:comment 'Professional or generational suffix appended to the HCP name (e.g., Jr., Sr., MD, PhD). [ENUM-REF-CANDIDATE: Jr|Sr|II|III|IV|V|MD|DO|PhD|PharmD|RN|NP|PA — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiration Date' ;
    rdfs:comment 'Date when the current accreditation certification expires. Triggers re-evaluation and compliance monitoring workflows.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current accreditation status from recognized healthcare accreditation bodies. Indicates quality standards compliance and eligibility for certain programs.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditingBody rdf:type rdf:Property ;
    rdfs:label 'Accrediting Body' ;
    rdfs:comment 'Name of the primary accreditation organization that has certified this healthcare organization (e.g., Joint Commission, NCQA, DNV, AAAHC).' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedCount rdf:type rdf:Property ;
    rdfs:label 'Bed Count' ;
    rdfs:comment 'Total number of licensed inpatient beds at the healthcare facility. Used for market sizing, territory planning, and commercial targeting segmentation.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmsCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Cms Certification Number' ;
    rdfs:comment 'CMS Certification Number (CCN) assigned to Medicare-certified healthcare facilities. Six-character alphanumeric identifier used for Medicare reimbursement.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the healthcare organization location. Determines applicable regulatory framework and market access requirements.' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or doing business as name used by the healthcare organization for commercial purposes.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for administrative contact at the healthcare organization.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Primary fax number for the healthcare organization. Still used for HIPAA-compliant document transmission in healthcare.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyStatus rdf:type rdf:Property ;
    rdfs:label 'Formulary Status' ;
    rdfs:comment 'Type of drug formulary management approach used by the organization. Determines market access strategy and pull-through tactics.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcoName rdf:type rdf:Property ;
    rdfs:label 'Hco Name' ;
    rdfs:comment 'Official legal name of the healthcare organization as registered with regulatory authorities.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcoType rdf:type rdf:Property ;
    rdfs:label 'Hco Type' ;
    rdfs:comment 'Classification of the healthcare organization by institutional type. Determines engagement strategy and regulatory requirements.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idnAffiliation rdf:type rdf:Property ;
    rdfs:label 'Idn Affiliation' ;
    rdfs:comment 'Name of the parent Integrated Delivery Network (IDN) or health system to which this organization belongs. Critical for account-based selling and contracting strategy.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the HCO master data was last verified or validated for accuracy. Drives data quality monitoring and stewardship workflows.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:magnetStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Magnet Status Flag' ;
    rdfs:comment 'Indicates whether the hospital has achieved Magnet Recognition from the American Nurses Credentialing Center (ANCC). Signifies nursing excellence and quality of care.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:n340bEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'N340b Eligible Flag' ;
    rdfs:comment 'Indicates whether the organization is eligible for the federal 340B Drug Pricing Program. Impacts pricing, contracting, and distribution strategy.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npi rdf:type rdf:Property ;
    rdfs:label 'Npi' ;
    rdfs:comment 'Unique 10-digit National Provider Identifier assigned by CMS for healthcare organizations. Type 2 NPI for organizational providers. Required for Medicare/Medicaid billing and HIPAA compliance.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationStatus rdf:type rdf:Property ;
    rdfs:label 'Organization Status' ;
    rdfs:comment 'Current operational status of the healthcare organization in the master data system. Drives eligibility for commercial engagement and sample distribution.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the healthcare organization main switchboard or administrative office.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax ID for the healthcare organization. Used for financial transactions, 1099 reporting, and Sunshine Act compliance.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teachingHospitalFlag rdf:type rdf:Property ;
    rdfs:label 'Teaching Hospital Flag' ;
    rdfs:comment 'Indicates whether the organization is a teaching hospital affiliated with a medical school. Teaching hospitals are priority targets for medical affairs and Key Opinion Leader (KOL) engagement.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:traumaLevel rdf:type rdf:Property ;
    rdfs:label 'Trauma Level' ;
    rdfs:comment 'Trauma center designation level indicating capability to provide comprehensive emergency care. Level 1 centers have the highest capability.' ;
    rdfs:domain ind:HcoMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL for the healthcare organization. Used for digital engagement and research.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardName rdf:type rdf:Property ;
    rdfs:label 'Board Name' ;
    rdfs:comment 'The name of the medical board that issued the board certification. Examples: American Board of Internal Medicine, American Board of Surgery. Applicable only for board certification license types.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'The level of board certification status. Board certified indicates full certification; board eligible indicates eligibility but not yet certified; recertified indicates successful recertification.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstanceAuthority rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Authority' ;
    rdfs:comment 'Indicates whether this license grants the HCP authority to prescribe controlled substances. True if authorized; False otherwise. Requires valid DEA registration.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Data Source Record Reference' ;
    rdfs:comment 'The unique identifier of this license record in the source system. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionDescription rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Description' ;
    rdfs:comment 'Detailed description of any disciplinary actions, sanctions, or restrictions associated with the license. Includes nature of action, date, and resolution status. Used for compliance risk assessment.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Flag' ;
    rdfs:comment 'Indicates whether the license has any associated disciplinary actions, sanctions, or restrictions. True if disciplinary action exists; False otherwise. Triggers compliance review before HCP engagement.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date the license was originally issued by the licensing authority. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingState rdf:type rdf:Property ;
    rdfs:label 'Issuing State' ;
    rdfs:comment 'The U.S. state or jurisdiction where the license was issued. Uses two-letter state abbreviation (e.g., CA, NY, TX). For federal licenses like DEA, this may indicate the primary registration state.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current status of the license in its lifecycle. Active licenses are valid for HCP engagement; expired, suspended, or revoked licenses require compliance review before any promotional or medical interaction.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'The category of professional license or credential. Distinguishes between medical licenses, DEA (Drug Enforcement Administration) registrations, board certifications, and specialty credentials. [ENUM-REF-CANDIDATE: medical_license|dea_registration|board_certification|specialty_credential|state_pharmacy_license|nursing_license|controlled_substance_license — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Primary License Flag' ;
    rdfs:comment 'Indicates whether this is the HCP\'s primary or principal license. True if primary; False if secondary or supplementary. Used to identify the main license for compliance validation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Record Active Flag' ;
    rdfs:comment 'Indicates whether this license record is currently active in the system. True if active; False if logically deleted or archived. Used for soft delete pattern.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Restriction Description' ;
    rdfs:comment 'Detailed description of any restrictions or limitations on the license. Specifies the nature and scope of restrictions for compliance purposes.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Restriction Flag' ;
    rdfs:comment 'Indicates whether the license has any practice restrictions or limitations. True if restrictions exist; False otherwise. Examples: limited to certain procedures, supervision required, geographic restrictions.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyCode rdf:type rdf:Property ;
    rdfs:label 'Specialty Code' ;
    rdfs:comment 'Standardized code representing the medical specialty. May use AMA specialty taxonomy codes or internal classification codes for analytics and reporting.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date the license was last verified against the issuing authority\'s records. Used for compliance audit trails and to ensure data accuracy. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to verify the license. Manual indicates human review; automated indicates system-based verification; third_party_service indicates use of external verification vendors; self_reported indicates HCP-provided data pending verification.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The name of the source used to verify the license. Examples: State Medical Board website, NPPES (National Plan and Provider Enumeration System), third-party credentialing service.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationId rdf:type rdf:Property ;
    rdfs:label 'Affiliation Id' ;
    rdfs:comment 'Unique identifier for the HCP affiliation relationship record. Primary key for the affiliation entity.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affiliationAffiliatedHcpPhysicianMasterId rdf:type rdf:Property ;
    rdfs:label 'Affiliation Affiliated Hcp Physician Master Id' ;
    rdfs:comment 'Foreign key reference to another HCP in HCP-to-HCP affiliation relationships (e.g., referral networks, group practice partnerships). Nullable when affiliation is HCP-to-HCO.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:admittingPrivilegesFlag rdf:type rdf:Property ;
    rdfs:label 'Admitting Privileges Flag' ;
    rdfs:comment 'Boolean flag indicating whether the HCP has hospital admitting privileges at this affiliated HCO. True if the HCP can admit patients; False otherwise.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affiliationStatus rdf:type rdf:Property ;
    rdfs:label 'Affiliation Status' ;
    rdfs:comment 'Current lifecycle status of the affiliation relationship. Indicates whether the affiliation is currently valid and operational.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationType rdf:type rdf:Property ;
    rdfs:label 'Affiliation Type' ;
    rdfs:comment 'Classification of the affiliation relationship between the HCP and HCO or between two HCPs. Defines the nature of the professional relationship.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationArrangementType rdf:type rdf:Property ;
    rdfs:label 'Compensation Arrangement Type' ;
    rdfs:comment 'The type of compensation arrangement associated with this affiliation, if any. Required for Sunshine Act transparency reporting and anti-kickback compliance.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Expiration Date' ;
    rdfs:comment 'The date when the HCP\'s credentialing at this affiliated organization expires and requires renewal. Used for compliance monitoring and re-credentialing workflows.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingStatus rdf:type rdf:Property ;
    rdfs:label 'Credentialing Status' ;
    rdfs:comment 'The current credentialing status of the HCP at this affiliated organization. Indicates whether the HCP has completed required credentialing processes.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'The department, division, or practice unit within the HCO where the HCP holds this affiliation (e.g., Oncology Department, Cardiology Division).' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyInfluenceLevel rdf:type rdf:Property ;
    rdfs:label 'Formulary Influence Level' ;
    rdfs:comment 'Assessment of the HCP\'s level of influence over formulary decisions at this affiliated organization. Used for Key Opinion Leader (KOL) identification and targeting.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullTimeEquivalent rdf:type rdf:Property ;
    rdfs:label 'Full Time Equivalent' ;
    rdfs:comment 'The proportion of full-time work the HCP dedicates to this affiliation, expressed as a decimal (e.g., 1.00 for full-time, 0.50 for half-time). Used for capacity planning and engagement prioritization.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryAffiliation rdf:type rdf:Property ;
    rdfs:label 'Is Primary Affiliation' ;
    rdfs:comment 'Boolean flag indicating whether this is the HCP\'s primary or main affiliation. True if this is the principal place of practice; False otherwise.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kolDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Kol Designation Flag' ;
    rdfs:comment 'Boolean flag indicating whether the HCP is designated as a Key Opinion Leader (KOL) within this affiliation context. True if KOL status applies; False otherwise.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'The date when this affiliation record was last verified or validated. Used for data quality monitoring and re-verification scheduling.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npiAtAffiliation rdf:type rdf:Property ;
    rdfs:label 'Npi At Affiliation' ;
    rdfs:comment 'The National Provider Identifier (NPI) the HCP uses at this specific affiliation. An HCP may have different NPIs for different practice locations or affiliations.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescribingAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Prescribing Authority Flag' ;
    rdfs:comment 'Boolean flag indicating whether the HCP has prescribing authority at this affiliated organization. True if the HCP can prescribe medications; False otherwise.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralDirection rdf:type rdf:Property ;
    rdfs:label 'Referral Direction' ;
    rdfs:comment 'The direction of patient referrals in this affiliation relationship. Indicates whether the HCP receives referrals, sends referrals, or both.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralRelationshipFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Relationship Flag' ;
    rdfs:comment 'Boolean flag indicating whether this affiliation represents a referral relationship (HCP-to-HCP). True if the affiliation involves patient referrals; False otherwise.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'The professional role or job title the HCP holds within this affiliation (e.g., Chief of Cardiology, Attending Physician, Clinical Director, Partner).' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyAtAffiliation rdf:type rdf:Property ;
    rdfs:label 'Specialty At Affiliation' ;
    rdfs:comment 'The medical specialty or therapeutic area the HCP practices within this specific affiliation. May differ from the HCP\'s primary specialty if they hold multiple affiliations.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'State License Number' ;
    rdfs:comment 'The state medical license number the HCP holds for practice at this affiliated organization. Required for credentialing and compliance verification.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthScore rdf:type rdf:Property ;
    rdfs:label 'Strength Score' ;
    rdfs:comment 'Quantitative measure of the strength or influence of this affiliation relationship, typically ranging from 0.00 to 100.00. Used for network mapping and prescribing influence analysis.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTherapeuticAreaId rdf:type rdf:Property ;
    rdfs:label 'Primary Therapeutic Area Id' ;
    rdfs:comment 'Foreign key linking to product.therapeutic_area. Business justification: KOL profiles are segmented by therapeutic area for medical affairs targeting, MSL assignment, and engagement strategy planning. Replaces denormalized primary_therapeutic_area text with structured FK f' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TherapeuticArea .

ind:academicRank rdf:type rdf:Property ;
    rdfs:label 'Academic Rank' ;
    rdfs:comment 'The KOL\'s academic title or rank at their primary affiliated institution. Indicates seniority, teaching responsibilities, and academic influence. [ENUM-REF-CANDIDATE: professor|associate_professor|assistant_professor|clinical_instructor|adjunct_faculty|emeritus|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advisoryBoardParticipationCount rdf:type rdf:Property ;
    rdfs:label 'Advisory Board Participation Count' ;
    rdfs:comment 'Total number of advisory board meetings or panels the KOL has participated in. Indicates level of industry engagement and strategic advisory experience.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinicalTrialInvestigatorFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Investigator Flag' ;
    rdfs:comment 'Indicates whether the KOL has served as a principal investigator (PI) or sub-investigator on clinical trials. True if the HCP has investigator experience, false otherwise. Used to identify KOLs with hands-on clinical research expertise.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Clearance Date' ;
    rdfs:comment 'Date when the most recent compliance clearance was completed and approved. Used to track clearance currency and schedule re-verification.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceClearanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Clearance Expiry Date' ;
    rdfs:comment 'Date when the current compliance clearance expires and re-verification is required. Used to proactively manage compliance renewal workflows.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Clearance Status' ;
    rdfs:comment 'Current compliance and credentialing clearance status for the KOL. Cleared indicates the KOL has passed all compliance checks and is eligible for engagement, pending indicates review in progress, flagged indicates potential compliance concerns requiring investigation, excluded indicates the KOL is on an exclusion list (OIG, SAM) and cannot be engaged, and expired indicates clearance has lapsed and requires renewal.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictOfInterestDisclosure rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Disclosure' ;
    rdfs:comment 'Summary of disclosed conflicts of interest, including financial relationships with other pharmaceutical or medical device companies, equity holdings, consulting arrangements, or advisory roles. Used to manage transparency and mitigate bias in scientific engagements.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congressSpeakingCount rdf:type rdf:Property ;
    rdfs:label 'Congress Speaking Count' ;
    rdfs:comment 'Number of presentations, lectures, or speaking engagements the KOL has delivered at medical congresses, symposia, or scientific conferences. Reflects public visibility and thought leadership.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departmentChairFlag rdf:type rdf:Property ;
    rdfs:label 'Department Chair Flag' ;
    rdfs:comment 'Indicates whether the KOL serves as a department chair or division head at their primary institution. True if the KOL holds a leadership position, false otherwise. Reflects institutional leadership and decision-making authority.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fellowshipInstitution rdf:type rdf:Property ;
    rdfs:label 'Fellowship Institution' ;
    rdfs:comment 'Name of the institution where the KOL completed their fellowship training. Indicates specialized training and institutional network.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineAuthorshipFlag rdf:type rdf:Property ;
    rdfs:label 'Guideline Authorship Flag' ;
    rdfs:comment 'Indicates whether the KOL has authored or co-authored clinical practice guidelines, consensus statements, or treatment recommendations. True if guideline authorship exists, false otherwise. Reflects standard-of-care influence.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hIndex rdf:type rdf:Property ;
    rdfs:label 'H Index' ;
    rdfs:comment 'Hirsch index measuring the productivity and citation impact of the KOL\'s published work. An h-index of n means the researcher has n publications with at least n citations each. Used to quantify scientific influence and publication quality.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCongressSpeakingDate rdf:type rdf:Property ;
    rdfs:label 'Last Congress Speaking Date' ;
    rdfs:comment 'Date of the most recent congress or conference speaking engagement by the KOL. Used to assess recency of public thought leadership activity.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMslInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Msl Interaction Date' ;
    rdfs:comment 'Date of the most recent interaction or engagement between an MSL and the KOL. Used to track engagement recency and plan follow-up activities.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Last Publication Date' ;
    rdfs:comment 'Date of the KOL\'s most recent peer-reviewed publication. Indicates currency of scientific contribution and active research status.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalSchool rdf:type rdf:Property ;
    rdfs:label 'Medical School' ;
    rdfs:comment 'Name of the medical school or institution where the KOL obtained their medical degree. Provides context on educational background and institutional affiliations.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mslEngagementStrategy rdf:type rdf:Property ;
    rdfs:label 'Msl Engagement Strategy' ;
    rdfs:comment 'Strategic priority level for Medical Science Liaison engagement with this KOL. High priority KOLs receive frequent proactive outreach, medium priority receive periodic engagement, low priority are engaged opportunistically, monitor only are tracked but not actively engaged, and do not contact indicates compliance or relationship restrictions.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orcidNumber rdf:type rdf:Property ;
    rdfs:label 'Orcid Number' ;
    rdfs:comment 'Unique persistent digital identifier for the researcher, used to disambiguate authors and link research outputs. Format: 0000-0000-0000-0000.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peerReviewedPublicationCount rdf:type rdf:Property ;
    rdfs:label 'Peer Reviewed Publication Count' ;
    rdfs:comment 'Total number of peer-reviewed journal articles, reviews, and original research publications authored or co-authored by the KOL. Reflects scientific productivity and contribution to medical literature.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAffiliation rdf:type rdf:Property ;
    rdfs:label 'Primary Affiliation' ;
    rdfs:comment 'The main hospital, academic medical center, research institution, or healthcare organization where the KOL holds a primary appointment or practices. Critical for understanding institutional influence and access.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalInvestigatorTrialCount rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Trial Count' ;
    rdfs:comment 'Number of clinical trials where the KOL has served as the principal investigator. Reflects depth of clinical research leadership and trial management experience.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Created Timestamp' ;
    rdfs:comment 'Timestamp when the KOL profile record was first created in the system. Used for audit trail and data lineage tracking.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profileUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Profile Updated By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last updated the KOL profile record. Used for audit trail and accountability.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Profile Updated Timestamp' ;
    rdfs:comment 'Timestamp when the KOL profile record was most recently updated. Used for audit trail, change tracking, and data currency assessment.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scopusAuthorNumber rdf:type rdf:Property ;
    rdfs:label 'Scopus Author Number' ;
    rdfs:comment 'Unique identifier assigned by Elsevier Scopus to track the KOL\'s publications and citation metrics. Used for bibliometric analysis and publication tracking.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:societyLeadershipFlag rdf:type rdf:Property ;
    rdfs:label 'Society Leadership Flag' ;
    rdfs:comment 'Indicates whether the KOL holds or has held a leadership position (board member, committee chair, president) in a professional medical society. True if leadership role exists, false otherwise. Reflects industry influence and governance participation.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:societyMembershipList rdf:type rdf:Property ;
    rdfs:label 'Society Membership List' ;
    rdfs:comment 'List of professional medical societies, associations, or organizations where the KOL holds membership. Examples include American Society of Clinical Oncology (ASCO), American College of Cardiology (ACC), European Society for Medical Oncology (ESMO). Stored as delimited text.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCitationCount rdf:type rdf:Property ;
    rdfs:label 'Total Citation Count' ;
    rdfs:comment 'Cumulative number of citations received across all of the KOL\'s published works. Indicates the breadth of scientific impact and recognition within the research community.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMslInteractionCount rdf:type rdf:Property ;
    rdfs:label 'Total Msl Interaction Count' ;
    rdfs:comment 'Cumulative number of documented interactions between MSLs and the KOL. Reflects depth of relationship and engagement history.' ;
    rdfs:domain ind:KolProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementId rdf:type rdf:Property ;
    rdfs:label 'Engagement Id' ;
    rdfs:comment 'Unique identifier for the HCP (Healthcare Professional) or HCO (Healthcare Organization) engagement record. Primary key.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speakerProgramId rdf:type rdf:Property ;
    rdfs:label 'Speaker Program Id' ;
    rdfs:comment 'Foreign key linking to hcp.hcp_speaker_program. Business justification: Speaker program events are a specific type of HCP engagement. When a field rep or MSL logs an engagement that is part of a speaker program event, linking hcp_engagement to hcp_speaker_program provides' ;
    rdfs:domain ind:Hcp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpeakerProgram .

ind:adverseEventReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Reported Flag' ;
    rdfs:comment 'Boolean indicator of whether an adverse event was reported by the HCP during this engagement. True if an AE was mentioned, triggering pharmacovigilance follow-up. False otherwise.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewed Flag' ;
    rdfs:comment 'Boolean indicator of whether this engagement record has been reviewed and approved by compliance or legal teams. True if reviewed, False if pending review.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the engagement activity measured in minutes. Calculated from start and end times or manually entered.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Precise timestamp when the engagement activity concluded. Used for duration calculation and resource planning.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementNumber rdf:type rdf:Property ;
    rdfs:label 'Engagement Number' ;
    rdfs:comment 'Business-facing unique identifier for the engagement record. Human-readable reference number used in Veeva CRM and reporting.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next planned follow-up action or engagement with this HCP. Nullable if no follow-up is planned.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Planned or actual frequency of professional interactions between the employee and HCP for this relationship. Used for territory planning, resource allocation, and relationship maintenance strategies.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpFeedback rdf:type rdf:Property ;
    rdfs:label 'Hcp Feedback' ;
    rdfs:comment 'Free-text capture of feedback, questions, or comments provided by the HCP during the engagement. Used for medical affairs insights and product feedback loops.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyMessageDelivered rdf:type rdf:Property ;
    rdfs:label 'Key Message Delivered' ;
    rdfs:comment 'The primary approved key message or talking point that was communicated during the engagement. Aligns with approved promotional messaging and Medical-Legal-Regulatory (MLR) reviewed content.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent professional interaction (meeting, call, email exchange, conference encounter) between this employee and HCP. Used to identify stale relationships requiring re-engagement and for compliance reporting of HCP interaction frequency.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Free-text description of the physical or virtual location where the engagement occurred. May include office name, hospital department, conference venue, or virtual platform name.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsShared rdf:type rdf:Property ;
    rdfs:label 'Materials Shared' ;
    rdfs:comment 'Description or list of promotional materials, medical information documents, or educational resources shared with the HCP during the engagement. May include brochure names, approved material IDs, or content titles.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalInquiryFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Inquiry Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP made a medical information request or inquiry during the engagement. True if a medical inquiry was raised, False otherwise. Triggers medical affairs follow-up.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Free-text description of the planned follow-up action or next step resulting from this engagement. May include scheduling another meeting, sending additional information, or other commitments.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this employee is designated as the primary point of contact for this HCP within the organization. Used for routing inquiries, coordinating multi-functional engagement, and preventing duplicate outreach. An HCP may have different primary contacts for different therapeutic areas.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when this employee-HCP engagement relationship was formally ended or reassigned. Null for active relationships. Used for tracking relationship handoffs during territory changes, employee transitions, or strategic deprioritization.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when this employee-HCP engagement relationship was formally established or assigned. Used for relationship tenure analysis, onboarding tracking, and historical relationship mapping.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of this HCP-employee engagement relationship. Active relationships require ongoing management and interaction tracking. Inactive or Suspended relationships are retained for historical analysis and potential reactivation.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength Score' ;
    rdfs:comment 'Quantitative metric (0-100 scale) assessing the strength and quality of this specific HCP-employee engagement relationship based on interaction frequency, responsiveness, collaboration depth, and strategic value. Used for prioritizing engagement efforts and measuring field team effectiveness.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classification of the professional engagement relationship type based on the employee\'s role and function in medical affairs (e.g., MSL for field-based scientific exchange, Medical Director for strategic advisory relationships, Clinical Scientist for research collaboration).' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplesProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Samples Provided Flag' ;
    rdfs:comment 'Boolean indicator of whether product samples were provided to the HCP during this engagement. True if samples were dispensed, False otherwise.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Precise timestamp when the engagement activity began. Used for duration calculation and detailed scheduling analytics.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:territoryAssignment rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment' ;
    rdfs:comment 'Geographic or organizational territory code under which this HCP-employee engagement relationship is managed. Used for field force alignment, territory planning, and sales/medical affairs coordination. Territory assignments can change during organizational restructuring while maintaining relationship continuity.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferOfValueAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Of Value Amount' ;
    rdfs:comment 'Monetary value of any transfer of value provided to the HCP during this engagement. Includes meals, honoraria, consulting fees, or other payments. Nullable if no transfer of value occurred. Used for Sunshine Act transparency reporting.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferOfValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Transfer Of Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transfer of value amount. Nullable if no transfer of value occurred.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequestId rdf:type rdf:Property ;
    rdfs:label 'Sample Request Id' ;
    rdfs:comment 'Unique identifier for the drug sample request record. Primary key for sample accountability tracking under 21 CFR Part 203 (Prescription Drug Marketing Act).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleRequest .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address where drug samples were delivered. Typically the HCP practice or clinic address.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address information such as suite number, floor, or building designation for sample delivery location.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City where drug samples were delivered to the HCP.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the sample delivery address. Format: 3 uppercase letters (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which drug samples were delivered to the HCP. In-person delivery by sales rep is most common for accountability.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the sample delivery address.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State or province code for the sample delivery address. Used for geographic compliance tracking and territory assignment.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityApproved rdf:type rdf:Property ;
    rdfs:label 'Quantity Approved' ;
    rdfs:comment 'Number of sample units approved for fulfillment. May differ from quantity requested based on inventory availability and HCP sample limits.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Number of sample units requested by the HCP. Measured in individual sample units (e.g., bottles, blister packs, vials).' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when the sample transaction was reconciled against inventory records. Required for PDMA sample accountability audits.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business identifier for the sample request. Externally visible tracking number used for audit trail and reconciliation. Format: SR-XXXXXXXXXX.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the sample request. Tracks progression from initial request through fulfillment and inventory reconciliation.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleValueUsd rdf:type rdf:Property ;
    rdfs:label 'Sample Value Usd' ;
    rdfs:comment 'Fair market value of the dispensed drug samples in US dollars. Required for Sunshine Act transparency reporting and financial reconciliation.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'Date and time when the HCP signed for receipt of drug samples. Captured electronically via mobile device or e-signature platform.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sunshineReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Sunshine Reportable Flag' ;
    rdfs:comment 'Indicates whether this sample transaction must be reported under the Physician Payments Sunshine Act transparency requirements.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiration Date' ;
    rdfs:comment 'The date on which the consent automatically expires and is no longer valid. Null for consents with no expiration.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Consent Granted Date' ;
    rdfs:comment 'The date on which the HCP granted consent or permission for the specified communication or engagement type. Principal business event timestamp for this record.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The method by which consent was obtained. Explicit indicates affirmative action by HCP; implicit or inferred indicates consent derived from behavior or context.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The origin or method through which the consent or restriction was captured. Identifies the system or channel that recorded the consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentText rdf:type rdf:Property ;
    rdfs:label 'Consent Text' ;
    rdfs:comment 'The full text or summary of the consent statement presented to and accepted by the HCP. Provides audit trail of what was agreed to.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent form or policy under which this consent was granted. Enables tracking of consent policy changes over time.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentWithdrawnDate rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawn Date' ;
    rdfs:comment 'The date on which the HCP withdrew or revoked their consent. Null if consent has not been withdrawn.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:digitalChannelSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Channel Sync Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record has been synchronized to digital engagement platforms. True indicates sync is complete.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dncFlag rdf:type rdf:Property ;
    rdfs:label 'Dnc Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP is on the Do Not Contact list. True indicates contact is prohibited.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailPlatformSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Email Platform Sync Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record has been synchronized to email marketing platforms for enforcement. True indicates sync is complete.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'Indicates whether the consent or restriction is currently being enforced in downstream systems. Active means the rule is enforced; override indicates temporary suspension.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentRecord rdf:type rdf:Property ;
    rdfs:label 'Is Current Record' ;
    rdfs:comment 'Boolean indicator of whether this is the current active version of the consent record. True indicates this is the latest version; false indicates historical version.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record is under legal hold and must be preserved for litigation or regulatory investigation. True indicates legal hold is active.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldReason rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Reason' ;
    rdfs:comment 'Explanation or case reference for why the legal hold was applied. Null if no legal hold is active.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noSeeFlag rdf:type rdf:Property ;
    rdfs:label 'No See Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP has requested no in-person visits from field representatives. True indicates no-see restriction is active.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP has explicitly opted in to receive communications. True indicates active opt-in consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Boolean indicator of whether the HCP has opted out of communications. True indicates active opt-out or withdrawal.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Record Effective Date' ;
    rdfs:comment 'The date from which this consent record version is effective. Supports temporal tracking and historical analysis.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordEndDate rdf:type rdf:Property ;
    rdfs:label 'Record End Date' ;
    rdfs:comment 'The date on which this consent record version ceased to be effective. Null for current active records. Supports temporal tracking and historical analysis.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionReason rdf:type rdf:Property ;
    rdfs:label 'Restriction Reason' ;
    rdfs:comment 'Free-text explanation or code describing why the restriction was applied. May reference regulatory requirement, HCP request, or internal policy.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'The type of restriction or limitation applied to HCP contact. DNC (Do Not Contact), no-see (field rep restriction), legal hold, compliance-driven restriction, or channel-specific limitation.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaCrmSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Sync Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record has been synchronized to Veeva CRM for field force enforcement. True indicates sync is complete.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaCrmSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Veeva Crm Sync Timestamp' ;
    rdfs:comment 'The date and time when this consent record was last synchronized to Veeva CRM. Null if never synchronized.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sunshineTransferId rdf:type rdf:Property ;
    rdfs:label 'Sunshine Transfer Id' ;
    rdfs:comment 'Unique identifier for the Open Payments (Sunshine Act) transfer of value record. Primary key for the sunshine_transfer data product.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmsPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Cms Publication Date' ;
    rdfs:comment 'The date on which CMS published this transfer record to the public Open Payments database. Typically June 30 for prior year data.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cmsReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Cms Reporting Status' ;
    rdfs:comment 'The current status of this transfer record in the CMS Open Payments submission lifecycle. Tracks progression from draft through final acceptance. [ENUM-REF-CANDIDATE: draft|pending_review|submitted|accepted|disputed|corrected|deleted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Cms Submission Date' ;
    rdfs:comment 'The date on which this transfer record was submitted to CMS for the Open Payments program. Used for compliance tracking and audit trails.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delayPublicationIndicator rdf:type rdf:Property ;
    rdfs:label 'Delay Publication Indicator' ;
    rdfs:comment 'Indicates whether publication of this transfer has been delayed due to ongoing research, clinical investigation, or product development activities.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formOfPayment rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment' ;
    rdfs:comment 'The form in which the transfer of value was provided: cash, in-kind items or services, stock, stock options, or other forms. [ENUM-REF-CANDIDATE: cash|in_kind|stock|stock_option|dividend|profit|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Transaction Number' ;
    rdfs:comment 'The company\'s internal transaction or payment reference number from the source financial or CRM system (e.g., SAP document number, Veeva CRM activity ID).' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:natureOfPayment rdf:type rdf:Property ;
    rdfs:label 'Nature Of Payment' ;
    rdfs:comment 'Detailed description of the context and purpose of the payment, including the specific service provided, event attended, or activity performed. Required for CMS transparency reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The monetary value of the transfer in the transaction currency. Represents the gross amount before any adjustments or taxes.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Payment Amount Usd' ;
    rdfs:comment 'The payment amount converted to US Dollars for CMS reporting purposes. Required for all Open Payments submissions regardless of original currency.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Payment Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the payment amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'The nature of the payment or transfer of value as defined by CMS Open Payments categories. Determines reporting requirements and compliance thresholds. [ENUM-REF-CANDIDATE: consulting_fee|speaker_honorarium|meal|travel|lodging|education|research_grant|charitable_contribution|royalty_license|ownership_interest|gift|entertainment|honoraria|current_or_prospective_ownership|compensation_for_services_other_than_consulting|space_rental_or_facility_fees|food_and_beverage — 17 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productIndication rdf:type rdf:Property ;
    rdfs:label 'Product Indication' ;
    rdfs:comment 'The therapeutic indication or disease state for which the associated product is marketed or being discussed in the context of this transfer.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productNdc rdf:type rdf:Property ;
    rdfs:label 'Product Ndc' ;
    rdfs:comment 'The 11-digit National Drug Code for the associated drug product in 5-4-2 or 11-digit format. Used for product identification in CMS submissions.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'The calendar year for which this transfer is being reported to CMS. Determines the applicable reporting deadline and publication cycle.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Recipient Address Line1' ;
    rdfs:comment 'The primary street address of the recipient\'s principal business location. Required for CMS Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCity rdf:type rdf:Property ;
    rdfs:label 'Recipient City' ;
    rdfs:comment 'The city of the recipient\'s principal business location. Required for CMS Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientCountry rdf:type rdf:Property ;
    rdfs:label 'Recipient Country' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code of the recipient\'s principal business location. Typically USA for domestic Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientFirstName rdf:type rdf:Property ;
    rdfs:label 'Recipient First Name' ;
    rdfs:comment 'The first name of the individual healthcare professional who received the transfer of value. Required for CMS Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientLastName rdf:type rdf:Property ;
    rdfs:label 'Recipient Last Name' ;
    rdfs:comment 'The last name of the individual healthcare professional who received the transfer of value. Required for CMS Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientNpi rdf:type rdf:Property ;
    rdfs:label 'Recipient Npi' ;
    rdfs:comment 'The 10-digit National Provider Identifier for the recipient healthcare professional or organization. Primary identifier for CMS reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPostalCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Postal Code' ;
    rdfs:comment 'The ZIP code of the recipient\'s principal business location in 5-digit or ZIP+4 format. Required for CMS Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientSpecialty rdf:type rdf:Property ;
    rdfs:label 'Recipient Specialty' ;
    rdfs:comment 'The primary medical specialty of the recipient healthcare professional (e.g., Oncology, Cardiology, Internal Medicine). Used for CMS reporting and analytics.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientState rdf:type rdf:Property ;
    rdfs:label 'Recipient State' ;
    rdfs:comment 'The two-letter US state or territory code of the recipient\'s principal business location. Required for CMS Open Payments reporting.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientStateLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Recipient State License Number' ;
    rdfs:comment 'The state medical license number of the recipient healthcare professional. Used for identity verification in Open Payments submissions.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'Classification of the payment recipient as defined by CMS: physician (MD/DO), non-physician practitioner (PA, NP, etc.), or teaching hospital.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchInformationIndicator rdf:type rdf:Property ;
    rdfs:label 'Research Information Indicator' ;
    rdfs:comment 'Indicates whether this transfer is related to research activities and may qualify for delayed publication under CMS rules.' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyPaymentRecipientIndicator rdf:type rdf:Property ;
    rdfs:label 'Third Party Payment Recipient Indicator' ;
    rdfs:comment 'Indicates whether the payment was made to a third party on behalf of the covered recipient (e.g., payment to a charity designated by the HCP).' ;
    rdfs:domain ind:SunshineTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:venueHcoMasterId rdf:type rdf:Property ;
    rdfs:label 'Venue Hco Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.hco_master. Business justification: Speaker program events are held at specific healthcare organization venues (hospitals, medical centers, conference facilities affiliated with HCOs). Linking hcp_speaker_program to the hosting HCO via ' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HcoMaster .

ind:audienceSize rdf:type rdf:Property ;
    rdfs:label 'Audience Size' ;
    rdfs:comment 'Number of healthcare professionals who attended the speaker program event. Used for reach metrics and ROI analysis.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current status of the speaker training certification. Must be certified to deliver programs and receive honoraria.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Date' ;
    rdfs:comment 'Date when the HCP completed mandatory compliance training covering anti-kickback regulations, Sunshine Act reporting, and promotional guidelines.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Status' ;
    rdfs:comment 'Current status of the HCP compliance certification. Must be current to participate in speaker programs.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the speaker bureau contract becomes effective and binding.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the speaker bureau contract expires. Requires renewal to continue the speaker relationship.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:honorariumCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Honorarium Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the honorarium payment. Supports multi-currency speaker programs.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honorariumPaidUsd rdf:type rdf:Property ;
    rdfs:label 'Honorarium Paid Usd' ;
    rdfs:comment 'Actual honorarium payment in US Dollars made to the HCP for delivering the speaker program. Component of total spend and Sunshine Act reportable value.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:honorariumRateUsd rdf:type rdf:Property ;
    rdfs:label 'Honorarium Rate Usd' ;
    rdfs:comment 'Standard honorarium payment rate in US Dollars per speaker program event. Rate varies by speaker tier and program type.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialsUsed rdf:type rdf:Property ;
    rdfs:label 'Materials Used' ;
    rdfs:comment 'List or description of promotional materials, slide decks, and educational content used during the speaker program. Must be Medical Legal Regulatory (MLR) approved.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlrApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Mlr Approval Number' ;
    rdfs:comment 'Approval reference number from Medical Legal Regulatory review for the materials used in the speaker program. Ensures promotional compliance.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEventNumber rdf:type rdf:Property ;
    rdfs:label 'Program Event Number' ;
    rdfs:comment 'Business identifier for the individual speaker program event. Externally visible unique code used for tracking and compliance reporting.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programsDeliveredCount rdf:type rdf:Property ;
    rdfs:label 'Programs Delivered Count' ;
    rdfs:comment 'Cumulative count of speaker programs delivered by this HCP to date. Used for speaker performance tracking and tier progression.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speakerPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Speaker Performance Rating' ;
    rdfs:comment 'Quantitative performance rating for the speaker program event on a scale of 0.00 to 5.00. Based on audience feedback, content delivery, and engagement metrics.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speakerTier rdf:type rdf:Property ;
    rdfs:label 'Speaker Tier' ;
    rdfs:comment 'Classification of the speaker based on expertise, reach, and engagement level. Determines honorarium rates and program eligibility.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunshineActReportedDate rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Reported Date' ;
    rdfs:comment 'Date when the transfer of value for this speaker program was submitted to the CMS Open Payments database for Sunshine Act compliance.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Total Spend Usd' ;
    rdfs:comment 'Total expenditure in US Dollars for the speaker program event including honorarium, venue costs, meals, and materials. Reportable transfer of value under Sunshine Act.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when the HCP completed mandatory speaker training for the therapeutic area and approved products. Required before delivering programs.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Training Expiration Date' ;
    rdfs:comment 'Date when the speaker training certification expires. Requires recertification to continue delivering programs.' ;
    rdfs:domain ind:SpeakerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualCapAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Cap Amount' ;
    rdfs:comment 'Maximum total compensation in USD that can be paid to the HCP under this contract in a calendar year. Enforces anti-kickback compliance and prevents excessive payments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Screening Date' ;
    rdfs:comment 'Date when the most recent exclusion screening was performed. Must be refreshed monthly per OIG guidance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusionScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Exclusion Screening Status' ;
    rdfs:comment 'Result of screening the HCP against government exclusion lists (OIG, GSA SAM, FDA Debarment). Must be cleared before contract execution and payment.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaDebarmentScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Fda Debarment Screening Result' ;
    rdfs:comment 'Result of screening against the FDA Debarment List. Debarred individuals cannot participate in drug development or approval processes.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmvMethodology rdf:type rdf:Property ;
    rdfs:label 'Fmv Methodology' ;
    rdfs:comment 'Methodology used to determine the FMV rate for this contract. Documents compliance with anti-kickback regulations and ensures defensible compensation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmvRateType rdf:type rdf:Property ;
    rdfs:label 'Fmv Rate Type' ;
    rdfs:comment 'Unit basis for the FMV compensation rate. Determines how payments are calculated and validated against caps.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honorariumRate rdf:type rdf:Property ;
    rdfs:label 'Honorarium Rate' ;
    rdfs:comment 'Fixed honorarium amount in USD for per-engagement or per-deliverable contracts. Used for speaker programs and advisory board participation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hourlyRateMax rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate Max' ;
    rdfs:comment 'Maximum hourly compensation rate in USD for services rendered under this contract. Part of the FMV range used for compliance validation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hourlyRateMin rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate Min' ;
    rdfs:comment 'Minimum hourly compensation rate in USD for services rendered under this contract. Part of the FMV range used for compliance validation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oigScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Oig Screening Result' ;
    rdfs:comment 'Result of screening against the OIG List of Excluded Individuals and Entities. HCPs on the exclusion list cannot receive federal healthcare program payments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Sam Screening Result' ;
    rdfs:comment 'Result of screening against the GSA System for Award Management exclusion list. Ensures HCP is not debarred from federal contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Detailed description of the services the HCP will provide under this contract. Defines deliverables, expectations, and compliance boundaries.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeTrialsCount rdf:type rdf:Property ;
    rdfs:label 'Active Trials Count' ;
    rdfs:comment 'Number of clinical trials currently active for this investigator. Used to assess investigator capacity and workload.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageEnrollmentRate rdf:type rdf:Property ;
    rdfs:label 'Average Enrollment Rate' ;
    rdfs:comment 'Average number of subjects enrolled per month by this investigator. Calculated metric used for trial planning and site selection.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conflictOfInterestDeclared rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Declared' ;
    rdfs:comment 'Indicates whether the investigator has declared any financial or other conflicts of interest that could affect trial conduct or data integrity.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Cv Last Updated Date' ;
    rdfs:comment 'Date when the investigator\'s curriculum vitae was last updated in the system.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cvOnFile rdf:type rdf:Property ;
    rdfs:label 'Cv On File' ;
    rdfs:comment 'Indicates whether a current curriculum vitae is on file for the investigator. CV is required for regulatory submissions and site qualification.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disqualificationDate rdf:type rdf:Property ;
    rdfs:label 'Disqualification Date' ;
    rdfs:comment 'Date when the investigator was disqualified from conducting clinical trials, either by regulatory authority or company decision.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason for investigator disqualification. May include regulatory violations, data integrity issues, or non-compliance with GCP.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fda1572OnFile rdf:type rdf:Property ;
    rdfs:label 'Fda 1572 On File' ;
    rdfs:comment 'Indicates whether a signed FDA Form 1572 (Statement of Investigator) is on file. Required for all US-based clinical trials.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fda1572SignatureDate rdf:type rdf:Property ;
    rdfs:label 'Fda 1572 Signature Date' ;
    rdfs:comment 'Date when the investigator signed the FDA Form 1572 for the current protocol assignment.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Completion Date' ;
    rdfs:comment 'Date when the investigator completed their most recent GCP training certification.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Expiration Date' ;
    rdfs:comment 'Date when the investigator\'s current GCP training certification expires. Investigators must renew training to remain qualified.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingStatus rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Status' ;
    rdfs:comment 'Status of the investigator\'s GCP training certification. GCP training is mandatory for all clinical trial investigators per ICH guidelines.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedTrialFlag rdf:type rdf:Property ;
    rdfs:label 'Initiated Trial Flag' ;
    rdfs:comment 'Indicates whether the investigator has conducted or is conducting investigator-initiated trials (IIT) with company products. IITs are investigator-led studies.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorNumber rdf:type rdf:Property ;
    rdfs:label 'Investigator Number' ;
    rdfs:comment 'Business identifier assigned to the investigator for tracking across clinical trials. May be company-specific or protocol-specific.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Expiration Date' ;
    rdfs:comment 'Date when the current IRB approval expires. Investigators must obtain renewal to continue trial activities.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kolInvestigatorFlag rdf:type rdf:Property ;
    rdfs:label 'Kol Investigator Flag' ;
    rdfs:comment 'Indicates whether the investigator is also classified as a Key Opinion Leader (KOL) in their therapeutic area. KOL investigators have additional engagement opportunities.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date when the investigator\'s performance was last formally reviewed by clinical operations or medical affairs.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Overall performance rating assigned to the investigator based on enrollment, data quality, compliance, and site management. Used for future site selection decisions.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Count' ;
    rdfs:comment 'Total number of protocol deviations reported for this investigator across all trials. Quality metric for investigator performance assessment.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the investigator was formally qualified to conduct clinical trials for the company. Represents completion of all qualification requirements.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seriousProtocolDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Serious Protocol Deviation Count' ;
    rdfs:comment 'Number of serious protocol deviations reported for this investigator. Serious deviations may impact subject safety or data integrity.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSubjectsEnrolled rdf:type rdf:Property ;
    rdfs:label 'Total Subjects Enrolled' ;
    rdfs:comment 'Cumulative number of subjects enrolled by this investigator across all trials. Key performance indicator for investigator productivity.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTrialsConducted rdf:type rdf:Property ;
    rdfs:label 'Total Trials Conducted' ;
    rdfs:comment 'Total number of clinical trials the investigator has conducted as PI or sub-investigator. Performance metric for investigator selection.' ;
    rdfs:domain ind:Investigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmoCdmoBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Cmo Cdmo Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: Production orders executed at CMOs/CDMOs must reference the qualified business partner for contract manufacturing oversight, GMP audit tracking, and regulatory agency notifications. cmo_cdmo_code is a' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when all production operations were completed and order was confirmed. Captured from Manufacturing Execution System (MES) at final operation completion.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual quantity produced and confirmed at order completion. May differ from planned quantity due to yield loss, in-process rejections, or overproduction within acceptable limits.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when production order execution commenced. Captured from Manufacturing Execution System (MES) at first operation start. Critical for cycle time analysis and Current Good Manufacturing Practice (cGMP) batch record documentation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID of the person who created the production order record. Required for audit trail and accountability per 21 CFR Part 11 electronic records requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID of the person who last modified the production order record. Required for audit trail and accountability per 21 CFR Part 11 electronic records requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Pat Enabled Flag' ;
    rdfs:comment 'Indicates whether Process Analytical Technology (PAT) tools are used for real-time monitoring and control of Critical Process Parameters (CPP) and Critical Quality Attributes (CQA) during manufacturing. True for processes with inline/online/at-line analytical instrumentation per FDA PAT Guidance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Target quantity to be produced as specified in the production order. Represents the batch size defined in the master batch record or Bill of Materials (BOM).' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Scheduling priority for the production order. Urgent for critical supply shortages or regulatory commitments; high for commercial launch or clinical trial material; normal for routine replenishment; low for strategic inventory build.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether the production order involves rework or reprocessing of previously manufactured material that did not meet specifications. Rework must be performed according to approved procedures and documented per 21 CFR Part 211.115.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date for production order completion including all manufacturing operations and in-process quality checks.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date for production order execution to begin. Used for capacity planning and material staging.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of material scrapped or rejected during production due to Out of Specification (OOS) results, equipment failures, or process deviations. Scrap must be documented and investigated per Current Good Manufacturing Practice (cGMP) requirements.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationBatchFlag rdf:type rdf:Property ;
    rdfs:label 'Validation Batch Flag' ;
    rdfs:comment 'Indicates whether the production order is a validation batch used for process qualification, process performance qualification (PPQ), or continued process verification. Validation batches require enhanced documentation and are used to demonstrate process capability and reproducibility.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Calculated yield percentage representing actual quantity produced divided by planned quantity, expressed as a percentage. Used for process performance monitoring and variance analysis. Deviations outside acceptable yield ranges may trigger investigation per Current Good Manufacturing Practice (cGMP).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUnitOfMeasureId rdf:type rdf:Property ;
    rdfs:label 'Batch Size Unit Of Measure Id' ;
    rdfs:comment 'Foreign key linking to masterdata.unit_of_measure. Business justification: Batch size UoM in GMP batch records must be standardized for yield calculations, regulatory submissions, and cross-site comparisons. batch_size_uom is a plain string; normalizing to masterdata.unit_of' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitOfMeasure .

ind:supplyInventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Supply Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: Manufacturing batch records must link to supply inventory lots to enable end-to-end traceability from production to distribution. This is critical for product recalls, quality investigations, and supp' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:actualYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Quantity' ;
    rdfs:comment 'The actual quantity of product produced at the end of the manufacturing process. Compared against theoretical yield to calculate yield percentage and identify process inefficiencies or material losses.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Size Quantity' ;
    rdfs:comment 'The planned or target quantity of product to be manufactured in this batch. Expressed in the unit of measure specified in batch_size_uom. Used for yield calculations and material planning.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch. In-process indicates active manufacturing; Released indicates QA approval for distribution; Rejected indicates failed quality specifications; Quarantine indicates pending investigation or testing; On-hold indicates temporary suspension; Expired indicates past shelf life.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the batch by manufacturing stage. Drug Substance (DS) refers to API production; Drug Product (DP) refers to formulated finished dosage form (FDF). Intermediate refers to in-process materials.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRequired rdf:type rdf:Property ;
    rdfs:label 'Capa Required' ;
    rdfs:comment 'Indicates whether a formal CAPA investigation was required for this batch due to deviations, out-of-specification (OOS) results, or quality issues. True indicates CAPA was initiated; False indicates no CAPA required.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'The number of manufacturing deviations or non-conformances documented during the production of this batch. Deviations require investigation and impact assessment per cGMP. Zero indicates no deviations occurred.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionApproverName rdf:type rdf:Property ;
    rdfs:label 'Disposition Approver Name' ;
    rdfs:comment 'The name of the qualified quality unit personnel who approved the final disposition decision. Must be an authorized individual per the quality management system (QMS).' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'The date on which the final disposition decision was made by the quality unit. Marks the completion of batch review and approval process.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'The final quality decision on the batch. Release indicates approval for distribution; Reject indicates failure to meet specifications; Rework indicates batch will be reprocessed; Destroy indicates batch will be disposed of. This is the authoritative disposition outcome.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionRationale rdf:type rdf:Property ;
    rdfs:label 'Disposition Rationale' ;
    rdfs:comment 'The documented justification for the disposition decision. For rejections, includes the specific quality failures or deviations. For releases, confirms all specifications and cGMP requirements were met. Required for regulatory compliance and audit trail.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringCompliant rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Compliant' ;
    rdfs:comment 'Indicates whether environmental monitoring results (viable and non-viable particulates, temperature, humidity) were within acceptable limits throughout the manufacturing process. Critical for sterile and aseptic manufacturing per cGMP.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formulationVersion rdf:type rdf:Property ;
    rdfs:label 'Formulation Version' ;
    rdfs:comment 'The version number of the product formulation used for this batch. Tracks changes to the formula, process parameters, or specifications. Critical for change control and regulatory submissions (CMC section).' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Classification' ;
    rdfs:comment 'The GMP classification under which this batch was manufactured. cGMP (current Good Manufacturing Practice) is required for commercial and late-stage clinical batches. GMP applies to earlier development batches. Non-GMP may apply to research-only materials.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'The date and time when manufacturing operations for this batch were completed. Marks the end of the production cycle before quality testing and release. Used to calculate cycle time and production efficiency.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'The date and time when manufacturing operations for this batch commenced. Marks the beginning of the batch production cycle. Critical for batch genealogy and process timeline documentation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:patMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Pat Monitoring Enabled' ;
    rdfs:comment 'Indicates whether Process Analytical Technology (PAT) tools were used for real-time monitoring and control of critical quality attributes (CQA) during this batch. PAT enables continuous quality verification per FDA PAT guidance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qbdDesignSpaceCompliance rdf:type rdf:Property ;
    rdfs:label 'Qbd Design Space Compliance' ;
    rdfs:comment 'Indicates whether all critical process parameters (CPP) remained within the approved QbD design space during manufacturing. True indicates full compliance; False indicates deviation requiring investigation. Applicable for products developed under QbD principles per ICH Q8.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sterilityAssuranceLevel rdf:type rdf:Property ;
    rdfs:label 'Sterility Assurance Level' ;
    rdfs:comment 'The probability of a single viable microorganism being present on a product unit after sterilization. Expressed as SAL-10^-N (e.g., SAL-10^-6 means one in a million probability). Required for sterile products. Not applicable for non-sterile products.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sterilizationMethod rdf:type rdf:Property ;
    rdfs:label 'Sterilization Method' ;
    rdfs:comment 'The sterilization method applied to this batch, if applicable. Required for sterile drug products and certain medical devices. Not applicable for non-sterile products. Method must be validated per regulatory requirements.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoreticalYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Theoretical Yield Quantity' ;
    rdfs:comment 'The expected quantity of product that should be produced based on the master batch record formula and input materials, assuming 100% efficiency with no losses. Used as the baseline for yield percentage calculation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByMbrMasterBatchRecordId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Mbr Master Batch Record Id' ;
    rdfs:comment 'Reference to the newer master batch record that supersedes this version, enabling version lineage tracking.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterBatchRecord .

ind:batchSizeMaximum rdf:type rdf:Property ;
    rdfs:label 'Batch Size Maximum' ;
    rdfs:comment 'The maximum allowable batch size that can be manufactured using this master batch record, supporting scale flexibility.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeMinimum rdf:type rdf:Property ;
    rdfs:label 'Batch Size Minimum' ;
    rdfs:comment 'The minimum allowable batch size that can be manufactured using this master batch record, supporting scale flexibility.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeStandard rdf:type rdf:Property ;
    rdfs:label 'Batch Size Standard' ;
    rdfs:comment 'The standard or nominal batch size for which this master batch record is designed, expressed in the unit of measure defined in batch_size_uom.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cgmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cgmp Compliance Flag' ;
    rdfs:comment 'Indicates whether this master batch record is compliant with current Good Manufacturing Practice (cGMP) regulations per 21 CFR Parts 210 and 211.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'The storage location or URI of the full master batch record document in the document management system (Veeva Vault QualityDocs or MasterControl).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Equipment Requirements' ;
    rdfs:comment 'Description of the equipment required for executing this master batch record, including specific equipment types, models, or identifiers.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percentage' ;
    rdfs:comment 'The expected theoretical yield for this batch as a percentage, used to calculate acceptable yield ranges and detect deviations.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulationDetails rdf:type rdf:Property ;
    rdfs:label 'Formulation Details' ;
    rdfs:comment 'Detailed formulation information including active pharmaceutical ingredient (API) and excipient quantities, ratios, and specifications. Business-confidential intellectual property.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inProcessControlSpecifications rdf:type rdf:Property ;
    rdfs:label 'In Process Control Specifications' ;
    rdfs:comment 'Summary of in-process control specifications and acceptance criteria that must be met during batch execution, including critical quality attributes (CQAs).' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mbrNumber rdf:type rdf:Property ;
    rdfs:label 'Mbr Number' ;
    rdfs:comment 'The externally-known unique business identifier for this master batch record, used across manufacturing, quality, and regulatory systems.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mbrTitle rdf:type rdf:Property ;
    rdfs:label 'Mbr Title' ;
    rdfs:comment 'Human-readable title or name of the master batch record, typically including product name and dosage form.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Yield Percentage' ;
    rdfs:comment 'The minimum acceptable yield percentage below which a batch is considered out of specification (OOS) and requires investigation.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processDescription rdf:type rdf:Property ;
    rdfs:label 'Process Description' ;
    rdfs:comment 'High-level description of the manufacturing process steps covered by this master batch record, including key operations and sequence.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Reference to the regulatory approval document (NDA, BLA, MAA, or ANDA number) under which this master batch record is authorized for commercial manufacturing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'The periodic review cycle in months for this master batch record, ensuring ongoing compliance and relevance per quality management system (QMS) requirements.' ;
    rdfs:domain ind:MasterBatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUnitOfMeasureId rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure Id' ;
    rdfs:comment 'Foreign key linking to masterdata.unit_of_measure. Business justification: Site capacity planning and OEE reporting require standardized UoM from the MDM master. capacity_unit_of_measure is a plain string on site; normalizing to masterdata.unit_of_measure ensures cross-site ' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitOfMeasure .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the manufacturing site became operational and began commercial production. Used for calculating site age, depreciation schedules, and historical performance analysis.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityUnitsPerYear rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Year' ;
    rdfs:comment 'Annual production capacity of the site measured in units appropriate to the site type (e.g., kilograms of API, millions of tablets, thousands of vials). Used for capacity planning, supply chain optimization, and network strategy.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emaAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Ema Authorization Number' ;
    rdfs:comment 'EMA manufacturing authorization number or EudraGMP identifier for sites manufacturing medicinal products for the European market. Required for GMP compliance verification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Ema Authorization Status' ;
    rdfs:comment 'Current status of the EMA manufacturing authorization indicating whether the site is actively authorized to manufacture for EU markets, authorization has expired, application is pending, authorization is not required, or has been suspended.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringProgram rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Program' ;
    rdfs:comment 'Indicates whether the site has an active environmental monitoring program for tracking viable and non-viable particulates, temperature, humidity, and other environmental conditions in classified manufacturing areas. Required for sterile and aseptic manufacturing operations.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdaRegistrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Expiry Date' ;
    rdfs:comment 'Date when the current FDA establishment registration expires. FDA registrations must be renewed annually between October 1 and December 31.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Number' ;
    rdfs:comment 'FDA establishment registration number assigned to the site. Required for all facilities manufacturing drugs for the US market per 21 CFR Part 207. Must be renewed annually.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Status' ;
    rdfs:comment 'Current status of the FDA establishment registration indicating whether the site is actively registered, registration has expired, renewal is pending, registration is not required, or registration has been suspended.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Status' ;
    rdfs:comment 'Overall current Good Manufacturing Practice (cGMP) certification status of the site indicating compliance with pharmaceutical quality standards. Certified means site has passed recent GMP inspection, expired means certification has lapsed, pending means inspection scheduled, not certified means site has not been inspected or failed inspection, conditional means certification granted with specific conditions or CAPA requirements.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001CertificationDate rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certification Date' ;
    rdfs:comment 'Date when the site received ISO 9001 certification. ISO 9001 certificates are typically valid for three years with annual surveillance audits.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the site holds ISO 9001 Quality Management System certification. While not required for pharmaceutical manufacturing, ISO 9001 certification demonstrates commitment to quality management best practices.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastGmpInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Gmp Inspection Date' ;
    rdfs:comment 'Date of the most recent GMP inspection conducted by any regulatory authority (FDA, EMA, PMDA, MHRA, etc.). Used to track inspection frequency and predict next inspection window.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mesSiteIdentifier rdf:type rdf:Property ;
    rdfs:label 'Mes Site Identifier' ;
    rdfs:comment 'Unique identifier for the site in the Manufacturing Execution System (MES). Used to link batch records, equipment data, and process parameters to the physical manufacturing location.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextGmpInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Gmp Inspection Due Date' ;
    rdfs:comment 'Expected or scheduled date for the next GMP inspection. Typically inspections occur every 2-3 years for routine surveillance or more frequently for sites with compliance issues or new product approvals.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the manufacturing site indicating whether the facility is actively producing, temporarily offline, permanently closed, being built, in validation phase, or suspended due to regulatory or quality issues.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patCapability rdf:type rdf:Property ;
    rdfs:label 'Pat Capability' ;
    rdfs:comment 'Indicates whether the site has Process Analytical Technology (PAT) capabilities for real-time monitoring and control of critical process parameters (CPP) and critical quality attributes (CQA) during manufacturing. PAT enables continuous process verification and improved process understanding.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:picsMembershipStatus rdf:type rdf:Property ;
    rdfs:label 'Pics Membership Status' ;
    rdfs:comment 'Indicates whether the site is located in a PIC/S member country, enabling mutual recognition of GMP inspections across participating regulatory authorities. Member status facilitates international regulatory acceptance.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbdImplementationStatus rdf:type rdf:Property ;
    rdfs:label 'Qbd Implementation Status' ;
    rdfs:comment 'Indicates the level of Quality by Design (QbD) principles implementation at the site. QbD is a systematic approach to pharmaceutical development that begins with predefined objectives and emphasizes product and process understanding based on sound science and quality risk management.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Quality Management System' ;
    rdfs:comment 'Primary Quality Management System platform deployed at the site for managing deviations, CAPA (Corrective and Preventive Action), change control, and document management. Critical for compliance and audit readiness.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Official legal or business name of the manufacturing facility as registered with regulatory authorities and used in regulatory submissions.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation for the manufacturing line. Continuous manufacturing represents advanced Process Analytical Technology (PAT) and Quality by Design (QbD) implementations.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityKgPerBatch rdf:type rdf:Property ;
    rdfs:label 'Capacity Kg Per Batch' ;
    rdfs:comment 'Maximum batch size capacity in kilograms for bulk processing lines such as granulation, blending, or Active Pharmaceutical Ingredient (API) synthesis. Null for unit-based lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Hour' ;
    rdfs:comment 'Rated production capacity of the line expressed as units per hour. For solid dosage forms, this represents tablets or capsules per hour; for liquids, vials or bottles per hour.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverTimeHours rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Hours' ;
    rdfs:comment 'Average time in hours required to perform a product changeover on this manufacturing line, including cleaning, setup, and line clearance activities per Good Manufacturing Practice (GMP) requirements.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Cleaning Validation Status' ;
    rdfs:comment 'Current status of cleaning validation for the manufacturing line. Critical for preventing cross-contamination and ensuring compliance with Current Good Manufacturing Practice (cGMP) per 21 CFR Part 211.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanroomClassification rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Classification' ;
    rdfs:comment 'ISO 14644 or European Union (EU) Good Manufacturing Practice (GMP) Annex 1 cleanroom classification for the manufacturing line environment. Critical for sterile and aseptic manufacturing operations. [ENUM-REF-CANDIDATE: ISO-5|ISO-6|ISO-7|ISO-8|Grade-A|Grade-B|Grade-C|Grade-D|non-classified — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmoCdmoOperated rdf:type rdf:Property ;
    rdfs:label 'Cmo Cdmo Operated' ;
    rdfs:comment 'Indicates whether this manufacturing line is operated by a Contract Manufacturing Organization (CMO) or Contract Development and Manufacturing Organization (CDMO) rather than owned and operated internally.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the manufacturing line was commissioned and became operational. Used for asset lifecycle management and depreciation tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the manufacturing line was decommissioned and taken out of service. Null for active lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dosageFormType rdf:type rdf:Property ;
    rdfs:label 'Dosage Form Type' ;
    rdfs:comment 'Type of Finished Dosage Form (FDF) produced on this manufacturing line. Aligns with regulatory submissions and product master data. [ENUM-REF-CANDIDATE: tablet|capsule|injectable|lyophilized-vial|suspension|solution|cream|ointment|patch|inhaler — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Required' ;
    rdfs:comment 'Indicates whether the manufacturing line requires environmental monitoring for viable and non-viable particulates per Good Manufacturing Practice (GMP) Annex 1 for sterile manufacturing.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentTrainComposition rdf:type rdf:Property ;
    rdfs:label 'Equipment Train Composition' ;
    rdfs:comment 'Comma-separated list or description of major equipment units that comprise the manufacturing line, such as \'Mixer-Granulator-Dryer-Mill\' or \'Filling Machine-Capper-Labeler\'. Supports equipment traceability and maintenance planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Outcome classification from the most recent regulatory inspection. Food and Drug Administration (FDA) uses classifications such as No Action Indicated (NAI), Voluntary Action Indicated (VAI), and Official Action Indicated (OAI).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent preventive or corrective maintenance activity performed on the manufacturing line. Supports equipment reliability and Overall Equipment Effectiveness (OEE) tracking.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Business identifier code for the manufacturing line, used in production scheduling, batch records, and Manufacturing Execution System (MES). Typically alphanumeric and unique within a site.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable name or designation of the manufacturing line, such as \'Tablet Compression Line 3\' or \'Sterile Fill-Finish Suite A\'.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the manufacturing line by its primary production function. Defines the type of manufacturing operation performed on this line. [ENUM-REF-CANDIDATE: granulation|blending|compression|coating|filling|lyophilization|packaging|inspection|labeling|serialization — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Mes Integration Status' ;
    rdfs:comment 'Indicates whether the manufacturing line is integrated with the Manufacturing Execution System (MES) for real-time batch tracking, Critical Process Parameter (CPP) monitoring, and electronic batch record generation.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance activity. Used for production scheduling and capacity planning to avoid conflicts with manufacturing campaigns.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percent' ;
    rdfs:comment 'Target Overall Equipment Effectiveness (OEE) percentage for this manufacturing line. OEE is a key performance indicator combining availability, performance, and quality metrics.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patEnabled rdf:type rdf:Property ;
    rdfs:label 'Pat Enabled' ;
    rdfs:comment 'Indicates whether the line is equipped with Process Analytical Technology (PAT) tools for real-time monitoring and control of Critical Quality Attributes (CQA) and Critical Process Parameters (CPP).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date when the current qualification or validation of the manufacturing line expires and requalification is required. Critical for compliance with Current Good Manufacturing Practice (cGMP) and Quality by Design (QbD) principles.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection by Food and Drug Administration (FDA), European Medicines Agency (EMA), or other regulatory authority. Critical for Pre-Approval Inspection (PAI) and ongoing compliance tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Operating shift pattern for the manufacturing line. Determines production capacity and labor planning requirements.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedStatus rdf:type rdf:Property ;
    rdfs:label 'Validated Status' ;
    rdfs:comment 'Current validation state of the manufacturing line under Computer System Validation (CSV) and process validation requirements per 21 CFR Part 11 and Good Manufacturing Practice (GMP) guidelines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Unique identifier for the manufacturing equipment asset. Primary key.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:acquisitionCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCriticality rdf:type rdf:Property ;
    rdfs:label 'Asset Criticality' ;
    rdfs:comment 'Business criticality classification of the equipment based on impact to production, product quality, and regulatory compliance. Critical assets require highest priority for maintenance and spare parts availability.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Number of days between required calibrations for this equipment, as defined in the calibration program.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current calibration status of the equipment. Indicates whether the equipment\'s measurement and control systems are within acceptable tolerances.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Nominal production capacity or throughput of the equipment. The unit of measure is specified in capacity_unit_of_measure.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleanRoomClassification rdf:type rdf:Property ;
    rdfs:label 'Clean Room Classification' ;
    rdfs:comment 'ISO 14644-1 clean room classification of the area where the equipment is installed. Applicable for equipment in controlled environments for sterile or aseptic manufacturing. [ENUM-REF-CANDIDATE: iso_3|iso_4|iso_5|iso_6|iso_7|iso_8|non_classified — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csvStatus rdf:type rdf:Property ;
    rdfs:label 'Csv Status' ;
    rdfs:comment 'Validation status for computerized equipment systems per 21 CFR Part 11 requirements. Applicable to equipment with electronic controls, data acquisition, or automated processes.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'High-level categorization of equipment by operational function: production (API/DP manufacturing), packaging (primary/secondary), quality control (testing/inspection), utilities (water/HVAC/compressed air), or support (material handling/storage).' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDescription rdf:type rdf:Property ;
    rdfs:label 'Equipment Description' ;
    rdfs:comment 'Detailed description of the equipment including its purpose, key features, and operational characteristics.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Descriptive name of the equipment asset (e.g., Reactor-101, Tablet Press Line 3, Lyophilizer A).' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Classification of the equipment based on its function in the manufacturing process. Includes primary manufacturing equipment, utilities, and support systems. [ENUM-REF-CANDIDATE: reactor|blender|granulator|tablet_press|capsule_filler|coating_machine|lyophilizer|autoclave|filling_machine|packaging_line|labeling_machine|inspection_system|fermentor|centrifuge|dryer|mill|sifter|homogenizer|mixer|sterilizer|isolator|laminar_flow_hood|clean_room_hvac|water_system|compressed_air_system|nitrogen_generator|other — 27 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Critical Flag' ;
    rdfs:comment 'Indicates whether this equipment is classified as GMP-critical, meaning it directly impacts product quality, safety, or efficacy and requires enhanced qualification, calibration, and change control.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the equipment was physically installed at the manufacturing site.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iqCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Iq Completion Date' ;
    rdfs:comment 'Date when Installation Qualification was successfully completed and approved.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date when the equipment was last calibrated.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPmDate rdf:type rdf:Property ;
    rdfs:label 'Last Pm Date' ;
    rdfs:comment 'Date when the last scheduled preventive maintenance was completed on this equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next calibration of the equipment to maintain measurement accuracy and GMP compliance.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPmDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Pm Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance activity on this equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextQualificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Qualification Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic requalification of the equipment to maintain GMP compliance.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oqCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Oq Completion Date' ;
    rdfs:comment 'Date when Operational Qualification was successfully completed and approved.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pqCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pq Completion Date' ;
    rdfs:comment 'Date when Performance Qualification was successfully completed and approved, confirming the equipment consistently performs as intended in the production environment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current qualification status of the equipment per Good Manufacturing Practice (GMP) requirements. Tracks progression through Installation Qualification (IQ), Operational Qualification (OQ), and Performance Qualification (PQ). [ENUM-REF-CANDIDATE: not_qualified|iq_in_progress|iq_complete|oq_in_progress|oq_complete|pq_in_progress|pq_complete|qualified|requalification_required — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapEquipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Equipment Number' ;
    rdfs:comment 'Equipment master record number in SAP PM module used for maintenance planning, work orders, and asset tracking.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagNumber rdf:type rdf:Property ;
    rdfs:label 'Tag Number' ;
    rdfs:comment 'Unique alphanumeric tag number assigned to the equipment for identification and tracking purposes in the manufacturing facility. This is the business identifier used in operations and maintenance.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer\'s warranty coverage for this equipment expires.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentQualificationId rdf:type rdf:Property ;
    rdfs:label 'Equipment Qualification Id' ;
    rdfs:comment 'Unique identifier for the equipment qualification record. Primary key for this entity.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Reference to the specific production line where the equipment operates. Provides manufacturing context for the qualification.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:acceptanceCriteriaSummary rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Summary' ;
    rdfs:comment 'Summary of the key acceptance criteria defined in the qualification protocol. Defines the pass/fail thresholds for qualification tests.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Indicates whether Corrective and Preventive Action (CAPA) is required based on qualification results. True if failures or significant deviations necessitate formal corrective action.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:csvCategory rdf:type rdf:Property ;
    rdfs:label 'Csv Category' ;
    rdfs:comment 'Computer System Validation (CSV) category per Good Automated Manufacturing Practice (GAMP) 5 guidelines. Category 3 (non-configured products), Category 4 (configured products), and Category 5 (custom applications) require different validation approaches.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Engineering Approval Date' ;
    rdfs:comment 'Date when the Engineering department formally approved the qualification from a technical perspective.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringApproverName rdf:type rdf:Property ;
    rdfs:label 'Engineering Approver Name' ;
    rdfs:comment 'Full name of the Engineering representative who reviewed and approved the technical aspects of the qualification.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionEndDate rdf:type rdf:Property ;
    rdfs:label 'Execution End Date' ;
    rdfs:comment 'Date when qualification testing activities were completed. Marks the conclusion of all qualification tests defined in the protocol.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executionStartDate rdf:type rdf:Property ;
    rdfs:label 'Execution Start Date' ;
    rdfs:comment 'Date when qualification testing activities commenced. Marks the beginning of the qualification execution phase.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpImpactClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Impact Classification' ;
    rdfs:comment 'Classification of the equipment based on its impact on product quality and Good Manufacturing Practice (GMP) compliance. GMP Critical equipment directly impacts product quality and requires full qualification.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Requalification Date' ;
    rdfs:comment 'Scheduled date for the next periodic requalification of the equipment. Ensures ongoing compliance with Current Good Manufacturing Practice (cGMP) requirements.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationLeadEmail rdf:type rdf:Property ;
    rdfs:label 'Qualification Lead Email' ;
    rdfs:comment 'Email address of the qualification lead for communication and coordination purposes.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationLeadName rdf:type rdf:Property ;
    rdfs:label 'Qualification Lead Name' ;
    rdfs:comment 'Full name of the individual responsible for leading and coordinating the qualification activities. Primary point of contact for the qualification project.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Qualification Outcome' ;
    rdfs:comment 'Final result of the qualification activity indicating whether the equipment met all acceptance criteria defined in the qualification protocol.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Protocol Number' ;
    rdfs:comment 'Unique protocol document number that defines the qualification test plan and acceptance criteria. Externally-known business identifier for this qualification activity.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Qualification Scope Description' ;
    rdfs:comment 'Detailed description of the qualification scope including systems, subsystems, and Critical Process Parameters (CPP) or Critical Quality Attributes (CQA) being validated.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification activity performed. IQ (Installation Qualification) verifies equipment is installed correctly; OQ (Operational Qualification) verifies equipment operates within specified parameters; PQ (Performance Qualification) verifies equipment consistently produces quality product under normal operating conditions.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Quality Approval Date' ;
    rdfs:comment 'Date when the Quality Assurance unit formally approved the qualification results and released the equipment for production use.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityApproverName rdf:type rdf:Property ;
    rdfs:label 'Quality Approver Name' ;
    rdfs:comment 'Full name of the Quality Assurance (QA) representative who reviewed and approved the qualification results. Required for Good Manufacturing Practice (GMP) compliance.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Reference' ;
    rdfs:comment 'Reference number of the risk assessment document that informed the qualification strategy. Aligns with Quality by Design (QbD) principles.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCasesExecutedCount rdf:type rdf:Property ;
    rdfs:label 'Test Cases Executed Count' ;
    rdfs:comment 'Total number of test cases executed during the qualification activity. Provides a measure of qualification scope and thoroughness.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCasesFailedCount rdf:type rdf:Property ;
    rdfs:label 'Test Cases Failed Count' ;
    rdfs:comment 'Number of test cases that did not meet acceptance criteria during qualification execution. Triggers investigation and Corrective and Preventive Action (CAPA) if applicable.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCasesPassedCount rdf:type rdf:Property ;
    rdfs:label 'Test Cases Passed Count' ;
    rdfs:comment 'Number of test cases that met acceptance criteria during qualification execution. Used to calculate pass rate.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationReportNumber rdf:type rdf:Property ;
    rdfs:label 'Validation Report Number' ;
    rdfs:comment 'Document number of the validation report that summarizes qualification results, deviations, and conclusions. Links to the formal documentation package.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Qualification Status' ;
    rdfs:comment 'Current qualification status of the equipment vendor. Vendors must be qualified before their equipment can be used in Good Manufacturing Practice (GMP) production.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Id' ;
    rdfs:comment 'Unique identifier for the production schedule record. Primary key.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProductionCampaignPlanId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Campaign Plan Id' ;
    rdfs:comment 'Identifier of the production campaign plan to which this schedule belongs, enabling grouping of related production runs.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:batchQuantityPlanned rdf:type rdf:Property ;
    rdfs:label 'Batch Quantity Planned' ;
    rdfs:comment 'Number of batches planned for production during the scheduled period.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchSizePlanned rdf:type rdf:Property ;
    rdfs:label 'Batch Size Planned' ;
    rdfs:comment 'Planned quantity or batch size for the scheduled production run, expressed in the product\'s unit of measure.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Type of production campaign (e.g., single-product campaign, multi-product campaign, validation campaign).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Planned capacity utilization percentage for the manufacturing line during the scheduled period.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmoCdmoFlag rdf:type rdf:Property ;
    rdfs:label 'Cmo Cdmo Flag' ;
    rdfs:comment 'Indicates whether this production schedule involves a CMO or CDMO partner rather than internal manufacturing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeReason rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason' ;
    rdfs:comment 'Reason for the scheduled downtime window (e.g., preventive maintenance, line cleaning, product changeover). [ENUM-REF-CANDIDATE: maintenance|cleaning|changeover|validation|calibration|inspection|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeWindowEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Window End Timestamp' ;
    rdfs:comment 'End timestamp of any scheduled downtime window for maintenance, cleaning, or changeover activities.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeWindowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Window Start Timestamp' ;
    rdfs:comment 'Start timestamp of any scheduled downtime window for maintenance, cleaning, or changeover activities.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Executed Timestamp' ;
    rdfs:comment 'Date and time when the production schedule was marked as executed or completed.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:frozenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Frozen Timestamp' ;
    rdfs:comment 'Date and time when the production schedule was frozen, preventing further changes without formal change control.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:patImplementationFlag rdf:type rdf:Property ;
    rdfs:label 'Pat Implementation Flag' ;
    rdfs:comment 'Indicates whether Process Analytical Technology is implemented for real-time monitoring during the scheduled production.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning horizon covered by this production schedule.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning horizon covered by this production schedule.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qbdPrinciplesAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Qbd Principles Applied Flag' ;
    rdfs:comment 'Indicates whether Quality by Design principles have been applied in the development of this production schedule.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text notes or comments related to the production schedule, capturing special instructions, constraints, or considerations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the production schedule indicating its approval and execution state.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Type of production schedule indicating the planning level (e.g., master schedule, operational schedule).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for the production schedule, enabling tracking of schedule revisions and changes over time.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDurationHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Hours' ;
    rdfs:comment 'Planned duration of the production run in hours, calculated from scheduled start to end timestamps.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned end date and time for the production run on the manufacturing line.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned start date and time for the production run on the manufacturing line.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplyChainPlanningSystem rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Planning System' ;
    rdfs:comment 'Name of the supply chain planning system that generated or influenced this production schedule (e.g., Kinaxis RapidResponse, Blue Yonder).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processParameterId rdf:type rdf:Property ;
    rdfs:label 'Process Parameter Id' ;
    rdfs:comment 'Unique identifier for the process parameter definition. Primary key for the process parameter entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessParameter .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual measured or recorded value of this parameter during batch execution. Captured from Manufacturing Execution System (MES), PAT instruments, or manual operator entry. Used for batch record documentation and process validation.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Conformance Status' ;
    rdfs:comment 'Assessment of whether the measured value meets the defined control and specification limits. Out of Specification (OOS) or Out of Trend (OOT) results trigger investigation and Corrective and Preventive Action (CAPA) processes.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityJustification rdf:type rdf:Property ;
    rdfs:label 'Criticality Justification' ;
    rdfs:comment 'Scientific rationale and risk assessment documentation explaining why this parameter is classified as critical or non-critical. Required for regulatory submissions and Quality by Design (QbD) documentation per ICH Q8.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityHash rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Hash' ;
    rdfs:comment 'Cryptographic hash or checksum of the parameter measurement record to ensure data integrity and detect unauthorized modifications. Supports 21 CFR Part 11 electronic signature and audit trail requirements.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Investigation Required Flag' ;
    rdfs:comment 'Indicates whether this parameter measurement requires formal investigation due to exceeding control or specification limits. True triggers Quality Assurance (QA) review and potential Corrective and Preventive Action (CAPA).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'The lower boundary of the normal operating range for this parameter. Values below this trigger investigation but may not require batch rejection. Used for statistical process control and continuous process verification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'The minimum acceptable value for this parameter as defined in regulatory filings and approved specifications. Values below this limit may result in batch rejection or deviation investigation per Current Good Manufacturing Practice (cGMP).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'The required frequency or timing for measuring this parameter during batch execution. Defines sampling plan and monitoring requirements per the approved batch record. [ENUM-REF-CANDIDATE: continuous|per_batch|hourly|per_shift|daily|on_demand|at_process_step — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The method by which this parameter is measured or recorded. Indicates whether data is captured through Process Analytical Technology (PAT), manual operator entry, or laboratory testing. [ENUM-REF-CANDIDATE: manual_entry|automated_sensor|pat_instrument|laboratory_analysis|inline_measurement|atline_measurement|offline_measurement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The date and time when this parameter measurement was recorded. Critical for establishing batch record chronology and supporting 21 CFR Part 11 electronic records compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the parameter within the manufacturing process. Used for cross-referencing with Manufacturing Execution System (MES) and Process Analytical Technology (PAT) instruments.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Human-readable name of the process parameter (e.g., Mixing Temperature, Compression Force, pH Level, Dissolution Rate).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterType rdf:type rdf:Property ;
    rdfs:label 'Parameter Type' ;
    rdfs:comment 'Classification of the parameter based on its impact on product quality. Critical Process Parameters (CPPs) have direct impact on Critical Quality Attributes (CQAs) and require stringent control per Quality by Design (QbD) principles.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterVersion rdf:type rdf:Property ;
    rdfs:label 'Parameter Version' ;
    rdfs:comment 'Version number of the parameter specification. Incremented when control limits, specification limits, or other parameter attributes are changed through the change control process. Supports regulatory change history requirements.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether deviations or out-of-specification results for this parameter must be reported to regulatory authorities (FDA, EMA, etc.) as part of annual product reviews or post-approval change protocols.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The intended setpoint or target value for this parameter as defined in the master batch record or process development documentation. Represents the optimal operating point.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'The upper boundary of the normal operating range for this parameter. Values above this trigger investigation but may not require batch rejection. Used for statistical process control and continuous process verification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'The maximum acceptable value for this parameter as defined in regulatory filings and approved specifications. Values above this limit may result in batch rejection or deviation investigation per Current Good Manufacturing Practice (cGMP).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'The date and time when this parameter measurement was reviewed and verified by Quality Assurance (QA) or supervisory personnel. Part of the batch record review and release process.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processParameterResultId rdf:type rdf:Property ;
    rdfs:label 'Process Parameter Result Id' ;
    rdfs:comment 'Unique identifier for the process parameter result record. Primary key for this entity.' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationResult rdf:type rdf:Property ;
    rdfs:label 'Evaluation Result' ;
    rdfs:comment 'Result of comparing the measured value against specification limits: Pass (within limits), Fail (out of specification), Warning (approaching limits), Not Evaluated (no limits defined).' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Actual measured value of the process parameter as recorded during batch execution. This is the primary result field.' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Name of the operator or technician who recorded the measurement. Denormalized for audit and compliance reporting.' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patIndicator rdf:type rdf:Property ;
    rdfs:label 'Pat Indicator' ;
    rdfs:comment 'Indicates whether this measurement was captured using Process Analytical Technology (PAT) real-time monitoring tools per FDA PAT guidance.' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingPoint rdf:type rdf:Property ;
    rdfs:label 'Sampling Point' ;
    rdfs:comment 'Physical location or sampling point within the process equipment where the measurement was taken (e.g., Inlet, Outlet, Mid-Point, Probe Location).' ;
    rdfs:domain ind:ProcessParameterResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the validated test method or Standard Operating Procedure (SOP) used for the measurement (e.g., SOP-QC-1234, USP Method 621).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'Date when the deviation was first identified or detected.' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detectionPhase rdf:type rdf:Property ;
    rdfs:label 'Detection Phase' ;
    rdfs:comment 'Manufacturing or quality control phase during which the deviation was detected: in-process (during production), packaging (during fill-finish or labeling), qc_testing (during in-process or final QC), release_testing (during batch release), stability_testing (during ongoing stability studies), post_release (after product distribution).' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Number' ;
    rdfs:comment 'Business identifier for the deviation, typically system-generated or manually assigned following organizational numbering convention. Used for external reference and tracking.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationType rdf:type rdf:Property ;
    rdfs:label 'Deviation Type' ;
    rdfs:comment 'Classification of the deviation by root category: process (procedure not followed), equipment (malfunction or failure), material (raw material or component issue), environmental (cleanroom or facility condition), documentation (batch record or SOP error), personnel (training or human error).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of containment or corrective actions taken immediately upon detection to prevent further impact or recurrence during the batch.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Evaluation of the deviations impact on product quality, safety, efficacy, and compliance. Includes assessment of affected batches, potential patient risk, and regulatory implications.' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the deviation investigation was completed and root cause determined.' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when formal investigation of the deviation was initiated.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Deviation Description' ;
    rdfs:comment 'Detailed narrative description of the deviation event, including what occurred, when it was observed, and the circumstances surrounding the event.' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDeviationStatus rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Deviation Status' ;
    rdfs:comment 'Current lifecycle state of the deviation: open (newly identified), under_investigation (root cause analysis in progress), pending_capa (awaiting corrective action), closed (investigation and actions complete), cancelled (determined not to be a deviation).' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Occurrence Date' ;
    rdfs:comment 'Estimated or known date when the deviation actually occurred, which may differ from detection date.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Specific manufacturing process step or operation during which the deviation occurred (e.g., blending, granulation, tablet compression, sterile filtration, lyophilization).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qmsSystemReference rdf:type rdf:Property ;
    rdfs:label 'Qms System Reference' ;
    rdfs:comment 'External reference identifier from the source quality management system (MasterControl, TrackWise, or other QMS) for integration and traceability.' ;
    rdfs:domain ind:ManufacturingDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the deviation was reported to regulatory authorities, if applicable.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of the identified root cause after investigation (e.g., human error, equipment failure, material defect, procedure inadequacy, environmental control failure).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed explanation of the root cause identified through investigation, including contributing factors and evidence supporting the conclusion.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Impact classification of the deviation: critical (direct impact on product quality, safety, or efficacy), major (potential impact requiring investigation), minor (no expected impact on product quality).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenDeclaration rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration' ;
    rdfs:comment 'Free-text declaration of any known allergens present in the formulation (e.g., lactose, egg protein, soy). Required for labeling and patient safety.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalDerivedMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Animal Derived Material Flag' ;
    rdfs:comment 'Indicates whether any component in this BOM is derived from animal sources. Triggers additional TSE/BSE risk assessment and documentation requirements.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiComponentCount rdf:type rdf:Property ;
    rdfs:label 'Api Component Count' ;
    rdfs:comment 'Number of API components in this BOM. Most formulations have 1-3 APIs; combination products may have more.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, externally visible and used in manufacturing execution and procurement systems.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Only active BOMs may be used in production. Superseded BOMs are retained for historical batch traceability.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version identifier for the BOM. Incremented when formulation or component changes occur. Critical for change control and regulatory traceability.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipientComponentCount rdf:type rdf:Property ;
    rdfs:label 'Excipient Component Count' ;
    rdfs:comment 'Number of excipient (inactive ingredient) components in this BOM. Includes binders, fillers, preservatives, stabilizers, etc.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpGradeRequirement rdf:type rdf:Property ;
    rdfs:label 'Gmp Grade Requirement' ;
    rdfs:comment 'The minimum quality grade required for all components in this BOM. Typically GMP or compendial grade for pharmaceutical manufacturing. [ENUM-REF-CANDIDATE: gmp|usp_nf|ep|jp|compendial|food_grade|technical — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halalCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Halal Certified Flag' ;
    rdfs:comment 'Indicates whether this BOM formulation is certified Halal, relevant for certain markets and patient populations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kosherCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kosher Certified Flag' ;
    rdfs:comment 'Indicates whether this BOM formulation is certified Kosher, relevant for certain markets and patient populations.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingComponentCount rdf:type rdf:Property ;
    rdfs:label 'Packaging Component Count' ;
    rdfs:comment 'Number of packaging material components (primary and secondary) in this BOM. Includes vials, stoppers, labels, cartons, inserts.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qbdDesignSpaceFlag rdf:type rdf:Property ;
    rdfs:label 'Qbd Design Space Flag' ;
    rdfs:comment 'Indicates whether this BOM was developed using Quality by Design principles with an established design space per ICH Q8.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalComponentCount rdf:type rdf:Property ;
    rdfs:label 'Total Component Count' ;
    rdfs:comment 'Total number of distinct component line items (raw materials, APIs, excipients, packaging) in this BOM. Used for completeness validation.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Total Material Cost' ;
    rdfs:comment 'Total cost of all materials (API, excipients, packaging) for one standard batch. Used for COGS calculation and pricing analysis. Currency assumed USD unless otherwise specified.' ;
    rdfs:domain ind:BillOfMaterials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Pre-defined acceptance criteria that the validation study must meet to be considered successful. Includes Critical Quality Attributes (CQA) specifications, Critical Process Parameters (CPP) ranges, yield targets, impurity limits, and other quality metrics. Must be established before validation execution.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeMax rdf:type rdf:Property ;
    rdfs:label 'Batch Size Max' ;
    rdfs:comment 'Maximum batch size validated in the study, expressed in the unit of measure appropriate for the product. Defines the upper bound of the validated batch size range.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeMin rdf:type rdf:Property ;
    rdfs:label 'Batch Size Min' ;
    rdfs:comment 'Minimum batch size validated in the study, expressed in the unit of measure appropriate for the product (kg for API, number of units for finished dosage form). Defines the lower bound of the validated batch size range.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cppMonitored rdf:type rdf:Property ;
    rdfs:label 'Cpp Monitored' ;
    rdfs:comment 'List of Critical Process Parameters (CPP) monitored during the validation study. CPPs are process parameters whose variability has an impact on a CQA and therefore should be monitored or controlled to ensure the process produces the desired quality. Examples include temperature, pressure, mixing time, pH, flow rate.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cqaMonitored rdf:type rdf:Property ;
    rdfs:label 'Cqa Monitored' ;
    rdfs:comment 'List of Critical Quality Attributes (CQA) monitored during the validation study. CQAs are physical, chemical, biological, or microbiological properties that should be within an appropriate limit, range, or distribution to ensure the desired product quality. Examples include assay, impurities, dissolution, content uniformity, sterility, endotoxin.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designSpaceDefined rdf:type rdf:Property ;
    rdfs:label 'Design Space Defined' ;
    rdfs:comment 'Indicates whether a design space was defined as part of the validation. Design space is the multidimensional combination and interaction of input variables and process parameters that have been demonstrated to provide assurance of quality per ICH Q8. True if design space was established through QbD approach.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfRuns rdf:type rdf:Property ;
    rdfs:label 'Number Of Runs' ;
    rdfs:comment 'Number of validation batches or runs executed as part of the validation study. Typically minimum 3 consecutive successful batches for process validation per FDA guidance. May vary based on validation type and risk assessment.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oosCount rdf:type rdf:Property ;
    rdfs:label 'Oos Count' ;
    rdfs:comment 'Number of Out of Specification (OOS) results encountered during validation execution. OOS results require investigation per FDA OOS guidance and may impact validation outcome.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patImplementation rdf:type rdf:Property ;
    rdfs:label 'Pat Implementation' ;
    rdfs:comment 'Indicates whether Process Analytical Technology (PAT) tools were implemented as part of the validation. PAT is a system for designing, analyzing, and controlling manufacturing through timely measurements of critical quality and performance attributes with the goal of ensuring final product quality. True if PAT tools (e.g., NIR, Raman, in-line sensors) were used.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Protocol Approval Date' ;
    rdfs:comment 'Date when the validation protocol was approved by Quality Assurance and authorized for execution. Represents the start of the validation lifecycle.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaApprover rdf:type rdf:Property ;
    rdfs:label 'Qa Approver' ;
    rdfs:comment 'Name of the Quality Assurance representative who reviewed and approved the validation protocol and report. QA approval is required per cGMP regulations.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference to the regulatory filing (IND, NDA, BLA, MAA, eCTD section) where this validation data is or will be submitted. Validation data is typically included in Module 3 (Quality) of the Common Technical Document (CTD).' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Report Approval Date' ;
    rdfs:comment 'Date when the validation report was reviewed and approved by Quality Assurance. This is the official validation completion date and triggers the validated state for the process.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revalidationTrigger rdf:type rdf:Property ;
    rdfs:label 'Revalidation Trigger' ;
    rdfs:comment 'Event or condition that triggered the need for revalidation. Examples include: process changes, equipment changes, facility changes, raw material supplier changes, scale-up or scale-down, transfer to new site, out-of-specification results, quality issues, regulatory inspection findings, or periodic review schedule. Supports change control and lifecycle management per ICH Q12.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationApproach rdf:type rdf:Property ;
    rdfs:label 'Validation Approach' ;
    rdfs:comment 'Validation approach methodology. Traditional approach uses fixed process parameters and extensive testing. Quality by Design (QbD) approach uses design space and process understanding per ICH Q8. Hybrid combines traditional and QbD elements. Risk-based approach uses ICH Q9 risk management principles to focus validation efforts.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationLead rdf:type rdf:Property ;
    rdfs:label 'Validation Lead' ;
    rdfs:comment 'Name of the person responsible for leading the validation study. Typically a validation engineer, process engineer, or quality assurance specialist.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationOutcome rdf:type rdf:Property ;
    rdfs:label 'Validation Outcome' ;
    rdfs:comment 'Overall outcome of the validation study. Pass indicates all acceptance criteria were met. Fail indicates one or more acceptance criteria were not met. Conditional indicates validation passed with minor deviations that require corrective action but do not invalidate the study. Inconclusive indicates validation could not be completed or results were ambiguous.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStage rdf:type rdf:Property ;
    rdfs:label 'Validation Stage' ;
    rdfs:comment 'Stage of process validation per FDA lifecycle approach. Stage 1 (Process Design) establishes commercial manufacturing process based on development knowledge. Stage 2 (Process Qualification) confirms process design is capable of reproducible commercial manufacturing. Stage 3 (Continued Process Verification) provides ongoing assurance that process remains in control. Also includes legacy approaches: prospective (validation before routine production), concurrent (validation during routine production), and retrospective (validation using historical data).' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationType rdf:type rdf:Property ;
    rdfs:label 'Validation Type' ;
    rdfs:comment 'Type of validation being performed. Process validation covers manufacturing processes, cleaning validation covers equipment cleaning procedures, computerized system validation covers MES/SCADA/LIMS systems per 21 CFR Part 11, analytical method validation covers laboratory test methods, equipment validation covers production equipment qualification, and sterilization validation covers sterilization cycles.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Id' ;
    rdfs:comment 'Unique identifier for the environmental monitoring record. Primary key.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionLimit rdf:type rdf:Property ;
    rdfs:label 'Action Limit' ;
    rdfs:comment 'Action limit threshold for the monitoring type and location. Exceeding this limit requires immediate corrective action and deviation investigation.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actionLimitExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Action Limit Exceeded Flag' ;
    rdfs:comment 'Boolean flag indicating whether the action limit was exceeded (True) or not (False).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertLimit rdf:type rdf:Property ;
    rdfs:label 'Alert Limit' ;
    rdfs:comment 'Alert limit threshold for the monitoring type and location. Exceeding this limit triggers investigation but does not necessarily indicate a deviation.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertLimitExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Limit Exceeded Flag' ;
    rdfs:comment 'Boolean flag indicating whether the alert limit was exceeded (True) or not (False).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cfuCount rdf:type rdf:Property ;
    rdfs:label 'Cfu Count' ;
    rdfs:comment 'Number of colony forming units (CFU) detected in the sample. For viable air, typically reported as CFU per cubic meter; for surface, CFU per plate or per area.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cfuPerCubicMeter rdf:type rdf:Property ;
    rdfs:label 'Cfu Per Cubic Meter' ;
    rdfs:comment 'Normalized CFU count per cubic meter of air sampled, calculated for viable air monitoring.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleanroomClassificationIso rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Classification Iso' ;
    rdfs:comment 'ISO 14644-1 cleanroom classification for the monitored area.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanroomGradeEu rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Grade Eu' ;
    rdfs:comment 'EU GMP Annex 1 cleanroom grade classification for the monitored area.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Exposure Duration Minutes' ;
    rdfs:comment 'Duration in minutes that a passive settle plate or contact plate was exposed. Null for active air sampling.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incubationDurationHours rdf:type rdf:Property ;
    rdfs:label 'Incubation Duration Hours' ;
    rdfs:comment 'Duration in hours for which the microbial sample was incubated before reading.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incubationTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Incubation Temperature Celsius' ;
    rdfs:comment 'Temperature in degrees Celsius at which the microbial sample was incubated.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingOperationPhase rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Operation Phase' ;
    rdfs:comment 'Phase of manufacturing operation during which the environmental monitoring was performed: at-rest (no activity), operational (normal production), or intervention (during maintenance or setup).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocationCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Code' ;
    rdfs:comment 'Unique code identifying the specific location within the cleanroom or controlled area where the sample was taken (e.g., FILL-ROOM-A-LOC-001).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Description' ;
    rdfs:comment 'Human-readable description of the monitoring location (e.g., \'Near filling line conveyor belt, 1 meter from HEPA filter\').' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Type' ;
    rdfs:comment 'Type of environmental monitoring performed: viable air (microbial air sampling), surface (contact plates or swabs), personnel (gown or glove sampling), non-viable particulate (particle counting), or water (for water systems).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organismIdentified rdf:type rdf:Property ;
    rdfs:label 'Organism Identified' ;
    rdfs:comment 'Name of the microorganism identified in the sample (e.g., Staphylococcus epidermidis, Bacillus species). Null if no growth or if identification not performed.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:particulateCount05Micron rdf:type rdf:Property ;
    rdfs:label 'Particulate Count 0 5 Micron' ;
    rdfs:comment 'Number of particles equal to or greater than 0.5 microns detected per cubic meter for non-viable particulate monitoring.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:particulateCount50Micron rdf:type rdf:Property ;
    rdfs:label 'Particulate Count 5 0 Micron' ;
    rdfs:comment 'Number of particles equal to or greater than 5.0 microns detected per cubic meter for non-viable particulate monitoring.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the environmental monitoring result was reviewed and approved by quality assurance.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleCollectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Timestamp' ;
    rdfs:comment 'Date and time when the environmental monitoring sample was collected.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Sample Volume Liters' ;
    rdfs:comment 'Volume of air sampled in liters for viable or non-viable air monitoring. Null for surface or personnel monitoring.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'Specific method used to collect the environmental sample (e.g., active air sampling with impactor, passive settle plate, contact plate, swab, finger dab, glove print).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendFlag rdf:type rdf:Property ;
    rdfs:label 'Trend Flag' ;
    rdfs:comment 'Boolean flag indicating whether this result is part of an adverse trend requiring investigation (True) or not (False).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggeringIcsrId rdf:type rdf:Property ;
    rdfs:label 'Triggering Icsr Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.icsr. Business justification: ICSRs reporting product-quality-related adverse events directly trigger CAPAs. FDA/EMA post-market surveillance requires tracing quality corrective actions back to the originating safety report. A pha' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Icsr .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business identifier for the CAPA record, typically system-generated or following organizational numbering convention. Used for external reference and tracking.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA record indicating its progression through the CAPA workflow from initiation through closure. [ENUM-REF-CANDIDATE: initiated|investigation|action_plan|implementation|verification|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classification of the CAPA as corrective (addressing existing nonconformance), preventive (preventing potential nonconformance), or combined (both corrective and preventive actions).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedByName rdf:type rdf:Property ;
    rdfs:label 'Closed By Name' ;
    rdfs:comment 'Full name of the individual who approved and closed the CAPA record.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureComments rdf:type rdf:Property ;
    rdfs:label 'Closure Comments' ;
    rdfs:comment 'Final comments and summary provided at CAPA closure, documenting the rationale for closure and any lessons learned.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Additional contributing factors identified during root cause analysis that may have influenced the occurrence of the issue.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Detailed plan describing the corrective actions to be taken to address the identified root cause and prevent recurrence.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckComments rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Comments' ;
    rdfs:comment 'Detailed comments and findings from the effectiveness check evaluation.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckCriteria rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Criteria' ;
    rdfs:comment 'Defined criteria and metrics to be used to evaluate the effectiveness of the CAPA actions.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Date' ;
    rdfs:comment 'Date when the effectiveness check was performed to verify CAPA effectiveness.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Required Flag' ;
    rdfs:comment 'Indicates whether an effectiveness check is required to verify that the CAPA actions successfully addressed the root cause and prevented recurrence.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivenessCheckResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Result' ;
    rdfs:comment 'Result of the effectiveness check indicating whether the CAPA actions were effective in addressing the root cause and preventing recurrence.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedByName rdf:type rdf:Property ;
    rdfs:label 'Initiated By Name' ;
    rdfs:comment 'Full name of the individual who initiated the CAPA record.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingEventType rdf:type rdf:Property ;
    rdfs:label 'Originating Event Type' ;
    rdfs:comment 'Type of quality management system event that triggered the CAPA, such as deviation, Out of Specification (OOS), Out of Trend (OOT), audit finding, customer complaint, or change control. [ENUM-REF-CANDIDATE: deviation|oos|oot|audit_finding|complaint|change_control|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Plan' ;
    rdfs:comment 'Detailed plan describing the preventive actions to be taken to eliminate potential causes of nonconformance and prevent occurrence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCapaDescription rdf:type rdf:Property ;
    rdfs:label 'Quality Capa Description' ;
    rdfs:comment 'Detailed description of the nonconformance, problem, or potential risk that the CAPA addresses, including background context and scope.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Commitment Flag' ;
    rdfs:comment 'Indicates whether this CAPA is a commitment made to a regulatory authority (FDA, EMA, MHRA, etc.) as part of an inspection response, warning letter response, or regulatory submission.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause(s) of the nonconformance or issue, documented as the outcome of the root cause analysis investigation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'Methodology used to perform root cause analysis, such as 5-Why, Fishbone (Ishikawa), Failure Mode and Effects Analysis (FMEA), Fault Tree Analysis, or Pareto analysis.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Flag' ;
    rdfs:comment 'Indicates whether the deviation was identified during an internal audit, external audit, or regulatory inspection.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Flag' ;
    rdfs:comment 'Indicates whether the deviation was identified as a result of a customer complaint, linking quality issues to market feedback.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedBy rdf:type rdf:Property ;
    rdfs:label 'Detected By' ;
    rdfs:comment 'Name or identifier of the individual who discovered the deviation. Used for quality culture assessment and training needs analysis.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedDate rdf:type rdf:Property ;
    rdfs:label 'Detected Date' ;
    rdfs:comment 'Calendar date when the deviation was first identified or discovered. Critical for timeline reconstruction and regulatory reporting.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deviationStatus rdf:type rdf:Property ;
    rdfs:label 'Deviation Status' ;
    rdfs:comment 'Current lifecycle state of the deviation record in the quality management workflow, from initial detection through investigation, corrective action, and closure.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Disposition Recommendation' ;
    rdfs:comment 'Recommended disposition of the affected batch or material based on investigation findings and quality risk assessment. Subject to quality assurance approval.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'Approved final disposition of the affected batch or material after quality assurance review and approval.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Actual date when the deviation investigation was completed and documented, including root cause analysis and corrective action plan.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationDueDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Due Date' ;
    rdfs:comment 'Target date for completion of the deviation investigation, typically based on GMP impact classification and organizational quality standards.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Qa Approval Date' ;
    rdfs:comment 'Date when the quality assurance reviewer approved the deviation investigation and closure, authorizing final disposition.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaReviewer rdf:type rdf:Property ;
    rdfs:label 'Qa Reviewer' ;
    rdfs:comment 'Name or identifier of the quality assurance professional who reviewed and approved the deviation investigation and disposition decision.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Quality Deviation Description' ;
    rdfs:comment 'Detailed narrative description of the deviation event, including what was observed, what was expected, and the nature of the departure from approved procedures or specifications.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Summary' ;
    rdfs:comment 'Summary of the root cause analysis findings, identifying the underlying reason(s) for the deviation occurrence. Populated after investigation completion.' ;
    rdfs:domain ind:QualityDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Oos Investigation Id' ;
    rdfs:comment 'Unique identifier for the OOS investigation record. Primary key.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosInvestigation .

ind:labTestResultId rdf:type rdf:Property ;
    rdfs:label 'Lab Test Result Id' ;
    rdfs:comment 'Reference to the specific laboratory test result that triggered the OOS investigation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabTestResult .

ind:assignabilityDetermination rdf:type rdf:Property ;
    rdfs:label 'Assignability Determination' ;
    rdfs:comment 'Determination of whether the OOS result is assignable to a specific identifiable cause. Assignable means a definitive cause was found; unassignable means no cause could be conclusively determined.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchDisposition rdf:type rdf:Property ;
    rdfs:label 'Batch Disposition' ;
    rdfs:comment 'Final disposition decision for the affected batch based on investigation findings (released, rejected, reworked, quarantined, or pending further investigation).' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'Name or identifier of the quality professional who formally closed the OOS investigation.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionJustification rdf:type rdf:Property ;
    rdfs:label 'Disposition Justification' ;
    rdfs:comment 'Scientific and regulatory justification for the batch disposition decision, including consideration of patient safety and product quality.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationClosedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Closed Date' ;
    rdfs:comment 'Date when the OOS investigation was formally closed after all phases completed and disposition determined.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationConclusion rdf:type rdf:Property ;
    rdfs:label 'Investigation Conclusion' ;
    rdfs:comment 'Final conclusion summary of the OOS investigation, including determination of cause, impact assessment, and corrective actions taken.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Business identifier for the OOS investigation, typically assigned by the Quality Management System (QMS) or Laboratory Information Management System (LIMS).' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the OOS investigation. Phase I covers laboratory investigation; Phase II covers full-scale investigation if laboratory error is ruled out.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryErrorDescription rdf:type rdf:Property ;
    rdfs:label 'Laboratory Error Description' ;
    rdfs:comment 'Detailed description of the laboratory error identified, if applicable (e.g., instrument malfunction, calculation error, contamination).' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryErrorIdentified rdf:type rdf:Property ;
    rdfs:label 'Laboratory Error Identified' ;
    rdfs:comment 'Indicates whether a laboratory error was conclusively identified during Phase I investigation that explains the OOS result.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observedResult rdf:type rdf:Property ;
    rdfs:label 'Observed Result' ;
    rdfs:comment 'Actual test result value that fell outside the specification limit and triggered the OOS investigation.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseICompletionDate rdf:type rdf:Property ;
    rdfs:label 'Phase I Completion Date' ;
    rdfs:comment 'Date when Phase I laboratory investigation was completed.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseIFindings rdf:type rdf:Property ;
    rdfs:label 'Phase I Findings' ;
    rdfs:comment 'Summary of findings from the Phase I laboratory investigation, including any identified laboratory errors or anomalies.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseIStartDate rdf:type rdf:Property ;
    rdfs:label 'Phase I Start Date' ;
    rdfs:comment 'Date when Phase I laboratory investigation began to determine if the OOS result was due to laboratory error.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseIiCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Completion Date' ;
    rdfs:comment 'Date when Phase II full-scale investigation was completed.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseIiFindings rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Findings' ;
    rdfs:comment 'Summary of findings from Phase II investigation, including root cause analysis of manufacturing, material, or process issues.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseIiRequired rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Required' ;
    rdfs:comment 'Indicates whether Phase II full-scale investigation is required. Phase II is triggered when no laboratory error is found in Phase I.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phaseIiStartDate rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Start Date' ;
    rdfs:comment 'Date when Phase II full-scale investigation began to determine root cause in manufacturing, materials, or process.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaReviewDate rdf:type rdf:Property ;
    rdfs:label 'Qa Review Date' ;
    rdfs:comment 'Date when the Quality Assurance review and approval was completed.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether the OOS investigation findings require reporting to regulatory authorities (FDA, EMA, etc.) per applicable regulations.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestAuthorized rdf:type rdf:Property ;
    rdfs:label 'Retest Authorized' ;
    rdfs:comment 'Indicates whether retesting was authorized following Phase I investigation. Retesting is only appropriate when laboratory error is confirmed.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestJustification rdf:type rdf:Property ;
    rdfs:label 'Retest Justification' ;
    rdfs:comment 'Scientific justification for authorizing retesting, including explanation of the laboratory error that invalidates the original result.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestResult rdf:type rdf:Property ;
    rdfs:label 'Retest Result' ;
    rdfs:comment 'Result obtained from authorized retesting, if performed.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseIdentified rdf:type rdf:Property ;
    rdfs:label 'Root Cause Identified' ;
    rdfs:comment 'Indicates whether a definitive root cause was identified during Phase II investigation.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Analytical test method or procedure used that produced the OOS result (e.g., HPLC, dissolution, assay).' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testParameter rdf:type rdf:Property ;
    rdfs:label 'Test Parameter' ;
    rdfs:comment 'Specific quality attribute or parameter being tested (e.g., potency, impurity level, dissolution rate).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Actual date when the change was implemented in production or operational environment.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedSopList rdf:type rdf:Property ;
    rdfs:label 'Affected Sop List' ;
    rdfs:comment 'List of SOP numbers or titles that are affected by the change and require revision or replacement.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the person or role who provided final approval for the change (typically QA Manager or Change Control Board Chair).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:comment 'Brief descriptive title summarizing the proposed change.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerified rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verified' ;
    rdfs:comment 'Indicates whether the change effectiveness has been verified through post-implementation review, confirming that the change achieved its intended purpose without adverse impact.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationPlan rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan' ;
    rdfs:comment 'Detailed plan describing how the change will be implemented, including steps, responsibilities, timelines, training requirements, and communication plan.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postImplementationReview rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review' ;
    rdfs:comment 'Summary of the post-implementation review conducted to verify that the change was implemented as planned, achieved intended objectives, and did not introduce unintended consequences. Includes effectiveness assessment.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Assessment' ;
    rdfs:comment 'Assessment of regulatory implications including whether the change requires prior approval, notification, or annual reporting to regulatory authorities (FDA, EMA, PMDA, etc.) and which markets are affected.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether regulatory notification or prior approval is required for this change based on regulatory impact assessment.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Summary of the risk assessment performed to evaluate potential impact on product quality, patient safety, data integrity, and regulatory compliance. Includes risk level determination.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopUpdatesRequired rdf:type rdf:Property ;
    rdfs:label 'Sop Updates Required' ;
    rdfs:comment 'Indicates whether existing SOPs need to be revised or new SOPs need to be created as part of the change implementation.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Target Implementation Date' ;
    rdfs:comment 'Planned or target date for implementing the approved change.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether personnel training is required before implementing the change to ensure staff competency with new processes, equipment, or procedures.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Validation Protocol Reference' ;
    rdfs:comment 'Reference to validation or qualification protocol document(s) required to support the change, including protocol numbers or document identifiers.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRequired rdf:type rdf:Property ;
    rdfs:label 'Validation Required' ;
    rdfs:comment 'Indicates whether validation or qualification activities are required to demonstrate that the change does not adversely affect product quality, process performance, or system functionality.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Primary key for audit' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:auditedHcpMasterId rdf:type rdf:Property ;
    rdfs:label 'Audited Hcp Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.master. Business justification: Pharma compliance audits of HCP speakers and contractors (not in investigator role) are a named regulatory process. The existing audited_investigator_id covers clinical investigators; this FK covers H' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:auditedInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Audited Investigator Id' ;
    rdfs:comment 'Foreign key linking to hcp.investigator. Business justification: Clinical investigator audits assess individual investigator GCP compliance, protocol adherence, and data integrity. Critical for clinical trial quality assurance, regulatory inspections, and investiga' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:findingOosInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Finding Oos Investigation Id' ;
    rdfs:comment 'Foreign key linking to quality.oos_investigation. Business justification: Audits can uncover OOS investigations that require review or follow-up. This FK links audit findings to specific OOS investigation records. Business case: regulatory inspections may review OOS investi' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosInvestigation .

ind:agenda rdf:type rdf:Property ;
    rdfs:label 'Agenda' ;
    rdfs:comment 'Detailed agenda or schedule of audit activities including opening meeting, process walkthroughs, document reviews, interviews, sampling activities, and closing meeting. May reference specific Standard Operating Procedures (SOPs) or areas to be assessed.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Business identifier for the audit or inspection, typically assigned by the Quality Management System (QMS) such as MasterControl or TrackWise. Externally visible audit reference number.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope including functional areas, processes, systems, or product lines covered. May include specific GMP (Good Manufacturing Practice) areas such as manufacturing, quality control, quality assurance, warehousing, distribution, or specific therapeutic product lines.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit. Planned indicates scheduled but not yet started; in preparation indicates pre-audit activities underway; in progress indicates on-site audit activities; fieldwork complete indicates audit activities concluded; draft report indicates findings being documented; final report issued indicates official audit report delivered; closed indicates all findings addressed and audit formally closed. [ENUM-REF-CANDIDATE: planned|in_preparation|in_progress|fieldwork_complete|draft_report|final_report_issued|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit or inspection. Internal GMP (Good Manufacturing Practice) audits assess company facilities; supplier qualification audits evaluate vendors; CMO (Contract Manufacturing Organization) audits assess outsourced manufacturing partners; regulatory inspections are conducted by agencies such as FDA (Food and Drug Administration), EMA (European Medicines Agency), or MHRA (Medicines and Healthcare products Regulatory Agency); self-inspections are proactive internal reviews; surveillance audits are follow-up assessments.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Closure Verification Date' ;
    rdfs:comment 'Date when closure verification activities were completed and all audit findings were confirmed as effectively resolved. Marks the formal closure of the audit record.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Verification Status' ;
    rdfs:comment 'Status of verification activities to confirm that corrective actions have been effectively implemented and findings are resolved. Pending indicates awaiting verification; in verification indicates verification activities underway; verified indicates actions confirmed effective; closed indicates audit formally closed with all findings resolved.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteria rdf:type rdf:Property ;
    rdfs:label 'Criteria' ;
    rdfs:comment 'Set of policies, procedures, regulations, or standards against which the audit was conducted. May include specific FDA 21 CFR parts, ICH guidelines, ISO standards, internal SOPs (Standard Operating Procedures), or GMP (Good Manufacturing Practice) requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical findings identified. Critical findings represent serious GMP (Good Manufacturing Practice) violations or compliance failures that pose significant risk to product quality, patient safety, or data integrity and require immediate corrective action.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:form483Issued rdf:type rdf:Property ;
    rdfs:label 'Form 483 Issued' ;
    rdfs:comment 'Boolean flag indicating whether the FDA (Food and Drug Administration) issued a Form 483 (Inspectional Observations) at the conclusion of the inspection. Form 483 documents objectionable conditions or practices observed during an FDA inspection.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Specific type of regulatory inspection. PAI (Pre-Approval Inspection) conducted before product approval; routine inspection per agency schedule; for-cause inspection triggered by quality issues; surveillance inspection for ongoing compliance; GMP (Good Manufacturing Practice), GCP (Good Clinical Practice), or GLP (Good Laboratory Practice) focused inspections. [ENUM-REF-CANDIDATE: pai|routine|for_cause|surveillance|pre_approval|gmp|gcp|glp — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major findings identified. Major findings represent significant compliance gaps or GMP (Good Manufacturing Practice) deviations that could impact product quality or regulatory compliance and require formal corrective and preventive action (CAPA).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Methodology used to conduct the audit. On-site indicates physical presence at the facility; remote indicates virtual audit via video conference and electronic document review; hybrid combines on-site and remote elements; desktop review indicates document-only assessment without site visit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor findings identified. Minor findings represent isolated compliance issues or documentation gaps that do not significantly impact product quality but should be addressed to maintain system integrity.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next audit or inspection of this site or supplier based on audit frequency requirements, risk rating, and regulatory expectations. Used for audit planning and compliance tracking.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationsCount rdf:type rdf:Property ;
    rdfs:label 'Observations Count' ;
    rdfs:comment 'Number of observations or opportunities for improvement identified. Observations are noted areas for enhancement that do not constitute compliance violations but represent best practice recommendations.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallAuditOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Outcome' ;
    rdfs:comment 'Summary conclusion of the audit or inspection. Satisfactory indicates full compliance; acceptable with observations indicates minor issues noted; deficient indicates significant compliance gaps; unacceptable indicates critical failures; Official Action Indicated (OAI) and Voluntary Action Indicated (VAI) are FDA inspection classifications indicating regulatory action required or recommended.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAuditDate rdf:type rdf:Property ;
    rdfs:label 'Planned Audit Date' ;
    rdfs:comment 'Originally scheduled date for the audit as defined in the annual audit plan or inspection schedule. Used for tracking schedule adherence and planning purposes.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preAuditPreparationStatus rdf:type rdf:Property ;
    rdfs:label 'Pre Audit Preparation Status' ;
    rdfs:comment 'Status of pre-audit preparation activities including document review, audit plan development, team briefing, and logistics coordination. Critical for audit readiness and effectiveness.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssueDate rdf:type rdf:Property ;
    rdfs:label 'Report Issue Date' ;
    rdfs:comment 'Date when the final audit report was officially issued to the auditee or facility management. For regulatory inspections, this is the date the Form 483 or Establishment Inspection Report (EIR) was issued.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk rating assigned to the audited site or supplier based on audit findings, compliance history, product criticality, and potential impact to patient safety or product quality. Used for risk-based oversight and audit frequency determination per ICH Q9 Quality Risk Management.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list or structured text of audit team members including subject matter experts, technical specialists, and observers participating in the audit.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of findings, observations, or deficiencies identified during the audit or inspection across all severity classifications.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warningLetterIssued rdf:type rdf:Property ;
    rdfs:label 'Warning Letter Issued' ;
    rdfs:comment 'Boolean flag indicating whether a regulatory Warning Letter was issued following the inspection. Warning Letters are official FDA (Food and Drug Administration) correspondence notifying a company of serious violations requiring prompt corrective action.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaId rdf:type rdf:Property ;
    rdfs:label 'Coa Id' ;
    rdfs:comment 'Foreign key linking to quality.coa. Business justification: Lab test results are aggregated into Certificates of Analysis (CoA) for batch release. This FK links each test result to the CoA it was included in. Business case: CoA documents reference specific tes' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coa .

ind:originalTestResultLabTestResultId rdf:type rdf:Property ;
    rdfs:label 'Original Test Result Lab Test Result Id' ;
    rdfs:comment 'Reference to the original test result if this is a retest. Links to another lab_test_result record.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabTestResult .

ind:analystName rdf:type rdf:Property ;
    rdfs:label 'Analyst Name' ;
    rdfs:comment 'Full name of the laboratory analyst who performed the test.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Full name of the QA person who approved the test result.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Flag' ;
    rdfs:comment 'Boolean indicator that the test result has been approved by Quality Assurance (QA) for release or further processing.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Inclusion Flag' ;
    rdfs:comment 'Boolean indicator that this test result is included in the Certificate of Analysis issued for the batch.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instrumentName rdf:type rdf:Property ;
    rdfs:label 'Instrument Name' ;
    rdfs:comment 'Name or model of the analytical instrument used (e.g., Agilent HPLC 1260, Distek Dissolution Apparatus).' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Flag' ;
    rdfs:comment 'Boolean indicator that the result is out of specification and requires investigation per OOS procedures.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ootFlag rdf:type rdf:Property ;
    rdfs:label 'Oot Flag' ;
    rdfs:comment 'Boolean indicator that the result is within specification but outside expected trend limits, requiring investigation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Determination of whether the test result meets the specification limits. Current lifecycle status of the test result.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultText rdf:type rdf:Property ;
    rdfs:label 'Result Text' ;
    rdfs:comment 'Textual or qualitative result for tests that do not produce numeric values (e.g., Pass/Fail, Conforms, Positive/Negative).' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Boolean indicator that this test is a retest of a previous result. Used to track retesting activities.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedByName rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Name' ;
    rdfs:comment 'Full name of the person who reviewed the test result.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedDate rdf:type rdf:Property ;
    rdfs:label 'Reviewed Date' ;
    rdfs:comment 'Date and time when the test result was reviewed.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Reviewed Flag' ;
    rdfs:comment 'Boolean indicator that the test result has been reviewed by a qualified reviewer (e.g., QC supervisor).' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Classification of the sample being tested. Indicates the stage in the manufacturing or quality lifecycle. [ENUM-REF-CANDIDATE: raw_material|in_process|drug_substance|drug_product|stability|reference_standard|retained_sample — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityTimepoint rdf:type rdf:Property ;
    rdfs:label 'Stability Timepoint' ;
    rdfs:comment 'Timepoint in the stability study protocol (e.g., Initial, 3 months, 6 months, 12 months, 24 months).' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the test execution was completed and result recorded.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date when the laboratory test was performed. Principal business event timestamp for the test execution.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testNumber rdf:type rdf:Property ;
    rdfs:label 'Test Number' ;
    rdfs:comment 'Business identifier for the test execution. Human-readable unique test number assigned by LIMS.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Start Timestamp' ;
    rdfs:comment 'Precise date and time when the test execution started. Used for audit trail and chronological sequencing.' ;
    rdfs:domain ind:LabTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerClosureSystem rdf:type rdf:Property ;
    rdfs:label 'Container Closure System' ;
    rdfs:comment 'Description of the primary packaging configuration used in the stability study (e.g., HDPE bottle with child-resistant cap, blister pack PVC/PVDC/Aluminum, glass vial with rubber stopper). Critical for assessing packaging compatibility and shelf-life.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTimePointMonths rdf:type rdf:Property ;
    rdfs:label 'Current Time Point Months' ;
    rdfs:comment 'Most recent time point (in months from study start) for which testing has been completed. Used to track study progress.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:limsStudyReference rdf:type rdf:Property ;
    rdfs:label 'Lims Study Reference' ;
    rdfs:comment 'External identifier from the Laboratory Information Management System (LIMS) stability module (LabWare or Thermo Fisher SampleManager) where detailed time-point test results are stored. Enables traceability to source system.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPassFailStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Pass Fail Status' ;
    rdfs:comment 'Aggregate pass/fail status for the most recent completed time point. Fail indicates one or more test parameters exceeded specification limits. Triggers Out of Specification (OOS) investigation if fail.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date for completion of the final time-point testing and study closure, typically aligned with regulatory commitment timelines (e.g., 36 months for long-term studies).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pullPointSchedule rdf:type rdf:Property ;
    rdfs:label 'Pull Point Schedule' ;
    rdfs:comment 'Comma-separated list of planned time points (in months) when samples will be pulled and tested (e.g., 0, 3, 6, 9, 12, 18, 24, 36). Defines the study sampling plan per ICH guidelines.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestDateMonths rdf:type rdf:Property ;
    rdfs:label 'Retest Date Months' ;
    rdfs:comment 'Retest period in months for drug substances (API) derived from stability data. Indicates the time period after which the material must be retested before use in manufacturing.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statisticalTrendAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Statistical Trend Analysis Method' ;
    rdfs:comment 'Statistical method applied to evaluate stability data trends and support shelf-life determination: linear regression, pooled regression across batches, bracketing design, matrixing design, or none if not yet analyzed.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyNotes rdf:type rdf:Property ;
    rdfs:label 'Study Notes' ;
    rdfs:comment 'Free-text field for capturing additional study-level observations, deviations from protocol, chamber malfunctions, sample handling issues, or other relevant comments that may impact data interpretation.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Study Protocol Number' ;
    rdfs:comment 'Unique protocol identifier assigned to the stability study per internal numbering convention and regulatory submission requirements.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testParameters rdf:type rdf:Property ;
    rdfs:label 'Test Parameters' ;
    rdfs:comment 'Comma-separated list of analytical test parameters performed at each time point (e.g., assay, degradation products, dissolution, appearance, pH, viscosity, water content, particulate matter). Defines the analytical scope per study protocol.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accuracyRecoveryPercentMean rdf:type rdf:Property ;
    rdfs:label 'Accuracy Recovery Percent Mean' ;
    rdfs:comment 'Mean recovery percentage from accuracy studies, typically expected to be 98-102% for assay methods.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyResult rdf:type rdf:Property ;
    rdfs:label 'Accuracy Result' ;
    rdfs:comment 'Outcome of the accuracy assessment. Pass indicates recovery within predefined acceptance criteria across the method range.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compendialMethodFlag rdf:type rdf:Property ;
    rdfs:label 'Compendial Method Flag' ;
    rdfs:comment 'Indicates whether the method is based on a pharmacopeial (compendial) method from USP, EP, JP, or other official compendia. True if compendial, False if proprietary or in-house developed.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compendialReference rdf:type rdf:Property ;
    rdfs:label 'Compendial Reference' ;
    rdfs:comment 'Reference to the pharmacopeial monograph or general chapter if the method is compendial (e.g., USP <621>, EP 2.2.46, JP 17).' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediatePrecisionRsdPercent rdf:type rdf:Property ;
    rdfs:label 'Intermediate Precision Rsd Percent' ;
    rdfs:comment 'Relative standard deviation (RSD) from intermediate precision studies (inter-assay precision, different days, analysts, equipment), typically expected to be ≤ 3% for assay methods.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearityCorrelationCoefficient rdf:type rdf:Property ;
    rdfs:label 'Linearity Correlation Coefficient' ;
    rdfs:comment 'Correlation coefficient (R) from the linearity study, typically expected to be ≥ 0.999 for assay methods.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearityRangeLower rdf:type rdf:Property ;
    rdfs:label 'Linearity Range Lower' ;
    rdfs:comment 'Lower limit of the concentration range over which linearity was demonstrated.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearityRangeUnit rdf:type rdf:Property ;
    rdfs:label 'Linearity Range Unit' ;
    rdfs:comment 'Unit of measure for the linearity range (e.g., mg/mL, µg/mL, percent label claim).' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linearityRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Linearity Range Upper' ;
    rdfs:comment 'Upper limit of the concentration range over which linearity was demonstrated.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearityResult rdf:type rdf:Property ;
    rdfs:label 'Linearity Result' ;
    rdfs:comment 'Outcome of the linearity assessment. Pass indicates acceptable correlation coefficient and residuals within acceptance criteria.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodUnit rdf:type rdf:Property ;
    rdfs:label 'Lod Unit' ;
    rdfs:comment 'Unit of measure for the limit of detection (e.g., µg/mL, ppm, percent).' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodValue rdf:type rdf:Property ;
    rdfs:label 'Lod Value' ;
    rdfs:comment 'Established limit of detection value for the method - the lowest amount of analyte that can be detected but not necessarily quantitated.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loqUnit rdf:type rdf:Property ;
    rdfs:label 'Loq Unit' ;
    rdfs:comment 'Unit of measure for the limit of quantitation (e.g., µg/mL, ppm, percent).' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loqValue rdf:type rdf:Property ;
    rdfs:label 'Loq Value' ;
    rdfs:comment 'Established limit of quantitation value for the method - the lowest amount of analyte that can be quantitatively determined with suitable precision and accuracy.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'Classification of the analytical method by its intended purpose (e.g., assay for potency, identification for substance confirmation, impurity for degradation products).' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallValidationConclusion rdf:type rdf:Property ;
    rdfs:label 'Overall Validation Conclusion' ;
    rdfs:comment 'Final conclusion of the method validation study. Validated indicates the method is fit for its intended purpose; not validated indicates it failed to meet acceptance criteria; conditionally validated indicates it passed with specific limitations or conditions.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionResult rdf:type rdf:Property ;
    rdfs:label 'Precision Result' ;
    rdfs:comment 'Outcome of the precision assessment. Pass indicates RSD values within predefined acceptance criteria for repeatability and intermediate precision.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatabilityRsdPercent rdf:type rdf:Property ;
    rdfs:label 'Repeatability Rsd Percent' ;
    rdfs:comment 'Relative standard deviation (RSD) from repeatability studies (intra-assay precision), typically expected to be ≤ 2% for assay methods.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:robustnessResult rdf:type rdf:Property ;
    rdfs:label 'Robustness Result' ;
    rdfs:comment 'Outcome of the robustness assessment. Pass indicates the method is robust to deliberate variations in parameters such as pH, temperature, flow rate, or mobile phase composition.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificityResult rdf:type rdf:Property ;
    rdfs:label 'Specificity Result' ;
    rdfs:comment 'Outcome of the specificity assessment. Pass indicates the method can unequivocally assess the analyte in the presence of impurities, degradation products, and matrix components.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technique rdf:type rdf:Property ;
    rdfs:label 'Technique' ;
    rdfs:comment 'Analytical technique or instrumentation used (e.g., HPLC, GC, UV-Vis Spectroscopy, FTIR, Mass Spectrometry, Titration, Dissolution Apparatus).' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Validation Protocol Number' ;
    rdfs:comment 'Unique protocol number assigned to the method validation study. Business identifier for the validation activity.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStartDate rdf:type rdf:Property ;
    rdfs:label 'Validation Start Date' ;
    rdfs:comment 'Date when the method validation activities commenced.' ;
    rdfs:domain ind:MethodValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Name of the Quality Assurance personnel who authorized and signed the CoA.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchLotNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Lot Number' ;
    rdfs:comment 'The batch or lot number of the drug substance, drug product, excipient, or raw material covered by this CoA.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version number of this CoA document, incremented when reissued or revised.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Flag' ;
    rdfs:comment 'Indicates whether the batch was manufactured under current Good Manufacturing Practice (cGMP) conditions.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when this CoA was officially issued and made available to the recipient.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Lims Reference Number' ;
    rdfs:comment 'Reference number or sample ID from the Laboratory Information Management System (LIMS) used for tracking test results.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Date when the batch was manufactured or compounded.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaReviewerName rdf:type rdf:Property ;
    rdfs:label 'Qa Reviewer Name' ;
    rdfs:comment 'Name of the Quality Assurance reviewer who performed the final review before CoA issuance.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Overall quality decision for the batch: released for use/distribution, rejected, pending further testing, conditional release, or quarantine.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional comments, notes, or special instructions related to this CoA, such as conditional release criteria or special handling requirements.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmInspectionLot rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Inspection Lot' ;
    rdfs:comment 'SAP QM inspection lot number associated with this CoA for integration with enterprise resource planning systems.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Test Completion Date' ;
    rdfs:comment 'Date when all quality control testing for this batch was completed.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Start Date' ;
    rdfs:comment 'Date when quality control testing for this batch commenced.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchDispositionId rdf:type rdf:Property ;
    rdfs:label 'Batch Disposition Id' ;
    rdfs:comment 'Primary key for batch_disposition' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeringSafetySignalId rdf:type rdf:Property ;
    rdfs:label 'Triggering Safety Signal Id' ;
    rdfs:comment 'Foreign key linking to pharmacovigilance.safety_signal. Business justification: Safety signals identifying a product risk can trigger quarantine or rejection of distributed batches before an ICSR is formally filed. QP batch release decisions must reference the safety signal that ' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetySignal .

ind:dispositionComments rdf:type rdf:Property ;
    rdfs:label 'Disposition Comments' ;
    rdfs:comment 'Additional comments, notes, or observations recorded by the quality unit or QP during the disposition review and approval process.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current workflow status of the disposition decision: pending review, approved by QP, rejected, on hold pending investigation closure, or completed.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'The precise date and time when the disposition decision was finalized and recorded in the QMS.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionType rdf:type rdf:Property ;
    rdfs:label 'Disposition Type' ;
    rdfs:comment 'The formal quality unit decision on the batch: release for distribution, reject and destroy, reprocess, rework, retest, or hold in quarantine pending further investigation.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketApplicability rdf:type rdf:Property ;
    rdfs:label 'Market Applicability' ;
    rdfs:comment 'Comma-separated list of markets or regulatory jurisdictions for which this batch is approved for distribution (e.g., USA, EU, JPN, ROW). Reflects market-specific release requirements.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openCapaCount rdf:type rdf:Property ;
    rdfs:label 'Open Capa Count' ;
    rdfs:comment 'Number of open CAPA records associated with this batch or its manufacturing process that may impact disposition decision.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Open Deviation Count' ;
    rdfs:comment 'Number of open quality deviations associated with this batch that must be resolved or justified prior to release per 21 CFR 211.192.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openOosCount rdf:type rdf:Property ;
    rdfs:label 'Open Oos Count' ;
    rdfs:comment 'Number of open Out of Specification (OOS) investigations linked to this batch that must be closed before disposition can be finalized.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qpApproverName rdf:type rdf:Property ;
    rdfs:label 'Qp Approver Name' ;
    rdfs:comment 'Full name of the Qualified Person or quality unit approver who signed off on the disposition decision.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Physical quarantine status of the batch: quarantined pending disposition, released from quarantine for distribution, or rejected and segregated for destruction.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether the batch is under regulatory hold pending resolution of compliance issues, regulatory inspection findings, or authority requests.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Explanation of the regulatory hold, including the authority imposing the hold, the compliance issue, and the resolution path.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'The quantity of the batch rejected and segregated for destruction or reprocessing due to non-conformance with specifications.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'The quantity of the batch approved for release and distribution, which may be less than the total batch size if partial rejection or rework occurred.' ;
    rdfs:domain ind:BatchDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complaintId rdf:type rdf:Property ;
    rdfs:label 'Complaint Id' ;
    rdfs:comment 'Primary key for complaint' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolDeviationId rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Id' ;
    rdfs:comment 'Foreign key linking to patient.protocol_deviation. Business justification: Product complaints from clinical trial sites (e.g., wrong product administered, packaging defect) may be directly associated with a protocol deviation. GCP requires traceability between product qualit' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProtocolDeviation .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Primary classification of the complaint type based on the nature of the issue reported.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the complaint as reported by the complainant, including symptoms, observations, and circumstances.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Business-facing unique complaint tracking number assigned by the Quality Management System (QMS). Format: CMP-YYYYNNNN.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSource rdf:type rdf:Property ;
    rdfs:label 'Complaint Source' ;
    rdfs:comment 'Origin of the complaint indicating who reported the product quality issue. HCP = Healthcare Professional.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current lifecycle status of the complaint investigation and resolution process.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of immediate and long-term corrective actions implemented to address the complaint and prevent recurrence.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskAssessment rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Assessment' ;
    rdfs:comment 'Preliminary risk classification assigned upon complaint receipt to prioritize investigation urgency and resource allocation.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationFindings rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings' ;
    rdfs:comment 'Summary of the investigation results, including laboratory testing, batch record review, and field investigation outcomes.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Impact Flag' ;
    rdfs:comment 'Indicates whether the complaint involves actual or potential patient harm, safety concern, or adverse event requiring pharmacovigilance assessment.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when the complaint was first received by the organization, triggering the complaint handling process.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Tracking number or case identifier assigned by the regulatory authority upon submission of the complaint report.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCommunication rdf:type rdf:Property ;
    rdfs:label 'Response Communication' ;
    rdfs:comment 'Summary of the response provided to the complainant, including explanation of findings and actions taken.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Date when the formal response was communicated to the complainant.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Detailed sub-classification providing additional granularity to the complaint category (e.g., foreign particulate matter, incorrect dosage form, damaged container).' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationSummary rdf:type rdf:Property ;
    rdfs:label 'Deviation Summary' ;
    rdfs:comment 'Summary description of any deviations encountered during validation execution, including their impact assessment and resolution.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationsObserved rdf:type rdf:Property ;
    rdfs:label 'Deviations Observed' ;
    rdfs:comment 'Count of deviations or non-conformances observed during validation execution that required documentation and investigation.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRevalidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Revalidation Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic revalidation activity. Calculated based on revalidation frequency and last validation completion date.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Outcome' ;
    rdfs:comment 'Final outcome determination of the validation: pass (all acceptance criteria met), fail (critical criteria not met), conditional_pass (passed with minor observations requiring follow-up), or incomplete (execution not finished).' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Protocol Approved By' ;
    rdfs:comment 'Name and title of the Quality Assurance representative who approved the validation protocol for execution.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolAuthor rdf:type rdf:Property ;
    rdfs:label 'Protocol Author' ;
    rdfs:comment 'Name of the individual who authored or prepared the validation protocol document.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolObjective rdf:type rdf:Property ;
    rdfs:label 'Protocol Objective' ;
    rdfs:comment 'Detailed objective and scope statement describing what the validation protocol intends to demonstrate or verify.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolTitle rdf:type rdf:Property ;
    rdfs:label 'Protocol Title' ;
    rdfs:comment 'Descriptive title of the validation protocol, summarizing the scope and objective of the validation activity.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicates whether this validation has regulatory reporting implications or is subject to regulatory inspection (True/False).' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revalidationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Revalidation Frequency Months' ;
    rdfs:comment 'Frequency in months at which revalidation must be performed (e.g., 12, 24, 36 months). Applicable when revalidation_required_flag is True.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revalidationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Revalidation Required Flag' ;
    rdfs:comment 'Indicates whether periodic revalidation is required for this validated system, process, or equipment (True/False).' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testRunsCompleted rdf:type rdf:Property ;
    rdfs:label 'Test Runs Completed' ;
    rdfs:comment 'Number of test runs or batches successfully completed during validation execution.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testRunsPlanned rdf:type rdf:Property ;
    rdfs:label 'Test Runs Planned' ;
    rdfs:comment 'Number of test runs or batches planned for execution as part of the validation protocol (e.g., 3 consecutive batches for process validation).' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testStepsFailed rdf:type rdf:Property ;
    rdfs:label 'Test Steps Failed' ;
    rdfs:comment 'Number of test steps that did not meet acceptance criteria and failed during validation execution.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testStepsPassed rdf:type rdf:Property ;
    rdfs:label 'Test Steps Passed' ;
    rdfs:comment 'Number of test steps that met acceptance criteria and passed during validation execution.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testStepsTotal rdf:type rdf:Property ;
    rdfs:label 'Test Steps Total' ;
    rdfs:comment 'Total number of individual test steps or test cases defined in the validation protocol.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationCategory rdf:type rdf:Property ;
    rdfs:label 'Validation Category' ;
    rdfs:comment 'High-level category of the validation activity: equipment, process, cleaning, computer system, analytical method, facility, or utility validation. [ENUM-REF-CANDIDATE: equipment|process|cleaning|computer_system|analytical_method|facility|utility — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededBySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Specification Id' ;
    rdfs:comment 'Reference to the newer specification version that supersedes this one. Null if this is the current effective version.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:acceptanceCriterion rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criterion' ;
    rdfs:comment 'The acceptance limit or range for the test parameter, expressed as numeric limits (e.g., \'95.0% - 105.0%\', \'NMT 0.5%\', \'pH 6.0 - 8.0\') or qualitative criteria (e.g., \'Conforms\', \'White to off-white powder\').' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cppLinkage rdf:type rdf:Property ;
    rdfs:label 'Cpp Linkage' ;
    rdfs:comment 'Reference to the Critical Process Parameters (CPPs) that impact this CQA, establishing the QbD design space linkage.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cqaFlag rdf:type rdf:Property ;
    rdfs:label 'Cqa Flag' ;
    rdfs:comment 'Indicates whether this test parameter is designated as a Critical Quality Attribute (CQA) under Quality by Design (QbD) principles. True if CQA, False otherwise.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Limit' ;
    rdfs:comment 'Numeric lower acceptance limit for quantitative test parameters. Null for qualitative tests or tests with only upper limits.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the quality assurance reviewer who reviewed this specification prior to approval.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Business identifier for the specification document, typically following organizational numbering conventions (e.g., SPEC-DS-001, SPEC-DP-045).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of the specification: draft (being authored), under_review (in approval workflow), approved (approved but not yet effective), effective (currently in use), superseded (replaced by newer version), obsolete (no longer valid), or withdrawn (removed from use). [ENUM-REF-CANDIDATE: draft|under_review|approved|effective|superseded|obsolete|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of the specification based on its intended use: release (batch release testing), shelf-life (end of shelf-life criteria), in-process (during manufacturing), stability (stability study acceptance), reference_standard (for reference materials), or raw_material (incoming material testing).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'The frequency at which this test must be performed (e.g., \'Every batch\', \'Annual\', \'Quarterly\', \'Skip lot (1 in 3)\', \'On change\').' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Limit' ;
    rdfs:comment 'Numeric upper acceptance limit for quantitative test parameters. Null for qualitative tests or tests with only lower limits.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Id' ;
    rdfs:comment 'Unique identifier for the supplier qualification record. Primary key for this entity.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Status' ;
    rdfs:comment 'Current status of the supplier qualification approval workflow. Draft indicates initial creation; pending review indicates awaiting Quality Assurance (QA) review; QA review indicates under active review; QA approved indicates final approval granted; rejected indicates qualification denied.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedMaterialScope rdf:type rdf:Property ;
    rdfs:label 'Approved Material Scope' ;
    rdfs:comment 'Detailed description of the materials, drug substances, drug products, or components that the supplier is qualified to provide. Includes specific material codes, grades, and specifications covered under this qualification.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedServiceScope rdf:type rdf:Property ;
    rdfs:label 'Approved Service Scope' ;
    rdfs:comment 'Detailed description of the services that the supplier is qualified to perform. Includes manufacturing operations, testing services, validation activities, clinical trial services, or other contracted services covered under this qualification.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Frequency in months at which the supplier site must be audited. Determined by risk tier and regulatory requirements. Critical suppliers may require annual audits; low-risk suppliers may be audited every 3-5 years.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaCountLast12Months rdf:type rdf:Property ;
    rdfs:label 'Capa Count Last 12 Months' ;
    rdfs:comment 'Number of Corrective and Preventive Action (CAPA) records initiated for the supplier in the last 12 months. Indicates frequency of quality issues requiring formal corrective action.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationCountLast12Months rdf:type rdf:Property ;
    rdfs:label 'Deviation Count Last 12 Months' ;
    rdfs:comment 'Number of quality deviations reported by or attributed to the supplier in the last 12 months. Used as a key performance indicator for supplier quality oversight.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpResponsibilityMatrix rdf:type rdf:Property ;
    rdfs:label 'Gmp Responsibility Matrix' ;
    rdfs:comment 'Detailed allocation of Good Manufacturing Practice (GMP) responsibilities between the pharmaceutical company and the supplier. Defines who is responsible for manufacturing, testing, release, stability, change control, deviation management, Corrective and Preventive Action (CAPA), and regulatory reporting.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent on-site or remote audit conducted at the supplier facility. Used to track audit schedule compliance and determine next audit due date.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAuditOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Audit Outcome' ;
    rdfs:comment 'Result of the most recent supplier audit. Approved indicates no significant findings; approved with observations indicates minor findings that do not impact qualification; conditional indicates findings requiring Corrective and Preventive Action (CAPA) before full approval; failed indicates critical findings resulting in disqualification.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRequalificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Requalification Due Date' ;
    rdfs:comment 'Scheduled date for the next supplier re-qualification activity. Calculated based on re-qualification frequency and last qualification date.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oosCountLast12Months rdf:type rdf:Property ;
    rdfs:label 'Oos Count Last 12 Months' ;
    rdfs:comment 'Number of Out of Specification (OOS) results reported for materials or services provided by the supplier in the last 12 months. Critical quality metric for supplier performance.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Quantitative performance rating of the supplier based on quality metrics including on-time delivery, Certificate of Analysis (CoA) accuracy, deviation rate, Out of Specification (OOS) incidents, and Corrective and Preventive Action (CAPA) closure timeliness. Typically scored on a scale of 0-100.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Effective Date' ;
    rdfs:comment 'Date on which the supplier qualification became effective and the supplier was approved for use under Good Manufacturing Practice (GMP) operations.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the supplier qualification record. Externally-known unique number assigned by the Quality Management System (QMS) for tracking and audit purposes.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAgreementType rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Type' ;
    rdfs:comment 'Classification of the quality agreement. Master indicates overarching agreement covering multiple products or services; product-specific indicates agreement for a single drug product or drug substance; service-specific indicates agreement for defined services; site-specific indicates agreement tied to a particular manufacturing or testing site.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Authority' ;
    rdfs:comment 'Name of the regulatory authority that conducted the most recent inspection. Examples include U.S. Food and Drug Administration (FDA), European Medicines Agency (EMA), Medicines and Healthcare products Regulatory Agency (MHRA), Pharmaceuticals and Medical Devices Agency (PMDA).' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Status' ;
    rdfs:comment 'Most recent regulatory inspection classification for the supplier facility. No Action Indicated (NAI) indicates no objectionable conditions; Voluntary Action Indicated (VAI) indicates objectionable conditions that do not meet threshold for regulatory action; Official Action Indicated (OAI) indicates objectionable conditions warranting regulatory action; not inspected indicates no recent regulatory inspection on record.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requalificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Requalification Frequency Months' ;
    rdfs:comment 'Frequency in months at which the supplier must be re-qualified. Typical values are 12, 24, or 36 months depending on supplier risk tier and regulatory requirements.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Risk classification of the supplier based on the criticality of materials or services provided, regulatory impact, and supplier performance history. Critical indicates highest risk requiring stringent oversight; high indicates significant risk; medium indicates moderate risk; low indicates minimal risk.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier based on the materials or services provided. Contract Manufacturing Organization (CMO) manufactures drug product; Contract Development and Manufacturing Organization (CDMO) provides development and manufacturing; Contract Research Organization (CRO) conducts research and clinical trials; Active Pharmaceutical Ingredient (API) supplier provides drug substance; excipient supplier provides inactive ingredients; packaging supplier provides primary or secondary packaging materials; equipment supplier provides manufacturing equipment; service provider offers validation, testing, or consulting services. [ENUM-REF-CANDIDATE: cmo|cdmo|cro|api_supplier|excipient_supplier|packaging_supplier|equipment_supplier|service_provider — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to masterdata.country. Business justification: legal_entity.jurisdiction_of_incorporation is a free-text STRING representing the country/jurisdiction where the entity is incorporated. The masterdata.country table is the authoritative reference for' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the parent legal entity in the organizational hierarchy. Null for top-level holding companies. Used to construct the legal entity hierarchy for consolidation and reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the ultimate parent legal entity at the top of the organizational hierarchy. Used for global consolidation and group-level reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:registeredAddressId rdf:type rdf:Property ;
    rdfs:label 'Registered Address Id' ;
    rdfs:comment 'Foreign key linking to masterdata.address. Business justification: legal_entity carries six inline registered address columns (registered_address_line1, registered_address_line2, registered_city, registered_state_province, registered_postal_code, registered_country) ' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'The consolidation group or reporting unit to which this legal entity belongs for financial consolidation purposes. Used to aggregate financial results across multiple legal entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStewardName rdf:type rdf:Property ;
    rdfs:label 'Data Steward Name' ;
    rdfs:comment 'The name of the individual or role responsible for maintaining the accuracy and completeness of this legal entity master data record. Part of the MDM governance framework.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the legal entity was officially dissolved or terminated. Null for active entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The 9-digit DUNS number assigned by Dun & Bradstreet for global business identification and credit reporting.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Ema Organization Code' ;
    rdfs:comment 'The organization identifier assigned by the European Medicines Agency for entities involved in pharmaceutical activities in the European Union. Used in regulatory submissions and correspondence.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'The current operational and legal status of the entity. Active entities are currently operating, inactive entities are dormant but legally registered, dissolved entities have been legally terminated, merged entities have been combined with another entity, acquired entities have been purchased by another organization, and pending formation entities are in the process of incorporation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'The month in which the legal entity\'s fiscal year ends, represented as an integer from 1 (January) to 12 (December). Used for financial reporting and tax purposes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'The primary currency in which the legal entity conducts its business and maintains its books of account, represented as a 3-letter ISO currency code.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was officially incorporated or registered in its jurisdiction.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'The standard industry classification code for the legal entity\'s primary business activity. May use NAICS, SIC, or ISIC classification systems.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Status' ;
    rdfs:comment 'The current ISO quality management system certifications held by this legal entity (e.g., ISO 9001, ISO 13485). Multiple certifications may be listed.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalForm rdf:type rdf:Property ;
    rdfs:label 'Legal Form' ;
    rdfs:comment 'The legal form or structure of the entity as defined by the jurisdiction of incorporation (e.g., Corporation, Limited Liability Company, Public Limited Company, Private Limited Company, Partnership). Uses ISO 20275 Entity Legal Forms codes where applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The official registered legal name of the entity as recorded in the jurisdiction of incorporation. This is the name that appears on all regulatory filings, contracts, and official documents.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'The 20-character ISO 17442 Legal Entity Identifier code used for global entity identification in financial transactions and regulatory reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBusinessActivity rdf:type rdf:Property ;
    rdfs:label 'Primary Business Activity' ;
    rdfs:comment 'Description of the primary business activity or operations conducted by this legal entity (e.g., pharmaceutical manufacturing, research and development, distribution, holding company).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'The currency used for external financial reporting and consolidation, represented as a 3-letter ISO currency code. May differ from functional currency for subsidiaries.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sap Company Code' ;
    rdfs:comment 'The 4-character SAP S/4HANA company code assigned to this legal entity. Company codes are the smallest organizational unit for which a complete self-contained set of accounts can be drawn up for external reporting purposes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or commonly used name for the legal entity used in internal systems and reporting.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchangeListing rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange Listing' ;
    rdfs:comment 'The stock exchange(s) on which the legal entity\'s securities are listed, if publicly traded. Uses ISO 10383 Market Identifier Codes (MIC) where applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker Symbol' ;
    rdfs:comment 'The ticker symbol or trading symbol for the legal entity\'s publicly traded securities, if applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'The VAT registration number assigned by the tax authority for entities registered for VAT purposes. Applicable primarily in jurisdictions with VAT systems.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the enterprise hierarchy. Enables hierarchical traversal and roll-up reporting across business units, divisions, departments, and teams. Null for top-level units.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the budget amount. Used for multi-currency reporting and financial consolidation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gcp Regulated Flag' ;
    rdfs:comment 'Indicates whether this organizational unit operates under GCP (Good Clinical Practice) regulations. True for clinical development, medical affairs, and pharmacovigilance units conducting or supporting clinical trials.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or market where this organizational unit operates (e.g., North America, Europe, Asia Pacific, Latin America). Used for regional performance analysis and market segmentation.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Glp Regulated Flag' ;
    rdfs:comment 'Indicates whether this organizational unit operates under GLP (Good Laboratory Practice) regulations. True for preclinical research and toxicology laboratories conducting non-clinical safety studies.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Regulated Flag' ;
    rdfs:comment 'Indicates whether this organizational unit operates under GMP (Good Manufacturing Practice) or cGMP (Current Good Manufacturing Practice) regulations. True for manufacturing, quality control, and quality assurance units handling drug substances or drug products.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headcountFte rdf:type rdf:Property ;
    rdfs:label 'Headcount Fte' ;
    rdfs:comment 'Total full-time equivalent employee count allocated to this organizational unit. Used for workforce planning, budget allocation, and productivity analysis. Includes full-time, part-time, and contractor resources normalized to FTE.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. Active units are operational and staffed. Inactive units are temporarily suspended. Pending units are approved but not yet operational. Dissolved units have been permanently closed.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qmsScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Qms Scope Flag' ;
    rdfs:comment 'Indicates whether this organizational unit is within the scope of the enterprise Quality Management System (QMS). True for units subject to ISO 9001 certification and quality audits.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapOrgUnitCode rdf:type rdf:Property ;
    rdfs:label 'Sap Org Unit Code' ;
    rdfs:comment 'Native SAP S/4HANA organizational unit identifier from the Organizational Management (OM) module. Used for bidirectional synchronization and cross-system reconciliation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLocation rdf:type rdf:Property ;
    rdfs:label 'Site Location' ;
    rdfs:comment 'Physical site or facility name where the organizational unit is primarily located. Used for facility management, space planning, and operational logistics.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Business-assigned unique code for the organizational unit. Used for cross-system integration and reporting. Typically aligned with SAP S/4HANA organizational element codes (cost center, profit center, business area).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitLevel rdf:type rdf:Property ;
    rdfs:label 'Unit Level' ;
    rdfs:comment 'Numeric level of the unit in the organizational hierarchy. Level 1 represents top-level enterprise units, with increasing numbers for deeper nesting. Supports hierarchy depth analysis and roll-up aggregation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full official name of the organizational unit as recognized in corporate documentation and reporting systems. Used for display in reports, dashboards, and organizational charts.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitShortName rdf:type rdf:Property ;
    rdfs:label 'Unit Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the organizational unit. Used in space-constrained displays and informal communication.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organizational unit by its role in the enterprise structure. Determines reporting hierarchy level and management accountability scope. [ENUM-REF-CANDIDATE: business_unit|division|department|function|team|cost_center|profit_center — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityTypeIndicator rdf:type rdf:Property ;
    rdfs:label 'Activity Type Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this cost center performs activity-based costing and maintains activity types for internal cost allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'The controlling area to which this cost center is assigned. Controlling area is the highest organizational unit in management accounting, representing a closed system for cost accounting purposes.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used for allocating costs from this cost center to other cost objects (e.g., direct allocation, activity-based costing, assessment, distribution). Supports COGS calculation and transfer pricing.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Classification of the cost center by functional area. Production includes manufacturing and API production; R&D includes drug discovery, preclinical, and clinical development; Quality Control includes QC labs and QA functions; Regulatory Affairs includes submission and compliance activities.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Extended textual description of the cost center\'s purpose, scope, and responsibilities within the organization.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full descriptive name of the cost center, providing human-readable identification for reporting and analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active cost centers accept postings; Inactive cost centers are closed; Blocked cost centers exist but cannot receive new postings; Planned cost centers are defined for future use.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Granular classification of the cost center type within its category, enabling detailed cost analysis and allocation logic.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area classification for cost-of-sales accounting and external financial reporting per IFRS/GAAP requirements. Typical values include manufacturing, R&D, sales, administration.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Standard hierarchy assignment for cost center grouping and roll-up reporting in management accounting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Indicates which types of postings are locked for this cost center. Unlocked allows all postings; Locked_actual prevents actual cost postings; Locked_plan prevents planning postings; Locked_all prevents all postings.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdmGoldenRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Mdm Golden Record Flag' ;
    rdfs:comment 'Indicates whether this record is the authoritative golden record in the MDM system, used for master data governance and data quality management.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Group' ;
    rdfs:comment 'Planning group assignment for cost center planning and budgeting cycles, enabling coordinated planning across related cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant Flag' ;
    rdfs:comment 'Indicates whether this cost center is subject to SOX financial controls and audit requirements, typically for cost centers involved in financial reporting processes.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statisticalCostCenterFlag rdf:type rdf:Property ;
    rdfs:label 'Statistical Cost Center Flag' ;
    rdfs:comment 'Indicates whether this is a statistical cost center used for informational purposes only, without actual cost postings.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this cost center master record is valid and can accept cost postings. Part of the time-dependent master data structure.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this cost center master record is valid. After this date, no new postings are allowed. Nullable for open-ended validity.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisPeriod rdf:type rdf:Property ;
    rdfs:label 'Analysis Period' ;
    rdfs:comment 'The fiscal period for which this profit center configuration is effective, in YYYYMM format. Supports period-specific profit center assignments and reorganizations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group' ;
    rdfs:comment 'The cost center group or range associated with this profit center. Links profit center to underlying cost centers for cost allocation and variance analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The department or organizational unit code associated with this profit center. Links profit center to the organizational hierarchy for reporting and governance.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dummyProfitCenterFlag rdf:type rdf:Property ;
    rdfs:label 'Dummy Profit Center Flag' ;
    rdfs:comment 'Indicates whether this is a dummy or placeholder profit center used for technical postings, system balancing, or temporary allocations. True if dummy, False if operational.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node' ;
    rdfs:comment 'The node identifier in the profit center standard hierarchy. Enables roll-up reporting and aggregation of P&L across organizational structures (e.g., by therapeutic area, geography, or product line).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'The product line or portfolio grouping associated with this profit center. May represent a brand family, drug class, or commercial franchise.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The business identifier code for the profit center as defined in SAP Controlling. Typically alphanumeric, 4-10 characters. Used across financial reporting, P&L statements, and management accounting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The full business name or description of the profit center. Human-readable label used in financial reports and management dashboards.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'The current lifecycle status of the profit center. Active profit centers are operational and accept postings. Planned profit centers are set up but not yet operational. Closed profit centers are historical and no longer accept postings.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'The classification type of the profit center indicating its primary business function. Operating profit centers generate revenue; support and corporate profit centers provide shared services.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'The segment classification for external segment reporting per IFRS 8 and US GAAP. Typically represents therapeutic area (oncology, immunology, rare diseases), product line, or geographic market.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortName rdf:type rdf:Property ;
    rdfs:label 'Account Short Name' ;
    rdfs:comment 'Abbreviated name or label for the GL account used in reports and user interfaces where space is limited.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'For balance sheet accounts, specifies whether the account is classified as current or non-current asset/liability, or equity. Not applicable for P&L accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaIntegration rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Integration' ;
    rdfs:comment 'Boolean flag indicating whether this account is integrated with the Controlling module for cost center, internal order, and profitability analysis postings.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'For accounts that are cost elements, specifies whether it is a primary cost element (posted from FI) or secondary cost element (used for internal allocations). Not applicable if cost_element_indicator is false.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Element Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this GL account is also defined as a cost element in Controlling (CO) module, enabling cost center and internal order postings.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Specifies which currency perspective this account primarily operates in: local currency, group currency, hard currency, index-based currency, or global company currency. Supports multi-currency pharmaceutical operations.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'Indicates which primary financial statement this account appears on: balance sheet (statement of financial position), profit and loss (income statement), cash flow statement, or statement of retained earnings.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsMappingCode rdf:type rdf:Property ;
    rdfs:label 'Ifrs Mapping Code' ;
    rdfs:comment 'The IFRS financial statement line item code that this account maps to for IFRS-compliant financial reporting. Enables parallel accounting and consolidated reporting under IFRS standards.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Boolean flag indicating whether individual line item details are stored and can be displayed for this account. Essential for accounts requiring detailed transaction audit trails.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneRevenueIndicator rdf:type rdf:Property ;
    rdfs:label 'Milestone Revenue Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this revenue account is used for milestone-based revenue recognition common in pharmaceutical licensing and collaboration agreements (e.g., regulatory approval milestones, sales milestones).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Boolean flag indicating whether this account uses open item management, requiring line items to be explicitly cleared (e.g., for receivables, payables, clearing accounts).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plClassification rdf:type rdf:Property ;
    rdfs:label 'Pl Classification' ;
    rdfs:comment 'For income statement accounts, specifies the detailed classification within the P&L structure (operating vs non-operating, revenue vs expense categories). Not applicable for balance sheet accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Posting Block Indicator' ;
    rdfs:comment 'Boolean flag indicating whether direct postings to this account are currently blocked. When true, the account can only receive postings through specific controlled processes.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterUpdateIndicator rdf:type rdf:Property ;
    rdfs:label 'Profit Center Update Indicator' ;
    rdfs:comment 'Boolean flag indicating whether postings to this account automatically update profit center accounting, enabling segment reporting and profitability analysis by therapeutic area or product line.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rdCapitalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Rd Capitalization Eligible' ;
    rdfs:comment 'Boolean flag indicating whether costs posted to this account are eligible for capitalization as intangible assets under development (e.g., post-IND development costs). Critical for pharmaceutical R&D accounting under IAS 38 and ASC 730.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this is a reconciliation account (subledger control account) that summarizes detailed transactions from subsidiary ledgers such as Accounts Receivable, Accounts Payable, or Asset Accounting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyAccrualIndicator rdf:type rdf:Property ;
    rdfs:label 'Royalty Accrual Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this account is used for royalty expense accruals or royalty revenue recognition, common in pharmaceutical licensing arrangements and patent agreements.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'The default sort key used for organizing and displaying line items within this account (e.g., by posting date, document number, reference). Improves usability for high-volume accounts.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The tax treatment category for this account, determining how transactions posted to this account are handled for tax reporting purposes (e.g., \'VAT_INPUT\', \'VAT_OUTPUT\', \'NON_TAXABLE\', \'EXEMPT\').' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usGaapMappingCode rdf:type rdf:Property ;
    rdfs:label 'Us Gaap Mapping Code' ;
    rdfs:comment 'The US GAAP financial statement line item code that this account maps to for US GAAP-compliant financial reporting. Supports dual reporting requirements for pharmaceutical companies with US operations.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagedIndicator rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Indicator' ;
    rdfs:comment 'Flag indicating whether the material requires batch-level tracking and management for traceability and quality control purposes.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the material including packaging, expressed in the weight unit of measure.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'Classification of hazardous materials per GHS (Globally Harmonized System) or DOT hazard classes for transportation and safety management.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Flag indicating whether the material is classified as hazardous per regulatory definitions, requiring special handling and documentation.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Lims Material Code' ;
    rdfs:comment 'Material identifier used in the LIMS system for laboratory testing, quality control, and certificate of analysis tracking.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Manufacturer\'s unique part number or catalog number for the material, used for procurement and supplier management.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Short textual description of the material for identification and display purposes.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Hierarchical grouping code for materials used for procurement, planning, and reporting purposes.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material indicating its availability for use in operations.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Mes Material Code' ;
    rdfs:comment 'Material identifier used in the MES system for production tracking, batch records, and manufacturing operations.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum number of days of remaining shelf life required at goods receipt or before use in production, ensuring adequate time for processing and distribution.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Weight of the material excluding packaging, expressed in the weight unit of measure.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Indicates how the material is obtained: externally purchased, internally manufactured, or both. Consignment indicates vendor-owned inventory.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Flag indicating whether incoming goods or production batches of this material require quality inspection before release for use.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Retest Interval Days' ;
    rdfs:comment 'Number of days after which stored material must be retested to confirm continued compliance with specifications, applicable to APIs and intermediates.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serialNumberProfile rdf:type rdf:Property ;
    rdfs:label 'Serial Number Profile' ;
    rdfs:comment 'Configuration profile defining serial number management requirements for the material, used for unit-level traceability.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureSensitiveIndicator rdf:type rdf:Property ;
    rdfs:label 'Temperature Sensitive Indicator' ;
    rdfs:comment 'Flag indicating whether the material requires temperature-controlled storage and transportation (cold chain management).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Physical volume of the material, used for storage and transportation planning.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for the volume field.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for gross and net weight fields.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Capacity Units' ;
    rdfs:comment 'Maximum annual production capacity of the plant expressed in standard units (e.g., kilograms of API, millions of dosage units), used for capacity planning and network design.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityClass rdf:type rdf:Property ;
    rdfs:label 'Capacity Class' ;
    rdfs:comment 'Classification of the plant\'s production or operational capacity relative to other facilities in the network, used for supply chain planning and network optimization.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaSiteNumber rdf:type rdf:Property ;
    rdfs:label 'Ema Site Number' ;
    rdfs:comment 'Unique site identifier assigned by the European Medicines Agency for manufacturing and testing facilities within the European Economic Area.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalPermitStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Status' ;
    rdfs:comment 'Current status of environmental operating permits required for pharmaceutical manufacturing operations at the plant facility.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Date' ;
    rdfs:comment 'Date when the plant received its current Good Manufacturing Practice certification from the relevant regulatory authority.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Expiry Date' ;
    rdfs:comment 'Date when the plant\'s current Good Manufacturing Practice certification expires and requires renewal or re-inspection.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection by FDA, EMA, or other competent authority at the plant facility.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the plant facility in decimal degrees, used for logistics planning and geographic analysis.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsSystem rdf:type rdf:Property ;
    rdfs:label 'Lims System' ;
    rdfs:comment 'Name and version of the Laboratory Information Management System used at the plant for sample tracking, testing, and Certificate of Analysis generation.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the plant facility in decimal degrees, used for logistics planning and geographic analysis.' ;
    rdfs:domain ind:Masterdata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingExecutionSystem rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Execution System' ;
    rdfs:comment 'Name and version of the Manufacturing Execution System used at the plant for batch execution, electronic batch records, and production tracking.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Anticipated or scheduled date for the next regulatory inspection based on inspection frequency requirements and risk classification.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'Business identifier code for the plant facility, typically used in SAP S/4HANA and other operational systems for cross-system reference.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Full business name of the plant facility as registered with regulatory authorities and used in official documentation.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantType rdf:type rdf:Property ;
    rdfs:label 'Plant Type' ;
    rdfs:comment 'Classification of the plant facility based on its primary operational function within the pharmaceutical enterprise.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityStorageUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Storage Units' ;
    rdfs:comment 'Maximum storage capacity of this location measured in storage units (pallets, bins, cubic meters, or location-specific unit). Used for warehouse space planning and inventory optimization.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deaLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Dea License Number' ;
    rdfs:comment 'DEA registration number for storage locations authorized to hold controlled substances (Schedule II-V). Format: 2 letters + 7 digits. Required for controlled substance accountability and regulatory inspections. Null for non-controlled substance storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deaScheduleAuthorized rdf:type rdf:Property ;
    rdfs:label 'Dea Schedule Authorized' ;
    rdfs:comment 'Highest DEA controlled substance schedule this storage location is authorized to hold. Schedule II requires vault-level security. Not applicable for non-controlled substance storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdp Compliant Flag' ;
    rdfs:comment 'Indicates whether this storage location meets GDP requirements for pharmaceutical distribution. True for qualified distribution centers with temperature mapping, security, and traceability controls. False for non-GDP locations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpZoneClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Zone Classification' ;
    rdfs:comment 'Cleanroom classification per EU GMP Annex 1 or ISO 14644. Grade A for aseptic processing, Grade D for general manufacturing. Unclassified for non-GMP warehouses. Drives gowning, environmental monitoring, and personnel flow requirements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatStorageClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Storage Class' ;
    rdfs:comment 'Classification of hazardous materials authorized for storage per OSHA and DOT regulations. Determines segregation requirements, fire suppression systems, and emergency response protocols. Non-hazardous for general storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Max Percent' ;
    rdfs:comment 'Maximum allowable relative humidity percentage for this storage location. Excursions may impact product stability and require OOT investigation. Null if humidity control is not required.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityMinPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Min Percent' ;
    rdfs:comment 'Minimum allowable relative humidity percentage for this storage location. Required for hygroscopic API and moisture-sensitive drug products. Null if humidity control is not required.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Date' ;
    rdfs:comment 'Date of the most recent qualification or requalification of this storage location per CSV and GMP requirements. Includes temperature mapping, humidity validation, and security system testing. Drives requalification scheduling.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Zone Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated as a quarantine zone for materials pending QC release, under investigation, or rejected. True for quarantine areas, false for released goods storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnsProcessingFlag rdf:type rdf:Property ;
    rdfs:label 'Returns Processing Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated for processing returned goods, including customer returns, expired products, and recalls. True for returns processing areas requiring segregation and disposition workflows.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingLocationFlag rdf:type rdf:Property ;
    rdfs:label 'Sampling Location Flag' ;
    rdfs:comment 'Indicates whether this storage location is designated for QC sampling activities. True for sampling areas where materials are temporarily held for sample collection per sampling plans.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Physical security classification for this storage location. High for DEA vaults and high-value products requiring 24/7 surveillance, access control, and intrusion detection. Medium for controlled access areas. Standard for general warehouses.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Segregation Required Flag' ;
    rdfs:comment 'Indicates whether materials in this storage location must be physically segregated from other materials due to cross-contamination risk, regulatory requirements, or product incompatibility. True for quarantine zones, controlled substances, and hazmat.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Business identifier for the storage location. Alphanumeric code used across SAP WM, LIMS, and MES systems for warehouse management and batch traceability. Typically 4-10 characters.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationName rdf:type rdf:Property ;
    rdfs:label 'Storage Location Name' ;
    rdfs:comment 'Human-readable name of the storage location. Examples: Cold Room 2-8C Building A, DEA Vault Schedule II, Quarantine Zone QC Lab 3, Hazmat Storage Flammables.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Storage Location Status' ;
    rdfs:comment 'Current operational status of the storage location. Blocked status prevents goods movements pending CAPA resolution or requalification. Under qualification indicates validation in progress per CSV requirements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Classification of the storage location by functional purpose. Determines applicable GMP, GDP, and DEA controls. Critical for regulatory inspection readiness and batch traceability. [ENUM-REF-CANDIDATE: warehouse|cold_room|freezer|controlled_substance_vault|quarantine_zone|qc_sampling_area|returns_processing|hazmat_storage|bulk_storage|finished_goods|raw_material|packaging_material|work_in_process — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowable temperature for this storage location in degrees Celsius. Excursions beyond this threshold trigger deviation investigations and potential batch impact assessments.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum allowable temperature for this storage location in degrees Celsius. Critical for cold-chain integrity and stability compliance. Examples: 2.0 for refrigerated, -25.0 for freezer, -85.0 for ultra-low freezer.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMonitoringSystem rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitoring System' ;
    rdfs:comment 'Type of temperature monitoring system deployed at this storage location. Continuous automated systems provide real-time alerts for excursions. Periodic manual monitoring uses data loggers with batch review. Not monitored for ambient storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Wms Integration Flag' ;
    rdfs:comment 'Indicates whether this storage location is integrated with a WMS for automated goods movements, bin management, and real-time inventory tracking. True for WMS-managed locations, false for manual locations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseUnitOfMeasureId rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure Id' ;
    rdfs:comment 'Self-referencing FK on unit_of_measure (base_unit_of_measure_id)' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitOfMeasure .

ind:applicableMaterialTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Material Types' ;
    rdfs:comment 'Comma-separated list of SAP material types or substance categories for which this UOM is applicable. Examples: API (Active Pharmaceutical Ingredient), DS (Drug Substance), DP (Drug Product), FDF (Finished Dosage Form), excipient, raw material, packaging material. Guides UOM selection during material master creation and transaction processing.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionGroup rdf:type rdf:Property ;
    rdfs:label 'Conversion Group' ;
    rdfs:comment 'Logical grouping of UOMs that can be converted among each other. UOMs within the same conversion group share a common dimension and can be mathematically converted (e.g., mass group: mg, g, kg; volume group: mL, L). Used to enforce conversion rules and prevent invalid cross-dimensional conversions.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decimalPrecision rdf:type rdf:Property ;
    rdfs:label 'Decimal Precision' ;
    rdfs:comment 'Number of decimal places typically used when recording measurements in this unit. Guides data entry validation and reporting formats. Example: 3 for milligrams (0.001), 6 for micrograms (0.000001), 0 for tablets (whole units).' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dimensionType rdf:type rdf:Property ;
    rdfs:label 'Dimension Type' ;
    rdfs:comment 'The fundamental physical dimension represented by this unit of measure per dimensional analysis. Aligns with SI base quantities and derived quantities. Used for dimensional consistency validation in formulation calculations and process parameter specifications. [ENUM-REF-CANDIDATE: length|mass|time|temperature|amount_of_substance|electric_current|luminous_intensity|area|volume|velocity|acceleration|force|pressure|energy|power|frequency|dimensionless — 17 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseUom rdf:type rdf:Property ;
    rdfs:label 'Is Base Uom' ;
    rdfs:comment 'Indicates whether this UOM is the base unit for its material or substance in SAP Material Master. Base UOMs serve as the reference for all alternative UOM conversions within a material. True if base UOM, False otherwise.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCommercialUom rdf:type rdf:Property ;
    rdfs:label 'Is Commercial Uom' ;
    rdfs:comment 'Indicates whether this UOM is used for commercial transactions, sales orders, and distribution (SAP SD module). Commercial UOMs may differ from manufacturing or laboratory UOMs. True if used in commercial contexts, False otherwise.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLaboratoryUom rdf:type rdf:Property ;
    rdfs:label 'Is Laboratory Uom' ;
    rdfs:comment 'Indicates whether this UOM is used in laboratory testing, quality control, and LIMS (Laboratory Information Management System). Laboratory UOMs support analytical testing, stability studies, and Certificate of Analysis (CoA) reporting. True if used in laboratory contexts, False otherwise.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManufacturingUom rdf:type rdf:Property ;
    rdfs:label 'Is Manufacturing Uom' ;
    rdfs:comment 'Indicates whether this UOM is used in manufacturing operations, batch production, and MES (Manufacturing Execution System). Manufacturing UOMs align with production planning (PP) and shop floor data collection. True if used in manufacturing, False otherwise.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoUnitCode rdf:type rdf:Property ;
    rdfs:label 'Iso Unit Code' ;
    rdfs:comment 'Standardized unit code per ISO 80000 and UN/CEFACT Recommendation 20. Enables interoperability across international regulatory submissions (eCTD) and supply chain systems. Examples: GRM (gram), KGM (kilogram), MLT (milliliter), LTR (liter).' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdmApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Mdm Approval Status' ;
    rdfs:comment 'Approval workflow status for this unit of measure within the MDM governance process. Draft records are under construction; pending_review records await data steward approval; approved records are released for operational use; rejected records require rework. Enforces data quality gates before UOM activation.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'Citation of the regulatory or pharmacopeial standard that defines or governs the use of this unit of measure. Examples: USP <1> Injections, Ph. Eur. 2.9.40 Uniformity of Dosage Units, FDA 21 CFR Part 210 Current Good Manufacturing Practice, ICH Q6A Specifications. Supports compliance traceability for regulatory submissions (IND, NDA, BLA, MAA).' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapInternalUom rdf:type rdf:Property ;
    rdfs:label 'Sap Internal Uom' ;
    rdfs:comment 'SAP S/4HANA internal unit of measure code used in Material Master (MM), Production Planning (PP), Quality Management (QM), and Warehouse Management (WM) modules. Maps external UOM codes to SAP-specific representations for ERP transaction processing.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Si Conversion Factor' ;
    rdfs:comment 'Numeric multiplier to convert this UOM to its SI base unit. Enables automated unit conversion across systems. Example: for milligram to kilogram, factor is 0.000001; for milliliter to liter, factor is 0.001. Null for dimensionless units.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasureStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure Status' ;
    rdfs:comment 'Current lifecycle status of the unit of measure in the master data repository. Active UOMs are available for use in transactions; inactive UOMs are retained for historical data but not selectable for new entries; deprecated UOMs are phased out per regulatory or business changes; pending_approval UOMs await MDM governance review before activation.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCategory rdf:type rdf:Property ;
    rdfs:label 'Uom Category' ;
    rdfs:comment 'Classification of the unit of measure by measurement type. Segments UOMs into functional categories for pharmaceutical operations: mass (mg, g, kg), volume (mL, L), concentration (mg/mL, %w/v), potency (IU, mcg), packaging (vial, ampoule, blister, tablet, capsule), analytical (ppm, ppb, CFU/mL), time (hour, day), temperature (Celsius, Fahrenheit), pressure (bar, psi), count (each, piece). [ENUM-REF-CANDIDATE: mass|volume|concentration|potency|packaging|analytical|time|temperature|pressure|count — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'Short alphanumeric code representing the unit of measure. Used as the business identifier across SAP S/4HANA, LIMS, and MES systems. Examples: MG, G, KG, ML, L, IU, MCG, PPM, PPB, CFU.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomDescription rdf:type rdf:Property ;
    rdfs:label 'Uom Description' ;
    rdfs:comment 'Full descriptive name of the unit of measure. Provides human-readable explanation of the UOM code. Examples: Milligram, Gram, Kilogram, Milliliter, Liter, International Unit, Microgram, Parts Per Million, Parts Per Billion, Colony Forming Unit per Milliliter.' ;
    rdfs:domain ind:UnitOfMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalTrialRegistrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Registration Required Flag' ;
    rdfs:comment 'Indicates whether the country mandates registration of clinical trials in a public registry (e.g., ClinicalTrials.gov, EU Clinical Trials Register, CTRI India) before trial initiation. True if registration required, False otherwise. Impacts CTMS workflows and regulatory compliance.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlledSubstanceScheduleSystem rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Schedule System' ;
    rdfs:comment 'Name of the controlled substance classification system used in the country (e.g., DEA Schedules I-V for USA, UK Misuse of Drugs Act Classes A/B/C, Japan Narcotics and Psychotropics Control Law). Determines manufacturing, storage, distribution, and prescribing requirements for controlled APIs and drug products. Impacts supply chain security and regulatory submissions.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Official English name of the country or territory as recognized by the United Nations and used in regulatory submissions, commercial documentation, and reporting (e.g., United States of America, United Kingdom, Japan, China, Germany).' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryStatus rdf:type rdf:Property ;
    rdfs:label 'Country Status' ;
    rdfs:comment 'Current operational status of the country for pharmaceutical business activities. Active: normal operations permitted. Inactive: no current operations or market presence. Restricted: limited operations due to regulatory or business constraints. Sanctioned: operations prohibited due to international sanctions or trade restrictions. Impacts supply chain routing, clinical trial site selection, and commercial activities.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyRegulation rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Regulation' ;
    rdfs:comment 'Name of the primary data privacy and protection regulation applicable in the country (e.g., GDPR for EU, HIPAA for USA, LGPD for Brazil, PDPA for Singapore). Governs handling of patient data in clinical trials, pharmacovigilance, and commercial activities. Critical for EDC system configuration, eTMF management, and data transfer agreements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionLicenseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Distribution License Required Flag' ;
    rdfs:comment 'Indicates whether a separate wholesale distribution license or GDP certification is required to distribute pharmaceutical products within the country. True if distribution license required, False otherwise. Impacts supply chain partner qualification and logistics planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ichRegionFlag rdf:type rdf:Property ;
    rdfs:label 'Ich Region Flag' ;
    rdfs:comment 'Indicates whether the country is a member of an ICH region (USA, EU, Japan, Canada, Switzerland). ICH membership determines applicability of harmonized technical requirements for pharmaceutical registration (CTD/eCTD format, stability testing, quality guidelines). True if ICH member, False otherwise.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ichRegionName rdf:type rdf:Property ;
    rdfs:label 'Ich Region Name' ;
    rdfs:comment 'Name of the ICH region to which the country belongs, if applicable. Used to determine which ICH guidelines and harmonized standards apply to regulatory submissions and CMC documentation.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha2Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 2 Code' ;
    rdfs:comment 'Two-letter country code as defined by ISO 3166-1 alpha-2 standard. Used for regulatory submissions, labeling, and system integrations (e.g., US, GB, JP, CN, DE).' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha3Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 3 Code' ;
    rdfs:comment 'Three-letter country code as defined by ISO 3166-1 alpha-3 standard. Used in eCTD submissions, regulatory documents, and SAP S/4HANA master data (e.g., USA, GBR, JPN, CHN, DEU).' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoNumericCode rdf:type rdf:Property ;
    rdfs:label 'Iso Numeric Code' ;
    rdfs:comment 'Three-digit numeric country code as defined by ISO 3166-1 numeric standard. Used in systems requiring numeric-only identifiers (e.g., 840 for USA, 826 for GBR, 392 for JPN).' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketAccessTier rdf:type rdf:Property ;
    rdfs:label 'Market Access Tier' ;
    rdfs:comment 'Commercial prioritization tier for market access and launch planning. Tier 1: high-value markets with established reimbursement frameworks and large patient populations (e.g., USA, Germany, Japan). Tier 2: significant markets with moderate access complexity. Tier 3: smaller markets or those with challenging reimbursement. Emerging: developing markets with growth potential. Drives commercial strategy, HEOR investment, and launch sequencing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentFilingAuthority rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Authority' ;
    rdfs:comment 'Name of the national intellectual property office responsible for patent applications and grants (e.g., USPTO, EPO, JPO, CNIPA, UKIPO). Used for tracking patent filings, patent term extensions, and exclusivity periods for NCEs and NBEs.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmaceuticalMarketClassification rdf:type rdf:Property ;
    rdfs:label 'Pharmaceutical Market Classification' ;
    rdfs:comment 'Classification of the country\'s pharmaceutical regulatory maturity and market structure. Regulated markets have stringent GMP, GCP, and pharmacovigilance requirements (e.g., USA, EU, Japan). Semi-Regulated markets have evolving frameworks. Emerging markets have developing regulatory infrastructure. Unregulated markets have minimal oversight. Drives market access strategy, clinical trial site selection, and supply chain compliance requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacovigilanceRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Pharmacovigilance Requirement Level' ;
    rdfs:comment 'Classification of the country\'s pharmacovigilance and adverse event reporting requirements. Stringent: mandatory ICSR reporting, SUSAR expedited reporting, periodic safety update reports (e.g., USA, EU, Japan). Moderate: ICSR reporting required with longer timelines. Basic: minimal AE reporting. None: no formal PV requirements. Drives Argus Safety configuration and safety reporting workflows.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:picsMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Pics Member Flag' ;
    rdfs:comment 'Indicates whether the country\'s regulatory authority is a member of PIC/S, enabling mutual recognition of GMP inspections and reducing duplicate inspections for manufacturing sites. True if PIC/S member, False otherwise.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for the country\'s primary official language (e.g., en, ja, zh, de, fr). Used for labeling requirements, patient information leaflets, regulatory submission language, and Veeva PromoMats localization.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the primary national regulatory authority responsible for pharmaceutical product approvals, post-market surveillance, and GMP inspections (e.g., FDA, EMA, MHRA, PMDA, NMPA, Health Canada, TGA, Anvisa). Critical for routing regulatory submissions and managing compliance obligations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementFrameworkType rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Framework Type' ;
    rdfs:comment 'Description of the country\'s pharmaceutical reimbursement and pricing framework (e.g., government-negotiated pricing, health technology assessment (HTA) required, free pricing, reference pricing, value-based agreements). Impacts pricing strategy, market access timelines, and HEOR evidence requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Serialization Requirement Flag' ;
    rdfs:comment 'Indicates whether the country mandates unique serialization and track-and-trace for pharmaceutical products to prevent counterfeiting (e.g., EU FMD, US DSCSA, China NMPA serialization, South Korea PMDA serialization). True if serialization required, False otherwise. Drives packaging line configuration and supply chain system requirements.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subRegion rdf:type rdf:Property ;
    rdfs:label 'Sub Region' ;
    rdfs:comment 'Sub-region classification within the broader region (e.g., Northern America, Western Europe, Eastern Asia, South-Eastern Asia, Southern Asia). Used for granular market segmentation and supply chain optimization.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAtcClassificationId rdf:type rdf:Property ;
    rdfs:label 'Parent Atc Classification Id' ;
    rdfs:comment 'Self-referencing FK on atc_classification (parent_atc_classification_id)' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtcClassification .

ind:administrationRoute rdf:type rdf:Property ;
    rdfs:label 'Administration Route' ;
    rdfs:comment 'The route by which the drug is administered: O=Oral, P=Parenteral, R=Rectal, V=Vaginal, N=Nasal, Implant=Implant, Inhal=Inhalation, Instill=Instillation, SL=Sublingual/Buccal, TD=Transdermal. Critical for DDD assignment and clinical use. [ENUM-REF-CANDIDATE: O|P|R|V|N|Implant|Inhal|Instill|SL|TD — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel rdf:type rdf:Property ;
    rdfs:label 'Atc Level' ;
    rdfs:comment 'The hierarchical level of the ATC code: 1=Anatomical main group (1 character), 2=Therapeutic subgroup (3 characters), 3=Pharmacological subgroup (4 characters), 4=Chemical subgroup (5 characters), 5=Chemical substance (7 characters).' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atcLevel1Code rdf:type rdf:Property ;
    rdfs:label 'Atc Level 1 Code' ;
    rdfs:comment 'First level anatomical main group code (single letter A-V) representing the organ or system on which the drug acts.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel1Description rdf:type rdf:Property ;
    rdfs:label 'Atc Level 1 Description' ;
    rdfs:comment 'Full description of the anatomical main group (e.g., \'Alimentary tract and metabolism\', \'Blood and blood forming organs\', \'Cardiovascular system\').' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel2Code rdf:type rdf:Property ;
    rdfs:label 'Atc Level 2 Code' ;
    rdfs:comment 'Second level therapeutic subgroup code (3 characters) representing the therapeutic main group.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel2Description rdf:type rdf:Property ;
    rdfs:label 'Atc Level 2 Description' ;
    rdfs:comment 'Full description of the therapeutic subgroup (e.g., \'Drugs used in diabetes\', \'Antithrombotic agents\').' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel3Code rdf:type rdf:Property ;
    rdfs:label 'Atc Level 3 Code' ;
    rdfs:comment 'Third level pharmacological subgroup code (4 characters) representing the pharmacological or therapeutic subgroup.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel3Description rdf:type rdf:Property ;
    rdfs:label 'Atc Level 3 Description' ;
    rdfs:comment 'Full description of the pharmacological subgroup (e.g., \'Blood glucose lowering drugs, excl. insulins\', \'Platelet aggregation inhibitors excl. heparin\').' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel4Code rdf:type rdf:Property ;
    rdfs:label 'Atc Level 4 Code' ;
    rdfs:comment 'Fourth level chemical subgroup code (5 characters) representing the chemical or therapeutic subgroup.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel4Description rdf:type rdf:Property ;
    rdfs:label 'Atc Level 4 Description' ;
    rdfs:comment 'Full description of the chemical subgroup (e.g., \'Biguanides\', \'Adenosine diphosphate (ADP) receptor inhibitors\').' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel5Code rdf:type rdf:Property ;
    rdfs:label 'Atc Level 5 Code' ;
    rdfs:comment 'Fifth level chemical substance code (7 characters) representing the specific chemical substance or combination.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcLevel5Description rdf:type rdf:Property ;
    rdfs:label 'Atc Level 5 Description' ;
    rdfs:comment 'Full description of the chemical substance, typically the INN (International Nonproprietary Name) or combination name (e.g., \'metformin\', \'clopidogrel\').' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcNote rdf:type rdf:Property ;
    rdfs:label 'Atc Note' ;
    rdfs:comment 'Additional notes, clarifications, or special instructions related to the ATC classification, including usage restrictions, combination product details, or cross-references to related codes.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcStatus rdf:type rdf:Property ;
    rdfs:label 'Atc Status' ;
    rdfs:comment 'Current lifecycle status of the ATC code: active=currently in use, inactive=temporarily suspended, withdrawn=permanently removed from WHO ATC index, pending=under review for inclusion, deprecated=superseded by another code.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biosimilarReferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Biosimilar Reference Flag' ;
    rdfs:comment 'Indicates whether this biological substance serves as a reference product for biosimilar development and approval (True) or not (False). Relevant for biologics license applications.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:combinationProductFlag rdf:type rdf:Property ;
    rdfs:label 'Combination Product Flag' ;
    rdfs:comment 'Indicates whether this ATC code represents a fixed-dose combination product containing two or more active pharmaceutical ingredients (True) or a single active substance (False).' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dddValue rdf:type rdf:Property ;
    rdfs:label 'Ddd Value' ;
    rdfs:comment 'The assumed average maintenance dose per day for a drug used for its main indication in adults, expressed as a numeric value. Used for drug utilization studies and pharmacoeconomic analysis.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:therapeuticEquivalenceGroup rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Equivalence Group' ;
    rdfs:comment 'Grouping code for substances considered therapeutically equivalent or interchangeable for the same indication, used in formulary management and substitution policies.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whoPublicationYear rdf:type rdf:Property ;
    rdfs:label 'Who Publication Year' ;
    rdfs:comment 'The year this ATC code was officially published or last updated by the WHO Collaborating Centre for Drug Statistics Methodology.' ;
    rdfs:domain ind:AtcClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strengthUnitOfMeasureId rdf:type rdf:Property ;
    rdfs:label 'Strength Unit Of Measure Id' ;
    rdfs:comment 'Foreign key linking to masterdata.unit_of_measure. Business justification: NDC codes have a \'strength\' STRING attribute (e.g., \'500mg\', \'10mg/mL\') that combines a numeric value and a unit of measure. Best practice is to split this into strength_value (DECIMAL) and strength_u' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitOfMeasure .

ind:activeIngredientCount rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Count' ;
    rdfs:comment 'The number of distinct active pharmaceutical ingredients (APIs) in the drug product. Most products have 1; combination products have 2 or more.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biosimilarFlag rdf:type rdf:Property ;
    rdfs:label 'Biosimilar Flag' ;
    rdfs:comment 'Indicates whether the biological product is a biosimilar (highly similar to an FDA-approved reference biological product). True if biosimilar, False otherwise.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endMarketingDate rdf:type rdf:Property ;
    rdfs:label 'End Marketing Date' ;
    rdfs:comment 'The date on which the drug product was discontinued from commercial marketing in the United States. Null if the product is still actively marketed.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interchangeableBiosimilarFlag rdf:type rdf:Property ;
    rdfs:label 'Interchangeable Biosimilar Flag' ;
    rdfs:comment 'Indicates whether the biosimilar product has been designated by the FDA as interchangeable with the reference biological product, allowing pharmacy-level substitution. True if interchangeable, False otherwise.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelerName rdf:type rdf:Property ;
    rdfs:label 'Labeler Name' ;
    rdfs:comment 'The legal name of the company responsible for labeling and marketing the drug product (manufacturer, repackager, or distributor).' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingStatus rdf:type rdf:Property ;
    rdfs:label 'Marketing Status' ;
    rdfs:comment 'The current marketing and distribution status of the drug product in the United States. Indicates whether the product is actively marketed as prescription, over-the-counter, or has been discontinued.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'A textual description of the package configuration, including quantity, container type, and packaging hierarchy (e.g., \'100 TABLET in 1 BOTTLE\', \'10 BLISTER PACK in 1 CARTON\').' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmClass rdf:type rdf:Property ;
    rdfs:label 'Pharm Class' ;
    rdfs:comment 'The pharmacologic class or mechanism of action (MOA) of the active ingredient, describing how the drug works at the molecular or physiological level.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repackagerFlag rdf:type rdf:Property ;
    rdfs:label 'Repackager Flag' ;
    rdfs:comment 'Indicates whether the labeler is a repackager (repackages bulk drug product into smaller units) rather than the original manufacturer. True if repackager, False if original manufacturer or distributor.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startMarketingDate rdf:type rdf:Property ;
    rdfs:label 'Start Marketing Date' ;
    rdfs:comment 'The date on which the drug product was first commercially marketed in the United States under this NDC.' ;
    rdfs:domain ind:MasterdataNdcCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeMoietyInn rdf:type rdf:Property ;
    rdfs:label 'Active Moiety Inn' ;
    rdfs:comment 'The INN of the active moiety (the molecule or ion responsible for physiological or pharmacological action) when the registered substance is a salt, ester, or other derivative. For example, imatinib mesylate (salt) has imatinib as the active moiety.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biosimilarReferenceInn rdf:type rdf:Property ;
    rdfs:label 'Biosimilar Reference Inn' ;
    rdfs:comment 'For biosimilar substances, the INN of the reference biologic product to which this biosimilar is compared. Null for non-biosimilar substances or originator biologics.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakthroughTherapyDesignationFlag rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy Designation Flag' ;
    rdfs:comment 'Boolean indicator of whether the substance has received breakthrough therapy designation from the FDA, indicating preliminary clinical evidence of substantial improvement over existing therapies for serious conditions.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:innDefinition rdf:type rdf:Property ;
    rdfs:label 'Inn Definition' ;
    rdfs:comment 'The official WHO definition or description of the substance associated with the INN, including its chemical nature, biological origin, or therapeutic purpose. Provides context for the INN assignment.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innLanguageVariants rdf:type rdf:Property ;
    rdfs:label 'Inn Language Variants' ;
    rdfs:comment 'Alternative language-specific spellings or transliterations of the INN (e.g., Latin, French, Spanish, Russian, Arabic, Chinese). Stored as a delimited list or JSON structure to support multilingual regulatory submissions and labeling.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innStatus rdf:type rdf:Property ;
    rdfs:label 'Inn Status' ;
    rdfs:comment 'Current status of the INN designation in the WHO publication lifecycle. Proposed indicates initial submission; Recommended indicates WHO expert committee approval; Published indicates final inclusion in WHO INN list; Withdrawn indicates retraction.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innStem rdf:type rdf:Property ;
    rdfs:label 'Inn Stem' ;
    rdfs:comment 'The suffix or stem used in the INN name that indicates the pharmacological or chemical class (e.g., -mab for monoclonal antibodies, -tinib for tyrosine kinase inhibitors, -pril for ACE inhibitors). INN stems provide systematic nomenclature consistency.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacologicalClass rdf:type rdf:Property ;
    rdfs:label 'Pharmacological Class' ;
    rdfs:comment 'The therapeutic or pharmacological classification of the substance based on its mechanism of action or therapeutic use (e.g., kinase inhibitor, monoclonal antibody, beta-lactam antibiotic, ACE inhibitor). Provides insight into the drug\'s mode of action and therapeutic category.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceClass rdf:type rdf:Property ;
    rdfs:label 'Substance Class' ;
    rdfs:comment 'High-level classification of the pharmaceutical substance type. Small molecule refers to chemically synthesized drugs; Biologic refers to protein-based therapeutics; Vaccine refers to immunization products; Gene therapy and Cell therapy refer to advanced therapeutic modalities; Oligonucleotide refers to nucleic acid-based drugs.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whoInnListNumber rdf:type rdf:Property ;
    rdfs:label 'Who Inn List Number' ;
    rdfs:comment 'The sequential WHO INN list number in which the substance was published. WHO publishes INN lists periodically; this number references the specific publication edition.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:whoPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Who Publication Date' ;
    rdfs:comment 'The date on which the INN was officially published by the WHO in the INN list. Represents the formal recognition date of the nonproprietary name.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:whoPublicationReference rdf:type rdf:Property ;
    rdfs:label 'Who Publication Reference' ;
    rdfs:comment 'The full citation or reference to the WHO document or publication in which the INN was announced. Typically includes WHO Drug Information volume and issue number.' ;
    rdfs:domain ind:InnRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are currently in use, inactive addresses are no longer valid but retained for historical reference, pending addresses are awaiting approval or validation, and archived addresses are historical records retained for compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose within pharmaceutical operations. Registered addresses are used for regulatory filings and legal documentation, operational addresses represent active business locations, shipping addresses are used for logistics and distribution, billing addresses are used for invoicing, clinical site addresses represent trial locations, and manufacturing addresses represent production facilities.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality name where the address is located. Used for geographic segmentation, logistics planning, and regulatory reporting by jurisdiction.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified Flag' ;
    rdfs:comment 'Boolean indicator identifying whether the address location holds current Good Manufacturing Practice (cGMP) certification. True indicates the site is certified for pharmaceutical manufacturing under FDA, EMA, or other regulatory authority standards.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line containing street number, street name, and building identifier. This is the main address component used for physical location identification and postal delivery.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as suite number, floor, building name, department, or unit identifier. Optional field used when address_line_1 is insufficient for precise location identification.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line for complex addresses requiring additional location context such as industrial park name, campus identifier, or district information. Rarely used but necessary for large pharmaceutical manufacturing complexes or research campuses.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for mail delivery and geographic precision. Format varies by country (e.g., 5-digit ZIP in USA, alphanumeric in Canada and UK). Used for logistics optimization, territory assignment, and distribution planning.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Address Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this is the primary or default address for the associated entity (vendor, customer, plant, site). True indicates this is the main address used for official correspondence and regulatory filings.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySiteIdentifier rdf:type rdf:Property ;
    rdfs:label 'Regulatory Site Identifier' ;
    rdfs:comment 'Official site registration number or establishment identifier assigned by regulatory authorities such as FDA Establishment Identifier (FEI), EMA site number, or PMDA registration number. Required for regulatory submissions and inspection tracking.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapAddressNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Address Number' ;
    rdfs:comment 'SAP S/4HANA system address number linking this master data address to the corresponding address record in SAP modules (MM, SD, FI). Enables cross-system reconciliation and ensures consistency between lakehouse and operational ERP system.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizationDate rdf:type rdf:Property ;
    rdfs:label 'Standardization Date' ;
    rdfs:comment 'Date when the address was last validated or standardized against postal authority databases. Used to determine when re-validation is required, as addresses may become outdated due to postal code changes or street renaming.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardizationSource rdf:type rdf:Property ;
    rdfs:label 'Standardization Source' ;
    rdfs:comment 'The authoritative postal service or third-party vendor used to validate and standardize the address format. Identifies which national postal authority or address verification service confirmed the address accuracy. [ENUM-REF-CANDIDATE: USPS|Royal_Mail|Deutsche_Post|Canada_Post|Australia_Post|manual|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avlFlag rdf:type rdf:Property ;
    rdfs:label 'Avl Flag' ;
    rdfs:comment 'Boolean indicator whether this business partner is on the Approved Vendor List. True indicates the partner is approved for procurement and manufacturing activities.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number for payment processing. Encrypted at rest and in transit per PCI DSS and SOX requirements.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingIndicator rdf:type rdf:Property ;
    rdfs:label 'Blocking Indicator' ;
    rdfs:comment 'Indicates whether the business partner is blocked for specific business functions (sales, purchasing, payment) due to compliance, quality, or financial issues.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bpCategory rdf:type rdf:Property ;
    rdfs:label 'Bp Category' ;
    rdfs:comment 'Classification of the business partner entity type: person (individual), organization (company/institution), or group (corporate group).' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bpNumber rdf:type rdf:Property ;
    rdfs:label 'Bp Number' ;
    rdfs:comment 'The externally-known unique business partner number assigned by SAP S/4HANA. This is the authoritative business identifier used across all systems for external party identity.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bpRole rdf:type rdf:Property ;
    rdfs:label 'Bp Role' ;
    rdfs:comment 'Comma-separated list of roles assigned to this business partner. Roles include: supplier, customer, carrier, CMO (Contract Manufacturing Organization), CRO (Contract Research Organization), CDMO (Contract Development and Manufacturing Organization), distributor, wholesaler, hospital, pharmacy, GPO (Group Purchasing Organization), government agency. A single BP may hold multiple roles.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPartnerStatus rdf:type rdf:Property ;
    rdfs:label 'Business Partner Status' ;
    rdfs:comment 'Current lifecycle status of the business partner record. Active indicates the partner is approved for transactions; inactive/suspended/terminated indicate various states of non-availability.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the credit limit amount.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment '13-digit GS1 Global Location Number uniquely identifying the business partners physical, functional, or legal entity location. Used in supply chain and EDI transactions.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number for SEPA and international wire transfers. Used for business partners in IBAN-participating countries.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsSupplierCode rdf:type rdf:Property ;
    rdfs:label 'Lims Supplier Code' ;
    rdfs:comment 'Cross-system identifier linking this business partner to the supplier master in LIMS for reagent, reference standard, and consumable procurement tracking.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Risk classification assigned to the business partner based on criticality of supplied materials, quality history, regulatory compliance, and business continuity factors.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'SWIFT/BIC code identifying the business partners bank for international payments and wire transfers.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaAccountCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Account Code' ;
    rdfs:comment 'Cross-system identifier linking this business partner to the corresponding account record in Veeva CRM for commercial and medical affairs integration.' ;
    rdfs:domain ind:BusinessPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the patient\'s residential address. Used for patient contact, investigational product shipment, and patient support services. Protected health information (PHI).' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the patient\'s residential address (apartment, suite, unit number). Optional field for complete address capture.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsSubjectNumber rdf:type rdf:Property ;
    rdfs:label 'Ctms Subject Number' ;
    rdfs:comment 'Subject identifier assigned by the Clinical Trial Management System (Oracle Clinical or Siebel CTMS). Used to link patient records to clinical trial enrollment and visit data.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassificationLevel rdf:type rdf:Property ;
    rdfs:label 'Data Classification Level' ;
    rdfs:comment 'Classification level of the patient record based on sensitivity and regulatory requirements. Determines access controls and handling procedures.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent Flag' ;
    rdfs:comment 'Indicates whether the patient has provided consent for data processing and sharing under GDPR and HIPAA regulations. True if consent obtained, false otherwise.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edcSubjectNumber rdf:type rdf:Property ;
    rdfs:label 'Edc Subject Number' ;
    rdfs:comment 'Patient identifier in the Electronic Data Capture system (Medidata Rave). Links patient to case report forms (CRFs) and clinical trial data collection.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehrMrn rdf:type rdf:Property ;
    rdfs:label 'Ehr Mrn' ;
    rdfs:comment 'Medical record number from external electronic health record systems. Used for real-world data (RWD) integration and health economics outcomes research (HEOR).' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethnicity rdf:type rdf:Property ;
    rdfs:label 'Ethnicity' ;
    rdfs:comment 'Self-reported ethnicity of the patient. Required for clinical trial diversity reporting and subgroup analysis per FDA and EMA guidelines.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'Self-identified gender of the patient. Captured separately from biological sex to support inclusive clinical research and patient-centered care.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpid rdf:type rdf:Property ;
    rdfs:label 'Gpid' ;
    rdfs:comment 'Global patient identifier used across all systems and geographies to uniquely identify a patient. Pseudonymized token for cross-system linkage while maintaining HIPAA and GDPR compliance.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Status' ;
    rdfs:comment 'Status of informed consent for clinical trial participation or data usage. Critical for GCP compliance and patient rights protection.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpiToken rdf:type rdf:Property ;
    rdfs:label 'Mpi Token' ;
    rdfs:comment 'Master patient index linkage token used to resolve patient identity across disparate source systems. Enables patient matching and deduplication while preserving privacy.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'Nationality of the patient represented as ISO 3166-1 alpha-3 country code. Used for regulatory reporting and cross-border clinical trial management.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientStatus rdf:type rdf:Property ;
    rdfs:label 'Patient Status' ;
    rdfs:comment 'Current lifecycle status of the patient in clinical trials or patient support programs. Tracks patient engagement and follow-up requirements.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'Primary language spoken by the patient. Used for informed consent delivery, patient communication, and patient-reported outcomes (PRO) instrument selection.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pseudonymizationToken rdf:type rdf:Property ;
    rdfs:label 'Pseudonymization Token' ;
    rdfs:comment 'Pseudonymized identifier used to protect patient identity in research datasets and analytics. Enables HIPAA and GDPR compliant data sharing while maintaining linkability.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvCasePatientReference rdf:type rdf:Property ;
    rdfs:label 'Pv Case Patient Reference' ;
    rdfs:comment 'Patient identifier in the pharmacovigilance safety reporting system (Argus Safety or Oracle AERS). Links patient to adverse event reports and ICSRs.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:race rdf:type rdf:Property ;
    rdfs:label 'Race' ;
    rdfs:comment 'Self-reported race of the patient. Required for clinical trial diversity reporting and subgroup safety and efficacy analysis per FDA and EMA guidelines.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sex rdf:type rdf:Property ;
    rdfs:label 'Sex' ;
    rdfs:comment 'Biological sex assigned at birth. Used for clinical trial eligibility, safety analysis, and pharmacokinetic (PK) / pharmacodynamic (PD) assessments.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyPharmacyCode rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Code' ;
    rdfs:comment 'Patient identifier in specialty pharmacy and patient support program systems. Used for copay assistance, adherence monitoring, and patient services.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryId rdf:type rdf:Property ;
    rdfs:label 'Registry Id' ;
    rdfs:comment 'Foreign key linking to patient.registry. Business justification: Patient enrollments can be for clinical trials OR patient registries. The existing trial_id FK handles clinical trial enrollments, but registry enrollments need a separate FK to link to the registry m' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:supportProgramId rdf:type rdf:Property ;
    rdfs:label 'Support Program Id' ;
    rdfs:comment 'Foreign key linking to the patient support program in which the patient is enrolled' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupportProgram .

ind:benefitAmountReceived rdf:type rdf:Property ;
    rdfs:label 'Benefit Amount Received' ;
    rdfs:comment 'Cumulative financial assistance amount (in USD) that this specific patient has received through this specific program enrollment. Tracked for benefit cap enforcement, Sunshine Act reporting, and program ROI analysis.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cohortIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cohort Identifier' ;
    rdfs:comment 'Identifier for the enrollment cohort or wave. Used in dose-escalation studies, adaptive trials, or phased enrollment programs to track enrollment groups.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentToProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Consent To Program Flag' ;
    rdfs:comment 'Indicates whether the patient has provided informed consent specific to this program\'s data collection, communication, and benefit processing. Separate from general clinical trial consent. Required for HIPAA compliance and program operations.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disenrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Date' ;
    rdfs:comment 'Date when the patient was disenrolled from this support program. Null for active enrollments. Used for benefit period closure and retention analytics.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disenrollmentReason rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Reason' ;
    rdfs:comment 'Reason code or description for why the patient was disenrolled from this program (e.g., treatment completed, patient request, insurance change to government payer, benefit maximum reached, non-compliance). Critical for retention analysis and program optimization.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionEventType rdf:type rdf:Property ;
    rdfs:label 'Disposition Event Type' ;
    rdfs:comment 'Type of disposition event that ended or changed the patients enrollment status: completed (finished protocol per plan), withdrawn (voluntary or investigator-initiated discontinuation), lost_to_followup (contact lost), death (patient died), screen_failure (did not meet eligibility), protocol_deviation (removed due to protocol violation).' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionPrimaryReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Primary Reason' ;
    rdfs:comment 'Primary reason code for the disposition event. Standardized per CDISC Controlled Terminology (e.g., adverse event, lack of efficacy, protocol violation, patient decision, lost to follow-up, death, completed per protocol).' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionSecondaryReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Secondary Reason' ;
    rdfs:comment 'Secondary or contributing reason code for the disposition event. Provides additional context beyond the primary reason.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Type of enrollment program: clinical_trial (interventional study), support_program (patient assistance program), registry (observational registry), expanded_access (pre-approval access), compassionate_use (emergency use).' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icfVersion rdf:type rdf:Property ;
    rdfs:label 'Icf Version' ;
    rdfs:comment 'Version of the informed consent form signed by the patient at enrollment. Tracks consent document revisions and re-consent requirements.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the last documented contact with the patient. Used for tracking lost-to-follow-up and vital status.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDoseDate rdf:type rdf:Property ;
    rdfs:label 'Last Dose Date' ;
    rdfs:comment 'Date the patient received their last dose of investigational product. Critical for safety follow-up and disposition tracking.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Patient Enrollment Date' ;
    rdfs:comment 'Date when the patient was enrolled in this specific support program. Critical for program eligibility, benefit period calculation, and compliance reporting.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Patient Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of this enrollment. Tracks progression from pending through active participation to completion or disenrollment. Used for operational reporting and benefit eligibility determination.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Method' ;
    rdfs:comment 'Patient\'s preferred method of contact for communications related to this specific program enrollment. May differ from general patient contact preferences.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the operational system of record from which this enrollment record originated (e.g., PSP hub platform, specialty pharmacy system, CRM). Used for data lineage and troubleshooting.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Population Flag' ;
    rdfs:comment 'Boolean flag indicating whether the patient is included in the safety analysis population. Typically true if the patient received at least one dose of investigational product.' ;
    rdfs:domain ind:PatientEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentArm rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm' ;
    rdfs:comment 'Treatment arm or cohort to which the patient was assigned (e.g., active drug, placebo, dose level, combination therapy). May be coded to maintain blinding.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentingInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Consenting Investigator Id' ;
    rdfs:comment 'Unique identifier for the principal investigator or sub-investigator who obtained the informed consent. Applicable for clinical trial consents.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:biomarkerSubstudyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Biomarker Substudy Consent Flag' ;
    rdfs:comment 'Indicates whether the patient consented to participate in biomarker or translational research sub-studies. True if consented, False if declined or not applicable.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCategory rdf:type rdf:Property ;
    rdfs:label 'Consent Category' ;
    rdfs:comment 'Category of consent record. Distinguishes between clinical informed consent (ICF), re-consent events, consent withdrawals, GDPR privacy consent, HIPAA authorization, and data sharing consent.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'Channel or interface through which consent was captured. Distinguishes between web portal, mobile app, paper form, in-person at site, telephonic, or email.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Document Url' ;
    rdfs:comment 'URL or file path to the signed consent document stored in the document management system (e.g., Veeva Vault, eTMF). Used for regulatory inspection readiness.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'Date when the consent expires or is no longer valid. Null for consents without expiration. Applicable for time-limited privacy consents or trial-specific consents.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedDate rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Date' ;
    rdfs:comment 'Date when the informed consent was obtained from the patient or legally authorized representative (LAR). Primary business event timestamp for consent lifecycle.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Timestamp' ;
    rdfs:comment 'Precise timestamp when consent was obtained. Used for eConsent systems and audit trail. Complements consent_obtained_date with time-of-day precision.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentPurpose rdf:type rdf:Property ;
    rdfs:label 'Consent Purpose' ;
    rdfs:comment 'Specific purpose for which consent was obtained. Examples: clinical_trial_participation, data_processing, research, marketing, data_sharing, pharmacovigilance, patient_support_program. Free-text or controlled vocabulary.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSignatureMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Signature Method' ;
    rdfs:comment 'Method by which the patient or LAR signed the consent. Examples: wet_signature (ink on paper), electronic_signature, digital_signature (PKI-based), biometric, verbal_recorded.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentWithdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawal Date' ;
    rdfs:comment 'Date when the patient withdrew consent. Null if consent has not been withdrawn. Critical for GCP compliance and data subject rights.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSubjectRightsFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Fulfillment Date' ;
    rdfs:comment 'Date when the data subject rights request was fulfilled or completed. Null if request is pending or no request exists.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSubjectRightsRequestDate rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Request Date' ;
    rdfs:comment 'Date when the data subject rights request was received. Null if no request. Critical for GDPR compliance (30-day response requirement).' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSubjectRightsRequestType rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Request Type' ;
    rdfs:comment 'Type of data subject rights request associated with this consent record. Examples: access, erasure, portability, rectification, restriction, objection. Null if no request. Applicable for GDPR compliance.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:futureUseConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Future Use Consent Flag' ;
    rdfs:comment 'Indicates whether the patient consented to future use of their data or biological samples for research purposes beyond the current study. True if consented, False if declined.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'GDPR Article 6 or Article 9 lawful basis for processing personal data. Examples: consent, legitimate_interest, legal_obligation, vital_interests, public_task, explicit_consent_special_category. Applicable for EU/EEA patients.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneticSubstudyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Genetic Substudy Consent Flag' ;
    rdfs:comment 'Indicates whether the patient consented to participate in genetic or genomic sub-studies. True if consented, False if declined or not applicable.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Flag' ;
    rdfs:comment 'Indicates whether HIPAA authorization was obtained for use and disclosure of protected health information (PHI). True if authorization obtained, False if not applicable or declined. Applicable for US patients.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reConsentReason rdf:type rdf:Property ;
    rdfs:label 'Re Consent Reason' ;
    rdfs:comment 'Reason for re-consenting the patient. Examples: protocol_amendment, new_safety_information, icf_version_update, regulatory_requirement. Applicable when consent_category is re_consent.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalScope rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Scope' ;
    rdfs:comment 'Scope of consent withdrawal. Indicates whether patient withdrew from entire study, data use only, biological sample use only, or future contact. Critical for GCP compliance.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Full name of the impartial witness who observed the consent process. Required when patient or LAR cannot read, or as per local regulations.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Date' ;
    rdfs:comment 'Date when the impartial witness signed the informed consent form. Null if no witness was required.' ;
    rdfs:domain ind:InformedConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:concomitantMedicationId rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication Id' ;
    rdfs:comment 'Unique identifier for the concomitant medication record. Primary key for this entity.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prescribingMasterId rdf:type rdf:Property ;
    rdfs:label 'Prescribing Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.master. Business justification: Drug-drug interaction analysis and pharmacovigilance safety reporting require knowing which HCP prescribed each concomitant medication. In clinical trials and post-marketing surveillance, prescriber i' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:dose rdf:type rdf:Property ;
    rdfs:label 'Dose' ;
    rdfs:comment 'The numeric dose amount of the concomitant medication administered per administration event. Used with dose_unit to specify complete dosing information.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicationClass rdf:type rdf:Property ;
    rdfs:label 'Medication Class' ;
    rdfs:comment 'The therapeutic or pharmacological class of the concomitant medication (e.g., antibiotic, antihypertensive, analgesic, anticoagulant). Used for safety signal detection and drug-drug interaction screening.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ongoingFlag rdf:type rdf:Property ;
    rdfs:label 'Ongoing Flag' ;
    rdfs:comment 'Boolean indicator of whether the concomitant medication is still being taken by the subject at the time of data capture or database lock. True if ongoing, False if stopped.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorToStudyFlag rdf:type rdf:Property ;
    rdfs:label 'Prior To Study Flag' ;
    rdfs:comment 'Boolean indicator of whether the concomitant medication was started before the subject enrolled in the clinical trial. True if started prior, False if started during study.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prohibitedConcomitantFlag rdf:type rdf:Property ;
    rdfs:label 'Prohibited Concomitant Flag' ;
    rdfs:comment 'Boolean indicator of whether the concomitant medication is prohibited per the clinical trial protocol. True if prohibited, False if allowed. Critical for protocol deviation tracking.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingMasterId rdf:type rdf:Property ;
    rdfs:label 'Reporting Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.master. Business justification: Pharmacovigilance and MedWatch/EudraVigilance regulatory reporting require traceability of the HCP who reported the adverse event. The \'reported_by\' plain-text field is a denormalization of hcp.master' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:actionTakenStudyDrug rdf:type rdf:Property ;
    rdfs:label 'Action Taken Study Drug' ;
    rdfs:comment 'Action taken with the investigational product or study drug in response to the adverse event.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeTerm rdf:type rdf:Property ;
    rdfs:label 'Ae Term' ;
    rdfs:comment 'The verbatim description of the adverse event as reported by the patient, investigator, or healthcare professional.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'The duration of the adverse event in days, calculated from onset date to resolution date. Null if ongoing or fatal.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedness rdf:type rdf:Property ;
    rdfs:label 'Expectedness' ;
    rdfs:comment 'Indicates whether the adverse event was expected based on the current Investigator Brochure or product labeling.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraSocName rdf:type rdf:Property ;
    rdfs:label 'Meddra Soc Name' ;
    rdfs:comment 'MedDRA system organ class name representing the body system affected by the adverse event.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'The date when the adverse event was first reported to the sponsor or investigator.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingTimelineComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Timeline Compliance Status' ;
    rdfs:comment 'Indicates whether the adverse event was reported to regulatory authorities within the required timeline (e.g., 7 days for fatal/life-threatening SAEs, 15 days for other SAEs).' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousnessCriteriaCongenitalAnomaly rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Congenital Anomaly' ;
    rdfs:comment 'Indicates whether the adverse event resulted in a congenital anomaly or birth defect.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteriaDeath rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Death' ;
    rdfs:comment 'Indicates whether the adverse event resulted in death.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteriaDisability rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Disability' ;
    rdfs:comment 'Indicates whether the adverse event resulted in persistent or significant disability or incapacity.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteriaHospitalization rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Hospitalization' ;
    rdfs:comment 'Indicates whether the adverse event resulted in initial or prolonged inpatient hospitalization.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteriaLifeThreatening rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Life Threatening' ;
    rdfs:comment 'Indicates whether the adverse event was life-threatening at the time of the event.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessCriteriaMedicallyImportant rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria Medically Important' ;
    rdfs:comment 'Indicates whether the adverse event was considered medically important and may jeopardize the patient or require intervention to prevent one of the other serious outcomes.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessFlag rdf:type rdf:Property ;
    rdfs:label 'Seriousness Flag' ;
    rdfs:comment 'Indicates whether the adverse event meets regulatory criteria for seriousness (death, life-threatening, hospitalization, disability, congenital anomaly, or other medically important condition).' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityGrade rdf:type rdf:Property ;
    rdfs:label 'Severity Grade' ;
    rdfs:comment 'Severity grade of the adverse event using CTCAE scale: Grade 1 (Mild), Grade 2 (Moderate), Grade 3 (Severe), Grade 4 (Life-threatening), Grade 5 (Death).' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administeredBy rdf:type rdf:Property ;
    rdfs:label 'Administered By' ;
    rdfs:comment 'Name or identifier of the healthcare professional (HCP) who administered the investigational product.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrationDate rdf:type rdf:Property ;
    rdfs:label 'Administration Date' ;
    rdfs:comment 'Calendar date on which the investigational product was administered to the subject.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:administrationSite rdf:type rdf:Property ;
    rdfs:label 'Administration Site' ;
    rdfs:comment 'Anatomical site or location where the investigational product was administered (e.g., left arm, right thigh, abdomen). Relevant for injectable and topical routes.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrationTime rdf:type rdf:Property ;
    rdfs:label 'Administration Time' ;
    rdfs:comment 'Precise date and time when the investigational product was administered. Critical for pharmacokinetic (PK) and pharmacodynamic (PD) analysis.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:concomitantMedicationFlag rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication Flag' ;
    rdfs:comment 'Indicator whether the subject was taking other concomitant medications at the time of this treatment exposure. Important for drug-drug interaction analysis.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeDose rdf:type rdf:Property ;
    rdfs:label 'Cumulative Dose' ;
    rdfs:comment 'Total cumulative dose of the investigational product administered to the subject from treatment start through this exposure event. Critical for dose-response modeling and safety assessment.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cycle Number' ;
    rdfs:comment 'Sequential cycle number for treatments administered in repeated cycles (common in oncology protocols).' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doseAdministered rdf:type rdf:Property ;
    rdfs:label 'Dose Administered' ;
    rdfs:comment 'Actual dose amount of the investigational product administered to the subject during this exposure event.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doseModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Dose Modification Flag' ;
    rdfs:comment 'Indicator whether the administered dose was modified from the planned protocol dose. True if dose was adjusted, false if administered as planned.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doseModificationReason rdf:type rdf:Property ;
    rdfs:label 'Dose Modification Reason' ;
    rdfs:comment 'Clinical rationale or reason for modifying the dose from the protocol-specified amount (e.g., adverse event, organ dysfunction, drug interaction).' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationOfInfusionMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Of Infusion Minutes' ;
    rdfs:comment 'Duration in minutes for intravenous infusion administration. Applicable only for IV infusion routes.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDose rdf:type rdf:Property ;
    rdfs:label 'Planned Dose' ;
    rdfs:comment 'Protocol-specified dose amount that was planned to be administered according to the study design.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Treatment Compliance Percentage' ;
    rdfs:comment 'Percentage of planned doses actually taken by the subject, calculated as (actual doses / planned doses) * 100. Measures adherence to protocol.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Treatment Status' ;
    rdfs:comment 'Current status of this treatment exposure event indicating whether the dose was successfully administered or not.' ;
    rdfs:domain ind:TreatmentExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalObservationId rdf:type rdf:Property ;
    rdfs:label 'Clinical Observation Id' ;
    rdfs:comment 'Primary key for clinical_observation' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assayVersion rdf:type rdf:Property ;
    rdfs:label 'Assay Version' ;
    rdfs:comment 'Version number or lot number of the assay kit or reagent used for the test. Critical for genomic and biomarker assays to ensure reproducibility and comparability across batches.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'Role or qualification of the person who performed or interpreted the observation (e.g., principal investigator, sub-investigator, central reviewer, laboratory technician, radiologist). [ENUM-REF-CANDIDATE: PRINCIPAL_INVESTIGATOR|SUB_INVESTIGATOR|CENTRAL_REVIEWER|LABORATORY_TECHNICIAN|RADIOLOGIST|PATHOLOGIST|OTHER — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerType rdf:type rdf:Property ;
    rdfs:label 'Biomarker Type' ;
    rdfs:comment 'Classification of biomarker (e.g., companion diagnostic (CDx), tumor mutational burden (TMB), programmed death-ligand 1 (PD-L1), microsatellite instability (MSI), pharmacogenomic (PGx) panel, circulating tumor DNA (ctDNA)). Applicable only to biomarker and genomic observations.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalEndpointType rdf:type rdf:Property ;
    rdfs:label 'Clinical Endpoint Type' ;
    rdfs:comment 'Type of clinical endpoint assessment (e.g., RECIST 1.1 tumor response, iRECIST, DAS28 disease activity score, ECOG performance status, Karnofsky performance status, quality of life (QoL) score). Applicable only to clinical endpoint observations.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDatetime rdf:type rdf:Property ;
    rdfs:label 'Collection Datetime' ;
    rdfs:comment 'Date and time when the specimen was collected or the observation was performed. Critical for pharmacokinetic (PK) and pharmacodynamic (PD) analysis and longitudinal trending.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deltaFromBaselineFlag rdf:type rdf:Property ;
    rdfs:label 'Delta From Baseline Flag' ;
    rdfs:comment 'Boolean flag indicating whether this observation represents a change from baseline value. True if this is a delta calculation, False if this is an absolute measurement. Used for longitudinal analysis and safety monitoring.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endpointResponse rdf:type rdf:Property ;
    rdfs:label 'Endpoint Response' ;
    rdfs:comment 'Categorical response or outcome for clinical endpoint assessments (e.g., complete response (CR), partial response (PR), stable disease (SD), progressive disease (PD) for RECIST; remission, relapse for DAS28). Uses standardized response criteria.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryIdentifier rdf:type rdf:Property ;
    rdfs:label 'Laboratory Identifier' ;
    rdfs:comment 'Unique identifier for the laboratory or assay vendor (e.g., CLIA number, CAP accreditation number, vendor assay catalog ID). Used for traceability and regulatory submissions.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the laboratory, imaging center, or facility that performed the test or assessment. Used for quality control and result reconciliation.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mutationDetected rdf:type rdf:Property ;
    rdfs:label 'Mutation Detected' ;
    rdfs:comment 'Specific genetic mutation or variant detected (e.g., EGFR L858R, KRAS G12C, BRCA1 c.68_69delAG). Uses HGVS (Human Genome Variation Society) nomenclature for precision.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationCategory rdf:type rdf:Property ;
    rdfs:label 'Observation Category' ;
    rdfs:comment 'High-level classification of the clinical observation type. Aligns with CDISC findings-class domains (LB=laboratory, VS=vital signs, MB=microbiology/biomarker, TR=tumor response).' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfRangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Out Of Range Indicator' ;
    rdfs:comment 'Flag indicating whether the result is within, above, or below the reference range. Critical for safety monitoring and adverse event (AE) detection.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedDatetime rdf:type rdf:Property ;
    rdfs:label 'Record Created Datetime' ;
    rdfs:comment 'Timestamp when this observation record was first created in the source system. Used for audit trail and data lineage tracking per Good Clinical Practice (GCP) and 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedDatetime rdf:type rdf:Property ;
    rdfs:label 'Record Updated Datetime' ;
    rdfs:comment 'Timestamp when this observation record was last modified in the source system. Used for audit trail and change tracking per Good Clinical Practice (GCP) and 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referenceRangeLower rdf:type rdf:Property ;
    rdfs:label 'Reference Range Lower' ;
    rdfs:comment 'Lower bound of the normal reference range for this test. Used to determine if result is out of range (low). May vary by age, sex, and laboratory.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Reference Range Upper' ;
    rdfs:comment 'Upper bound of the normal reference range for this test. Used to determine if result is out of range (high). May vary by age, sex, and laboratory.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultInterpretation rdf:type rdf:Property ;
    rdfs:label 'Result Interpretation' ;
    rdfs:comment 'Clinical interpretation or assessment of the result by the investigator or central reviewer (e.g., clinically significant, not clinically significant, consistent with disease progression). Free-text field.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValueText rdf:type rdf:Property ;
    rdfs:label 'Result Value Text' ;
    rdfs:comment 'Text or categorical result value for qualitative observations (e.g., positive/negative, normal/abnormal, gene mutation detected). Used when result is not numeric.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenType rdf:type rdf:Property ;
    rdfs:label 'Specimen Type' ;
    rdfs:comment 'Type of biological specimen collected for laboratory or biomarker testing (e.g., blood, serum, plasma, urine, tissue, saliva, cerebrospinal fluid). Uses SNOMED CT or CDISC controlled terminology.' ;
    rdfs:domain ind:Pharmaceuticals ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCode rdf:type rdf:Property ;
    rdfs:label 'Test Code' ;
    rdfs:comment 'Standardized code for the test or assessment. Typically LOINC code for laboratory tests, SNOMED CT for clinical findings, or proprietary assay identifier for genomic tests.' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCodeSystem rdf:type rdf:Property ;
    rdfs:label 'Test Code System' ;
    rdfs:comment 'The coding system or terminology used for the test_code field. Identifies the standard vocabulary (LOINC, SNOMED CT, CDISC controlled terminology, or proprietary assay catalog).' ;
    rdfs:domain ind:ClinicalObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedOutcomeId rdf:type rdf:Property ;
    rdfs:label 'Reported Outcome Id' ;
    rdfs:comment 'Primary key for reported_outcome' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Window End Date' ;
    rdfs:comment 'End date of the protocol-defined assessment window during which the PRO should be completed. Used to determine compliance with the study schedule.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Window Start Date' ;
    rdfs:comment 'Start date of the protocol-defined assessment window during which the PRO should be completed. Used to determine compliance with the study schedule.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Flag' ;
    rdfs:comment 'Indicates whether this PRO assessment represents the baseline measurement collected before the start of investigational product administration. True indicates baseline assessment; False indicates post-baseline assessment.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicallyMeaningfulChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Clinically Meaningful Change Flag' ;
    rdfs:comment 'Indicates whether the change in PRO score from baseline or previous assessment meets the threshold for clinically meaningful change as defined by the instrument validation studies or regulatory guidance. True indicates clinically meaningful change; False indicates change below the threshold.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionMethod rdf:type rdf:Property ;
    rdfs:label 'Completion Method' ;
    rdfs:comment 'Method or modality by which the patient completed the PRO instrument (e.g., ePRO electronic system, paper questionnaire, telephone interview, mobile app, web portal). Important for data quality assessment and regulatory submissions.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Status of the PRO assessment completion. Indicates whether the instrument was fully completed, partially completed, not done, missed, or deferred to a later timepoint.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the patient completed the PRO instrument. Provides granular temporal data for ePRO systems and compliance monitoring.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the PRO assessment was completed within the protocol-specified timeframe and according to the study procedures. True indicates compliant completion; False indicates non-compliance or protocol deviation.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:domainName rdf:type rdf:Property ;
    rdfs:label 'Domain Name' ;
    rdfs:comment 'Name of the health domain or subscale measured by this outcome (e.g., Physical Functioning, Emotional Well-being, Pain, Fatigue, Social Functioning). Represents the specific aspect of quality of life being assessed.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentVersion rdf:type rdf:Property ;
    rdfs:label 'Instrument Version' ;
    rdfs:comment 'Version number or edition of the PRO instrument used (e.g., EQ-5D-5L, SF-36v2). Critical for ensuring consistency and comparability of results across timepoints and studies.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemIdentifier rdf:type rdf:Property ;
    rdfs:label 'Item Identifier' ;
    rdfs:comment 'Unique identifier for the specific question or item within the PRO instrument (e.g., Q1, Q2, Item_3). Used to map individual responses to the instrument structure.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemText rdf:type rdf:Property ;
    rdfs:label 'Item Text' ;
    rdfs:comment 'Full text of the question or item presented to the patient. Provides context for interpreting the response value.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingItemsCount rdf:type rdf:Property ;
    rdfs:label 'Missing Items Count' ;
    rdfs:comment 'Number of items within the PRO instrument that were not answered by the patient. Used to assess data completeness and determine whether the instrument can be scored according to its validation rules.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseLabel rdf:type rdf:Property ;
    rdfs:label 'Response Label' ;
    rdfs:comment 'Human-readable label corresponding to the response value (e.g., Not at all, A little bit, Moderately, Quite a bit, Extremely). Provides semantic meaning to numeric or coded responses.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseValue rdf:type rdf:Property ;
    rdfs:label 'Response Value' ;
    rdfs:comment 'Raw response value provided by the patient for this specific item. May be numeric, categorical, or free-text depending on the instrument design.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscaleScore rdf:type rdf:Property ;
    rdfs:label 'Subscale Score' ;
    rdfs:comment 'Score calculated for a specific domain or subscale within the PRO instrument (e.g., Physical Component Score, Mental Component Score). Allows granular analysis of specific health dimensions.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalScore rdf:type rdf:Property ;
    rdfs:label 'Total Score' ;
    rdfs:comment 'Overall composite score calculated from all items in the PRO instrument. Represents the aggregate quality of life or health status measure. Calculation methodology is instrument-specific.' ;
    rdfs:domain ind:ReportedOutcome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:principalInvestigatorMasterId rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.master. Business justification: Patient registries require a named responsible HCP (principal investigator) for regulatory mandate compliance, IRB submissions, and governing authority reporting. \'principal_investigator_name\' and \'ma' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:currentEnrollment rdf:type rdf:Property ;
    rdfs:label 'Current Enrollment' ;
    rdfs:comment 'Current number of participants actively enrolled in the registry as of the last update.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataCollectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Collection Frequency' ;
    rdfs:comment 'Frequency at which data is collected from registry participants. Continuous indicates real-time or near-real-time collection; event-driven indicates collection triggered by specific clinical events. [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|annually|event_driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Primary method used to collect registry data. EDC: electronic data capture systems; Medical records: chart review and abstraction; Patient reported: direct from participants; Claims: insurance/billing data; Hybrid: multiple methods.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Years' ;
    rdfs:comment 'Number of years that registry data must be retained after registry completion per regulatory requirements and company policy.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourceType rdf:type rdf:Property ;
    rdfs:label 'Data Source Type' ;
    rdfs:comment 'Temporal nature of data collection. Prospective: data collected going forward from enrollment; Retrospective: historical data collected from existing records; Hybrid: combination of both.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcSystem rdf:type rdf:Property ;
    rdfs:label 'Edc System' ;
    rdfs:comment 'Name of the electronic data capture system or platform used for registry data collection (e.g., Medidata Rave, Oracle Clinical, REDCap).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliance Flag' ;
    rdfs:comment 'Indicates whether the registry is subject to and compliant with EU GDPR regulations for personal data protection (True) or not applicable (False).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingAuthority rdf:type rdf:Property ;
    rdfs:label 'Governing Authority' ;
    rdfs:comment 'Primary regulatory authority that oversees or mandates the registry. Multiple indicates oversight by more than one regulatory body. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|NMPA|WHO|multiple — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Compliance Flag' ;
    rdfs:comment 'Indicates whether the registry is subject to and compliant with HIPAA regulations for protected health information (True) or not applicable (False).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:informedConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Required' ;
    rdfs:comment 'Indicates whether participants must provide informed consent to participate in the registry (True) or consent is waived (False).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Required' ;
    rdfs:comment 'Indicates whether the registry requires Institutional Review Board or Ethics Committee approval (True) or is exempt (False).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Anticipated date for completion of all registry activities including final data collection and analysis. May be null for indefinite registries.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protocolEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Protocol Effective Date' ;
    rdfs:comment 'Date when the current version of the registry protocol became effective.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registryCode rdf:type rdf:Property ;
    rdfs:label 'Registry Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the registry for internal tracking and cross-system reference.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryName rdf:type rdf:Property ;
    rdfs:label 'Registry Name' ;
    rdfs:comment 'Official name of the patient registry as registered with regulatory authorities and used in protocol documentation.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryStatus rdf:type rdf:Property ;
    rdfs:label 'Registry Status' ;
    rdfs:comment 'Current operational status of the registry. Planning: protocol development phase; Active: operational and collecting data; Enrolling: actively recruiting participants; Closed to enrollment: no new participants but follow-up continues; Completed: all data collection finished; Terminated: ended prematurely; Suspended: temporarily paused. [ENUM-REF-CANDIDATE: planning|active|enrolling|closed_to_enrollment|completed|terminated|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryType rdf:type rdf:Property ;
    rdfs:label 'Registry Type' ;
    rdfs:comment 'Classification of the registry based on its primary purpose and regulatory mandate. Disease registries track natural history of specific conditions; pregnancy registries monitor maternal and fetal outcomes; PASS registries fulfill post-marketing safety commitments; REMS registries are mandated by Risk Evaluation and Mitigation Strategy programs.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether the registry is mandated by a regulatory authority as a condition of drug approval or post-marketing requirement (True) or is voluntary/observational (False).' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetEnrollment rdf:type rdf:Property ;
    rdfs:label 'Target Enrollment' ;
    rdfs:comment 'Planned total number of participants to be enrolled in the registry as specified in the protocol.' ;
    rdfs:domain ind:Registry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryHcoMasterId rdf:type rdf:Property ;
    rdfs:label 'Delivery Hco Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.hco_master. Business justification: Patient support programs (hub services, infusion programs, nurse educator programs) are operationally delivered at specific HCOs (infusion centers, specialty pharmacies). Network management, reimburse' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HcoMaster .

ind:adherenceDataSource rdf:type rdf:Property ;
    rdfs:label 'Adherence Data Source' ;
    rdfs:comment 'Primary source of medication adherence data for programs with adherence monitoring enabled. [ENUM-REF-CANDIDATE: specialty_pharmacy|epro|connected_device|patient_reported|claims_data|mixed|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adherenceMonitoringEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Adherence Monitoring Enabled Flag' ;
    rdfs:comment 'Indicates whether this program includes medication adherence tracking and intervention services.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialPayerOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Payer Only Flag' ;
    rdfs:comment 'Indicates whether the program is restricted to commercial insurance patients only (true) or allows government payer patients (false). Copay programs must exclude government payers per Anti-Kickback Statute.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'Primary email address for program inquiries and patient support communications.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Primary toll-free or direct phone number for patients and healthcare providers (HCPs) to contact the support program.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyClassification rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Classification' ;
    rdfs:comment 'Classification level for patient data collected and processed through this support program under HIPAA and GDPR requirements.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentMethod rdf:type rdf:Property ;
    rdfs:label 'Enrollment Method' ;
    rdfs:comment 'Primary method(s) by which patients can enroll in the support program.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nurseEducatorSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Nurse Educator Support Flag' ;
    rdfs:comment 'Indicates whether the program provides dedicated nurse educator support for patient education and clinical guidance.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalVendorName rdf:type rdf:Property ;
    rdfs:label 'Operational Vendor Name' ;
    rdfs:comment 'Name of the third-party vendor or hub services provider contracted to administer the patient support program operations.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthorizationSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Support Flag' ;
    rdfs:comment 'Indicates whether the program assists patients and providers with insurance prior authorization processes.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'Date when the patient support program is scheduled to terminate or was terminated. Null for ongoing programs.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Start Date' ;
    rdfs:comment 'Date when the patient support program became operational and began accepting enrollments.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Support Flag' ;
    rdfs:comment 'Indicates whether the program provides reimbursement navigation and claims appeal support services.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyPharmacyNetwork rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Network' ;
    rdfs:comment 'Names of specialty pharmacy partners integrated with this patient support program for coordinated dispensing and adherence tracking.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBenefitDisbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Benefit Disbursed Amount' ;
    rdfs:comment 'Cumulative financial assistance amount (in USD) disbursed through this program since inception for copay assistance programs.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorContractNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Number' ;
    rdfs:comment 'Contract reference number for the agreement with the operational vendor managing this program.' ;
    rdfs:domain ind:SupportProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterdataOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Masterdata Org Unit Id' ;
    rdfs:comment 'Foreign key linking to masterdata.org_unit. Business justification: Protocol deviations are reviewed and managed by organizational units (quality assurance, medical affairs) for CAPA tracking, root cause analysis, regulatory reporting (FDA Form 1572), and inspection r' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:reviewingInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Reviewing Investigator Id' ;
    rdfs:comment 'Foreign key linking to hcp.investigator. Business justification: FDA/ICH E6 GCP requires formal investigator accountability for protocol deviations — who identified and reviewed each deviation must be traceable to a credentialed investigator. \'reviewed_by\' and \'ide' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigator .

ind:capaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Reference Number' ;
    rdfs:comment 'Reference number linking this protocol deviation to a formal CAPA record in the Quality Management System (QMS) for tracking preventive measures.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Date' ;
    rdfs:comment 'The date on which corrective action was implemented to address the protocol deviation.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deviationDate rdf:type rdf:Property ;
    rdfs:label 'Deviation Date' ;
    rdfs:comment 'The date on which the protocol deviation occurred or was identified to have occurred.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'The date on which the protocol deviation was discovered or detected by site staff or monitors.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactOnDataIntegrity rdf:type rdf:Property ;
    rdfs:label 'Impact On Data Integrity' ;
    rdfs:comment 'Assessment of the protocol deviation\'s impact on the reliability and validity of clinical trial data: none, low, moderate, or high.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnSubjectSafety rdf:type rdf:Property ;
    rdfs:label 'Impact On Subject Safety' ;
    rdfs:comment 'Assessment of the protocol deviation\'s impact on the safety and well-being of the trial participant: none, low, moderate, or high.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportability Flag' ;
    rdfs:comment 'Indicates whether the protocol deviation is reportable to regulatory authorities (FDA, EMA, etc.) based on severity and impact criteria. True if reportable, False if not.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Documented analysis of the underlying root cause(s) that led to the protocol deviation, used to inform preventive actions.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'Classification of the deviation severity: major (significant impact on subject safety or data integrity), minor (minimal impact), or critical (immediate threat to subject safety or trial integrity).' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference to the source document or record in the originating system (e.g., Veeva Vault document ID, Medidata Rave form ID) for audit trail purposes.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerResultId rdf:type rdf:Property ;
    rdfs:label 'Biomarker Result Id' ;
    rdfs:comment 'Unique identifier for the biomarker result record. Primary key for this entity.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdxInnRegistryId rdf:type rdf:Property ;
    rdfs:label 'Cdx Inn Registry Id' ;
    rdfs:comment 'Foreign key linking to masterdata.inn_registry. Business justification: Companion diagnostic (CDx) biomarker results must be linked to the specific INN of the indicated drug per FDA/EMA CDx regulatory submissions (e.g., EGFR mutation → erlotinib). The cdx_drug_indication ' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InnRegistry .

ind:alleleFrequency rdf:type rdf:Property ;
    rdfs:label 'Allele Frequency' ;
    rdfs:comment 'The variant allele frequency (VAF) expressed as a decimal (e.g., 0.45 for 45% mutant allele frequency).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biomarkerCode rdf:type rdf:Property ;
    rdfs:label 'Biomarker Code' ;
    rdfs:comment 'Standardized code for the biomarker using LOINC, SNOMED CT, or HGNC nomenclature for genomic markers.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerName rdf:type rdf:Property ;
    rdfs:label 'Biomarker Name' ;
    rdfs:comment 'The name of the biomarker or molecular marker being measured (e.g., PD-L1, EGFR, KRAS, HER2, TMB, MSI).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdxApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Cdx Approved Flag' ;
    rdfs:comment 'Indicates whether this biomarker assay is an FDA-approved or EMA-approved companion diagnostic (CDx) for a specific therapeutic indication.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutoffValue rdf:type rdf:Property ;
    rdfs:label 'Cutoff Value' ;
    rdfs:comment 'The threshold value used to determine positive vs negative result interpretation for this biomarker (e.g., PD-L1 ≥50% for pembrolizumab eligibility).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryCliaNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Clia Number' ;
    rdfs:comment 'The CLIA certification number of the testing laboratory, required for clinical diagnostic testing in the United States.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mutationType rdf:type rdf:Property ;
    rdfs:label 'Mutation Type' ;
    rdfs:comment 'The type of genetic mutation detected (e.g., missense, nonsense, frameshift, deletion, insertion, amplification, fusion).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'Indicates whether the biomarker assay passed internal quality control checks (e.g., passed, failed, not applicable).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultDate rdf:type rdf:Property ;
    rdfs:label 'Result Date' ;
    rdfs:comment 'The date on which the biomarker result was finalized and reported by the laboratory.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specimenCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Specimen Collection Date' ;
    rdfs:comment 'The date on which the biological specimen was collected from the subject.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'The name of the laboratory or Contract Research Organization (CRO) that performed the biomarker assay.' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantAnnotation rdf:type rdf:Property ;
    rdfs:label 'Variant Annotation' ;
    rdfs:comment 'Detailed annotation of the genetic variant using HGVS nomenclature (e.g., c.2573T>G, p.L858R).' ;
    rdfs:domain ind:BiomarkerResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryAssayId rdf:type rdf:Property ;
    rdfs:label 'Discovery Assay Id' ;
    rdfs:comment 'Foreign key linking to discovery.assay. Business justification: Translational medicine programs run validated discovery assays (target engagement, PD biomarker assays) on clinical biospecimens. The biospecimen record must reference which discovery assay is planned' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assay .

ind:parentBiospecimenId rdf:type rdf:Property ;
    rdfs:label 'Parent Biospecimen Id' ;
    rdfs:comment 'Self-referencing FK on biospecimen (parent_biospecimen_id)' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Biospecimen .

ind:reagentInventoryLotId rdf:type rdf:Property ;
    rdfs:label 'Reagent Inventory Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.inventory_lot. Business justification: Biospecimen processing uses reagent/consumable lots; GCP compliance (ICH E6) requires lot traceability for data integrity and result reproducibility. Role prefix distinguishes reagent lots from clinic' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLot .

ind:anatomicalSite rdf:type rdf:Property ;
    rdfs:label 'Anatomical Site' ;
    rdfs:comment 'The anatomical location from which the specimen was collected, such as left arm, liver, or lung. Particularly important for tissue biopsies and tumor samples.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayPlanned rdf:type rdf:Property ;
    rdfs:label 'Assay Planned' ;
    rdfs:comment 'The name or code of the assay or test planned to be performed on this specimen, such as pharmacokinetic (PK) analysis, biomarker assay, or genomic sequencing. Supports laboratory planning and resource allocation.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyVerified rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Verified' ;
    rdfs:comment 'Indicates whether the chain of custody for the specimen has been verified and documented. True if verified, False otherwise. Critical for regulatory compliance and data integrity.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'The method or procedure used to collect the specimen, such as venipuncture, biopsy, or catheterization. Ensures protocol compliance and reproducibility.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionVisitName rdf:type rdf:Property ;
    rdfs:label 'Collection Visit Name' ;
    rdfs:comment 'The protocol-defined name of the visit during which the specimen was collected, such as Baseline, Week 4, End of Treatment. Aligns with the visit schedule in the Case Report Form (CRF).' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentBiobankFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Biobank Flag' ;
    rdfs:comment 'Indicates whether the subject provided optional consent for long-term biobanking and future research use of this specimen. True if consent was provided, False otherwise.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentGeneticTestingFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Genetic Testing Flag' ;
    rdfs:comment 'Indicates whether the subject provided optional consent for genetic or pharmacogenomic testing on this specimen. True if consent was provided, False otherwise.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'The type of tube or container used for specimen collection, such as EDTA tube, serum separator tube, cryovial. Critical for ensuring proper specimen handling and assay validity.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDate rdf:type rdf:Property ;
    rdfs:label 'Processing Date' ;
    rdfs:comment 'The date on which the specimen was processed in the laboratory. Used to track time from collection to processing for quality control.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processingMethod rdf:type rdf:Property ;
    rdfs:label 'Processing Method' ;
    rdfs:comment 'The method used to process the specimen after collection, such as centrifugation, aliquoting, or fixation. Ensures traceability of specimen handling procedures.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snomedCode rdf:type rdf:Property ;
    rdfs:label 'Snomed Code' ;
    rdfs:comment 'The standardized SNOMED CT code representing the specimen type or anatomical source. Supports clinical terminology standardization and regulatory compliance.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenNumber rdf:type rdf:Property ;
    rdfs:label 'Specimen Number' ;
    rdfs:comment 'Unique business identifier for the biospecimen, typically a barcode or alphanumeric code assigned at collection. Used for chain-of-custody tracking and laboratory processing.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenQuality rdf:type rdf:Property ;
    rdfs:label 'Specimen Quality' ;
    rdfs:comment 'Assessment of the specimen quality upon receipt or processing. Identifies any conditions that may affect assay results or specimen usability.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenStatus rdf:type rdf:Property ;
    rdfs:label 'Specimen Status' ;
    rdfs:comment 'The current lifecycle status of the biospecimen, indicating its stage in the collection, processing, storage, and analysis workflow. [ENUM-REF-CANDIDATE: collected|processed|stored|shipped|received|analyzed|depleted|discarded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenSubtype rdf:type rdf:Property ;
    rdfs:label 'Specimen Subtype' ;
    rdfs:comment 'Further classification or detail of the specimen type, such as specific tissue origin or blood component. Provides granular categorization for specialized assays.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperature rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature' ;
    rdfs:comment 'The temperature condition under which the specimen is stored, such as room temperature, refrigerated (2-8°C), frozen at -20°C, frozen at -80°C, or in liquid nitrogen. Critical for specimen stability and assay integrity.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCollected rdf:type rdf:Property ;
    rdfs:label 'Volume Collected' ;
    rdfs:comment 'The quantity of specimen collected, measured in the unit specified in volume_unit. Used to determine sufficiency for planned assays.' ;
    rdfs:domain ind:Biospecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentTherapeuticAreaId rdf:type rdf:Property ;
    rdfs:label 'Parent Therapeutic Area Id' ;
    rdfs:comment 'Self-referencing FK on therapeutic_area (parent_therapeutic_area_id)' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TherapeuticArea .

ind:areaDescription rdf:type rdf:Property ;
    rdfs:label 'Area Description' ;
    rdfs:comment 'Detailed description of the therapeutic area, including scope, disease categories, and clinical focus.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaName rdf:type rdf:Property ;
    rdfs:label 'Area Name' ;
    rdfs:comment 'Full name of the therapeutic area (e.g., Oncology, Immunology, Rare Diseases, Neuroscience, Cardiovascular).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakthroughTherapyEligible rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy Eligible' ;
    rdfs:comment 'Indicates whether products in this therapeutic area are typically eligible for breakthrough therapy designation due to serious or life-threatening conditions with unmet medical need.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessUnitOwner rdf:type rdf:Property ;
    rdfs:label 'Business Unit Owner' ;
    rdfs:comment 'Name of the business unit or division responsible for strategy, portfolio management, and commercial execution for this therapeutic area.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalTrialComplexityLevel rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Complexity Level' ;
    rdfs:comment 'Assessment of clinical trial design and execution complexity for this therapeutic area based on endpoint selection, patient recruitment challenges, and trial duration.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Commercial Priority Level' ;
    rdfs:comment 'Strategic priority level for commercial investment and market development in this therapeutic area.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstancePotential rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Potential' ;
    rdfs:comment 'Indicates whether products in this therapeutic area have potential for abuse or dependence requiring Drug Enforcement Administration (DEA) scheduling consideration.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diseaseCategory rdf:type rdf:Property ;
    rdfs:label 'Disease Category' ;
    rdfs:comment 'Primary disease category or pathology focus within the therapeutic area (e.g., Solid Tumors, Hematologic Malignancies, Autoimmune Disorders, Genetic Disorders).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastTrackEligible rdf:type rdf:Property ;
    rdfs:label 'Fast Track Eligible' ;
    rdfs:comment 'Indicates whether products in this therapeutic area are typically eligible for fast track designation to facilitate development and expedite review of drugs for serious conditions with unmet medical need.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalMarketSizeUsdMillions rdf:type rdf:Property ;
    rdfs:label 'Global Market Size Usd Millions' ;
    rdfs:comment 'Estimated global market size for this therapeutic area in millions of USD. Used for strategic planning and investment prioritization.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:icd10ChapterCode rdf:type rdf:Property ;
    rdfs:label 'Icd 10 Chapter Code' ;
    rdfs:comment 'ICD-10 chapter code representing the primary disease classification for this therapeutic area (e.g., C00-D49 for Neoplasms).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10ChapterName rdf:type rdf:Property ;
    rdfs:label 'Icd 10 Chapter Name' ;
    rdfs:comment 'ICD-10 chapter name describing the disease classification (e.g., Neoplasms, Diseases of the Circulatory System, Diseases of the Nervous System).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanismOfActionCategory rdf:type rdf:Property ;
    rdfs:label 'Mechanism Of Action Category' ;
    rdfs:comment 'High-level mechanism of action category for products in this therapeutic area (e.g., Targeted Therapy, Immunotherapy, Enzyme Replacement, Receptor Agonist).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDesignationEligible rdf:type rdf:Property ;
    rdfs:label 'Orphan Designation Eligible' ;
    rdfs:comment 'Indicates whether products in this therapeutic area are typically eligible for orphan drug designation due to rare disease prevalence (affecting fewer than 200,000 patients in the US or fewer than 5 in 10,000 in the EU).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientPopulationEstimate rdf:type rdf:Property ;
    rdfs:label 'Patient Population Estimate' ;
    rdfs:comment 'Estimated global patient population affected by diseases within this therapeutic area. Used for epidemiological analysis and market sizing.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pediatricFocus rdf:type rdf:Property ;
    rdfs:label 'Pediatric Focus' ;
    rdfs:comment 'Indicates whether this therapeutic area has a specific focus on pediatric populations, requiring pediatric investigation plans (PIP) or pediatric study plans (PSP).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectedCagrPercent rdf:type rdf:Property ;
    rdfs:label 'Projected Cagr Percent' ;
    rdfs:comment 'Projected compound annual growth rate (CAGR) for this therapeutic area market over the next 5 years, expressed as a percentage.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplexityLevel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Complexity Level' ;
    rdfs:comment 'Assessment of regulatory complexity for products in this therapeutic area based on approval pathway requirements, clinical endpoint challenges, and post-market obligations.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsTypicallyRequired rdf:type rdf:Property ;
    rdfs:label 'Rems Typically Required' ;
    rdfs:comment 'Indicates whether products in this therapeutic area typically require Risk Evaluation and Mitigation Strategies (REMS) due to serious safety concerns.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:researchPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Research Priority Level' ;
    rdfs:comment 'Strategic priority level for research and development investment in this therapeutic area.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicFranchise rdf:type rdf:Property ;
    rdfs:label 'Strategic Franchise' ;
    rdfs:comment 'Indicates whether this therapeutic area is designated as a strategic franchise with dedicated resources, leadership, and long-term investment commitment.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:therapeuticClass rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Class' ;
    rdfs:comment 'Pharmacological or therapeutic class of drugs within this area (e.g., Kinase Inhibitors, Monoclonal Antibodies, Immunomodulators, Gene Therapies).' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unmetMedicalNeedLevel rdf:type rdf:Property ;
    rdfs:label 'Unmet Medical Need Level' ;
    rdfs:comment 'Assessment of unmet medical need in this therapeutic area based on availability of effective treatments, disease burden, and patient outcomes.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentExcipientId rdf:type rdf:Property ;
    rdfs:label 'Parent Excipient Id' ;
    rdfs:comment 'Self-referencing FK on excipient (parent_excipient_id)' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Excipient .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether the excipient contains or is derived from known allergens. Critical for patient safety labeling and formulation risk assessment.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenType rdf:type rdf:Property ;
    rdfs:label 'Allergen Type' ;
    rdfs:comment 'Specific allergen classification if allergen_flag is true. Examples include lactose (milk-derived), gelatin (animal-derived), or gluten.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:animalDerivedFlag rdf:type rdf:Property ;
    rdfs:label 'Animal Derived Flag' ;
    rdfs:comment 'Indicates whether the excipient is derived from animal sources. Important for TSE/BSE risk assessment and religious/dietary considerations.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compendialGrade rdf:type rdf:Property ;
    rdfs:label 'Compendial Grade' ;
    rdfs:comment 'Pharmacopoeial grade or quality standard to which the excipient conforms. Indicates the regulatory monograph governing quality specifications.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compendialMonograph rdf:type rdf:Property ;
    rdfs:label 'Compendial Monograph' ;
    rdfs:comment 'Specific pharmacopoeial monograph reference number or title that defines quality standards, test methods, and acceptance criteria for the excipient.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipientCode rdf:type rdf:Property ;
    rdfs:label 'Excipient Code' ;
    rdfs:comment 'Unique business identifier or material master code for the excipient used across manufacturing, procurement, and formulation systems. Typically aligned with ERP material master.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excipientName rdf:type rdf:Property ;
    rdfs:label 'Excipient Name' ;
    rdfs:comment 'Common or trade name of the excipient as used in formulation documentation and manufacturing records.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCategory rdf:type rdf:Property ;
    rdfs:label 'Functional Category' ;
    rdfs:comment 'Primary functional role of the excipient in drug product formulation. Defines the excipient\'s purpose in the dosage form.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmoStatus rdf:type rdf:Property ;
    rdfs:label 'Gmo Status' ;
    rdfs:comment 'Indicates whether the excipient is derived from genetically modified organisms. Required for labeling in certain jurisdictions.' ;
    rdfs:domain ind:Excipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRecordId rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Record Id' ;
    rdfs:comment 'Unique identifier for the cold chain monitoring record. Primary key for the cold_chain_record product.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierBusinessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Carrier Business Partner Id' ;
    rdfs:comment 'Foreign key linking to masterdata.business_partner. Business justification: cold_chain_record.carrier_name is a denormalized plain-text field. Linking to masterdata.business_partner enables carrier qualification tracking, GDP deviation attribution to specific carriers, and ca' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:precedingColdChainRecordId rdf:type rdf:Property ;
    rdfs:label 'Preceding Cold Chain Record Id' ;
    rdfs:comment 'Self-referencing FK on cold_chain_record (preceding_cold_chain_record_id)' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ColdChainRecord .

ind:deviationReference rdf:type rdf:Property ;
    rdfs:label 'Deviation Reference' ;
    rdfs:comment 'The reference number of the quality deviation or non-conformance record associated with the temperature excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The category of temperature monitoring device used to capture the reading.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision Date' ;
    rdfs:comment 'The date when the quality disposition decision was made following excursion investigation and impact assessment.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:excursionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Excursion Duration Minutes' ;
    rdfs:comment 'The total duration in minutes that the temperature or humidity remained outside the acceptable range during the excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Excursion End Timestamp' ;
    rdfs:comment 'The date and time when the temperature or humidity returned to within the acceptable range, marking the end of the excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excursionFlag rdf:type rdf:Property ;
    rdfs:label 'Excursion Flag' ;
    rdfs:comment 'Boolean indicator whether this reading represents a temperature or humidity excursion outside the acceptable range. True indicates an excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excursionSeverity rdf:type rdf:Property ;
    rdfs:label 'Excursion Severity' ;
    rdfs:comment 'The severity classification of the temperature excursion based on the magnitude and duration of the deviation from acceptable range.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Excursion Start Timestamp' ;
    rdfs:comment 'The date and time when the temperature or humidity first exceeded the acceptable threshold, marking the beginning of the excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:humidityReadingPct rdf:type rdf:Property ;
    rdfs:label 'Humidity Reading Pct' ;
    rdfs:comment 'The relative humidity percentage recorded by the monitoring device, if humidity monitoring is required for the product.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'The category of location where the temperature monitoring occurred, indicating the supply chain segment.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Device Code' ;
    rdfs:comment 'Unique identifier of the temperature monitoring device or data logger used to capture the reading. Required for device calibration traceability.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringEventCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Event Code' ;
    rdfs:comment 'Business identifier for the temperature monitoring event or data collection session. Used for traceability and audit purposes.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'The precise date and time when the temperature or humidity reading was captured by the monitoring device. Critical for excursion analysis.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Boolean indicator whether the temperature excursion event requires reporting to regulatory authorities such as FDA, EMA, or other health agencies.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageConditionRequired rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Required' ;
    rdfs:comment 'The required storage condition classification for the pharmaceutical product as defined in the product specification and regulatory approval.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'The specific storage zone, room, or area within the facility where the product was located during monitoring.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxThresholdC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Threshold C' ;
    rdfs:comment 'The maximum acceptable temperature in degrees Celsius for the product storage condition. Readings above this trigger an excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinThresholdC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Threshold C' ;
    rdfs:comment 'The minimum acceptable temperature in degrees Celsius for the product storage condition. Readings below this trigger an excursion event.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureReadingC rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading C' ;
    rdfs:comment 'The actual temperature measurement in degrees Celsius recorded by the monitoring device at the reading timestamp.' ;
    rdfs:domain ind:ColdChainRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPaymentRunId rdf:type rdf:Property ;
    rdfs:label 'Prior Payment Run Id' ;
    rdfs:comment 'Self-referencing FK on payment_run (prior_payment_run_id)' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or acknowledgment number received from the bank or payment processor upon successful file receipt.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Number of payment transactions within the run that encountered errors or failed validation.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Consolidated error messages or failure reasons for the payment run, used for troubleshooting and resolution.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'The precise date and time when the payment run was executed and payments were initiated.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The accounting period date when the payment run transactions were posted to the general ledger.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isTestRun rdf:type rdf:Property ;
    rdfs:label 'Is Test Run' ;
    rdfs:comment 'Boolean flag indicating whether this is a test or simulation run (true) or a live production payment run (false).' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentCategory rdf:type rdf:Property ;
    rdfs:label 'Payment Category' ;
    rdfs:comment 'Classification of the payment run by recipient type or payment purpose for financial reporting and analysis.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCount rdf:type rdf:Property ;
    rdfs:label 'Payment Count' ;
    rdfs:comment 'Total number of individual payment transactions included in this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentFileName rdf:type rdf:Property ;
    rdfs:label 'Payment File Name' ;
    rdfs:comment 'Name of the payment file generated for transmission to the bank or payment processor.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFilePath rdf:type rdf:Property ;
    rdfs:label 'Payment File Path' ;
    rdfs:comment 'Storage location or file path where the payment file is archived for audit and compliance purposes.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRunDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Run Description' ;
    rdfs:comment 'Free-text description providing additional context about the purpose or scope of this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRunStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Run Status' ;
    rdfs:comment 'Current lifecycle status of the payment run in the payment processing workflow.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPriority rdf:type rdf:Property ;
    rdfs:label 'Processing Priority' ;
    rdfs:comment 'Priority level assigned to the payment run for queue management and execution sequencing.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciled Timestamp' ;
    rdfs:comment 'Date and time when the payment run was successfully reconciled with banking records.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business identifier for the payment run, formatted as PR-YYYYMMDD-NNNN for external reference and audit tracking.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payment run indicating its purpose and processing priority.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'The aggregate monetary value of all payments in this run before any adjustments or fees.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Date and time when the payment file was transmitted to the bank or payment processor.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date when funds are to be available to payees, used for cash flow planning and bank reconciliation.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:branchAddressId rdf:type rdf:Property ;
    rdfs:label 'Branch Address Id' ;
    rdfs:comment 'Foreign key linking to masterdata.address. Business justification: Bank branch address is required for correspondent banking documentation, regulatory filings, and KYC compliance. The plain branch_address and branch_city columns are denormalized; FK to address master' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:masterAccountBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Master Account Bank Account Id' ;
    rdfs:comment 'Reference to the master bank account if this is a subsidiary or zero balance account. Null if this is a standalone account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:parentBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Bank Account Id' ;
    rdfs:comment 'Self-referencing FK on bank_account (parent_bank_account_id)' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'The legal name of the primary account holder as registered with the bank.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Account Manager Email' ;
    rdfs:comment 'The email address of the bank relationship manager for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerName rdf:type rdf:Property ;
    rdfs:label 'Account Manager Name' ;
    rdfs:comment 'The name of the relationship manager or account officer at the bank responsible for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Account Manager Phone' ;
    rdfs:comment 'The phone number of the bank relationship manager for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'The business purpose or function of the bank account (e.g., operating expenses, payroll disbursement, R&D funding, royalty collections).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'The available balance in the bank account after accounting for holds, pending transactions, and reserved funds.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankIdentifierCode rdf:type rdf:Property ;
    rdfs:label 'Bank Identifier Code' ;
    rdfs:comment 'The BIC or SWIFT code uniquely identifying the financial institution for international transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'The legal name of the financial institution holding the account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCode rdf:type rdf:Property ;
    rdfs:label 'Branch Code' ;
    rdfs:comment 'The unique code identifying the bank branch within the financial institution\'s network.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'The name of the specific bank branch where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'The date when the bank account was closed or deactivated. Null if the account is still open.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'The current balance of the bank account in the account\'s primary currency as of the last reconciliation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The annual interest rate applied to the bank account balance, expressed as a decimal (e.g., 0.0250 for 2.50%).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryAccount rdf:type rdf:Property ;
    rdfs:label 'Is Primary Account' ;
    rdfs:comment 'Indicates whether this is the primary operating bank account for the legal entity or cost center.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isZeroBalanceAccount rdf:type rdf:Property ;
    rdfs:label 'Is Zero Balance Account' ;
    rdfs:comment 'Indicates whether this is a zero balance account that automatically sweeps funds to or from a master account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date when the bank account was last reconciled with bank statements.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Requirement' ;
    rdfs:comment 'The minimum balance that must be maintained in the account to avoid fees or penalties.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReconciliationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reconciliation Due Date' ;
    rdfs:comment 'The date by which the next bank reconciliation must be completed.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date when the bank account was opened and became active.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'The maximum overdraft or credit limit allowed on this bank account. Null if no overdraft facility exists.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The domestic routing number, ABA number, or sort code used to identify the bank branch for electronic transfers.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant Flag' ;
    rdfs:comment 'Indicates whether this bank account is subject to SOX compliance controls and audit requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditedInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Credited Invoice Id' ;
    rdfs:comment 'Self-referencing FK on invoice (credited_invoice_id)' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:invoiceBillToAddressId rdf:type rdf:Property ;
    rdfs:label 'Invoice Bill To Address Id' ;
    rdfs:comment 'Reference to the billing address where the invoice is sent.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:invoiceShipToAddressId rdf:type rdf:Property ;
    rdfs:label 'Invoice Ship To Address Id' ;
    rdfs:comment 'Reference to the shipping address where the goods or services were delivered.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'The end date of the period covered by this invoice, relevant for subscription or recurring billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'The start date of the period covered by this invoice, relevant for subscription or recurring billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which the customer raised a dispute for this invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-known unique business identifier for the invoice, used for customer communication and payment reference.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the accounts receivable workflow.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'The date on which payment for this invoice was received from the customer.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The date on which revenue from this invoice is recognized in the financial statements per GAAP revenue recognition rules.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'The shipping and handling charges included in this invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'The sum of all line item amounts before taxes, discounts, and adjustments.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committeeChairMasterId rdf:type rdf:Property ;
    rdfs:label 'Committee Chair Master Id' ;
    rdfs:comment 'Foreign key linking to hcp.master. Business justification: Hospital formulary P&T committees are chaired by HCPs. Pharma market access teams track the P&T committee chair as a key stakeholder for formulary pull-through and KOL engagement strategy. Role-prefix' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:parentFormularyId rdf:type rdf:Property ;
    rdfs:label 'Parent Formulary Id' ;
    rdfs:comment 'Self-referencing FK on formulary (parent_formulary_id)' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulary .

ind:copayStructure rdf:type rdf:Property ;
    rdfs:label 'Copay Structure' ;
    rdfs:comment 'The cost-sharing structure applied to drugs in this formulary (e.g., flat copayment, percentage coinsurance, deductible-based, or mixed model).' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRegion rdf:type rdf:Property ;
    rdfs:label 'Coverage Region' ;
    rdfs:comment 'Geographic region(s) where the formulary is applicable, represented as comma-separated ISO 3166-1 alpha-3 country codes or state/province codes.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL link to the official formulary document or drug list published for member and provider access.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionListUrl rdf:type rdf:Property ;
    rdfs:label 'Exclusion List Url' ;
    rdfs:comment 'URL link to the published list of drugs excluded from coverage under this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyCode rdf:type rdf:Property ;
    rdfs:label 'Formulary Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the formulary for external identification and system integration.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyName rdf:type rdf:Property ;
    rdfs:label 'Formulary Name' ;
    rdfs:comment 'The official name or title of the formulary as recognized by payers, pharmacy benefit managers (PBM), or health systems.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyType rdf:type rdf:Property ;
    rdfs:label 'Formulary Type' ;
    rdfs:comment 'Classification of the formulary based on the payer segment or market it serves (e.g., commercial insurance, Medicare Part D, Medicaid, health exchange, employer-sponsored, hospital, specialty pharmacy).' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genericSubstitutionPolicy rdf:type rdf:Property ;
    rdfs:label 'Generic Substitution Policy' ;
    rdfs:comment 'Policy governing whether and how generic drugs may be substituted for brand-name drugs under this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossToNetAdjustmentRate rdf:type rdf:Property ;
    rdfs:label 'Gross To Net Adjustment Rate' ;
    rdfs:comment 'The average percentage adjustment rate applied to gross drug prices to calculate net revenue after rebates, discounts, and other deductions for this formulary. Expressed as a percentage.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:htaSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Hta Submission Required' ;
    rdfs:comment 'Indicates whether health technology assessment submissions are required for drugs to be considered for inclusion in this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailOrderAvailable rdf:type rdf:Property ;
    rdfs:label 'Mail Order Available' ;
    rdfs:comment 'Indicates whether mail-order pharmacy services are available for drugs covered under this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientAccessProgramLinked rdf:type rdf:Property ;
    rdfs:label 'Patient Access Program Linked' ;
    rdfs:comment 'Indicates whether patient access programs (copay assistance, patient support services) are linked to drugs covered under this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityLimitsApplied rdf:type rdf:Property ;
    rdfs:label 'Quantity Limits Applied' ;
    rdfs:comment 'Indicates whether quantity limits (maximum dispensing quantities per prescription or time period) are enforced on drugs in this formulary.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rweDataConsidered rdf:type rdf:Property ;
    rdfs:label 'Rwe Data Considered' ;
    rdfs:comment 'Indicates whether real-world evidence and real-world data are considered in formulary decision-making and drug evaluations.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:therapeuticCategoriesCovered rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Categories Covered' ;
    rdfs:comment 'Comma-separated list of therapeutic categories or drug classes covered by this formulary (e.g., oncology, immunology, cardiovascular, diabetes).' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStructure rdf:type rdf:Property ;
    rdfs:label 'Tier Structure' ;
    rdfs:comment 'The tiering model used by the formulary to classify drugs by cost-sharing level (e.g., generic, preferred brand, non-preferred brand, specialty).' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDossierRequired rdf:type rdf:Property ;
    rdfs:label 'Value Dossier Required' ;
    rdfs:comment 'Indicates whether a value dossier (comprehensive evidence package demonstrating clinical and economic value) is required for formulary inclusion.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySalesBillToAddressId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Bill To Address Id' ;
    rdfs:comment 'Reference to the billing address for invoicing purposes.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:primarySalesContractAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Contract Account Id' ;
    rdfs:comment 'Reference to the customer or healthcare organization that placed the sales order.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAccount .

ind:referenceSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Reference Sales Order Id' ;
    rdfs:comment 'Self-referencing FK on sales_order (reference_sales_order_id)' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The date confirmed by logistics for delivery of the order to the customer.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'The commercial channel or route to market through which the order was placed.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'The system or channel through which the sales order was originally captured.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'Authorization number for product returns associated with this order, if applicable.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDistributionFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Distribution Flag' ;
    rdfs:comment 'Indicates whether this order includes or is exclusively for pharmaceutical sample distribution to healthcare professionals.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'The logistics method used to ship the order, particularly important for temperature-sensitive pharmaceutical products.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text field capturing any special handling, storage, or delivery instructions for the order, particularly for controlled substances or temperature-sensitive products.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallLotScopeId rdf:type rdf:Property ;
    rdfs:label 'Recall Lot Scope Id' ;
    rdfs:comment 'Primary key for the recall_lot_scope association' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedQuantityPerLot rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity Per Lot' ;
    rdfs:comment 'The quantity of this specific inventory lot that falls within the scope of the recall. Distinct from product_recall.quantity_distributed, which is the aggregate across all lots. Required for per-lot effectiveness check reporting to the FDA.' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionPerLot rdf:type rdf:Property ;
    rdfs:label 'Disposition Per Lot' ;
    rdfs:comment 'The approved disposition method for this specific lot as determined by quality review. May differ from the recall-level product_disposition on the parent recall record if lot-specific conditions (e.g., cold chain break, partial quantity) warrant a different disposition decision.' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the holder or custodian of this specific inventory lot has been formally notified of the recall. Tracked per lot because lots may be held at different locations (3PL, distributor, hospital) requiring separate notification actions.' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'The date on which this specific inventory lot was physically recovered, confirmed destroyed, or otherwise resolved within the recall process. Per-lot date required for FDA effectiveness check documentation.' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recoveryStatus rdf:type rdf:Property ;
    rdfs:label 'Recovery Status' ;
    rdfs:comment 'Current recovery status for this specific lot within the recall. Tracked independently per lot as different lots may be at different stages of recovery simultaneously. Cannot reside on inventory_lot (which reflects current inventory state) or product_recall (which is aggregate).' ;
    rdfs:domain ind:RecallLotScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalCaseSeriesId rdf:type rdf:Property ;
    rdfs:label 'Signal Case Series Id' ;
    rdfs:comment 'Primary key for the signal_case_series association' ;
    rdfs:domain ind:SignalCaseSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseContributionFlag rdf:type rdf:Property ;
    rdfs:label 'Case Contribution Flag' ;
    rdfs:comment 'Indicates whether this ICSR is a contributing (numerator) case in the disproportionality analysis for the signal, as opposed to a background reference case. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:SignalCaseSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseCount rdf:type rdf:Property ;
    rdfs:label 'Case Count' ;
    rdfs:comment 'Total number of Individual Case Safety Reports (ICSRs) or adverse event cases contributing to this safety signal at the time of detection or most recent assessment. Used as a threshold criterion alongside disproportionality metrics. [Moved from safety_signal: The aggregate case_count on safety_signal is a derived summary of the signal_case_series records. While the aggregate may be retained on safety_signal for performance/reporting purposes, the authoritative case-level data now lives in signal_case_series. If retained, it should be treated as a denormalized cache, not the source of truth.]' ;
    rdfs:domain ind:SignalCaseSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectionRunDate rdf:type rdf:Property ;
    rdfs:label 'Detection Run Date' ;
    rdfs:comment 'Date of the specific signal detection run during which this ICSR was identified as contributing to the safety signal. Belongs to the relationship, not to the signal or the ICSR alone. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:SignalCaseSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disproportionalityContributionScore rdf:type rdf:Property ;
    rdfs:label 'Disproportionality Contribution Score' ;
    rdfs:comment 'Per-case contribution score to the aggregate disproportionality metric (PRR/ROR/EBGM/IC) for this signal. Quantifies how much this individual ICSR influences the signal strength. Belongs to the relationship, not to either entity alone. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:SignalCaseSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meddraPtCodeMatched rdf:type rdf:Property ;
    rdfs:label 'Meddra Pt Code Matched' ;
    rdfs:comment 'The specific MedDRA Preferred Term code from the ICSR that matched the signal\'s MedDRA PT during the detection run. An ICSR may have multiple MedDRA terms; this records which one drove the case\'s inclusion in this signal\'s case series. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:SignalCaseSeries ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedPatentScheduleId rdf:type rdf:Property ;
    rdfs:label 'Licensed Patent Schedule Id' ;
    rdfs:comment 'Primary key for the licensed_patent_schedule association' ;
    rdfs:domain ind:LicensedPatentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licensedScope rdf:type rdf:Property ;
    rdfs:label 'Licensed Scope' ;
    rdfs:comment 'Narrative or structured description of which patent claims, fields of use, or indications are licensed under this agreement for this specific patent. A patent may be partially licensed (e.g., only method-of-use claims, not composition claims). Cannot reside on the agreement (varies per patent) or on the patent (varies per agreement).' ;
    rdfs:domain ind:LicensedPatentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePerPatent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Per Patent' ;
    rdfs:comment 'The royalty rate (expressed as a percentage of net sales or a fixed per-unit amount) applicable specifically to this patent under this agreement. In multi-patent deals, individual patents may carry different royalty rates reflecting their relative commercial importance. Cannot reside on licensing_agreement (which may aggregate rates) or on patent (which may be licensed at different rates to different partners).' ;
    rdfs:domain ind:LicensedPatentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmfCrossReferenceId rdf:type rdf:Property ;
    rdfs:label 'Dmf Cross Reference Id' ;
    rdfs:comment 'Primary key for the dmf_cross_reference association' ;
    rdfs:domain ind:DmfCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Access Granted Date' ;
    rdfs:comment 'Date on which the applicant was formally granted access to reference the DMF content within their application. Marks the effective start of the cross-reference authorization for this DMF-application pair.' ;
    rdfs:domain ind:DmfCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationLetterReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Letter Reference' ;
    rdfs:comment 'The document reference number of the Letter of Authorization issued by the DMF holder for this specific DMF-application cross-reference. Unique to each LoA issued.' ;
    rdfs:domain ind:DmfCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Cross Reference Number' ;
    rdfs:comment 'The FDA-assigned identifier for this specific DMF citation within the regulatory application dossier. Assigned by the agency upon receipt and used to track the cross-reference in the review process.' ;
    rdfs:domain ind:DmfCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossReferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Cross Reference Status' ;
    rdfs:comment 'Current lifecycle status of this DMF cross-reference authorization within the application. Tracks whether the authorization is active, has been withdrawn by the DMF holder, or is pending receipt of the LoA.' ;
    rdfs:domain ind:DmfCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referencingApplicationCount rdf:type rdf:Property ;
    rdfs:label 'Referencing Application Count' ;
    rdfs:comment 'Number of regulatory applications (NDA, BLA, ANDA, MAA) that currently reference this DMF. Indicates the strategic importance of the DMF to the product portfolio and the breadth of supplier dependency. [Moved from dmf: This is a derived count of how many applications reference this DMF. It is a denormalized summary that can be computed from the dmf_cross_reference association table (COUNT of application_id grouped by dmf_id). Storing it on the DMF entity creates a maintenance burden and data integrity risk. It should be removed from dmf and derived from this association.]' ;
    rdfs:domain ind:DmfCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteActivationId rdf:type rdf:Property ;
    rdfs:label 'Site Activation Id' ;
    rdfs:comment 'Primary key for the site_activation association' ;
    rdfs:domain ind:SiteActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .
