# RDFS Schema for Business: Manufacturing

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/manufacturing#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Manufacturing ---
ind:Manufacturing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Manufacturing' ;
    rdfs:comment 'Industrial Manufacturing encompasses the design, production, and delivery of automation systems, electrification solutions, and smart infrastructure components for factories, buildings, transportation, and urban environments.' .

# --- Domain Classes ---
ind:Production rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production' ;
    rdfs:comment 'Core manufacturing execution domain governing shop floor control, work orders, routing, scheduling, WIP tracking, cycle time, takt time, throughput, and OEE. Integrates with MES (Siemens Opcenter) and ERP (SAP PP) to orchestrate production runs, machine assignments, capacity planning, and shift-level output reporting via SCADA/DCS systems.' .

ind:Engineering rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Engineering' ;
    rdfs:comment 'Product design and engineering lifecycle domain covering CAD/CAM models, BOMs, ECOs, ECNs, DFM analysis, DFMEA, PFMEA, and PLM data managed in Siemens Teamcenter. Serves as the SSOT for product structure, revision history, engineering change governance, technical specifications, drawings, and prototypes for all manufactured automation systems.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Quality' ;
    rdfs:comment 'Quality assurance and control domain encompassing SPC, Cp/Cpk indices, inspection plans, NCRs, CAPAs, PPAP, APQP, and FMEA records. Manages in-process and final inspection results, supplier quality audits, compliance testing, and regulatory conformance data aligned with ISO 9001 and SAP QM.' .

ind:Asset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Asset' ;
    rdfs:comment 'Equipment and asset lifecycle management domain tracking physical assets, machinery maintenance (CMMS), preventive maintenance scheduling, TPM, work order execution, MTBF/MTTR analysis, downtime events, spare parts, condition monitoring, and CapEx asset registers via Maximo. Manages production equipment, PLCs, CNC machines, robotics, and facility infrastructure.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Inventory and warehouse management domain governing raw materials, WIP, finished goods, SKUs, lot/batch tracking, bin locations, cycle counts, stock movements, JIT inventory control, safety stock optimization, and material handling across all facilities. Integrates SAP WM and Microsoft Dynamics 365 SCM for real-time stock visibility and MRP-driven replenishment.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Supply' ;
    rdfs:comment 'Supply chain planning and demand management domain covering MRP/MRP II runs, demand forecasting, capacity planning, APS scheduling, supplier lead times, MOQ management, supply risk, multi-tier supplier coordination, and supply network optimization. Integrates Microsoft Dynamics 365 SCM and SAP PP/MM for end-to-end supply network visibility.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Customer identity and account management domain serving as the SSOT for all B2B industrial customers, OEM accounts, distributors, and end-user organizations. Manages customer profiles, contacts, account hierarchies, segmentation, credit terms, relationship history, and SLA agreements via Salesforce CRM.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Product' ;
    rdfs:comment 'Product catalog and offering management domain serving as the SSOT for all manufactured products, automation systems, electrification solutions, and smart infrastructure components. Manages SKU master data, product families, configurations, pricing structures, product lifecycle stages from NPI to end-of-life, and product portfolio management.' .

ind:Sales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Sales' ;
    rdfs:comment 'Sales and commercial domain managing the revenue pipeline including opportunities, quotes, proposals, contracts, order intake, sales pipeline tracking, territory management, and commercial KPIs for industrial automation and electrification products via Salesforce Sales Cloud.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Order' ;
    rdfs:comment 'Order management and fulfillment domain governing the end-to-end order lifecycle from customer purchase orders through production scheduling, shipment, and delivery confirmation. Manages order headers, line items, delivery schedules, RMAs, fulfillment SLAs, and customer order lifecycle via SAP SD.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Supplier relationship and performance management domain tracking supplier profiles, qualification status, scorecards, audit results, certifications, risk ratings, and long-term relationship data. Distinct from procurement transactions — this domain owns the supplier identity and master data used across procurement, quality, and supply chain.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Corporate finance and cost management domain governing general ledger, cost centers, profit centers, accounts payable, CapEx/OpEx tracking, EBITDA reporting, budgeting, financial planning and analysis, and financial consolidation via SAP FI/CO. Serves as SSOT for all internal financial structures and management accounting aligned with IFRS/GAAP.' .

# --- Data Product Classes (Tables) ---
ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account' ;
    rdfs:comment 'Master record for all B2B industrial customers, OEM accounts, distributors, and end-user organizations. Serves as the SSOT for customer identity in Salesforce CRM (Account object) and SAP Business Partner. Captures legal entity name, industry classification (SIC/NAICS), account type (OEM, distributor, system integrator, end-user, EPC contractor), account status with full lifecycle history, annual revenue, employee count, DUNS number, tax ID, VAT registration, credit rating, assigned account manager, parent account reference, and strategic account flag. Foundation entity referenced by all other products in this domain and cross-referenced by sales, service, order, and billing domains. Corporate hierarchy and commercial relationships are managed in account_relationship.' .

ind:CustomerContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Customer Contact' ;
    rdfs:comment 'Individual person records associated with customer accounts representing key stakeholders at B2B industrial organizations — including design engineers, procurement managers, plant managers, maintenance supervisors, and executive sponsors. Maps to Salesforce CRM Contact object. Captures full name, job title, department, phone, email, preferred communication channel, language preference, marketing consent status, decision-making role (technical evaluator, commercial buyer, executive approver), and active/inactive status. Serves as the SSOT for person-level engagement across sales, service, and marketing.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Market segmentation classification for customer accounts used in sales strategy, pricing tiers, and service prioritization. Captures segment name (Strategic, Key Account, Growth, Transactional), segment criteria, revenue band, industry vertical, geographic region, assigned segment manager, and review cycle. Enables targeted commercial strategies for OEMs, distributors, and end-users.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical and mailing address records for customer accounts and contacts, including headquarters, billing address, shipping/delivery address, and plant site addresses. Captures address type, street lines, city, state/province, postal code, country, geocoordinates, validated flag, and primary address indicator. Supports logistics, invoicing, and field service dispatch.' .

ind:CreditProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Credit Profile' ;
    rdfs:comment 'Customer credit assessment and terms management record. Captures credit limit, credit rating, payment terms (Net 30, Net 60, Net 90), currency, credit hold status, credit hold reason, last credit review date, next review date, credit insurance policy reference, outstanding balance, and days sales outstanding (DSO). Managed in SAP S/4HANA FI-AR and synchronized with Salesforce CRM.' .

ind:SlaAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Sla Agreement' ;
    rdfs:comment 'Service Level Agreement records defining contractual service commitments to industrial customers, including response time SLAs, uptime guarantees, on-time delivery targets, and support tier entitlements. Captures SLA type, tier (Platinum, Gold, Silver, Bronze), response time thresholds, resolution time thresholds, penalty clauses, effective date, expiry date, and associated account. Managed via Salesforce Service Cloud.' .

ind:AccountSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Site' ;
    rdfs:comment 'Physical plant, factory, or facility locations associated with a customer account where Manufacturing products are installed, delivered, or serviced. Captures site name, site type (manufacturing plant, warehouse, distribution center, data center, commercial building, substation), address reference, site contact, installed product count, site criticality rating, site status (active, decommissioned, under construction), operational hours, and environmental/safety classification. Enables field service dispatch, logistics planning, installed base tracking, and preventive maintenance scheduling at customer locations.' .

ind:EquipmentRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Equipment Register' ;
    rdfs:comment 'Master record of all physical assets and production equipment in the CapEx asset register, including CNC machines, PLCs, robotics, conveyors, HVAC, and facility infrastructure. Serves as the SSOT for equipment identity, classification, parent-child hierarchy (structural decomposition into sub-assemblies and components), installation details, manufacturer specifications, commissioning date, depreciation method, book value, current operational status, criticality ranking, and location assignment history (including transfer/relocation audit trail with origin, destination, reason, condition at transfer, and authorization reference). Sourced from Maximo Asset Management and SAP S/4HANA PM module.' .

ind:Location rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Location' ;
    rdfs:comment 'Hierarchical location structure for physical asset placement, covering plant, building, floor, production line, work center, and exact bay/cell coordinates with optional GIS/GPS reference points. Tracks functional location hierarchy per Maximo FL structure and IEC 81346 reference designation system, enabling spatial queries for maintenance routing, safety zone mapping, environmental zone classification (ATEX zones, clean rooms), and OEE analysis by location. Serves as the SSOT for where assets can be installed and the physical topology of the manufacturing facility.' .

ind:AssetWorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Asset Work Order' ;
    rdfs:comment 'Maintenance work order record capturing all maintenance activity types executed against equipment assets: corrective, preventive, predictive, condition-based, emergency, and shutdown/turnaround maintenance. Tracks work order type, priority, TPM pillar classification, originating failure code, assigned craft/trade, planned vs actual labor hours, planned vs actual material costs, spare parts reserved and consumed (part number, quantity, issue date, cost), start/finish dates, downtime duration, and completion status. For shutdown-type work orders, additionally captures scope of work summary, affected production lines, shutdown coordinator, planned start/end dates, and estimated total cost. Core transactional entity sourced from Maximo Work Management module and SAP PM orders. Serves as the SSOT for all maintenance execution activity.' .

ind:PmSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Pm Schedule' ;
    rdfs:comment 'Preventive maintenance schedule master defining recurring maintenance tasks, inspection intervals, trigger types (calendar-based, meter-based, condition-based), and TPM task sequences for each equipment asset. Stores frequency, last completion date, next due date, estimated duration, required craft skills, and associated job plan reference. Supports TPM pillar execution and regulatory inspection compliance.' .

ind:JobPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Job Plan' ;
    rdfs:comment 'Standardized job plan (task list) defining the step-by-step maintenance procedure, required labor crafts, estimated hours per task step, safety precautions, required tools, and spare parts for a specific maintenance activity type. Acts as the reusable template applied to work orders and PM schedules. Sourced from Maximo Job Plans and SAP PM Task Lists.' .

ind:FailureRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Failure Record' ;
    rdfs:comment 'Failure event record capturing equipment breakdowns and fault occurrences, including failure date/time, failure class, failure mode code, failure cause code, remedy code, affected component, downtime start/end, production impact (units lost), and MTBF contribution data. Embeds the full failure mode classification taxonomy: failure mode description, affected component class, potential cause, detection method, severity rating, occurrence rating, detection rating, and RPN (Risk Priority Number) derived from FMEA/PFMEA analysis. Serves as both the transactional failure event record and the reference catalog for standardized failure modes per equipment class. Feeds MTBF/MTTR reliability analysis, FMEA validation, and maintenance strategy selection. Sourced from Maximo Failure Reporting and SAP PM Notifications.' .

ind:AssetDowntimeEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Asset Downtime Event' ;
    rdfs:comment 'Discrete downtime event record tracking unplanned and planned equipment stoppages on the shop floor, including start timestamp, end timestamp, total duration minutes, downtime category (breakdown, changeover, planned maintenance, tooling, material shortage, quality hold, no operator), affected equipment asset, affected production line, shift context, root cause code, and OEE availability impact percentage. Integrates with MES/SCADA downtime capture systems and manual operator entry. Feeds OEE calculation pipelines, downtime Pareto analysis, and production loss costing. Serves as the SSOT for all equipment stoppage events regardless of cause.' .

ind:ConditionReading rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Condition Reading' ;
    rdfs:comment 'Time-series asset measurement record capturing condition monitoring data (vibration, temperature, pressure, oil viscosity, acoustic emission, ultrasound) and cumulative meter/counter readings (runtime hours, cycle counts, production units, energy consumption, distance traveled) from equipment sensors, IIoT gateways, SCADA systems, and manual operator inputs. Stores reading timestamp, sensor/meter identifier, reading type (condition indicator vs cumulative meter), measurement unit, current value, delta since last reading, threshold breach flag, alert severity, and reading source. Serves as the single source of truth for all equipment measurement data — supports predictive maintenance (PdM) trigger logic, condition-based maintenance (CBM), meter-based PM schedule triggering, lubrication route monitoring, and asset utilization rate calculation.' .

ind:SparePart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Spare Part' ;
    rdfs:comment 'Spare parts and MRO (Maintenance, Repair, and Operations) materials master record specific to asset maintenance, including part number, description, manufacturer part number, OEM compatibility list (linked to equipment classes and specific assets), criticality classification (insurance spares, critical, non-critical), ABC classification for inventory prioritization, reorder point, safety stock level, lead time, unit of measure, storeroom bin location, interchangeability/supersession chain, and shelf life expiry where applicable. Distinct from production inventory — focused on maintenance-specific materials managed in Maximo Inventory and SAP MM-PM integration. Serves as the SSOT for maintenance material identity and stocking parameters.' .

ind:InspectionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Inspection Event' ;
    rdfs:comment 'Formal equipment inspection event record capturing scheduled and ad-hoc inspections including safety inspections, regulatory compliance inspections (OSHA, UL, CE), and quality-related equipment audits. Stores inspection type, inspector identity, inspection date, checklist results, pass/fail outcome, findings count, corrective action required flag, and next inspection due date.' .

ind:CalibrationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Calibration Record' ;
    rdfs:comment 'Instrument and measurement equipment calibration record tracking calibration events for gauges, sensors, PLCs, and precision measurement tools. Captures calibration date, calibration standard used, as-found reading, as-left reading, tolerance limits, pass/fail result, calibration interval, next due date, and certifying technician. Supports ISO 9001 measurement system compliance and SPC instrument traceability.' .

ind:InspectionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Plan' ;
    rdfs:comment 'Master definition of inspection plans aligned with SAP QM, specifying inspection characteristics, sampling procedures, control methods, and acceptance criteria for in-process and final inspection operations. Covers PPAP, APQP, and routine production inspection plans per ISO 9001 requirements.' .

ind:InspectionLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Lot' ;
    rdfs:comment 'Transactional inspection lot record representing a single inspection event triggered by goods receipt, production order completion, in-process milestone, periodic schedule, or customer return receipt. Captures lot origin, material/part reference, inspection quantity, inspection type (incoming, in-process, final, recurring, RMA-receipt), current status (created, released, results-recorded, usage-decided), and disposition decision (accept, reject, rework, scrap). Links to inspection plan for execution instructions and generates inspection_result child records. Triggers NCR creation upon reject disposition or non-conformance detection. Central transactional entity for quality execution aligned with SAP QM inspection lot processing.' .

ind:InspectionResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Detailed measurement and characteristic result records captured during inspection lot execution. Stores individual measured values, attribute results (pass/fail), SPC data points, Cp/Cpk indices, and defect codes per inspection characteristic. Feeds SPC charts and process capability reporting.' .

ind:Ncr rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Ncr' ;
    rdfs:comment 'Non-Conformance Report (NCR) serving as the single, unified quality event record for ALL deviations from specifications, standards, or requirements regardless of detection source or reporting channel. Encompasses internal defects, customer complaints (including 8D problem-solving), supplier non-conformances, field returns/RMA dispositions, and audit-triggered findings. Captures non-conformance type (internal/customer/supplier/field-return/audit), affected material/product/serial number, detection source (incoming inspection, in-process, final inspection, field/customer, audit, supplier delivery), severity classification, containment actions, root cause analysis, disposition decision (use-as-is, rework, scrap, return-to-supplier, repair, replace, credit, no-fault-found), RMA tracking fields (return authorization number, customer reference, repair actions, return shipment status), SAP QM notification type mapping (Q1/Q2/Q3), and linkage to CAPA for corrective/preventive action. Supports 8D methodology for customer-facing issues. Aligned with ISO 9001 clause 8.7 (control of nonconforming outputs), clause 10.2 (corrective action), and integrates with Salesforce Service Cloud for customer-originated events.' .

ind:Capa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Capa' ;
    rdfs:comment 'Corrective and Preventive Action (CAPA) record managing the full lifecycle of quality improvement actions triggered by NCRs, audit findings, customer complaints, or internal quality events. Tracks root cause analysis (5-Why, Ishikawa), corrective action plan, preventive action plan, responsible owner, target dates, verification of effectiveness, and closure status per ISO 9001 clause 10.2.' .

ind:Fmea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Fmea' ;
    rdfs:comment 'Failure Mode and Effects Analysis (FMEA) master record covering both DFMEA (Design FMEA) and PFMEA (Process FMEA). Stores failure modes, effects, causes, current controls, severity/occurrence/detection ratings, Risk Priority Number (RPN), recommended actions, and revised RPN after action implementation. Managed in Siemens Teamcenter PLM and aligned with AIAG-VDA FMEA methodology.' .

ind:ControlPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Control Plan' ;
    rdfs:comment 'Manufacturing control plan defining the process controls, inspection frequency, measurement methods, reaction plans, and control limits for each critical-to-quality (CTQ) characteristic at each process step. Links to PFMEA and inspection plans. Core APQP deliverable managed per AIAG standards and ISO 9001 clause 8.5.' .

ind:CustomerComplaint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Customer Complaint' ;
    rdfs:comment 'Customer complaint and field quality issue record capturing reported defects, failures, or dissatisfaction from OEM customers, distributors, or end users. Tracks complaint description, affected product/serial number, failure mode, 8D problem-solving steps, containment actions, root cause, corrective actions, and customer response. Integrates with Salesforce Service Cloud and SAP QM QN.' .

ind:QualityAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Quality Audit' ;
    rdfs:comment 'Quality audit record documenting all scheduled and unscheduled audits regardless of target — internal departments, supplier facilities, subcontractor sites, or customer-mandated assessments. Captures audit type (system audit, process audit, product audit, layered process audit), target scope (internal department/process, supplier site, subcontractor, remote), audit program/schedule reference, checklist criteria and results, findings classification (major non-conformance, minor non-conformance, observation, opportunity for improvement), audit score/rating, auditor qualification and independence verification, evidence collected, corrective action requirements with CAPA linkage, re-audit schedule, and closure status. Supports ISO 9001 clause 9.2 (internal audit), clause 8.4 (externally provided processes — supplier control), VDA 6.3 process audit methodology, and SAP Ariba supplier qualification workflows.' .

ind:StockLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Location' ;
    rdfs:comment 'Master record for all physical storage locations within warehouses and facilities, including bin, rack, shelf, zone, and aisle designations. Captures location type (bulk, pick, reserve, staging), capacity constraints, temperature and environmental requirements, and coordinate-based bin addressing. Serves as the single source of truth for all bin-level location data used for real-time stock placement, retrieval, and directed put-away across all manufacturing facilities.' .

ind:Warehouse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Warehouse' ;
    rdfs:comment 'Master record for each physical warehouse or storage facility in the manufacturing network. Captures warehouse code, name, address, facility type (raw material, WIP, finished goods, distribution), total capacity, climate control capabilities, and operational status. Serves as the top-level organizational unit for all inventory storage hierarchies and warehouse management operations.' .

ind:MaterialMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Material Master' ;
    rdfs:comment 'Authoritative master record for every raw material, component, sub-assembly, WIP item, and finished good managed in inventory. Captures SKU code, material description, material type (raw, semi-finished, finished), base unit of measure, weight, dimensions, shelf life, hazardous material classification, planning type, reorder point, safety stock level, ABC classification, and storage conditions. Serves as the single source of truth for material identity and attributes referenced by all inventory transactions, stock balances, and planning processes across the enterprise.' .

ind:StockBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Balance' ;
    rdfs:comment 'Current and period-end stock balance record capturing on-hand quantity by stock category (unrestricted, quality inspection, blocked, in-transit, reserved) for each material at each storage location. Tracks valuation price, total stock value, last physical count date, and last movement date. Serves as the single source of truth for real-time stock position used by material planning, available-to-promise calculations, and inventory reporting across all facilities.' .

ind:LotBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Lot Batch' ;
    rdfs:comment 'Lot and batch master record for materials subject to batch management, capturing batch number, material reference, manufacturing date, expiry date, shelf life expiration date (SLED), batch status (unrestricted, restricted, blocked), origin plant, supplier batch number, and quality inspection results. Supports full lot traceability from raw material receipt through production and customer shipment per ISO 9001 and PPAP requirements.' .

ind:StockMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Movement' ;
    rdfs:comment 'Transactional record of every inventory movement event including goods receipts, goods issues, stock transfers, internal transfers between bins, returns, adjustments, write-offs, and scrapping. Captures movement type code, quantity, unit of measure, source and destination storage locations, plant, cost center, reference document (purchase order, production order, delivery, cost center), posting date, movement reason code, picker/operator assignment, and confirmation status. Serves as the single source of truth for all inventory transaction activity, supporting stock balance updates, audit trails, and material document history across all facilities.' .

ind:CycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Cycle count event header record capturing scheduled and ad-hoc physical inventory counts for specific materials, storage locations, or zones. Tracks count document number, count date, count type (ABC cycle, annual physical, ad-hoc recount), counter assignment, zone or location scope, planned vs actual count date, overall variance summary, approval status, and posting status. Supports ABC-based cycle count programs, annual physical inventory compliance, and inventory accuracy KPI tracking.' .

ind:CycleCountLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count Line' ;
    rdfs:comment 'Individual line item within a cycle count document representing the count result for a specific material-batch-bin combination. Captures line number, material, batch, storage bin, book quantity, counted quantity, difference quantity, unit of measure, recount indicator, and posting result. Enables granular variance analysis and audit trail for physical inventory reconciliation per ISO 9001 inventory accuracy requirements.' .

ind:ReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Replenishment Order' ;
    rdfs:comment 'Planning-driven, kanban-triggered, or manually-created replenishment and reservation record for restocking materials to safety stock or reorder point levels, or committing stock for planned consumption. Captures order number, material, plant, storage location, replenishment type (planning-driven, kanban, min-max, JIT, manual reservation), required quantity, requested delivery date, source (purchase requisition, production order, stock transfer), reference order (production order, sales order, maintenance order), priority, reserved quantity, and fulfillment status. Unifies demand commitment and replenishment execution into a single record for available-to-promise calculation.' .

ind:SerializedUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Serialized Unit' ;
    rdfs:comment 'Individual unit tracking record for serialized components, assemblies, finished goods, and handling units (pallets, containers, totes, drums, reels) managed by unique identifier throughout their inventory lifecycle. Captures serial/unit number, material, unit type (serialized part, pallet, container, tote), contents (for handling units), batch, quantity, gross/net weight, dimensions, current plant and storage location, status (in stock, in production, shipped, returned, scrapped), seal number, and last movement timestamp. Provides pallet-level and serial-level traceability for warehouse operations, field service, and regulatory compliance.' .

ind:Component rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Component' ;
    rdfs:comment 'Master record for every discrete engineered part, sub-assembly, or raw material managed in PLM. Serves as the SSOT for component identity, revision state, lifecycle phase, engineering classification, material specification, weight, dimensional envelope, tolerance class, CAD model reference, PLM item ID, and approved substitutes. Covers all manufactured automation system components including electrification modules, PLCs, HMIs, drives, sensors, and structural enclosures. Includes classification taxonomy (commodity, technology family, functional group) for BOM analytics and sourcing alignment.' .

ind:Bom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Bom' ;
    rdfs:comment 'Bill of Materials master record defining the structured product hierarchy for a given component or finished assembly at a specific revision. Captures BOM type (engineering BOM, manufacturing BOM, service BOM), effectivity dates, quantity basis, unit of measure, and the owning PLM item. Acts as the SSOT for product structure consumed by MRP, MES, and production planning.' .

ind:EngineeringBomLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Engineering Bom Line' ;
    rdfs:comment 'Individual line item within a Bill of Materials, representing a single parent-child component relationship. Captures position number, find number, quantity per assembly, unit of measure, reference designator, substitute component references (approved alternates with qualification status and usage restrictions), phantom flag, effectivity start/end dates, and engineering notes. Enables full BOM explosion and implosion queries for MRP, supports alternate sourcing without ECO, and provides the granular structure for production routing and cost rollup.' .

ind:Drawing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Drawing' ;
    rdfs:comment 'Engineering drawing record representing the formal 2D technical drawing released for a component or assembly. Captures drawing number, revision level, sheet count, drawing standard (ISO, ANSI), tolerance class, surface finish specification, material callout, approval status, release date, and associated CAD model reference. Serves as the authoritative manufacturing and inspection reference document.' .

ind:Eco rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Eco' ;
    rdfs:comment 'Engineering Change Order — the formal governance record initiating, tracking, approving, and closing a controlled change to a released product design. Captures ECO number, change type (design, material, process), priority, reason code, affected items with disposition (use-as-is, rework, scrap, retrofit), effectivity date, cost/schedule impact, initiator, approver chain, closure status, and revision transition (from/to). Includes affected item detail: item reference, type, current/proposed revision, disposition action, quantity affected, and implementation status per item. Upon approval, also serves as the Engineering Change Notice (ECN) — the formal communication record distributed to production, supply chain, quality, and supplier portals capturing notification distribution list, acknowledgement tracking, implementation date, and affected BOM/drawing revisions. SSOT for engineering change governance and change communication per ISO 9001 change control requirements.' .

ind:Ecn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Ecn' ;
    rdfs:comment 'Engineering Change Notice — the released notification record that communicates an approved and implemented engineering change to all affected stakeholders including production, supply chain, and quality. Captures ECN number, linked ECO, effective revision transition (from/to), implementation date, affected BOM revisions, affected drawings, distribution list, and acknowledgement tracking. Downstream consumers include MES, MRP, and supplier portals.' .

ind:EngineeringRevision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Engineering Revision' ;
    rdfs:comment 'Revision history record for a component or assembly, capturing each discrete revision state managed in PLM. Tracks revision label (A, B, C or 01, 02), lifecycle state (in-work, released, obsolete), release date, superseded revision, release authority, change justification summary, linked ECO, and effectivity window. Provides full revision lineage for traceability, regulatory compliance, configuration audits, and as-designed vs as-built reconciliation. Supports multi-level revision schemes (major/minor) and parallel branch revisions for variant management.' .

ind:EngineeringSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Engineering Specification' ;
    rdfs:comment 'Engineering specification document record defining technical requirements, performance criteria, material standards, and acceptance criteria for a component, assembly, or system. Captures specification number, revision, specification type (material, functional, interface, environmental, safety), applicable standards (IEC, ISO, UL, CE), scope description, approval status, and linked components. Serves as the authoritative technical requirements baseline for design validation and supplier qualification.' .

ind:Project rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Project' ;
    rdfs:comment 'Engineering project master record representing a discrete R&D or product development initiative. Captures project code, project name, project type (new product development, product improvement, platform, cost reduction), program phase (concept, development, validation, launch), target launch date, project manager, budget allocation, priority, and linked product family. Serves as the organizing entity for all engineering deliverables, prototypes, and design reviews within a development program.' .

ind:TestResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Engineering test and validation result record capturing outcomes of design verification and validation (DV&V) activities performed on prototypes, pre-production units, or production samples. Captures test type (functional, environmental, EMC, safety, endurance, performance, reliability), test standard reference, tested unit identification (prototype phase, build number, component revision), test date, test facility, pass/fail outcome, measured values vs acceptance criteria, failure description, linked DFMEA failure mode, and prototype build context (phase, purpose, disposition). Supports DVP&R evidence for PPAP, regulatory certification submissions, and R&D program milestone tracking.' .

ind:ProductionWorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Production Work Order' ;
    rdfs:comment 'Core manufacturing work order representing a discrete production job issued to the shop floor. Authorizes manufacture of a specific quantity of finished or semi-finished goods by linking a routing, BOM revision, and production version. Tracks planned vs. actual dates, priority, order status, WIP value, and completion percentage. The SSOT for all production execution activity within this domain. Sourced from ERP production orders (e.g., SAP PP) and MES work order management (e.g., Siemens Opcenter).' .

ind:Schedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Schedule' ;
    rdfs:comment 'Master production schedule (MPS) record defining planned production quantities, start/finish dates, and shift assignments for a given production item across a planning horizon. Tracks schedule version, freeze horizon, planning bucket (daily/weekly), and schedule status (draft, released, frozen, revised). Represents the output of APS/MRP II scheduling runs. Sourced from ERP production planning (e.g., SAP PP) and APS systems (e.g., Microsoft Dynamics 365 Supply Chain).' .

ind:WorkCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'Master data entity representing a physical or logical production resource on the shop floor — a machine, assembly cell, production line segment, or labor group — at which manufacturing operations are performed. Captures work center code, plant, cost center linkage, capacity category, available capacity per shift, efficiency rate, utilization rate, and OEE baseline target. The SSOT for capacity planning and routing assignments within the production domain. Sourced from ERP work center master (e.g., SAP CR01).' .

ind:Routing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Routing' ;
    rdfs:comment 'Manufacturing routing master defining the ordered sequence of operations required to produce a finished or semi-finished item. Captures routing number, routing type (production, inspection, universal), base quantity, status, and validity dates. Each routing is composed of individual operations (modeled as line items) linked to work centers with standard times for setup, machine run, and labor. The SSOT for standard production process definitions. Sourced from ERP routing master (e.g., SAP CA01) and PLM process plans (e.g., Siemens Teamcenter).' .

ind:Shift rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Shift definition master representing a named working period pattern for a plant or work center. Defines shift code, start/end times, break structure, net available minutes, and shift type (regular, overtime, weekend). Used as the time-boundary reference for capacity planning, OEE shift-level reporting, takt time calculation, and workforce scheduling integration.' .

ind:ShiftReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Shift Report' ;
    rdfs:comment 'Shift-level production performance report capturing actual results for a specific shift at a work center or line. Records planned vs. actual good quantity, scrap, rework, downtime minutes, OEE (availability × performance × quality), cycle time, takt time, and throughput rate. The SSOT for shift-level OEE and production KPIs. Drives daily production meetings, continuous improvement actions, and management escalation triggers. Sourced from MES shift close procedures (e.g., Siemens Opcenter) and SCADA data aggregation.' .

ind:ProductionDowntimeEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Production Downtime Event' ;
    rdfs:comment 'Downtime event capturing a planned or unplanned production stoppage at a work center or line. Records start/end timestamps, duration, downtime category (breakdown, planned maintenance, changeover, material shortage, quality hold, operator absence), root cause code, and responsible department. Critical input for OEE availability calculation, TPM analysis, and changeover time (SMED) tracking. Sourced from SCADA alarm logs and MES downtime tracking (e.g., Siemens Opcenter).' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Goods receipt event recording formal completion and stock posting of finished or semi-finished goods produced against a work order. Captures GR document number, posting date, material, plant, storage location, received quantity, batch number, and movement type (101). Sourced from SAP PP/WM (MIGO). This is the production domain\'s handoff point — it triggers inventory update in the inventory domain and signals work order completion. Does NOT own ongoing stock balances (inventory domain owns those).' .

ind:Run rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Run' ;
    rdfs:comment 'Production run entity representing a continuous execution campaign on a production line or work center, potentially spanning multiple work orders for the same or similar products. Captures run number, production line, start timestamp, end timestamp, total planned quantity, total actual quantity, total scrap quantity, overall yield rate, number of work orders included, and run status (active, completed, cancelled). Sourced from Siemens Opcenter MES campaign/run management. Enables campaign-level performance analysis beyond individual work orders.' .

ind:ProductionLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Production line master entity representing a named, configured manufacturing line within a plant, composed of an ordered set of work centers and machines. Captures line code, line name, plant, line type (assembly, machining, fabrication, painting, testing), design throughput rate (units/hour), takt time target, number of stations, automation level (manual, semi-automated, fully automated), and current operational status. The SSOT for production line configuration used in scheduling, OEE reporting, and capacity planning.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Core master entity representing the authoritative supplier identity record (SSOT) for all vendors, sub-contractors, and raw material suppliers engaged by Manufacturing. Captures legal entity name, DUNS number, tax ID, SAP vendor master number (from SAP Ariba/S4HANA MM), business type (OEM, distributor, raw material, MRO), incorporation country, headquarters address, primary contact, preferred currency, payment terms, incoterms, and active status. This is the golden record used across procurement, quality, supply chain, and logistics domains.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Site' ;
    rdfs:comment 'Represents a specific physical manufacturing, warehouse, or service site belonging to a vendor. A single vendor legal entity may operate multiple sites with distinct capabilities, certifications, and risk profiles. Captures site address, site type (manufacturing, distribution, R&D), production capacity, geographic region, ISO certification scope, and site-level contact. Used by procurement and quality to route sourcing decisions to the correct facility.' .

ind:SupplierContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Supplier Contact' ;
    rdfs:comment 'Tracks individual contacts associated with a vendor organization, including account managers, quality engineers, logistics coordinators, and executive sponsors. Captures full name, job title, department, email, phone, preferred language, contact role (commercial, technical, quality, logistics), and active status. Supports multi-threaded supplier relationship management across procurement, quality, and after-sales functions.' .

ind:Qualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Qualification' ;
    rdfs:comment 'Records the formal supplier qualification lifecycle for each vendor, tracking whether a vendor has been approved or disqualified for specific commodity categories or part families. Captures qualification status (prospective, under evaluation, approved, conditional, disqualified), qualification type (new supplier, re-qualification, commodity extension, disqualification), evaluation start/end dates, approving engineer, qualification basis (PPAP, APQP, audit, sample approval), expiry date, and for disqualification events: disqualification reason, affected commodities, transition plan reference, and re-qualification eligibility. Managed in SAP Ariba and aligned with PPAP/APQP standards.' .

ind:Scorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Scorecard' ;
    rdfs:comment 'Periodic supplier performance scorecard capturing aggregated KPI results across quality, delivery, cost, and responsiveness dimensions for a defined evaluation period (monthly, quarterly, annual). Stores overall score, individual pillar scores (OTD — On-Time Delivery, PPM — Parts Per Million defect rate, cost variance, responsiveness index), scorecard period, rating tier (preferred, approved, conditional, development), and issuing buyer. Drives strategic sourcing decisions and supplier development programs.' .

ind:SupplierAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Supplier Audit' ;
    rdfs:comment 'Records formal supplier audits conducted at vendor sites, including quality system audits (ISO 9001, IATF 16949), process audits, environmental audits (ISO 14001), cybersecurity audits (IEC 62443), and social compliance audits. Captures audit type, audit date, lead auditor, audit scope, findings count by severity (critical, major, minor), overall audit result (pass, conditional pass, fail), and next scheduled audit date. Linked to CAPA records for finding remediation tracking.' .

ind:SupplierCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Supplier Certification' ;
    rdfs:comment 'Tracks all regulatory, quality, and industry certifications held by a vendor or vendor site, including ISO 9001, ISO 14001, ISO 45001, ISO 50001, IEC 62443, UL, CE Marking, IATF 16949, AS9100, and RoHS compliance. Captures certification standard, issuing body, certificate number, issue date, expiry date, scope of certification, and renewal status. Drives automated alerts for expiring certifications and gates procurement decisions for regulated commodity categories.' .

ind:ApprovedVendorList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Approved Vendor List' ;
    rdfs:comment 'The Approved Vendor List (AVL) entry linking a qualified vendor to a specific commodity category, material group, or part family for which they are authorized to supply. Captures AVL status (active, suspended, phased-out), commodity code, material group, preferred/backup designation, MOQ (Minimum Order Quantity), lead time, geographic supply region, and approval date. The AVL is the operational gate used by MRP and procurement to select valid sources during purchase order creation in SAP S/4HANA MM.' .

ind:Opportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Opportunity' ;
    rdfs:comment 'Core sales opportunity record representing a potential deal for industrial automation, electrification, or smart infrastructure products. Tracks the full revenue pipeline from initial identification through close, including estimated value, probability, stage progression, expected close date, product lines of interest, competitive landscape, win/loss outcome, and primary loss reason. Sourced from Salesforce Sales Cloud Opportunity object. SSOT for all pipeline, forecast, and win/loss analysis data.' .

ind:Quote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote' ;
    rdfs:comment 'Commercial quotation issued to a prospective or existing industrial customer for automation systems, electrification solutions, or smart infrastructure components. Captures quoted price, discount structure (including approved non-standard discounts), validity period, payment terms, delivery lead time, configuration details, and approval status. Linked to an opportunity and may progress to a formal proposal or order. Sourced from Salesforce CPQ / Sales Cloud Quote object.' .

ind:QuoteLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote Line' ;
    rdfs:comment 'Individual line item within a commercial quotation, representing a specific SKU, product configuration, or service offering with its own quantity, unit price, discount, and extended amount. Supports multi-line complex industrial system quotes including hardware, software, installation, and commissioning services. Sourced from Salesforce CPQ Quote Line object.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Executed commercial sales contract governing the terms and conditions for supply of industrial automation, electrification, or infrastructure products and systems. Captures contract value, duration, payment milestones, delivery schedule, SLA commitments, warranty provisions, penalty clauses, governing law, and Incoterms. Distinct from procurement contracts (owned by procurement domain) and service contracts (owned by service domain). SSOT for commercial sales agreement terms only.' .

ind:Territory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Sales territory definition representing a geographic, industry-vertical, or account-based assignment used to organize the sales force for industrial automation and electrification markets. Captures territory code, region hierarchy (global/regional/local), assigned revenue quota, product line scope, and effective dates. Enables territory-based pipeline reporting and quota attainment tracking.' .

ind:Rep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Rep' ;
    rdfs:comment 'Sales representative profile within the sales domain capturing commercial role, quota assignment, product line specialization (drives, PLCs, switchgear, building automation), territory alignment, and performance targets. Distinct from the workforce domain employee record — this is the sales-domain view of a seller including their book of business, commission plan reference, CRM user linkage, and sales hierarchy position (individual contributor, team lead, regional manager). Sourced from Salesforce User / Sales Cloud.' .

ind:PriceBook rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Price Book' ;
    rdfs:comment 'Commercial price book defining the standard or customer-specific list prices for industrial automation products, electrification solutions, and smart infrastructure components. Captures price book name, currency, effective date range, customer segment applicability, and whether it is the standard or a custom price book. Sourced from Salesforce CPQ Price Book. SSOT for sales-side pricing (distinct from product catalog cost data).' .

ind:PriceBookEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Price Book Entry' ;
    rdfs:comment 'Individual product-price association within a price book, linking a specific SKU or product configuration to its list price, minimum price, and discount thresholds for a given currency and effective period. Supports multi-currency industrial sales across global markets and enables CPQ-driven automated pricing in Salesforce.' .

ind:OrderIntake rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Order Intake' ;
    rdfs:comment 'Sales order intake record capturing the commercial handoff from a won opportunity or accepted quote to the order management domain. Records the intake date, confirmed order value, customer PO reference, requested delivery date, payment terms confirmed, and handoff status. This is NOT the SSOT for order fulfillment data — the authoritative order record lives in the order domain. The sales domain retains this record solely for order intake KPI tracking, sales-to-fulfillment cycle time measurement, and booking recognition against quota.' .

ind:MrpRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Mrp Run' ;
    rdfs:comment 'Captures each MRP/MRP II planning run execution, recording planning horizon, run type (regenerative vs. net change), plant scope, planning parameters, BOM/routing explosion level, and completion status. Serves as the authoritative audit record of when and how material requirements were calculated, enabling traceability of all planned orders and material requirements back to their originating MRP execution in SAP PP/MM or Microsoft Dynamics 365 SCM.' .

ind:PlannedOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Planned Order' ;
    rdfs:comment 'Represents a planned production, procurement, or stock transfer order generated by MRP/APS to satisfy a material requirement. Consolidates all replenishment proposals awaiting planner review through to firmed orders ready for conversion. Tracks planned quantity, scheduled start/finish dates, order type (production order, purchase requisition, stock transfer), priority, firming status, proposal lifecycle (open, under review, firmed, converted, rejected), planner override details, converting planner ID, and the material/plant combination. Serves as the single actionable output of MRP runs requiring human review before release to procurement or production. Sourced from SAP PP/MM and Microsoft Dynamics 365 SCM planning outputs.' .

ind:DemandForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Demand Forecast' ;
    rdfs:comment 'Stores version-aware demand forecast records supporting scenario comparison and consensus planning. Captures statistical baseline forecasts, sales-adjusted forecasts, consensus forecasts, and approved forecasts with full version lineage. Each record includes forecast quantity, forecast horizon, forecast model used, confidence interval, demand class (independent vs. dependent), item/location combination, version type, version approval workflow status, and planning period. Supports S&OP processes by maintaining multiple demand scenarios for supply planning sensitivity analysis. Sourced from Microsoft Dynamics 365 SCM demand planning module.' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Master supply plan record representing the approved supply response to demand for a given planning period, plant, and material group. Captures planned supply quantities by time bucket, planning method (MRP, APS, manual), plan version, approval status, planning parameters (strategy, horizon, time fences, lot-sizing procedure, MRP controller), and variance against demand forecast. Integrates outputs from SAP PP and Microsoft Dynamics 365 SCM APS scheduling into a unified supply position for S&OP review.' .

ind:CapacityPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Capacity Plan' ;
    rdfs:comment 'Records capacity planning data for work centers and production resources, including available capacity, required capacity derived from planned orders, utilization rate, bottleneck flags, and capacity leveling adjustments. Supports rough-cut capacity planning (RCCP) and detailed capacity planning (CRP) as executed in SAP PP and Siemens Opcenter APS. Enables identification of capacity constraints before production scheduling.' .

ind:MaterialRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Material Requirement' ;
    rdfs:comment 'Individual material requirement record produced by MRP, representing the net requirement for a specific material at a specific plant and date. Captures gross requirement, scheduled receipts, projected available balance, net requirement, lot-size adjusted requirement, and the requirement source (sales order, forecast, safety stock). Core output of SAP PP MRP runs used to drive procurement and production planning.' .

ind:SourcingRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Sourcing Rule' ;
    rdfs:comment 'Defines the complete sourcing logic, lot-sizing constraints, and MOQ parameters for each material-plant-supplier combination. Specifies preferred suppliers, make-vs-buy decisions, split sourcing percentages, sourcing priority, applicable date ranges, Minimum Order Quantity (MOQ), maximum order quantity, lot size rounding values, fixed lot sizes, order quantity constraints, MOQ negotiation history, and planner-approved exceptions. These rules directly govern how MRP generates planned purchase requisitions or production orders and enforce procurement cost optimization through lot-size calculations. Managed in SAP MM and Microsoft Dynamics 365 SCM.' .

ind:SafetyStockPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Safety Stock Policy' ;
    rdfs:comment 'Defines safety stock parameters and reorder point policies for each material-plant combination, including safety stock quantity, safety days of supply, service level target, reorder point, maximum stock level, and the calculation method (static, dynamic, statistical). Captures the business rules governing buffer stock levels to protect against demand variability and supplier lead time uncertainty. Managed in SAP MM material master planning data.' .

ind:DemandPlanVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Demand Plan Version' ;
    rdfs:comment 'Manages versioned demand plan records enabling scenario comparison and consensus planning. Captures plan version identifier, version type (baseline statistical, sales-adjusted, consensus, approved), creation date, planning horizon, total planned demand quantity, and version approval workflow status. Supports S&OP (Sales and Operations Planning) processes by maintaining multiple demand scenarios for supply planning sensitivity analysis in Microsoft Dynamics 365 SCM.' .

ind:SkuMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku Master' ;
    rdfs:comment 'Single source of truth for all Stock Keeping Units (SKUs) across the manufactured product portfolio. Captures the authoritative SKU identifier, description, unit of measure, weight, dimensions, hazardous material classification (UN number, hazard class, packing group, SDS reference), export control classification (ECCN), and lifecycle status. Serves as the foundational master record referenced by BOM, MES, ERP (SAP S/4HANA MM), and PLM (Siemens Teamcenter) systems. Every manufactured item, automation system component, electrification solution, and smart infrastructure element is registered here before it can be produced, sold, or shipped. Includes base/sales/production UoM with conversion factors and multi-language commercial descriptions. Note: product pricing structures are owned by the sales domain; this domain owns product identity, structure, and commercial catalog definition only.' .

ind:Family rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Family' ;
    rdfs:comment 'Defines the hierarchical grouping of related manufactured products into product families and sub-families (e.g., Industrial Drives, Low-Voltage Switchgear, Smart Building Controllers). Manages the product portfolio taxonomy used for planning, pricing, and go-to-market segmentation. Supports multi-level hierarchy with parent-child relationships, market segment alignment, and product line ownership. Referenced by PLM (Siemens Teamcenter) and SAP S/4HANA SD for catalog navigation and revenue reporting.' .

ind:Configuration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Configuration' ;
    rdfs:comment 'Manages configurable product variants and option sets for make-to-order and engineer-to-order automation systems and electrification solutions. Captures configuration rules, valid option combinations, constraint logic, base model references, and configured variant codes. Supports CPQ (Configure-Price-Quote) workflows in Salesforce CRM and variant configuration in SAP S/4HANA. Tracks which configuration options are available per product family, regional market, and customer segment.' .

ind:BomHeader rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bom Header' ;
    rdfs:comment 'Bill of Materials (BOM) header record defining the top-level assembly structure for manufactured products, automation systems, and electrification solutions. Captures BOM type (engineering BOM, manufacturing BOM, sales BOM), BOM status, effective date range, plant assignment, base quantity, and revision level. Managed in Siemens Teamcenter PLM and synchronized to SAP S/4HANA PP for production planning. The BOM header is the authoritative structural definition of a manufactured product.' .

ind:ProductBomLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Bom Line' ;
    rdfs:comment 'Individual component line items within a Bill of Materials (BOM), representing the parent-child assembly relationships for manufactured products. Captures component SKU reference, quantity per assembly, unit of measure, item category (stock, non-stock, phantom), scrap factor, lead time offset, alternative item group, and engineering change order (ECO) reference. Supports multi-level BOM explosion for MRP runs in SAP S/4HANA PP and production routing in Siemens Opcenter MES. Each bom_line belongs to exactly one bom_header and references exactly one component from sku_master.' .

ind:ProductRevision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Revision' ;
    rdfs:comment 'Manages engineering revision history for manufactured products, tracking each revision level, Engineering Change Order (ECO) and Engineering Change Notice (ECN) references, revision description, effectivity date, and approval status. Captures the delta between revisions including affected BOM lines, drawing changes, and specification updates. Ensures traceability from product design through manufacturing execution per ISO 9001 document control requirements. Sourced from Siemens Teamcenter PLM.' .

ind:ProductSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Specification' ;
    rdfs:comment 'Technical and commercial specifications for manufactured products, automation systems, and electrification solutions. Captures electrical ratings, mechanical dimensions, environmental ratings (IP class, NEMA class), operating temperature range, performance parameters, and application suitability. Includes references to associated technical documentation (datasheets, installation manuals, safety data sheets) managed in the engineering domain\'s document management system. Serves as the authoritative technical specification record referenced by engineering, quality, and sales teams. Managed in Siemens Teamcenter PLM and SAP S/4HANA. Note: certification records (UL, CE, IEC, ATEX, RoHS/REACH) are tracked separately in the certification product.' .

ind:ProductCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Certification' ;
    rdfs:comment 'Tracks regulatory and safety certifications obtained for manufactured products including UL listings, CE marking, IEC compliance, ATEX ratings, RoHS/REACH declarations, and export control classifications (ECCN). Captures certifying body, certificate number, issue date, expiry date, applicable markets/regions, product scope, and renewal status. Critical for market access compliance and customer-facing documentation. Supports ISO 9001 quality records and regulatory reporting to UL, CE, and OSHA.' .

ind:PlantData rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Plant Data' ;
    rdfs:comment 'Plant-specific master data extensions for each SKU, capturing manufacturing plant assignment, MRP type, lot size procedure, safety stock level, reorder point, planned delivery time, production storage location, and quality inspection type. Represents the SAP S/4HANA MM/PP plant view of the material master, enabling plant-level production planning, MRP runs, and inventory management. Each SKU may have different plant data records per manufacturing facility.' .

ind:PurchaseRequisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Purchase Requisition' ;
    rdfs:comment 'Master record for internal purchase requisition (PR) initiated by a department or MRP run. Captures the request for direct materials, indirect materials, MRO supplies, or capital equipment before a purchase order is raised. Tracks requestor, cost center, required delivery date, material/service description, estimated value, approval status, and sourcing assignment. Serves as the originating document in the procure-to-pay cycle.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Core transactional document representing a legally binding purchase order (PO) issued to a supplier. Captures PO number, supplier, plant/delivery location, payment terms, incoterms, total PO value, currency, PO type (standard, blanket, framework, subcontracting), approval status, and confirmation status. Central document in the procure-to-pay process linking requisitions to goods receipts and supplier invoices.' .

ind:PoLineItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Po Line Item' ;
    rdfs:comment 'Individual line item within a purchase order representing a specific material, service, or SKU being procured. Captures line number, material number, short text, quantity ordered, unit of measure, net price, delivery date, storage location, account assignment (cost center, WBS element, asset), and goods receipt indicator. Enables granular spend tracking, partial delivery management, and three-way match at the item level.' .

ind:ProcurementContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Procurement Contract' ;
    rdfs:comment 'Master procurement contract or framework agreement established with a supplier for recurring supply of materials or services over a defined term. Captures contract number, contract type (blanket PO, scheduling agreement, value contract, quantity contract), effective/expiration dates, total contract value, target/release quantities, auto-renewal flag, SLA terms, penalty clauses, price escalation/de-escalation mechanisms, compliance status, and contract owner. Distinct from sales contracts owned by the sales domain. Supports contract coverage KPI tracking and maverick spend identification.' .

ind:ProcurementGoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Procurement Goods Receipt' ;
    rdfs:comment 'Goods receipt (GR) document recorded when materials or services are physically received from a supplier against a purchase order. Captures GR document number, posting date, delivery note number, received quantity, unit of measure, storage location, batch number, quality inspection flag, and GR/IR clearing status. Triggers inventory update and initiates the three-way match process (PO–GR–Invoice) for accounts payable.' .

ind:SupplierInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Supplier Invoice' ;
    rdfs:comment 'Supplier invoice document received from a vendor and processed for three-way match verification (PO–GR–Invoice). Captures invoice number, supplier invoice reference, invoice date, posting date, gross amount, tax amount, currency, payment due date, payment terms, invoice status (parked, posted, blocked, cleared), and tolerance check results. Serves as the SSOT for procurement-side payables within the procure-to-pay cycle.' .

ind:InvoiceLineItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Invoice Line Item' ;
    rdfs:comment 'Individual line item on a supplier invoice corresponding to a specific PO line, service entry sheet, or unplanned delivery cost. Captures line number, material or service description, invoiced quantity, unit price, line amount, tax code, account assignment, and three-way match status (matched, quantity variance, price variance, blocked). Enables granular invoice verification and exception management in logistics invoice verification.' .

ind:CommodityCategory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'Commodity and spend category taxonomy used to classify all purchased materials and services into a hierarchical structure aligned with UNSPSC or internal category codes. Captures category code, category name, category level (L1/L2/L3), parent category, spend type (direct/indirect/MRO/CapEx), category owner, preferred supplier flag, and strategic sourcing priority. Enables category management, spend cube construction, and sourcing strategy alignment.' .

ind:PurchaseInfoRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Purchase Info Record' ;
    rdfs:comment 'Approved source master record linking a material or service to a qualified supplier, storing the negotiated price, standard order quantity, planned delivery time, tolerance limits, validity period, and plant-level sourcing assignments. Captures info record type (standard, subcontracting, pipeline, consignment), net price, price unit, minimum order quantity, reminder lead times, approved source indicators, MRP relevance flags, fixed source flags, valid-from/to dates, and outline agreement references. Drives automatic price proposals during PO creation and ensures MRP-driven orders are directed to approved suppliers at the correct plant.' .

ind:Header rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Header' ;
    rdfs:comment 'Core master record for customer purchase orders representing the full order commitment in the order-to-cash lifecycle. Captures customer reference, order type (standard, rush, blanket, consignment), requested delivery date, incoterms, payment terms, pricing date, total net value, currency, sales organization, distribution channel, division, and overall order status. Serves as the SSOT for all customer order commitments in the industrial manufacturing order lifecycle, driving downstream delivery, billing, and revenue recognition.' .

ind:OrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Line' ;
    rdfs:comment 'Individual line item within a customer sales order representing a discrete product, automation system, or service being ordered. Captures material number, ordered and confirmed quantities, unit of measure, schedule line dates, net price, pricing conditions, plant assignment, storage location, delivery status, rejection reason, and blanket order release reference. Serves as the demand signal for MRP and production scheduling. May reference a parent blanket order for scheduling agreement releases.' .

ind:ScheduleLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Schedule Line' ;
    rdfs:comment 'Delivery schedule line within a sales order line item defining confirmed delivery quantities and dates for industrial manufacturing fulfillment. Captures schedule line number, confirmed quantity, delivery date, goods issue date, route, shipping point, and MRP-confirmed availability date. Critical for Available-to-Promise (ATP) checks and production scheduling alignment in the order fulfillment process.' .

ind:Delivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Delivery' ;
    rdfs:comment 'Outbound delivery document created from a sales order authorizing the physical shipment of finished goods or automation systems from a plant or warehouse. Captures delivery number, delivery type, shipping point, planned goods issue date, actual goods issue date, total weight, volume, carrier, tracking number, and delivery status. Links order fulfillment to warehouse execution and logistics operations.' .

ind:DeliveryItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Delivery Item' ;
    rdfs:comment 'Individual line item within an outbound delivery document specifying the material, quantity, batch, storage location, and picking status for each product being shipped. Captures delivery item number, material number, delivery quantity, picked quantity, batch number, serial number range, storage location, and goods movement status. Supports warehouse picking, packing, and goods issue execution.' .

ind:Rma rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Rma' ;
    rdfs:comment 'Return Material Authorization record managing the end-to-end return process for defective, damaged, or incorrectly shipped industrial products and automation systems. Captures RMA number, originating sales order reference, return reason code (quality defect, shipping damage, wrong item, warranty claim), authorized return quantity, return plant, credit memo indicator, inspection requirement flag, and RMA status. Integrates with returns processing workflows and quality non-conformance reporting.' .

ind:RmaLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Rma Line' ;
    rdfs:comment 'Individual line item within an RMA document specifying the material, quantity, and disposition instructions for each returned product. Captures RMA line number, material number, returned quantity, original delivery reference, serial numbers, batch number, condition code, disposition action (scrap, rework, restock, replace), and credit value. Supports quality inspection routing and inventory reintegration decisions.' .

ind:GoodsIssue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Goods Issue' ;
    rdfs:comment 'Goods issue posting event recording the physical departure of finished goods, automation systems, or components from a plant or warehouse against an outbound delivery document. Captures goods issue document number, posting date, movement type (standard issue, reversal), plant, storage location, material document number, total value at cost, and goods issue status. Triggers inventory reduction, revenue recognition eligibility, COGS posting, and billing due list creation. Represents the legal transfer of custody from manufacturer to carrier.' .

ind:BlanketOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Blanket Order' ;
    rdfs:comment 'Long-term supply agreement or scheduling agreement from an industrial customer committing to purchase a defined quantity of products over a specified period at agreed pricing. Captures blanket order number, customer account, validity start and end dates, total committed quantity, total committed value, release frequency, minimum order quantity (MOQ), pricing conditions, and cumulative released quantity to date. Contains individual release call-offs as line-level records with release number, release date, quantity, requested delivery date, cumulative released quantity, and release status. Supports demand planning, JIT delivery scheduling, and production scheduling for high-volume OEM customers.' .

ind:BlanketOrderRelease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Blanket Order Release' ;
    rdfs:comment 'Individual release call-off against a blanket order or scheduling agreement, specifying the quantity and delivery date for a specific shipment within the long-term supply commitment. Captures release number, blanket order reference, release date, release quantity, requested delivery date, cumulative released quantity, and release status. Enables JIT delivery scheduling and production demand triggering for OEM and high-volume industrial customers.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Master record for all SAP CO cost centers representing organizational units responsible for incurring costs. Captures cost center hierarchy, responsible manager, controlling area assignment, profit center assignment, currency, validity period, cost center category (production, administration, R&D, sales), and standard hierarchy position. Serves as the SSOT for internal cost allocation, overhead absorption, and management accounting structures. The primary controlling object for budget assignment, actual cost collection, and variance analysis in manufacturing operations.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Master record for profit centers representing autonomous business segments within the manufacturing enterprise used for internal profitability reporting. Captures profit center hierarchy, controlling area, responsible manager, segment classification, currency, and validity dates. Enables P&L reporting at sub-entity level per SAP EC-PCA (Profit Center Accounting) aligned with IFRS segment reporting.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account master record serving as the SSOT for the chart of accounts used across all financial postings. Captures account number, account type (balance sheet, P&L), account group, reconciliation account flag, currency, tax category, field status group, cost element category (primary/secondary for CO integration), functional area, and IFRS/GAAP classification. Bridges financial accounting and management accounting by carrying cost element attributes that enable controlling postings. Governs all financial postings and is the backbone of the enterprise chart of accounts.' .

ind:CompanyCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Master record for SAP FI company codes representing legally independent entities within the manufacturing group. Captures company code identifier, company name, country, currency, fiscal year variant, chart of accounts assignment, controlling area assignment, consolidation group, consolidation method, and elimination scope. Serves as the organizational anchor for all financial postings, statutory reporting under IFRS/GAAP, and the consolidation unit for group financial statement preparation.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core transactional record capturing all general ledger postings at both document header and line item level, serving as the single source of truth for the complete financial audit trail. Header attributes include document number, document type, posting date, fiscal year, period, company code, currency, exchange rate, reference document, reversal indicator, and IFRS/GAAP compliance flags. Line item attributes include line number, GL account, debit/credit indicator, amount in transaction and local currencies, cost center, profit center, WBS element reference, internal order, tax code, assignment field, and posting text. Covers manual journal entries, automated system postings, accruals, reversals, reclassifications, and period-end closing entries. Foundation for trial balance, financial statements, reconciliation, and audit evidence.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Budget planning and tracking records capturing both header-level governance and period-level line item detail for all controlling objects (cost centers, profit centers, internal orders). Header captures budget version, fiscal year, budget type (original, revised, supplemental), approval workflow status, responsible manager, and total planned amounts. Line items capture controlling object assignment, GL account, cost element, fiscal period, planned amount, revised amount, committed amount, currency, and budget category (CapEx, OpEx, headcount, materials). Supports FP&A variance analysis (plan vs actual vs forecast), budget-to-actual reporting, rolling forecast integration, budget transfer workflows, and CapEx/OpEx governance across the manufacturing enterprise.' .

ind:ApInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Invoice' ;
    rdfs:comment 'Accounts payable full lifecycle records capturing vendor invoices and their associated payment execution processed as a unified payables document. Invoice attributes include document number, vendor, company code, invoice date, posting date, baseline date, payment terms, gross amount, tax amount, net amount, three-way match status (PO/GR/IR verification), payment block reason, and approval workflow status. Payment attributes include payment method (ACH, wire, check, direct debit), house bank account, value date, payment amount, discount taken, cash discount percentage, clearing document reference, payment run identifier, and bank statement reconciliation status. Covers the complete payables cycle from invoice receipt through three-way matching, approval, payment proposal, payment execution, and bank clearing. Serves as the SSOT for all vendor obligations, payment commitments, and outgoing cash flows.' .

ind:ArItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Item' ;
    rdfs:comment 'Accounts receivable open item and cleared item records from SAP FI-AR tracking customer receivables arising from product sales and service billings. Captures AR document number, customer account, company code, posting date, due date, invoice amount, currency, payment terms, dunning level, clearing document, aging bucket, and dispute status. Serves as the SSOT for customer receivables aging and cash collection tracking.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Fixed asset register and complete transaction history serving as the lifecycle record for all capitalized assets of the manufacturing enterprise including production machinery, CNC equipment, robotics, automation systems, buildings, vehicles, tooling, and IT infrastructure. Master data captures asset number, asset class, description, serial number, acquisition date and value, useful life, depreciation method/key, salvage value, location/plant assignment, and cost center assignment. Transaction history captures all asset movements: acquisitions, retirements, transfers, revaluations, impairments, and periodic depreciation postings with transaction type, posting date, amount, document reference, and depreciation area (book/tax/IFRS). Provides accumulated depreciation, net book value, replacement value, and insurance value. The SSOT for asset valuation, depreciation scheduling, capital base reporting, and insurance declarations.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Master record for all house bank accounts used by the manufacturing enterprise for payment processing, cash pooling, and liquidity management. Captures bank key, account number, IBAN, SWIFT/BIC, bank name, country, currency, GL account assignment, payment method eligibility, daily transaction limits, and cash pool membership. Serves as the SSOT for treasury operations and bank statement reconciliation in SAP FI.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Master record for supplier-level framework agreements, quality agreements, NDAs, long-term supply agreements (LTAs), and consignment agreements that govern the overall commercial and quality relationship between Manufacturing and a vendor. Distinct from individual purchase orders (owned by procurement) — this captures the umbrella contractual instruments that set terms, pricing frameworks, IP protections, and quality expectations across multiple POs. Captures agreement type (framework, quality, NDA, LTA, consignment, tooling loan), effective date, expiry date, auto-renewal terms, governing law, key commercial terms summary, associated commodity scope, and agreement status (draft, active, expired, terminated).' .

ind:BusinessPartner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Business Partner' ;
    rdfs:comment 'Master reference table for business_partner. Referenced by business_partner_id.' .

ind:Plant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Master reference table for plant. Referenced by plant_id.' .

ind:InspectionCharacteristic rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Characteristic' ;
    rdfs:comment 'Master reference table for inspection_characteristic. Referenced by characteristic_id.' .

ind:PlanCharacteristicAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Plan Characteristic Assignment' ;
    rdfs:comment 'This association product represents the formal Assignment between an inspection_plan and an inspection_characteristic within a quality management system. It captures the operational configuration of each characteristic as it applies within a specific plan, including sequencing, mandatory status, and plan-specific overrides for sampling, tolerance, and control method. Each record links one inspection_plan to one inspection_characteristic and carries attributes that exist only in the context of this assignment — not on the plan or characteristic master alone. Supports PPAP, APQP, and ISO 9001 traceability requirements.. Existence Justification: In SAP QM and ISO 9001-aligned quality management systems, inspection plans are formally composed of multiple inspection characteristics, and each master characteristic (e.g., \'surface roughness\', \'tensile strength\') is deliberately reused across many inspection plans for different components, SKUs, or production stages. This is not an analytical correlation — quality engineers actively create, sequence, and configure characteristic assignments within each plan, with plan-specific overrides for tolerances, sample sizes, and control methods. The business concept \'Inspection Plan Characteristic Assignment\' is a recognized SAP QM entity (QP01 operation characteristic) that carries its own operational data.' .

ind:JobPlanMaterialRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Job Plan Material Requirement' ;
    rdfs:comment 'This association product represents the Material Requirement contract between a job_plan and a spare_part. It captures the structured Bill of Materials (BOM) for a maintenance job plan — defining which spare parts are required, in what quantity, in what sequence, and at what estimated cost, for each job plan execution. Each record links one job_plan to one spare_part with attributes that exist only in the context of this planned material requirement. Replaces the denormalized spare_parts_list STRING on job_plan. Sourced from Maximo Job Plan Materials and SAP PM Task List Components.. Existence Justification: In Maximo and SAP PM, a Job Plan (Task List) explicitly defines a Bill of Materials — a list of spare parts required to execute the maintenance procedure. A single job plan requires multiple spare parts (e.g., filters, seals, lubricants, fasteners), and a single spare part appears in many job plans across different equipment types and maintenance activities. This is a first-class operational relationship that maintenance planners actively create, update, and delete as part of the planning process, carrying its own data (quantity required, sequence, mandatory flag, estimated cost).' .

ind:RoutingOperation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Routing Operation' ;
    rdfs:comment 'This association product represents the assignment of a work center to a specific operation step within a manufacturing routing. It captures the ordered sequence of operations that constitute a routing, with each record linking one routing to one work center at a defined operation step. Attributes that exist only in the context of this assignment — operation sequence, time standards for setup/processing/labor/machine, control key, and costing standard values — are stored here. This is the SSOT for operation-level process definitions and is the primary source for capacity planning, production scheduling, and standard cost calculation. Corresponds to SAP PP table PLPO (routing operation) and Siemens Opcenter process step assignment.. Existence Justification: In manufacturing ERP systems (SAP PP, Siemens Opcenter), a routing is composed of ordered operation steps, and each operation step is explicitly assigned to a specific work center. One routing references many work centers (one per operation step, and potentially the same work center at multiple steps), and one work center appears in many routings across different products and production scenarios. The \'routing operation\' is a well-recognized, actively managed business entity in manufacturing — planners create, update, and delete operation assignments as part of process engineering, and each assignment carries its own time standards, control keys, and costing data that belong neither to the routing header nor to the work center master alone.' .

ind:AffectedItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Affected Item' ;
    rdfs:comment 'This association product represents the Affected Item relationship between an Engineering Change Order (ECO) and a Component. It captures the formal per-component change record within an ECO — the operational entity that engineers create, manage, and close for each component impacted by a change. Each record links one ECO to one component and carries the disposition instruction, revision transition, effectivity data, and implementation status that exist only in the context of this specific ECO-component pairing. Serves as the SSOT for affected item detail required by ISO 9001 change control, PPAP submissions, and quality audit trails.. Existence Justification: In PLM and engineering change management, an ECO formally governs changes to multiple components simultaneously (e.g., a design change affecting a PLC module, its mounting bracket, and a connector), while a single component can be affected by many ECOs over its lifecycle (initial release, design iterations, material substitutions, regulatory updates). This is a first-class operational relationship — engineers actively create, manage, and close \'Affected Item\' records per ECO-component pair, each carrying disposition instructions, revision transitions, and effectivity data that belong to neither the ECO nor the component alone.' .

# --- Attribute Properties ---
ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer account record in the Databricks Silver Layer. Primary key for the customer_account master data product. Serves as the SSOT reference key for all downstream domains including sales, service, order, and billing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:businessPartnerId rdf:type rdf:Property ;
    rdfs:label 'Business Partner Id' ;
    rdfs:comment 'Foreign key linking to finance.business_partner. Business justification: In SAP-based industrial manufacturing ERP, every customer account maps to a business partner master record for unified MDM, payment terms, and compliance management. customer_account.sap_business_part' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessPartner .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Legal-entity invoicing and tax reporting assign each customer to a company code for statutory compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Cost Allocation Report requires mapping each customer account to a cost center for internal expense tracking per strategic account.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:parentAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Customer Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent customer_account record in the corporate hierarchy. Enables multi-level account hierarchy modeling (e.g., subsidiary → division → global parent). Null for top-level accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:priceBookId rdf:type rdf:Property ;
    rdfs:label 'Price Book Id' ;
    rdfs:comment 'Identifier of the SAP S/4HANA pricing condition group or price list assigned to this customer. Determines applicable pricing, discounts, and surcharges during sales order creation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:primarySalesRepId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Primary sales rep on an account drives quota allocation, forecasting, and territory performance metrics in industrial manufacturing.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:primaryUltimateParentAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Account Customer Account Id' ;
    rdfs:comment 'Identifier of the topmost entity in the corporate hierarchy for this customer account. Supports global account consolidation, enterprise-level revenue reporting, and strategic account management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Profitability analysis per customer uses profit_center_id on the account to attribute revenue and margin to the correct profit center.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Direct FK to sales territory replaces the denormalized code, supporting territory-based reporting and incentive calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Linking account to its segment enables normalization of segment data and removes redundant string field.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to supplier.supplier. Business justification: Procurement planning and supplier performance dashboards require each account to designate a primary supplier.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:accountSource rdf:type rdf:Property ;
    rdfs:label 'Account Source' ;
    rdfs:comment 'Channel or method through which this customer account was originally acquired. Used for marketing attribution, channel effectiveness analysis, and sales pipeline reporting. [ENUM-REF-CANDIDATE: direct_sales|referral|trade_show|inbound_marketing|partner|acquisition|existing_relationship — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the customer account. Controls whether transactions, orders, and service requests can be processed against this account. Managed in Salesforce CRM and synchronized to SAP S/4HANA.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the customer\'s commercial role in the industrial supply chain. Drives pricing tiers, contract templates, and service entitlements. [ENUM-REF-CANDIDATE: OEM|distributor|system_integrator|end_user|EPC_contractor|reseller|value_added_reseller|direct — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Customer organization\'s most recently reported annual revenue in the account\'s local currency. Used for customer segmentation, credit risk assessment, and strategic account classification. Currency indicated by revenue_currency_code.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City of the customer\'s primary billing address. Used for geographic segmentation, logistics planning, and tax jurisdiction determination.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the customer\'s primary billing address country. Used for tax jurisdiction determination, regulatory compliance, and geographic segmentation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the customer\'s primary billing address. Used for tax jurisdiction mapping, logistics routing, and geographic analytics.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province of the customer\'s primary billing address. Used for tax jurisdiction determination, sales territory assignment, and regional reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date on which the customer account was formally closed or terminated. Null for active accounts. Used for churn analysis, lifecycle reporting, and regulatory record retention.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the customer account record was first created in the source system of record (Salesforce CRM). Conforms to ISO 8601 format yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for audit trail and data lineage.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding accounts receivable balance permitted for this customer account, denominated in the account\'s billing currency. Enforced in SAP S/4HANA SD order processing and credit management workflows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the credit_limit field. Ensures correct interpretation of the credit limit in multi-currency environments.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Credit rating assigned to the customer by an internal credit team or external agency (e.g., Dun & Bradstreet, Moody\'s). Used to determine credit limits, payment terms, and order approval workflows in SAP S/4HANA FI.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'Native Account record ID from Salesforce CRM (Account object). Used to cross-reference the master record back to the operational source system for reconciliation and lineage tracing.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the completeness and accuracy of the customer account record as assessed by Informatica MDM data quality rules. Used to prioritize data stewardship activities and MDM enrichment workflows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP S/4HANA distribution channel code indicating how products are sold to this customer (e.g., direct sales, wholesale, OEM channel). Part of the SAP SD organizational assignment.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet DUNS number uniquely identifying the customer\'s legal entity globally. Used for credit risk assessment, supplier/customer verification, and corporate hierarchy resolution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Total number of employees at the customer organization as reported or estimated. Used for customer segmentation (SMB vs. enterprise), credit risk scoring, and market sizing analytics.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'ICC Incoterms code defining the agreed delivery and risk transfer conditions for shipments to this customer. Used in SAP S/4HANA SD sales order processing and logistics planning. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryNaicsCode rdf:type rdf:Property ;
    rdfs:label 'Industry Naics Code' ;
    rdfs:comment 'Six-digit NAICS code identifying the customer\'s primary industry sector per North American classification standards. Complements SIC code for more granular industry segmentation and analytics.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySicCode rdf:type rdf:Property ;
    rdfs:label 'Industry Sic Code' ;
    rdfs:comment 'Four-digit Standard Industrial Classification code identifying the customer\'s primary industry sector. Used for market segmentation, regulatory reporting, and credit risk assessment.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobalAccount rdf:type rdf:Property ;
    rdfs:label 'Is Global Account' ;
    rdfs:comment 'Indicates whether this customer operates across multiple countries and is managed under a global account management program with consolidated commercial terms and cross-regional coordination.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrategicAccount rdf:type rdf:Property ;
    rdfs:label 'Is Strategic Account' ;
    rdfs:comment 'Indicates whether this customer is designated as a strategic account requiring executive-level relationship management and customized service agreements. Strategic accounts receive dedicated account teams and priority support.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent commercial activity (order, service request, or interaction) recorded against this customer account. Used for account health monitoring, dormancy detection, and re-engagement campaigns.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the customer account record in the source system of record. Used for change data capture (CDC), incremental ETL processing, and audit compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the B2B customer organization as recorded in official corporate filings. Used for invoicing, contracts, and regulatory compliance. Must match the name on file with the relevant tax authority.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdmGoldenRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Mdm Golden Record Flag' ;
    rdfs:comment 'Indicates whether this record has been designated as the MDM golden (master) record for the customer entity after deduplication and survivorship processing in Informatica MDM. False indicates a candidate or survivor record pending promotion.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date on which the customer account was formally opened and activated in the system of record. Marks the start of the commercial relationship. Used for customer tenure calculations and cohort analysis.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business telephone number for the customer organization. Used for account management communications and service escalation. Stored in E.164-compatible format.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 region suffix) indicating the customer\'s preferred language for communications, documents, and correspondence (e.g., en-US, de-DE, fr-FR).' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the annual_revenue field (e.g., USD, EUR, GBP). Required to correctly interpret the revenue figure for multi-currency global accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'SAP S/4HANA sales organization code responsible for selling to this customer. Determines the legal entity, currency, and pricing procedures applicable to sales transactions.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'SLA tier assigned to this customer account, defining the service response times, support priority, and escalation paths applicable to service requests and after-sales support. Managed in Salesforce Service Cloud.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusDate rdf:type rdf:Property ;
    rdfs:label 'Status Date' ;
    rdfs:comment 'Date on which the current account_status became effective. Supports lifecycle history tracking and audit compliance. Used to calculate duration in current status for account health reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Government-issued tax identification number for the customer\'s legal entity (e.g., EIN in the US, CRN in the UK). Required for invoicing, tax reporting, and regulatory compliance under IFRS/GAAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Commercial or brand name under which the customer operates if different from the legal entity name. Used in sales communications, account management, and CRM displays.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT registration number for the customer entity, required for EU and international tax compliance. Used in invoice generation and cross-border transaction reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:website rdf:type rdf:Property ;
    rdfs:label 'Website' ;
    rdfs:comment 'Official website URL of the customer organization. Used for account research, digital engagement tracking, and customer profile enrichment.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactId rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for the contact record in the Databricks Silver Layer. Serves as the primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContact .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the contact\'s organizational superior within the same account. Enables modeling of the customer-side org chart for multi-stakeholder enterprise sales and service engagement strategies.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContact .

ind:salesRepId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Assigning a sales rep to each contact enables contact-level sales follow-up and pipeline reporting, a standard practice in manufacturing account management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:accountSite rdf:type rdf:Property ;
    rdfs:label 'Account Site' ;
    rdfs:comment 'Specific plant, facility, or site within the parent account organization where this contact is based. Critical for industrial manufacturing customers with multiple production sites, enabling site-level service and sales targeting.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantName rdf:type rdf:Property ;
    rdfs:label 'Assistant Name' ;
    rdfs:comment 'Name of the contact\'s executive assistant or administrative coordinator. Used to facilitate scheduling, correspondence routing, and executive-level engagement for senior stakeholders at key accounts.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantPhone rdf:type rdf:Property ;
    rdfs:label 'Assistant Phone' ;
    rdfs:comment 'Phone number of the contact\'s executive assistant. Enables sales and service teams to reach senior contacts through their administrative support channel.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthdate rdf:type rdf:Property ;
    rdfs:label 'Birthdate' ;
    rdfs:comment 'Date of birth of the contact. Captured selectively for key account contacts where relationship management programs require it. Subject to strict GDPR data minimization principles — only collected when there is a documented lawful basis.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentRecordCode rdf:type rdf:Property ;
    rdfs:label 'Consent Record Code' ;
    rdfs:comment 'Reference identifier linking to the formal consent record in the consent management system. Provides an auditable trail of the lawful basis under which this contact\'s personal data is processed, as required by GDPR Article 7.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s decision-making role in the B2B buying and service process. Drives sales engagement strategy and marketing segmentation. [ENUM-REF-CANDIDATE: technical_evaluator|commercial_buyer|executive_approver|end_user|influencer|other — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'External identifier for this contact record as assigned by Salesforce CRM. Used for cross-system reconciliation and delta-load processing from the operational source of record.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Governs whether the contact is eligible for outreach, service engagement, and data processing activities. \'do_not_contact\' enforces opt-out and regulatory suppression requirements.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department or functional unit to which the contact belongs at their employer (e.g., Engineering, Procurement, Manufacturing, Maintenance, Finance, Executive). Supports segmentation for targeted outreach.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Indicates whether the contact has requested to be excluded from telephone outreach. True = phone contact suppressed. Enforced in compliance with national do-not-call registries and GDPR consent requirements.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact. Used as the principal digital communication channel for sales outreach, service notifications, and marketing campaigns. Governed under GDPR and applicable privacy regulations.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptOut rdf:type rdf:Property ;
    rdfs:label 'Email Opt Out' ;
    rdfs:comment 'Indicates whether the contact has explicitly opted out of email communications. True = email suppressed; False = email permitted. Distinct from marketing_opt_in as it applies specifically to all email types including transactional. Enforced by Salesforce CRM email suppression lists.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fax rdf:type rdf:Property ;
    rdfs:label 'Fax' ;
    rdfs:comment 'Fax number associated with the contact or their office location. Retained for legacy B2B industrial communication workflows and regulatory document exchange in certain jurisdictions.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the individual contact as recorded in Salesforce CRM. Used for personalized communication across sales, service, and marketing channels.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDataSubjectCode rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Subject Code' ;
    rdfs:comment 'Unique identifier assigned to this contact as a GDPR data subject. Used to process data subject rights requests (access, erasure, portability) and maintain the record of processing activities (ROPA) as required under GDPR Article 30.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact holds formal decision-making authority for purchasing or contracting at their organization. True = authorized decision maker. Used to prioritize sales engagement and opportunity progression in the CRM pipeline.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is designated as the primary point of contact for their account. True = primary contact for account-level communications and escalations. Only one contact per account should hold this designation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title of the contact at their organization (e.g., Plant Manager, Procurement Manager, Design Engineer, Maintenance Supervisor, VP of Operations). Critical for routing sales and service engagements to the appropriate stakeholder.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the contact\'s preferred language for communications and documentation (e.g., en, de, zh, fr, ja). Drives localization of marketing materials, service documents, and product manuals.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the individual contact. Combined with first_name to form the full display name used in correspondence and CRM records.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Channel or origin through which this contact was first acquired or identified. Used for marketing attribution, ROI analysis of demand generation programs, and sales pipeline reporting. [ENUM-REF-CANDIDATE: trade_show|web_inquiry|referral|partner|direct_sales|marketing_campaign|distributor|other — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'URL of the contact\'s LinkedIn professional profile. Used by sales and marketing teams for social selling, account-based marketing (ABM), and contact enrichment workflows.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City component of the contact\'s mailing address. Used in geographic segmentation, territory assignment, and regional sales reporting.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the contact\'s mailing address (e.g., USA, DEU, CHN). Drives multi-national compliance, language preference defaults, and export control screening.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal or ZIP code component of the contact\'s mailing address. Used for geographic routing, logistics planning, and regional analytics.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingState rdf:type rdf:Property ;
    rdfs:label 'Mailing State' ;
    rdfs:comment 'State or province component of the contact\'s mailing address. Supports territory management, tax jurisdiction determination, and regional compliance reporting.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStreet rdf:type rdf:Property ;
    rdfs:label 'Mailing Street' ;
    rdfs:comment 'Street address line for the contact\'s mailing address. Used for physical correspondence, contract delivery, and regulatory document dispatch.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the contact has provided explicit consent to receive marketing communications. True = opted in; False = opted out or consent not obtained. Mandatory for GDPR and CAN-SPAM compliance. Must be False by default until affirmative consent is recorded.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Date' ;
    rdfs:comment 'Date on which the contact provided or last renewed their marketing consent. Required for GDPR audit trail demonstrating lawful basis for marketing data processing.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mdmGoldenRecordCode rdf:type rdf:Property ;
    rdfs:label 'Mdm Golden Record Code' ;
    rdfs:comment 'Identifier of the golden (master) record in Informatica MDM to which this contact has been matched and merged. Enables cross-system deduplication and single-view-of-contact analytics across Salesforce CRM, SAP S/4HANA, and other operational systems.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cellular phone number for the contact. Used for SMS notifications, urgent service alerts, and field engineer coordination. Distinct from the primary business phone line.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:persona rdf:type rdf:Property ;
    rdfs:label 'Persona' ;
    rdfs:comment 'Functional persona label describing the contact\'s primary business role in the industrial context (e.g., Design Engineer, Procurement Manager, Plant Manager, Maintenance Supervisor, Executive Sponsor, Quality Engineer). Used for targeted content delivery and sales play alignment.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s stated preferred channel for receiving communications from the company. Drives outreach strategy for sales, service, and marketing teams to maximize engagement effectiveness.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal honorific or title prefix used when addressing the contact in written and verbal communication (e.g., Mr., Dr., Prof.).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Flag' ;
    rdfs:comment 'Indicates whether this contact serves as a technical point of contact for product support, engineering queries, or MES/PLC/SCADA integration activities. True = designated technical contact. Drives routing of technical service cases and engineering change notifications (ECN).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the segment definition was formally approved by the designated commercial authority. Used for governance audit trails and to establish the authoritative effective date of the segment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the commercial leadership authority (e.g., VP Sales, Regional Sales Director) who formally approved this segment definition and its commercial parameters. Sourced from Salesforce CRM approval workflow records.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedSegmentManager rdf:type rdf:Property ;
    rdfs:label 'Assigned Segment Manager' ;
    rdfs:comment 'Full name or employee identifier of the commercial manager responsible for owning the segment strategy, reviewing segment performance, and approving account assignments. Sourced from Salesforce CRM user records and Workday HCM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Indicates the go-to-market channel model applicable to this segment: Direct (manufacturer sells directly to end customer), Indirect (sales through distributors or channel partners), or Hybrid (combination of direct and indirect). Drives commercial policy and commission structures.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRequired rdf:type rdf:Property ;
    rdfs:label 'Contract Required' ;
    rdfs:comment 'Indicates whether a formal master supply agreement or framework contract is mandatory for customer accounts in this segment before order processing can commence. Enforced in SAP S/4HANA SD order entry validation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Standard credit limit in USD applied to customer accounts assigned to this segment. Used as the default credit exposure ceiling in SAP S/4HANA FI-AR credit management for new account onboarding within the segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criteria rdf:type rdf:Property ;
    rdfs:label 'Criteria' ;
    rdfs:comment 'Structured definition of the qualifying rules and thresholds used to assign a customer account to this segment (e.g., annual revenue > $10M, OEM classification, multi-site deployment). Supports automated segmentation logic in Salesforce CRM and Informatica MDM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSegmentRecordCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Record Code' ;
    rdfs:comment 'Native Salesforce CRM record identifier for the corresponding segment or account group object in Salesforce Sales Cloud. Used for bi-directional synchronization between the Databricks Silver Layer and the CRM system of record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountType rdf:type rdf:Property ;
    rdfs:label 'Customer Account Type' ;
    rdfs:comment 'Classification of the customer relationship type that this segment targets. OEM (Original Equipment Manufacturer) accounts receive differentiated pricing and co-development support; Distributors receive channel margin structures; End Users receive direct service SLAs; System Integrators and EPCs (Engineering, Procurement & Construction) receive project-based commercial terms.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedAccountManagerRequired rdf:type rdf:Property ;
    rdfs:label 'Dedicated Account Manager Required' ;
    rdfs:comment 'Indicates whether customer accounts in this segment require a dedicated named account manager assignment in Salesforce CRM. Strategic and Key Account segments typically require dedicated coverage; Transactional segments may use pooled inside sales resources.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountRatePct rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Pct' ;
    rdfs:comment 'Standard discount percentage applied to list prices for customers in this segment, expressed as a percentage (e.g., 12.50 = 12.5%). Confidential as it reflects commercial pricing strategy. Used in SAP S/4HANA SD pricing condition records.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this segment definition became commercially active and applicable to account assignments. Supports temporal validity tracking for segment versioning and historical analysis of commercial strategy changes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which this segment definition ceases to be commercially active. Null indicates the segment is open-ended with no planned expiry. Used for segment versioning, sunset planning, and historical reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:erpCustomerGroupCode rdf:type rdf:Property ;
    rdfs:label 'Erp Customer Group Code' ;
    rdfs:comment 'SAP S/4HANA SD customer group code (Kundengruppe) mapped to this segment. Used to apply segment-specific pricing conditions, output determination, and reporting groupings in the ERP system of record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Primary geographic sales region associated with this segment definition (e.g., North America, EMEA, APAC, LATAM). Used to align segment management responsibilities with regional sales organizations and territory planning in Salesforce CRM. [ENUM-REF-CANDIDATE: North America|EMEA|APAC|LATAM|Greater China|South Asia|Middle East & Africa — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The primary industry vertical classification of customers within this segment (e.g., Automotive OEM, Aerospace & Defense, Food & Beverage, Energy & Utilities, Building Automation, Transportation). Aligns with NAICS/SIC industry classification and Salesforce CRM account industry field. [ENUM-REF-CANDIDATE: Automotive OEM|Aerospace & Defense|Food & Beverage|Energy & Utilities|Building Automation|Transportation|Semiconductor|Pharmaceuticals|Oil & Gas|General Manufacturing — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date on which the most recent formal review of this segment\'s criteria, account assignments, and commercial performance was completed. Used to trigger the next review cycle and track governance compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxAccountCount rdf:type rdf:Property ;
    rdfs:label 'Max Account Count' ;
    rdfs:comment 'Maximum number of customer accounts permitted in this segment before a split or restructuring review is triggered. Ensures segment managers maintain adequate coverage quality. Null indicates no upper cap.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mdmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Mdm Segment Code' ;
    rdfs:comment 'Informatica MDM golden record identifier for this segment definition. Ensures cross-system consistency of segment master data across Salesforce CRM, SAP S/4HANA, and Microsoft Dynamics 365 Supply Chain Management.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minAccountCount rdf:type rdf:Property ;
    rdfs:label 'Min Account Count' ;
    rdfs:comment 'Minimum number of customer accounts that should be assigned to this segment to maintain commercial viability and justify dedicated segment management resources. Used in segment health monitoring and portfolio planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moqApplicable rdf:type rdf:Property ;
    rdfs:label 'Moq Applicable' ;
    rdfs:comment 'Indicates whether a Minimum Order Quantity (MOQ) policy applies to customer accounts in this segment. When True, the MOQ defined in SAP S/4HANA SD condition records is enforced during order entry for accounts in this segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaRequired rdf:type rdf:Property ;
    rdfs:label 'Nda Required' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) is required for customer accounts in this segment before sharing product roadmaps, engineering specifications, or pricing strategies. Relevant for Strategic and OEM segments involved in co-development programs.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this segment definition. Calculated from last_review_date plus review_cycle_months. Used by the segment manager and commercial governance team to plan review activities.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Business email address of the assigned segment manager. Used for automated notifications, review cycle reminders, and escalation routing in Salesforce CRM workflows. Classified confidential as it is an internal business contact.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP S/4HANA payment terms code (e.g., NT30, NT60, 2/10NT30) assigned as the default for customer accounts in this segment. Defines invoice due dates, early payment discount eligibility, and cash flow planning inputs.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTierCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Code' ;
    rdfs:comment 'Code referencing the applicable pricing tier in SAP S/4HANA SD condition records for customers assigned to this segment. Drives list price, discount matrix, and rebate eligibility. Confidential as it encodes commercial pricing strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateEligible rdf:type rdf:Property ;
    rdfs:label 'Rebate Eligible' ;
    rdfs:comment 'Indicates whether customer accounts in this segment are eligible for volume-based rebate programs. When True, rebate agreements are activated in SAP S/4HANA SD rebate processing for qualifying accounts.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueBandCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the revenue band thresholds (revenue_band_min and revenue_band_max) are denominated (e.g., USD, EUR, GBP). Ensures consistent multi-currency interpretation across global sales regions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueBandMax rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Max' ;
    rdfs:comment 'Maximum annual revenue threshold (in USD) that defines the upper boundary of the revenue band for this segment. Null indicates an open-ended upper bound (e.g., for the Strategic tier). Used in pricing tier assignment and SLA prioritization.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBandMin rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Min' ;
    rdfs:comment 'Minimum annual revenue threshold (in USD) that a customer account must meet to qualify for this segment. Used in conjunction with revenue_band_max to define the revenue band boundary for segmentation scoring.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Frequency in months at which the segment definition, criteria, and account assignments are formally reviewed and validated by the segment manager and commercial leadership (e.g., 3 = quarterly, 6 = semi-annual, 12 = annual).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the segment across systems (e.g., STRAT-001, KEY-002). Used as the business key in Salesforce CRM and SAP S/4HANA SD module for cross-system reconciliation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment\'s commercial purpose, qualifying criteria, and strategic intent. Used by sales managers and account teams to understand segment boundaries and apply correct commercial policies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment (e.g., Strategic, Key Account, Growth, Transactional). Used in sales strategy, pricing tier assignment, and service prioritization workflows.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the segment definition. Active segments are applied in commercial operations; Under Review segments are being reassessed during periodic review cycles; Archived segments are retired and no longer assigned to new accounts.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment into one of the four standard commercial tiers used by the industrial manufacturing sales organization: Strategic (top-tier OEM/enterprise accounts), Key Account (high-value recurring customers), Growth (emerging or expanding accounts), Transactional (low-frequency, price-driven buyers).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Service Priority Level' ;
    rdfs:comment 'Service prioritization level for after-sales support and field service dispatch for customers in this segment. Critical and High priority segments receive preferential scheduling in Salesforce Service Cloud and Maximo work order queues.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTierCode rdf:type rdf:Property ;
    rdfs:label 'Sla Tier Code' ;
    rdfs:comment 'Code identifying the SLA tier assigned to customers in this segment, referencing the SLA agreement product. Determines response time commitments, field service priority, spare parts availability guarantees, and escalation paths in Salesforce Service Cloud and Maximo Asset Management.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Account Flag' ;
    rdfs:comment 'Indicates whether this segment is classified as a strategic segment requiring executive sponsorship, board-level visibility, and dedicated cross-functional account teams. Drives escalation routing and executive review cadence in Salesforce CRM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetGrossMarginPct rdf:type rdf:Property ;
    rdfs:label 'Target Gross Margin Pct' ;
    rdfs:comment 'Target gross margin percentage for the segment, used in pricing strategy and commercial deal approval thresholds. Deals below this margin threshold require escalated approval for accounts in this segment. Confidential as it encodes commercial profitability strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Usd' ;
    rdfs:comment 'Annual revenue target in USD for the aggregate of all customer accounts assigned to this segment. Used in commercial planning, sales quota allocation, and KPI tracking against actual segment revenue performance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this segment record, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change detection, incremental data pipeline processing, and audit trail maintenance in the Databricks Silver Layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Monotonically incrementing version number tracking revisions to the segment definition, criteria, or commercial parameters. Supports audit trail and change history for governance and compliance reviews.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique surrogate identifier for each address record in the customer domain. Serves as the primary key for the address data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are in current use; inactive addresses are no longer used but retained for historical reference; pending addresses are awaiting validation or approval; archived addresses are soft-deleted for audit trail purposes.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Functional classification of the address indicating its business purpose. Billing addresses are used for invoicing (SAP SD), shipping/delivery addresses for logistics dispatch (SAP WM/TMS), headquarters for corporate correspondence, plant_site for manufacturing facility locations, mailing for postal communications, and field_service for on-site service dispatch. [ENUM-REF-CANDIDATE: billing|shipping|headquarters|plant_site|mailing|field_service|registered|returns — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionLine rdf:type rdf:Property ;
    rdfs:label 'Attention Line' ;
    rdfs:comment 'Addressee attention line specifying the department, role, or individual to whom correspondence or deliveries should be directed at this address (e.g., \'Attn: Procurement Department\', \'Attn: Receiving Dock\'). Common in B2B industrial shipping.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingName rdf:type rdf:Property ;
    rdfs:label 'Building Name' ;
    rdfs:comment 'Name of the building or facility at this address (e.g., \'Tower A\', \'Building 7 - Final Assembly\', \'North Warehouse\'). Common in large industrial campuses and multi-building manufacturing complexes. Supplements street address for precise delivery and field service dispatch.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City, municipality, or locality name of the address. Used for logistics routing, tax jurisdiction determination, and field service territory assignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 Alpha-3 country code for the address (e.g., USA, DEU, CHN, GBR). Used for international logistics, customs documentation, export compliance, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyDistrict rdf:type rdf:Property ;
    rdfs:label 'County District' ;
    rdfs:comment 'County, district, or sub-regional administrative unit of the address. Used for local tax jurisdiction determination, permit compliance, and field service territory mapping in industrial manufacturing contexts.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Free-text special instructions for deliveries to this address, such as dock access hours, security clearance requirements, forklift availability, hazardous material handling notes, or contact person for receiving. Critical for industrial manufacturing shipments to plant sites.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this address record is valid and in effect for business operations. Supports bi-temporal address management for customers who relocate or open new facilities, ensuring correct address is used for historical invoicing and logistics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date until which this address record is valid. Null indicates the address is open-ended and currently active. Used for managing address changes over time, particularly for plant site relocations and facility closures.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Floor or level number within a building at this address. Used for precise field service dispatch and delivery routing within multi-story industrial facilities, office buildings, and distribution centers.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoordinates assigned to this address. Rooftop indicates exact building-level precision; range_interpolated is street-level; geometric_center is centroid of a region; approximate is low-precision; ungeocoded means no coordinates assigned. Informs reliability of geospatial analytics.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether this address/facility is certified to receive hazardous materials shipments. Relevant for industrial manufacturing customers receiving chemicals, electrification components, or other regulated materials. Supports EPA and OSHA compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Flag indicating whether this is the primary address for the associated customer account or contact. Only one address per customer per address_type should be marked as primary. Used to determine the default address for invoicing, shipping, and correspondence.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isValidated rdf:type rdf:Property ;
    rdfs:label 'Is Validated' ;
    rdfs:comment 'Indicates whether the address has been validated against a postal authority or address verification service (e.g., USPS CASS, Informatica MDM address cleansing). Validated addresses reduce delivery failures and logistics errors.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable descriptive label or nickname for the address record (e.g., \'Stuttgart HQ\', \'Chicago Distribution Center\', \'Plant 3 - Assembly Line\'). Facilitates quick identification in Salesforce CRM and SAP S/4HANA user interfaces.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the address in decimal degrees (WGS 84 datum). Precision to 7 decimal places (~1 cm accuracy). Used for field service dispatch routing, logistics optimization, and geospatial analytics in industrial manufacturing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including building number, street name, and any directional qualifiers. This is the first and mandatory line of the physical or mailing address as captured in Salesforce CRM and SAP S/4HANA customer master.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, unit, building name, mail stop, or additional location qualifier. Optional field used when the primary address line is insufficient to fully identify the location.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line for additional location details such as industrial park name, campus identifier, or zone designation. Used primarily for complex plant site and industrial facility addresses common in manufacturing environments.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingDockAvailable rdf:type rdf:Property ;
    rdfs:label 'Loading Dock Available' ;
    rdfs:comment 'Indicates whether a loading dock is available at this address for receiving industrial equipment, automation systems, and bulk material shipments. Affects carrier selection (LTL vs FTL) and delivery scheduling in the Transportation Management System (TMS).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the address in decimal degrees (WGS 84 datum). Precision to 7 decimal places (~1 cm accuracy). Used alongside latitude for geospatial analytics, field service routing, and logistics network optimization.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdmAddressKey rdf:type rdf:Property ;
    rdfs:label 'Mdm Address Key' ;
    rdfs:comment 'Unique address identifier assigned by Informatica MDM during master data consolidation and deduplication. Enables cross-system address matching and golden record linkage across SAP S/4HANA, Salesforce CRM, and other operational systems.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP S/4HANA plant code associated with this address when the address represents a customer\'s manufacturing plant or production facility. Enables direct linkage between customer delivery addresses and SAP plant master data for production planning (MRP/MRP II) and goods receipt processing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBox rdf:type rdf:Property ;
    rdfs:label 'Po Box' ;
    rdfs:comment 'Post Office (PO) Box number for mailing addresses where physical street delivery is not applicable. Used for billing correspondence and formal legal notices to corporate customers. Stored separately from street address lines.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBoxPostalCode rdf:type rdf:Property ;
    rdfs:label 'Po Box Postal Code' ;
    rdfs:comment 'Postal code specific to the PO Box address, which may differ from the street address postal code. Required for accurate mail routing when a PO Box is used for billing or correspondence.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the address. Format varies by country (e.g., 5-digit US ZIP, alphanumeric UK postcode). Used for mail delivery, logistics carrier routing (LTL/FTL), and geographic segmentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeExtension rdf:type rdf:Property ;
    rdfs:label 'Postal Code Extension' ;
    rdfs:comment 'Extended postal code suffix providing finer delivery point precision (e.g., ZIP+4 in the US). Improves mail delivery accuracy and carrier routing for industrial shipments.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomNumber rdf:type rdf:Property ;
    rdfs:label 'Room Number' ;
    rdfs:comment 'Room, suite, or unit number within a building at this address. Provides the most granular level of location detail for field service technician dispatch and internal mail routing at customer facilities.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRegionCode rdf:type rdf:Property ;
    rdfs:label 'Sales Region Code' ;
    rdfs:comment 'Sales region or territory code associated with this address, used for sales force assignment, revenue reporting, and quota management. Derived from geographic location and aligned with SAP S/4HANA SD sales organization structure.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Service Territory Code' ;
    rdfs:comment 'Field service territory code assigned to this address, used to route field service engineers and technicians for equipment maintenance, installation, and after-sales support. Aligns with Salesforce Service Cloud territory management and Maximo Asset Management work order dispatch.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCondition rdf:type rdf:Property ;
    rdfs:label 'Shipping Condition' ;
    rdfs:comment 'Default shipping condition or delivery method applicable to this address, indicating the preferred logistics mode. LTL (Less Than Truckload) and FTL (Full Truckload) are standard industrial shipping terms. Drives carrier selection and Transportation Management System (TMS) routing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Operational system of record from which this address record originated. Supports data lineage tracking and conflict resolution during MDM consolidation across Salesforce CRM, SAP S/4HANA, and Informatica MDM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAddressCode rdf:type rdf:Property ;
    rdfs:label 'Source System Address Code' ;
    rdfs:comment 'The native address identifier from the originating source system (e.g., Salesforce CRM Address ID, SAP ADRC ADDRNUMBER). Enables reverse lookup and reconciliation between the Databricks Silver Layer and operational systems during ETL and data quality processes.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or regional administrative division of the address. Stored as ISO 3166-2 subdivision code (e.g., US-CA, DE-BY). Used for tax jurisdiction, regulatory compliance (OSHA, EPA), and logistics zone determination.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier for the address location, used to determine applicable sales tax, VAT, or GST rates for invoicing. Typically derived from postal code and state/province. Aligns with SAP S/4HANA tax determination and IFRS/GAAP revenue recognition requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the address location (e.g., \'America/Chicago\', \'Europe/Berlin\', \'Asia/Shanghai\'). Used for scheduling field service visits, coordinating production planning across global manufacturing sites, and SLA response time calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'The system or method used to validate the address. Tracks whether validation was performed by USPS CASS certification, a geocoding API (Google Maps, HERE), Informatica MDM address cleansing, manual review, or not yet validated. Supports data quality governance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated against a postal authority or address verification service. Used to determine if re-validation is required based on data quality policies.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer credit profile record in the Databricks Silver Layer. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditProfile .

ind:badDebtProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Provision Amount' ;
    rdfs:comment 'Amount provisioned for potential bad debt loss on this customer\'s receivables under the IFRS 9 Expected Credit Loss (ECL) model or GAAP ASC 310 allowance method. Maintained in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Bank Account Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s bank account details on file have been verified through the company\'s bank account validation process. True = verified; False = unverified. Required for direct debit and bank transfer payment methods.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Collection Strategy Code' ;
    rdfs:comment 'Code identifying the dunning and collections strategy assigned to this customer in SAP S/4HANA FI-AR (e.g., standard dunning, escalated collections, legal action track). Drives automated dunning notice generation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAccountType rdf:type rdf:Property ;
    rdfs:label 'Credit Account Type' ;
    rdfs:comment 'Classification of the credit account based on the nature of the customer relationship. Determines applicable credit policies and risk frameworks. [ENUM-REF-CANDIDATE: domestic|export|intercompany|distributor|oem|government — promote to reference product if additional types are required]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP organizational unit (credit control area code) responsible for managing and monitoring this customer\'s credit. Defines the credit management scope and currency for credit limit enforcement in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Date on which the credit hold was applied to the customer account. Used for aging analysis of credit holds and SLA compliance tracking for credit resolution processes.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the customer account is currently placed on credit hold, blocking new order processing in SAP S/4HANA SD and Siemens Opcenter MES. True = credit hold active; False = no hold. Synchronized with Salesforce CRM account status.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code explaining why the customer account has been placed on credit hold. Required for audit trail and CAPA (Corrective and Preventive Action) processes. Null when credit_hold_flag is False.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Released Date' ;
    rdfs:comment 'Date on which the credit hold was lifted and normal order processing was reinstated. Null if the credit hold is still active. Used for credit resolution cycle time analysis.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditInsuranceCoverageLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Coverage Limit' ;
    rdfs:comment 'Maximum insured amount under the trade credit insurance policy for this customer, in the account currency. Represents the maximum receivable amount recoverable in case of customer default.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditInsuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Expiry Date' ;
    rdfs:comment 'Date on which the trade credit insurance policy for this customer expires. Triggers renewal workflow alerts to prevent uninsured credit exposure.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Number' ;
    rdfs:comment 'Reference number of the trade credit insurance policy (e.g., Euler Hermes, Coface, Atradius) covering this customer\'s receivables. Null if no credit insurance is in place. Used for insurance claim processing and risk mitigation reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Provider' ;
    rdfs:comment 'Name of the trade credit insurance provider covering this customer\'s receivables (e.g., Euler Hermes, Coface, Atradius, Credendo). Null if no credit insurance is in place.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNotes rdf:type rdf:Property ;
    rdfs:label 'Credit Notes' ;
    rdfs:comment 'Free-text field for credit analyst notes, special conditions, exceptions, or contextual information relevant to this customer\'s credit profile. Supports credit review documentation and exception management.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingAgency rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Agency' ;
    rdfs:comment 'Source or agency that issued the credit rating for this customer. Distinguishes between internally-derived ratings and third-party agency assessments used for credit risk management. [ENUM-REF-CANDIDATE: internal|dun_bradstreet|moody|sp|fitch|coface|euler_hermes — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Credit Review Frequency' ;
    rdfs:comment 'Frequency at which formal credit reviews are scheduled for this customer. Determined by credit risk tier and customer segment. Higher-risk customers require more frequent reviews.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditSegment rdf:type rdf:Property ;
    rdfs:label 'Credit Segment' ;
    rdfs:comment 'SAP S/4HANA credit segment identifier that groups customers under a common credit management policy and credit limit pool. Enables multi-segment credit management for customers operating across multiple business units or regions.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current lifecycle status of the customer credit profile. Drives order release decisions in SAP S/4HANA SD and MES order management. \'on_hold\' and \'blocked\' prevent new order processing until resolved.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Credit Utilization Pct' ;
    rdfs:comment 'Percentage of the approved credit limit currently consumed by the outstanding balance (outstanding_balance / credit_limit × 100). Triggers credit hold alerts when threshold is breached. Synchronized from SAP S/4HANA FI-AR credit exposure calculation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the credit limit, outstanding balance, and financial terms are denominated (e.g., USD, EUR, GBP). Aligns with the customer\'s billing currency in SAP S/4HANA.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsoDays rdf:type rdf:Property ;
    rdfs:label 'Dso Days' ;
    rdfs:comment 'Days Sales Outstanding — the average number of days it takes the customer to pay invoices, calculated as (outstanding_balance / total_credit_sales) × number_of_days. A key KPI for accounts receivable performance and cash flow management per IFRS/GAAP reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning level (1–4) indicating the escalation stage of overdue payment notices sent to the customer. Level 1 = first reminder; Level 4 = final notice before legal action. Managed in SAP S/4HANA FI-AR dunning program.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountDays rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Days' ;
    rdfs:comment 'Number of days from invoice date within which the customer must pay to qualify for the early payment discount. Null if no early payment discount applies.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Pct' ;
    rdfs:comment 'Percentage discount offered to the customer for early payment within the discount period defined in the payment terms (e.g., 2.00 for a 2% early payment discount). Null if no early payment discount applies.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which the current credit terms, credit limit, and risk classification became effective for this customer. Supports temporal credit management and audit trail requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the current credit terms and credit limit are scheduled to expire and require renewal or re-assessment. Null for open-ended credit agreements. Triggers next_credit_review_date workflow.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Credit Review Date' ;
    rdfs:comment 'Date on which the most recent formal credit assessment was completed for this customer. Triggers next review scheduling and is used for credit governance compliance reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date on which the most recent dunning notice was issued to the customer for overdue invoices. Used to track collections activity and enforce dunning intervals in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this credit profile record, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change data capture (CDC) in Databricks Silver Layer ingestion and audit compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Credit Review Date' ;
    rdfs:comment 'Scheduled date for the next formal credit review of this customer. Drives workflow alerts in SAP S/4HANA FI-AR and Salesforce CRM for proactive credit management.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oldestOverdueDays rdf:type rdf:Property ;
    rdfs:label 'Oldest Overdue Days' ;
    rdfs:comment 'Number of days since the oldest unpaid overdue invoice became due. Used for collections aging bucket analysis and bad debt provisioning triggers in SAP S/4HANA FI-AR.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Total open accounts receivable balance currently owed by the customer in the account currency, as synchronized from SAP S/4HANA FI-AR. Includes all open invoices, debit memos, and unapplied credits. Used for credit utilization monitoring.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total value of invoices that have exceeded their due date and remain unpaid, in the account currency. A subset of outstanding_balance. Used for collections prioritization and bad debt provisioning per IFRS 9 expected credit loss model.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBehaviorScore rdf:type rdf:Property ;
    rdfs:label 'Payment Behavior Score' ;
    rdfs:comment 'Internal scoring metric (0–100) reflecting the customer\'s historical payment behavior, including on-time payment rate, frequency of late payments, and average days late. Inputs into credit rating and risk category determination.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Agreed payment instrument used by the customer for settling invoices (e.g., bank transfer, letter of credit for export customers, direct debit). Configured in SAP S/4HANA FI-AR payment method settings.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of calendar days from invoice date within which payment is due under the agreed payment terms (e.g., 30 for Net 30, 60 for Net 60, 90 for Net 90). Used for DSO calculation and cash flow forecasting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Categorical risk classification assigned to the customer based on credit rating, payment history, and financial health assessment. Drives credit limit setting, insurance requirements, and collection strategy.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'Salesforce CRM Account record ID for this customer, used for bi-directional synchronization of credit status and credit hold flags between SAP S/4HANA FI-AR and Salesforce CRM Sales Cloud.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Account Number' ;
    rdfs:comment 'The externally-known SAP S/4HANA FI-AR customer account number (debtor number) used to uniquely identify the customer in the ERP system. Serves as the business identifier for cross-system reconciliation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sla Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for the SLA agreement record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaAgreement .

ind:accountSiteId rdf:type rdf:Property ;
    rdfs:label 'Account Site Id' ;
    rdfs:comment 'Foreign key linking to customer.account_site. Business justification: In industrial manufacturing, SLA agreements are frequently scoped to specific physical plant or factory locations (account_sites) rather than just the parent customer account. For example, a factory r' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountSite .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_contract. Business justification: In industrial manufacturing, SLA agreements are formalized within or attached to a sales contract. Linking sla_agreement to sales_contract enables contract-SLA traceability for compliance audits, rene' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:skuMasterId rdf:type rdf:Property ;
    rdfs:label 'Sku Master Id' ;
    rdfs:comment 'Foreign key linking to product.sku_master. Business justification: Service Contract Management: SLA agreements in industrial manufacturing are scoped to specific product SKUs (e.g., a maintenance contract for a specific automation controller). Field service dispatch,' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name of the SLA agreement as displayed in Salesforce Service Cloud and customer-facing documents (e.g., \'Platinum Support SLA — Acme Automation 2024\'). Used for identification and reporting.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number for the SLA agreement as assigned in Salesforce Service Cloud (e.g., SLA-2024-00123). Used in customer communications, contract documents, and cross-system references.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the SLA agreement: draft (under negotiation), active (in force), suspended (temporarily paused), expired (past end date without renewal), or terminated (cancelled before end date). Governs whether SLA commitments are enforceable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'The date on which the most recent amendment or revision to the SLA agreement was executed and became effective. Null for the original version. Supports change management and audit compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualFee rdf:type rdf:Property ;
    rdfs:label 'Annual Fee' ;
    rdfs:comment 'The recurring annual fee charged to the customer for the SLA agreement, in the agreement currency. Used for revenue recognition, billing scheduling in SAP S/4HANA SD, and profitability analysis.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether the SLA agreement automatically renews upon expiry without requiring a new contract signature. True = auto-renews; False = requires explicit renewal action. Drives renewal workflow automation in Salesforce Service Cloud.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'The frequency at which the customer is invoiced for the SLA agreement fee (e.g., monthly, quarterly, annual). Drives billing schedule creation in SAP S/4HANA SD and revenue recognition cadence.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Contract Document Ref' ;
    rdfs:comment 'Reference identifier or URL to the signed SLA contract document stored in the document management system (e.g., Siemens Teamcenter PLM or SharePoint). Enables traceability to the original legal document.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'The total monetary value of the SLA agreement over its full term, expressed in the agreement currency. Used for financial reporting, revenue recognition under IFRS 15/ASC 606, and penalty cap calculations.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveredAssetCount rdf:type rdf:Property ;
    rdfs:label 'Covered Asset Count' ;
    rdfs:comment 'The number of individual equipment units, machines, or installed assets covered under this SLA agreement. Used for capacity planning of field service resources and Maximo Asset Management integration.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldServiceIncluded rdf:type rdf:Property ;
    rdfs:label 'Field Service Included' ;
    rdfs:comment 'Indicates whether on-site field service visits are included in the SLA agreement. True = field service dispatches are covered; False = remote support only. Drives field service scheduling and resource allocation in Salesforce Field Service.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the interpretation and enforcement of this SLA agreement (e.g., USA, DEU). Determines applicable legal and regulatory frameworks for dispute resolution.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Initial Response Time Hours' ;
    rdfs:comment 'The maximum number of hours within which the service team must provide an initial acknowledgment or response to a customer-reported incident or service request under this SLA. A core contractual KPI metric tracked in Salesforce Service Cloud.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxAnnualServiceVisits rdf:type rdf:Property ;
    rdfs:label 'Max Annual Service Visits' ;
    rdfs:comment 'The maximum number of on-site service visits (preventive or corrective) included per year under this SLA agreement. Null if unlimited or not applicable. Used for field service capacity planning and entitlement consumption tracking.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for capturing additional contractual terms, special conditions, exclusions, or operational notes associated with the SLA agreement that are not captured in structured fields. Sourced from Salesforce Service Cloud Entitlement description.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryTargetPct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Target Pct' ;
    rdfs:comment 'The contractually committed minimum percentage of orders or shipments that must be delivered on or before the promised delivery date under this SLA. Applicable for on_time_delivery SLA types. Tracked against SAP S/4HANA SD delivery performance.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentContractRef rdf:type rdf:Property ;
    rdfs:label 'Parent Contract Ref' ;
    rdfs:comment 'Reference number of the master or parent commercial contract (e.g., Master Service Agreement or Framework Agreement) under which this SLA agreement is issued. Enables hierarchical contract traceability in SAP S/4HANA SD.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCapPct rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Pct' ;
    rdfs:comment 'The maximum cumulative penalty or service credit that can be applied over the agreement period, expressed as a percentage of the total contract value. Limits the company\'s financial liability exposure from SLA breaches.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Applicable' ;
    rdfs:comment 'Indicates whether financial or service credit penalties apply to this SLA agreement when contractual thresholds are breached. True = penalty clauses are active; False = no penalty provisions. Drives financial exposure tracking and CAPA processes.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCreditPct rdf:type rdf:Property ;
    rdfs:label 'Penalty Credit Pct' ;
    rdfs:comment 'The percentage of the contracted service fee or invoice value that is credited or refunded to the customer for each SLA breach event, as defined in the penalty clause. Null when penalty_clause_applicable is False.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preventiveMaintenanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Included' ;
    rdfs:comment 'Indicates whether scheduled preventive maintenance visits are included as part of the SLA agreement entitlement. True = preventive maintenance is covered; False = corrective/reactive only. Linked to TPM programs managed in Maximo.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteMonitoringIncluded rdf:type rdf:Property ;
    rdfs:label 'Remote Monitoring Included' ;
    rdfs:comment 'Indicates whether IIoT-based remote monitoring and diagnostics of covered assets is included in the SLA agreement. True = remote monitoring via Aveva SCADA or IIoT platform is active; False = not included.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'The number of calendar days before the expiry date by which either party must provide written notice of intent to renew or terminate the SLA agreement. Triggers automated renewal alerts in Salesforce Service Cloud.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Hours' ;
    rdfs:comment 'The maximum number of hours within which a reported incident or service request must be fully resolved under this SLA agreement. Drives escalation rules and penalty clause triggers in Salesforce Service Cloud.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRegion rdf:type rdf:Property ;
    rdfs:label 'Service Region' ;
    rdfs:comment 'The primary geographic region where the SLA service commitments apply, expressed as an ISO 3166-1 alpha-3 country code (e.g., USA, DEU, GBR). Determines applicable regulatory requirements, support staffing, and logistics SLA parameters.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'The contractual service tier level assigned to this SLA agreement, determining the priority, response speed, and entitlements available to the customer. Platinum is the highest tier; Bronze is the base tier. Drives case prioritization in Salesforce Service Cloud.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA agreement by the primary service commitment it governs: response_time (initial response to incidents), uptime_guarantee (system/equipment availability), on_time_delivery (order fulfillment punctuality), support_entitlement (support tier access), or maintenance_coverage (preventive/corrective maintenance). [ENUM-REF-CANDIDATE: response_time|uptime_guarantee|on_time_delivery|support_entitlement|maintenance_coverage|field_service — promote to reference product]' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsIncluded rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Included' ;
    rdfs:comment 'Indicates whether the cost of spare parts and replacement components is covered under this SLA agreement. True = parts included; False = parts billed separately. Impacts inventory planning in SAP S/4HANA MM and WMS.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportHoursCoverage rdf:type rdf:Property ;
    rdfs:label 'Support Hours Coverage' ;
    rdfs:comment 'The contracted support availability window defining hours per day and days per week during which the service team is obligated to respond (e.g., 8x5 = 8 hours/day, 5 days/week; 24x7 = round-the-clock). Determines staffing and escalation routing in Salesforce Service Cloud.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The actual date on which the SLA agreement was terminated prior to its scheduled expiry date. Null for agreements that are active or expired naturally. Required for financial accrual reversal and CAPA closure in SAP S/4HANA.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'The reason code for early termination of the SLA agreement. Null when the agreement is active or expired naturally. Used for churn analysis, CAPA processes, and financial reporting.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimeTargetPct rdf:type rdf:Property ;
    rdfs:label 'Uptime Target Pct' ;
    rdfs:comment 'The contractually committed minimum system or equipment availability expressed as a percentage (e.g., 99.5 for 99.5% uptime). Applicable for uptime_guarantee SLA types. Used in OEE and availability reporting.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Site Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Site-level sales rep ownership is required for site-specific revenue tracking and service contract management.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:vendorSiteId rdf:type rdf:Property ;
    rdfs:label 'Vendor Site Id' ;
    rdfs:comment 'Foreign key linking to supplier.supplier_site. Business justification: Logistics scheduling links each customer site to the supplier site that delivers goods, enabling inbound receipt matching.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:accessRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Notes' ;
    rdfs:comment 'Free-text notes describing access restrictions, security clearance requirements, visitor registration procedures, or special entry protocols for field service engineers and delivery personnel at this site.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date on which the site was formally commissioned and became operational for Manufacturing product installations and services. Used to calculate site age, warranty period tracking, and lifecycle analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmSiteCode rdf:type rdf:Property ;
    rdfs:label 'Crm Site Code' ;
    rdfs:comment 'Salesforce CRM native identifier for this account site record. Used for cross-system data lineage, reconciliation between the lakehouse silver layer and the Salesforce source system, and audit traceability.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date on which the site was or is planned to be decommissioned. Populated when site_status transitions to \'decommissioned\'. Used for installed base retirement tracking and asset lifecycle reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalClassification rdf:type rdf:Property ;
    rdfs:label 'Environmental Classification' ;
    rdfs:comment 'Environmental condition classification of the site affecting product installation requirements, equipment ratings, and maintenance intervals. Informs selection of appropriate equipment IP ratings and material specifications. [ENUM-REF-CANDIDATE: standard|controlled|outdoor|corrosive|high_temperature|high_humidity — promote to reference product]' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpPlantCode rdf:type rdf:Property ;
    rdfs:label 'Erp Plant Code' ;
    rdfs:comment 'SAP S/4HANA plant code corresponding to this customer site. Used for cross-system reconciliation of delivery addresses, service orders, and inventory movements associated with this site.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySegment rdf:type rdf:Property ;
    rdfs:label 'Industry Segment' ;
    rdfs:comment 'Industry vertical or market segment classification of the customer site (e.g., Automotive, Food & Beverage, Oil & Gas, Utilities, Pharmaceuticals). Used for market analytics, product compatibility assessment, and regulatory compliance framework selection. [ENUM-REF-CANDIDATE: promote to reference product for full industry taxonomy]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedProductCount rdf:type rdf:Property ;
    rdfs:label 'Installed Product Count' ;
    rdfs:comment 'Total number of Manufacturing products currently installed and tracked at this site. Drives installed base analytics, preventive maintenance scheduling volume, and spare parts demand forecasting.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isHeadquarters rdf:type rdf:Property ;
    rdfs:label 'Is Headquarters' ;
    rdfs:comment 'Indicates whether this site is the primary headquarters or main facility of the customer account. Used for account hierarchy reporting, executive relationship management, and primary billing address determination.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSiteVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Site Visit Date' ;
    rdfs:comment 'Date of the most recent field service engineer or account manager visit to the site. Used for relationship management, service frequency analysis, and identifying sites overdue for preventive maintenance visits.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximoLocationCode rdf:type rdf:Property ;
    rdfs:label 'Maximo Location Code' ;
    rdfs:comment 'IBM Maximo Asset Management location identifier for this site. Used to link account site records to Maximo work orders, preventive maintenance plans, and asset hierarchies for field service execution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesSystemPresent rdf:type rdf:Property ;
    rdfs:label 'Mes System Present' ;
    rdfs:comment 'Indicates whether a Manufacturing Execution System (MES) is installed at the site. Used to assess integration readiness for Siemens Opcenter MES connectivity and shop floor data exchange.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkConnectivityType rdf:type rdf:Property ;
    rdfs:label 'Network Connectivity Type' ;
    rdfs:comment 'Primary network connectivity type available at the site for IIoT device integration, remote monitoring, and SCADA/MES connectivity. Determines feasibility of remote diagnostics and predictive maintenance services.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance visit at this site. Drives field service dispatch scheduling, spare parts pre-positioning, and resource capacity planning for the service organization.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfProductionLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Production Lines' ;
    rdfs:comment 'Count of active production lines at the manufacturing site. Used to estimate installed base potential, maintenance workload, and spare parts demand. Relevant for manufacturing plant site types.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operates24x7 rdf:type rdf:Property ;
    rdfs:label 'Operates 24x7' ;
    rdfs:comment 'Indicates whether the site operates continuously 24 hours a day, 7 days a week. When true, overrides operational_hours_start/end for scheduling purposes and may trigger higher SLA tier assignment.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operational Hours End' ;
    rdfs:comment 'Daily operational end time of the site in HH:MM (24-hour) format in the site\'s local time zone. Used to constrain field service scheduling, maintenance windows, and delivery cutoff times.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operational Hours Start' ;
    rdfs:comment 'Daily operational start time of the site in HH:MM (24-hour) format in the site\'s local time zone. Used to schedule field service visits, preventive maintenance windows, and delivery time slots within permitted hours.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantFloorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Plant Floor Area Sqm' ;
    rdfs:comment 'Total operational floor area of the site in square meters. Used for capacity planning, equipment density analysis, and logistics resource estimation for large-scale installations.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerSupplyFrequencyHz rdf:type rdf:Property ;
    rdfs:label 'Power Supply Frequency Hz' ;
    rdfs:comment 'Electrical supply frequency at the site in Hertz (50 or 60 Hz). Required for equipment compatibility validation for automation systems, drives, and electrification products.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerSupplyVoltage rdf:type rdf:Property ;
    rdfs:label 'Power Supply Voltage' ;
    rdfs:comment 'Primary electrical supply voltage standard at the site. Critical for ensuring compatibility of electrification solutions and automation equipment installed or to be installed at the site. [ENUM-REF-CANDIDATE: 110V|220V|380V|400V|480V|600V|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Safety and environmental classification of the site indicating special handling requirements for field service engineers and delivery personnel. Drives PPE requirements, access protocols, and compliance documentation. [ENUM-REF-CANDIDATE: hazardous|non_hazardous|restricted_access|cleanroom|explosion_proof — promote to reference product if additional classifications are required]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaSystemPresent rdf:type rdf:Property ;
    rdfs:label 'Scada System Present' ;
    rdfs:comment 'Indicates whether a SCADA system is installed and operational at the site. Relevant for integration planning with Aveva SCADA and for determining remote monitoring service eligibility.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the site across operational systems (SAP, Salesforce, Maximo). Used as the cross-system business key for site-level transactions, work orders, and shipments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactEmail rdf:type rdf:Property ;
    rdfs:label 'Site Contact Email' ;
    rdfs:comment 'Email address of the primary on-site contact for service notifications, maintenance scheduling confirmations, and delivery alerts.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactName rdf:type rdf:Property ;
    rdfs:label 'Site Contact Name' ;
    rdfs:comment 'Full name of the primary on-site contact person for field service coordination, delivery acceptance, and maintenance scheduling. Captured directly for operational use when the contact master record may not yet be established.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactPhone rdf:type rdf:Property ;
    rdfs:label 'Site Contact Phone' ;
    rdfs:comment 'Direct phone number for the primary on-site contact. Used by field service engineers and logistics teams for on-site coordination and delivery confirmation.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCriticalityRating rdf:type rdf:Property ;
    rdfs:label 'Site Criticality Rating' ;
    rdfs:comment 'Business-assigned criticality level of the site reflecting the operational impact of downtime or service disruption. Drives SLA priority, spare parts stocking strategy, and preventive maintenance frequency. Aligned with FMEA risk classification.' ;
    rdfs:domain ind:AccountSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name of the physical plant, factory, or facility location (e.g., \'Chicago North Assembly Plant\', \'Frankfurt Distribution Hub\'). Used in field service dispatch, logistics planning, and installed base reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle state of the customer site. Determines eligibility for field service dispatch, new product installations, and preventive maintenance scheduling. \'decommissioned\' sites are retained for historical installed base tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the facility type indicating the primary operational purpose of the site. Drives field service routing, SLA tier assignment, and preventive maintenance scheduling. [ENUM-REF-CANDIDATE: manufacturing_plant|warehouse|distribution_center|data_center|commercial_building|substation — promote to reference product if additional types are required]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentRegisterId rdf:type rdf:Property ;
    rdfs:label 'Equipment Register Id' ;
    rdfs:comment 'Unique surrogate identifier for each equipment record in the CapEx asset register. Primary key for the equipment_register data product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentRegister .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to supplier.agreement. Business justification: Equipment under active OEM service or warranty agreements must reference the governing agreement for warranty claim processing, service entitlement validation, and contract compliance — a standard req' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:configurationId rdf:type rdf:Property ;
    rdfs:label 'Configuration Id' ;
    rdfs:comment 'Foreign key linking to product.configuration. Business justification: As-built configuration tracking: industrial asset management requires knowing the exact product configuration installed (e.g., drive configured for specific voltage/power rating). This supports engine' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Configuration .

ind:drawingId rdf:type rdf:Property ;
    rdfs:label 'Drawing Id' ;
    rdfs:comment 'Foreign key linking to engineering.drawing. Business justification: Regulatory audit requires each equipment to reference its engineering drawing for compliance verification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Drawing .

ind:ecnId rdf:type rdf:Property ;
    rdfs:label 'Ecn Id' ;
    rdfs:comment 'Foreign key linking to engineering.ecn. Business justification: Engineering change implementation tracking: when an ECN modifies equipment design, the equipment register must reference the latest applicable ECN to reflect the current as-built configuration. Asset ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ecn .

ind:engineeringSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Engineering Specification Id' ;
    rdfs:comment 'Foreign key linking to engineering.specification. Business justification: Quality control tracks equipment against its engineering specification to ensure performance and safety standards.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringSpecification .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Capital asset lifecycle management requires linking the physical equipment record to its financial fixed_asset record for depreciation tracking, net book value reporting, insurance valuation, and CAPE' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: DEPRECIATION: Each asset is tied to a GL account for posting depreciation expense in financial statements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Foreign key linking to asset.location. Business justification: Every physical asset in the equipment register must be placed at a specific location (plant, building, floor, production cell). This is a fundamental CMMS relationship — equipment is installed at a lo' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Foreign key linking to inventory.material_master. Business justification: Capital asset procurement references a material master record; the link supports cost, valuation, and purchase-order reporting across asset and inventory modules.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Foreign key linking to production.production_line. Business justification: Equipment is physically installed on a production line; essential for line-level OEE aggregation, production line capacity analysis, and maintenance impact assessment. Industrial manufacturing asset r' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionLine .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Foreign key linking to supplier.site. Business justification: Equipment traceability requires knowing the specific supplier manufacturing site of origin — critical for warranty claims, product recalls, and regulatory compliance. equipment_register.manufacturer_n' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:stockLocationId rdf:type rdf:Property ;
    rdfs:label 'Stock Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_location. Business justification: Business process: Asset Receiving & Storage requires tracking which warehouse bin new equipment is stored in before installation, enabling inventory valuation and location reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLocation .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Foreign key linking to production.work_center. Business justification: Equipment is physically assigned to a work center; this is fundamental to capacity planning, OEE reporting, and maintenance scheduling. work_center_code on equipment_register is a denormalization of t' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'Broad category grouping for the asset used in CapEx asset register classification, depreciation policy assignment, and financial reporting under IFRS/GAAP fixed asset schedules.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique asset tag or equipment number assigned in the CapEx asset register and stamped on the physical asset. Corresponds to the Maximo Asset Number and SAP S/4HANA Equipment Number (PM module). Serves as the primary business identifier for cross-system reconciliation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the rated capacity value (e.g., \'units/hr\', \'kg/hr\', \'tonnes/day\', \'cycles/min\'). Required to correctly interpret and compare capacity figures across heterogeneous equipment types.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Condition At Transfer' ;
    rdfs:comment 'Recorded physical condition grade of the equipment at the time of its most recent transfer or relocation. Provides a point-in-time condition snapshot for the location assignment history audit trail and insurance/liability documentation.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Current physical condition assessment grade of the equipment based on the most recent inspection or condition monitoring evaluation. Used in asset lifecycle management decisions (repair vs. replace), maintenance prioritization, and insurance assessments.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityRanking rdf:type rdf:Property ;
    rdfs:label 'Criticality Ranking' ;
    rdfs:comment 'Business criticality classification of the equipment based on its impact on production throughput, safety, and quality if it fails. Critical assets receive priority maintenance resources and are included in TPM and FMEA programs. Used in maintenance strategy selection and spare parts stocking decisions.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentClass rdf:type rdf:Property ;
    rdfs:label 'Equipment Class' ;
    rdfs:comment 'High-level classification of the equipment type used for asset categorization, maintenance strategy assignment, and reporting. [ENUM-REF-CANDIDATE: CNC Machine|PLC|Robotics|Conveyor|HVAC|Compressor|Pump|Electrical Panel|Facility Infrastructure|Inspection Equipment — promote to reference product]' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable descriptive name of the equipment or asset (e.g., \'CNC Milling Machine #3\', \'Conveyor Belt Line A\'). Used as the primary identity label for display in reports, dashboards, and work orders.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocation rdf:type rdf:Property ;
    rdfs:label 'Functional Location' ;
    rdfs:comment 'Hierarchical functional location code (e.g., PLANT-AREA-LINE-STATION) representing the physical and functional position of the equipment within the facility structure. Corresponds to the SAP PM Functional Location and Maximo Location fields. Supports spatial analytics and maintenance planning.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date on which the equipment was physically installed at its designated location. May precede commissioning date if acceptance testing or qualification activities are required before productive use.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent formal inspection or condition assessment performed on the equipment. Used to track regulatory inspection compliance intervals and condition monitoring schedules.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date on which the most recent completed maintenance activity (preventive or corrective) was performed on the equipment. Used to calculate maintenance intervals, overdue PM alerts, and MTBF analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransferDate rdf:type rdf:Property ;
    rdfs:label 'Last Transfer Date' ;
    rdfs:comment 'Date of the most recent location transfer or relocation of the equipment. Part of the location assignment history audit trail tracking asset movements between plants, production lines, or storage areas.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransferDestination rdf:type rdf:Property ;
    rdfs:label 'Last Transfer Destination' ;
    rdfs:comment 'Functional location or plant code to which the equipment was most recently transferred. Provides the destination leg of the location transfer audit trail for asset movement traceability.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTransferOrigin rdf:type rdf:Property ;
    rdfs:label 'Last Transfer Origin' ;
    rdfs:comment 'Functional location or plant code from which the equipment was most recently transferred. Provides the origin leg of the location transfer audit trail for asset movement traceability.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTransferReason rdf:type rdf:Property ;
    rdfs:label 'Last Transfer Reason' ;
    rdfs:comment 'Business reason code for the most recent equipment relocation or transfer. Part of the location assignment history audit trail required for asset tracking compliance and CapEx asset register accuracy.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Assigned maintenance approach for the equipment as defined in the Maximo CMMS and SAP PM maintenance plan. Drives scheduling of preventive maintenance (PM) work orders, TPM activities, and condition monitoring programs.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date on which the equipment was manufactured by the OEM. Used to calculate equipment age, assess remaining useful life, and determine warranty expiry.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meanTimeBetweenFailures rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures' ;
    rdfs:comment 'Average elapsed time in hours between successive equipment failures, calculated from historical work order and downtime event data. Key reliability KPI used in TPM programs, maintenance strategy optimization, and OEE analysis. Expressed in hours.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepair rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair' ;
    rdfs:comment 'Average elapsed time in hours required to restore the equipment to operational status following a failure, calculated from historical corrective maintenance work orders. Key maintainability KPI used in TPM and SLA management. Expressed in hours.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'OEM-assigned model or part number for the equipment. Used for spare parts procurement, technical documentation lookup, and warranty claims.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next planned preventive maintenance activity on the equipment, as calculated by the maintenance plan in SAP PM or Maximo. Drives work order generation and maintenance scheduling.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational lifecycle state of the equipment. Drives maintenance scheduling, OEE calculations, and asset availability reporting. \'In Service\' indicates active production use; \'Decommissioned\' triggers asset write-off in SAP FI-AA.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerRatingKw rdf:type rdf:Property ;
    rdfs:label 'Power Rating Kw' ;
    rdfs:comment 'Nominal electrical power consumption rating of the equipment in kilowatts as specified by the OEM. Used for energy management planning, ISO 50001 energy audits, electrical load balancing, and CapEx infrastructure sizing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratedCapacity rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity' ;
    rdfs:comment 'OEM-specified nominal production capacity or throughput rating of the equipment (e.g., units per hour, tonnes per day). Serves as the denominator for OEE availability and performance calculations and production planning in APS.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the equipment record was first created in the master data system (Maximo or SAP S/4HANA). Provides the record creation audit trail for data governance and MDM lineage tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the equipment record in the master data system. Used for change detection, data synchronization between Maximo and SAP, and MDM data quality monitoring.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:replacementValue rdf:type rdf:Property ;
    rdfs:label 'Replacement Value' ;
    rdfs:comment 'Current estimated cost to replace the equipment with an equivalent new asset. Used for insurance valuation, CapEx planning, and asset renewal decision-making. Updated periodically based on market pricing.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for the specific equipment unit. Used for warranty registration, OEM service calls, and regulatory compliance traceability. Classified as confidential device identifier.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferAuthorizationRef rdf:type rdf:Property ;
    rdfs:label 'Transfer Authorization Ref' ;
    rdfs:comment 'Reference number of the authorization document (e.g., work order, change request, or management approval) that sanctioned the most recent equipment transfer or relocation. Provides the authorization audit trail for asset movement governance.' ;
    rdfs:domain ind:EquipmentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date on which the OEM or supplier warranty for the equipment expires. Used to trigger preventive maintenance strategy transitions from warranty-covered to self-maintained, and to initiate extended warranty negotiations.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Physical weight of the equipment in kilograms as specified by the OEM. Used for facility floor load planning, rigging and relocation logistics, and transportation planning during asset transfers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentLocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Location Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent location in the functional location hierarchy. Enables recursive traversal of the plant topology from site level down to individual bay/cell coordinates. Null for top-level (plant/site) locations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Foreign key linking to production.plant. Business justification: Locations belong to a plant; required for plant-level maintenance planning, regulatory compliance reporting by plant, and energy/safety zone management. Industrial manufacturing asset hierarchies alwa' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Foreign key linking to engineering.engineering_project. Business justification: Project asset management assigns physical locations to engineering projects for planning and reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: In industrial manufacturing, plant and site locations are mapped to sales territories for service coverage assignment, revenue attribution by region, and key account management. Territory-based servic' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the facility or plant location. Used for regulatory reporting, logistics coordination, emergency services, and legal documentation. Classified as confidential organizational address data.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqm rdf:type rdf:Property ;
    rdfs:label 'Area Sqm' ;
    rdfs:comment 'Physical floor area of the location in square metres. Used for capacity planning, safety zone sizing, equipment layout design, and facility management reporting. Represents the principal quantitative measurement of the location resource.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atexZoneClassification rdf:type rdf:Property ;
    rdfs:label 'Atex Zone Classification' ;
    rdfs:comment 'Explosive atmosphere zone classification per ATEX Directive 2014/34/EU and IEC 60079 standard (e.g., Zone 0, Zone 1, Zone 2 for gas/vapour; Zone 20, Zone 21, Zone 22 for dust). Mandatory for equipment selection, safety inspections, and regulatory compliance in hazardous areas. Null if location is not classified as hazardous.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific building or structure within the plant site where this location resides (e.g., \'BLD-A\', \'HALL-3\'). Used for maintenance routing, emergency response planning, and facility management.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexAssetRegisterCode rdf:type rdf:Property ;
    rdfs:label 'Capex Asset Register Code' ;
    rdfs:comment 'SAP S/4HANA FI-AA (Fixed Asset Accounting) asset register code associated with this location for CapEx tracking, depreciation calculation, and balance sheet reporting. Links the physical location to the financial asset register per IFRS/GAAP fixed asset accounting standards.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceilingHeightM rdf:type rdf:Property ;
    rdfs:label 'Ceiling Height M' ;
    rdfs:comment 'Clear ceiling height at this location in metres. Determines suitability for tall equipment installation (e.g., overhead cranes, tall CNC machines, robotic gantries), forklift operation clearance, and ventilation system design.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleanRoomClassification rdf:type rdf:Property ;
    rdfs:label 'Clean Room Classification' ;
    rdfs:comment 'ISO 14644-1 clean room classification for controlled environment locations (ISO 1 through ISO 9, representing particle count per cubic metre). Governs equipment installation requirements, personnel access protocols, and environmental monitoring for precision manufacturing, electronics assembly, or pharmaceutical-adjacent processes. Null if not a controlled environment.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationM rdf:type rdf:Property ;
    rdfs:label 'Elevation M' ;
    rdfs:comment 'Elevation of the location above mean sea level in metres (WGS84). Used for environmental zone classification, flood risk assessment, HVAC system design, and precision asset installation requirements in multi-storey or outdoor facilities.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyZoneCode rdf:type rdf:Property ;
    rdfs:label 'Energy Zone Code' ;
    rdfs:comment 'Energy management zone code assigned to this location per ISO 50001 energy management system. Groups locations into energy monitoring boundaries for sub-metering, energy consumption reporting, and energy efficiency KPI calculation by production area.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalZoneCode rdf:type rdf:Property ;
    rdfs:label 'Environmental Zone Code' ;
    rdfs:comment 'Environmental monitoring zone code per ISO 14001 environmental management system. Groups locations for emissions monitoring, waste management tracking, and environmental compliance reporting to EPA and regulatory bodies.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireZoneCode rdf:type rdf:Property ;
    rdfs:label 'Fire Zone Code' ;
    rdfs:comment 'Fire compartment or zone code assigned to this location per fire safety regulations and building codes (e.g., \'FZ-A1\', \'COMP-03\'). Used for fire suppression system mapping, emergency response planning, and compliance with NFPA and local fire codes.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Identifier for the floor or level within a building where this location is situated (e.g., \'G\', \'1\', \'2\', \'B1\', \'MEZZANINE\'). Supports maintenance technician routing, emergency evacuation planning, and vertical spatial queries.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationCode rdf:type rdf:Property ;
    rdfs:label 'Functional Location Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying the functional location per Maximo FL structure and IEC 81346 reference designation system (e.g., PLT01-BLD02-FL03-WC04). Used as the primary business identifier for spatial referencing, maintenance routing, and asset installation tracking.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this location within the functional location hierarchy (1 = plant/site, 2 = building/area, 3 = floor/zone, 4 = production line, 5 = work center, 6 = bay/cell). Enables hierarchical rollup queries for OEE analysis, maintenance cost aggregation, and spatial reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iecReferenceDesignation rdf:type rdf:Property ;
    rdfs:label 'Iec Reference Designation' ;
    rdfs:comment 'Structured reference designation code per IEC 81346 standard for industrial systems (e.g., \'=A1+B2-C3\'). Provides internationally standardized identification of the location within the technical system hierarchy, enabling interoperability with engineering documentation, CAD/CAM systems, and PLM.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedAssetCount rdf:type rdf:Property ;
    rdfs:label 'Installed Asset Count' ;
    rdfs:comment 'Current count of physical assets installed at this location as recorded in Maximo. Provides a snapshot of location utilization density for capacity planning, maintenance workload estimation, and facility layout optimization. Updated by the asset installation/deinstallation process.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isOutdoor rdf:type rdf:Property ;
    rdfs:label 'Is Outdoor' ;
    rdfs:comment 'Indicates whether this location is an outdoor or open-air area (True) versus an enclosed indoor facility (False). Determines weatherproofing requirements for installed assets, IP rating specifications for equipment, and applicable environmental protection standards.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestrictedAccess rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Access' ;
    rdfs:comment 'Indicates whether this location requires special authorization, permits, or PPE for personnel access (True) beyond standard plant access controls. Drives access management workflows, permit-to-work systems, and safety induction requirements for maintenance technicians.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Free-text detailed description of the asset location including physical characteristics, operational context, special conditions, and any relevant notes for maintenance technicians (e.g., \'North-east corner of Building A, adjacent to emergency exit 3, high-vibration environment due to press operations\').' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable descriptive name of the asset location (e.g., \'Assembly Line 3 - Bay 7\', \'CNC Machining Cell A\'). Used in maintenance work orders, safety documentation, and OEE reporting to identify the physical location clearly.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current lifecycle status of the asset location indicating whether it is operationally active, temporarily inactive, decommissioned, under construction, or reserved for future use. Controls whether assets can be installed at this location and whether maintenance work orders can be raised against it.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the location within the facility hierarchy (e.g., plant, building, floor, production_line, work_center, bay, cell). Drives hierarchy navigation, maintenance routing logic, and spatial analytics. [ENUM-REF-CANDIDATE: plant|building|floor|production_line|work_center|bay|cell|storage_area|utility_room|outdoor_area — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePlannerGroup rdf:type rdf:Property ;
    rdfs:label 'Maintenance Planner Group' ;
    rdfs:comment 'SAP S/4HANA PM or Maximo planner group code responsible for planning and scheduling preventive maintenance (PM) and corrective maintenance work orders at this location. Drives maintenance routing, resource allocation, and TPM scheduling.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWorkCenter rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Center' ;
    rdfs:comment 'SAP S/4HANA PM maintenance work center responsible for executing maintenance activities at this location. Distinct from the production work center; this identifies the maintenance crew or workshop assigned for TPM, corrective maintenance, and breakdown response.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAssetCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Asset Capacity' ;
    rdfs:comment 'Maximum number of assets that can be physically installed at this location based on space, power, and structural constraints. Used for capacity planning, CapEx project scoping, and facility layout design to prevent over-installation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxLoadCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Max Load Capacity Kg' ;
    rdfs:comment 'Maximum permissible floor or structural load capacity at this location in kilograms. Critical for equipment installation planning, CapEx asset placement decisions, and structural safety compliance. Prevents overloading of floors, platforms, or mezzanines during asset installation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkSegment rdf:type rdf:Property ;
    rdfs:label 'Network Segment' ;
    rdfs:comment 'Industrial network segment or VLAN identifier assigned to this location for IIoT device connectivity, SCADA/DCS integration, and PLC communication (e.g., \'OT-ZONE-A\', \'SCADA-NET-02\'). Supports IEC 62443 industrial cybersecurity zone and conduit model for network segmentation compliance.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmScheduleType rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Type' ;
    rdfs:comment 'Type of preventive maintenance scheduling strategy applied to assets at this location (time_based, usage_based, condition_based, or none). Supports TPM strategy configuration, maintenance planning in Maximo, and predictive maintenance analytics.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerSupplyType rdf:type rdf:Property ;
    rdfs:label 'Power Supply Type' ;
    rdfs:comment 'Primary electrical power supply specification available at this location (e.g., AC_220V, AC_480V, DC_24V). Governs equipment compatibility for asset installation, PLC and CNC machine power requirements, and electrical safety compliance per IEC 61131 and NEC standards.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLineCode rdf:type rdf:Property ;
    rdfs:label 'Production Line Code' ;
    rdfs:comment 'Code identifying the production line associated with this location (e.g., \'LINE-01\', \'ASSY-B\'). Links the physical location to production scheduling, OEE measurement, and Siemens Opcenter MES work center definitions for throughput and cycle time analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyZoneType rdf:type rdf:Property ;
    rdfs:label 'Safety Zone Type' ;
    rdfs:comment 'Safety zone designation for the location per OSHA and ISO 45001 requirements (e.g., general access, restricted, exclusion zone, emergency assembly point, fire zone, chemical storage). Drives access control, PPE requirements, and emergency response planning. [ENUM-REF-CANDIDATE: general|restricted|exclusion|emergency_assembly|fire_zone|chemical_storage — promote to reference product]' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA time zone identifier for the location (e.g., \'Europe/Berlin\', \'America/Detroit\'). Critical for accurate timestamp interpretation of SCADA/MES events, shift scheduling, maintenance work order timing, and cross-site production reporting across time zones.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'SAP S/4HANA or Opcenter MES work center code associated with this functional location. Enables direct linkage between the physical location and production planning, capacity scheduling, and cost center allocation for manufacturing execution analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Asset Work Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the maintenance work order record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetWorkOrder .

ind:engineeringRevisionId rdf:type rdf:Property ;
    rdfs:label 'Engineering Revision Id' ;
    rdfs:comment 'Foreign key linking to engineering.revision. Business justification: Implementation work orders must reference the specific engineering revision they are executing (ECO/ECN driven change).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringRevision .

ind:jobPlanId rdf:type rdf:Property ;
    rdfs:label 'Job Plan Id' ;
    rdfs:comment 'Reference to the maintenance plan or strategy record under which this work order was generated. Links to the strategic maintenance plan defining the maintenance approach for the asset class.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobPlan .

ind:parentWorkOrderAssetWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Parent Work Order Asset Work Order Id' ;
    rdfs:comment 'Self-referencing identifier linking this work order to a parent work order, used for shutdown/turnaround scope decomposition or hierarchical work order structures. Null for top-level work orders.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetWorkOrder .

ind:plannedOrderId rdf:type rdf:Property ;
    rdfs:label 'Planned Order Id' ;
    rdfs:comment 'Foreign key linking to supply.planned_order. Business justification: Execution of a Planned Order creates a Work Order; required for the \'Planned Order Execution\' report linking production planning to execution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlannedOrder .

ind:productionWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Work Order Id' ;
    rdfs:comment 'Foreign key linking to production.production_work_order. Business justification: Maintenance work orders raised due to equipment failure during production are linked to the triggering production work order for cost allocation, OEE impact analysis, and production loss attribution —' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionWorkOrder .

ind:actualFinishDate rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Date' ;
    rdfs:comment 'Actual date and time when maintenance execution was completed and the asset was returned to service. Used for MTTR calculation, downtime reporting, and OEE analysis.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'Actual cost of labor incurred for executing this work order, calculated from actual labor hours and applicable craft rates. Used for total maintenance cost reporting and OpEx analysis.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Total labor hours actually expended by all technicians in executing this work order. Captured from time reporting in Maximo or Workday. Used for cost variance analysis and workforce productivity reporting.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Actual Material Cost' ;
    rdfs:comment 'Actual cost of spare parts and materials consumed during execution of this work order, in the local operating currency. Sourced from inventory issue transactions in Maximo/SAP MM. Used for maintenance cost variance and OpEx reporting.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date and time when maintenance execution commenced on this work order. Captured by the technician via MES or Maximo mobile. Used for MTTR calculation and schedule adherence analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductionLines rdf:type rdf:Property ;
    rdfs:label 'Affected Production Lines' ;
    rdfs:comment 'Comma-separated list or description of production lines impacted by this work order\'s execution. Applicable primarily for shutdown/turnaround and emergency work orders. Used for production scheduling coordination.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCriticality rdf:type rdf:Property ;
    rdfs:label 'Asset Criticality' ;
    rdfs:comment 'Criticality classification of the asset at the time this work order was created, indicating the business impact of asset failure. Drives maintenance prioritization and resource allocation. Derived from the asset master criticality assessment.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexOpexClassification rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Classification' ;
    rdfs:comment 'Financial classification of the work order costs as either Capital Expenditure (CapEx) for asset improvements/replacements or Operational Expenditure (OpEx) for routine maintenance and repairs. Critical for financial reporting under IFRS/GAAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionCode rdf:type rdf:Property ;
    rdfs:label 'Completion Code' ;
    rdfs:comment 'Standardized code indicating the outcome or resolution of the work order upon completion (e.g., repaired, replaced, adjusted, no fault found, deferred). Used for failure analysis and maintenance effectiveness reporting. Corresponds to ACTFINISH resolution codes in Maximo.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRemarks rdf:type rdf:Property ;
    rdfs:label 'Completion Remarks' ;
    rdfs:comment 'Free-text technician notes documenting the work performed, findings, parts replaced, and any follow-up actions recommended upon work order completion. Captured in Maximo WORKLOG or SAP PM notification.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craftType rdf:type rdf:Property ;
    rdfs:label 'Craft Type' ;
    rdfs:comment 'The maintenance craft or trade skill classification required and assigned to execute this work order (e.g., Electrician, Millwright, Instrumentation Technician, Welder, Pipefitter). Corresponds to CRAFT in Maximo Labor records.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Hours' ;
    rdfs:comment 'Total production downtime in hours caused by the failure or maintenance activity associated with this work order. Core input for OEE availability calculation and MTTR analysis. Null if the work order did not cause production downtime.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Standardized failure classification code identifying the root cause or failure mode that originated this work order. Used for FMEA analysis, MTBF/MTTR trending, and CAPA tracking. Corresponds to FAILURECODE in Maximo and Cause Code in SAP PM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Free-text narrative describing the observed failure, fault symptom, or maintenance trigger that initiated this work order. Captured by the originating technician or operator at time of request.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProductionImpacting rdf:type rdf:Property ;
    rdfs:label 'Is Production Impacting' ;
    rdfs:comment 'Indicates whether this work order caused or required a production stoppage or capacity reduction. True = production was impacted; False = maintenance performed without production impact (e.g., running maintenance). Key filter for OEE and availability reporting.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Detailed narrative of the scope of work, maintenance instructions, safety precautions, and special requirements for executing this work order. Corresponds to LDTEXT in Maximo.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrReference rdf:type rdf:Property ;
    rdfs:label 'Ncr Reference' ;
    rdfs:comment 'Reference number of any Non-Conformance Report (NCR) or CAPA record linked to this work order, where the maintenance activity was triggered by or resulted in a quality non-conformance event.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedFinishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Date' ;
    rdfs:comment 'Scheduled date and time when execution of this work order is planned to be completed. Used for production downtime planning and resource scheduling. Corresponds to SCHEDFINISH in Maximo.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Planned Labor Hours' ;
    rdfs:comment 'Total labor hours estimated and planned for executing this work order across all assigned crafts. Used for resource capacity planning, scheduling, and budget estimation. Corresponds to ESTLABHRS in Maximo.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Planned Material Cost' ;
    rdfs:comment 'Estimated cost of spare parts and materials planned for this work order, in the local operating currency. Used for maintenance budget planning and CapEx/OpEx classification. Corresponds to ESTMATCOST in Maximo.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date and time when execution of this work order is planned to begin. Used for maintenance scheduling, resource planning, and production coordination. Corresponds to SCHEDSTART in Maximo.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmScheduleId rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Id' ;
    rdfs:comment 'Reference to the preventive maintenance schedule master record that generated this work order, if applicable. Null for corrective or emergency work orders. Corresponds to PM record in Maximo.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PmSchedule .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority ranking assigned to the work order indicating urgency and scheduling precedence. Priority 1 (Emergency) requires immediate response; Priority 5 (Low) is deferred maintenance. Drives scheduling in APS and resource allocation decisions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date and time when the maintenance need was first reported or the work order was created in the source system. Represents the principal business event timestamp for this transaction. Corresponds to REPORTDATE in Maximo.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Safety Permit Number' ;
    rdfs:comment 'Reference number of the safety permit (e.g., LOTO permit, hot work permit) issued for this work order. Null if no permit is required. Supports OSHA compliance audit trails.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Permit Required' ;
    rdfs:comment 'Indicates whether a safety permit (e.g., Lockout/Tagout, hot work permit, confined space entry permit) is required before executing this work order. Drives safety compliance workflow in Maximo. Mandatory for OSHA and ISO 45001 compliance.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shutdownScopeSummary rdf:type rdf:Property ;
    rdfs:label 'Shutdown Scope Summary' ;
    rdfs:comment 'For shutdown or turnaround-type work orders only: a structured summary of the full scope of work to be executed during the planned outage. Null for non-shutdown work orders.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEstimatedCost rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Cost' ;
    rdfs:comment 'Total estimated cost for this work order encompassing planned labor, materials, and any additional service costs. Used for maintenance budget approval workflows and CapEx authorization. Corresponds to ESTLABCOST + ESTMATCOST + ESTSERVCOST in Maximo.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tpmPillar rdf:type rdf:Property ;
    rdfs:label 'Tpm Pillar' ;
    rdfs:comment 'Classification of the work order under the applicable Total Productive Maintenance (TPM) pillar framework. Enables TPM program performance tracking and OEE improvement analysis. Null if the work order is not part of a formal TPM program.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Work Order Description' ;
    rdfs:comment 'Short descriptive title or summary of the maintenance task to be performed. Displayed on work order printouts and shop floor scheduling boards. Corresponds to DESCRIPTION in Maximo WORKORDER table.' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally-known, human-readable work order number assigned by the source system (Maximo or SAP PM). Used for cross-system reference, shop floor communication, and audit trails. Corresponds to WONUM in Maximo and Order Number in SAP PM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderSource rdf:type rdf:Property ;
    rdfs:label 'Work Order Source' ;
    rdfs:comment 'System or channel through which this work order was originated. Enables source system traceability and analysis of maintenance demand drivers (e.g., SCADA alarm-triggered vs. manually created vs. IoT condition-based alert). [ENUM-REF-CANDIDATE: maximo|sap_pm|scada_alarm|iot_alert|manual|inspection|operator_request — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle state of the work order workflow. Tracks progression from creation through approval, material staging, execution, completion, and closure. Corresponds to STATUS field in Maximo WORKORDER table. [ENUM-REF-CANDIDATE: draft|approved|waiting_material|in_progress|on_hold|completed|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentId rdf:type rdf:Property ;
    rdfs:label 'Component Id' ;
    rdfs:comment 'Foreign key linking to engineering.component. Business justification: Preventive-maintenance schedules are created per component type to align with design-life expectations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:sparePartId rdf:type rdf:Property ;
    rdfs:label 'Spare Part Id' ;
    rdfs:comment 'Foreign key linking to the spare part master record required by this PM schedule' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePart .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which this PM schedule was formally approved by the authorized maintenance manager or engineering authority. Marks the schedule as valid for work order generation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetPmScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Pm Schedule Description' ;
    rdfs:comment 'Detailed narrative description of the preventive maintenance schedule, including the scope of work, maintenance objectives, and any special instructions or safety precautions relevant to the task.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Condition Threshold Unit' ;
    rdfs:comment 'Unit of measure for the condition monitoring threshold value (e.g., mm/s for vibration velocity, °C for temperature, cSt for oil viscosity). Provides context for interpreting condition_threshold_value.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Condition Threshold Value' ;
    rdfs:comment 'Numeric threshold value for condition-based PM triggering. When the monitored parameter (e.g., vibration amplitude, temperature, oil viscosity) exceeds this value, a PM work order is generated. Applicable when trigger_type is CONDITION.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'Number of maintenance technicians or craft workers required to execute this PM task simultaneously. Used for labor resource planning and shift scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date after which this PM schedule is no longer active and will not generate new work orders. Null for open-ended schedules. Used when an asset is decommissioned or a maintenance program is superseded.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this PM schedule becomes active and eligible to generate work orders. Supports phased rollout of new maintenance programs and asset commissioning workflows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Hours' ;
    rdfs:comment 'Estimated number of hours the asset will be unavailable for production during execution of this PM task. Used in OEE calculations, production scheduling, and downtime planning.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Estimated number of labor hours required to complete the preventive maintenance task. Used for maintenance scheduling, craft resource planning, and downtime window estimation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Material Cost' ;
    rdfs:comment 'Estimated cost of materials and spare parts required to execute this PM task, in the local operating currency. Used for maintenance budget planning and CapEx/OpEx cost allocation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyUnit rdf:type rdf:Property ;
    rdfs:label 'Frequency Unit' ;
    rdfs:comment 'Unit of measure for the PM recurrence frequency. Combined with frequency_value to define the full interval (e.g., 30 DAYS, 500 HOURS, 10000 CYCLES). Determines whether the schedule is calendar-based or meter-based. [ENUM-REF-CANDIDATE: DAYS|WEEKS|MONTHS|YEARS|HOURS|CYCLES|KILOMETERS — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyValue rdf:type rdf:Property ;
    rdfs:label 'Frequency Value' ;
    rdfs:comment 'Numeric value representing how often the PM task should recur. Interpreted in conjunction with frequency_unit (e.g., a value of 30 with unit DAYS means every 30 days; a value of 500 with unit HOURS means every 500 operating hours).' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCriticalForPm rdf:type rdf:Property ;
    rdfs:label 'Is Critical For Pm' ;
    rdfs:comment 'Indicates whether this spare part is critical for PM execution — i.e., the PM task cannot be safely or effectively completed without this part being available. Drives pre-staging and kitting priority decisions.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Indicates whether this PM schedule is mandated by a regulatory body (e.g., OSHA, EPA, UL, CE Marking authority) and must be completed and documented for compliance purposes. Drives audit trail requirements.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyCritical rdf:type rdf:Property ;
    rdfs:label 'Is Safety Critical' ;
    rdfs:comment 'Indicates whether this PM schedule is classified as safety-critical, meaning non-execution could result in personnel injury, environmental incident, or regulatory violation. Safety-critical PMs require mandatory completion tracking.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Last Completion Date' ;
    rdfs:comment 'Date on which the most recent execution of this PM schedule was completed and the corresponding work order was closed. Used as the baseline for calculating the next due date.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRevisedDate rdf:type rdf:Property ;
    rdfs:label 'Last Revised Date' ;
    rdfs:comment 'Date on which this PM schedule definition was last revised or updated. Supports document control, audit trails, and change management processes.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeBufferDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Buffer Days' ;
    rdfs:comment 'Number of additional buffer days beyond the spare part\'s standard lead time that the planner has specified for this PM-part combination. Accounts for PM-specific procurement complexity or criticality. Belongs to the relationship, not to the part master or PM schedule alone.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Number of days before the next_due_date that the PM work order should be generated to allow sufficient time for parts procurement, scheduling, and preparation. Supports JIT maintenance planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Classification of the maintenance activity type. PREVENTIVE: time/usage-based task to prevent failure. PREDICTIVE: condition-monitoring-driven task. INSPECTION: regulatory or quality inspection. LUBRICATION: lubrication task. CALIBRATION: instrument calibration. OVERHAUL: major scheduled overhaul.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterUnit rdf:type rdf:Property ;
    rdfs:label 'Meter Unit' ;
    rdfs:comment 'Unit of measure for the meter reading used in meter-based PM scheduling (e.g., HOURS for operating hours, CYCLES for press strokes, KILOMETERS for vehicle mileage). Null when trigger_type is CALENDAR only.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Calculated date on which the next preventive maintenance work order is due to be generated or executed. Derived from last_completion_date plus the frequency interval. Drives maintenance scheduling and resource planning.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDueMeterReading rdf:type rdf:Property ;
    rdfs:label 'Next Due Meter Reading' ;
    rdfs:comment 'Meter reading value (e.g., operating hours, cycle count, kilometers) at which the next PM work order is due. Applicable when trigger_type is METER or when a meter-based override supplements calendar scheduling.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRequired rdf:type rdf:Property ;
    rdfs:label 'Quantity Required' ;
    rdfs:comment 'The quantity of this spare part required to complete one full execution of the associated PM schedule. Belongs to the relationship — the same part may be required in different quantities on different PM schedules.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Specific regulatory standard, clause, or requirement that mandates this PM schedule (e.g., \'OSHA 29 CFR 1910.217 Mechanical Power Presses\', \'ISO 9001:2015 Clause 7.1.5 Monitoring Resources\'). Populated when is_regulatory_required is True.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Document revision number for this PM schedule, incremented when the schedule definition is updated (e.g., frequency change, task scope change, job plan update). Supports document control and change management per ISO 9001.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name or title describing the preventive maintenance schedule (e.g., \'Monthly Lubrication — CNC Spindle\', \'Annual Safety Inspection — Conveyor Line 3\'). Used for display and search.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the PM schedule, as assigned in Maximo Asset Management. Used for cross-system reference and field communication (e.g., PM-2024-00123).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the preventive maintenance schedule. ACTIVE schedules generate work orders automatically. SUSPENDED schedules are temporarily paused (e.g., during planned shutdown). CLOSED schedules are retired.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceInJobPlan rdf:type rdf:Property ;
    rdfs:label 'Sequence In Job Plan' ;
    rdfs:comment 'The sequential position in the PM job plan task list at which this spare part is consumed or installed. Enables technicians to stage parts in the correct order for efficient PM execution. Belongs to the PM-part relationship, not to either entity independently.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordering sequence number for this PM schedule within a TPM task sequence or maintenance route. Enables ordered execution of multiple PM tasks on the same asset or production line during a maintenance window.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownRequired rdf:type rdf:Property ;
    rdfs:label 'Shutdown Required' ;
    rdfs:comment 'Indicates whether the asset must be taken offline (production shutdown) to perform this PM task. Critical for production planning and scheduling maintenance windows to minimize OEE impact.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sparePartsRequired rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Required' ;
    rdfs:comment 'Indicates whether this PM task requires spare parts or consumable materials to be reserved or procured prior to execution. Triggers inventory reservation in WMS or SAP MM when True.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toleranceDays rdf:type rdf:Property ;
    rdfs:label 'Tolerance Days' ;
    rdfs:comment 'Allowable number of days before or after the next_due_date within which the PM task can be performed without being considered overdue. Provides scheduling flexibility while maintaining compliance.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'Mechanism that triggers the generation of a work order for this PM schedule. CALENDAR: time-based (e.g., every 30 days). METER: usage-based (e.g., every 500 operating hours). CONDITION: condition-based monitoring threshold breach. SEASONAL: tied to seasonal calendar. EVENT: triggered by a specific operational event.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderCount rdf:type rdf:Property ;
    rdfs:label 'Work Order Count' ;
    rdfs:comment 'Cumulative count of work orders that have been generated from this PM schedule since its creation. Provides a historical activity indicator and supports MTBF/MTTR analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableEquipmentClass rdf:type rdf:Property ;
    rdfs:label 'Applicable Equipment Class' ;
    rdfs:comment 'Equipment class or asset type classification code for which this job plan is applicable (e.g., CNC-LATHE, ROBOT-WELDING, CONVEYOR-BELT, COMPRESSOR-SCREW). Enables automatic job plan assignment when creating PM schedules for assets of a given class.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confinedSpaceEntry rdf:type rdf:Property ;
    rdfs:label 'Confined Space Entry' ;
    rdfs:comment 'Indicates whether this job plan involves entry into a permit-required confined space as defined by OSHA 29 CFR 1910.146. Triggers additional safety controls, atmospheric testing, and standby attendant requirements.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Estimated total labor cost to execute this job plan, calculated from craft rates and estimated hours. Used for maintenance budget planning and CapEx/OpEx analysis. Expressed in the operational currency.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyInterval rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval' ;
    rdfs:comment 'Numeric interval value for scheduling this job plan on PM schedules. Interpreted in conjunction with frequency_unit (e.g., interval=3 with unit=MONTH means every 3 months). Null for condition-based or on-demand plans.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyType rdf:type rdf:Property ;
    rdfs:label 'Frequency Type' ;
    rdfs:comment 'Defines the trigger basis for scheduling this job plan on PM schedules. TIME_BASED = calendar interval; METER_BASED = usage/runtime meter (hours, cycles, km); CONDITION_BASED = triggered by condition monitoring threshold; EVENT_BASED = triggered by a specific event; ON_DEMAND = unscheduled/corrective.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialsInvolved rdf:type rdf:Property ;
    rdfs:label 'Hazardous Materials Involved' ;
    rdfs:comment 'Indicates whether the execution of this job plan involves handling, exposure to, or disposal of hazardous materials (chemicals, lubricants, refrigerants, etc.). Triggers environmental compliance controls per EPA and ISO 14001 requirements.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionChecklistRef rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Ref' ;
    rdfs:comment 'Reference identifier for the associated inspection checklist or measurement point document linked to this job plan. Used when the job plan includes condition monitoring readings, SPC measurement points, or quality inspection steps.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Job Plan Description' ;
    rdfs:comment 'Detailed narrative description of the maintenance procedure, scope of work, and objectives covered by this job plan. Provides context for planners and technicians beyond the short title.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Job Plan Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the job plan as assigned in Maximo or SAP PM Task List. Used by maintenance planners and technicians to reference the standard procedure (e.g., JP-MECH-0042, TASKLIST-PM-001).' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this job plan was last formally reviewed for accuracy, safety compliance, and alignment with current OEM recommendations. Supports periodic review tracking per ISO 9001 and ISO 45001 document control.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotoRequired rdf:type rdf:Property ;
    rdfs:label 'Loto Required' ;
    rdfs:comment 'Indicates whether Lockout/Tagout (LOTO) energy isolation procedures are mandatory before executing this job plan. Drives safety compliance workflows and permit-to-work issuance in the CMMS.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this job plan record was last modified in the source system. Supports change tracking, audit trails, and incremental data loading in the lakehouse silver layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oemProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Oem Procedure Reference' ;
    rdfs:comment 'Reference number or document identifier from the Original Equipment Manufacturer (OEM) maintenance manual or service bulletin that this job plan is based on or aligned with. Ensures traceability to manufacturer-recommended procedures.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Required' ;
    rdfs:comment 'Indicates whether a formal Permit to Work (PTW) must be issued and approved before this job plan can be executed. Applies to high-risk activities such as hot work, confined space entry, and electrical work on live systems.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the job plan indicating whether it is available for use on work orders and PM schedules. DRAFT = under development; ACTIVE = approved and in use; INACTIVE = temporarily suspended; PENDING_REVIEW = awaiting approval; OBSOLETE = superseded and retired.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the maintenance activity type this job plan covers. Drives scheduling logic, resource allocation, and KPI reporting. [ENUM-REF-CANDIDATE: PREVENTIVE|CORRECTIVE|PREDICTIVE|INSPECTION|OVERHAUL|LUBRICATION|CALIBRATION|EMERGENCY|SHUTDOWN — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerGroup rdf:type rdf:Property ;
    rdfs:label 'Planner Group' ;
    rdfs:comment 'Maintenance planner group or planning team responsible for maintaining and executing this job plan (e.g., MECH-PLANNER-01, ELEC-PLANNER-NORTH). Aligns with SAP PM Planner Group and Maximo planning organization structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Comma-separated list or narrative description of required Personal Protective Equipment (PPE) for executing this job plan (e.g., safety glasses, hard hat, arc flash suit, chemical gloves, hearing protection). Mandatory for ISO 45001 and OSHA compliance.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCraft rdf:type rdf:Property ;
    rdfs:label 'Primary Craft' ;
    rdfs:comment 'The primary labor craft or trade skill required to execute this job plan (e.g., Millwright, Electrician, Instrumentation Technician, Mechanic). Sourced from Maximo Craft master and used for work order labor planning.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Default priority level assigned to work orders generated from this job plan. Drives scheduling urgency and resource allocation in the CMMS. CRITICAL = safety/production-critical; HIGH = significant impact; MEDIUM = moderate impact; LOW = minor impact; ROUTINE = standard scheduled.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Ref' ;
    rdfs:comment 'Reference to applicable regulatory standards, codes, or compliance requirements that this job plan satisfies (e.g., ISO 9001, ISO 45001, OSHA 1910.147, IEC 62443, UL certification requirement). Supports compliance audit traceability.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTechnicianCount rdf:type rdf:Property ;
    rdfs:label 'Required Technician Count' ;
    rdfs:comment 'Minimum number of technicians required to safely and effectively execute this job plan. Used for crew scheduling and compliance with safety regulations (e.g., confined space entry requiring a standby person per OSHA 29 CFR 1910.146).' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredTools rdf:type rdf:Property ;
    rdfs:label 'Required Tools' ;
    rdfs:comment 'List of specialized tools, equipment, and instruments required to execute this job plan (e.g., torque wrench, vibration analyzer, multimeter, alignment laser, hydraulic jack). Used for tool reservation and kitting in the CMMS.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPrecautions rdf:type rdf:Property ;
    rdfs:label 'Safety Precautions' ;
    rdfs:comment 'Narrative description of mandatory safety precautions, lockout/tagout (LOTO) requirements, personal protective equipment (PPE), and hazard controls that must be observed before and during execution of this job plan. Compliance with OSHA and ISO 45001 requirements.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'Natural key or identifier of this job plan record in the originating source system (e.g., Maximo Job Plan Number, SAP PM Task List Number). Enables traceability and reconciliation between the lakehouse and operational systems.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsList rdf:type rdf:Property ;
    rdfs:label 'Spare Parts List' ;
    rdfs:comment 'Narrative or structured list of spare parts and materials required for this job plan, including part numbers and quantities (e.g., \'Bearing SKF 6205-2RS x2, O-Ring Kit x1, Filter Element x1\'). Used for pre-kitting and MRP-driven spare parts reservation.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStepCount rdf:type rdf:Property ;
    rdfs:label 'Task Step Count' ;
    rdfs:comment 'Total number of discrete task steps defined within this job plan. Provides a quick indicator of procedure complexity and is used for work order progress tracking in Maximo and Siemens Opcenter MES.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Human-readable descriptive title of the job plan summarizing the maintenance activity (e.g., \'Annual Preventive Maintenance - CNC Spindle Assembly\', \'Hydraulic System Inspection\'). Used in work order templates and PM schedules.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCategory rdf:type rdf:Property ;
    rdfs:label 'Work Category' ;
    rdfs:comment 'Trade or discipline category of the maintenance work defined in this job plan. Used to route work orders to the correct craft group and for workforce planning. [ENUM-REF-CANDIDATE: MECHANICAL|ELECTRICAL|INSTRUMENTATION|CIVIL|HVAC|HYDRAULIC|PNEUMATIC|LUBRICATION|AUTOMATION|WELDING — promote to reference product]' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenter rdf:type rdf:Property ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'Maintenance work center or department responsible for executing this job plan (e.g., MAINT-MECH-01, MAINT-ELEC-02). Maps to SAP PM Work Center and Maximo Labor Group for capacity planning and cost center assignment.' ;
    rdfs:domain ind:JobPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Default work order type that should be generated when this job plan is applied. PM = Preventive Maintenance; CM = Corrective Maintenance; EM = Emergency Maintenance; INSPECTION = Inspection only; OVERHAUL = Major overhaul; PROJECT = Capital project work.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureRecordId rdf:type rdf:Property ;
    rdfs:label 'Failure Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each failure event record in the system. Primary key for the failure_record data product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureRecord .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Foreign key linking to order.order_rma. Business justification: Warranty claim initiation: field equipment failures documented in failure_record drive warranty RMA creation. In industrial manufacturing, the failure record is the source document for warranty claims' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:assetOperatingHoursAtFailure rdf:type rdf:Property ;
    rdfs:label 'Asset Operating Hours At Failure' ;
    rdfs:comment 'Total cumulative operating hours recorded on the asset at the time of the failure event. Used as a key input for reliability analysis, MTBF trending, and predictive maintenance model training.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Reference Number' ;
    rdfs:comment 'The reference number of the formal CAPA record initiated in response to this failure event. Populated when capa_required_flag is True. Enables traceability between the failure event and the quality management corrective action process.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Indicates whether a formal Corrective and Preventive Action (CAPA) process must be initiated as a result of this failure event. True if CAPA is required; False otherwise. Driven by RPN threshold, safety impact, or quality management system requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Detection Method Code' ;
    rdfs:comment 'Standardized code indicating how the failure was detected (e.g., operator observation, automated alarm, predictive sensor alert, scheduled inspection, SCADA alarm, condition monitoring). Sourced from FMEA detection method taxonomy and Aveva SCADA alarm data. [ENUM-REF-CANDIDATE: operator_observation|scada_alarm|condition_monitoring|scheduled_inspection|predictive_alert|customer_report|automated_sensor — promote to reference product]' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionRating rdf:type rdf:Property ;
    rdfs:label 'Detection Rating' ;
    rdfs:comment 'Numeric detection rating (1-10 scale) from the FMEA/PFMEA analysis indicating the ability of current controls to detect the failure cause or mode before it reaches the customer or causes production impact. A rating of 10 represents the lowest detectability. Used in RPN calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration of equipment downtime in minutes resulting from this failure event, calculated as the difference between downtime_end_datetime and downtime_start_datetime. Stored as a business-captured field from the source system (Maximo) rather than derived at query time. Feeds OEE, MTTR, and production impact analysis.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Downtime End Datetime' ;
    rdfs:comment 'The precise date and time at which the equipment was restored to operational status following the failure event. Used in conjunction with downtime_start_datetime to calculate total downtime duration and MTTR. Null if equipment has not yet been restored.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Datetime' ;
    rdfs:comment 'The precise date and time at which the equipment became unavailable for production due to this failure event. Used to calculate total downtime duration and OEE impact. Feeds MTTR analysis and production loss quantification.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Flag' ;
    rdfs:comment 'Indicates whether this failure event resulted in an environmental incident such as a spill, emission exceedance, or hazardous material release. True if an environmental event occurred; False otherwise. Triggers EPA and ISO 14001 reporting obligations.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureCauseCode rdf:type rdf:Property ;
    rdfs:label 'Failure Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the failure event (e.g., inadequate lubrication, overload, material defect, operator error, design deficiency). Sourced from the Maximo Failure Cause catalog and used in CAPA and FMEA root cause analysis.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Cause Description' ;
    rdfs:comment 'Detailed description of the identified root cause of the failure, providing narrative context for the failure_cause_code. Supports CAPA documentation and FMEA validation.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureClassCode rdf:type rdf:Property ;
    rdfs:label 'Failure Class Code' ;
    rdfs:comment 'Standardized classification code categorizing the type of failure at the highest level of the failure taxonomy (e.g., mechanical, electrical, hydraulic, pneumatic, software, structural). Sourced from the Maximo Failure Class hierarchy and aligned with ISO 14224 failure classification. [ENUM-REF-CANDIDATE: mechanical|electrical|hydraulic|pneumatic|software|structural|thermal|instrumentation|process — promote to reference product]' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureClassDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Class Description' ;
    rdfs:comment 'Human-readable description of the failure class, providing context for the failure_class_code. Used in maintenance reports, FMEA documentation, and reliability dashboards.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDatetime rdf:type rdf:Property ;
    rdfs:label 'Failure Datetime' ;
    rdfs:comment 'The precise date and time at which the equipment failure or fault was detected or reported. This is the principal real-world event timestamp for the failure record, distinct from the record creation audit timestamp. Used as the anchor for MTBF calculations and downtime duration derivation.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureImpactType rdf:type rdf:Property ;
    rdfs:label 'Failure Impact Type' ;
    rdfs:comment 'Classification of the operational impact of the failure event on production and safety. \'production_stoppage\' indicates complete halt of production; \'partial_degradation\' indicates reduced throughput or capacity; \'quality_impact\' indicates output quality was affected; \'safety_incident\' indicates a safety hazard was created; \'no_production_impact\' indicates the failure was detected without affecting output.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeCode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Code' ;
    rdfs:comment 'Standardized code identifying the specific manner in which the equipment failed (e.g., wear, fracture, corrosion, overheating, short circuit, vibration). Sourced from the Maximo Failure Mode catalog and aligned with FMEA/PFMEA failure mode taxonomy. Feeds FMEA validation and maintenance strategy selection.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Description' ;
    rdfs:comment 'Detailed description of the failure mode, explaining how the equipment deviated from its intended function. Embedded from the FMEA/PFMEA failure mode classification taxonomy. Used in reliability analysis and maintenance strategy documentation.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureNarrative rdf:type rdf:Property ;
    rdfs:label 'Failure Narrative' ;
    rdfs:comment 'Free-text narrative description of the failure event as recorded by the reporting technician or operator. Captures contextual details not covered by structured codes, including observed symptoms, environmental conditions, and sequence of events. Used in root cause analysis and knowledge base enrichment.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureNumber rdf:type rdf:Property ;
    rdfs:label 'Failure Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this failure event record. Used in maintenance reports, CAPA documentation, and cross-system references. Follows the format FR-XXXXXXXXXX.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtbfContributionHours rdf:type rdf:Property ;
    rdfs:label 'Mtbf Contribution Hours' ;
    rdfs:comment 'The operating hours accumulated on the asset since the previous failure event of the same failure class, contributing to the MTBF calculation for this asset and failure class combination. Stored as a raw business input value from Maximo rather than an aggregated metric. Feeds reliability analysis and TPM strategy.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncrReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Reference Number' ;
    rdfs:comment 'The reference number of the Non-Conformance Report (NCR) raised in the quality management system as a result of this failure event. Links the failure record to the formal quality non-conformance documentation in SAP QM.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceRating rdf:type rdf:Property ;
    rdfs:label 'Occurrence Rating' ;
    rdfs:comment 'Numeric occurrence rating (1-10 scale) from the FMEA/PFMEA analysis indicating the likelihood or frequency of the failure cause occurring. A rating of 10 represents the highest probability of occurrence. Used in RPN calculation and preventive maintenance scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:potentialFailureEffect rdf:type rdf:Property ;
    rdfs:label 'Potential Failure Effect' ;
    rdfs:comment 'Description of the potential effect or consequence of the failure mode on the process, product quality, equipment, or safety. Embedded from the FMEA failure mode classification taxonomy. Used in FMEA validation and maintenance strategy documentation.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionUnitsLost rdf:type rdf:Property ;
    rdfs:label 'Production Units Lost' ;
    rdfs:comment 'Estimated number of production units (parts, assemblies, or output units) lost due to this failure event and associated downtime. Quantifies the direct production impact for OEE performance loss analysis and financial impact assessment.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the failure record workflow. \'open\' indicates the failure has been reported but not yet actioned; \'in_progress\' indicates active remediation; \'closed\' indicates the failure has been resolved and verified; \'cancelled\' indicates the record was voided; \'pending_review\' indicates awaiting quality or engineering sign-off.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remedyCode rdf:type rdf:Property ;
    rdfs:label 'Remedy Code' ;
    rdfs:comment 'Standardized code identifying the corrective action or remedy applied to resolve the failure (e.g., replacement, repair, adjustment, cleaning, lubrication, recalibration). Sourced from the Maximo Remedy catalog and SAP PM catalog codes.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remedyDescription rdf:type rdf:Property ;
    rdfs:label 'Remedy Description' ;
    rdfs:comment 'Detailed description of the corrective action taken to resolve the failure event. Provides narrative context for the remedy_code and supports maintenance knowledge base and CAPA documentation.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairCost rdf:type rdf:Property ;
    rdfs:label 'Repair Cost' ;
    rdfs:comment 'Total cost incurred to remediate this failure event, including labor, spare parts, and external contractor costs. Expressed in the local operating currency. Used for maintenance cost analysis, CapEx vs OpEx classification, and total cost of ownership (TCO) reporting.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskPriorityNumber rdf:type rdf:Property ;
    rdfs:label 'Risk Priority Number' ;
    rdfs:comment 'Risk Priority Number derived from FMEA/PFMEA analysis, calculated as the product of severity_rating × occurrence_rating × detection_rating (range 1-1000). Stored as a business-captured value from the FMEA source record rather than computed at query time. Used to prioritize corrective actions and maintenance strategy selection.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Indicates whether this failure event resulted in or contributed to a safety incident, near-miss, or occupational hazard. True if a safety event occurred; False otherwise. Triggers mandatory OSHA/ISO 45001 reporting workflows and CAPA initiation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Numeric severity rating (1-10 scale) from the FMEA/PFMEA analysis indicating the seriousness of the failure effect on the product, process, or safety. A rating of 10 represents the most severe impact (safety hazard or regulatory non-compliance). Used in RPN calculation and maintenance strategy prioritization.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sparePartConsumedFlag rdf:type rdf:Property ;
    rdfs:label 'Spare Part Consumed Flag' ;
    rdfs:comment 'Indicates whether one or more spare parts were consumed during the remediation of this failure event. True if spare parts were used; False otherwise. Feeds spare parts inventory consumption analysis and reorder planning.' ;
    rdfs:domain ind:FailureRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetDowntimeEventId rdf:type rdf:Property ;
    rdfs:label 'Asset Downtime Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each discrete downtime event record. Primary key for the downtime_event data product in the asset domain.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetDowntimeEvent .

ind:affectedSkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Affected Sku Master Id' ;
    rdfs:comment 'Foreign key linking to product.sku_master. Business justification: OEE reporting by product SKU: downtime events must be linked to the specific product SKU being produced to calculate availability losses per product, a mandatory KPI in industrial manufacturing. affec' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:runId rdf:type rdf:Property ;
    rdfs:label 'Run Id' ;
    rdfs:comment 'Foreign key linking to production.run. Business justification: Asset downtime events interrupt specific production runs; linking enables run-level OEE availability impact calculation and production loss attribution per run — essential for manufacturing performanc' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:shiftId rdf:type rdf:Property ;
    rdfs:label 'Shift Id' ;
    rdfs:comment 'Reference to the production shift during which the downtime event occurred. Enables shift-level downtime analysis and operator accountability reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:capaReference rdf:type rdf:Property ;
    rdfs:label 'Capa Reference' ;
    rdfs:comment 'Reference number of the Corrective and Preventive Action (CAPA) record initiated as a result of this downtime event. Links the downtime event to the quality management system for systematic root cause elimination. Sourced from SAP QM or the plant\'s CAPA system.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method by which the downtime event was detected and captured. Distinguishes automated detection (SCADA alarm, MES alert, IIoT sensor trigger, predictive maintenance alert) from manual detection (operator report, visual inspection, manual entry). Supports data quality assessment and IIoT maturity tracking. [ENUM-REF-CANDIDATE: scada_alarm|mes_alert|operator_report|sensor_trigger|visual_inspection|predictive_alert|manual_entry — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'High-level classification of the downtime event type. Drives OEE availability loss categorization and Pareto analysis. [ENUM-REF-CANDIDATE: breakdown|planned_maintenance|changeover|tooling|material_shortage|quality_hold|no_operator|utility_failure|scheduled_break|trial_run — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeType rdf:type rdf:Property ;
    rdfs:label 'Downtime Type' ;
    rdfs:comment 'Indicates whether the downtime event was unplanned (unexpected equipment failure, breakdown) or planned (scheduled maintenance, changeover, tooling change). Critical discriminator for OEE availability calculation — only unplanned downtime reduces OEE availability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total elapsed duration of the downtime event in minutes, calculated as the difference between end_timestamp and start_timestamp. Stored as a business field for direct use in OEE availability calculations, Pareto analysis, and production loss costing. Null if event is still open.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The precise date and time when the equipment was restored to operational status and production resumed. Null if the event is still open/in-progress. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Flag' ;
    rdfs:comment 'Indicates whether this downtime event resulted in an environmental impact (e.g., spill, emission exceedance, energy waste) requiring EPA or ISO 14001 reporting. True = environmental impact occurred.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedLossCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Loss Cost' ;
    rdfs:comment 'Estimated financial cost of production loss attributable to this downtime event, expressed in the plant\'s local currency. Calculated from estimated_production_loss_units multiplied by the standard cost per unit. Used for downtime Pareto cost analysis and CapEx justification.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedProductionLossUnits rdf:type rdf:Property ;
    rdfs:label 'Estimated Production Loss Units' ;
    rdfs:comment 'Estimated number of production units lost due to this downtime event, calculated based on the equipment\'s standard throughput rate and the downtime duration. Used for production loss costing and OEE throughput impact analysis.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the downtime event (e.g., DT-2024-000123). Used for cross-system reference, operator communication, and audit trail. Sourced from Maximo or Siemens Opcenter MES downtime capture.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the downtime event record. \'open\' indicates the stoppage is active; \'in_progress\' indicates maintenance is underway; \'resolved\' indicates equipment is restored; \'closed\' indicates the record is fully documented and approved; \'cancelled\' indicates a false or erroneous entry.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureClass rdf:type rdf:Property ;
    rdfs:label 'Failure Class' ;
    rdfs:comment 'High-level classification of the failure mode grouping (mechanical, electrical, hydraulic, pneumatic, software, instrumentation, structural, operator_error, external). Aligns with Maximo failure class hierarchy and supports FMEA/PFMEA analysis and spare parts categorization. [ENUM-REF-CANDIDATE: mechanical|electrical|hydraulic|pneumatic|software|instrumentation|structural|operator_error|external — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRepeatFailure rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Failure' ;
    rdfs:comment 'Indicates whether this downtime event is a recurrence of a previously recorded failure on the same asset within a defined lookback period (typically 30 or 90 days). True = repeat failure. Used to trigger CAPA escalation and identify chronic equipment issues.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyIncident rdf:type rdf:Property ;
    rdfs:label 'Is Safety Incident' ;
    rdfs:comment 'Indicates whether this downtime event was associated with or caused a safety incident (True) or not (False). Triggers mandatory safety reporting workflows and OSHA recordkeeping requirements when True.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeeAvailabilityImpactPct rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Impact Pct' ;
    rdfs:comment 'The percentage reduction in OEE availability attributable to this specific downtime event, expressed as a decimal percentage (e.g., 4.17 = 4.17%). Calculated as (duration_minutes / planned_production_time_minutes) * 100 for the affected shift/period. Feeds OEE calculation pipelines.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plcFaultCode rdf:type rdf:Property ;
    rdfs:label 'Plc Fault Code' ;
    rdfs:comment 'The fault or error code reported by the Programmable Logic Controller (PLC) or DCS at the time of the downtime event. Provides low-level diagnostic information for maintenance engineers and supports automated fault classification.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemCode rdf:type rdf:Property ;
    rdfs:label 'Problem Code' ;
    rdfs:comment 'Maximo CMMS problem code describing the observed symptom or problem that triggered the downtime event (e.g., vibration, overheating, noise, no output). Part of the Maximo failure reporting triad: problem_code → failure_code → root_cause_code.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Repair Time Minutes' ;
    rdfs:comment 'Elapsed time in minutes from when maintenance work began to when the equipment was restored to operational status. Core component of Mean Time To Repair (MTTR) calculation. Excludes waiting/response time.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Time Minutes' ;
    rdfs:comment 'Elapsed time in minutes from the downtime event start_timestamp to when a maintenance technician acknowledged or began working on the issue. Component of Mean Time To Repair (MTTR) analysis and maintenance SLA performance tracking.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the downtime event (e.g., mechanical failure, electrical fault, operator error, material defect, software fault). Sourced from the plant\'s root cause taxonomy maintained in Maximo or the CMMS. Used for CAPA initiation and FMEA updates. [ENUM-REF-CANDIDATE: promote to reference product with full root cause taxonomy]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Free-text narrative description of the identified root cause of the downtime event, as entered by the maintenance technician or engineer. Complements the structured root_cause_code with contextual detail for CAPA and FMEA analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentReference rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Reference' ;
    rdfs:comment 'Reference number of the associated safety incident report when is_safety_incident is True. Links the downtime event to the EHS (Environmental Health and Safety) management system for OSHA compliance reporting.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEventReference rdf:type rdf:Property ;
    rdfs:label 'Source Event Reference' ;
    rdfs:comment 'The native identifier of this downtime event in the originating source system (e.g., Maximo work order number, Opcenter MES downtime record ID, SCADA alarm ID). Enables traceability back to the system of record for reconciliation and audit.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsUsed rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Used' ;
    rdfs:comment 'Comma-separated list or free-text description of spare parts consumed during the repair of this downtime event (e.g., part numbers, descriptions). Used for spare parts consumption tracking, inventory replenishment, and maintenance cost analysis. Detailed parts data is managed in Maximo inventory.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The precise date and time when the equipment stoppage began. Principal real-world event timestamp for the downtime event. Captured from SCADA/MES automated detection or manual operator entry. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicianNotes rdf:type rdf:Property ;
    rdfs:label 'Technician Notes' ;
    rdfs:comment 'Free-text field for maintenance technician observations, diagnostic findings, and repair actions taken during the downtime event. Captured in Maximo work order long description. Supports knowledge management and future FMEA updates.' ;
    rdfs:domain ind:AssetDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionReadingId rdf:type rdf:Property ;
    rdfs:label 'Condition Reading Id' ;
    rdfs:comment 'Unique surrogate identifier for each condition monitoring or meter reading record. Primary key for the condition_reading data product in the asset domain.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertSeverity rdf:type rdf:Property ;
    rdfs:label 'Alert Severity' ;
    rdfs:comment 'Severity classification assigned to this reading when a threshold breach is detected. \'none\' indicates no breach; \'informational\' is advisory only; \'warning\' requires monitoring; \'critical\' requires prompt maintenance action; \'emergency\' requires immediate shutdown or intervention. Drives maintenance prioritization and escalation routing.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ambientTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature C' ;
    rdfs:comment 'The ambient environmental temperature in degrees Celsius at the measurement location at the time of reading. Used as a contextual covariate for temperature-sensitive condition measurements such as bearing temperature and oil viscosity.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetOperatingState rdf:type rdf:Property ;
    rdfs:label 'Asset Operating State' ;
    rdfs:comment 'The operational state of the asset at the time the reading was captured. Condition readings taken during different operating states (running vs idle vs startup) have different baseline norms and must be segregated for accurate trend analysis and anomaly detection.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'The externally visible physical tag or barcode number affixed to the equipment from which this reading was taken. Provides a human-readable cross-reference to the physical asset in the field, independent of the system surrogate key.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Identifier of the data ingestion batch or pipeline run that loaded this reading into the lakehouse silver layer. Supports data lineage, reprocessing, and audit trail for the condition monitoring data pipeline.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFactor rdf:type rdf:Property ;
    rdfs:label 'Calibration Factor' ;
    rdfs:comment 'Multiplicative or additive calibration coefficient applied to the raw sensor value to derive the engineering-unit reading value. Supports traceability of measurement accuracy and recalculation when sensor calibration is updated.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deltaValue rdf:type rdf:Property ;
    rdfs:label 'Delta Value' ;
    rdfs:comment 'The incremental change in the reading value since the previous reading for the same sensor or meter. For cumulative meters, this represents consumption or usage since the last reading (e.g., runtime hours accumulated since last meter read). Used for utilization rate calculation and meter-based PM trigger logic.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyBand rdf:type rdf:Property ;
    rdfs:label 'Frequency Band' ;
    rdfs:comment 'For vibration and acoustic emission readings, the frequency band or spectral range (e.g., \'10-1000 Hz\', \'1-10 kHz\') within which the measurement was taken. Enables frequency-domain analysis for bearing fault detection and rotating machinery diagnostics.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isManualOverride rdf:type rdf:Property ;
    rdfs:label 'Is Manual Override' ;
    rdfs:comment 'Boolean flag indicating that the reading value was manually entered or corrected by an operator, overriding an automated sensor value. When true, the original automated value is preserved in raw_value for audit purposes.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadPercentage rdf:type rdf:Property ;
    rdfs:label 'Load Percentage' ;
    rdfs:comment 'The percentage of rated capacity or load at which the asset was operating when this reading was taken (0.00–100.00). Load normalization is essential for accurate condition trending — the same vibration amplitude at 50% load vs 100% load has different diagnostic significance.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDirection rdf:type rdf:Property ;
    rdfs:label 'Measurement Direction' ;
    rdfs:comment 'The physical axis or direction in which the measurement was taken for directional sensors such as vibration accelerometers (axial, radial, tangential) or displacement probes. Null for non-directional measurements such as temperature or pressure.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Specific physical or operational quantity being measured. Examples include vibration, temperature, pressure, oil_viscosity, acoustic_emission, ultrasound, runtime_hours, cycle_count, energy_consumption_kwh, distance_km, production_units. [ENUM-REF-CANDIDATE: vibration|temperature|pressure|oil_viscosity|acoustic_emission|ultrasound|runtime_hours|cycle_count|energy_consumption|distance|production_units|current|voltage|flow_rate — promote to reference product]' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text or coded reason provided by the operator when manually overriding or correcting an automated reading. Required when is_manual_override is true. Supports audit trail and data quality governance.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Pm Trigger Flag' ;
    rdfs:comment 'Boolean flag indicating whether this reading caused a meter-based or condition-based preventive maintenance (PM) schedule to be triggered in the CMMS. True when the cumulative meter value crossed a PM due-point or a condition indicator breached a CBM trigger threshold.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rawValue rdf:type rdf:Property ;
    rdfs:label 'Raw Value' ;
    rdfs:comment 'The unprocessed, uncalibrated value as received directly from the sensor or IIoT gateway before any engineering unit conversion, calibration offset, or data quality correction is applied. Preserved for audit, recalibration, and data lineage purposes.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingSource rdf:type rdf:Property ;
    rdfs:label 'Reading Source' ;
    rdfs:comment 'Origin system or method by which the reading was captured. Distinguishes automated IIoT gateway feeds, Aveva SCADA real-time data, Siemens Opcenter MES inputs, manual operator entries, CMMS (Maximo) imports, and energy management system (EMS) feeds. Critical for data lineage and trust scoring.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingStatus rdf:type rdf:Property ;
    rdfs:label 'Reading Status' ;
    rdfs:comment 'Quality or lifecycle status of the reading record. \'valid\' indicates a confirmed good reading; \'suspect\' flags a reading that may be erroneous pending review; \'invalid\' marks a rejected reading; \'estimated\' indicates an interpolated or manually estimated value; \'overridden\' indicates the original value was corrected by an operator.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the condition measurement or meter reading was recorded. This is the principal business event timestamp used for time-series analysis, predictive maintenance (PdM) trigger logic, and condition-based maintenance (CBM) scheduling.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readingType rdf:type rdf:Property ;
    rdfs:label 'Reading Type' ;
    rdfs:comment 'Discriminator indicating whether this record represents a condition indicator (instantaneous measurement such as vibration, temperature, pressure) or a cumulative meter/counter reading (runtime hours, cycle counts, energy consumption, distance traveled). Drives downstream PM trigger logic.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingValue rdf:type rdf:Property ;
    rdfs:label 'Reading Value' ;
    rdfs:comment 'The principal observed numeric measurement or meter count captured at the reading timestamp. For condition indicators this is the instantaneous measured value (e.g., 2.45 mm/s vibration velocity). For cumulative meters this is the absolute odometer-style counter value at the time of reading.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingIntervalSec rdf:type rdf:Property ;
    rdfs:label 'Sampling Interval Sec' ;
    rdfs:comment 'The configured data acquisition interval in seconds at which this sensor or meter is polled or sampled. Used to validate reading frequency, detect missed readings, and calculate expected vs actual data completeness.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensorCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Code' ;
    rdfs:comment 'Reference to the specific sensor, transducer, or meter instrument that produced this reading. Identifies the IIoT device, SCADA tag, or manual meter point.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native record identifier from the originating operational system (e.g., Maximo meter reading ID, Aveva SCADA historian tag timestamp key, Siemens Opcenter MES event ID). Enables bidirectional traceability between the lakehouse silver layer and the system of record.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdBreached rdf:type rdf:Property ;
    rdfs:label 'Threshold Breached' ;
    rdfs:comment 'Boolean flag indicating whether the reading value exceeded either the low or high threshold limit at the time of capture. True triggers downstream alert generation and may initiate predictive maintenance (PdM) or corrective maintenance workflows.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdHigh rdf:type rdf:Property ;
    rdfs:label 'Threshold High' ;
    rdfs:comment 'Upper boundary of the acceptable operating range for this measurement type on this asset. A reading above this value triggers a high-threshold breach flag and may initiate a CBM alert or PdM workflow.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdLow rdf:type rdf:Property ;
    rdfs:label 'Threshold Low' ;
    rdfs:comment 'Lower boundary of the acceptable operating range for this measurement type on this asset. A reading below this value triggers a low-threshold breach flag and may initiate a condition-based maintenance (CBM) alert or predictive maintenance (PdM) workflow.' ;
    rdfs:domain ind:ConditionReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Engineering unit associated with the reading value (e.g., mm/s, °C, bar, cSt, dB, kWh, hours, cycles, units, km). Follows SI and industry-standard unit conventions to ensure dimensional consistency across analytics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorListId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Id' ;
    rdfs:comment 'Foreign key linking to supplier.approved_vendor_list. Business justification: Critical MRO spare parts are governed by the AVL — only approved vendors may supply them. Maintenance planners reference the AVL entry when raising purchase requisitions for spare parts, ensuring comp' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedVendorList .

ind:commodityCategoryId rdf:type rdf:Property ;
    rdfs:label 'Commodity Category Id' ;
    rdfs:comment 'Foreign key linking to finance.commodity_category. Business justification: Spare parts are classified into commodity categories for strategic sourcing, MRO spend analysis, and contract coverage reporting. spare_part has mro_category and material_group_code as denormalized si' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityCategory .

ind:procurementContractId rdf:type rdf:Property ;
    rdfs:label 'Procurement Contract Id' ;
    rdfs:comment 'Foreign key linking to finance.procurement_contract. Business justification: MRO spare parts are sourced under specific procurement contracts governing pricing, lead times, and quality. Linking spare_part to procurement_contract enables contract compliance tracking, spend-unde' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementContract .

ind:productCertificationId rdf:type rdf:Property ;
    rdfs:label 'Product Certification Id' ;
    rdfs:comment 'Foreign key linking to product.product_certification. Business justification: Regulatory compliance for spare parts: maintenance teams must verify spare parts meet product certifications (CE, ATEX, UL) before installation in certified industrial equipment. This is a mandatory c' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductCertification .

ind:productRevisionId rdf:type rdf:Property ;
    rdfs:label 'Product Revision Id' ;
    rdfs:comment 'Foreign key linking to product.product_revision. Business justification: Spare part revision control: engineering change management requires knowing which product revision a spare part corresponds to, ensuring maintenance uses the correct revision and identifying supersede' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRevision .

ind:purchaseInfoRecordId rdf:type rdf:Property ;
    rdfs:label 'Purchase Info Record Id' ;
    rdfs:comment 'Foreign key linking to supplier.purchase_info_record. Business justification: Purchase info records hold negotiated price, lead time, and vendor material number for a spare part from a specific supplier. MRP controllers and maintenance planners use this to auto-populate PRs and' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseInfoRecord .

ind:safetyStockPolicyId rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Policy Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_safety_stock_policy. Business justification: Critical spare parts management: industrial manufacturers maintain centralized safety stock policies for MRO spares tied to equipment criticality. Linking spare_part to supply_safety_stock_policy enab' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyStockPolicy .

ind:sourcingRuleId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Rule Id' ;
    rdfs:comment 'Foreign key linking to supply.sourcing_rule. Business justification: MRO procurement process: maintenance planners must know which sourcing rule governs spare part replenishment (make-or-buy, preferred supplier, MOQ, lead time). Industrial manufacturing domain experts ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingRule .

ind:abcClass rdf:type rdf:Property ;
    rdfs:label 'Abc Class' ;
    rdfs:comment 'ABC classification for inventory prioritization based on annual consumption value. \'A\' items represent high-value, high-priority parts requiring tight inventory control; \'B\' items are moderate value; \'C\' items are low-value, high-volume parts with relaxed control. Aligns with SAP MM ABC Indicator and supports MRP/MRP II planning.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageAnnualConsumption rdf:type rdf:Property ;
    rdfs:label 'Average Annual Consumption' ;
    rdfs:comment 'Average quantity of this spare part consumed per year across all work orders and maintenance activities. Used for ABC classification, reorder point calculation, and inventory optimization in Microsoft Dynamics 365 Supply Chain Management.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexAssetFlag rdf:type rdf:Property ;
    rdfs:label 'Capex Asset Flag' ;
    rdfs:comment 'Indicates whether this spare part is classified as a capital expenditure (CapEx) item that must be capitalized on the asset register rather than expensed as operational expenditure (OpEx). Drives financial treatment in SAP FI/CO and supports CapEx asset register management.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalityClass rdf:type rdf:Property ;
    rdfs:label 'Criticality Class' ;
    rdfs:comment 'Maintenance criticality classification of the spare part. \'insurance_spare\' denotes a high-value, long-lead-time part held solely to protect against catastrophic equipment failure; \'critical\' denotes parts whose absence would cause significant production downtime; \'non_critical\' denotes parts with readily available substitutes or low downtime impact. Drives stocking policy and capital allocation decisions.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingNumber rdf:type rdf:Property ;
    rdfs:label 'Drawing Number' ;
    rdfs:comment 'Reference to the engineering drawing or technical document number in Siemens Teamcenter PLM (PDM) that defines the specifications, dimensions, and tolerances for this spare part. Supports design-to-maintenance traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'Broad category of production equipment or facility asset for which this spare part is applicable. Supports OEM compatibility list management and enables filtering of applicable parts during maintenance planning. [ENUM-REF-CANDIDATE: cnc_machine|plc|robotics|conveyor|hvac|electrical_panel|pump|motor|sensor|general — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentClassCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Class Code' ;
    rdfs:comment 'Equipment class or functional location class code identifying the category of production equipment (e.g., CNC machines, PLCs, robotics, conveyors) for which this spare part is applicable. Supports OEM compatibility list management and preventive maintenance (PM) task planning in Maximo.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether this spare part is classified as a hazardous material requiring special handling, storage, or disposal procedures under OSHA or EPA regulations. Drives safety data sheet (SDS) requirements and storeroom segregation rules.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClassCode rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class Code' ;
    rdfs:comment 'Regulatory hazardous material classification code (e.g., UN/DOT hazard class) for spare parts flagged as hazardous. Required for compliant storage, transport documentation, and EPA/OSHA reporting. Null when hazardous_material_flag is false.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeablePartNumbers rdf:type rdf:Property ;
    rdfs:label 'Interchangeable Part Numbers' ;
    rdfs:comment 'Comma-separated list of alternative part numbers that are functionally interchangeable with this spare part. Supports maintenance technician substitution decisions when the primary part is out of stock. Managed in Maximo Item Cross-Reference.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Last Issued Date' ;
    rdfs:comment 'Date on which this spare part was most recently issued from the storeroom to a maintenance work order. Used to identify slow-moving or dormant inventory for stock rationalization and obsolescence review.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchasePrice rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Price' ;
    rdfs:comment 'Most recent purchase price per unit of measure paid to a supplier for this spare part. Sourced from SAP MM purchasing info record (EINA/EINE) or Maximo PO history. Used for budget estimation and procurement benchmarking.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Received Date' ;
    rdfs:comment 'Date on which the most recent goods receipt was posted for this spare part in the storeroom. Used to track replenishment activity and assess supplier delivery performance.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) or component manufacturer who produces this spare part. Used for sourcing, warranty management, and OEM compatibility validation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'The Original Equipment Manufacturer (OEM) or component manufacturer\'s part number. Used for cross-referencing during procurement, warranty claims, and interchangeability validation. Corresponds to SAP Manufacturer Part Number (MFRPN) and Maximo Manufacturer Part Number field.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Maximum allowable on-hand inventory quantity for this spare part in the storeroom. Used to prevent overstocking and manage storeroom space. Corresponds to SAP MM Maximum Stock Level (MABST) and Maximo Maximum Quantity.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQty rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Qty' ;
    rdfs:comment 'Minimum quantity that must be ordered per purchase order line for this spare part, as stipulated by the supplier or procurement policy. Corresponds to SAP MM Minimum Order Quantity (MINBE) and Maximo Order Unit.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partDescription rdf:type rdf:Property ;
    rdfs:label 'Part Description' ;
    rdfs:comment 'Long-form technical description of the spare part including functional purpose, specifications, and application context. Supports maintenance technician identification and procurement sourcing.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partName rdf:type rdf:Property ;
    rdfs:label 'Part Name' ;
    rdfs:comment 'Short descriptive name of the spare part as used in maintenance work orders, purchase requisitions, and storeroom pick lists. Corresponds to SAP Material Short Text (MAKTX) and Maximo Item Description.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'The internal part number (material number) assigned to the spare part in SAP MM / Maximo Inventory. This is the primary business identifier used across procurement, maintenance work orders, and storeroom operations. Corresponds to SAP Material Number (MATNR) and Maximo Item Number.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partStatus rdf:type rdf:Property ;
    rdfs:label 'Part Status' ;
    rdfs:comment 'Current lifecycle status of the spare part master record. \'active\' indicates the part is in use and available for procurement and work orders; \'obsolete\' indicates the part is no longer supported; \'superseded\' indicates it has been replaced by another part number; \'pending_approval\' indicates the record is under review; \'blocked\' indicates procurement or usage is temporarily suspended.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partType rdf:type rdf:Property ;
    rdfs:label 'Part Type' ;
    rdfs:comment 'Technical classification of the spare part by engineering discipline. Drives routing to the correct maintenance trade, storeroom zone, and procurement category. [ENUM-REF-CANDIDATE: mechanical|electrical|electronic|hydraulic|pneumatic|consumable|structural|instrumentation — promote to reference product]' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Number' ;
    rdfs:comment 'SAP Vendor Account Number (LIFNR) or SAP Ariba supplier ID of the preferred supplier for this spare part. Used to default the vendor on purchase requisitions and supports supplier performance management.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Indicates whether the spare part is procured externally from a supplier (\'external\'), produced internally (\'internal\'), or both. Corresponds to SAP MM Procurement Type (BESKZ) and drives MRP planning logic.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether this spare part requires a quality inspection upon goods receipt before it can be issued to a work order. Corresponds to SAP QM Inspection Type 01 (Goods Receipt Inspection) and supports ISO 9001 incoming quality control requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'Number of calendar days from purchase order placement to receipt of the spare part at the storeroom. Used in reorder point calculation and MRP planning. Corresponds to SAP MM Planned Delivery Time (PLIFZ) and Maximo Lead Time.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days this spare part can be stored before it expires or degrades below acceptable quality standards. Applicable to consumables, lubricants, seals, gaskets, and chemical materials. Corresponds to SAP MM Total Shelf Life (MHDRZ). Zero or null indicates no shelf life restriction.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard cost per unit of measure for the spare part as maintained in SAP MM valuation (moving average or standard price). Used for inventory valuation, work order cost accounting, and CapEx/OpEx reporting. Expressed in the plant\'s local currency.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByPartNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Part Number' ;
    rdfs:comment 'Part number of the replacement spare part that supersedes this record in the interchangeability/supersession chain. Populated when part_status is \'superseded\'. Enables maintenance planners to identify the correct current part for work orders.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionEventId rdf:type rdf:Property ;
    rdfs:label 'Inspection Event Id' ;
    rdfs:comment 'Unique surrogate identifier for the inspection event record in the asset management domain. Primary key for this entity.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Product Specification Id' ;
    rdfs:comment 'Foreign key linking to product.product_specification. Business justification: Specification-based inspection: inspectors verify equipment condition against product specifications (IP rating, operating temperature, voltage rating). This is a core industrial inspection process — ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSpecification .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the inspection results were formally reviewed and approved by the authorized approver. Establishes the official close of the inspection event for audit and compliance purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assetOperationalStatusAtInspection rdf:type rdf:Property ;
    rdfs:label 'Asset Operational Status At Inspection' ;
    rdfs:comment 'The operational state of the asset at the time the inspection was conducted: running (in active production), shutdown (powered down for inspection), standby (idle but available), or under_maintenance (already in a maintenance window). Relevant for OEE downtime attribution and safety compliance.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'The date on which the compliance or safety certificate issued as a result of this inspection expires. Populated only when certificate_issued is True. Drives certificate renewal scheduling and regulatory compliance monitoring.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssued rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued' ;
    rdfs:comment 'Indicates whether a compliance certificate, safety certificate, or inspection certificate was issued as a result of this inspection event (True) or not (False). Relevant for UL, CE, and ISO certification inspections.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether one or more findings from this inspection require a formal Corrective and Preventive Action (CAPA) to be initiated. When True, triggers CAPA workflow creation in the quality management system per ISO 9001 Clause 10.2.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of findings classified as critical or safety-critical, requiring immediate corrective action before the asset may return to service. Supports OSHA compliance reporting and safety escalation workflows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeCaused rdf:type rdf:Property ;
    rdfs:label 'Downtime Caused' ;
    rdfs:comment 'Indicates whether this inspection event caused a production downtime event (True) or was conducted without interrupting production (False). Used for OEE downtime attribution and production loss reporting.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAuditReference rdf:type rdf:Property ;
    rdfs:label 'External Audit Reference' ;
    rdfs:comment 'Reference number or identifier assigned by an external regulatory body, certification authority, or third-party auditor for inspections conducted as part of an external audit program (e.g., OSHA inspection citation number, UL audit reference, ISO certification audit ID). Nullable for internal inspections.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'Total number of distinct findings, deficiencies, or non-conformances identified during the inspection event. A finding may span multiple checklist items; this field captures the consolidated count used for CAPA prioritization and NCR generation.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Free-text narrative summary of the key findings, deficiencies, and observations recorded during the inspection. Provides the qualitative context for the quantitative findings_count and supports CAPA root cause analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'The calendar date on which the inspection was physically performed. This is the principal real-world event date used for compliance reporting, regulatory submissions, and maintenance history analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from inspection start to completion. Derived from start and end timestamps at source but stored as a business fact for resource utilization reporting, labor cost estimation, and inspection planning benchmarks.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection End Timestamp' ;
    rdfs:comment 'Precise date and time when the inspector completed all inspection activities and closed the event. Combined with start timestamp to derive inspection duration for resource planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Interval Days' ;
    rdfs:comment 'The prescribed frequency interval in calendar days between successive inspections of this asset, as defined by the preventive maintenance plan, regulatory requirement, or manufacturer specification. Used to calculate next_inspection_due_date.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'The primary technique used to conduct the inspection: visual (physical observation), functional_test (operational test of equipment), measurement (dimensional or parametric measurement), non_destructive_testing (NDT methods such as ultrasonic or thermographic), or document_review (records and certification review). [ENUM-REF-CANDIDATE: visual|functional_test|measurement|non_destructive_testing|document_review|combined — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the inspection event, used in regulatory submissions, audit trails, and cross-system references (e.g., INSP-2024-000123). Aligns with Maximo inspection record numbering conventions.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Overall pass/fail result of the inspection event: pass (all checklist items met), fail (one or more critical items failed), conditional_pass (minor findings with corrective action required but asset may continue operating), or incomplete (inspection not fully executed).' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Indicates the breadth of the inspection performed: full (all checklist items evaluated), partial (subset of items evaluated due to access or time constraints), or spot_check (random sampling of key items). Affects the validity weight of the inspection outcome for compliance purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Timestamp' ;
    rdfs:comment 'Precise date and time when the inspector began the inspection activity on-site. Used for duration calculation, shift alignment, and OEE downtime impact analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the inspection event: scheduled (planned but not started), in_progress (inspector on-site), completed (results recorded), cancelled (inspection voided), or overdue (past due date without completion). Drives maintenance scheduling and compliance dashboards.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection by its business purpose: preventive (scheduled TPM), safety (OSHA/facility safety), regulatory_compliance (UL, CE, ISO certification), quality_audit (QM equipment audit), condition_based (triggered by sensor/SCADA alert), ad_hoc (unplanned), or acceptance (new asset commissioning). [ENUM-REF-CANDIDATE: preventive|safety|regulatory_compliance|quality_audit|condition_based|ad_hoc|acceptance — promote to reference product]' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'The professional certification or qualification number of the inspector, confirming their authority to conduct this type of inspection (e.g., OSHA-certified safety inspector, UL-authorized auditor, ISO lead auditor credential). Required for regulatory compliance evidence.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the qualified inspector or technician who performed the inspection. Stored for audit trail and regulatory evidence purposes. Classified as confidential as it is an employee business record.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorRemarks rdf:type rdf:Property ;
    rdfs:label 'Inspector Remarks' ;
    rdfs:comment 'Free-text field for the inspector\'s additional observations, recommendations, or notes that do not constitute formal findings but provide context for maintenance planning and asset condition assessment.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemsFailed rdf:type rdf:Property ;
    rdfs:label 'Items Failed' ;
    rdfs:comment 'Count of checklist line items that did not meet acceptance criteria during this inspection. Drives findings count reporting, CAPA initiation thresholds, and regulatory non-conformance escalation.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemsPassed rdf:type rdf:Property ;
    rdfs:label 'Items Passed' ;
    rdfs:comment 'Count of checklist line items that met acceptance criteria during this inspection. Together with total_checklist_items and items_failed, provides the raw data for compliance rate reporting without pre-aggregating the metric.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'The date by which the next inspection of this asset must be completed, as determined by the inspection interval, regulatory requirement, or inspector recommendation. Drives the preventive maintenance scheduling engine in Maximo.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The governing body or certification authority whose standard applies to this inspection (e.g., OSHA, ISO, IEC, UL, CE, EPA, NIST, ANSI, IPC). Used to filter and group compliance inspections for regulatory reporting dashboards. [ENUM-REF-CANDIDATE: OSHA|ISO|IEC|UL|CE|EPA|NIST|ANSI|IPC|NONE — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'The specific regulatory or certification standard under which this inspection was conducted (e.g., OSHA 29 CFR 1910, ISO 9001, ISO 14001, ISO 45001, UL 508A, CE Directive 2006/42/EC, IEC 62443). Mandatory for compliance inspections to support regulatory reporting and audit evidence.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk classification assigned to the inspection outcome based on the severity and nature of findings: critical (immediate safety or production risk), high (significant risk requiring prompt action), medium (moderate risk with planned remediation), or low (minor or no risk). Drives escalation and prioritization workflows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The originally planned date for this inspection as generated by the preventive maintenance schedule or regulatory compliance calendar. Compared against inspection_date to measure schedule adherence.' ;
    rdfs:domain ind:InspectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalChecklistItems rdf:type rdf:Property ;
    rdfs:label 'Total Checklist Items' ;
    rdfs:comment 'Total number of inspection checklist line items evaluated during this inspection event. Used as the denominator for compliance rate calculations and inspection completeness metrics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationRecordId rdf:type rdf:Property ;
    rdfs:label 'Calibration Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each calibration record event. Primary key for the calibration_record data product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationRecord .

ind:adjustmentDescription rdf:type rdf:Property ;
    rdfs:label 'Adjustment Description' ;
    rdfs:comment 'Narrative description of the adjustment or corrective action applied to the instrument during calibration (e.g., zero offset correction, span adjustment, sensor replacement). Populated only when adjustment_made is True.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentMade rdf:type rdf:Property ;
    rdfs:label 'Adjustment Made' ;
    rdfs:comment 'Indicates whether a physical adjustment or correction was applied to the instrument during this calibration event. True if the instrument was adjusted; False if it was verified only. Drives downstream impact assessment for prior measurements.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:asFoundError rdf:type rdf:Property ;
    rdfs:label 'As Found Error' ;
    rdfs:comment 'The calculated deviation of the as-found reading from the reference value (as_found_reading minus reference_value). Stored as a business fact to support drift trend analysis and SPC instrument capability studies without requiring recalculation.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asFoundReading rdf:type rdf:Property ;
    rdfs:label 'As Found Reading' ;
    rdfs:comment 'The measured value of the instrument at the start of the calibration event, before any adjustment is made. Used to assess instrument drift, determine if prior measurements were valid, and support SPC instrument traceability analysis.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asLeftError rdf:type rdf:Property ;
    rdfs:label 'As Left Error' ;
    rdfs:comment 'The calculated deviation of the as-left reading from the reference value (as_left_reading minus reference_value). Confirms residual error after adjustment and is used for measurement uncertainty budgets.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asLeftReading rdf:type rdf:Property ;
    rdfs:label 'As Left Reading' ;
    rdfs:comment 'The measured value of the instrument at the conclusion of the calibration event, after any adjustment or correction has been applied. Confirms the instrument is within tolerance before being returned to service.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'The date on which the calibration activity was physically performed. This is the principal business event date used for certificate issuance, compliance records, and next-due-date calculation.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'The date by which the next calibration must be completed, calculated from calibration_date plus the calibration_interval. Used for preventive maintenance scheduling and compliance monitoring.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Interval Days' ;
    rdfs:comment 'The approved recalibration frequency expressed in calendar days. Used to compute calibration_due_date and to schedule preventive maintenance in Maximo. Determined by instrument criticality, historical drift, and manufacturer recommendations.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationLab rdf:type rdf:Property ;
    rdfs:label 'Calibration Lab' ;
    rdfs:comment 'Indicates whether the calibration was performed by an internal calibration lab, an externally accredited laboratory (ISO/IEC 17025), an external non-accredited service provider, or the OEM service team.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationMethod rdf:type rdf:Property ;
    rdfs:label 'Calibration Method' ;
    rdfs:comment 'The documented calibration procedure or method reference used (e.g., internal procedure number, NIST traceable method, manufacturer procedure). Ensures repeatability and traceability of the calibration process.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationNotes rdf:type rdf:Property ;
    rdfs:label 'Calibration Notes' ;
    rdfs:comment 'Free-text field for the technician to record observations, anomalies, special conditions, or additional context about the calibration event not captured in structured fields.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Number' ;
    rdfs:comment 'Externally visible, human-readable unique identifier for this calibration event, used on calibration certificates and quality records. Format: CAL-{ASSET_CODE}-{SEQUENCE}.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Overall result and lifecycle status of the calibration event. \'pass\' indicates the instrument is within tolerance; \'fail\' triggers quarantine and CAPA; \'conditional_pass\' indicates marginal acceptance with restrictions; \'out_of_tolerance\' indicates as-found deviation requiring adjustment.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationType rdf:type rdf:Property ;
    rdfs:label 'Calibration Type' ;
    rdfs:comment 'Classification of the calibration event by trigger or purpose. \'initial\' is performed on new instruments; \'periodic\' is routine scheduled calibration; \'after_repair\' follows maintenance; \'unscheduled\' is triggered by suspected drift or incident.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'The date on which the calibration certificate was formally issued and signed. May differ from calibration_date if review and approval occur after the physical calibration activity.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The official certificate number issued upon successful calibration, as printed on the calibration certificate. Used for document control, quality records management, and regulatory audit evidence.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Environmental Humidity Pct' ;
    rdfs:comment 'Relative humidity percentage recorded at the time and location of calibration. Required environmental condition documentation per ISO/IEC 17025 for humidity-sensitive instruments.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Environmental Temperature C' ;
    rdfs:comment 'Ambient temperature in degrees Celsius recorded at the time and location of calibration. Environmental conditions can affect measurement accuracy and are required to be documented per ISO/IEC 17025.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalLabAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'External Lab Accreditation Number' ;
    rdfs:comment 'Accreditation body certificate number for the external calibration laboratory (e.g., A2LA, NVLAP, UKAS accreditation number). Validates the laboratory\'s ISO/IEC 17025 accreditation status.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalLabName rdf:type rdf:Property ;
    rdfs:label 'External Lab Name' ;
    rdfs:comment 'Name of the external calibration service provider or accredited laboratory, when calibration_lab is \'external_accredited\' or \'external_non_accredited\'. Used for supplier qualification and audit trail.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentTag rdf:type rdf:Property ;
    rdfs:label 'Instrument Tag' ;
    rdfs:comment 'Plant or facility tag number assigned to the measurement instrument per ISA-5.1 instrumentation standards (e.g., TI-101, PT-205). Used for shop floor identification and P&ID cross-reference.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Classification of the measurement instrument or device being calibrated. Drives applicable calibration procedures and tolerance standards. [ENUM-REF-CANDIDATE: gauge|sensor|transducer|transmitter|analyzer|controller|plc|cnc_probe|torque_wrench|caliper|micrometer|thermometer|pressure_meter|flow_meter — promote to reference product]' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementParameter rdf:type rdf:Property ;
    rdfs:label 'Measurement Parameter' ;
    rdfs:comment 'The physical or process parameter being measured by the instrument (e.g., temperature, pressure, flow, voltage, torque, dimension, weight). Determines the applicable calibration standard and tolerance regime.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUncertainty rdf:type rdf:Property ;
    rdfs:label 'Measurement Uncertainty' ;
    rdfs:comment 'The expanded measurement uncertainty (k=2, 95% confidence) associated with the calibration result, expressed in the same unit as measurement_unit. Required for ISO/IEC 17025 accredited calibration certificates.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'The unit of measure applicable to as_found_reading, as_left_reading, reference_value, and tolerance fields (e.g., °C, bar, mA, mm, Nm, V, kg). Must conform to SI units per ISO 80000.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfService rdf:type rdf:Property ;
    rdfs:label 'Out Of Service' ;
    rdfs:comment 'Indicates whether the instrument has been placed out of service as a result of this calibration event (e.g., due to a fail or out-of-tolerance result). When True, the instrument must be quarantined and a CAPA initiated before return to service.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorMeasurementImpact rdf:type rdf:Property ;
    rdfs:label 'Prior Measurement Impact' ;
    rdfs:comment 'Assessment of whether measurements taken by this instrument since its last calibration may have been affected by the out-of-tolerance condition found. Required for product conformity risk assessment when a calibration failure is detected.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceValue rdf:type rdf:Property ;
    rdfs:label 'Reference Value' ;
    rdfs:comment 'The true or nominal value against which the instrument reading is compared during calibration. Established by the reference standard and used to compute as-found and as-left errors.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Standard Certificate Number' ;
    rdfs:comment 'Certificate number of the reference standard used during calibration, establishing the NIST/SI traceability chain. Required for ISO/IEC 17025 compliance documentation.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Number' ;
    rdfs:comment 'The qualification or certification number of the technician who performed the calibration, as issued by an accredited body (e.g., ASQ, NIST, internal competency register). Required for ISO/IEC 17025 personnel traceability.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianName rdf:type rdf:Property ;
    rdfs:label 'Technician Name' ;
    rdfs:comment 'Full name of the qualified technician who performed and certified the calibration. Captured as a denormalized field on the calibration certificate for regulatory traceability even if the technician record changes.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Lower Limit' ;
    rdfs:comment 'The minimum acceptable deviation from the reference value for the instrument to be considered in calibration. Expressed in the same unit as measurement_unit. Falling below this limit results in a fail or out-of-tolerance status.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Upper Limit' ;
    rdfs:comment 'The maximum acceptable deviation from the reference value for the instrument to be considered in calibration. Expressed in the same unit as measurement_unit. Exceeding this limit results in a fail or out-of-tolerance status.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Unique system-generated identifier for the inspection plan record. Primary key for the inspection_plan data product in the quality domain.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:ecoId rdf:type rdf:Property ;
    rdfs:label 'Eco Id' ;
    rdfs:comment 'Foreign key linking to engineering.eco. Business justification: When an ECO changes a component, the associated inspection plan must be revised. The existing eco_number plain-text field is a denormalized ECO reference; replacing it with eco_id FK enforces referent' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Eco .

ind:fmeaId rdf:type rdf:Property ;
    rdfs:label 'Fmea Id' ;
    rdfs:comment 'Foreign key linking to quality.fmea. Business justification: inspection_plan carries fmea_reference as a plain STRING field referencing the FMEA that drove the inspection plan\'s characteristic definitions and control limits. This is a denormalized text referenc' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fmea .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the inspection plan was formally approved for use. Provides an audit trail for ISO 9001 document control and regulatory compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:apqpPhase rdf:type rdf:Property ;
    rdfs:label 'Apqp Phase' ;
    rdfs:comment 'APQP phase during which this inspection plan was developed or is applicable. Phase 1: Plan and Define; Phase 2: Product Design and Development; Phase 3: Process Design and Development; Phase 4: Product and Process Validation; Phase 5: Feedback, Assessment and Corrective Action.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aqlLevel rdf:type rdf:Property ;
    rdfs:label 'Aql Level' ;
    rdfs:comment 'Acceptable Quality Level expressed as a percentage defective, defining the maximum tolerable defect rate for the sampling plan. Used in conjunction with ISO 2859-1 / ANSI Z1.4 sampling tables.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlMethodCode rdf:type rdf:Property ;
    rdfs:label 'Control Method Code' ;
    rdfs:comment 'Code identifying the measurement or control method used during inspection (e.g., visual, dimensional, functional, chemical, SPC chart). References the SAP QM master inspection characteristic control indicator.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPlanReference rdf:type rdf:Property ;
    rdfs:label 'Control Plan Reference' ;
    rdfs:comment 'Document number of the associated APQP Control Plan that this inspection plan implements. The control plan defines the process controls and reaction plans linked to inspection characteristics.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpkMinimum rdf:type rdf:Property ;
    rdfs:label 'Cpk Minimum' ;
    rdfs:comment 'Minimum acceptable Cpk (Process Capability Index) value required for this inspection characteristic. Typically 1.33 for standard processes and 1.67 for safety-critical characteristics per PPAP requirements.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSpecificRequirement rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Requirement' ;
    rdfs:comment 'Indicates whether this inspection plan was created or modified to satisfy a specific customer quality requirement (CSR) beyond standard internal or regulatory requirements. Relevant for OEM (Original Equipment Manufacturer) supply relationships.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Method Code' ;
    rdfs:comment 'Reference to the standardized inspection method or test procedure document used to perform the inspection. Links to the SAP QM inspection method master record.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'Stage in the production or supply chain process at which the inspection is performed. Incoming covers receiving inspection; in-process covers WIP (Work In Progress) checks; final covers end-of-line; outgoing covers pre-shipment; skip indicates skip-lot logic.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longTextDescription rdf:type rdf:Property ;
    rdfs:label 'Long Text Description' ;
    rdfs:comment 'Detailed narrative description of the inspection plan scope, special instructions, safety precautions, and any additional context required by the inspector. Corresponds to SAP QM long text on the task list header.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerToleranceLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Tolerance Limit' ;
    rdfs:comment 'Lower specification limit for the primary inspection characteristic. Values below this limit result in a non-conformance. Used in SPC and Cp/Cpk capability index calculations.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'Routing operation number within the inspection plan, corresponding to the SAP QM task list operation (PLPO.VORNR). Defines the sequence of inspection steps within the plan.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name or short description of the inspection plan, identifying the product, process, or operation it governs.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the inspection plan, aligned with SAP QM plan group and plan group counter. Used for cross-system reference and document control.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version or revision number of the inspection plan, corresponding to the SAP QM plan group counter. Tracks engineering changes and revisions aligned with ECO/ECN processes.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapLevel rdf:type rdf:Property ;
    rdfs:label 'Ppap Level' ;
    rdfs:comment 'PPAP submission level (1–5) required for this inspection plan, per AIAG PPAP standard. Level 1 requires only a Part Submission Warrant; Level 3 is the default full submission; Level 5 requires records reviewed at the manufacturing site.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productGroupCode rdf:type rdf:Property ;
    rdfs:label 'Product Group Code' ;
    rdfs:comment 'SAP material group or product family code to which this inspection plan applies. Enables grouping of inspection plans by product category for reporting and analytics.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Description of the reason for the current plan version, such as an ECO (Engineering Change Order), CAPA (Corrective and Preventive Action) outcome, customer complaint, or regulatory update.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of units to be drawn from the inspection lot for evaluation. Determined by the sampling procedure and AQL level. A value of zero indicates 100% inspection.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Size Unit' ;
    rdfs:comment 'Unit of measure for the sample size quantity (e.g., EA for each/piece, KG for kilogram, M for meter). Aligns with SAP base unit of measure for the material. [ENUM-REF-CANDIDATE: EA|PC|KG|M|L|M2|M3 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure Code' ;
    rdfs:comment 'Code referencing the statistical sampling procedure applied in this inspection plan, including sample size, acceptance number, and rejection number per AQL (Acceptable Quality Level) tables.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcEnabled rdf:type rdf:Property ;
    rdfs:label 'Spc Enabled' ;
    rdfs:comment 'Indicates whether SPC (Statistical Process Control) charting and Cp/Cpk capability monitoring are activated for this inspection plan. When true, measurement results feed into control charts and process capability analysis.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Nominal or target value for the primary inspection characteristic. Represents the ideal measurement around which tolerances are defined. Used as the centerline reference in SPC control charts.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperToleranceLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Tolerance Limit' ;
    rdfs:comment 'Upper specification limit for the primary inspection characteristic. Values exceeding this limit result in a non-conformance. Used in SPC (Statistical Process Control) and Cp/Cpk capability index calculations.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Code' ;
    rdfs:comment 'SAP QM usage decision code that defines the default disposition action (accept, reject, rework) applied when inspection results meet or fail acceptance criteria.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID of the quality engineer or planner who originally created this inspection plan record in SAP QM or the source system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a single inspection lot record in the quality execution system. Primary key for the inspection_lot entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Foreign key linking to order.delivery. Business justification: Outbound delivery inspections and inbound goods-receipt inspection lots are directly triggered by a delivery in SAP QM. Quality teams need delivery_id on inspection_lot to trace which shipment trigger' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Delivery .

ind:goodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Id' ;
    rdfs:comment 'Foreign key linking to order.goods_issue. Business justification: In SAP QM and industrial manufacturing, a goods issue movement can trigger an outbound inspection lot (e.g., final inspection before shipment). Linking inspection_lot to goods_issue enables quality ga' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsIssue .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Reference to the sales order associated with this inspection lot, applicable for customer-specific inspection requirements, pre-shipment inspections, or RMA receipt inspections. Links quality execution to order fulfillment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:lotBatchId rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot_batch. Business justification: In SAP QM and IATF 16949 manufacturing, every inspection lot is raised against a specific lot/batch. This link enables lot-level quality traceability for PPAP, containment, and disposition decisions. ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotBatch .

ind:materialRequirementId rdf:type rdf:Property ;
    rdfs:label 'Material Requirement Id' ;
    rdfs:comment 'Foreign key linking to supply.material_requirement. Business justification: Inspection lots for incoming goods trace back to the material requirement that drove the purchase order, enabling planning-to-quality traceability reporting. In industrial manufacturing MRP/QM integra' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialRequirement .

ind:ncrId rdf:type rdf:Property ;
    rdfs:label 'Ncr Id' ;
    rdfs:comment 'Reference to the Non-Conformance Report (NCR) record created as a result of this inspection lot\'s non-conformance or reject disposition. Enables traceability from inspection event to corrective action workflow.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ncr .

ind:poLineItemId rdf:type rdf:Property ;
    rdfs:label 'Po Line Item Id' ;
    rdfs:comment 'Foreign key linking to supplier.po_line_item. Business justification: In industrial manufacturing, incoming inspection lots are created at the PO line item level (each line item may have different material, quantity, and quality requirements). Line-item-level lot tracea' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLineItem .

ind:primaryInspectionMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Material Master Id' ;
    rdfs:comment 'Reference to the material or part master record subject to this inspection lot. Links to the product/material master in SAP MM/PLM for BOM and specification retrieval.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:procurementGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Procurement Goods Receipt Id' ;
    rdfs:comment 'Reference to the goods receipt document (SAP material document) that triggered this incoming inspection lot. Applicable for inspection types 01 (GR from PO) and 04 (GR from Production Order). Enables traceability from inspection to inventory movement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementGoodsReceipt .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Reference to the purchase order associated with this inspection lot, applicable for incoming goods receipt inspections from suppliers. Links to SAP MM purchasing documents.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:serializedUnitId rdf:type rdf:Property ;
    rdfs:label 'Serialized Unit Id' ;
    rdfs:comment 'Foreign key linking to inventory.serialized_unit. Business justification: For serialized industrial products (drives, PLCs, switchgear), inspection lots are raised against individual serial numbers. Serial-level inspection traceability is required for warranty, field servic' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SerializedUnit .

ind:certificateOfConformanceRequired rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Conformance Required' ;
    rdfs:comment 'Indicates whether a Certificate of Conformance (CoC) or quality certificate must be generated and issued upon acceptance of this inspection lot. Driven by customer contract requirements or regulatory mandates.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects or non-conformances detected across all inspection characteristics within this lot. Used for defect rate calculation, SPC analysis, and NCR triggering thresholds.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionBy rdf:type rdf:Property ;
    rdfs:label 'Disposition By' ;
    rdfs:comment 'User ID or name of the quality engineer or authorized personnel who recorded the usage decision and disposition for this inspection lot. Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'SAP QM usage decision code (e.g., A1=Accept, R1=Reject, R2=Rework, S1=Scrap) providing a standardized coded classification of the disposition decision for system processing and reporting.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final disposition decision made upon completion of inspection results evaluation. Determines the fate of the inspected material: \'accept\' = material released to stock/use; \'reject\' = material blocked/returned; \'rework\' = material sent for corrective rework; \'scrap\' = material scrapped; \'conditional_release\' = accepted with documented deviations/concessions.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'Date and time when the usage decision (disposition) was formally recorded in the quality management system. Marks the closure of the active inspection phase and triggers downstream stock posting or NCR creation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dynamicModificationRule rdf:type rdf:Property ;
    rdfs:label 'Dynamic Modification Rule' ;
    rdfs:comment 'Code or name of the dynamic modification rule applied to automatically adjust the inspection level (normal/tightened/reduced/skip) based on cumulative quality history for this material-supplier or material-plant combination. Aligns with SAP QM dynamic modification.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLevel rdf:type rdf:Property ;
    rdfs:label 'Inspection Level' ;
    rdfs:comment 'Current inspection severity level applied to this lot based on the supplier or process quality history. \'normal\' = standard AQL sampling; \'tightened\' = increased scrutiny due to recent failures; \'reduced\' = relaxed sampling due to consistent quality; \'skip\' = lot accepted without inspection based on skip-lot qualification.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Type Code' ;
    rdfs:comment 'SAP QM inspection type code classifying the origin and nature of the inspection lot. Standard SAP codes: 01=Goods Receipt from Purchase Order (incoming), 04=Goods Receipt from Production Order (final), 05=Goods Issue, 06=Delivery to Customer, 08=In-Process Inspection, 10=Recurring Inspection, 89=RMA/Customer Return Receipt. [ENUM-REF-CANDIDATE: 01|04|05|06|08|10|89 — promote to reference product for full SAP inspection type catalogue]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Type Description' ;
    rdfs:comment 'Business-readable classification of the inspection event type: \'incoming\' = supplier goods receipt; \'in_process\' = mid-production milestone check; \'final\' = post-production completion check; \'recurring\' = periodic scheduled inspection; \'rma_receipt\' = customer return receipt inspection; \'delivery\' = pre-shipment inspection; \'goods_issue\' = outbound goods inspection. [ENUM-REF-CANDIDATE: incoming|in_process|final|recurring|rma_receipt|delivery|goods_issue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the inspection lot by the quality management system (e.g., SAP QM lot number). Used for cross-system traceability and communication with shop floor, suppliers, and auditors.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOriginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Origin Timestamp' ;
    rdfs:comment 'The principal real-world business event timestamp recording when the inspection lot was triggered and created in the quality management system. Distinct from ETL audit timestamps. Aligns with SAP QM lot creation date/time.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity' ;
    rdfs:comment 'Total quantity of material or units submitted for inspection in this lot. Represents the population from which samples are drawn. Expressed in the base unit of measure of the material.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity Uom' ;
    rdfs:comment 'Unit of measure for the inspection lot quantity (e.g., EA=Each, KG=Kilogram, M=Meter, L=Liter, M2=Square Meter). Aligns with SAP base unit of measure from material master.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotRemarks rdf:type rdf:Property ;
    rdfs:label 'Lot Remarks' ;
    rdfs:comment 'Free-text field for quality engineers to record observations, special conditions, deviations, or contextual notes relevant to this inspection lot that are not captured in structured fields. Supports audit documentation.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current workflow state of the inspection lot within the quality execution lifecycle. Drives downstream actions: \'created\' = lot opened awaiting release; \'released\' = inspection authorized to begin; \'results_recorded\' = all characteristic results entered; \'usage_decided\' = disposition decision made; \'closed\' = lot archived. [ENUM-REF-CANDIDATE: created|released|results_recorded|usage_decided|closed — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrTriggered rdf:type rdf:Property ;
    rdfs:label 'Ncr Triggered' ;
    rdfs:comment 'Indicates whether a Non-Conformance Report (NCR) was automatically or manually triggered as a result of this inspection lot\'s reject disposition or detected non-conformances. True = NCR created; False = no NCR required.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonconformingQuantity rdf:type rdf:Property ;
    rdfs:label 'Nonconforming Quantity' ;
    rdfs:comment 'Quantity of units or material within the lot that failed to meet specification requirements. Expressed in the same unit of measure as lot_quantity. Used to calculate reject rate and determine disposition scope.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Summarized quality outcome of the inspection lot based on all characteristic results evaluated against acceptance criteria. \'passed\' = all characteristics within specification; \'failed\' = one or more characteristics out of specification; \'conditionally_passed\' = passed with documented deviations; \'pending\' = results not yet fully recorded.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredEndDate rdf:type rdf:Property ;
    rdfs:label 'Required End Date' ;
    rdfs:comment 'Target date by which the inspection lot must be completed and a usage decision recorded, as defined by the inspection plan or production schedule. Supports SLA monitoring and escalation management.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionLevel rdf:type rdf:Property ;
    rdfs:label 'Revision Level' ;
    rdfs:comment 'Engineering revision or drawing revision level of the material or part at the time of inspection. Ensures inspection results are traceable to the correct design revision, supporting Engineering Change Order (ECO) and ECN management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDrawingProcedure rdf:type rdf:Property ;
    rdfs:label 'Sample Drawing Procedure' ;
    rdfs:comment 'Code or name of the sampling procedure applied to determine the sample size for this inspection lot (e.g., AQL 1.0, AQL 2.5, 100% inspection, skip-lot). Derived from the inspection plan sampling scheme.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultId rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each inspection characteristic result record within an inspection lot. Primary key for the inspection_result data product in the quality domain.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionCharacteristicId rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Id' ;
    rdfs:comment 'Reference to the master inspection characteristic definition (e.g., dimension, hardness, visual attribute) as configured in the inspection plan. Enables aggregation of results across lots for SPC analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionCharacteristic .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Foreign key linking to order.order_line. Business justification: Required for linking each inspection result to its specific order line, enabling quality reports and order fulfillment decisions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:attributeResult rdf:type rdf:Property ;
    rdfs:label 'Attribute Result' ;
    rdfs:comment 'Pass/fail judgment for attribute-type inspection characteristics (e.g., visual defect present/absent, functional test pass/fail). Null for variable characteristics where measured_value is populated.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpIndex rdf:type rdf:Property ;
    rdfs:label 'Cp Index' ;
    rdfs:comment 'Process capability index Cp measuring the ratio of the specification width to the process spread (6-sigma). Indicates whether the process is capable of meeting specification limits regardless of centering. Cp ≥ 1.33 is typically required per PPAP.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpkIndex rdf:type rdf:Property ;
    rdfs:label 'Cpk Index' ;
    rdfs:comment 'Process capability index Cpk measuring the ratio of the nearest specification limit to the process mean, accounting for process centering. Cpk ≥ 1.33 is typically required for PPAP approval. Key metric for supplier quality and process performance reporting.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized defect classification code identifying the type of nonconformance detected (e.g., DIM-OOT for out-of-tolerance dimension, SURF-SCR for surface scratch). Feeds Pareto analysis and CAPA root cause categorization. [ENUM-REF-CANDIDATE: promote to reference product for defect code catalog]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Free-text description of the nonconformance or defect observed during inspection. Provides context beyond the defect code for root cause analysis and CAPA documentation.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the inspection measurement was physically recorded. The principal business event timestamp for this result. Used for SPC time-series analysis, shift-based quality reporting, and audit trail.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isOutOfControl rdf:type rdf:Property ;
    rdfs:label 'Is Out Of Control' ;
    rdfs:comment 'Indicates whether the measurement triggered an SPC out-of-control signal (e.g., point beyond control limits, run rule violation per Western Electric rules). Distinct from out-of-spec: a process can be in-spec but out-of-control. Triggers SPC investigation workflow.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOutOfSpec rdf:type rdf:Property ;
    rdfs:label 'Is Out Of Spec' ;
    rdfs:comment 'Indicates whether the measured value falls outside the engineering specification limits (USL or LSL). True when measured_value > upper_spec_limit or measured_value < lower_spec_limit. Used for rapid filtering of nonconforming results and NCR triggering.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'The lower statistical process control limit for the characteristic, typically set at ±3 sigma from the process mean. Used in SPC X-bar and R charts to detect process shifts.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Spec Limit' ;
    rdfs:comment 'The lower engineering specification limit for the characteristic. Measurements below this value are out-of-specification. Used in Cp/Cpk calculation and SPC control chart setup.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual numeric measurement recorded for a variable inspection characteristic (e.g., 24.987 mm for a diameter). Null for attribute-type characteristics. Core data point for SPC charting and Cp/Cpk calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominalValue rdf:type rdf:Property ;
    rdfs:label 'Nominal Value' ;
    rdfs:comment 'The engineering design target or nominal value for the characteristic as specified in the drawing or specification. Used to calculate deviation from target and for SPC centering analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text remarks or observations entered by the inspector at the time of measurement. Captures contextual information not covered by structured fields, such as environmental conditions, equipment anomalies, or visual observations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current disposition status of the inspection characteristic result: \'accepted\' (within specification), \'rejected\' (out of specification), \'conditional\' (requires further review or deviation approval), \'open\' (not yet evaluated), or \'cancelled\'.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedure rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure' ;
    rdfs:comment 'Sampling procedure or plan applied for this inspection characteristic (e.g., AQL 1.0 Level II, 100% inspection, skip-lot). Determines the statistical confidence of the inspection result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Production shift during which the inspection was performed (e.g., day, afternoon, night). Enables shift-based quality performance analysis to identify systematic variation by shift.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcChartType rdf:type rdf:Property ;
    rdfs:label 'Spc Chart Type' ;
    rdfs:comment 'Type of SPC control chart applied to this characteristic: \'xbar_r\' (X-bar and R for subgroups), \'i_mr\' (Individuals and Moving Range), \'p_chart\' (proportion defective), \'np_chart\' (number defective), \'c_chart\' (count of defects), \'u_chart\' (defects per unit). Determines the statistical method for control limit calculation. [ENUM-REF-CANDIDATE: xbar_r|xbar_s|i_mr|p_chart|np_chart|c_chart|u_chart — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subgroupNumber rdf:type rdf:Property ;
    rdfs:label 'Subgroup Number' ;
    rdfs:comment 'Sequential subgroup number within the SPC control chart for this characteristic. Used to order data points on the SPC chart and identify the rational subgroup to which this measurement belongs.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'The upper statistical process control limit for the characteristic, typically set at ±3 sigma from the process mean. Triggers investigation when exceeded even if within specification. Used in SPC X-bar and R charts.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Spec Limit' ;
    rdfs:comment 'The upper engineering specification limit for the characteristic. Measurements above this value are out-of-specification. Used in Cp/Cpk calculation and SPC control chart setup.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderIntakeId rdf:type rdf:Property ;
    rdfs:label 'Order Intake Id' ;
    rdfs:comment 'Foreign key linking to sales.order_intake. Business justification: NCRs in industrial manufacturing are raised against specific customer orders. Linking NCR to order_intake enables RMA processing, customer notification, disposition tracking, and order-level nonconfor' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderIntake .

ind:qualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Quality Audit Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_audit. Business justification: A quality audit (internal, supplier, or process audit) frequently generates NCRs as findings. quality_audit tracks major_ncr_count and minor_ncr_count as aggregate counts, but there is no FK from indi' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityAudit .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Actual date on which the NCR was formally closed after verification of all corrective actions and disposition completion. Used for cycle time KPI calculation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Description of immediate containment actions taken to prevent further non-conforming product from reaching the customer or next process step (e.g., quarantine, 100% inspection, production hold). Corresponds to 8D Step D3.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Containment Completed Date' ;
    rdfs:comment 'Date by which all immediate containment actions were verified as complete. Used for 8D D3 closure tracking and customer reporting.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerComplaintNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Number' ;
    rdfs:comment 'Customer-provided reference number for the complaint or quality issue, as received from the customer or logged in Salesforce Service Cloud. Enables cross-reference with customer records.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required' ;
    rdfs:comment 'Indicates whether the customer must be formally notified of this non-conformance (e.g., for shipped non-conforming product, field safety issues, or contractual quality notification requirements).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectLocation rdf:type rdf:Property ;
    rdfs:label 'Defect Location' ;
    rdfs:comment 'Physical location or feature on the part/product where the defect was found (e.g., weld seam, connector pin 3, housing surface). Supports targeted rework and process improvement.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'The process stage or channel where the non-conformance was first detected: incoming_inspection (receiving), in_process (shop floor/WIP), final_inspection (end-of-line), field_customer (reported by customer or field), audit (internal/external audit), supplier_delivery (at point of supplier delivery).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the non-conformance was first detected or observed. This is the principal business event timestamp for the NCR lifecycle.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Formal disposition decision for the non-conforming material: use_as_is (accept with deviation), rework (correct in-house), scrap (destroy), return_to_supplier, repair, replace (issue replacement), credit (issue financial credit), no_fault_found. Drives material handling and financial impact. [ENUM-REF-CANDIDATE: use_as_is|rework|scrap|return_to_supplier|repair|replace|credit|no_fault_found — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionAuthority rdf:type rdf:Property ;
    rdfs:label 'Disposition Authority' ;
    rdfs:comment 'Name or role of the authorized person or body (e.g., Material Review Board, Quality Manager, Engineering) who approved the disposition decision. Required for regulatory and customer-specific quality requirements.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eightDReportNumber rdf:type rdf:Property ;
    rdfs:label 'Eight D Report Number' ;
    rdfs:comment 'Reference number of the formal 8D problem-solving report associated with this NCR. Applicable when is_8d_required is true. Enables cross-reference to the 8D documentation submitted to the customer.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is8dRequired rdf:type rdf:Property ;
    rdfs:label 'Is 8d Required' ;
    rdfs:comment 'Indicates whether the 8D (Eight Disciplines) structured problem-solving methodology is required for this NCR, typically mandated for customer-facing complaints or high-severity issues.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Short description of the affected material or product as defined in the material master. Provides human-readable context without requiring a join to the material master.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Number' ;
    rdfs:comment 'Human-readable, externally-visible NCR reference number used in communications with suppliers, customers, and auditors. Format: NCR-YYYY-NNNNNN. Maps to SAP QM notification number.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrStatus rdf:type rdf:Property ;
    rdfs:label 'Ncr Status' ;
    rdfs:comment 'Current lifecycle state of the NCR workflow: draft (being authored), open (submitted and active), under_review (root cause analysis in progress), disposition_pending (awaiting disposition decision), closed (all actions complete), cancelled (voided).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrType rdf:type rdf:Property ;
    rdfs:label 'Ncr Type' ;
    rdfs:comment 'Classification of the NCR by originating channel: internal (detected in-house), customer (complaint from customer), supplier (incoming material non-conformance), field_return (RMA/field failure), or audit (finding from internal or external audit).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceDescription rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Description' ;
    rdfs:comment 'Detailed narrative description of the non-conformance, including the observed defect, deviation from specification, or failure mode. Supports root cause analysis and CAPA.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformingQty rdf:type rdf:Property ;
    rdfs:label 'Nonconforming Qty' ;
    rdfs:comment 'Quantity of units, parts, or material identified as non-conforming. Used for scrap cost calculation, yield rate analysis, and containment scope.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Qty Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the non-conforming quantity (e.g., EA=each, KG=kilogram, M=meter, PC=piece). Aligns with SAP base unit of measure. [ENUM-REF-CANDIDATE: EA|KG|LB|M|M2|M3|L|PC|SET|BOX — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this non-conformance must be reported to a regulatory authority (e.g., OSHA, EPA, CE/UL product safety authority). Triggers mandatory regulatory notification workflows.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the NCR was formally submitted and entered into the quality management system. May differ from detection_timestamp if there is a reporting lag.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnShipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Return Shipment Status' ;
    rdfs:comment 'Current status of the physical return shipment for RMA-linked NCRs: not_applicable (no physical return), pending (RMA issued, awaiting shipment), in_transit (goods in transit), received (goods received at facility), inspected (incoming inspection complete), closed (return process complete).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Standardized category of the identified root cause for trend analysis and SPC reporting: design, process, material, equipment, human_error, measurement, supplier, or environment. Enables Pareto analysis of quality failures. [ENUM-REF-CANDIDATE: design|process|material|equipment|human_error|measurement|supplier|environment — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmNotificationType rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Notification Type' ;
    rdfs:comment 'SAP QM notification type code mapped to this NCR: Q1 (customer complaint), Q2 (internal quality notification), Q3 (supplier quality notification). Enables direct traceability to the SAP QM source record.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity level of the non-conformance based on impact to safety, quality, regulatory compliance, or customer satisfaction: critical (safety/regulatory risk), major (significant quality impact), minor (limited impact), observation (potential risk noted).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Planned date by which the NCR is expected to be fully closed, including all corrective actions verified. Used for SLA tracking and escalation management.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Unique system-generated identifier for the Corrective and Preventive Action (CAPA) record. Primary key for the capa data product in the quality domain.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Foreign key linking to production.routing. Business justification: CAPAs involving process changes reference the affected routing for change control and re-validation. APQP/PPAP process change notifications require routing reference to assess impact on process steps ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:supplierAuditId rdf:type rdf:Property ;
    rdfs:label 'Supplier Audit Id' ;
    rdfs:comment 'Foreign key linking to supplier.supplier_audit. Business justification: In industrial manufacturing, CAPAs are routinely initiated from supplier audit findings (major/critical nonconformances). IATF 16949 requires traceability from audit finding to corrective action. sour' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierAudit .

ind:actionImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Action Implementation Date' ;
    rdfs:comment 'The date on which the corrective and/or preventive actions were fully implemented in the production process or quality system. Marks the transition from planning to execution phase.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedProcessCode rdf:type rdf:Property ;
    rdfs:label 'Affected Process Code' ;
    rdfs:comment 'Identifier of the manufacturing process, work center, or production routing step where the nonconformity was detected or originated. Sourced from SAP PP routing or Siemens Opcenter MES process definition.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the CAPA record, typically formatted as CAPA-YYYY-NNNNNN. Used in communications, audit trails, and regulatory submissions. Sourced from SAP QM notification numbering.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle state of the CAPA record. Tracks progression from initial creation through root cause analysis, action implementation, effectiveness verification, and formal closure per ISO 9001 Clause 10.2.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classifies whether the action is corrective (addressing an existing nonconformity), preventive (eliminating a potential nonconformity), or both. Drives workflow routing and reporting in SAP QM.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Containment Completion Date' ;
    rdfs:comment 'The date on which all immediate containment actions were completed and verified. Used to measure response speed and compliance with customer-mandated containment timelines.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Detailed description of the permanent corrective actions planned to eliminate the root cause of the nonconformity and prevent recurrence. Includes process changes, design modifications, procedure updates, or training interventions.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'The date on which the customer was formally notified of the nonconformity and the corrective action plan. Null if customer notification is not required or has not yet occurred.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Organizational department or cost center responsible for the process or area where the nonconformity originated. Used for departmental quality KPI reporting and accountability tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Date' ;
    rdfs:comment 'The date on which the effectiveness of the implemented actions was formally verified and documented. Required for CAPA closure per ISO 9001 Clause 10.2.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Method' ;
    rdfs:comment 'Description of the method used to verify that the implemented corrective and preventive actions were effective in eliminating the root cause and preventing recurrence. May include SPC monitoring, re-audit, production run data review, or customer feedback analysis.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerified rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verified' ;
    rdfs:comment 'Indicates whether the corrective and preventive actions have been formally verified as effective. True when verification is complete and documented; False when verification is pending or failed. Required gate for CAPA closure.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immediateContainmentAction rdf:type rdf:Property ;
    rdfs:label 'Immediate Containment Action' ;
    rdfs:comment 'Description of the short-term containment actions taken immediately upon detection of the nonconformity to prevent further defective product from reaching the customer or next process step. Corresponds to D3 in the 8D methodology.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The calendar date on which the CAPA was formally opened and initiated. Represents the principal business event timestamp for the CAPA lifecycle. Used to calculate cycle time and compliance with response time SLAs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Summary of key lessons learned from the CAPA investigation and resolution that should be shared across the organization to prevent similar issues. Feeds into the knowledge management and APQP process for future product launches.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:n8dReportNumber rdf:type rdf:Property ;
    rdfs:label 'N8d Report Number' ;
    rdfs:comment 'Reference number of the formal 8D (Eight Disciplines) problem-solving report associated with this CAPA, if applicable. Used when customer-mandated 8D reporting is required, particularly in automotive and industrial OEM supply chains.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Ppap Impact Flag' ;
    rdfs:comment 'Indicates whether this CAPA requires a new or revised Production Part Approval Process (PPAP) submission due to process or design changes resulting from the corrective action. Relevant for automotive and industrial OEM supply chains.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Plan' ;
    rdfs:comment 'Description of proactive actions planned to eliminate the causes of potential nonconformities before they occur. Addresses systemic risks identified during root cause analysis that may affect similar processes or products.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemDescription rdf:type rdf:Property ;
    rdfs:label 'Problem Description' ;
    rdfs:comment 'Detailed narrative describing the nonconformity, defect, or quality event that triggered the CAPA. Includes observed symptoms, affected product or process, and initial impact assessment. Corresponds to the problem statement in the 8D or CAPA methodology.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandardReference rdf:type rdf:Property ;
    rdfs:label 'Quality Standard Reference' ;
    rdfs:comment 'The specific quality standard clause, regulatory requirement, or customer specification that was violated or is being addressed by this CAPA. Examples: ISO 9001:2015 Clause 8.5.2, IATF 16949, customer-specific quality requirements.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this CAPA addresses a recurring nonconformity that has been previously reported. True if the same or similar root cause has been identified in a prior CAPA. Used for chronic problem identification and escalation.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicates whether this CAPA has regulatory reporting implications, such as mandatory notification to ISO certification bodies, OSHA, EPA, or CE/UL certification authorities. Triggers compliance escalation workflow when True.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'The structured methodology used to identify the root cause of the nonconformity. Common methods include 5-Why, Ishikawa (fishbone) diagram, 8D problem solving, Failure Mode and Effects Analysis (FMEA), fault tree analysis, or Pareto analysis. [ENUM-REF-CANDIDATE: 5_why|ishikawa|8d|fmea|fault_tree|pareto|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'The identifier of the originating document or record that triggered this CAPA, such as an NCR number, audit finding reference, customer complaint ticket number, or SAP QM notification number. Enables traceability back to the triggering event.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Category of the triggering event that initiated the CAPA. Indicates whether the CAPA originated from a Non-Conformance Report (NCR), customer complaint, internal or external audit finding, shop floor quality event, supplier quality issue, or regulatory inspection finding. [ENUM-REF-CANDIDATE: ncr|customer_complaint|audit_finding|internal_quality_event|supplier_issue|regulatory_finding|field_failure|warranty_claim — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionPriority rdf:type rdf:Property ;
    rdfs:label 'Action Priority' ;
    rdfs:comment 'AIAG-VDA Action Priority classification (High, Medium, Low) assigned to the failure mode based on the combination of Severity, Occurrence, and Detection ratings. Replaces the legacy RPN-only prioritization approach introduced in the 2019 AIAG-VDA FMEA Handbook. Core AIAG-VDA Step 7 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Description of the actual corrective or preventive action implemented to address the failure mode. Documents what was done versus what was recommended, enabling traceability for PPAP and audit purposes. Core AIAG-VDA Step 9 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date on which the recommended action was actually implemented and verified as complete. Compared against target_completion_date to measure action closure timeliness. Formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentDetectionControls rdf:type rdf:Property ;
    rdfs:label 'Current Detection Controls' ;
    rdfs:comment 'Description of existing design verification or process monitoring controls that detect the failure mode or cause before the product reaches the customer. Examples include inspection plans, SPC monitoring, functional testing, and CMM measurement. Core AIAG-VDA Step 7 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPreventionControls rdf:type rdf:Property ;
    rdfs:label 'Current Prevention Controls' ;
    rdfs:comment 'Description of existing design or process controls that prevent the failure cause from occurring or reduce the occurrence rate. Examples include design standards, material specifications, process parameters, and mistake-proofing (poka-yoke) devices. Core AIAG-VDA Step 6 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCause rdf:type rdf:Property ;
    rdfs:label 'Failure Cause' ;
    rdfs:comment 'Root cause or mechanism that leads to the failure mode. Describes the specific design weakness, process deficiency, or material condition that initiates the failure (e.g., \'insufficient weld penetration\', \'incorrect torque specification\'). Core AIAG-VDA Step 4 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureEffect rdf:type rdf:Property ;
    rdfs:label 'Failure Effect' ;
    rdfs:comment 'Description of the consequence of the failure mode on the customer, end user, or downstream process. Defines what the customer experiences when the failure occurs (e.g., \'loss of function\', \'noise\', \'injury risk\'). Core AIAG-VDA Step 4 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'The specific manner in which the item, component, or process step could potentially fail to perform its intended function. Represents the physical or chemical description of the failure (e.g., \'fracture\', \'short circuit\', \'dimensional out-of-tolerance\'). Core AIAG-VDA Step 4 field.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaNumber rdf:type rdf:Property ;
    rdfs:label 'Fmea Number' ;
    rdfs:comment 'Externally-known, human-readable document control number assigned to the FMEA record in Siemens Teamcenter PLM. Used for cross-referencing in engineering change orders (ECOs), PPAP packages, and APQP deliverables.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaScope rdf:type rdf:Property ;
    rdfs:label 'Fmea Scope' ;
    rdfs:comment 'Description of the boundaries and scope of the FMEA analysis, including what is included and excluded from the analysis. Defines the system boundary, interfaces, and assumptions. Required for AIAG-VDA Step 2 (Structure Analysis).' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaStatus rdf:type rdf:Property ;
    rdfs:label 'Fmea Status' ;
    rdfs:comment 'Current lifecycle state of the FMEA document within the Siemens Teamcenter PLM workflow. Controls whether the FMEA is editable, under review, formally released for production use, or retired.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaType rdf:type rdf:Property ;
    rdfs:label 'Fmea Type' ;
    rdfs:comment 'Classification of the FMEA by analysis scope: DFMEA (Design FMEA) evaluates design-related failure modes; PFMEA (Process FMEA) evaluates manufacturing process failure modes; SFMEA (System FMEA) evaluates system-level interactions; MFMEA (Machinery FMEA) evaluates equipment failure modes. Aligned with AIAG-VDA methodology.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionDescription rdf:type rdf:Property ;
    rdfs:label 'Function Description' ;
    rdfs:comment 'Description of the intended function or purpose of the item, component, or process step being analyzed. Defines what the element is supposed to do under normal operating conditions. Core AIAG-VDA Step 3 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Name or description of the specific manufacturing process step or operation being analyzed in a PFMEA (e.g., \'Welding Station 3\', \'CNC Milling Op 20\'). Derived from the process routing in SAP S/4HANA PP or Siemens Opcenter MES.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Proposed corrective or preventive action to reduce the severity, occurrence, or detection rating of the failure mode. Drives CAPA initiation and engineering change orders (ECOs). Core AIAG-VDA Step 8 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether the failure mode is associated with a regulatory compliance requirement (e.g., CE Marking, UL certification, EPA, OSHA). Failure modes with this flag require documented evidence of control effectiveness in regulatory submissions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedActionPriority rdf:type rdf:Property ;
    rdfs:label 'Revised Action Priority' ;
    rdfs:comment 'Updated AIAG-VDA Action Priority (High, Medium, Low) recalculated after implementation of the recommended action. Confirms whether the residual risk level is acceptable or requires further action.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedDetectionRating rdf:type rdf:Property ;
    rdfs:label 'Revised Detection Rating' ;
    rdfs:comment 'Updated detection rating (1–10) after implementation of the recommended action. Reflects improved detection capability resulting from new controls, inspection methods, or monitoring systems. Core AIAG-VDA Step 9 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedOccurrenceRating rdf:type rdf:Property ;
    rdfs:label 'Revised Occurrence Rating' ;
    rdfs:comment 'Updated occurrence rating (1–10) after implementation of the recommended action. Reflects the reduced likelihood of the failure cause occurring following corrective action. Core AIAG-VDA Step 9 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedRpn rdf:type rdf:Property ;
    rdfs:label 'Revised Rpn' ;
    rdfs:comment 'Recalculated Risk Priority Number (Revised S × Revised O × Revised D) after implementation of the recommended action. Used to verify that the corrective action achieved the desired risk reduction. Core AIAG-VDA Step 9 field.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Revised Severity Rating' ;
    rdfs:comment 'Updated severity rating (1–10) after implementation of the recommended action. Severity typically does not change unless a design change eliminates the failure effect. Core AIAG-VDA Step 9 field for post-action re-evaluation.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revision rdf:type rdf:Property ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Document revision identifier (e.g., A, B, C, 01, 02) tracking the version history of the FMEA in Siemens Teamcenter PLM. Incremented upon each approved change to the FMEA content.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rpn rdf:type rdf:Property ;
    rdfs:label 'Rpn' ;
    rdfs:comment 'Risk Priority Number calculated as the product of Severity × Occurrence × Detection ratings (S × O × D). Ranges from 1 to 1000. Used to prioritize failure modes for corrective action. Higher RPN indicates greater risk requiring immediate attention. Stored as a business-critical field per AIAG-VDA methodology.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether the failure mode has a safety-critical or regulatory compliance impact (severity rating 9 or 10). Safety-critical failure modes require mandatory escalation, special controls, and PPAP documentation. Aligned with OSHA and CE Marking requirements.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialCharacteristicCode rdf:type rdf:Property ;
    rdfs:label 'Special Characteristic Code' ;
    rdfs:comment 'Designation indicating whether the failure mode relates to a special product or process characteristic requiring enhanced control. SC = Special Characteristic; CC = Critical Characteristic; KPC = Key Product Characteristic; KCC = Key Control Characteristic. Drives control plan and inspection plan requirements.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the recommended action must be implemented and verified. Used for action tracking and escalation management in the FMEA review cycle. Formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list or description of cross-functional team members who participated in the FMEA analysis session. Typically includes representatives from design engineering, manufacturing, quality, and supplier quality. Required for AIAG-VDA Step 1 documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPlanId rdf:type rdf:Property ;
    rdfs:label 'Control Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the control plan record in the lakehouse silver layer. Primary key.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlPlan .

ind:characteristicClass rdf:type rdf:Property ;
    rdfs:label 'Characteristic Class' ;
    rdfs:comment 'Classification of the quality characteristic by its impact on safety, regulatory compliance, or fit/function. Critical (safety/regulatory impact), Significant (functional impact), Major (customer-noticeable), Minor (cosmetic). Drives inspection frequency and reaction plan severity.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicName rdf:type rdf:Property ;
    rdfs:label 'Characteristic Name' ;
    rdfs:comment 'Name or description of the quality characteristic being controlled (e.g., \'Weld Bead Width\', \'Torque Value\', \'Surface Roughness Ra\'). Directly corresponds to the CTQ characteristic defined in the PFMEA.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicNumber rdf:type rdf:Property ;
    rdfs:label 'Characteristic Number' ;
    rdfs:comment 'Sequential number identifying the specific quality characteristic within the process step of this control plan row. Enables precise referencing of individual CTQ (Critical-to-Quality) characteristics.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicType rdf:type rdf:Property ;
    rdfs:label 'Characteristic Type' ;
    rdfs:comment 'Indicates whether the characteristic is measured on a variable (continuous numeric) or attribute (pass/fail, go/no-go) scale. Determines the applicable SPC (Statistical Process Control) methodology and control chart type.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMethod rdf:type rdf:Property ;
    rdfs:label 'Control Method' ;
    rdfs:comment 'The process control technique applied to monitor and control this characteristic (e.g., \'SPC X-bar/R Chart\', \'Pre-control Chart\', \'Poka-yoke\', \'Visual Standard\', \'Attribute Control Chart\', \'Process Parameter Monitoring\'). Core APQP deliverable field.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Indicates whether the control is a prevention control (prevents the defect from occurring) or a detection control (detects the defect after it has occurred). Aligns with PFMEA prevention/detection control columns.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpkMinimumRequired rdf:type rdf:Property ;
    rdfs:label 'Cpk Minimum Required' ;
    rdfs:comment 'The minimum acceptable Cpk (Process Capability Index) value required for this characteristic to be considered capable. Typically 1.33 for production and 1.67 for critical/safety characteristics per AIAG PPAP requirements.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorProofingMethod rdf:type rdf:Property ;
    rdfs:label 'Error Proofing Method' ;
    rdfs:comment 'Description of the poka-yoke or error-proofing device/method applied at this process step to prevent or detect non-conformances (e.g., \'Torque monitoring with automatic shutdown\', \'Vision system barcode verification\', \'Fixture limit switch\'). Reduces reliance on operator inspection.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeType rdf:type rdf:Property ;
    rdfs:label 'Gauge Type' ;
    rdfs:comment 'Type or category of measurement instrument or gauge used for this characteristic (e.g., \'Vernier Caliper\', \'CMM\', \'Go/No-Go Gauge\', \'Torque Tester\', \'Vision System\'). Used for gauge calibration scheduling and MSA planning.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCtq rdf:type rdf:Property ;
    rdfs:label 'Is Ctq' ;
    rdfs:comment 'Indicates whether this characteristic is designated as Critical-to-Quality (CTQ), meaning it directly impacts customer satisfaction, safety, or regulatory compliance. CTQ characteristics receive enhanced monitoring and are mandatory in PPAP submissions.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Requirement' ;
    rdfs:comment 'Indicates whether this characteristic is controlled to meet a specific regulatory or certification requirement (e.g., CE Marking, UL, IEC 62443, EPA, OSHA). Drives mandatory retention of inspection records for regulatory audit purposes.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Is Safety Characteristic' ;
    rdfs:comment 'Indicates whether this characteristic is classified as a safety-critical characteristic (SC) per customer-specific requirements or regulatory mandates. Safety characteristics require 100% inspection or validated error-proofing (poka-yoke) and special PPAP documentation.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Description of the measurement technique or method used to evaluate the characteristic (e.g., \'CMM dimensional measurement\', \'Torque wrench with digital readout\', \'Visual inspection per drawing\'). Supports Measurement System Analysis (MSA) traceability.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepName rdf:type rdf:Property ;
    rdfs:label 'Process Step Name' ;
    rdfs:comment 'Descriptive name of the manufacturing process step or operation (e.g., \'Welding\', \'CNC Machining\', \'Final Assembly Inspection\'). Provides human-readable context for the control being defined.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepNumber rdf:type rdf:Property ;
    rdfs:label 'Process Step Number' ;
    rdfs:comment 'Sequential identifier for the manufacturing process step or operation within the control plan (e.g., 10, 20, 30). Aligns with the process flow diagram and PFMEA step numbering per AIAG standards.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionPlan rdf:type rdf:Property ;
    rdfs:label 'Reaction Plan' ;
    rdfs:comment 'Prescribed corrective actions to be taken when the process goes out of control or a non-conformance is detected for this characteristic (e.g., \'Stop production, quarantine last 2 hours output, notify quality engineer, initiate NCR\'). Mandatory APQP control plan field.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleFrequency rdf:type rdf:Property ;
    rdfs:label 'Sample Frequency' ;
    rdfs:comment 'Frequency or trigger condition for performing the inspection (e.g., \'Every 2 hours\', \'Every 50 pieces\', \'First-off and last-off\', \'Each lot\', \'100% inspection\'). Defines the inspection cadence on the shop floor.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerComplaintId rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Id' ;
    rdfs:comment 'Unique system-generated identifier for the customer complaint record. Primary key for this entity.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesOrderIntakeId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Intake Id' ;
    rdfs:comment 'Foreign key linking to sales.order_intake. Business justification: Complaints are investigated against the exact order intake that generated the sale, supporting root-cause analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderIntake .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date on which the complaint was formally closed following customer acceptance of the resolution and verification of corrective action effectiveness.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Full narrative description of the customer complaint including observed symptoms, conditions of failure, and customer-reported impact. Corresponds to SAP QM QN Problem Description field.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Externally-visible, human-readable complaint reference number used in customer communications and SAP QM Quality Notification (QN). Format: CC-YYYY-NNNNNN.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSource rdf:type rdf:Property ;
    rdfs:label 'Complaint Source' ;
    rdfs:comment 'Origin channel or party type from which the complaint was received. Supports segmentation of complaint volumes by customer tier.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current workflow state of the complaint record. Drives escalation, SLA tracking, and reporting. \'pending_customer\' indicates awaiting customer feedback or approval.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintTitle rdf:type rdf:Property ;
    rdfs:label 'Complaint Title' ;
    rdfs:comment 'Short, human-readable summary title of the complaint as entered by the quality engineer or service representative. Used in dashboards and notification emails.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Categorization of the complaint by nature of the issue. Used for trend analysis, routing, and regulatory reporting. [ENUM-REF-CANDIDATE: product_defect|field_failure|delivery_issue|documentation_error|safety_concern|performance_deviation — promote to reference product]' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentDate rdf:type rdf:Property ;
    rdfs:label 'Containment Date' ;
    rdfs:comment 'Date on which the containment action was implemented. Used to measure response speed and SLA compliance for initial containment.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Date' ;
    rdfs:comment 'Actual date on which the permanent corrective action was fully implemented and verified effective.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Description of the permanent corrective action selected and implemented to eliminate the root cause, corresponding to 8D Steps D5 (select) and D6 (implement). May trigger an Engineering Change Order (ECO) or Engineering Change Notice (ECN).' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which the permanent corrective action must be implemented and verified. Used for SLA tracking and escalation management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Status' ;
    rdfs:comment 'Status of the customer\'s acceptance of the proposed resolution or 8D corrective action response. Determines whether the complaint can be formally closed.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Order Number' ;
    rdfs:comment 'SAP SD sales order number associated with the delivery of the affected product. Links complaint to order fulfillment and revenue impact analysis.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Date' ;
    rdfs:comment 'Date on which the formal response (e.g., 8D report, corrective action plan) was communicated to the customer. Used for SLA compliance measurement.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this complaint must be reported to a regulatory authority (e.g., OSHA, EPA, UL, CE Marking body). Triggers compliance workflow and documentation requirements.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyRelated rdf:type rdf:Property ;
    rdfs:label 'Is Safety Related' ;
    rdfs:comment 'Indicates whether the complaint involves a potential safety hazard to personnel or end users. Triggers mandatory escalation to product safety and regulatory teams per OSHA and CE Marking requirements.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Description of systemic preventive actions taken to prevent recurrence of similar complaints across other products or processes, corresponding to 8D Step D7.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityComplained rdf:type rdf:Property ;
    rdfs:label 'Quantity Complained' ;
    rdfs:comment 'Number of units reported as defective or non-conforming in the complaint. Used for severity assessment and potential recall scope estimation.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'Number of units physically returned by the customer under a Return Material Authorization (RMA). May differ from quantity complained if partial returns occur.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise date and time when the complaint was received and logged in the system. Used for SLA response-time measurement.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Type of resolution provided to the customer. Drives financial impact tracking (credit notes, replacements) and customer satisfaction measurement.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Salesforce Case Number' ;
    rdfs:comment 'Cross-reference identifier from Salesforce Service Cloud case record linked to this complaint, enabling traceability between CRM and quality management systems.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQnNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Qn Number' ;
    rdfs:comment 'SAP QM Quality Notification number corresponding to this complaint, used for traceability within SAP S/4HANA QM module.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Severity classification of the complaint based on customer impact, safety risk, and regulatory implications. Drives escalation rules and response SLA targets. Aligned with FMEA severity ranking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyId rdf:type rdf:Property ;
    rdfs:label 'Family Id' ;
    rdfs:comment 'Foreign key linking to product.family. Business justification: Quality audits in industrial manufacturing are frequently scoped to a product family (e.g., ISO 9001 audit of the entire drives product family, or IATF audit of automation systems). audit_scope on qua' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:previousAuditQualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Quality Audit Id' ;
    rdfs:comment 'Reference to the previous audit of the same entity, enabling audit history tracking and trend analysis.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityAudit .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the audit was completed, including closing meeting and final observations.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCategory rdf:type rdf:Property ;
    rdfs:label 'Audit Category' ;
    rdfs:comment 'Categorization of the audit by the relationship to the audited party: internal (own departments/processes), external supplier (supplier facilities), external subcontractor (subcontractor sites), external customer (customer-mandated), certification (third-party certification body), surveillance (ongoing certification monitoring), or special (triggered by incident or complaint). [ENUM-REF-CANDIDATE: internal|external_supplier|external_subcontractor|external_customer|certification|surveillance|special — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditMethod rdf:type rdf:Property ;
    rdfs:label 'Audit Method' ;
    rdfs:comment 'The method by which the audit is conducted: on-site (physical presence at audited location), remote (virtual audit via video/document sharing), hybrid (combination of on-site and remote), or document review (desk audit of documentation only).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Business identifier for the audit, externally visible and used for tracking and reference across systems and documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'Overall result or conclusion of the audit: conforming (no major issues), non-conforming (major issues found), conditional pass (minor issues requiring follow-up), fail (critical issues), acceptable, or unacceptable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including the processes, departments, product lines, or ISO clauses covered. Defines the boundaries and focus areas of the audit.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit: planned (in audit program), scheduled (dates confirmed), in progress (audit underway), report draft (findings being documented), report issued (formal report distributed), CAPA pending (corrective actions awaited), CAPA verification (actions being verified), closed (audit complete and verified), or cancelled. [ENUM-REF-CANDIDATE: planned|scheduled|in_progress|report_draft|report_issued|capa_pending|capa_verification|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit by its focus area: system audit (QMS compliance), process audit (manufacturing process conformance per VDA 6.3), product audit (finished goods verification), layered process audit (LPA short-interval checks), supplier audit (external provider assessment), or customer audit (customer-mandated assessment).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedEntityCountry rdf:type rdf:Property ;
    rdfs:label 'Audited Entity Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the audited entity location.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedEntityType rdf:type rdf:Property ;
    rdfs:label 'Audited Entity Type' ;
    rdfs:comment 'Type of entity being audited: internal department, supplier facility, subcontractor site, customer site, manufacturing plant, warehouse, or laboratory. [ENUM-REF-CANDIDATE: internal_department|supplier|subcontractor|customer_site|manufacturing_plant|warehouse|laboratory — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeContactEmail rdf:type rdf:Property ;
    rdfs:label 'Auditee Contact Email' ;
    rdfs:comment 'Email address of the auditee contact for audit coordination and communication.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeContactName rdf:type rdf:Property ;
    rdfs:label 'Auditee Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the audited entity responsible for coordinating the audit and providing access to information.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorIndependenceVerified rdf:type rdf:Property ;
    rdfs:label 'Auditor Independence Verified' ;
    rdfs:comment 'Flag indicating whether auditor independence and impartiality have been verified per ISO 19011 requirements, ensuring no conflict of interest.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capaRequired rdf:type rdf:Property ;
    rdfs:label 'Capa Required' ;
    rdfs:comment 'Flag indicating whether corrective and preventive actions are required based on the audit findings.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conformingItemsCount rdf:type rdf:Property ;
    rdfs:label 'Conforming Items Count' ;
    rdfs:comment 'Number of checklist items found to be in full conformance with the audit criteria.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total duration of the audit in days, calculated from actual start to actual end date.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceCollected rdf:type rdf:Property ;
    rdfs:label 'Evidence Collected' ;
    rdfs:comment 'Description or reference to the objective evidence collected during the audit, such as documents reviewed, records examined, interviews conducted, and observations made.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor for quick reference and reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorQualification rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Qualification' ;
    rdfs:comment 'Certification or qualification held by the lead auditor, such as ISO 9001 Lead Auditor, VDA 6.3 Process Auditor, or internal auditor certification.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNcrCount rdf:type rdf:Property ;
    rdfs:label 'Major Ncr Count' ;
    rdfs:comment 'Number of major non-conformances identified during the audit. Major NCRs represent significant deviations that affect the QMS effectiveness or product quality.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNcrCount rdf:type rdf:Property ;
    rdfs:label 'Minor Ncr Count' ;
    rdfs:comment 'Number of minor non-conformances identified during the audit. Minor NCRs represent isolated or less significant deviations that do not critically impact the QMS.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Statement of the audit\'s purpose and intended outcomes, such as QMS conformance verification, process effectiveness assessment, supplier qualification, or compliance validation.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Number of observations or opportunities for improvement noted during the audit that do not constitute non-conformances but warrant attention.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled end date for the audit as defined in the audit program or audit plan.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Re Audit Required' ;
    rdfs:comment 'Flag indicating whether a follow-up re-audit is required to verify the effectiveness of corrective actions or to address major non-conformances.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Re Audit Scheduled Date' ;
    rdfs:comment 'Scheduled date for the follow-up re-audit to verify corrective action effectiveness.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Document management system reference or file path to the formal audit report document.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date when the formal audit report was issued and distributed to relevant stakeholders.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numerical score or rating assigned to the audit based on conformance level, typically expressed as a percentage or on a defined scale (e.g., VDA 6.3 scoring).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standard rdf:type rdf:Property ;
    rdfs:label 'Standard' ;
    rdfs:comment 'The quality standard or framework against which the audit is conducted, such as ISO 9001:2015, IATF 16949, VDA 6.3, AS9100, ISO 13485, or customer-specific requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Reference to the parent warehouse or facility where this storage location resides. Links to the facility master for site-level aggregation and reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC classification of the storage location based on inventory velocity and value. A-class locations store high-velocity or high-value items in the most accessible zones. B-class locations store medium-velocity items. C-class locations store slow-moving items in less accessible areas. Used for warehouse slotting optimization and space allocation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Access Equipment Required' ;
    rdfs:comment 'Type of material handling equipment required to access this storage location. Determines labor and equipment resource planning for put-away and picking operations. Influences cycle time calculations and warehouse operational efficiency metrics (OEE). [ENUM-REF-CANDIDATE: none|forklift|reach_truck|order_picker|crane|agv|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleNumber rdf:type rdf:Property ;
    rdfs:label 'Aisle Number' ;
    rdfs:comment 'Aisle identifier within the warehouse zone. Aisles are the primary navigation paths for material handlers and automated guided vehicles (AGVs). Used for directed put-away and optimized picking routes.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binPosition rdf:type rdf:Property ;
    rdfs:label 'Bin Position' ;
    rdfs:comment 'Horizontal bin position within the shelf level. Represents the finest granularity of storage location addressing. Used for precise material placement and retrieval in high-density storage environments.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Capacity Pallet Positions' ;
    rdfs:comment 'Number of standard pallet positions that can be stored in this location. Used for pallet storage locations to calculate available capacity and optimize warehouse space utilization. Assumes standard pallet dimensions (e.g., 1200mm x 1000mm EUR pallet or 1219mm x 1016mm North American pallet).' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume M3' ;
    rdfs:comment 'Maximum volumetric capacity of the storage location measured in cubic meters. Used for space utilization analysis, slotting optimization, and warehouse capacity planning. Constrains the physical size of materials that can be stored in this location.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location measured in kilograms. Enforces structural load limits for racks and shelves. Critical for safety compliance and preventing equipment damage. Used in slotting algorithms to match heavy materials with appropriate locations.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when this storage location record was initially created in the warehouse management system. Used for master data audit trails, location lifecycle tracking, and warehouse expansion analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Frequency at which this storage location is scheduled for cycle counting inventory verification. High-value or high-velocity locations typically have higher cycle count frequencies. Used to generate cycle count schedules and ensure inventory accuracy per ISO 9001 quality management requirements.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when this storage location was deactivated or retired from operational use. Deactivated locations are no longer available for material placement but may retain historical inventory transaction data. Used for warehouse reconfiguration tracking and capacity planning analysis.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fifoEnforced rdf:type rdf:Property ;
    rdfs:label 'Fifo Enforced' ;
    rdfs:comment 'Boolean flag indicating whether this location enforces First In First Out (FIFO) inventory rotation. FIFO ensures older materials are consumed before newer materials, critical for perishable goods, time-sensitive components, and materials with shelf-life constraints. Used by warehouse management systems (WMS) to generate FIFO-compliant pick instructions.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireZone rdf:type rdf:Property ;
    rdfs:label 'Fire Zone' ;
    rdfs:comment 'Fire safety zone identifier for this storage location. Fire zones group locations by fire suppression system coverage and emergency response protocols. Critical for safety compliance, emergency planning, and hazardous material segregation per OSHA and NFPA standards.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityControlled rdf:type rdf:Property ;
    rdfs:label 'Humidity Controlled' ;
    rdfs:comment 'Boolean flag indicating whether this location maintains controlled humidity levels. Humidity control is critical for materials susceptible to moisture damage, corrosion, or degradation such as electronics, metal components, and hygroscopic materials.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humidityMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Max Percent' ;
    rdfs:comment 'Maximum allowable relative humidity percentage for this storage location. Enforces upper humidity boundary to prevent condensation, corrosion, or mold growth. Typically ranges from 50% to 70% for general storage, lower for electronics.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityMinPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Min Percent' ;
    rdfs:comment 'Minimum allowable relative humidity percentage for this storage location. Enforces lower humidity boundary to prevent static electricity buildup or material desiccation. Typically ranges from 20% to 40% for electronics and sensitive components.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Approved' ;
    rdfs:comment 'Boolean flag indicating whether this location is certified and approved for storing hazardous materials. Hazmat-approved locations must meet specific safety, ventilation, containment, and regulatory requirements per OSHA and EPA standards. Used to enforce material placement rules for dangerous goods.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPickingLocation rdf:type rdf:Property ;
    rdfs:label 'Is Picking Location' ;
    rdfs:comment 'Boolean flag indicating whether this location is designated as a primary picking location for order fulfillment. Picking locations are typically positioned in ergonomic zones with high accessibility and are replenished from reserve locations. Used by warehouse management systems (WMS) to optimize pick path generation.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReplenishmentLocation rdf:type rdf:Property ;
    rdfs:label 'Is Replenishment Location' ;
    rdfs:comment 'Boolean flag indicating whether this location serves as a reserve or bulk storage location that feeds picking locations through replenishment processes. Replenishment locations typically have higher capacity and lower accessibility than picking locations.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the most recent cycle count was performed for this storage location. Used to track cycle count compliance, identify overdue counts, and calculate inventory accuracy metrics. Critical for maintaining inventory integrity and meeting audit requirements.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the storage location within the warehouse. Used for barcode scanning, pick lists, and warehouse management system (WMS) transactions. Typically follows a structured format combining zone, aisle, rack, shelf, and bin identifiers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotControlRequired rdf:type rdf:Property ;
    rdfs:label 'Lot Control Required' ;
    rdfs:comment 'Boolean flag indicating whether materials stored in this location must be tracked by lot or batch number. Lot control is mandatory for materials subject to traceability requirements, expiration date management, or quality recall procedures per ISO 9001 and industry-specific regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixedSkuAllowed rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed' ;
    rdfs:comment 'Boolean flag indicating whether this location can store multiple different SKUs simultaneously. Single-SKU locations simplify picking and inventory accuracy but reduce space utilization. Mixed-SKU locations increase storage density but require more sophisticated inventory tracking and picking processes.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Date when this storage location record was last modified. Tracks changes to location attributes such as capacity, status, or environmental requirements. Used for change management, audit compliance, and data quality monitoring.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pickSequence rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence' ;
    rdfs:comment 'Numeric sequence number used to optimize picking routes within the warehouse. Lower numbers indicate locations that should be visited earlier in the pick path. Used by warehouse management systems (WMS) to generate efficient pick lists and minimize travel distance for order fulfillment.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rackNumber rdf:type rdf:Property ;
    rdfs:label 'Rack Number' ;
    rdfs:comment 'Rack or bay identifier within the aisle. Racks are vertical storage structures containing multiple shelf levels. Critical for coordinate-based bin addressing and warehouse layout optimization.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Security classification level for this storage location. Determines access control requirements, surveillance coverage, and material handling authorization levels. High-security locations store valuable materials, controlled substances, or proprietary components requiring enhanced protection.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLevel rdf:type rdf:Property ;
    rdfs:label 'Shelf Level' ;
    rdfs:comment 'Vertical shelf or tier position within the rack (e.g., 1, 2, 3 or A, B, C). Shelf level determines accessibility, ergonomics, and suitability for different material handling equipment. Lower shelves typically used for high-velocity or heavy items.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Boolean flag indicating whether this location is within a temperature-controlled environment. Temperature-controlled locations are required for materials sensitive to heat, cold, or humidity such as chemicals, electronics, pharmaceuticals, and certain raw materials.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum allowable temperature for this storage location measured in degrees Celsius. Enforces upper temperature boundary for temperature-sensitive materials. Exceeding this threshold may trigger quality alerts and material quarantine procedures.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum allowable temperature for this storage location measured in degrees Celsius. Enforces lower temperature boundary for temperature-sensitive materials. Used in conjunction with maximum temperature to define the acceptable storage environment range.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:xCoordinate rdf:type rdf:Property ;
    rdfs:label 'X Coordinate' ;
    rdfs:comment 'Horizontal X-axis coordinate of the storage location within the warehouse floor plan. Used for warehouse mapping, route optimization, and integration with warehouse automation systems and AGVs. Measured in meters or feet from a defined origin point.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yCoordinate rdf:type rdf:Property ;
    rdfs:label 'Y Coordinate' ;
    rdfs:comment 'Horizontal Y-axis coordinate of the storage location within the warehouse floor plan. Used in conjunction with X coordinate for precise location mapping and automated material handling system navigation.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zCoordinate rdf:type rdf:Property ;
    rdfs:label 'Z Coordinate' ;
    rdfs:comment 'Vertical Z-axis coordinate representing the height of the storage location above the warehouse floor. Critical for automated storage and retrieval systems (AS/RS) and crane operations. Measured in meters or feet.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'High-level zone identifier within the warehouse (e.g., A, B, C or NORTH, SOUTH). Zones group locations by physical area, product category, or operational function to optimize picking routes and material flow.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when the warehouse facility became operational and available for inventory storage. Marks the start of the facility lifecycle.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'Date when the warehouse facility ceased operations or was decommissioned. Null for currently active facilities. Used for historical reporting and capacity planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the warehouse facility. First line of the physical location address.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as building number, suite, or floor. Optional additional address detail.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedStorageFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Storage Flag' ;
    rdfs:comment 'Indicates whether the warehouse uses automated storage and retrieval systems (AS/RS). Impacts throughput rates, labor requirements, and integration with WMS and MES.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:climateControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Climate Controlled Flag' ;
    rdfs:comment 'Indicates whether the warehouse has climate control capabilities for temperature and humidity-sensitive materials. Critical for pharmaceutical, electronic component, and chemical storage compliance.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for warehouse operational communication. Used for shipment notifications, inventory alerts, and administrative correspondence.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary contact phone number for the warehouse facility. Used for carrier coordination, emergency contact, and operational communication.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBondedFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Flag' ;
    rdfs:comment 'Indicates whether the warehouse is a customs-bonded facility authorized to store imported goods before duty payment. Critical for international supply chain and duty deferral strategies.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the warehouse based on the primary type of inventory stored. Determines storage requirements, handling procedures, and integration with MRP and MES systems.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionSystemType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System Type' ;
    rdfs:comment 'Type of fire suppression system installed in the warehouse. Critical for insurance, safety compliance, and determining storage eligibility for flammable materials.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the warehouse is certified to store hazardous materials. Determines eligibility for storing chemicals, flammables, and regulated substances per OSHA and EPA requirements.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatStorageClasses rdf:type rdf:Property ;
    rdfs:label 'Hazmat Storage Classes' ;
    rdfs:comment 'Comma-separated list of hazardous material storage classes the warehouse is certified to handle (e.g., Class 3 Flammable Liquids, Class 8 Corrosives). Based on UN hazard classification system.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified Flag' ;
    rdfs:comment 'Indicates whether the warehouse facility holds ISO 14001 environmental management system certification. Demonstrates commitment to environmental sustainability and regulatory compliance.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the warehouse facility holds ISO 9001 quality management system certification. Impacts supplier qualification and customer audit requirements.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the warehouse lease agreement expires. Null for owned facilities. Used for facility planning and contract renewal management.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfLoadingDocks rdf:type rdf:Property ;
    rdfs:label 'Number Of Loading Docks' ;
    rdfs:comment 'Total count of loading and unloading dock positions. Determines receiving and shipping throughput capacity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfStorageBins rdf:type rdf:Property ;
    rdfs:label 'Number Of Storage Bins' ;
    rdfs:comment 'Total count of discrete storage bin locations within the warehouse. Used for bin location management and inventory tracking granularity in SAP WM.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHoursDescription rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Description' ;
    rdfs:comment 'Textual description of standard operating hours and shift patterns (e.g., 24/7, Monday-Friday 8am-5pm, Three-shift operation). Used for carrier scheduling and labor planning.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Classification of warehouse ownership model. Determines financial accounting treatment, CapEx vs OpEx allocation, and operational control level.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Identifier of the source system that created or owns this warehouse master record (e.g., SAP_S4HANA, DYNAMICS_365_SCM, MDM). Used for data lineage and system-of-record identification.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageAreaSquareMeters rdf:type rdf:Property ;
    rdfs:label 'Storage Area Square Meters' ;
    rdfs:comment 'Floor area dedicated to inventory storage in square meters. Excludes receiving docks, shipping areas, and administrative space.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum temperature that can be maintained in climate-controlled zones, measured in Celsius. Used for material storage requirement validation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum temperature that can be maintained in climate-controlled zones, measured in Celsius. Used for material storage requirement validation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Cubic Meters' ;
    rdfs:comment 'Total storage capacity of the warehouse measured in cubic meters. Represents maximum volumetric storage capability for inventory planning and capacity utilization analysis.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFloorAreaSquareMeters rdf:type rdf:Property ;
    rdfs:label 'Total Floor Area Square Meters' ;
    rdfs:comment 'Total floor area of the warehouse facility in square meters. Includes storage, receiving, shipping, and administrative areas.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usableCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Usable Capacity Cubic Meters' ;
    rdfs:comment 'Actual usable storage capacity after accounting for aisles, equipment, and operational space. Used for realistic inventory allocation and safety stock calculations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the warehouse facility. Used in SAP WM and Microsoft Dynamics 365 SCM for warehouse identification and cross-system integration.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseName rdf:type rdf:Property ;
    rdfs:label 'Warehouse Name' ;
    rdfs:comment 'Full business name of the warehouse facility. Human-readable identifier used in operational documentation and reporting.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Wms System Code' ;
    rdfs:comment 'Code identifying the WMS system deployed at this warehouse (e.g., SAP_WM, DYNAMICS_365_SCM, MANHATTAN). Used for system integration routing and data synchronization.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantDataId rdf:type rdf:Property ;
    rdfs:label 'Plant Data Id' ;
    rdfs:comment 'Foreign key linking to product.plant_data. Business justification: In industrial manufacturing ERP (SAP-style), material_master and plant_data are the general and plant-specific views of the same master data object. Direct FK enables procurement, MRP, and inventory t' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlantData .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'ABC classification for inventory management prioritization. A items are high-value requiring tight control, B items are moderate-value, C items are low-value with relaxed controls. Used for cycle counting frequency and safety stock strategies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Primary unit in which the material is managed in inventory and production. Examples: EA (each), KG (kilogram), L (liter), M (meter). All stock quantities are maintained in this unit.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Batch Management Indicator' ;
    rdfs:comment 'Flag indicating whether the material requires batch or lot tracking. When active, all inventory transactions must reference a batch number for full traceability and quality control.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dimensionUnit rdf:type rdf:Property ;
    rdfs:label 'Dimension Unit' ;
    rdfs:comment 'Unit of measure for length, width, and height dimensions. Examples: MM (millimeter), CM (centimeter), M (meter), IN (inch).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptProcessingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Processing Time Days' ;
    rdfs:comment 'Time required for quality inspection and goods receipt posting after physical delivery. Added to planned delivery time for total procurement lead time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the material including all packaging. Used for logistics planning, freight calculation, and warehouse capacity management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'Classification of hazardous material type per UN/DOT regulations. Examples: flammable liquid, corrosive, toxic, oxidizer. Determines packaging, labeling, and shipping requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Flag indicating whether the material is classified as hazardous. Triggers additional safety, handling, storage, and transportation requirements per OSHA and EPA regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:height rdf:type rdf:Property ;
    rdfs:label 'Height' ;
    rdfs:comment 'Height dimension of the material. Used for storage bin assignment, handling equipment selection, and transportation planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionSetupIndicator rdf:type rdf:Property ;
    rdfs:label 'Inspection Setup Indicator' ;
    rdfs:comment 'Flag indicating whether incoming goods require quality inspection before stock placement. Triggers QM (Quality Management) inspection lot creation at goods receipt.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID of the person who last modified the material master record. Used for audit trail and data governance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the material master record was last changed. Used for audit trail and change management tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:length rdf:type rdf:Property ;
    rdfs:label 'Length' ;
    rdfs:comment 'Length dimension of the material. Used for storage bin assignment, handling equipment selection, and transportation planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Lot-sizing procedure code determining how procurement or production quantities are calculated. Examples: EX (exact order quantity), FX (fixed lot size), HB (lot-for-lot).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Hierarchical classification code grouping materials with similar characteristics for procurement, planning, and reporting purposes. Used in MRP (Material Requirements Planning) and purchasing strategies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Unique business identifier for the material assigned by the enterprise. This is the externally-known SKU (Stock Keeping Unit) code used across all systems and documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material master record. Controls whether the material can be procured, produced, or sold. Blocked materials cannot be used in new transactions.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the material based on its role in the manufacturing and supply chain process. Determines procurement, production, and inventory management rules. [ENUM-REF-CANDIDATE: raw_material|semi_finished|finished_good|trading_good|spare_part|consumable|packaging_material|service — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLotSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Lot Size' ;
    rdfs:comment 'Maximum quantity that can be ordered or produced in a single transaction. Constrained by storage capacity, shelf life, or supplier limitations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLotSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Lot Size' ;
    rdfs:comment 'Minimum quantity that must be ordered or produced in a single transaction. Driven by supplier MOQ (Minimum Order Quantity) or production setup constraints.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum remaining shelf life required at goods receipt. Materials with less remaining shelf life are rejected. Ensures adequate usable life for production and customer delivery.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Weighted average cost per base unit of measure, recalculated with each goods receipt. Used when price control is set to moving average price.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'MRP procedure code controlling how the material is planned. Determines reorder point planning, forecast-based planning, or time-phased planning methods.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Weight of the material itself excluding packaging. Used for production planning, yield calculations, and material consumption tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Days' ;
    rdfs:comment 'Expected lead time in days from order placement to goods receipt. Used by MRP to calculate order release dates. Includes supplier lead time and internal processing time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Control Indicator' ;
    rdfs:comment 'Defines material valuation method. S = standard price (fixed cost), V = moving average price (recalculated with each goods receipt). Determines inventory valuation approach.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'Quantity unit for which the price is maintained. Example: if price is $100 per 1000 units, price unit is 1000. Allows fractional pricing for low-cost materials.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productHierarchy rdf:type rdf:Property ;
    rdfs:label 'Product Hierarchy' ;
    rdfs:comment 'Multi-level classification structure organizing materials into product families and categories. Used for sales reporting, forecasting, and product portfolio management.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory level that triggers automatic replenishment. When stock falls below this level, MRP generates procurement proposals. Critical for JIT (Just In Time) inventory control.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStock rdf:type rdf:Property ;
    rdfs:label 'Safety Stock' ;
    rdfs:comment 'Minimum inventory buffer maintained to protect against demand variability and supply disruptions. Never falls below this level under normal planning. Used in safety stock optimization algorithms.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberProfile rdf:type rdf:Property ;
    rdfs:label 'Serial Number Profile' ;
    rdfs:comment 'Configuration code defining serial number management requirements. Determines whether material requires unique serial number tracking for traceability, warranty, and asset management.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeExpirationDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Days' ;
    rdfs:comment 'Total shelf life of the material from production or goods receipt date. After this period, material expires and cannot be used. Critical for perishable materials and chemicals.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Fixed valuation price per base unit of measure. Used when price control is set to standard price. Updated periodically through cost accounting processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required environmental conditions for material storage. Examples: temperature range, humidity control, light protection, hazardous material segregation. Used for warehouse bin assignment and handling instructions.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureConditions rdf:type rdf:Property ;
    rdfs:label 'Temperature Conditions' ;
    rdfs:comment 'Specific temperature range requirements for storage and transportation. Examples: ambient, refrigerated (2-8°C), frozen (-20°C), controlled room temperature (15-25°C).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'Accounting classification code linking material to general ledger accounts. Determines which GL (General Ledger) accounts are posted for inventory movements and consumption.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Physical volume occupied by the material. Used for warehouse space planning, container loading optimization, and transportation planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for volume field. Examples: L (liter), M3 (cubic meter), GAL (gallon).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for gross and net weight fields. Examples: KG (kilogram), LB (pound), TON (metric ton).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:width rdf:type rdf:Property ;
    rdfs:label 'Width' ;
    rdfs:comment 'Width dimension of the material. Used for storage bin assignment, handling equipment selection, and transportation planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockBalanceId rdf:type rdf:Property ;
    rdfs:label 'Stock Balance Id' ;
    rdfs:comment 'Unique identifier for the stock balance record. Primary key for the stock balance entity.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrpRunId rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Id' ;
    rdfs:comment 'Foreign key linking to supply.mrp_run. Business justification: INVENTORY RECONCILIATION: each stock balance snapshot is associated with the MRP run that calculated it.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrpRun .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Quantity available for new orders or production, calculated as unrestricted quantity on hand minus reserved quantity. Used for Available-to-Promise (ATP) calculations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedReasonCode rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason Code' ;
    rdfs:comment 'Code indicating the reason why stock is blocked from use. Examples include quality hold, pending investigation, customer return, damaged goods, regulatory hold. Null if stock is not blocked.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Consignment Indicator' ;
    rdfs:comment 'Flag indicating whether this stock is consignment stock owned by the supplier but held at the customer location. True for consignment stock; false for own stock.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date after which the material should not be used due to shelf life limitations. Applicable for perishable materials, chemicals, and time-sensitive components. Null for non-expiring materials.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryTurnoverDays rdf:type rdf:Property ;
    rdfs:label 'Inventory Turnover Days' ;
    rdfs:comment 'Average number of days this material remains in stock before being consumed or sold. Calculated as (quantity on hand / average daily usage). Used for inventory performance KPI tracking.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCountVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Last Count Variance Quantity' ;
    rdfs:comment 'Difference between book quantity and physical count quantity from the last inventory count. Positive values indicate surplus; negative values indicate shortage.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Issue Date' ;
    rdfs:comment 'Date of the most recent goods issue transaction that decreased stock for this material at this location. Used for inventory turnover analysis.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt transaction that increased stock for this material at this location. Used for inventory aging analysis.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count performed for this material at this location. Used to track count frequency and compliance.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Upper limit for stock quantity to prevent overstocking and excess inventory carrying costs. Used in inventory optimization and replenishment planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsoleteIndicator rdf:type rdf:Property ;
    rdfs:label 'Obsolete Indicator' ;
    rdfs:comment 'Flag indicating whether this material is classified as obsolete and should be phased out or written off. True if material is no longer used in production or sales.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndSnapshotDate rdf:type rdf:Property ;
    rdfs:label 'Period End Snapshot Date' ;
    rdfs:comment 'Date representing the period-end for which this stock balance snapshot was captured. Used for month-end, quarter-end, and year-end inventory reporting and financial close processes.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical quantity of material available in this storage location and stock category. Measured in the materials base unit of measure.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of material reserved for specific sales orders, production orders, or other commitments. Reduces available-to-promise quantity.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Minimum stock level maintained as buffer against demand variability and supply disruptions. Used in MRP calculations and reorder point determination.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slowMovingIndicator rdf:type rdf:Property ;
    rdfs:label 'Slow Moving Indicator' ;
    rdfs:comment 'Flag indicating whether this material is classified as slow-moving based on consumption patterns. True if no movement in the defined threshold period (e.g., 90 days).' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialStockType rdf:type rdf:Property ;
    rdfs:label 'Special Stock Type' ;
    rdfs:comment 'Classification of special stock scenarios. Standard is regular stock; consignment is supplier-owned; project stock is allocated to specific projects; sales order stock is customer-specific; subcontracting is at vendor location; returnable packaging is reusable containers.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockCategory rdf:type rdf:Property ;
    rdfs:label 'Stock Category' ;
    rdfs:comment 'Classification of stock availability status. Unrestricted stock is available for use; quality inspection stock is pending QA approval; blocked stock cannot be used; in-transit stock is moving between locations; reserved stock is allocated to specific orders or production.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Overall status of the stock balance record. Active indicates normal operations; frozen indicates temporary hold; blocked indicates quality or compliance issues; pending disposal indicates scheduled for write-off or scrap.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of material by its role in the production process. Raw material is input to production; WIP is work in progress; finished goods are ready for sale; semi-finished are intermediate products; spare parts support maintenance; packaging materials; MRO is maintenance, repair, and operations supplies. [ENUM-REF-CANDIDATE: raw_material|wip|finished_goods|semi_finished|spare_parts|packaging|mro — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'Total financial value of the stock on hand, calculated as quantity on hand multiplied by valuation price. Used for inventory valuation reporting and balance sheet preparation.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the valuation price. Typically the plant or company code currency.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationPrice rdf:type rdf:Property ;
    rdfs:label 'Valuation Price' ;
    rdfs:comment 'Standard or moving average price used to value the stock for financial reporting. Price per base unit of measure.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Batch Number' ;
    rdfs:comment 'Batch or lot number assigned by the supplier for purchased materials. Used for supplier traceability and quality issue resolution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchClassification rdf:type rdf:Property ;
    rdfs:label 'Batch Classification' ;
    rdfs:comment 'The material type classification for this batch indicating its stage in the production process. Used for inventory segmentation and MRP planning logic.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchCostAmount rdf:type rdf:Property ;
    rdfs:label 'Batch Cost Amount' ;
    rdfs:comment 'The total production or procurement cost for this batch in the company currency. Used for inventory valuation, cost of goods sold calculation, and financial reporting per IFRS/GAAP standards.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchNotes rdf:type rdf:Property ;
    rdfs:label 'Batch Notes' ;
    rdfs:comment 'Free-text field for capturing additional information, special handling instructions, quality observations, or deviation notes specific to this batch. Used by production, quality, and warehouse personnel.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch indicating its usability. Unrestricted: available for use; Quality Inspection: under QA review; Restricted: limited use with approval; Blocked: not available for use due to quality or compliance issues.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Quantity' ;
    rdfs:comment 'The quantity of this batch that is blocked and not available for any use. Set when batch fails quality inspection or is subject to hold for investigation per CAPA or NCR processes.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The user ID or username of the person who created this batch record. Audit field for accountability and data governance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerBatchRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Batch Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this batch must be tracked and reported to customers on shipping documents and certificates of analysis. True when customer contracts require batch-level traceability.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date when this batch was received into inventory via goods receipt posting. Marks the start of inventory availability and shelf life tracking for purchased materials.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Movement Date' ;
    rdfs:comment 'The date of the most recent goods movement transaction for this batch (receipt, issue, transfer, or adjustment). Used for inventory aging analysis and slow-moving stock identification.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The user ID or username of the person who last modified this batch record. Audit field for accountability and change management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'The date on which this batch was produced or manufactured. Critical for shelf life calculation, expiry determination, and lot traceability per ISO 9001 and PPAP requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country of origin for this batch. Required for customs, trade compliance, and country-of-origin labeling.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Certificate Number' ;
    rdfs:comment 'The certificate number or document identifier for the quality certificate issued for this batch. Required for customer shipments and regulatory compliance documentation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDecision rdf:type rdf:Property ;
    rdfs:label 'Quality Decision' ;
    rdfs:comment 'The final quality decision for this batch based on inspection results. Accepted: meets all specifications; Rejected: fails quality criteria; Conditional: accepted with restrictions; Pending: awaiting inspection completion.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:comment 'The total quantity of material produced in this batch, expressed in the base unit of measure for the material. Used for inventory valuation and yield analysis.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedQuantity rdf:type rdf:Property ;
    rdfs:label 'Restricted Quantity' ;
    rdfs:comment 'The quantity of this batch that is restricted and requires special approval for use. Typically set during quality inspection or when quality issues are identified.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Date' ;
    rdfs:comment 'The calculated shelf life expiration date based on manufacturing date and material-specific shelf life duration. Used in SAP MM for automatic batch determination and FEFO (First Expired First Out) logic.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Indicator for special stock types such as consignment stock, project stock, or customer stock. Used for specialized inventory management scenarios and ownership tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Batch Number' ;
    rdfs:comment 'The batch or lot number assigned by the supplier or vendor for raw materials and purchased components. Used for upstream traceability and supplier quality management.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'The valuation type or split valuation indicator for this batch when multiple valuations exist for the same material (e.g., domestic vs. imported, new vs. refurbished). Used for financial accounting and cost segregation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique identifier for each stock movement transaction. Primary key for the stock movement data product.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceStockLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Stock Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_location. Business justification: Link stock movement to its source location for traceability; replace free-text code with FK.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLocation .

ind:destinationBinLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Bin Location' ;
    rdfs:comment 'Specific bin, shelf, or warehouse location identifier to which the material was placed or moved.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location Code' ;
    rdfs:comment 'For transfer movements, the receiving storage location to which the material was moved.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date on the source document (e.g., delivery note, production confirmation) that triggered this stock movement. May differ from posting date due to processing delays.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The precise date and time when this stock movement record was created in the system, capturing the moment of transaction entry.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goodsIssueIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this movement decreases inventory (goods issue scenario).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this movement increases inventory (goods receipt scenario).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Material Document Item' ;
    rdfs:comment 'Line item number within the material document, representing the sequence of this movement within a multi-line transaction.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'The externally-known SAP material document number that uniquely identifies this inventory movement transaction in the ERP system. This is the business identifier used for audit trails and cross-system reconciliation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'Fiscal year of the material document posting, used in combination with material document number for unique identification in SAP systems.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementIndicator rdf:type rdf:Property ;
    rdfs:label 'Movement Indicator' ;
    rdfs:comment 'High-level classification of the movement direction: receipt (inbound), issue (outbound), transfer (location-to-location), or adjustment (correction/write-off).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'Code explaining the business reason for the movement (e.g., damaged goods, quality defect, process scrap, customer return, inventory correction). Used for root cause analysis and continuous improvement.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the stock movement transaction: posted (completed and effective), pending (awaiting confirmation), cancelled (voided before posting), or reversed (corrected after posting).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'Three-digit SAP movement type code that classifies the nature of the inventory transaction (e.g., 101=Goods Receipt from PO, 261=Goods Issue to Production Order, 311=Transfer Posting, 551=Scrapping). This code determines the accounting impact and stock ledger behavior.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the stock movement was posted to the inventory ledger and became effective for stock balance and financial accounting purposes. This is the principal business event timestamp for the transaction.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The quantity of material moved in this transaction, expressed in the base unit of measure. Positive for receipts, negative for issues in some system configurations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Reference Document Item' ;
    rdfs:comment 'Line item number within the reference document that corresponds to this stock movement.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'The document number of the source transaction (e.g., purchase order number, production order number, sales order number) that initiated this stock movement.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that triggered this stock movement (e.g., purchase order for goods receipt, production order for goods issue, delivery for shipment). [ENUM-REF-CANDIDATE: purchase_order|production_order|sales_order|delivery|transfer_order|physical_inventory|reservation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this movement is a reversal (correction) of a previously posted transaction.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedMaterialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Material Document Number' ;
    rdfs:comment 'The material document number of the original transaction that this movement reverses, establishing audit trail linkage for corrections.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceBinLocation rdf:type rdf:Property ;
    rdfs:label 'Source Bin Location' ;
    rdfs:comment 'Specific bin, shelf, or warehouse location identifier from which the material was picked or moved, enabling precise warehouse management and cycle count accuracy.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Code identifying the storage location (warehouse, stockroom, or inventory area) within the plant where the material is stored or was moved from.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the cycle count event. Primary key for the cycle count record.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:accuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percentage' ;
    rdfs:comment 'Inventory accuracy rate for this count, calculated as (items with zero variance / total items counted) × 100. Key Performance Indicator (KPI) for inventory management.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Approval workflow status for the cycle count results. Counts with material variances typically require supervisor or manager approval before posting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The actual date when the physical count was performed. Principal business event timestamp for the cycle count activity.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Count Document Number' ;
    rdfs:comment 'Business identifier for the cycle count document. Externally-known unique reference number used in SAP WM and warehouse operations.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'Precise timestamp when the physical counting activity was completed. Used to calculate count duration and resource utilization.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Technology or method used to perform the physical count. Impacts count accuracy and efficiency metrics.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countScope rdf:type rdf:Property ;
    rdfs:label 'Count Scope' ;
    rdfs:comment 'Defines the breadth of the counting activity. Indicates whether count covers entire warehouse, specific zones, material categories, or individual items.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the physical counting activity began. Used for labor tracking and cycle time analysis.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count event. Tracks progression from planning through execution, approval, and posting to inventory ledger. [ENUM-REF-CANDIDATE: Planned|In Progress|Completed|Approved|Posted|Cancelled|On Hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count event. Defines the counting methodology and business purpose (ABC-based frequency, annual compliance, variance investigation, or continuous counting program).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countZone rdf:type rdf:Property ;
    rdfs:label 'Count Zone' ;
    rdfs:comment 'Physical zone or area within the warehouse designated for this count. Used to organize counting activities by geographic sections or material groupings.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterName rdf:type rdf:Property ;
    rdfs:label 'Counter Name' ;
    rdfs:comment 'Full name of the employee who performed the physical count. Used for operational visibility and audit trail.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year in which the cycle count was performed. Used for annual physical inventory compliance and year-over-year accuracy trending.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeBookInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Freeze Book Inventory Flag' ;
    rdfs:comment 'Indicates whether book inventory was frozen (locked from transactions) during the count to ensure data integrity. True=frozen, False=not frozen.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCountDate rdf:type rdf:Property ;
    rdfs:label 'Planned Count Date' ;
    rdfs:comment 'The originally scheduled date for the cycle count. Used to track adherence to ABC cycle count schedules and annual physical inventory calendars.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'Fiscal period (YYYY-MM format) to which inventory adjustments are posted. Used for period-end close and financial reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Status of inventory adjustment posting to the general ledger and inventory subledger. Posted=variances reflected in stock balances, Not Posted=count complete but not yet posted.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountReason rdf:type rdf:Property ;
    rdfs:label 'Recount Reason' ;
    rdfs:comment 'Business reason or justification for requiring a recount. Populated when recount_required_flag is True.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether a recount is required due to significant variances exceeding tolerance thresholds. True=recount needed, False=count accepted.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage' ;
    rdfs:comment 'Acceptable variance threshold as a percentage of book quantity. Variances within tolerance may auto-approve; exceeding tolerance triggers recount or management review.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalItemsCounted rdf:type rdf:Property ;
    rdfs:label 'Total Items Counted' ;
    rdfs:comment 'Total number of distinct Stock Keeping Units (SKUs) or material numbers included in this cycle count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Variance Quantity' ;
    rdfs:comment 'Aggregate quantity variance across all materials in this count (sum of absolute differences between book and physical quantities). Measured in base unit of measure.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVarianceValue rdf:type rdf:Property ;
    rdfs:label 'Total Variance Value' ;
    rdfs:comment 'Aggregate financial value of inventory variances in this count. Calculated as sum of (variance quantity × standard cost) across all materials. Used for materiality assessment and financial impact analysis.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Variance Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total variance value. Typically plant or company code default currency.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountLineId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Line Id' ;
    rdfs:comment 'Unique identifier for the cycle count line item. Primary key for the cycle count line entity.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Number' ;
    rdfs:comment 'Reference number of the financial accounting document generated when the variance was posted. Links the physical inventory adjustment to General Ledger (GL) entries in SAP Financial Accounting (FI).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookQuantity rdf:type rdf:Property ;
    rdfs:label 'Book Quantity' ;
    rdfs:comment 'System-recorded quantity of material in the storage bin at the time of cycle count initiation. Represents the expected quantity per Enterprise Resource Planning (ERP) records before physical verification.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Actual physical quantity counted by warehouse personnel during the cycle count execution. This is the verified on-hand quantity observed in the storage bin.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Counted Timestamp' ;
    rdfs:comment 'Date and time when the physical count was completed by warehouse personnel. Represents the actual business event time of inventory verification.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:differenceQuantity rdf:type rdf:Property ;
    rdfs:label 'Difference Quantity' ;
    rdfs:comment 'Variance between book quantity and counted quantity. Calculated as counted_quantity minus book_quantity. Positive values indicate surplus, negative values indicate shortage. Critical for inventory accuracy Key Performance Indicator (KPI) measurement.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freezeBookInventoryIndicator rdf:type rdf:Property ;
    rdfs:label 'Freeze Book Inventory Indicator' ;
    rdfs:comment 'Flag indicating whether the book inventory quantity was frozen at the time of count initiation to prevent changes during the count period. True if frozen, false if dynamic.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the cycle count document. Determines the ordering and position of this count line within the parent document.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingIndicator rdf:type rdf:Property ;
    rdfs:label 'Posting Indicator' ;
    rdfs:comment 'Flag indicating whether the variance on this line has been posted to inventory and financial ledgers. True if posted, false if pending approval or recount.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountIndicator rdf:type rdf:Property ;
    rdfs:label 'Recount Indicator' ;
    rdfs:comment 'Flag indicating whether this line item requires or has undergone a recount due to variance exceeding tolerance thresholds. True if recount is required or completed, false otherwise.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountReasonCode rdf:type rdf:Property ;
    rdfs:label 'Recount Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason a recount was triggered. Used for root cause analysis and Corrective and Preventive Action (CAPA) processes per ISO 9001.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBin rdf:type rdf:Property ;
    rdfs:label 'Storage Bin' ;
    rdfs:comment 'Specific bin, shelf, or rack location within the storage location where the material is stored. Enables precise physical location tracking for Warehouse Management System (WMS) operations.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Root cause classification for inventory variance identified during cycle count. Enables variance analysis and process improvement initiatives. Required when difference_quantity is non-zero and exceeds tolerance. [ENUM-REF-CANDIDATE: counting_error|theft|damage|obsolescence|system_error|goods_receipt_not_posted|goods_issue_not_posted|transfer_not_posted|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Date and time when the count result was verified by a supervisor or second counter. Null if verification is not required or not yet completed.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique identifier for the replenishment order record. Primary key for this entity.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when this replenishment order was closed after complete fulfillment or cancellation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'Actual confirmed delivery date provided by the supplier or internal source, may differ from requested date based on availability and lead time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated total cost for fulfilling this replenishment order, including material cost, freight, and handling charges.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfilledQuantity rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Quantity' ;
    rdfs:comment 'Actual quantity of material that has been delivered and received against this replenishment order.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether incoming quality inspection is required before the replenished material can be released for use.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kanbanCardNumber rdf:type rdf:Property ;
    rdfs:label 'Kanban Card Number' ;
    rdfs:comment 'Unique identifier of the kanban card that triggered this replenishment, applicable when replenishment type is kanban-based pull system.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Size Quantity' ;
    rdfs:comment 'Standard or economic order quantity used for replenishment, may be based on MOQ (Minimum Order Quantity), EOQ (Economic Order Quantity), or fixed lot size rules.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business-facing unique identifier for the replenishment order, used for tracking and reference across systems and documents.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the replenishment order indicating its progress through the fulfillment workflow. [ENUM-REF-CANDIDATE: draft|open|in_progress|partially_fulfilled|fulfilled|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Order Number' ;
    rdfs:comment 'Reference to the consuming order that requires this replenishment (e.g., production order, sales order, maintenance order). Used to link demand to supply.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceOrderType rdf:type rdf:Property ;
    rdfs:label 'Reference Order Type' ;
    rdfs:comment 'Classification of the reference order type that is consuming or requiring this replenishment.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level threshold that triggers automatic replenishment when stock falls below this point, used in min-max and reorder point planning strategies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentType rdf:type rdf:Property ;
    rdfs:label 'Replenishment Type' ;
    rdfs:comment 'Classification of the replenishment trigger mechanism: planning-driven (MRP-based), kanban (pull-based), min-max (reorder point), JIT (Just In Time), manual reservation, or safety stock replenishment.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target date by which the replenished material is required to be available at the storage location to meet production or demand requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredQuantity rdf:type rdf:Property ;
    rdfs:label 'Required Quantity' ;
    rdfs:comment 'Total quantity of material required to meet the replenishment target or reservation commitment, expressed in the base unit of measure.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberRequired rdf:type rdf:Property ;
    rdfs:label 'Serial Number Required' ;
    rdfs:comment 'Indicates whether individual serial number tracking is required for the replenished material items.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'Reference number of the originating document that triggered or fulfills this replenishment order (e.g., purchase requisition number, production order number, stock transfer order number).' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProcurementType rdf:type rdf:Property ;
    rdfs:label 'Special Procurement Type' ;
    rdfs:comment 'Classification of special procurement arrangements such as consignment stock, subcontracting, pipeline materials, or inter-plant stock transfers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentUnitSerializedUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Unit Serialized Unit Id' ;
    rdfs:comment 'Reference to the parent handling unit (pallet, container, tote) that contains this serialized unit. Enables hierarchical packing structure and nested unit tracking for warehouse operations.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SerializedUnit .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, rack, or storage position identifier within the warehouse where this serialized unit is physically located. Enables precise picking and putaway operations.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where this serialized unit was manufactured or assembled. Required for customs declarations and trade compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsTariffCode rdf:type rdf:Property ;
    rdfs:label 'Customs Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) code or Harmonized Tariff Schedule (HTS) code for customs classification and duty calculation. Required for international shipments.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the serialized unit including packaging and contents, measured in kilograms. Used for logistics planning and transportation compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'United Nations (UN) hazard classification code for hazardous materials (e.g., Class 3 Flammable Liquids, Class 8 Corrosives). Required for transportation and storage compliance.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Boolean indicator whether this serialized unit contains hazardous materials requiring special handling, storage, and transportation compliance.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Height dimension of the serialized unit or handling unit in centimeters. Used for warehouse space planning and transportation optimization.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent inventory movement transaction for this serialized unit. Used for inventory aging analysis and cycle count prioritization.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastMovementType rdf:type rdf:Property ;
    rdfs:label 'Last Movement Type' ;
    rdfs:comment 'Type of the most recent inventory movement transaction for this serialized unit (e.g., goods receipt, goods issue, transfer posting, physical inventory). Provides audit trail context.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Length dimension of the serialized unit or handling unit in centimeters. Used for warehouse space planning and transportation optimization.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'Net weight of the material contents excluding packaging, measured in kilograms. Used for material valuation and yield calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current quality inspection status of the serialized unit. Indicates whether the unit has passed quality checks and is approved for use or shipment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal number applied to handling units (containers, pallets) for tamper detection and customs compliance. Required for international shipments and high-value goods.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN number identifying the hazardous substance for transportation and emergency response (e.g., UN1203 for gasoline). Required for hazmat shipping documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the serialized unit indicating whether it is a serialized component part, assembly, finished good, or handling unit (pallet, container, tote, drum, reel) used for material handling and logistics. [ENUM-REF-CANDIDATE: serialized_part|assembly|finished_good|pallet|container|tote|drum|reel|handling_unit — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Monetary valuation of this serialized unit for inventory accounting and financial reporting. Represents standard cost, moving average price, or actual cost depending on valuation method.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volume of the serialized unit or handling unit in cubic meters. Used for warehouse capacity planning and freight cost calculation.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Width dimension of the serialized unit or handling unit in centimeters. Used for warehouse space planning and transportation optimization.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substituteComponentId rdf:type rdf:Property ;
    rdfs:label 'Substitute Component Id' ;
    rdfs:comment 'Identifier of an approved substitute component that can be used interchangeably. Supports supply chain flexibility and risk mitigation.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:cadModelReference rdf:type rdf:Property ;
    rdfs:label 'Cad Model Reference' ;
    rdfs:comment 'File path or URI reference to the authoritative CAD model in PLM. Links to 3D geometry for design, simulation, and manufacturing.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceMarkingFlag rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Flag' ;
    rdfs:comment 'Indicates CE marking compliance for European market access. Confirms conformity with EU health, safety, and environmental protection standards.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed technical description of the component including functional characteristics, application context, and distinguishing features.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentName rdf:type rdf:Property ;
    rdfs:label 'Component Name' ;
    rdfs:comment 'Descriptive name of the component. Primary human-readable identifier used in engineering documentation and BOMs.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentNumber rdf:type rdf:Property ;
    rdfs:label 'Component Number' ;
    rdfs:comment 'Business identifier for the component. Human-readable unique code used across engineering, procurement, and manufacturing.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component by procurement and manufacturing strategy. Determines BOM explosion logic and sourcing approach.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for standard cost. Enables multi-currency cost management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmScore rdf:type rdf:Property ;
    rdfs:label 'Dfm Score' ;
    rdfs:comment 'Quantitative assessment of component manufacturability. Higher scores indicate easier, lower-cost manufacturing.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dfmeaReference rdf:type rdf:Property ;
    rdfs:label 'Dfmea Reference' ;
    rdfs:comment 'Reference identifier to the DFMEA document analyzing potential design failure modes and mitigation strategies.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalGroup rdf:type rdf:Property ;
    rdfs:label 'Functional Group' ;
    rdfs:comment 'Functional classification of the component within the product architecture. Used for design reuse and modular engineering.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'Maximum height dimension of the component envelope in millimeters. Part of dimensional specification for packaging and assembly planning.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lengthMm rdf:type rdf:Property ;
    rdfs:label 'Length Mm' ;
    rdfs:comment 'Maximum length dimension of the component envelope in millimeters. Part of dimensional specification for packaging and assembly planning.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifecyclePhase rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Phase' ;
    rdfs:comment 'Current phase in the component lifecycle from concept through obsolescence. Governs release status and usage authorization. [ENUM-REF-CANDIDATE: concept|design|prototype|validation|production|phase_out|obsolete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makeOrBuy rdf:type rdf:Property ;
    rdfs:label 'Make Or Buy' ;
    rdfs:comment 'Strategic sourcing decision indicating whether the component is manufactured in-house, purchased from suppliers, or both.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSpecification rdf:type rdf:Property ;
    rdfs:label 'Material Specification' ;
    rdfs:comment 'Material composition and grade specification. Defines raw material requirements for manufactured components.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum order quantity required by supplier or manufacturing process. Constraint for procurement and production planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier of the engineer who last modified the component record. Audit trail for change management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obsolescenceDate rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Date' ;
    rdfs:comment 'Planned or actual date when the component will be obsoleted and no longer available for new designs. Supports lifecycle planning.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pfmeaReference rdf:type rdf:Property ;
    rdfs:label 'Pfmea Reference' ;
    rdfs:comment 'Reference identifier to the PFMEA document analyzing potential manufacturing process failure modes and controls.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmItemCode rdf:type rdf:Property ;
    rdfs:label 'Plm Item Code' ;
    rdfs:comment 'Unique identifier for this component in Siemens Teamcenter PLM system. External system reference for PLM integration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant Flag' ;
    rdfs:comment 'Indicates compliance with EU REACH regulation for chemical substance registration and safety assessment.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Engineering release status indicating approval state for manufacturing and procurement use.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant Flag' ;
    rdfs:comment 'Indicates compliance with EU RoHS directive restricting use of hazardous substances in electrical and electronic equipment.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technologyFamily rdf:type rdf:Property ;
    rdfs:label 'Technology Family' ;
    rdfs:comment 'Engineering technology classification grouping components by functional domain (e.g., electrification, automation, control systems).' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceClass rdf:type rdf:Property ;
    rdfs:label 'Tolerance Class' ;
    rdfs:comment 'Manufacturing tolerance classification defining acceptable dimensional variation. Drives manufacturing process selection and quality inspection requirements.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ulCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Ul Certification Number' ;
    rdfs:comment 'UL certification identifier for product safety compliance. Required for electrical components in North American markets.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'Maximum width dimension of the component envelope in millimeters. Part of dimensional specification for packaging and assembly planning.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Unique identifier for the Bill of Materials record. Primary key for the BOM master data entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:productBomHeaderId rdf:type rdf:Property ;
    rdfs:label 'Product Bom Header Id' ;
    rdfs:comment 'Foreign key linking to product.bom_header. Business justification: eBOM-to-mBOM promotion: the engineering BOM is the upstream source that is transferred and transformed into the manufacturing/product BOM header. Change impact analysis and BOM synchronization reports' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomHeader .

ind:alternativeBomIndicator rdf:type rdf:Property ;
    rdfs:label 'Alternative Bom Indicator' ;
    rdfs:comment 'Identifier for alternative BOM variants of the same product, used to represent different manufacturing methods, material substitutions, or regional variations. Blank for primary BOM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomCategory rdf:type rdf:Property ;
    rdfs:label 'Bom Category' ;
    rdfs:comment 'High-level classification of the BOM structure. Material BOM lists physical components, Document BOM references technical drawings and specifications, Equipment BOM defines installed assets, Variant BOM supports product families, Configurable BOM enables customer-specific selections.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomDescription rdf:type rdf:Property ;
    rdfs:label 'Bom Description' ;
    rdfs:comment 'Free-text description of the BOM, providing additional context about the product structure, manufacturing method, or special handling requirements. Supplements the BOM number and type.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, typically a human-readable code used across engineering, manufacturing, and procurement systems. Serves as the externally-known unique reference.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle state of the BOM. Draft indicates work in progress, In Review means under engineering approval, Approved is ready for release, Active is in production use, Obsolete is no longer valid, Superseded has been replaced by a newer revision, and Frozen is locked for regulatory or contractual reasons. [ENUM-REF-CANDIDATE: draft|in_review|approved|active|obsolete|superseded|frozen — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM by its intended business purpose. Engineering BOM (EBOM) represents design intent, Manufacturing BOM (MBOM) reflects shop floor assembly, Service BOM supports after-sales maintenance, Sales BOM defines customer-facing configurations, Planning BOM is used for MRP, and As-Maintained BOM tracks actual installed configurations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationProfile rdf:type rdf:Property ;
    rdfs:label 'Configuration Profile' ;
    rdfs:comment 'Identifier for a variant configuration profile or product family definition. Used in configurable BOMs to define which components are included based on customer selections or feature options.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the BOM cost estimate. Supports multi-currency costing for global manufacturing operations.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateTotal rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Total' ;
    rdfs:comment 'Estimated total cost of the BOM including all material, labor, and overhead components. Rolled up from component costs and routing operations. Used for product costing and pricing decisions.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date until which this BOM revision remains valid. Nullable for open-ended BOMs. Used to manage phase-out of legacy product structures and ensure correct BOM selection in MRP and MES systems.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringChangeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Order Number' ;
    rdfs:comment 'Reference to the ECO that created or last modified this BOM revision. Provides traceability to the engineering change management process and links to ECO approval workflows.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:explosionType rdf:type rdf:Property ;
    rdfs:label 'Explosion Type' ;
    rdfs:comment 'Defines how the BOM structure should be expanded for planning and execution. Single Level shows only immediate children, Multi Level recursively expands all sub-assemblies, Summarized aggregates quantities across all levels.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfigurable rdf:type rdf:Property ;
    rdfs:label 'Is Configurable' ;
    rdfs:comment 'Flag indicating whether this BOM supports variant configuration, allowing customer-specific or order-specific component selection. True for configurable BOMs, False for fixed BOMs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCriticalBom rdf:type rdf:Property ;
    rdfs:label 'Is Critical Bom' ;
    rdfs:comment 'Flag indicating whether this BOM is for a critical or high-value product requiring special handling, approval workflows, or regulatory compliance. True for critical BOMs, False for standard BOMs.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantomBom rdf:type rdf:Property ;
    rdfs:label 'Is Phantom Bom' ;
    rdfs:comment 'Flag indicating whether this is a phantom (transient) BOM that is not stocked as a discrete item but is exploded through to its components during MRP and production. True for phantom BOMs, False for standard stocked assemblies.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'Identifier linking this BOM to a specific production version in SAP PP, which combines a BOM with a routing to define a complete manufacturing process. Supports multiple production methods for the same product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityBasis rdf:type rdf:Property ;
    rdfs:label 'Quantity Basis' ;
    rdfs:comment 'The base quantity for which this BOM is defined, typically 1 for single-unit BOMs or a batch size for process manufacturing. All component quantities in the BOM structure are expressed relative to this basis.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'Expected scrap or waste percentage at the BOM header level, applied to all components. Used in MRP to inflate material requirements. Expressed as a percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usage rdf:type rdf:Property ;
    rdfs:label 'Usage' ;
    rdfs:comment 'Defines the business context in which this BOM is intended to be used. Production for shop floor execution, Costing for standard cost calculation, Engineering for design and development, Maintenance for service and repair, Sales Order for customer-specific configurations, Project for one-time builds.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightTotal rdf:type rdf:Property ;
    rdfs:label 'Weight Total' ;
    rdfs:comment 'Total weight of the finished assembly including all components, calculated from the BOM structure. Used for logistics planning, freight cost estimation, and product specifications.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineeringBomLineId rdf:type rdf:Property ;
    rdfs:label 'Engineering Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the BOM line entity representing a single parent-child component relationship within a bill of materials structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringBomLine .

ind:bomHeaderId rdf:type rdf:Property ;
    rdfs:label 'Bom Header Id' ;
    rdfs:comment 'Reference to the parent BOM header that this line belongs to. Links the line item to its containing bill of materials assembly structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomHeader .

ind:primaryEngineeringComponentId rdf:type rdf:Property ;
    rdfs:label 'Primary Engineering Component Id' ;
    rdfs:comment 'Reference to the parent assembly or product that contains this component. Represents the \'parent\' side of the parent-child relationship in the BOM structure.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:tertiaryEngineeringSubstituteComponentId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Engineering Substitute Component Id' ;
    rdfs:comment 'Reference to an approved alternate component that can be used in place of the primary component without requiring an Engineering Change Order (ECO). Enables flexible sourcing and supply chain continuity.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:assemblyInstruction rdf:type rdf:Property ;
    rdfs:label 'Assembly Instruction' ;
    rdfs:comment 'Specific instructions for assembling or installing this component into the parent assembly. May reference work instructions, torque specifications, or special tooling requirements.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Bulk Material Flag' ;
    rdfs:comment 'Indicates whether this component is a bulk material (e.g., paint, adhesive, lubricant) that is consumed in variable quantities and may not be tracked at individual unit level.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'The Engineering Change Order (ECO) or Engineering Change Notice (ECN) number that introduced or last modified this BOM line. Provides traceability to engineering change governance processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coProductFlag rdf:type rdf:Property ;
    rdfs:label 'Co Product Flag' ;
    rdfs:comment 'Indicates whether this line represents a co-product or by-product that is produced alongside the main assembly. Co-products have negative quantities in the BOM and represent outputs rather than inputs.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Rollup Flag' ;
    rdfs:comment 'Indicates whether the cost of this component should be included in the parent assembly cost rollup calculation. Some components (e.g., reference items, tooling) may be excluded from product costing.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical to product functionality, safety, or regulatory compliance. Critical components may require additional quality controls, traceability, or supply chain management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity End Date' ;
    rdfs:comment 'The date after which this component is no longer effective in the parent assembly. Used to manage engineering changes and phase-out of obsolete components. Null indicates the component is currently effective with no planned end date.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivitySerialNumberEnd rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Number End' ;
    rdfs:comment 'The ending serial number of the parent assembly for which this component is effective. Null indicates the component remains effective for all subsequent serial numbers.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivitySerialNumberStart rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Number Start' ;
    rdfs:comment 'The starting serial number of the parent assembly for which this component is effective. Enables serial-number-based effectivity control for mid-production engineering changes.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Start Date' ;
    rdfs:comment 'The date from which this component becomes effective in the parent assembly. Used to manage engineering changes and phase-in of new components without creating new BOM versions.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringBomLineStatus rdf:type rdf:Property ;
    rdfs:label 'Engineering Bom Line Status' ;
    rdfs:comment 'Current lifecycle status of this BOM line. Indicates whether the component relationship is currently in use, pending approval, or has been superseded.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringNotes rdf:type rdf:Property ;
    rdfs:label 'Engineering Notes' ;
    rdfs:comment 'Free-text notes from engineering regarding special assembly instructions, design considerations, quality requirements, or other technical information relevant to this component usage.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findNumber rdf:type rdf:Property ;
    rdfs:label 'Find Number' ;
    rdfs:comment 'Reference designator or callout number used to locate this component on engineering drawings, assembly diagrams, and technical documentation. Also known as item number or balloon number.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedQuantityFlag rdf:type rdf:Property ;
    rdfs:label 'Fixed Quantity Flag' ;
    rdfs:comment 'Indicates whether the component quantity is fixed regardless of parent assembly batch size. When true, the quantity does not scale with production order quantity (e.g., setup materials, tooling).' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationPoint rdf:type rdf:Property ;
    rdfs:label 'Installation Point' ;
    rdfs:comment 'The specific location or mounting point within the parent assembly where this component is installed. Used in assembly instructions and maintenance documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Offset Days' ;
    rdfs:comment 'The number of days before the parent assembly start date that this component must be available. Used in production scheduling and material requirements planning (MRP) to ensure timely component availability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phantomFlag rdf:type rdf:Property ;
    rdfs:label 'Phantom Flag' ;
    rdfs:comment 'Indicates whether this component is a phantom (transient) assembly that is not stocked or tracked in inventory. Phantom items are exploded through to their child components during MRP processing.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:positionNumber rdf:type rdf:Property ;
    rdfs:label 'Position Number' ;
    rdfs:comment 'Sequential position or line number of this component within the parent assembly BOM. Used for ordering and identifying components in engineering drawings and manufacturing instructions.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerAssembly rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Assembly' ;
    rdfs:comment 'The number of units of this component required to build one unit of the parent assembly. Used for material requirements planning (MRP) calculations and cost rollup.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDesignator rdf:type rdf:Property ;
    rdfs:label 'Reference Designator' ;
    rdfs:comment 'Alphanumeric code identifying the specific location or function of the component in the assembly (e.g., R1, C5, U3 for electronics; A-01, B-12 for mechanical). Used in assembly instructions and maintenance documentation.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percentage' ;
    rdfs:comment 'Expected scrap or waste percentage for this component during assembly or manufacturing. Used to adjust material requirements planning (MRP) calculations to account for normal production losses.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sortSequence rdf:type rdf:Property ;
    rdfs:label 'Sort Sequence' ;
    rdfs:comment 'Numeric value used to control the display order of BOM lines in reports, pick lists, and assembly instructions. Lower values appear first.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substituteQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Substitute Qualification Status' ;
    rdfs:comment 'Approval status of the substitute component for use in this assembly. Indicates whether the alternate has passed qualification testing and is approved for production use.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substituteUsageRestriction rdf:type rdf:Property ;
    rdfs:label 'Substitute Usage Restriction' ;
    rdfs:comment 'Conditions or limitations on when the substitute component may be used (e.g., only for specific customer orders, only when primary is unavailable, geographic restrictions). Ensures proper alternate sourcing governance.' ;
    rdfs:domain ind:EngineeringBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyLevel rdf:type rdf:Property ;
    rdfs:label 'Assembly Level' ;
    rdfs:comment 'Hierarchical level of the item depicted (component, subassembly, assembly, system). Indicates the complexity and position in the product structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkedBy rdf:type rdf:Property ;
    rdfs:label 'Checked By' ;
    rdfs:comment 'Name or identifier of the engineer who reviewed and checked the drawing for accuracy and completeness before approval.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level of the drawing (public, internal, confidential, restricted, proprietary). Governs access control and distribution.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingStatus rdf:type rdf:Property ;
    rdfs:label 'Drawing Status' ;
    rdfs:comment 'Current lifecycle status of the drawing (draft, in_review, approved, released, obsolete, superseded). Governs whether the drawing can be used for manufacturing.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingType rdf:type rdf:Property ;
    rdfs:label 'Drawing Type' ;
    rdfs:comment 'Classification of the drawing by its purpose and content (assembly, detail, schematic, layout, installation, wiring, piping, fabrication). [ENUM-REF-CANDIDATE: assembly|detail|schematic|layout|installation|wiring|piping|fabrication — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawnBy rdf:type rdf:Property ;
    rdfs:label 'Drawn By' ;
    rdfs:comment 'Name or identifier of the engineer or drafter who created the drawing. Recorded in the title block.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlClassification rdf:type rdf:Property ;
    rdfs:label 'Export Control Classification' ;
    rdfs:comment 'Export control classification number (ECCN) or similar designation if the drawing contains controlled technical data. Required for international compliance.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Digital file format of the drawing (PDF, DWG, DXF, STEP, IGES, JT). Determines compatibility and usage.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Storage location or URI of the drawing file in the document management system or file server.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMasterDrawing rdf:type rdf:Property ;
    rdfs:label 'Is Master Drawing' ;
    rdfs:comment 'Flag indicating whether this is the master (authoritative) drawing for the part. True if this is the primary reference; false if it is a derivative or copy.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCallout rdf:type rdf:Property ;
    rdfs:label 'Material Callout' ;
    rdfs:comment 'Material specification called out on the drawing (e.g., AISI 304, Al 6061-T6, SAE 1020). Defines the material from which the part is manufactured.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionMethod rdf:type rdf:Property ;
    rdfs:label 'Projection Method' ;
    rdfs:comment 'Orthographic projection method used (first_angle per ISO, third_angle per ANSI). Determines the arrangement of views.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the drawing was officially released for manufacturing and procurement. Marks the transition from engineering to production.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scale rdf:type rdf:Property ;
    rdfs:label 'Scale' ;
    rdfs:comment 'Scale ratio of the drawing (e.g., 1:1, 1:2, 2:1, NTS for Not To Scale). Indicates the relationship between drawing dimensions and actual part dimensions.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sheetCount rdf:type rdf:Property ;
    rdfs:label 'Sheet Count' ;
    rdfs:comment 'Total number of sheets in this drawing set. Multi-sheet drawings are common for complex assemblies.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sheetSize rdf:type rdf:Property ;
    rdfs:label 'Sheet Size' ;
    rdfs:comment 'Standard sheet size designation (ISO: A0, A1, A2, A3, A4; ANSI: A, B, C, D, E, F) used for this drawing. [ENUM-REF-CANDIDATE: A0|A1|A2|A3|A4|A|B|C|D|E|F — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByDrawingNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Drawing Number' ;
    rdfs:comment 'Drawing number that supersedes this drawing when status is obsolete or superseded. Maintains traceability in the revision chain.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesDrawingNumber rdf:type rdf:Property ;
    rdfs:label 'Supersedes Drawing Number' ;
    rdfs:comment 'Previous drawing number that this drawing supersedes. Establishes the backward link in the revision history.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceFinishSpecification rdf:type rdf:Property ;
    rdfs:label 'Surface Finish Specification' ;
    rdfs:comment 'Surface roughness or finish requirement specified on the drawing (e.g., Ra 0.8, N6, 125 microinch). Critical for functional surfaces.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_budget. Business justification: ECOs consume engineering change budgets independently of projects. ECOs can exist without an engineering_project (standalone change orders). Direct ECO→finance_budget link enables budget vs. actual tr' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:acknowledgementCount rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Count' ;
    rdfs:comment 'Number of stakeholders who have acknowledged receipt of the ECN.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgementRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required' ;
    rdfs:comment 'Indicates whether recipients of the ECN are required to formally acknowledge receipt and understanding.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualCostImpact rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Impact' ;
    rdfs:comment 'Actual financial impact realized after implementation, including all direct and indirect costs.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualScheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Actual Schedule Impact Days' ;
    rdfs:comment 'Actual impact on production schedule in days realized after implementation.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Items Count' ;
    rdfs:comment 'Total number of product items (parts, assemblies, drawings, documents) affected by this engineering change.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Full name of the final approver who authorized the engineering change.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByTitle rdf:type rdf:Property ;
    rdfs:label 'Approved By Title' ;
    rdfs:comment 'Job title or role of the final approver (e.g., Chief Engineer, VP Engineering, Quality Manager).' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changePriority rdf:type rdf:Property ;
    rdfs:label 'Change Priority' ;
    rdfs:comment 'Business priority level for implementing the change. Critical = safety/regulatory; High = customer impact; Medium = quality improvement; Low = cost reduction.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the engineering change by category: design (product geometry/function), material (BOM substitution), process (manufacturing method), documentation (drawing/spec update), specification (performance criteria), or tooling (fixture/jig modification).' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Date' ;
    rdfs:comment 'Date when customer approval was received for the engineering change.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerApprovalReceived rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Received' ;
    rdfs:comment 'Indicates whether required customer approval has been obtained.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Primary disposition action for existing inventory and work-in-progress: use_as_is (no action required), rework (modify to new spec), scrap (discard), retrofit (field upgrade), return_to_supplier (vendor return).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecoDescription rdf:type rdf:Property ;
    rdfs:label 'Eco Description' ;
    rdfs:comment 'Detailed description of the engineering change including technical rationale, scope, and implementation approach.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecoNumber rdf:type rdf:Property ;
    rdfs:label 'Eco Number' ;
    rdfs:comment 'Business identifier for the engineering change order, externally visible and used across systems. Typically follows format ECO-NNNNNN.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Date' ;
    rdfs:comment 'Date when the engineering change becomes effective and must be implemented in production. Controls when new revision supersedes old revision.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivityReference rdf:type rdf:Property ;
    rdfs:label 'Effectivity Reference' ;
    rdfs:comment 'Reference value for effectivity (e.g., serial number, lot number, or date) that defines the cutover point for the change.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityType rdf:type rdf:Property ;
    rdfs:label 'Effectivity Type' ;
    rdfs:comment 'Method by which the change takes effect: date (on specific date), serial_number (from specific unit serial), lot_batch (from specific production lot), immediate (next unit produced).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSystemReference rdf:type rdf:Property ;
    rdfs:label 'Erp System Reference' ;
    rdfs:comment 'Reference identifier linking this ECO to the corresponding engineering change record in the ERP system (e.g., SAP S/4HANA).' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'Estimated financial impact of implementing the change, including material, labor, tooling, and scrap costs. Positive values indicate cost increase; negative values indicate savings.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedScheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Schedule Impact Days' ;
    rdfs:comment 'Estimated impact on production schedule in days. Positive values indicate delay; negative values indicate acceleration.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fromRevision rdf:type rdf:Property ;
    rdfs:label 'From Revision' ;
    rdfs:comment 'Current revision level of the primary affected item before the change is applied.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Actual date when the engineering change was implemented in production systems and processes.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatorDepartment rdf:type rdf:Property ;
    rdfs:label 'Initiator Department' ;
    rdfs:comment 'Organizational department or functional area of the change initiator (e.g., Product Engineering, Quality, Manufacturing Engineering).' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorEmail rdf:type rdf:Property ;
    rdfs:label 'Initiator Email' ;
    rdfs:comment 'Email address of the change initiator for communication and audit trail purposes.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the ECO in its approval and implementation workflow: draft (being prepared), submitted (awaiting review), under_review (in approval chain), approved (authorized for implementation), rejected (not approved), in_implementation (being executed), completed (closed), cancelled (withdrawn). [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|in_implementation|completed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plm System Reference' ;
    rdfs:comment 'Reference identifier or URL linking this ECO to the corresponding record in the PLM system (e.g., Siemens Teamcenter).' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Root cause or business driver for initiating the engineering change: safety issue, regulatory compliance, quality improvement, cost reduction, component obsolescence, or customer-requested modification.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed explanation of the business or technical reason necessitating the change, including problem statement and justification.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCustomerApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Customer Approval' ;
    rdfs:comment 'Indicates whether this engineering change requires formal customer notification and approval before implementation.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSupplierNotification rdf:type rdf:Property ;
    rdfs:label 'Requires Supplier Notification' ;
    rdfs:comment 'Indicates whether this change requires notification to suppliers for purchased components or materials.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Date when the ECO was submitted for formal review and approval.' ;
    rdfs:domain ind:Eco ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:toRevision rdf:type rdf:Property ;
    rdfs:label 'To Revision' ;
    rdfs:comment 'New revision level of the primary affected item after the change is applied.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementTargetCount rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Target Count' ;
    rdfs:comment 'Total number of stakeholders required to acknowledge this ECN before it can be marked as fully distributed.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedDrawingCount rdf:type rdf:Property ;
    rdfs:label 'Affected Drawing Count' ;
    rdfs:comment 'Total number of engineering drawings, Computer-Aided Design (CAD) models, or technical documents affected by this ECN.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedPartCount rdf:type rdf:Property ;
    rdfs:label 'Affected Part Count' ;
    rdfs:comment 'Total number of distinct part numbers or Bill of Materials (BOM) items affected by this ECN.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedProductLines rdf:type rdf:Property ;
    rdfs:label 'Affected Product Lines' ;
    rdfs:comment 'Comma-separated list or narrative of product lines, families, or platforms impacted by this ECN. Used for scoping and impact analysis.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Bom Impact Flag' ;
    rdfs:comment 'Indicates whether this ECN requires changes to one or more Bill of Materials (BOM) structures. True = BOM changes required; False = no BOM impact.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Primary category of the engineering change. Design = product design modification; Material = material substitution; Process = manufacturing process change; Documentation = drawing/spec update; Specification = requirement change; Supplier = vendor change.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed narrative description of the engineering change being communicated, including technical modifications, affected components, and implementation instructions.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business justification and rationale for the engineering change, including root cause, customer requirements, regulatory compliance, or quality improvement drivers.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional notes, instructions, or clarifications related to the ECN implementation, distribution, or acknowledgement process.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost impact estimate (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Estimate' ;
    rdfs:comment 'Estimated total cost impact of implementing this ECN, including material, labor, tooling, and inventory disposition costs. Positive values indicate cost increase; negative values indicate cost savings.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'Comma-separated list or structured text of roles, departments, or individuals who must receive and acknowledge this ECN (e.g., Production, Quality, Supply Chain, Engineering).' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnNumber rdf:type rdf:Property ;
    rdfs:label 'Ecn Number' ;
    rdfs:comment 'Business identifier for the engineering change notice, typically formatted as ECN-NNNNNN. Used for external communication and tracking across systems.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnStatus rdf:type rdf:Property ;
    rdfs:label 'Ecn Status' ;
    rdfs:comment 'Current lifecycle status of the ECN. Draft = being prepared; Released = approved for distribution; Distributed = sent to stakeholders; Acknowledged = recipients confirmed receipt; Closed = implementation complete; Cancelled = voided.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecnType rdf:type rdf:Property ;
    rdfs:label 'Ecn Type' ;
    rdfs:comment 'Classification of the ECN based on urgency and scope. Standard = normal process; Urgent = expedited review; Emergency = immediate action required; Field Change = affects deployed products; Design Improvement = enhancement.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Erp Sync Status' ;
    rdfs:comment 'Status of synchronization of this ECN to downstream Enterprise Resource Planning (ERP) systems (SAP S/4HANA). Pending = awaiting sync; Synced = successfully transmitted; Failed = sync error; Not Required = no ERP impact.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Impact Flag' ;
    rdfs:comment 'Indicates whether this ECN affects existing inventory, requiring disposition decisions (scrap, rework, use-as-is). True = inventory action required; False = no inventory impact.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Mes Sync Status' ;
    rdfs:comment 'Status of synchronization of this ECN to Manufacturing Execution System (MES) for shop floor implementation. Pending = awaiting sync; Synced = successfully transmitted; Failed = sync error; Not Required = no MES impact.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmSystemCode rdf:type rdf:Property ;
    rdfs:label 'Plm System Code' ;
    rdfs:comment 'Unique identifier for this ECN in the source Product Lifecycle Management (PLM) system (Siemens Teamcenter). Used for system integration and traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionFrom rdf:type rdf:Property ;
    rdfs:label 'Revision From' ;
    rdfs:comment 'The previous revision level of the affected item(s) before this ECN takes effect. Used to track revision transitions.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionTo rdf:type rdf:Property ;
    rdfs:label 'Revision To' ;
    rdfs:comment 'The new revision level of the affected item(s) after this ECN is implemented. Represents the target state.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Routing Impact Flag' ;
    rdfs:comment 'Indicates whether this ECN requires changes to manufacturing routings or process plans. True = routing changes required; False = no routing impact.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Supplier Notification Required' ;
    rdfs:comment 'Indicates whether external suppliers must be notified of this ECN due to purchased part changes or specification updates. True = supplier notification required; False = internal only.' ;
    rdfs:domain ind:Ecn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySupersededByRevisionEngineeringRevisionId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Revision Engineering Revision Id' ;
    rdfs:comment 'Reference to the newer revision that supersedes this revision. Establishes the revision lineage chain for traceability and configuration management. Null if this is the current active revision.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringRevision .

ind:qualificationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Id' ;
    rdfs:comment 'Foreign key linking to supplier.qualification. Business justification: PPAP/APQP process: a new engineering revision with `ppap_required=true` triggers a supplier qualification activity. Linking revision to the qualification record enables PPAP status tracking against th' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Qualification .

ind:cadFileReference rdf:type rdf:Property ;
    rdfs:label 'Cad File Reference' ;
    rdfs:comment 'Reference path or identifier to the Computer-Aided Design (CAD) model file associated with this revision in the Product Data Management (PDM) or PLM system.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceMarkingRequired rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Required' ;
    rdfs:comment 'Flag indicating whether CE marking (European Conformity) is required for this revision. True indicates CE marking is mandatory for European market release.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Change Impact Level' ;
    rdfs:comment 'Assessment of the impact magnitude of this revision on form, fit, function, quality, cost, or schedule. Critical indicates significant impact requiring extensive validation, low indicates minimal impact.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeJustification rdf:type rdf:Property ;
    rdfs:label 'Change Justification' ;
    rdfs:comment 'Business justification and summary description of why this revision was created. Captures the rationale for the design change, improvement, or correction.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationBaseline rdf:type rdf:Property ;
    rdfs:label 'Configuration Baseline' ;
    rdfs:comment 'The configuration baseline identifier that this revision belongs to. Used for configuration management and as-designed vs as-built reconciliation.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmAnalysisCompleted rdf:type rdf:Property ;
    rdfs:label 'Dfm Analysis Completed' ;
    rdfs:comment 'Flag indicating whether Design for Manufacturability (DFM) analysis has been completed for this revision. True indicates DFM review is complete and findings are incorporated.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dfmeaCompleted rdf:type rdf:Property ;
    rdfs:label 'Dfmea Completed' ;
    rdfs:comment 'Flag indicating whether Design Failure Mode and Effects Analysis (DFMEA) has been completed for this revision. True indicates DFMEA is complete and risk mitigation actions are defined.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interchangeabilityCode rdf:type rdf:Property ;
    rdfs:label 'Interchangeability Code' ;
    rdfs:comment 'Indicates whether this revision is interchangeable with previous revisions. Fully interchangeable means drop-in replacement, form-fit-function means functionally equivalent, retrofit required means modification needed, not interchangeable means incompatible.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleState rdf:type rdf:Property ;
    rdfs:label 'Lifecycle State' ;
    rdfs:comment 'Current lifecycle state of the revision within the Product Lifecycle Management (PLM) workflow. In-work indicates active development, in-review indicates pending approval, approved indicates ready for release, released indicates production-ready, obsolete indicates no longer valid, superseded indicates replaced by newer revision, frozen indicates locked for reference. [ENUM-REF-CANDIDATE: in_work|in_review|approved|released|obsolete|superseded|frozen — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:massProductionApproved rdf:type rdf:Property ;
    rdfs:label 'Mass Production Approved' ;
    rdfs:comment 'Flag indicating whether this revision has been approved for mass production. True indicates all validation activities are complete and production release is authorized.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pfmeaCompleted rdf:type rdf:Property ;
    rdfs:label 'Pfmea Completed' ;
    rdfs:comment 'Flag indicating whether Process Failure Mode and Effects Analysis (PFMEA) has been completed for this revision. True indicates PFMEA is complete and process controls are established.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppapRequired rdf:type rdf:Property ;
    rdfs:label 'Ppap Required' ;
    rdfs:comment 'Flag indicating whether Production Part Approval Process (PPAP) submission is required for this revision. True indicates customer or regulatory requirement for PPAP documentation.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prototypeTestDate rdf:type rdf:Property ;
    rdfs:label 'Prototype Test Date' ;
    rdfs:comment 'The date when prototype testing was completed for this revision. Null if prototype testing has not been performed.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prototypeTested rdf:type rdf:Property ;
    rdfs:label 'Prototype Tested' ;
    rdfs:comment 'Flag indicating whether a physical prototype of this revision has been built and tested. True indicates prototype validation is complete.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachCompliant rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant' ;
    rdfs:comment 'Flag indicating whether this revision complies with REACH regulation for chemical substances. True indicates compliance with EU chemical safety requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Status of regulatory compliance assessment for this revision. Indicates whether the revision meets applicable regulatory requirements (ISO, IEC, UL, CE, OSHA, EPA).' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseAuthority rdf:type rdf:Property ;
    rdfs:label 'Release Authority' ;
    rdfs:comment 'Name or identifier of the person, role, or committee that authorized the release of this revision. Captures the approval authority for traceability and compliance.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Release Authority Role' ;
    rdfs:comment 'The organizational role or title of the release authority (e.g., Chief Engineer, Engineering Manager, Change Control Board). Provides context for the approval level.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionType rdf:type rdf:Property ;
    rdfs:label 'Revision Type' ;
    rdfs:comment 'Classification of the revision indicating the magnitude of change. Major revisions represent significant design changes, minor revisions represent incremental improvements, patch revisions represent corrections, branch revisions represent parallel variant development, and prototype revisions represent pre-release experimental versions.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsCompliant rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant' ;
    rdfs:comment 'Flag indicating whether this revision complies with Restriction of Hazardous Substances (RoHS) directive. True indicates the design meets RoHS material restrictions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ulCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Ul Certification Required' ;
    rdfs:comment 'Flag indicating whether Underwriters Laboratories (UL) product safety certification is required for this revision. True indicates UL certification is mandatory for market release.' ;
    rdfs:domain ind:EngineeringRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededBySpecificationEngineeringSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Specification Engineering Specification Id' ;
    rdfs:comment 'Reference to the specification that supersedes this specification. Null if this specification is still current. Supports specification revision history and traceability.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringSpecification .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Specific criteria and test methods used to determine whether a component or assembly meets the specification requirements. Defines pass/fail thresholds for inspection, testing, and validation activities.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableStandards rdf:type rdf:Property ;
    rdfs:label 'Applicable Standards' ;
    rdfs:comment 'Comma-separated list of industry, regulatory, and international standards that this specification must comply with (e.g., IEC 61131, ISO 9001, UL 508, CE Marking, ANSI standards). Critical for design validation, supplier qualification, and regulatory compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the authorized individual who approved the specification for release. Part of the document control and approval workflow.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designAuthority rdf:type rdf:Property ;
    rdfs:label 'Design Authority' ;
    rdfs:comment 'Name or identifier of the engineering team, department, or individual responsible for the technical content and maintenance of this specification. Serves as the point of contact for specification-related questions and change requests.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format of the specification document (e.g., PDF for released documents, DOCX for drafts, DWG for CAD drawings, STEP/IGES for 3D models, XML for structured data exchange).' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'File path, URL, or document management system reference where the full specification document is stored. Typically points to a location in Siemens Teamcenter PLM Document Management or a shared engineering repository.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConditions rdf:type rdf:Property ;
    rdfs:label 'Environmental Conditions' ;
    rdfs:comment 'Specified environmental operating conditions and limits, including temperature range, humidity, vibration, shock, altitude, and exposure to chemicals or contaminants. Critical for environmental-type specifications.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the primary language of the specification document (e.g., ENG for English, DEU for German, FRA for French). Supports multi-language engineering documentation in global manufacturing operations.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStandard rdf:type rdf:Property ;
    rdfs:label 'Material Standard' ;
    rdfs:comment 'Specific material standard or grade required for the component or assembly (e.g., ASTM A36, SAE 304, ISO 898-1). Applicable primarily to material-type specifications.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obsoleteDate rdf:type rdf:Property ;
    rdfs:label 'Obsolete Date' ;
    rdfs:comment 'Date when the specification was marked as obsolete or superseded. Null if the specification is still active.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Performance Criteria' ;
    rdfs:comment 'Detailed performance requirements and acceptance criteria that the component, assembly, or system must meet. Includes quantitative metrics such as load capacity, operating temperature range, voltage ratings, cycle life, and reliability targets.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeRequired rdf:type rdf:Property ;
    rdfs:label 'Prototype Required' ;
    rdfs:comment 'Indicates whether a prototype must be built and validated before the specification is approved for production use. Supports the Advanced Product Quality Planning (APQP) and Production Part Approval Process (PPAP) workflows.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyRequirements rdf:type rdf:Property ;
    rdfs:label 'Safety Requirements' ;
    rdfs:comment 'Safety-related requirements and compliance criteria, including electrical safety, mechanical safety, functional safety, and hazard mitigation measures. Applicable to safety-type specifications and critical for certification.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the scope, applicability, and boundaries of the specification. Defines what is covered and what is explicitly excluded from the specification requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Business identifier for the specification document, typically following organizational numbering conventions. Externally-known unique code used for reference in engineering documentation, supplier communications, and design reviews.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of the specification document by its primary purpose: material (material properties and composition), functional (operational requirements), interface (connection and integration standards), environmental (operating conditions and environmental compliance), safety (safety requirements and certifications), or performance (performance criteria and benchmarks).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualificationRequired rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Required' ;
    rdfs:comment 'Indicates whether suppliers must undergo formal qualification and approval before being authorized to supply components or materials meeting this specification. Supports supplier management and procurement processes.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Standardized test method or procedure reference used to verify compliance with the specification (e.g., ASTM test methods, IEC test standards, internal test procedures). Links to quality inspection plans and validation protocols.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceSpecification rdf:type rdf:Property ;
    rdfs:label 'Tolerance Specification' ;
    rdfs:comment 'Dimensional, geometric, and functional tolerances specified for the component or assembly. Defines acceptable variation ranges for critical dimensions and characteristics, supporting Design for Manufacturability (DFM) and Statistical Process Control (SPC).' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date when the design validation was completed. Null if validation is not yet complete. Key milestone in the product development lifecycle.' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current status of the design validation and verification activities for this specification: not_started (validation not yet initiated), in_progress (validation activities underway), completed (validation successfully completed), or failed (validation did not meet acceptance criteria).' ;
    rdfs:domain ind:EngineeringSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamilyId rdf:type rdf:Property ;
    rdfs:label 'Product Family Id' ;
    rdfs:comment 'Reference to the product family or platform that this engineering project is developing or enhancing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'Actual date when the engineering project completed and the product was launched to production or market.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget amount allocated to the engineering project for all development activities and resources.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the project budget amounts.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Spent Amount' ;
    rdfs:comment 'Cumulative amount of budget spent to date on the engineering project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Strategic rationale and business case for undertaking the engineering project, including expected ROI and market drivers.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationPartners rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partners' ;
    rdfs:comment 'List of external partners, suppliers, or research institutions collaborating on the engineering project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexityScore rdf:type rdf:Property ;
    rdfs:label 'Complexity Score' ;
    rdfs:comment 'Numerical score (1-10) representing the technical and organizational complexity of the engineering project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designMethodology rdf:type rdf:Property ;
    rdfs:label 'Design Methodology' ;
    rdfs:comment 'Engineering design and development methodology being applied to the project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designReviewCount rdf:type rdf:Property ;
    rdfs:label 'Design Review Count' ;
    rdfs:comment 'Number of formal design reviews conducted during the engineering project lifecycle.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ecoCount rdf:type rdf:Property ;
    rdfs:label 'Eco Count' ;
    rdfs:comment 'Total number of Engineering Change Orders issued during the engineering project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the engineering project was officially closed or completed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentApplicationCount rdf:type rdf:Property ;
    rdfs:label 'Patent Application Count' ;
    rdfs:comment 'Number of patent applications filed as a result of innovations developed in the engineering project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programPhase rdf:type rdf:Property ;
    rdfs:label 'Program Phase' ;
    rdfs:comment 'Current lifecycle phase of the engineering project within the product development process. [ENUM-REF-CANDIDATE: concept|feasibility|design|development|validation|launch|production|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the engineering project for identification and tracking across systems.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative description of the engineering project objectives, scope, and deliverables.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name of the engineering project describing the initiative or product being developed.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current operational status of the engineering project indicating its execution state.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the engineering project based on its strategic purpose and scope.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeCount rdf:type rdf:Property ;
    rdfs:label 'Prototype Count' ;
    rdfs:comment 'Number of physical or digital prototypes developed as part of the engineering project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryComplianceScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Scope' ;
    rdfs:comment 'List of regulatory standards and certifications that the engineering project must comply with (e.g., ISO 9001, CE, UL, IEC 61131).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the engineering project was officially initiated and work began.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityTarget rdf:type rdf:Property ;
    rdfs:label 'Sustainability Target' ;
    rdfs:comment 'Environmental sustainability goals and targets for the engineering project (e.g., energy efficiency, carbon reduction, recyclability).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Target Launch Date' ;
    rdfs:comment 'Planned date for the engineering project to complete development and transition to production or market launch.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetMarketSegment rdf:type rdf:Property ;
    rdfs:label 'Target Market Segment' ;
    rdfs:comment 'Primary market segment or customer group that the engineering project is designed to serve.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamSizeCount rdf:type rdf:Property ;
    rdfs:label 'Team Size Count' ;
    rdfs:comment 'Number of engineers and team members assigned to the engineering project.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technologyPlatform rdf:type rdf:Property ;
    rdfs:label 'Technology Platform' ;
    rdfs:comment 'Core technology platform or architecture that the engineering project is based on (e.g., PLC, SCADA, IoT, IIoT).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultId rdf:type rdf:Property ;
    rdfs:label 'Test Result Id' ;
    rdfs:comment 'Unique identifier for the engineering test result record. Primary key for the test result entity.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTestResultId rdf:type rdf:Property ;
    rdfs:label 'Original Test Result Id' ;
    rdfs:comment 'Reference to the original test result record if this is a retest. Creates traceability chain for test iterations.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestResult .

ind:acceptanceCriteriaLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Lower Limit' ;
    rdfs:comment 'Minimum acceptable value for the test measurement. Defines the lower boundary of the pass/fail acceptance range.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptanceCriteriaTarget rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Target' ;
    rdfs:comment 'Target or nominal value for the test measurement. Represents the ideal design specification value within the acceptance range.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptanceCriteriaUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Upper Limit' ;
    rdfs:comment 'Maximum acceptable value for the test measurement. Defines the upper boundary of the pass/fail acceptance range.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildNumber rdf:type rdf:Property ;
    rdfs:label 'Build Number' ;
    rdfs:comment 'Prototype build iteration number or production batch identifier. Tracks which manufacturing build or prototype iteration the tested unit belongs to.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the regulatory or certification authority for which this test evidence is required (e.g., UL, TUV, CSA, FCC). Applicable when regulatory submission flag is true.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dvpRReference rdf:type rdf:Property ;
    rdfs:label 'Dvp R Reference' ;
    rdfs:comment 'Reference to the Design Verification Plan and Report document that governs this test. Links test execution to the master validation plan.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredValueUnit rdf:type rdf:Property ;
    rdfs:label 'Measured Value Unit' ;
    rdfs:comment 'Unit of measure for the measured value (e.g., volts, amps, degrees Celsius, newtons, cycles). Ensures correct interpretation of test measurements.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypePhase rdf:type rdf:Property ;
    rdfs:label 'Prototype Phase' ;
    rdfs:comment 'Development phase or maturity stage of the tested unit. Indicates whether the unit is a concept prototype, alpha build, beta unit, pre-production sample, or production unit.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this test result is required for regulatory certification or compliance submission (e.g., UL, CE, FCC). Flags test data needed for regulatory dossiers.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Indicates whether this test is a retest of a previously failed or inconclusive test. Used to track test iteration history.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisRequired rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Required' ;
    rdfs:comment 'Indicates whether a formal root cause analysis (RCA) is required for this test result. Typically true for test failures or unexpected results.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date when the test was executed. Principal business event timestamp for the test activity.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testDurationHours rdf:type rdf:Property ;
    rdfs:label 'Test Duration Hours' ;
    rdfs:comment 'Total elapsed time for test execution measured in hours. Captures the actual test run time for endurance and long-duration tests.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test End Timestamp' ;
    rdfs:comment 'Precise date and time when the test execution completed. Used for duration calculation and detailed test timeline tracking.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testNotes rdf:type rdf:Property ;
    rdfs:label 'Test Notes' ;
    rdfs:comment 'Free-form notes, observations, or comments recorded by the test engineer during test execution. Captures contextual information not covered by structured fields.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testNumber rdf:type rdf:Property ;
    rdfs:label 'Test Number' ;
    rdfs:comment 'Business identifier for the test execution. Externally-known unique test reference number used for traceability and reporting.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testOutcome rdf:type rdf:Property ;
    rdfs:label 'Test Outcome' ;
    rdfs:comment 'Overall pass/fail result of the test execution. Indicates whether the tested unit met the acceptance criteria defined in the test specification.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPurpose rdf:type rdf:Property ;
    rdfs:label 'Test Purpose' ;
    rdfs:comment 'Business objective or reason for conducting the test. Describes the validation goal, such as design verification, production qualification, regulatory compliance, or failure investigation.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSpecificationVersion rdf:type rdf:Property ;
    rdfs:label 'Test Specification Version' ;
    rdfs:comment 'Version or revision of the test specification document used for this test execution. Ensures traceability to the correct test procedure version.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStandardReference rdf:type rdf:Property ;
    rdfs:label 'Test Standard Reference' ;
    rdfs:comment 'Industry or regulatory standard governing the test procedure. References the specific standard, specification, or protocol followed during test execution (e.g., IEC 61131-2, UL 508, ISO 16750).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Start Timestamp' ;
    rdfs:comment 'Precise date and time when the test execution began. Used for duration calculation and detailed test timeline tracking.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the test execution. Tracks the test through its workflow from scheduling to completion.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Classification of the test performed. Defines the category of validation activity conducted on the unit under test. [ENUM-REF-CANDIDATE: functional|environmental|emc|safety|endurance|performance|reliability|thermal|vibration|shock|humidity|salt_spray|dust|ingress_protection — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Order-to-Production report requires linking each work order to the originating sales opportunity for fulfillment tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.plan. Business justification: Work orders execute against supply plans. Supply planners need to reconcile work order actuals (actual_cost, yield_rate, scrap) against the originating supply plan for plan adherence KPIs. planned_ord' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual total cost incurred for this work order, including material, labor, and overhead.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when production execution was completed on the shop floor.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual quantity of finished goods produced and confirmed, in base unit of measure.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when production execution began on the shop floor.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of work order completion based on actual quantity versus planned quantity (0.00 to 100.00).' ;
    rdfs:domain ind:ProductionWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Minutes' ;
    rdfs:comment 'Actual cycle time in minutes to produce one unit, used for OEE calculation and capacity planning.' ;
    rdfs:domain ind:ProductionWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total unplanned downtime in minutes during work order execution, impacting OEE availability.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeePercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Percentage' ;
    rdfs:comment 'Calculated OEE percentage for this work order, combining availability, performance, and quality metrics (0.00 to 100.00).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Target quantity of finished goods to be produced by this work order, in base unit of measure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Scheduling priority assigned to this work order, determining its sequence in the production queue.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionNotes rdf:type rdf:Property ;
    rdfs:label 'Production Notes' ;
    rdfs:comment 'Free-text notes capturing special instructions, issues, or observations during work order execution.' ;
    rdfs:domain ind:ProductionWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of material scrapped or rejected during production, in base unit of measure.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Rate Percentage' ;
    rdfs:comment 'Percentage of material scrapped or rejected during production (0.00 to 100.00).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Actual time in minutes required to set up equipment and tooling before production begins.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taktTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Takt Time Minutes' ;
    rdfs:comment 'Target takt time in minutes per unit, representing the rate at which products must be completed to meet customer demand.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipValue rdf:type rdf:Property ;
    rdfs:label 'Wip Value' ;
    rdfs:comment 'Current financial value of work in progress for this order, including material, labor, and overhead costs.' ;
    rdfs:domain ind:ProductionWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Rate Percentage' ;
    rdfs:comment 'Percentage of good units produced versus total units started, used for OEE quality calculation (0.00 to 100.00).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Unique identifier for the production schedule record. Primary key.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:scheduleLineId rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Id' ;
    rdfs:comment 'Foreign key linking to order.schedule_line. Business justification: MRP pegging: production schedules are generated to fulfill specific order schedule lines (confirmed delivery dates/quantities). This ATP and MRP pegging relationship is fundamental to industrial manuf' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleLine .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this schedule requires management approval before release. True for high-value, high-risk, or exception schedules; false for routine schedules.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when this schedule was cancelled. Null if the schedule was not cancelled.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capacityRequirementHours rdf:type rdf:Property ;
    rdfs:label 'Capacity Requirement Hours' ;
    rdfs:comment 'Total machine or labor hours required to complete this schedule. Used for capacity planning and load leveling.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Timestamp when production for this schedule was completed. Used for schedule performance analysis and cycle time measurement.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firmedFlag rdf:type rdf:Property ;
    rdfs:label 'Firmed Flag' ;
    rdfs:comment 'Indicates whether this schedule is firmed (locked) and should not be automatically rescheduled by planning systems. True means the schedule is manually controlled; false means it can be adjusted by MRP/APS.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freezeHorizonDate rdf:type rdf:Property ;
    rdfs:label 'Freeze Horizon Date' ;
    rdfs:comment 'Date beyond which this schedule is frozen and cannot be changed without formal approval. Protects near-term execution from planning volatility.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizingRule rdf:type rdf:Property ;
    rdfs:label 'Lot Sizing Rule' ;
    rdfs:comment 'Algorithm used to determine production lot sizes. Fixed lot uses a constant quantity; lot-for-lot matches demand exactly; EOQ optimizes ordering costs; POQ aggregates demand over periods.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'Code identifying the MRP controller or planner responsible for this schedule. Used for accountability and workload distribution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peggingReference rdf:type rdf:Property ;
    rdfs:label 'Pegging Reference' ;
    rdfs:comment 'Reference to the demand source (sales order, forecast, safety stock) that this schedule is pegged to. Enables traceability from supply to demand.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningBucket rdf:type rdf:Property ;
    rdfs:label 'Planning Bucket' ;
    rdfs:comment 'Time granularity of the schedule planning horizon. Daily for short-term detailed scheduling, weekly for medium-term planning, monthly for long-term capacity planning.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonWeeks rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Weeks' ;
    rdfs:comment 'Number of weeks into the future that this schedule covers. Defines the forward visibility window for production planning.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningStrategy rdf:type rdf:Property ;
    rdfs:label 'Planning Strategy' ;
    rdfs:comment 'Manufacturing strategy governing how this schedule is planned and executed. Make-to-stock builds for inventory; make-to-order builds against customer orders; assemble-to-order configures from standard components; engineer-to-order designs and builds custom products.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Relative priority of this schedule compared to other schedules. Lower numbers indicate higher priority. Used for resource allocation and sequencing decisions.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Timestamp when this schedule was released for execution. Marks the transition from planning to active production.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runTimeHours rdf:type rdf:Property ;
    rdfs:label 'Run Time Hours' ;
    rdfs:comment 'Estimated time required to produce the planned quantity, excluding setup and teardown. Used for cycle time analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleSource rdf:type rdf:Property ;
    rdfs:label 'Schedule Source' ;
    rdfs:comment 'System or process that generated this schedule. MRP run for material requirements planning; APS optimization for advanced planning and scheduling; manual planning for planner-created schedules; demand forecast for forecast-driven schedules; customer order for order-driven schedules.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the schedule by planning level. MPS for top-level finished goods; FAS for final assembly operations; RCCP for high-level capacity validation; MRP for detailed component planning.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date when production for this schedule is expected to be completed. Used for order promising and delivery planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledFinishTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Time' ;
    rdfs:comment 'Precise timestamp when production execution is scheduled to finish, used for detailed capacity loading and sequencing.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when production for this schedule is expected to begin. Key input for capacity planning and material availability checks.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise timestamp when production execution is scheduled to start, including shift and time-of-day information for detailed shop floor scheduling.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:setupTimeHours rdf:type rdf:Property ;
    rdfs:label 'Setup Time Hours' ;
    rdfs:comment 'Estimated time required to set up equipment and tooling before production can begin. Part of total lead time calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the schedule. Incremented each time the schedule is revised or replanned.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityPerShift rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Per Shift' ;
    rdfs:comment 'Standard available capacity of the work center per shift, measured in the capacity category unit.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'Unit of measure for capacity planning (e.g., machine hours, labor hours, throughput units).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPlanningGroup rdf:type rdf:Property ;
    rdfs:label 'Capacity Planning Group' ;
    rdfs:comment 'Grouping code for aggregating work centers in capacity planning and leveling activities.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlKey rdf:type rdf:Property ;
    rdfs:label 'Control Key' ;
    rdfs:comment 'Control key defining how operations are processed at this work center (e.g., internal processing, external processing, inspection).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Efficiency Rate Percent' ;
    rdfs:comment 'Standard efficiency rate of the work center expressed as a percentage, representing the ratio of actual output to theoretical maximum output.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulaKey rdf:type rdf:Property ;
    rdfs:label 'Formula Key' ;
    rdfs:comment 'Formula key used for calculating operation times and capacity requirements at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Mes Integration Enabled' ;
    rdfs:comment 'Indicates whether this work center is integrated with the MES for real-time shop floor control and data collection.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfMachines rdf:type rdf:Property ;
    rdfs:label 'Number Of Machines' ;
    rdfs:comment 'Count of individual machines or equipment units within this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfOperators rdf:type rdf:Property ;
    rdfs:label 'Number Of Operators' ;
    rdfs:comment 'Standard number of operators or workers assigned to this work center during normal operation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeBaselineTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Baseline Target Percent' ;
    rdfs:comment 'Target OEE baseline for this work center, calculated as Availability × Performance × Quality. Used for capacity planning and performance benchmarking.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plcAddress rdf:type rdf:Property ;
    rdfs:label 'Plc Address' ;
    rdfs:comment 'Network address or identifier of the PLC controlling this work center, used for SCADA and MES integration.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaTagPrefix rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Prefix' ;
    rdfs:comment 'SCADA tag prefix used to identify real-time data points from this work center in the process control system.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingType rdf:type rdf:Property ;
    rdfs:label 'Scheduling Type' ;
    rdfs:comment 'Scheduling strategy used for operations at this work center (forward scheduling, backward scheduling, or capacity-only).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardProcessingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Processing Time Minutes' ;
    rdfs:comment 'Standard processing or cycle time in minutes per unit for operations performed at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardQueueTimeHours rdf:type rdf:Property ;
    rdfs:label 'Standard Queue Time Hours' ;
    rdfs:comment 'Standard queue time in hours representing the typical wait time before an operation begins at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Setup Time Minutes' ;
    rdfs:comment 'Standard setup or changeover time in minutes required to prepare the work center for a new production run.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardTeardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Teardown Time Minutes' ;
    rdfs:comment 'Standard teardown time in minutes required to complete and clean up after an operation at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Target utilization rate of the work center expressed as a percentage, representing the ratio of actual operating time to available time.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Date from which this work center configuration is effective and available for production planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'Date until which this work center configuration is effective. Null indicates indefinite validity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'Classification of the work center type indicating the nature of the production resource.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Human-readable name or description of the work center (e.g., Assembly Line 3, CNC Machining Cell A, Welding Station 5).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current lifecycle status of the work center indicating its operational availability.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'Standard lot size or batch quantity for which the routing times and resource requirements are defined. All operation times are calculated relative to this base quantity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counter rdf:type rdf:Property ;
    rdfs:label 'Counter' ;
    rdfs:comment 'Sequential counter within the routing group. Together with routing_group, forms an alternative business key.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultRouting rdf:type rdf:Property ;
    rdfs:label 'Is Default Routing' ;
    rdfs:comment 'Indicates whether this routing is the default routing for the material. True if this is the primary routing; false if it is an alternative.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantomRouting rdf:type rdf:Property ;
    rdfs:label 'Is Phantom Routing' ;
    rdfs:comment 'Indicates whether this is a phantom routing that is automatically consumed without generating a separate production order. Used for subassemblies that are immediately incorporated into parent assemblies.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Most recent date on which this routing was used in a production order or work order. Used to identify obsolete or inactive routings.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizeFrom rdf:type rdf:Property ;
    rdfs:label 'Lot Size From' ;
    rdfs:comment 'Minimum lot size for which this routing is applicable. Supports lot-size-dependent routing selection.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeTo rdf:type rdf:Property ;
    rdfs:label 'Lot Size To' ;
    rdfs:comment 'Maximum lot size for which this routing is applicable. Null indicates no upper limit.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingDescription rdf:type rdf:Property ;
    rdfs:label 'Routing Description' ;
    rdfs:comment 'Detailed textual description of the routing purpose, scope, and special instructions. Provides context for production planners and shop floor operators.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingGroup rdf:type rdf:Property ;
    rdfs:label 'Routing Group' ;
    rdfs:comment 'Grouping code for related routings. Used to organize routings by product family, process type, or manufacturing cell.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Business identifier for the routing. Externally visible routing code used in production planning and shop floor documentation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Draft routings are under development; released routings are approved for use; active routings are currently in production; inactive routings are temporarily suspended; obsolete routings are retired; blocked routings are prohibited from use.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingText rdf:type rdf:Property ;
    rdfs:label 'Routing Text' ;
    rdfs:comment 'Extended free-form text field for detailed routing notes, special handling instructions, safety warnings, and quality requirements.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing purpose. Production routings define standard manufacturing sequences; inspection routings define quality check sequences; rework routings define repair processes; universal routings apply across multiple materials; rate routings define continuous process flows; reference routings serve as templates.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Unique identifier of this routing in the source system. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'Standard cost to execute this routing for the base quantity. Includes labor, machine, overhead, and tooling costs. Used for cost accounting and variance analysis.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Labor Time Minutes' ;
    rdfs:comment 'Total cumulative labor time in minutes across all operations for the base quantity. Labor time may scale differently than machine time.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Lead Time Hours' ;
    rdfs:comment 'Total cumulative lead time in hours required to complete all operations in this routing for the base quantity. Includes setup, machine, labor, and queue times.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Machine Time Minutes' ;
    rdfs:comment 'Total cumulative machine processing time in minutes across all operations for the base quantity. Machine time scales with lot size.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperationCount rdf:type rdf:Property ;
    rdfs:label 'Total Operation Count' ;
    rdfs:comment 'Total number of operations (steps) defined in this routing. Derived from routing operation line items.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Setup Time Minutes' ;
    rdfs:comment 'Total cumulative setup time in minutes across all operations for the base quantity. Setup time is independent of lot size.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of times this routing has been used in production orders or work orders. Indicates routing popularity and stability.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Sum of all scheduled break periods (lunch, rest breaks) within the shift, in minutes. Subtracted from gross duration to calculate net available time for production.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakSchedule rdf:type rdf:Property ;
    rdfs:label 'Break Schedule' ;
    rdfs:comment 'Textual description of the break structure, including start times and durations (e.g., \'10:00-10:15 (15 min), 12:00-12:30 (30 min)\'). Used for communication to shop floor personnel and HMI display.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverAllowanceMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Allowance Minutes' ;
    rdfs:comment 'Standard time reserved within the shift for product changeovers, tool changes, or setup activities. Used to adjust net available time for multi-product shifts and to calculate planned downtime for OEE.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Days Of Week' ;
    rdfs:comment 'Comma-separated list of weekday codes (MON, TUE, WED, THU, FRI, SAT, SUN) indicating which days this shift pattern applies to. Used for weekly capacity planning and workforce rostering.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Time of day when the shift ends, in HH:mm:ss format (24-hour clock). May be less than start_time for shifts that cross midnight. Used to calculate gross shift duration.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Gross Duration Minutes' ;
    rdfs:comment 'Total elapsed time of the shift from start to end, in minutes, including all breaks and non-productive time. Used as the denominator for availability calculations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handoverDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Handover Duration Minutes' ;
    rdfs:comment 'Planned overlap time between consecutive shifts for handover communication, equipment status review, and safety briefing. Subtracted from net available time if included in shift boundaries. Nullable for non-continuous operations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isContinuousOperation rdf:type rdf:Property ;
    rdfs:label 'Is Continuous Operation' ;
    rdfs:comment 'Indicates whether this shift is part of a 24/7 continuous manufacturing operation (True) or a discrete batch operation (False). Used to determine handover requirements and WIP tracking rules.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to base labor rates for this shift type (e.g., 1.0 for regular, 1.5 for overtime, 2.0 for holiday). Used for labor cost calculation and variance analysis.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAvailableMinutes rdf:type rdf:Property ;
    rdfs:label 'Net Available Minutes' ;
    rdfs:comment 'Net productive time available for manufacturing execution, calculated as gross_duration_minutes minus break_duration_minutes. Used as the planned production time for OEE availability calculation and takt time planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfBreaks rdf:type rdf:Property ;
    rdfs:label 'Number Of Breaks' ;
    rdfs:comment 'Count of distinct break periods scheduled within the shift (e.g., 2 for a shift with one lunch break and one rest break). Used for workforce scheduling and labor compliance reporting.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOutputQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Output Quantity' ;
    rdfs:comment 'Target production volume for this shift, in base unit of measure. Used as the denominator for performance OEE calculation and as input to takt time calculation. Nullable for non-production shifts.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationPattern rdf:type rdf:Property ;
    rdfs:label 'Rotation Pattern' ;
    rdfs:comment 'Description of the multi-day or multi-week rotation cycle this shift belongs to (e.g., \'2-2-3 Continental\', \'4-on-4-off\', \'DuPont 12-hour\'). Used for long-term workforce scheduling and fatigue management.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Ordinal position of this shift within a daily rotation (e.g., 1 for first shift, 2 for second shift, 3 for third shift). Used for shift handover reporting and continuous production tracking.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftCategory rdf:type rdf:Property ;
    rdfs:label 'Shift Category' ;
    rdfs:comment 'Broad categorization of shift purpose. Production shifts are used for manufacturing execution and OEE calculation; non-production shifts (e.g., maintenance, training) are excluded from throughput metrics; mixed shifts include both activities.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Human-readable name of the shift (e.g., Day Shift, Night Shift, Morning Shift). Used for display in reports and HMI screens.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle state of the shift definition. Active shifts are available for scheduling; inactive shifts are temporarily disabled; draft shifts are under review; archived shifts are retained for historical reference only.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift pattern indicating the nature of the working period. Regular shifts are standard production periods; overtime, weekend, and holiday shifts may carry premium labor rates; maintenance and emergency shifts are non-production periods.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Time of day when the shift begins, in HH:mm:ss format (24-hour clock). Used to calculate shift boundaries for production tracking and OEE reporting.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taktTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Takt Time Seconds' ;
    rdfs:comment 'Target cycle time per unit to meet customer demand, calculated as net_available_minutes * 60 / planned_output_quantity. Used for production pacing and line balancing. Nullable if not applicable to this shift type.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftReportId rdf:type rdf:Property ;
    rdfs:label 'Shift Report Id' ;
    rdfs:comment 'Unique identifier for the shift report record. Primary key.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualGoodQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Good Quantity' ;
    rdfs:comment 'Actual quantity of conforming units produced during the shift that passed quality inspection.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualProductionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Production Time Minutes' ;
    rdfs:comment 'Actual time the work center was actively producing during the shift, excluding downtime.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Availability Percentage' ;
    rdfs:comment 'Percentage of planned production time that the equipment was available and operating, calculated as (Planned Time - Downtime) / Planned Time × 100.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverCount rdf:type rdf:Property ;
    rdfs:label 'Changeover Count' ;
    rdfs:comment 'Number of production changeovers or setups performed during the shift.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'Total time spent on changeovers and setups during the shift.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Seconds' ;
    rdfs:comment 'Average time in seconds to complete one production cycle or unit during the shift.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the primary source system from which shift data was captured (MES, SCADA, ERP, or manual entry).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumptionKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh' ;
    rdfs:comment 'Total electrical energy consumed by the work center during the shift, measured in kilowatt-hours.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether this shift report requires management escalation due to performance issues, quality problems, or safety concerns.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialConsumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Material Consumed Quantity' ;
    rdfs:comment 'Total quantity of raw materials or components consumed during the shift.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialWasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Material Waste Quantity' ;
    rdfs:comment 'Quantity of material wasted or lost during production beyond normal scrap allowances.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorCount rdf:type rdf:Property ;
    rdfs:label 'Operator Count' ;
    rdfs:comment 'Number of operators assigned to the work center during this shift.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performancePercentage rdf:type rdf:Property ;
    rdfs:label 'Performance Percentage' ;
    rdfs:comment 'Percentage of maximum possible output achieved during operating time, calculated as (Actual Output / Theoretical Maximum Output) × 100.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Production Time Minutes' ;
    rdfs:comment 'Total planned available production time for the shift, excluding scheduled breaks and maintenance windows.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether production output from this shift is on quality hold pending inspection or investigation.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Percentage' ;
    rdfs:comment 'Percentage of good units produced out of total units, calculated as (Good Quantity / Total Produced Quantity) × 100.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Closed Timestamp' ;
    rdfs:comment 'Timestamp when the shift report was officially closed and finalized in the MES system.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Created Timestamp' ;
    rdfs:comment 'Timestamp when the shift report record was first created in the system.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Business identifier for the shift report, typically formatted as YYYYMMDD-SHIFT-WORKCENTER.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of units requiring rework or reprocessing to meet quality standards.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'Calendar date on which the shift occurred.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Shift Duration Minutes' ;
    rdfs:comment 'Total duration of the shift in minutes, calculated from start to end timestamp.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift End Timestamp' ;
    rdfs:comment 'Actual timestamp when the shift ended production activities.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the shift started production activities.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:throughputRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Throughput Rate Per Hour' ;
    rdfs:comment 'Average number of units produced per hour during the shift.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProducedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Produced Quantity' ;
    rdfs:comment 'Total quantity produced during the shift, including good, scrap, and rework units.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionDowntimeEventId rdf:type rdf:Property ;
    rdfs:label 'Production Downtime Event Id' ;
    rdfs:comment 'Unique identifier for the production downtime event record. Primary key.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.capacity_plan. Business justification: Downtime events directly impact capacity plan actuals. Capacity planners reconcile unplanned downtime against capacity plans to update available capacity, trigger replanning, and calculate capacity va' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityPlan .

ind:alarmCode rdf:type rdf:Property ;
    rdfs:label 'Alarm Code' ;
    rdfs:comment 'SCADA or DCS alarm code that triggered the downtime event. Used to correlate downtime with specific equipment faults.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmDescription rdf:type rdf:Property ;
    rdfs:label 'Alarm Description' ;
    rdfs:comment 'Human-readable description of the SCADA alarm that initiated the downtime event.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeEventNumber rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Number' ;
    rdfs:comment 'Business-readable unique identifier for the downtime event, typically generated by MES or SCADA system.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeReason rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason' ;
    rdfs:comment 'Operator or supervisor entered reason for the downtime event. Free-text field capturing immediate observed cause.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnOee rdf:type rdf:Property ;
    rdfs:label 'Impact On Oee' ;
    rdfs:comment 'Calculated percentage impact of this downtime event on the work center or line OEE for the shift or day. Expressed as percentage points lost.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Flag indicating whether this downtime event record is currently active. False indicates the record has been logically deleted or superseded.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Flag indicating whether this downtime event is part of a recurring pattern at this work center or equipment. True if similar events have occurred within the past 30 days.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mttrMinutes rdf:type rdf:Property ;
    rdfs:label 'Mttr Minutes' ;
    rdfs:comment 'Mean time to repair for this type of downtime event, calculated from historical data. Used for benchmarking and performance tracking.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Flag indicating whether automated notifications were sent to supervisors, maintenance team, or management when this downtime event occurred.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of preventive measures implemented to avoid recurrence of this type of downtime event.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLossUnits rdf:type rdf:Property ;
    rdfs:label 'Production Loss Units' ;
    rdfs:comment 'Estimated quantity of production units lost due to this downtime event. Calculated based on standard cycle time and downtime duration.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionLossValue rdf:type rdf:Property ;
    rdfs:label 'Production Loss Value' ;
    rdfs:comment 'Estimated financial value of production lost due to this downtime event. Calculated using standard cost per unit and production loss units.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recorded Timestamp' ;
    rdfs:comment 'Date and time when this downtime event record was first created in the system. Audit trail field.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recurrenceCount rdf:type rdf:Property ;
    rdfs:label 'Recurrence Count' ;
    rdfs:comment 'Number of times this type of downtime event has occurred at this work center or equipment within the past 30 days. Used for chronic loss identification.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Description of the corrective action taken to resolve the downtime event and restore production.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department accountable for resolving the downtime event: production (operator-related), maintenance (equipment repair), quality (inspection/testing), materials (supply chain), engineering (design/process), operations (planning/scheduling).' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Unique identifier for the production goods receipt event. Primary key for this entity.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'The production confirmation number from the MES or ERP system that triggered this goods receipt. Links shop floor execution to inventory posting.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Reference number from the physical delivery documentation or packing slip accompanying the goods. Used for reconciliation with physical documents.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month) within the fiscal year when the goods receipt was posted. Used for monthly financial closing and reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The unique document number generated by the ERP system for this goods receipt transaction. This is the business identifier used for tracking and audit purposes.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt document. Indicates whether the receipt has been successfully posted, reversed, cancelled, or is awaiting quality inspection.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP movement type code that classifies the type of inventory transaction. For production goods receipts, typically 101 (goods receipt to stock) or 131 (goods receipt from production order).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:note rdf:type rdf:Property ;
    rdfs:label 'Note' ;
    rdfs:comment 'Free-text notes or comments entered by the operator or warehouse personnel regarding the goods receipt. Captures exceptions, observations, or special handling instructions.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'The total quantity originally planned to be produced on the work order. Used to calculate yield and completion percentage.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingUser rdf:type rdf:Property ;
    rdfs:label 'Posting User' ;
    rdfs:comment 'The system user ID who posted the goods receipt transaction in the ERP system. Used for audit trail and accountability.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The precise date and time when the goods were physically received and confirmed on the shop floor or warehouse. Captures the real-world event time for production completion.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The quantity of finished or semi-finished goods received and posted to inventory. Measured in the base unit of measure for the material.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'The material reservation number that was created for the work order and fulfilled by this goods receipt. Links production output to material planning.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The document number of the reversal transaction if this goods receipt was reversed. Provides audit trail for corrections.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for reversing the goods receipt (e.g., quantity error, wrong material, quality issue). Used for root cause analysis.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'The percentage of good output relative to the total input or planned quantity. Calculated as (received_quantity / order_quantity) * 100. Key OEE component.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Campaign or project code associated with this production run, used for grouping related runs for reporting and analysis.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Timestamp' ;
    rdfs:comment 'Scheduled date and time when the production run is planned to complete execution.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled date and time when the production run is planned to begin execution.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business identifier for the production run campaign, externally visible and used for tracking and reporting purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the production run indicating its operational state.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the production run indicating the purpose or nature of the execution (standard production, pilot run, rework campaign, validation run, trial batch, or extended campaign).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputRate rdf:type rdf:Property ;
    rdfs:label 'Throughput Rate' ;
    rdfs:comment 'Average throughput rate achieved during the production run, measured as units produced per hour.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Cycle Time Minutes' ;
    rdfs:comment 'Total cycle time for the production run, representing the sum of all processing time across all operations, measured in minutes.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Downtime Minutes' ;
    rdfs:comment 'Total unplanned downtime during the production run, measured in minutes.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualOeePercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Oee Percentage' ;
    rdfs:comment 'Most recent calculated Overall Equipment Effectiveness percentage for this production line based on actual performance data.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation implemented on the production line, ranging from manual operations to fully automated lights-out manufacturing.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Capacity Constraint Flag' ;
    rdfs:comment 'Indicates whether this production line is identified as a bottleneck or capacity constraint in the manufacturing process requiring special attention in scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designThroughputRate rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Rate' ;
    rdfs:comment 'Theoretical maximum production rate of the line measured in units per hour under ideal conditions. Used for capacity planning and OEE calculations.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwhPerUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Unit' ;
    rdfs:comment 'Average energy consumption in kilowatt-hours required to produce one unit of output on this production line. Used for energy management and cost analysis.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Indicates whether this production line is subject to environmental compliance monitoring and reporting requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpWorkCenterCode rdf:type rdf:Property ;
    rdfs:label 'Erp Work Center Code' ;
    rdfs:comment 'Corresponding work center code in the ERP system for integration with production planning and costing modules.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMajorUpgradeDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Upgrade Date' ;
    rdfs:comment 'Date of the most recent major upgrade or modernization performed on the production line equipment or control systems.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:layoutDiagramUrl rdf:type rdf:Property ;
    rdfs:label 'Layout Diagram Url' ;
    rdfs:comment 'Reference URL or document path to the physical layout diagram or CAD drawing of the production line configuration.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Unique business identifier code for the production line used across MES and ERP systems. Externally-known identifier for scheduling, capacity planning, and shop floor control.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable name of the production line for identification and reporting purposes.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the production line based on its primary manufacturing function. Determines the type of operations performed on this line.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesLineIdentifier rdf:type rdf:Property ;
    rdfs:label 'Mes Line Identifier' ;
    rdfs:comment 'Unique identifier for this production line in the Manufacturing Execution System used for shop floor control and production tracking.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtbfHours rdf:type rdf:Property ;
    rdfs:label 'Mtbf Hours' ;
    rdfs:comment 'Average time between equipment failures on this production line, used for reliability analysis and preventive maintenance planning.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mttrHours rdf:type rdf:Property ;
    rdfs:label 'Mttr Hours' ;
    rdfs:comment 'Average time required to repair and restore this production line to operational status after a failure event.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfStations rdf:type rdf:Property ;
    rdfs:label 'Number Of Stations' ;
    rdfs:comment 'Total count of work stations or process steps configured on this production line. Defines the line configuration and complexity.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedAvailabilityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Planned Availability Hours Per Day' ;
    rdfs:comment 'Total hours per day that the production line is scheduled to be available for production, excluding planned maintenance windows.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDecommissionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Decommission Date' ;
    rdfs:comment 'Planned date for decommissioning or retirement of this production line from active service.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether output from this production line requires mandatory quality inspection before release to inventory.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Required' ;
    rdfs:comment 'List of safety certifications or compliance requirements applicable to this production line based on the products manufactured and jurisdictional regulations.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaSystemTag rdf:type rdf:Property ;
    rdfs:label 'Scada System Tag' ;
    rdfs:comment 'Unique tag identifier in the SCADA system used to monitor and control this production line in real-time.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Operating shift pattern configured for this production line defining daily operational hours and crew rotation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardOperatingProcedureUrl rdf:type rdf:Property ;
    rdfs:label 'Standard Operating Procedure Url' ;
    rdfs:comment 'Reference URL or document path to the standard operating procedures governing operation of this production line.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOeePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Oee Percentage' ;
    rdfs:comment 'Target Overall Equipment Effectiveness percentage for this production line, representing the goal for availability, performance, and quality combined.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Throughput Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the throughput rate indicating how production output is quantified for this line.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessType rdf:type rdf:Property ;
    rdfs:label 'Business Type' ;
    rdfs:comment 'Classification of the supplier based on the type of goods or services provided. OEM (Original Equipment Manufacturer) supplies finished components, distributor resells products, raw_material provides base materials, MRO (Maintenance Repair Operations) supplies consumables, subcontractor provides manufacturing services, service_provider delivers non-manufacturing services.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'Primary street address line for the supplier\'s corporate headquarters. Used for legal correspondence, audit notices, and official communications.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'Secondary address line for suite, building, or floor information at the supplier\'s headquarters location.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City or municipality where the supplier\'s headquarters is located.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'Three-letter ISO country code for the supplier\'s headquarters location. May differ from incorporation country for multinational organizations.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the supplier\'s headquarters location.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region for the supplier\'s headquarters address.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationCountry rdf:type rdf:Property ;
    rdfs:label 'Incorporation Country' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the supplier is legally incorporated and registered. Used for trade compliance, tax jurisdiction, and regulatory reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Standard three-letter Incoterms code defining the division of costs, risks, and responsibilities between buyer and seller in international trade (e.g., FOB, CIF, DDP). Published by International Chamber of Commerce. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso14001 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds valid ISO 14001 Environmental Management System certification. True if certified, False if not certified or certification expired.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso45001 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds valid ISO 45001 Occupational Health and Safety Management System certification. True if certified, False if not certified or certification expired.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso9001 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds valid ISO 9001 Quality Management System certification. True if certified, False if not certified or certification expired.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent supplier audit conducted by Manufacturing\'s quality or procurement team. Used to track audit frequency and schedule next audit per supplier management policy.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastScorecardDate rdf:type rdf:Property ;
    rdfs:label 'Last Scorecard Date' ;
    rdfs:comment 'Date of the most recent supplier scorecard evaluation. Scorecards typically assess quality, delivery, cost, and responsiveness on a quarterly or annual basis.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minorityOwned rdf:type rdf:Property ;
    rdfs:label 'Minority Owned' ;
    rdfs:comment 'Indicates whether the supplier is certified as a minority-owned business enterprise. Used for diversity supplier programs and regulatory reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next supplier audit based on risk rating, performance, and audit frequency policy. Used for audit planning and compliance tracking.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage of purchase orders delivered on or before the requested delivery date over the evaluation period. Key performance indicator (KPI) for supplier scorecard and performance management. Expressed as percentage (0.00 to 100.00).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScorecardRating rdf:type rdf:Property ;
    rdfs:label 'Overall Scorecard Rating' ;
    rdfs:comment 'Composite supplier performance score from the most recent scorecard evaluation, typically on a scale of 0.0 to 10.0 or 0.0 to 100.0. Aggregates quality, delivery, cost, and service metrics into a single performance indicator.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms negotiated with the supplier (e.g., Net 30, Net 60, 2/10 Net 30). Defines the payment due date and any early payment discounts available.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the supplier\'s preferred currency for invoicing and payment transactions (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary supplier contact for business communications, purchase orders, and quality notifications.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the supplier organization for procurement, quality, and supply chain coordination.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Business phone number for the primary supplier contact including country code and extension if applicable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Quality and compliance qualification status indicating whether the supplier has passed required audits, certifications, and capability assessments. Qualified suppliers meet all requirements, conditional suppliers have minor gaps, not_qualified suppliers failed assessment, under_review suppliers are being evaluated.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate' ;
    rdfs:comment 'Percentage of received materials that passed incoming quality inspection without rejection or rework over the evaluation period. Key performance indicator (KPI) for supplier quality performance. Expressed as percentage (0.00 to 100.00).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when the business relationship with this supplier was terminated or the vendor record was deactivated. Null for active suppliers. Used for supplier lifecycle tracking and historical analysis.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when the business relationship with this supplier was established and the vendor record was first activated. Used for relationship tenure analysis and supplier lifecycle reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk assessment for the supplier based on financial stability, geopolitical factors, quality performance, delivery reliability, and compliance history. Used for supply chain risk management and contingency planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Number' ;
    rdfs:comment 'Vendor master number from SAP S/4HANA MM (Materials Management) or SAP Ariba. This is the authoritative supplier identifier in the ERP system used for procurement transactions.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusiness rdf:type rdf:Property ;
    rdfs:label 'Small Business' ;
    rdfs:comment 'Indicates whether the supplier qualifies as a small business based on revenue, employee count, or regulatory definitions. Used for small business procurement programs and compliance reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierCategory rdf:type rdf:Property ;
    rdfs:label 'Supplier Category' ;
    rdfs:comment 'Strategic classification indicating the supplier\'s relationship tier and procurement priority. Strategic suppliers are critical long-term partners, preferred suppliers have favorable terms, approved suppliers meet minimum standards, conditional suppliers are under review, blocked suppliers are prohibited from new business.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Status' ;
    rdfs:comment 'Current lifecycle status of the supplier relationship. Active suppliers are approved for procurement, inactive suppliers are no longer used, suspended suppliers are temporarily restricted, pending_approval suppliers are under qualification review, blocked suppliers are prohibited from new transactions.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Internal alphanumeric code assigned to the supplier for identification across procurement, quality, and supply chain systems. Often synchronized with SAP vendor master number.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Full legal name of the supplier organization as registered with incorporation authorities. Used for contracts, purchase orders, and legal documentation.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:womanOwned rdf:type rdf:Property ;
    rdfs:label 'Woman Owned' ;
    rdfs:comment 'Indicates whether the supplier is certified as a woman-owned business enterprise. Used for diversity supplier programs and regulatory reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedForNewBusiness rdf:type rdf:Property ;
    rdfs:label 'Approved For New Business' ;
    rdfs:comment 'Indicates whether the vendor site is approved to receive new purchase orders and sourcing awards.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the primary quality management certification expires. Used to trigger recertification workflows.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Performance Score' ;
    rdfs:comment 'On-time delivery performance score for the vendor site. Scale 0-100.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iatf16949Certified rdf:type rdf:Property ;
    rdfs:label 'Iatf 16949 Certified' ;
    rdfs:comment 'Indicates whether the vendor site holds IATF 16949 automotive quality management certification. Required for automotive supply chain participation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the vendor site holds ISO 14001 Environmental Management System certification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified' ;
    rdfs:comment 'Indicates whether the vendor site holds ISO 45001 Occupational Health and Safety Management System certification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the vendor site holds ISO 9001 Quality Management System certification. Critical for supplier qualification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the minimum order quantity such as pieces, kilograms, or pallets.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this vendor site has preferred supplier status for strategic sourcing decisions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionCapacityAnnual rdf:type rdf:Property ;
    rdfs:label 'Production Capacity Annual' ;
    rdfs:comment 'Annual production capacity of the site in units relevant to the site type. Used for capacity planning and sourcing allocation decisions.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Composite quality performance score for the vendor site based on defect rates, audit results, and corrective action responsiveness. Scale 0-100.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'Tax identification or VAT registration number for the vendor site. Used for tax compliance and invoice validation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierContactId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Id' ;
    rdfs:comment 'Primary key for contact' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContact .

ind:certificationHeld rdf:type rdf:Property ;
    rdfs:label 'Certification Held' ;
    rdfs:comment 'Professional certifications or qualifications held by the contact relevant to their role (e.g., Six Sigma Black Belt, PMP, ISO Lead Auditor, APICS CPIM). Multiple certifications separated by semicolon.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Preferred method of communication for reaching this contact for routine supplier relationship activities.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'Primary functional role of the contact in the supplier relationship. Determines routing of communications and escalations.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the vendor contact. Inactive or terminated contacts should not receive communications.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for the vendor contact. Used for procurement communications, quality notifications, and supply chain coordination.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Numeric escalation tier for this contact in the supplier relationship hierarchy. Level 1 is first point of contact, higher numbers represent management escalation paths.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete name of the vendor contact person, typically concatenation of first and last name.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Interaction Frequency Days' ;
    rdfs:comment 'Target frequency in days for regular business interactions with this contact. Used for relationship management planning and alerts.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent business interaction or communication with this contact. Used for relationship health monitoring.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL to the contacts LinkedIn professional profile. Used for relationship intelligence and network mapping.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number for the vendor contact. Used for urgent supply chain escalations and on-call support.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary telephone number for the vendor contact. Includes country code and extension where applicable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code representing the contacts preferred language for business communications (e.g., ENG, DEU, FRA, SPA, CHI, JPN).' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength Score' ;
    rdfs:comment 'Quantitative score (0-100) representing the strength and quality of the business relationship with this contact. Based on interaction frequency, responsiveness, collaboration quality, and business outcomes.' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specializationArea rdf:type rdf:Property ;
    rdfs:label 'Specialization Area' ;
    rdfs:comment 'Specific area of expertise or specialization for the contact (e.g., electrification products, automation systems, quality management, supply chain logistics, contract negotiation).' ;
    rdfs:domain ind:SupplierContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of professional experience the contact has in their field or industry. Used for relationship quality assessment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierCertificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Certification Id' ;
    rdfs:comment 'Foreign key linking to supplier.supplier_certification. Business justification: A qualification record requires specific certifications (currently stored as a string in certification_required). Normalizing this to a FK to supplier_certification.supplier_certification_id allows th' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierCertification .

ind:affectedCommodities rdf:type rdf:Property ;
    rdfs:label 'Affected Commodities' ;
    rdfs:comment 'Comma-separated list or description of commodity categories affected by a disqualification event. Null if not disqualified or if disqualification is global.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date when the on-site or remote supplier audit was conducted as part of the qualification process. Null if no audit was performed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numerical score from the supplier qualification audit, typically expressed as a percentage (0.00 to 100.00). Null if no audit was conducted.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Primary method or standard used to qualify the supplier: PPAP (Production Part Approval Process), APQP (Advanced Product Quality Planning), on-site audit, sample approval, document review, third-party certification (ISO, UL, etc.), or legacy performance history. [ENUM-REF-CANDIDATE: ppap|apqp|on_site_audit|sample_approval|document_review|third_party_certification|legacy_performance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalApprovalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Expiry Date' ;
    rdfs:comment 'Date by which the supplier must satisfy conditional approval requirements to achieve full approval status. Null if not conditionally approved.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionalApprovalReason rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Reason' ;
    rdfs:comment 'Explanation of why the supplier was granted conditional approval rather than full approval, including specific restrictions or pending actions. Null if not conditionally approved.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationDate rdf:type rdf:Property ;
    rdfs:label 'Disqualification Date' ;
    rdfs:comment 'Date when the supplier was formally disqualified or approval was revoked. Null if not disqualified.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Detailed explanation of why the supplier was disqualified or rejected, including specific quality, delivery, compliance, or financial issues. Null if not disqualified.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or link to the formal qualification documentation package, including audit reports, PPAP submissions, certificates, and approval memos.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation End Date' ;
    rdfs:comment 'Date when the qualification evaluation was completed and a decision was rendered.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text field capturing additional observations, findings, or context from the qualification evaluation process.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Date' ;
    rdfs:comment 'Date when the formal supplier qualification evaluation process was initiated.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationTeam rdf:type rdf:Property ;
    rdfs:label 'Evaluation Team' ;
    rdfs:comment 'Comma-separated list or description of the cross-functional team members who participated in the supplier qualification evaluation (e.g., quality, engineering, procurement, operations).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the qualification record, typically system-generated and used in external communications and audit trails.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification event: new supplier onboarding, periodic re-qualification, extension to new commodity categories, disqualification action, or conditional approval pending corrective action.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reQualificationConditions rdf:type rdf:Property ;
    rdfs:label 'Re Qualification Conditions' ;
    rdfs:comment 'Specific conditions or corrective actions the supplier must complete before being eligible for re-qualification. Null if not applicable or if permanently disqualified.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reQualificationEligible rdf:type rdf:Property ;
    rdfs:label 'Re Qualification Eligible' ;
    rdfs:comment 'Indicates whether a disqualified supplier is eligible to apply for re-qualification in the future. True if eligible, False if permanently disqualified.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Transition Plan Reference' ;
    rdfs:comment 'Reference identifier or document number for the supplier transition or phase-out plan in the event of disqualification. Null if not applicable.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardId rdf:type rdf:Property ;
    rdfs:label 'Scorecard Id' ;
    rdfs:comment 'Unique identifier for the supplier performance scorecard record.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaCount rdf:type rdf:Property ;
    rdfs:label 'Capa Count' ;
    rdfs:comment 'Total number of corrective and preventive action requests issued to this supplier during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costScore rdf:type rdf:Property ;
    rdfs:label 'Cost Score' ;
    rdfs:comment 'Performance score for the cost pillar, measuring price competitiveness, cost variance, and total cost of ownership, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Percentage' ;
    rdfs:comment 'Percentage variance between actual costs and target or budgeted costs during the evaluation period, where negative values indicate cost savings.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to the cost pillar in the overall score calculation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Score' ;
    rdfs:comment 'Performance score for the delivery pillar, measuring on-time delivery performance and schedule adherence, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to the delivery pillar in the overall score calculation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationMethodology rdf:type rdf:Property ;
    rdfs:label 'Evaluation Methodology' ;
    rdfs:comment 'Description of the scoring methodology, weighting scheme, and calculation approach used for this scorecard evaluation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'The end date of the performance evaluation period covered by this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'The start date of the performance evaluation period covered by this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:improvementActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Improvement Actions Required' ;
    rdfs:comment 'Summary of required improvement actions or corrective measures the supplier must implement based on scorecard results.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrCount rdf:type rdf:Property ;
    rdfs:label 'Ncr Count' ;
    rdfs:comment 'Total number of non-conformance reports issued against this supplier during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otdPercentage rdf:type rdf:Property ;
    rdfs:label 'Otd Percentage' ;
    rdfs:comment 'Percentage of deliveries received on or before the scheduled delivery date during the evaluation period, a key delivery performance indicator.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Composite overall performance score for the supplier, typically calculated as a weighted average of individual pillar scores, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'The frequency or type of evaluation period for this scorecard (monthly, quarterly, annual, or ad-hoc).' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppmDefectRate rdf:type rdf:Property ;
    rdfs:label 'Ppm Defect Rate' ;
    rdfs:comment 'Number of defective parts per million parts received during the evaluation period, a key quality performance indicator.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousRatingTier rdf:type rdf:Property ;
    rdfs:label 'Previous Rating Tier' ;
    rdfs:comment 'The rating tier assigned to the supplier in the previous evaluation period, used for trend analysis and tier movement tracking.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'The date when the scorecard was officially published and communicated to the supplier.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to the quality pillar in the overall score calculation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingTier rdf:type rdf:Property ;
    rdfs:label 'Rating Tier' ;
    rdfs:comment 'Strategic classification tier assigned to the supplier based on scorecard performance, driving sourcing decisions and supplier development programs.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsivenessIndex rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Index' ;
    rdfs:comment 'Composite index measuring supplier responsiveness across communication, issue resolution, and collaboration dimensions, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Performance score for the responsiveness pillar, measuring communication effectiveness, issue resolution speed, and collaboration quality, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to the responsiveness pillar in the overall score calculation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmaCount rdf:type rdf:Property ;
    rdfs:label 'Rma Count' ;
    rdfs:comment 'Total number of return material authorizations processed for defective or non-conforming materials from this supplier during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Business identifier for the scorecard, typically formatted as a human-readable code used in reports and communications.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle status of the scorecard indicating its approval and publication state.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Summary of the supplier\'s key strengths and positive performance areas identified during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLineItemsEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Line Items Evaluated' ;
    rdfs:comment 'Total number of purchase order line items included in the evaluation period for this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrdersEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Orders Evaluated' ;
    rdfs:comment 'Total number of purchase orders included in the evaluation period for this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseValue rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Value' ;
    rdfs:comment 'Total monetary value of purchases from this supplier during the evaluation period, used for spend-weighted performance analysis.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReceiptsEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Receipts Evaluated' ;
    rdfs:comment 'Total number of goods receipts or deliveries included in the evaluation period for this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weaknessesSummary rdf:type rdf:Property ;
    rdfs:label 'Weaknesses Summary' ;
    rdfs:comment 'Summary of the supplier\'s key weaknesses and performance gaps identified during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorComments rdf:type rdf:Property ;
    rdfs:label 'Auditor Comments' ;
    rdfs:comment 'Free-text comments and observations from the lead auditor summarizing key findings, strengths, and areas for improvement.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Completion Date' ;
    rdfs:comment 'Actual date when all required corrective and preventive actions were verified as complete and closed.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Due Date' ;
    rdfs:comment 'Target date by which the supplier must complete and submit corrective and preventive actions to address audit findings.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'The specific certification standard or framework being audited against, such as ISO 9001, IATF 16949, ISO 14001, ISO 45001, IEC 62443, or other industry-specific standards.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Total cost incurred for conducting the audit, including auditor fees, travel expenses, and administrative costs.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'Scheduled or actual date of the follow-up audit conducted to verify corrective action effectiveness.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Boolean indicator whether a follow-up audit is required to verify implementation and effectiveness of corrective actions.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Frequency Months' ;
    rdfs:comment 'Standard audit frequency interval in months for this supplier based on risk classification and business requirements (e.g., 12, 24, 36 months).' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical location or site where the audit was conducted, typically the supplier facility address or site name.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major non-conformances or findings identified during the audit that represent significant deviations from standards or requirements.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor non-conformances or findings identified during the audit that represent isolated or low-impact deviations from standards.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'Date when the formal audit report was issued to the supplier and internal stakeholders.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRatingPostAudit rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Post Audit' ;
    rdfs:comment 'Updated supplier risk rating assigned after the audit based on audit findings and overall performance evaluation.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRatingPreAudit rdf:type rdf:Property ;
    rdfs:label 'Risk Rating Pre Audit' ;
    rdfs:comment 'Supplier risk rating assigned before the audit based on historical performance, criticality, and risk assessment criteria.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierResponse rdf:type rdf:Property ;
    rdfs:label 'Supplier Response' ;
    rdfs:comment 'Free-text response or feedback from the supplier regarding the audit findings and proposed corrective actions.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of all findings (critical, major, minor) identified during the audit, excluding observations.' ;
    rdfs:domain ind:SupplierAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'The name of the accreditation body that accredits the issuing certification body. Examples include ANAB (ANSI National Accreditation Board), UKAS (United Kingdom Accreditation Service), DAkkS (German Accreditation Body), or other national accreditation authorities.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Days' ;
    rdfs:comment 'The number of days before expiry at which automated alerts should be triggered to notify stakeholders of the upcoming certification expiration. Typical values range from 30 to 180 days.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditReportUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Report Url' ;
    rdfs:comment 'The URL or file path to the most recent audit report document stored in the document management system or cloud storage.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automatic renewal workflows and alerts are enabled for this certification. True if the system should automatically trigger renewal processes and notifications. False if renewal is managed manually.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessCriticality rdf:type rdf:Property ;
    rdfs:label 'Business Criticality' ;
    rdfs:comment 'The importance of this certification to the business relationship with the supplier. Critical certifications are mandatory for continued business. High criticality certifications are strongly preferred. Medium and low criticality certifications are informational or nice-to-have.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'The URL or file path to the digital copy of the certification certificate document stored in the document management system or cloud storage.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'The tier, grade, or level of certification achieved, if the standard defines multiple levels. Examples include Level 1, Level 2, Level 3 for IEC 62443, or Gold, Silver, Bronze for tiered certification programs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique certificate number or registration number issued by the certifying body. This is the externally-known identifier for the certification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'The current lifecycle status of the certification. Active indicates the certification is valid and in good standing. Expired indicates the certification has passed its expiry date. Suspended indicates temporary suspension by the issuing body. Revoked indicates permanent withdrawal. Pending renewal indicates the certification is in the renewal process. Under review indicates the certification is being audited or reassessed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The category or domain of the certification. Classifies certifications into quality management, environmental management, health and safety, energy management, cybersecurity, product safety, industry-specific standards, or regulatory compliance. [ENUM-REF-CANDIDATE: quality|environmental|health_safety|energy|cybersecurity|product_safety|industry_specific|regulatory_compliance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedProcesses rdf:type rdf:Property ;
    rdfs:label 'Certified Processes' ;
    rdfs:comment 'A comma-separated or structured list of specific manufacturing processes, production lines, or operational activities that are covered under this certification. Examples include welding, machining, assembly, testing, or packaging.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedProducts rdf:type rdf:Property ;
    rdfs:label 'Certified Products' ;
    rdfs:comment 'A comma-separated or structured list of specific product categories, product families, or SKUs (Stock Keeping Units) that are covered under this certification. Used to gate procurement decisions for regulated commodity categories.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Boolean flag indicating whether corrective actions are required to address audit findings. True if corrective actions are pending or in progress. False if no corrective actions are needed or all have been completed.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gatedCommodityCategories rdf:type rdf:Property ;
    rdfs:label 'Gated Commodity Categories' ;
    rdfs:comment 'A comma-separated list of commodity categories or material groups for which this certification is mandatory. Procurement of these commodities from this supplier is blocked if the certification is not active and valid.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic regions, countries, or markets where this certification is recognized and valid. Examples include USA, EU, China, or Global. Uses 3-letter ISO country codes where applicable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the certification was originally issued by the certifying body. Represents the start of the certification validity period.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The name of the certification body, registrar, or regulatory authority that issued the certification. Examples include TUV, BSI, DNV, SGS, UL, Intertek, Bureau Veritas, LRQA, or government agencies.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'The user identifier or system account that most recently modified this certification record. Audit trail field for accountability and data lineage.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Major Nonconformance Count' ;
    rdfs:comment 'The number of major non-conformances identified during the most recent audit. Major non-conformances are serious violations that can lead to certification suspension or revocation.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Minor Nonconformance Count' ;
    rdfs:comment 'The number of minor non-conformances identified during the most recent audit. Minor non-conformances are less serious violations that require corrective action but do not immediately threaten certification status.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'The scheduled date for the next surveillance audit or recertification audit. Used for planning and ensuring continuous compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Count' ;
    rdfs:comment 'The total number of non-conformances (major and minor) identified during the most recent audit. Used to assess the supplier\'s compliance maturity and risk level.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementGateEnabled rdf:type rdf:Property ;
    rdfs:label 'Procurement Gate Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this certification is used to gate procurement decisions. True if suppliers without valid certification in this standard cannot be selected for certain commodity categories. False if the certification is informational only.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The target date by which the certification renewal process must be completed to avoid expiration. Typically occurs before the expiry date to allow for processing time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'The current status of the certification renewal process. Not due indicates renewal is not yet required. Renewal initiated indicates the renewal process has started. Renewal in progress indicates active renewal activities. Renewal completed indicates successful renewal. Renewal overdue indicates the renewal deadline has passed.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfCertification rdf:type rdf:Property ;
    rdfs:label 'Scope Of Certification' ;
    rdfs:comment 'A detailed description of the scope, activities, products, services, or processes covered by this certification. Defines the boundaries and applicability of the certification within the supplier\'s operations.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which the certification was last verified by internal quality assurance or procurement teams. Verification includes confirming the certificate is authentic, current, and matches the supplier\'s claims.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to verify the certification. Document review indicates verification by examining the certificate document. Certifying body confirmation indicates direct verification with the issuing body. On-site inspection indicates physical verification during a supplier visit. Third-party verification indicates verification by an external auditor. Supplier declaration indicates acceptance of supplier-provided documentation without independent verification.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'The name or identifier of the internal employee or quality assurance team member who verified the authenticity and validity of this certification with the issuing body.' ;
    rdfs:domain ind:SupplierCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryApprovedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Approved Supplier Id' ;
    rdfs:comment 'Reference to the qualified supplier authorized to supply materials or services for the specified commodity category.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:annualSpendTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Target' ;
    rdfs:comment 'Target annual procurement spend with this supplier for the specified commodity category, used for volume commitment tracking and supplier relationship management.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avlNumber rdf:type rdf:Property ;
    rdfs:label 'Avl Number' ;
    rdfs:comment 'Business identifier for the AVL entry used in procurement documents and Material Requirements Planning (MRP) source selection.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avlStatus rdf:type rdf:Property ;
    rdfs:label 'Avl Status' ;
    rdfs:comment 'Current lifecycle status of the AVL entry determining whether the supplier can be selected during purchase order creation in Material Requirements Planning (MRP) and procurement processes.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityRating rdf:type rdf:Property ;
    rdfs:label 'Capacity Rating' ;
    rdfs:comment 'Assessment of the suppliers production capacity and ability to scale volume for this commodity category.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationList rdf:type rdf:Property ;
    rdfs:label 'Certification List' ;
    rdfs:comment 'Comma-separated list of required certifications such as ISO 9001, ISO 14001, IATF 16949, AS9100, or industry-specific quality standards.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether specific certifications (ISO, industry-specific, regulatory) are required for the supplier to maintain AVL status for this commodity.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCompetitivenessRating rdf:type rdf:Property ;
    rdfs:label 'Cost Competitiveness Rating' ;
    rdfs:comment 'Cost competitiveness rating comparing the suppliers pricing for this commodity against market benchmarks and other approved suppliers.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryRating rdf:type rdf:Property ;
    rdfs:label 'Delivery Rating' ;
    rdfs:comment 'Current on-time delivery performance rating for the supplier in this commodity category, used in Material Requirements Planning (MRP) source selection.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expeditedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Expedited Lead Time Days' ;
    rdfs:comment 'Expedited lead time in days available for urgent orders, typically shorter than standard lead time but may incur additional costs.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicSupplyRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Supply Region' ;
    rdfs:comment 'Three-letter ISO country code or region code indicating the primary geographic region from which the supplier will ship materials for this commodity.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) required by the supplier for this commodity category. Used by Material Requirements Planning (MRP) to ensure order quantities meet supplier constraints.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partFamily rdf:type rdf:Property ;
    rdfs:label 'Part Family' ;
    rdfs:comment 'Part family or product line grouping for which the supplier is qualified to provide components or assemblies.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'End date for the current pricing agreement, after which prices must be renegotiated or updated.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'Start date for the current pricing agreement applicable to this AVL entry.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Purchasing group or buyer team responsible for managing the supplier relationship and executing purchase orders for this commodity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Purchasing organization code responsible for managing this AVL entry and executing procurement transactions with the supplier.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Current quality performance rating for the supplier in this commodity category, typically expressed as a percentage or score used in supplier selection decisions.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Frequency in months at which this AVL entry must be reviewed and revalidated to ensure continued supplier qualification.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:singleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Single Source Flag' ;
    rdfs:comment 'Indicates whether this supplier is the only approved source for the commodity category, representing a supply chain risk requiring mitigation strategies.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Standard procurement lead time in days from purchase order placement to delivery for this supplier and commodity combination. Used by Material Requirements Planning (MRP) for scheduling.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierDesignation rdf:type rdf:Property ;
    rdfs:label 'Supplier Designation' ;
    rdfs:comment 'Designation indicating the suppliers priority level for sourcing decisions. Preferred suppliers are selected first by Material Requirements Planning (MRP), backup suppliers are used when preferred suppliers cannot fulfill demand.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyPlantCode rdf:type rdf:Property ;
    rdfs:label 'Supply Plant Code' ;
    rdfs:comment 'Supplier plant or facility code from which materials will be shipped for this commodity category.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Total estimated revenue value of the opportunity in the base currency. Represents the gross deal size before discounts.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Actual date when the opportunity was marked as closed (won or lost). Null if still open.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the primary competitor identified in this sales opportunity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstallationStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Installation Status' ;
    rdfs:comment 'Current status of product delivery and installation for won opportunities. Tracks post-sale fulfillment.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Total discount percentage applied to the opportunity amount. Used for pricing and margin analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedRevenue rdf:type rdf:Property ;
    rdfs:label 'Expected Revenue' ;
    rdfs:comment 'Probability-weighted revenue calculated as amount multiplied by probability percentage. Used for forecast accuracy.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter in which the opportunity is expected to close (e.g., Q1 FY2024). Used for quota and forecast alignment.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Sales forecast classification indicating confidence level for revenue planning and quota tracking.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasOpenActivity rdf:type rdf:Property ;
    rdfs:label 'Has Open Activity' ;
    rdfs:comment 'Boolean indicator whether there are open tasks or activities associated with this opportunity. Used for pipeline health monitoring.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClosed rdf:type rdf:Property ;
    rdfs:label 'Is Closed' ;
    rdfs:comment 'Boolean indicator whether the opportunity has reached a final closed state (won or lost).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivate rdf:type rdf:Property ;
    rdfs:label 'Is Private' ;
    rdfs:comment 'Boolean indicator whether the opportunity is marked as private with restricted visibility.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWon rdf:type rdf:Property ;
    rdfs:label 'Is Won' ;
    rdfs:comment 'Boolean indicator whether the opportunity was closed as won (deal successfully secured).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason why the opportunity was lost. Used for win/loss analysis and competitive intelligence.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Description of the next planned action or milestone to advance the opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityDescription rdf:type rdf:Property ;
    rdfs:label 'Opportunity Description' ;
    rdfs:comment 'Detailed narrative description of the opportunity including customer needs, solution scope, and strategic context.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Business-friendly name or title of the sales opportunity describing the potential deal.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the opportunity used in sales communications and reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity based on customer relationship status (new customer acquisition vs existing customer expansion).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Probability Percent' ;
    rdfs:comment 'Estimated probability of winning this opportunity expressed as a percentage (0-100). Used for weighted pipeline forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Primary product line or business unit category for the opportunity (e.g., automation systems, electrification solutions, smart infrastructure).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectEndDate rdf:type rdf:Property ;
    rdfs:label 'Project End Date' ;
    rdfs:comment 'Planned or actual completion date for project delivery if the opportunity is won.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Planned or actual start date for project delivery if the opportunity is won.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region classification for the opportunity (e.g., North America, EMEA, APAC).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesCycleDays rdf:type rdf:Property ;
    rdfs:label 'Sales Cycle Days' ;
    rdfs:comment 'Number of days from opportunity creation to close date. Used for sales velocity analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage of the opportunity in the sales pipeline lifecycle indicating progression toward close. [ENUM-REF-CANDIDATE: prospecting|qualification|needs_analysis|proposal|negotiation|closed_won|closed_lost — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageChangedDate rdf:type rdf:Property ;
    rdfs:label 'Stage Changed Date' ;
    rdfs:comment 'Timestamp when the opportunity stage was last changed. Used for stage duration and velocity analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Unique identifier for the commercial quotation record. Primary key.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:previousQuoteId rdf:type rdf:Property ;
    rdfs:label 'Previous Quote Id' ;
    rdfs:comment 'Reference to the prior version of this quote if this is a revision or amendment.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:shipToAddressId rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Quotes in industrial manufacturing CPQ processes specify a validated ship-to address for freight cost calculation, incoterms selection, and tax determination. A FK to customer.address enables accurate' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:acceptedDate rdf:type rdf:Property ;
    rdfs:label 'Accepted Date' ;
    rdfs:comment 'Date on which the customer formally accepted the quote, triggering order creation.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:configurationSummary rdf:type rdf:Property ;
    rdfs:label 'Configuration Summary' ;
    rdfs:comment 'High-level summary of the product configuration details included in the quote (e.g., system specifications, key components, customization notes).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Estimated number of days from order confirmation to delivery of the quoted products.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total monetary value of all discounts applied to the quote (standard and non-standard).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Overall discount rate applied to the quote, expressed as a percentage of the subtotal.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International Commercial Terms (Incoterms) defining the responsibilities of buyer and seller for delivery, insurance, and risk transfer. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonStandardDiscountFlag rdf:type rdf:Property ;
    rdfs:label 'Non Standard Discount Flag' ;
    rdfs:comment 'Indicates whether the quote includes discounts that exceed standard approval thresholds and require special authorization.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:presentedDate rdf:type rdf:Property ;
    rdfs:label 'Presented Date' ;
    rdfs:comment 'Date on which the quote was formally presented to the customer.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'Date on which the quote was formally issued to the customer.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteName rdf:type rdf:Property ;
    rdfs:label 'Quote Name' ;
    rdfs:comment 'Descriptive name or title of the quote, typically reflecting the project or product scope (e.g., \'Factory Automation System - Plant 5\').' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Externally visible business identifier for the quote. Used in customer communications and contract references.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle status of the quote in the sales workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|presented|accepted|rejected|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of the quote based on the nature of the commercial transaction.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedDate rdf:type rdf:Property ;
    rdfs:label 'Rejected Date' ;
    rdfs:comment 'Date on which the customer formally rejected or declined the quote.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation or reason provided by the customer for rejecting the quote (e.g., \'Price too high\', \'Lead time unacceptable\', \'Competitor selected\').' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Service level commitments included in the quote (e.g., response time, uptime guarantees, maintenance windows).' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingHandlingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Handling Amount' ;
    rdfs:comment 'Estimated cost for shipping and handling of the quoted products to the customer site.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Planned method of shipment for the quoted products (e.g., \'Air Freight\', \'Ocean Freight\', \'Ground Transport\', \'Courier\').' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialTermsConditions rdf:type rdf:Property ;
    rdfs:label 'Special Terms Conditions' ;
    rdfs:comment 'Additional contractual terms, conditions, or clauses specific to this quote that deviate from standard terms.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Total value of all quoted line items before discounts, taxes, and adjustments.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount calculated on the quote based on applicable tax jurisdictions and rates.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final total value of the quote including all line items, discounts, taxes, and fees.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validUntilDate rdf:type rdf:Property ;
    rdfs:label 'Valid Until Date' ;
    rdfs:comment 'Expiration date after which the quote is no longer valid and prices/terms may change.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Description of warranty coverage included with the quoted products (duration, scope, exclusions).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winProbabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percentage' ;
    rdfs:comment 'Estimated probability (0-100%) that this quote will be accepted and converted to an order, based on sales assessment.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteLineId rdf:type rdf:Property ;
    rdfs:label 'Quote Line Id' ;
    rdfs:comment 'Unique identifier for the quote line item. Primary key.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteLine .

ind:bundleParentLineId rdf:type rdf:Property ;
    rdfs:label 'Bundle Parent Line Id' ;
    rdfs:comment 'Reference to the parent quote line if this line is part of a product bundle. Enables hierarchical quote structures for complex system quotes.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteLine .

ind:priceBookEntryId rdf:type rdf:Property ;
    rdfs:label 'Price Book Entry Id' ;
    rdfs:comment 'Foreign key linking to sales.price_book_entry. Business justification: A quote line is priced from a specific price book entry (SKU-price association). Adding price_book_entry_id to quote_line establishes the authoritative pricing reference used when the line was quoted.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBookEntry .

ind:primaryQuoteSkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Quote Sku Master Id' ;
    rdfs:comment 'Reference to the product master record. Identifies the specific SKU (Stock Keeping Unit), product configuration, or service offering being quoted.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'The approval authority level required for this line item based on discount depth or special terms. Escalates based on business rules.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionPercent rdf:type rdf:Property ;
    rdfs:label 'Commission Percent' ;
    rdfs:comment 'The commission rate applicable to this line item for sales compensation. Business confidential.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'The delivery date committed by the manufacturer for this line item. Based on production schedule and capacity planning.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'The total cost to manufacture or procure the items on this line. Used for margin analysis and profitability calculations. Business confidential.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBundleParent rdf:type rdf:Property ;
    rdfs:label 'Is Bundle Parent' ;
    rdfs:comment 'Indicates whether this line item is a parent bundle that contains child line items. True for bundle headers, false for standalone or child items.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOptional rdf:type rdf:Property ;
    rdfs:label 'Is Optional' ;
    rdfs:comment 'Indicates whether this line item is optional or required. Optional items may be removed by the customer without affecting the core quote.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'The current status of this quote line item in the approval workflow. Tracks the lifecycle state of individual line items.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'The standard catalog or list price per unit before any discounts. Base price from the product master or price book.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Amount' ;
    rdfs:comment 'The gross margin amount for this line item. Calculated as subtotal amount minus cost amount. Business confidential.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginPercent rdf:type rdf:Property ;
    rdfs:label 'Margin Percent' ;
    rdfs:comment 'The gross margin percentage for this line item. Calculated as margin amount divided by subtotal amount. Business confidential.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'The product family or category classification. Groups related products for reporting and analysis (e.g., Automation Systems, Electrification Solutions, Smart Infrastructure).' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialTerms rdf:type rdf:Property ;
    rdfs:label 'Special Terms' ;
    rdfs:comment 'Any special terms, conditions, or notes specific to this line item. May include warranty extensions, service level agreements, or custom provisions.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'The actual selling price per unit after applying discounts and adjustments. This is the negotiated price for this specific quote.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryAddressId rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Sales contracts in industrial manufacturing specify a validated delivery address governing incoterms, tax jurisdiction, and logistics obligations. \'delivery_location\' is a denormalized text field; a F' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:fulfillmentWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Warehouse Id' ;
    rdfs:comment 'Foreign key linking to inventory.warehouse. Business justification: Industrial manufacturing sales contracts (frame agreements, blanket orders) specify the fulfilling warehouse for delivery scheduling and SLA compliance. Contract managers and logistics planners use th' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:signatoryCustomerContactId rdf:type rdf:Property ;
    rdfs:label 'Signatory Customer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_contact. Business justification: Contract lifecycle management and legal audit trails require identifying the specific customer contact who signed the contract. \'customer_signatory_name\' is a denormalized text field; a FK to customer' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContact .

ind:complianceCertificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications Required' ;
    rdfs:comment 'List of mandatory certifications, standards, or regulatory approvals that products or services must meet under the sales contract. Examples: CE marking, UL certification, ISO 9001, IEC 61131, OSHA compliance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClause rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause' ;
    rdfs:comment 'Contractual provisions protecting proprietary information, trade secrets, technical specifications, and business data shared between parties. Defines confidential information, permitted uses, and disclosure restrictions.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the sales contract. Used for customer communication, legal reference, and cross-system tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the sales contract. Draft contracts are being prepared; pending approval contracts await internal or customer sign-off; active contracts are in force; suspended contracts are temporarily on hold; completed contracts have fulfilled all obligations; terminated contracts ended early by mutual agreement; cancelled contracts were voided before activation. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|completed|terminated|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the sales contract based on commercial structure. Standard contracts use pre-approved terms; custom contracts are negotiated; framework contracts establish terms for multiple orders; blanket contracts cover recurring purchases; spot contracts are one-time transactions; turnkey contracts include design, supply, and commissioning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySchedule rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'Detailed timeline and milestones for delivery of products, systems, or services under the sales contract. May include phased deliveries, installation schedules, and commissioning dates.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed mechanism for resolving disputes arising from the sales contract. Litigation involves court proceedings; arbitration uses neutral arbitrators; mediation involves facilitated negotiation; negotiation is direct party-to-party resolution.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) or file path to the digitally stored executed sales contract document. Links to document management system or secure repository.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Contractual provisions excusing non-performance due to unforeseeable events beyond parties control such as natural disasters, war, pandemics, or government actions. Defines qualifying events and relief procedures.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction and body of law that governs the interpretation, enforcement, and dispute resolution of the sales contract. Typically specifies country and state/province.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Mandatory insurance coverage that the supplier or customer must maintain during contract performance. May include general liability, professional indemnity, product liability, or cargo insurance with specified coverage limits.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intellectualPropertyTerms rdf:type rdf:Property ;
    rdfs:label 'Intellectual Property Terms' ;
    rdfs:comment 'Provisions defining ownership, licensing, and usage rights for intellectual property including patents, designs, software, documentation, and technical know-how. Specifies IP ownership and license grants.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum financial liability amount that either party can be held responsible for under the sales contract. Limits exposure for damages, losses, or claims arising from contract performance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netContractValue rdf:type rdf:Property ;
    rdfs:label 'Net Contract Value' ;
    rdfs:comment 'Net monetary value of the sales contract after applying discounts, rebates, and before taxes. Represents the actual revenue to be recognized.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Contractual provisions defining financial penalties or liquidated damages for non-performance, late delivery, or breach of SLA commitments. Specifies penalty amounts, triggers, and caps.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Provisions governing automatic renewal, renewal options, or renegotiation terms at contract expiration. Defines renewal notice periods, pricing adjustments, and renewal conditions.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date when the sales contract was signed by both parties and became legally executed. May differ from effective date if contract has a future start date.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaResolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Time Hours' ;
    rdfs:comment 'Maximum number of hours within which the supplier must resolve customer issues or restore service under the contract. Part of SLA commitments for uptime and availability.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Maximum number of hours within which the supplier must respond to customer service requests or incidents under the contract. Part of SLA commitments for support and maintenance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'Guaranteed minimum uptime or availability percentage for systems, equipment, or services covered by the sales contract. Expressed as a percentage (e.g., 99.5% uptime).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Supplier Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative who signed the sales contract on behalf of the supplier. Used for legal verification and audit trail.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Contractual provisions defining conditions, notice periods, and procedures under which either party may terminate the sales contract. Includes termination for cause, convenience, or force majeure.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueAmount rdf:type rdf:Property ;
    rdfs:label 'Value Amount' ;
    rdfs:comment 'Total monetary value of the sales contract representing the gross revenue commitment. Includes all line items, products, services, and deliverables before adjustments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueCurrency rdf:type rdf:Property ;
    rdfs:label 'Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value. Defines the currency in which all financial terms, payments, and penalties are denominated.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Duration in months for which the supplier provides warranty coverage for products, systems, or equipment delivered under the sales contract. Covers defects in materials and workmanship.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Id' ;
    rdfs:comment 'Reference to the parent territory in the hierarchical territory structure. Null for top-level territories.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:accountCount rdf:type rdf:Property ;
    rdfs:label 'Account Count' ;
    rdfs:comment 'Total number of customer accounts assigned to this territory. Used for territory balance and coverage analysis.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualRevenueQuota rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Quota' ;
    rdfs:comment 'Target annual revenue quota assigned to this territory in the base currency. Used for quota attainment tracking and sales performance measurement.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentRule rdf:type rdf:Property ;
    rdfs:label 'Assignment Rule' ;
    rdfs:comment 'Business rule or criteria used to assign accounts or opportunities to this territory (e.g., \'Postal codes 10000-19999\', \'Annual revenue > $1M in automotive sector\'). Free-text description of assignment logic.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Reference code to the commission or incentive compensation plan applicable to sales representatives in this territory. Links to compensation management system.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes covered by this territory (e.g., \'USA,CAN,MEX\' or \'DEU,AUT,CHE\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageModel rdf:type rdf:Property ;
    rdfs:label 'Coverage Model' ;
    rdfs:comment 'Sales coverage approach for this territory: direct (direct sales force), channel (partner/distributor), hybrid (combination), inside_sales (remote/phone), or field_sales (on-site visits).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOverlayTerritory rdf:type rdf:Property ;
    rdfs:label 'Is Overlay Territory' ;
    rdfs:comment 'Boolean flag indicating whether this is an overlay territory (True) that operates across other territories for specialized products or services, or a standard exclusive territory (False).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Target customer segment for this territory: enterprise (large corporations), mid_market (medium businesses), smb (small business), oem (Original Equipment Manufacturer), government (public sector), or education (academic institutions).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overlayType rdf:type rdf:Property ;
    rdfs:label 'Overlay Type' ;
    rdfs:comment 'Type of overlay territory if is_overlay_territory is True: product_specialist (specific product expertise), solution_architect (technical pre-sales), key_account (strategic account support), or none (not an overlay).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineScope rdf:type rdf:Property ;
    rdfs:label 'Product Line Scope' ;
    rdfs:comment 'Comma-separated list of product lines or families assigned to this territory (e.g., \'PLC,SCADA,HMI\' or \'Electrification,Automation,Digitalization\'). Defines which products the territory sales team is responsible for.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the revenue quota (e.g., \'USD\', \'EUR\', \'CNY\').' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriod rdf:type rdf:Property ;
    rdfs:label 'Quota Period' ;
    rdfs:comment 'Time period for quota measurement: annual (yearly), semi_annual (twice per year), quarterly (every quarter), or monthly.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionLevel rdf:type rdf:Property ;
    rdfs:label 'Region Level' ;
    rdfs:comment 'Hierarchical level of the territory within the organizational geography: global (worldwide), regional (multi-country), country (single nation), local (sub-national), district (city/metro), or zone (sub-district).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Primary sales channel used in this territory: direct (company sales force), distributor (third-party distributor), reseller (value-added reseller), online (e-commerce), oem (embedded in OEM products), or system_integrator (SI partner).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTeamSize rdf:type rdf:Property ;
    rdfs:label 'Sales Team Size' ;
    rdfs:comment 'Number of sales representatives assigned to this territory. Used for capacity planning and workload distribution.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Business identifier code for the territory used in Salesforce Sales Cloud and reporting systems. Externally-known unique code.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Detailed textual description of the territory scope, strategic objectives, and special considerations. Provides context for territory planning and handoff.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the sales territory (e.g., \'North America Industrial Automation\', \'EMEA Electrification Solutions\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory: active (operational), inactive (not in use), pending (awaiting activation), suspended (temporarily disabled), archived (historical), or planned (future territory).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of territory assignment model: geographic (region-based), industry_vertical (sector-based), account_based (strategic accounts), product_line (product family focus), hybrid (combination), or named_account (specific customer assignment).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Primary key for rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerRepId rdf:type rdf:Property ;
    rdfs:label 'Manager Rep Id' ;
    rdfs:comment 'Reference to the sales representative record of this rep\'s direct manager in the sales hierarchy.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:activeAccountCount rdf:type rdf:Property ;
    rdfs:label 'Active Account Count' ;
    rdfs:comment 'Number of active customer accounts currently assigned to and managed by this sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeOpportunityCount rdf:type rdf:Property ;
    rdfs:label 'Active Opportunity Count' ;
    rdfs:comment 'Number of open sales opportunities currently in the representative\'s pipeline.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Amount' ;
    rdfs:comment 'Annual sales quota target assigned to the representative measured in base currency. Used for performance tracking and commission calculation.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookOfBusinessValue rdf:type rdf:Property ;
    rdfs:label 'Book Of Business Value' ;
    rdfs:comment 'Total annual recurring revenue or contract value of the customer accounts currently managed by this sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmUserCode rdf:type rdf:Property ;
    rdfs:label 'Crm User Code' ;
    rdfs:comment 'Salesforce Sales Cloud user identifier linking this sales representative to their CRM login and activity tracking.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Target customer segment that the sales representative primarily serves based on account size and strategic importance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date when the sales representative was hired into the sales organization.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryVerticalFocus rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical Focus' ;
    rdfs:comment 'Target industry vertical or market segment that the sales representative focuses on, such as automotive, food and beverage, pharmaceuticals, or infrastructure.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKeyAccountManager rdf:type rdf:Property ;
    rdfs:label 'Is Key Account Manager' ;
    rdfs:comment 'Boolean flag indicating whether this sales representative is designated as a key account manager responsible for strategic, high-value customer relationships.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Languages spoken by the sales representative relevant for customer communication and territory coverage, stored as comma-separated language codes.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review conducted for this sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'Date of the most recent sales training, product training, or professional development activity completed by the representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completion Date' ;
    rdfs:comment 'Date when the sales representative completed the formal onboarding and training program for new sales hires.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent performance evaluation rating for the sales representative based on quota attainment, customer satisfaction, and other Key Performance Indicators (KPIs).' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineSpecialization rdf:type rdf:Property ;
    rdfs:label 'Product Line Specialization' ;
    rdfs:comment 'Primary product line or solution area that the sales representative specializes in, such as drives, PLCs (Programmable Logic Controllers), switchgear, building automation, or electrification systems.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period End Date' ;
    rdfs:comment 'End date of the current quota period for this sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotaPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period Start Date' ;
    rdfs:comment 'Start date of the current quota period for this sales representative, typically aligned with fiscal year or calendar year.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repCode rdf:type rdf:Property ;
    rdfs:label 'Rep Code' ;
    rdfs:comment 'Business-assigned unique code for the sales representative used in order entry, commission tracking, and reporting systems.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repStatus rdf:type rdf:Property ;
    rdfs:label 'Rep Status' ;
    rdfs:comment 'Current lifecycle status of the sales representative indicating their availability and eligibility for sales assignments.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOfficeLocation rdf:type rdf:Property ;
    rdfs:label 'Sales Office Location' ;
    rdfs:comment 'Primary office location or branch where the sales representative is based for administrative and reporting purposes.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRole rdf:type rdf:Property ;
    rdfs:label 'Sales Role' ;
    rdfs:comment 'Commercial role classification indicating the sales representative\'s position in the sales organization hierarchy.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Percentage' ;
    rdfs:comment 'Expected percentage of work time spent traveling for customer visits, trade shows, and field sales activities.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentPriceBookId rdf:type rdf:Property ;
    rdfs:label 'Parent Price Book Id' ;
    rdfs:comment 'Reference to a parent or master price book from which this price book inherits base pricing. Null if this is a top-level price book.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Boolean flag indicating whether quotes or orders using this price book require management approval before finalization.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountPolicy rdf:type rdf:Property ;
    rdfs:label 'Discount Policy' ;
    rdfs:comment 'Reference to the discount policy or guidelines that govern allowable discounts from this price book (e.g., \'Standard 10% max\', \'Volume-based tiered\', \'No discounts allowed\').' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStandard rdf:type rdf:Property ;
    rdfs:label 'Is Standard' ;
    rdfs:comment 'Boolean flag indicating whether this is the standard (default) price book for the organization. Only one standard price book should be active at a time.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceBookCode rdf:type rdf:Property ;
    rdfs:label 'Price Book Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the price book for system integration and reporting purposes.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookDescription rdf:type rdf:Property ;
    rdfs:label 'Price Book Description' ;
    rdfs:comment 'Detailed description of the price book purpose, scope, and applicability (e.g., \'Standard list prices for North America industrial automation products effective Q1 2024\').' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookName rdf:type rdf:Property ;
    rdfs:label 'Price Book Name' ;
    rdfs:comment 'Business name of the price book (e.g., \'Standard Price Book\', \'EMEA Industrial Automation 2024\', \'OEM Partner Pricing\').' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookStatus rdf:type rdf:Property ;
    rdfs:label 'Price Book Status' ;
    rdfs:comment 'Current lifecycle status of the price book indicating whether it is available for use in sales transactions.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookType rdf:type rdf:Property ;
    rdfs:label 'Price Book Type' ;
    rdfs:comment 'Classification of the price book indicating its purpose and usage context within the sales organization.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'The pricing methodology or strategy applied in this price book (e.g., list pricing, cost-plus, competitive pricing, value-based pricing).' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date when the current version of the price book was last revised or updated.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'The internal cost or standard cost of the product. Used for margin calculation and profitability analysis. Business-confidential data.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographyCode rdf:type rdf:Property ;
    rdfs:label 'Geography Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or region code indicating the geographic market for which this pricing applies (e.g., USA, DEU, CHN).' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Percent' ;
    rdfs:comment 'The maximum allowable discount percentage that can be applied to this product without requiring special approval. Used to enforce pricing governance.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPrice rdf:type rdf:Property ;
    rdfs:label 'Minimum Price' ;
    rdfs:comment 'The floor price below which this product cannot be sold. Used to enforce pricing policies and protect margin thresholds in Configure Price Quote (CPQ) processes.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBookEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Price Book Entry Description' ;
    rdfs:comment 'Additional notes or description providing context about this pricing entry, such as special terms, conditions, or the rationale for custom pricing.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookEntryName rdf:type rdf:Property ;
    rdfs:label 'Price Book Entry Name' ;
    rdfs:comment 'A descriptive name or label for this price book entry, typically combining product name, price book name, and currency for easy identification in reports and user interfaces.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'The type or nature of the price (e.g., list price, negotiated price, promotional price, contract price, spot price). Indicates the pricing strategy applied.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingMethod rdf:type rdf:Property ;
    rdfs:label 'Pricing Method' ;
    rdfs:comment 'The methodology used to determine the price (e.g., fixed, cost-plus, market-based, value-based). Supports pricing strategy analysis and governance.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax classification code that determines applicable sales tax, Value Added Tax (VAT), or Goods and Services Tax (GST) rates for this product in the specified geography.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useStandardPrice rdf:type rdf:Property ;
    rdfs:label 'Use Standard Price' ;
    rdfs:comment 'Indicates whether this entry uses the standard price book price or a custom price. True means standard pricing applies; false indicates custom or negotiated pricing.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arItemId rdf:type rdf:Property ;
    rdfs:label 'Ar Item Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_item. Business justification: Order-to-cash process: booked orders generate AR items for receivables tracking. Industrial manufacturing DSO (Days Sales Outstanding) reporting and revenue recognition (IFRS 15) require linking order' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArItem .

ind:contactCustomerContactId rdf:type rdf:Property ;
    rdfs:label 'Contact Customer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_contact. Business justification: Order confirmation, delivery coordination, and dispute resolution in industrial manufacturing require knowing which buyer contact placed the order. Order management teams use this for customer communi' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContact .

ind:bookingRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Booking Recognition Date' ;
    rdfs:comment 'The date when this order intake was recognized as a booking for quota and sales performance measurement. May differ from intake date based on validation rules.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingRecognizedFlag rdf:type rdf:Property ;
    rdfs:label 'Booking Recognized Flag' ;
    rdfs:comment 'Indicates whether this order intake has been recognized as a booking against sales quota. True when order meets booking recognition criteria per sales policy.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Date' ;
    rdfs:comment 'Date when credit approval was granted for this order, if required. Null if order did not require credit approval or is still pending.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Check Status' ;
    rdfs:comment 'Result of the customer credit check performed at order intake. Orders failing credit check may require advance payment or credit approval before handoff to fulfillment.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPoDate rdf:type rdf:Property ;
    rdfs:label 'Customer Po Date' ;
    rdfs:comment 'The date on the customer\'s purchase order. Used for contract compliance verification and order validity checks.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'The customer\'s purchase order reference number. Critical for order validation, invoicing, and customer reconciliation. May be required per customer contract terms.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied at intake date to convert order value to base currency. Locked at intake for consistent booking valuation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoffDate rdf:type rdf:Property ;
    rdfs:label 'Handoff Date' ;
    rdfs:comment 'The date when the order intake was successfully handed off to the order management domain. Used for sales-to-fulfillment cycle time KPI calculation.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:handoffStatus rdf:type rdf:Property ;
    rdfs:label 'Handoff Status' ;
    rdfs:comment 'Current status of the handoff from sales to order management domain. Tracks the intake record through validation, transfer, and acceptance by the fulfillment organization.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intakeDate rdf:type rdf:Property ;
    rdfs:label 'Intake Date' ;
    rdfs:comment 'The date when the order was officially received and recorded in the sales system. This is the booking date used for sales quota recognition and revenue pipeline tracking.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intakeNumber rdf:type rdf:Property ;
    rdfs:label 'Intake Number' ;
    rdfs:comment 'Business identifier for the order intake record. Human-readable unique number used for tracking and reference in sales reporting and KPI dashboards.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intakeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Intake Timestamp' ;
    rdfs:comment 'Precise timestamp when the order intake record was created in the system. Used for sales-to-fulfillment cycle time measurement and operational analytics.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderManagementReference rdf:type rdf:Property ;
    rdfs:label 'Order Management Reference' ;
    rdfs:comment 'The order number or reference assigned by the order management system after handoff. Links this sales intake record to the authoritative order record in SAP SD or equivalent ERP.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPriority rdf:type rdf:Property ;
    rdfs:label 'Order Priority' ;
    rdfs:comment 'The priority level assigned to this order intake. Influences production scheduling and resource allocation in the fulfillment process.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the order by business type. Distinguishes between new customer acquisition, existing customer expansion, and service orders for sales mix analysis. [ENUM-REF-CANDIDATE: New Business|Renewal|Upgrade|Add-On|Replacement|Service|Spare Parts — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderValue rdf:type rdf:Property ;
    rdfs:label 'Order Value' ;
    rdfs:comment 'The total confirmed order value at intake. This is the gross order amount before any adjustments, used for sales booking recognition and quota attainment calculation.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderValueBaseCurrency rdf:type rdf:Property ;
    rdfs:label 'Order Value Base Currency' ;
    rdfs:comment 'Order value converted to the company\'s base reporting currency using the exchange rate at intake date. Used for consolidated sales reporting and KPI tracking.' ;
    rdfs:domain ind:OrderIntake ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when this MRP run completed or terminated. Used to calculate run duration and identify performance bottlenecks.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bomExplosionLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Explosion Level' ;
    rdfs:comment 'Maximum depth of BOM explosion performed during this MRP run. Indicates how many levels down the product structure the planning calculation extended (e.g., 1 for single-level, 99 for full multi-level explosion).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes or comments entered by planners or system administrators regarding the outcome, issues, or special circumstances of this MRP run.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandTimeFenceDays rdf:type rdf:Property ;
    rdfs:label 'Demand Time Fence Days' ;
    rdfs:comment 'Number of days from the run date within which the MRP system does not automatically create, reschedule, or cancel planned orders. Defines the frozen zone where manual intervention is required.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorMessagesCount rdf:type rdf:Property ;
    rdfs:label 'Error Messages Count' ;
    rdfs:comment 'Total number of error messages generated during this MRP run that prevented successful completion or caused partial failures.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionMessagesCount rdf:type rdf:Property ;
    rdfs:label 'Exception Messages Count' ;
    rdfs:comment 'Total number of exception or warning messages generated during this MRP run, indicating planning issues such as material shortages, capacity overloads, or invalid master data.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includeForecastFlag rdf:type rdf:Property ;
    rdfs:label 'Include Forecast Flag' ;
    rdfs:comment 'Indicates whether demand forecast data was included in the MRP calculation (True) or only firm customer orders were considered (False).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includeSafetyStockFlag rdf:type rdf:Property ;
    rdfs:label 'Include Safety Stock Flag' ;
    rdfs:comment 'Indicates whether safety stock requirements were included in the MRP calculation (True) or excluded (False).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includeWipFlag rdf:type rdf:Property ;
    rdfs:label 'Include Wip Flag' ;
    rdfs:comment 'Indicates whether existing work-in-progress inventory was considered as available supply during this MRP run (True) or excluded (False).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialsProcessedCount rdf:type rdf:Property ;
    rdfs:label 'Materials Processed Count' ;
    rdfs:comment 'Total number of material master records processed during this MRP run. Indicates the scope and scale of the planning calculation.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOrdersCancelledCount rdf:type rdf:Property ;
    rdfs:label 'Planned Orders Cancelled Count' ;
    rdfs:comment 'Total number of existing planned orders that were cancelled by this MRP run because they were no longer needed to satisfy material requirements.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOrdersCreatedCount rdf:type rdf:Property ;
    rdfs:label 'Planned Orders Created Count' ;
    rdfs:comment 'Total number of new planned orders (purchase requisitions or production orders) created by this MRP run to satisfy material requirements.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOrdersRescheduledCount rdf:type rdf:Property ;
    rdfs:label 'Planned Orders Rescheduled Count' ;
    rdfs:comment 'Total number of existing planned orders that were rescheduled (date or quantity changed) by this MRP run due to changes in demand or supply.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Days' ;
    rdfs:comment 'Total number of days covered by the planning horizon for this MRP run, calculated from start to end date.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'End date of the planning horizon for this MRP run. Defines the end of the period for which material requirements are calculated.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'Start date of the planning horizon for this MRP run. Defines the beginning of the period for which material requirements are calculated.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningMode rdf:type rdf:Property ;
    rdfs:label 'Planning Mode' ;
    rdfs:comment 'Manufacturing planning strategy applied during this MRP run: make-to-stock (MTS), make-to-order (MTO), assemble-to-order (ATO), or engineer-to-order (ETO).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningTimeFenceDays rdf:type rdf:Property ;
    rdfs:label 'Planning Time Fence Days' ;
    rdfs:comment 'Number of days from the run date within which the MRP system can reschedule but not create new planned orders. Defines the slushy zone between frozen and free planning periods.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingExplosionFlag rdf:type rdf:Property ;
    rdfs:label 'Routing Explosion Flag' ;
    rdfs:comment 'Indicates whether production routing and work center capacity requirements were calculated during this MRP run (True) or only material requirements were computed (False).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Run Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from actual start to actual end of the MRP run. Key performance indicator for planning system efficiency.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runParametersJson rdf:type rdf:Property ;
    rdfs:label 'Run Parameters Json' ;
    rdfs:comment 'JSON-formatted string containing additional MRP run configuration parameters and settings not captured in dedicated columns. Enables flexible storage of system-specific or advanced planning parameters.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockMethod rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Method' ;
    rdfs:comment 'Safety stock calculation method applied during this MRP run: fixed quantity, days of supply, statistical (based on demand variability), or none.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when this MRP run was scheduled to begin execution.' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulingMethod rdf:type rdf:Property ;
    rdfs:label 'Scheduling Method' ;
    rdfs:comment 'Scheduling algorithm applied during this MRP run: forward (schedule from earliest start), backward (schedule from due date), finite (capacity-constrained), or infinite (no capacity constraints).' ;
    rdfs:domain ind:MrpRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours' ;
    rdfs:comment 'Production capacity in hours available at the work center or plant for executing this planned order, used for capacity planning validation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:convertedOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Converted Order Number' ;
    rdfs:comment 'Document number of the production order, purchase requisition, or stock transfer order created when this planned order was converted to an executable order.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Converted Timestamp' ;
    rdfs:comment 'Date and time when the planned order was converted to an executable order.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicator that this planned order has been marked for deletion by a subsequent planning run because the requirement no longer exists or has been satisfied by other means.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code identifying planning exceptions or issues requiring planner intervention (e.g., capacity overload, material shortage, lead time violation, MOQ conflict).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessage rdf:type rdf:Property ;
    rdfs:label 'Exception Message' ;
    rdfs:comment 'Detailed description of the planning exception or constraint violation that requires planner review and resolution.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Firmed Timestamp' ;
    rdfs:comment 'Date and time when the planned order was firmed by the planner.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firmingIndicator rdf:type rdf:Property ;
    rdfs:label 'Firming Indicator' ;
    rdfs:comment 'Flag indicating whether this planned order has been firmed by the planner, preventing it from being automatically changed or deleted by subsequent planning runs.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeRule rdf:type rdf:Property ;
    rdfs:label 'Lot Size Rule' ;
    rdfs:comment 'Lot sizing method applied by the planning system: exact_quantity (order exact requirement), moq (minimum order quantity), fixed_lot (standard batch size), or rounding (round up to packaging unit).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqQuantity rdf:type rdf:Property ;
    rdfs:label 'Moq Quantity' ;
    rdfs:comment 'Minimum order quantity constraint from the supplier or production process that was applied during lot sizing.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiTierSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Tier Supplier Flag' ;
    rdfs:comment 'Indicator that this planned order requires coordination across multiple tiers of the supply network (e.g., raw material supplier, component manufacturer, final assembly).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text comments entered by the planner documenting decisions, constraints, or coordination details related to this planned order.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerOverrideDate rdf:type rdf:Property ;
    rdfs:label 'Planner Override Date' ;
    rdfs:comment 'Manually adjusted scheduled finish date entered by the planner to override the system-calculated date based on capacity constraints or customer negotiation.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannerOverrideQuantity rdf:type rdf:Property ;
    rdfs:label 'Planner Override Quantity' ;
    rdfs:comment 'Manually adjusted quantity entered by the planner to override the system-calculated planned quantity based on business judgment or known constraints.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planning Run Timestamp' ;
    rdfs:comment 'Date and time when the planning run that created this planned order was executed.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'Number of days required to procure or produce the material, used by the planning system to calculate scheduled start date from requirement date.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current lifecycle state of the planned order proposal: open (awaiting planner review), under_review (being evaluated), firmed (approved for conversion), converted (released to execution), rejected (not needed), or cancelled (superseded by new planning run).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Required Capacity Hours' ;
    rdfs:comment 'Production capacity in hours required to complete this planned order based on routing and quantity.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requirementDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Date' ;
    rdfs:comment 'Date when the material is needed to fulfill a sales order, production order component, or safety stock replenishment.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceRequirementNumber rdf:type rdf:Property ;
    rdfs:label 'Source Requirement Number' ;
    rdfs:comment 'Document number of the originating requirement (sales order, production order, forecast entry) that drove the creation of this planned order.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRequirementType rdf:type rdf:Property ;
    rdfs:label 'Source Requirement Type' ;
    rdfs:comment 'Type of demand that triggered the creation of this planned order: sales order (customer demand), production order (component requirement), safety stock (replenishment), forecast (anticipated demand), or service order (spare parts).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyRiskScore rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Score' ;
    rdfs:comment 'Quantitative risk assessment score (0-100) indicating the likelihood of supply disruption for this planned order based on supplier performance, lead time volatility, and geopolitical factors.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandForecastId rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Id' ;
    rdfs:comment 'Unique identifier for the demand forecast record. Primary key for the demand forecast entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandForecast .

ind:demandPlanVersionId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Version Id' ;
    rdfs:comment 'Reference to the forecast version record enabling scenario comparison and version lineage tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlanVersion .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Comments or notes provided by the approver during the forecast approval workflow, documenting decision rationale or conditions.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biasPercent rdf:type rdf:Property ;
    rdfs:label 'Bias Percent' ;
    rdfs:comment 'Systematic forecast bias expressed as percentage, indicating tendency to over-forecast (positive) or under-forecast (negative). Used to detect and correct systematic errors.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'Lower bound of the forecast confidence interval, representing the pessimistic demand scenario for risk analysis and safety stock planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'Upper bound of the forecast confidence interval, representing the optimistic demand scenario for capacity planning and supply risk assessment.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percent' ;
    rdfs:comment 'Statistical confidence level of the forecast interval expressed as a percentage (e.g., 95.00 for 95% confidence). Used for supply planning sensitivity analysis.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Consensus Approval Date' ;
    rdfs:comment 'Date when the forecast achieved consensus approval in the Sales and Operations Planning (S&OP) process, marking it as the agreed demand plan.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demandClass rdf:type rdf:Property ;
    rdfs:label 'Demand Class' ;
    rdfs:comment 'Classification of demand type: independent (end-customer driven, forecasted) or dependent (derived from BOM and parent item demand via MRP explosion).' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPattern rdf:type rdf:Property ;
    rdfs:label 'Demand Pattern' ;
    rdfs:comment 'Characterization of the historical demand behavior pattern used to select appropriate forecasting models and safety stock strategies.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percent' ;
    rdfs:comment 'Historical accuracy percentage of the forecast model for this material-location combination, calculated as (1 - MAPE) * 100. Used for model selection and tuning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastConsumptionFlag rdf:type rdf:Property ;
    rdfs:label 'Forecast Consumption Flag' ;
    rdfs:comment 'Indicates whether this forecast is subject to consumption by actual customer orders in the MRP logic. Controls forecast vs. order-driven planning behavior.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Forecast Generation Timestamp' ;
    rdfs:comment 'Timestamp when the forecast was generated by the forecasting engine or planning system. Represents the business event time of forecast creation.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Days' ;
    rdfs:comment 'Number of days into the future that this forecast covers, calculated from the planning period start date. Used for lead time coverage analysis.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastModelCode rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Code' ;
    rdfs:comment 'Code identifying the statistical or algorithmic model used to generate the forecast (e.g., ARIMA, EXP_SMOOTH, MOVING_AVG, ML_ENSEMBLE).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastModelName rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Name' ;
    rdfs:comment 'Human-readable name of the forecasting model or algorithm applied to generate this forecast.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Business identifier for the forecast record, externally visible and used for tracking and reference in planning meetings.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Quantity' ;
    rdfs:comment 'Predicted demand quantity for the material at the specified location during the planning period. Core forecast value used for MRP and capacity planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the forecast record in the approval workflow. Tracks progression from draft through approval or rejection.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanAbsolutePercentageError rdf:type rdf:Property ;
    rdfs:label 'Mean Absolute Percentage Error' ;
    rdfs:comment 'MAPE metric measuring forecast error as a percentage of actual demand. Lower values indicate better forecast accuracy. Key KPI for demand planning performance.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpAreaCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Area Code' ;
    rdfs:comment 'MRP area code defining the planning scope and organizational unit for material requirements planning execution.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outlierFlag rdf:type rdf:Property ;
    rdfs:label 'Outlier Flag' ;
    rdfs:comment 'Indicates whether this forecast was flagged as a statistical outlier requiring review. Used for data quality monitoring and exception management.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outlierReason rdf:type rdf:Property ;
    rdfs:label 'Outlier Reason' ;
    rdfs:comment 'Explanation for why this forecast was flagged as an outlier, documenting the business or statistical reason for the exception.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningGroupCode rdf:type rdf:Property ;
    rdfs:label 'Planning Group Code' ;
    rdfs:comment 'Code identifying the planning group or demand planner responsible for this forecast. Used for workload distribution and accountability.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period for which this forecast applies. Defines the end of the demand horizon.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period for which this forecast applies. Defines the beginning of the demand horizon.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Stage' ;
    rdfs:comment 'Current stage of the product in its lifecycle. Influences forecasting model selection and demand pattern expectations.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this forecast includes promotional or campaign-driven demand uplift. Used to separate base demand from promotional spikes.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalUpliftPercent rdf:type rdf:Property ;
    rdfs:label 'Promotional Uplift Percent' ;
    rdfs:comment 'Expected percentage increase in demand due to promotional activities during the planning period. Used for promotional planning and inventory pre-positioning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesAdjustmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Sales Adjustment Quantity' ;
    rdfs:comment 'Manual adjustment quantity applied by sales team to the statistical baseline forecast, reflecting market intelligence and customer commitments.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Sales Adjustment Reason' ;
    rdfs:comment 'Business justification for the sales adjustment, documenting market intelligence, customer commitments, or promotional activities driving the override.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Name of the planning scenario this forecast belongs to (e.g., Base Case, Optimistic, Pessimistic, New Product Launch). Enables scenario comparison and sensitivity analysis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalityIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonality Index' ;
    rdfs:comment 'Seasonal adjustment factor applied to the forecast for this planning period. Values above 1.0 indicate peak season, below 1.0 indicate off-season.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendCoefficient rdf:type rdf:Property ;
    rdfs:label 'Trend Coefficient' ;
    rdfs:comment 'Trend component coefficient from the forecasting model, indicating the rate of demand growth or decline over time.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the forecast version: baseline (statistical model output), sales_adjusted (sales team input), consensus (S&OP aligned), approved (final for MRP), or working (draft).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percentage' ;
    rdfs:comment 'Percentage of available production or procurement capacity utilized by this supply plan, indicating capacity constraints.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandForecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Quantity' ;
    rdfs:comment 'Total forecasted demand quantity for the planning period, serving as the primary input to the supply plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizingProcedure rdf:type rdf:Property ;
    rdfs:label 'Lot Sizing Procedure' ;
    rdfs:comment 'Lot-sizing rule used to determine planned order quantities: LOT_FOR_LOT (exact requirement), FIXED_LOT (fixed quantity), EOQ (Economic Order Quantity), POQ (Periodic Order Quantity), or PERIOD_LOT (period-based aggregation).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupCode rdf:type rdf:Property ;
    rdfs:label 'Material Group Code' ;
    rdfs:comment 'Material group or product family covered by this supply plan, enabling aggregated planning at the product category level.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpControllerCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller Code' ;
    rdfs:comment 'Code identifying the MRP controller or planner responsible for this supply plan, enabling workload distribution and accountability.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSupplyQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Supply Quantity' ;
    rdfs:comment 'Total quantity of material planned to be supplied during the planning period, aggregated across all time buckets.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningMethod rdf:type rdf:Property ;
    rdfs:label 'Planning Method' ;
    rdfs:comment 'Method used to generate the supply plan: MRP (Material Requirements Planning), MRP II (Manufacturing Resource Planning), APS (Advanced Planning and Scheduling), MANUAL (manual planning), JIT (Just In Time), or KANBAN (pull-based replenishment).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingValue rdf:type rdf:Property ;
    rdfs:label 'Rounding Value' ;
    rdfs:comment 'Rounding increment for planned order quantities, ensuring orders align with packaging or production batch multiples.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Level' ;
    rdfs:comment 'Assessed risk level for supply availability: LOW (stable supply), MEDIUM (minor risks), HIGH (significant risks), or CRITICAL (severe supply constraints).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance expressed as a percentage of demand forecast, enabling normalized comparison across materials.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Variance between planned supply quantity and demand forecast quantity, indicating over-planning or under-planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityBufferHours rdf:type rdf:Property ;
    rdfs:label 'Capacity Buffer Hours' ;
    rdfs:comment 'Safety buffer or protective capacity reserved to absorb variability and prevent schedule disruptions. Part of Theory of Constraints buffer management.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityLoadProfile rdf:type rdf:Property ;
    rdfs:label 'Capacity Load Profile' ;
    rdfs:comment 'Pattern of capacity demand over the planning period. Indicates whether load is evenly distributed, concentrated in peaks, or highly variable.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacitySourceSystem rdf:type rdf:Property ;
    rdfs:label 'Capacity Source System' ;
    rdfs:comment 'Source system that generated the capacity plan data. Typically SAP PP, Siemens Opcenter APS, or Microsoft Dynamics 365 SCM.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for capacity planning. Typically hours for time-based capacity or units/pieces for output-based capacity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationRate rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Rate' ;
    rdfs:comment 'Percentage of available capacity that is utilized by required capacity. Calculated as (required_capacity_hours / available_capacity_hours) * 100. Key metric for identifying overload or underutilization.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalRatio rdf:type rdf:Property ;
    rdfs:label 'Critical Ratio' ;
    rdfs:comment 'Ratio of time remaining until due date to work time remaining. Used for priority scheduling and capacity allocation. Values less than 1.0 indicate behind schedule.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:efficiencyRate rdf:type rdf:Property ;
    rdfs:label 'Efficiency Rate' ;
    rdfs:comment 'Efficiency factor applied to available capacity to account for actual performance versus standard. Expressed as percentage. Used to adjust theoretical capacity to realistic capacity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBottleneck rdf:type rdf:Property ;
    rdfs:label 'Is Bottleneck' ;
    rdfs:comment 'Boolean flag indicating whether this work center is identified as a bottleneck constraint in the production schedule. True if utilization exceeds threshold or if this resource limits throughput.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelingAdjustmentHours rdf:type rdf:Property ;
    rdfs:label 'Leveling Adjustment Hours' ;
    rdfs:comment 'Capacity adjustment applied through leveling actions such as overtime, shift changes, subcontracting, or order rescheduling to balance load.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:levelingStrategy rdf:type rdf:Property ;
    rdfs:label 'Leveling Strategy' ;
    rdfs:comment 'Strategy applied to resolve capacity overload. Indicates the method used to balance capacity constraints.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overloadHours rdf:type rdf:Property ;
    rdfs:label 'Overload Hours' ;
    rdfs:comment 'Number of hours by which required capacity exceeds available capacity. Positive value indicates capacity shortage requiring leveling or additional resources.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Created Timestamp' ;
    rdfs:comment 'Timestamp when the capacity plan record was created in the system.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Updated Timestamp' ;
    rdfs:comment 'Timestamp when the capacity plan record was last updated or recalculated.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Hours' ;
    rdfs:comment 'Hours of planned maintenance, changeovers, or scheduled downtime that reduce available capacity during the planning period.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Time granularity of the capacity plan. Indicates whether this is a short-term, medium-term, or long-term capacity plan.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningVersion rdf:type rdf:Property ;
    rdfs:label 'Planning Version' ;
    rdfs:comment 'Version identifier for the capacity plan. Supports scenario planning and what-if analysis by maintaining multiple plan versions.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueTimeHours rdf:type rdf:Property ;
    rdfs:label 'Queue Time Hours' ;
    rdfs:comment 'Average queue time or wait time for jobs at this work center during the planning period. Indicates congestion and scheduling delays.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceType rdf:type rdf:Property ;
    rdfs:label 'Resource Type' ;
    rdfs:comment 'Type of production resource being planned. Distinguishes between machine capacity, labor capacity, tooling, or other equipment.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCount rdf:type rdf:Property ;
    rdfs:label 'Shift Count' ;
    rdfs:comment 'Number of production shifts scheduled for the work center during the planning period. Used to calculate available capacity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Shift Hours Per Day' ;
    rdfs:comment 'Total productive hours per day across all shifts. Excludes breaks and non-productive time.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underloadHours rdf:type rdf:Property ;
    rdfs:label 'Underload Hours' ;
    rdfs:comment 'Number of hours by which available capacity exceeds required capacity. Positive value indicates spare capacity available for additional orders or maintenance.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unplannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Unplanned Downtime Hours' ;
    rdfs:comment 'Estimated or historical hours of unplanned downtime (breakdowns, failures) factored into capacity planning to provide realistic capacity estimates.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomExplosionDate rdf:type rdf:Property ;
    rdfs:label 'Bom Explosion Date' ;
    rdfs:comment 'The date on which the BOM was exploded to generate dependent requirements for component materials.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionMessageCode rdf:type rdf:Property ;
    rdfs:label 'Exception Message Code' ;
    rdfs:comment 'SAP exception code indicating planning issues such as late orders, missing parts, excess stock, or capacity overload.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageText rdf:type rdf:Property ;
    rdfs:label 'Exception Message Text' ;
    rdfs:comment 'Human-readable description of the planning exception or issue requiring planner attention.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmingDate rdf:type rdf:Property ;
    rdfs:label 'Firming Date' ;
    rdfs:comment 'Date after which this planned order is frozen and will not be automatically rescheduled or changed by subsequent MRP runs.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossRequirementQuantity rdf:type rdf:Property ;
    rdfs:label 'Gross Requirement Quantity' ;
    rdfs:comment 'Total quantity of material required before considering available stock or scheduled receipts.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inHouseProductionTimeDays rdf:type rdf:Property ;
    rdfs:label 'In House Production Time Days' ;
    rdfs:comment 'Total manufacturing lead time in days from production order release to finished goods availability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeKey rdf:type rdf:Property ;
    rdfs:label 'Lot Size Key' ;
    rdfs:comment 'SAP lot-sizing procedure code applied to this requirement: EX (lot-for-lot), HB (replenish to maximum), FX (fixed lot size), WB (weekly lot size), PD (period lot size).' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Largest quantity that can be ordered or produced in a single transaction due to capacity, storage, or supplier constraints.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpElementType rdf:type rdf:Property ;
    rdfs:label 'Mrp Element Type' ;
    rdfs:comment 'Classification of the MRP element that created this requirement: sales order, forecast, safety stock replenishment, dependent requirement from BOM explosion, planned order, or purchase requisition.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Timestamp' ;
    rdfs:comment 'Date and time when the MRP run that generated this requirement record was executed.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netRequirementQuantity rdf:type rdf:Property ;
    rdfs:label 'Net Requirement Quantity' ;
    rdfs:comment 'The actual shortage quantity that must be procured or produced, calculated as gross requirement minus available stock and scheduled receipts.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peggingRequirementReference rdf:type rdf:Property ;
    rdfs:label 'Pegging Requirement Reference' ;
    rdfs:comment 'Reference to the parent requirement that triggered this dependent requirement through BOM explosion (used for requirement traceability).' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Order Quantity' ;
    rdfs:comment 'The lot-size adjusted quantity that MRP proposes to procure or produce, after applying lot-sizing rules (MOQ, rounding, fixed lot size).' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedAvailableBalance rdf:type rdf:Property ;
    rdfs:label 'Projected Available Balance' ;
    rdfs:comment 'Projected on-hand inventory balance after accounting for gross requirements and scheduled receipts up to this requirement date.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requirementPriority rdf:type rdf:Property ;
    rdfs:label 'Requirement Priority' ;
    rdfs:comment 'Numeric priority ranking used to sequence requirements when allocating limited supply or production capacity (lower number = higher priority).' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementSourceItem rdf:type rdf:Property ;
    rdfs:label 'Requirement Source Item' ;
    rdfs:comment 'The line item number within the source document that triggered this requirement.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementSourceNumber rdf:type rdf:Property ;
    rdfs:label 'Requirement Source Number' ;
    rdfs:comment 'The document number of the source that triggered this requirement (e.g., sales order number, forecast ID, planned order number).' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current fulfillment status of the material requirement: open (not yet covered), partially covered (some supply allocated), fully covered (sufficient supply allocated), cancelled, or expired.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Scheduled Receipt Quantity' ;
    rdfs:comment 'Quantity of material expected to be received from open purchase orders, production orders, or transfer orders by the requirement date.' ;
    rdfs:domain ind:MaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blanketOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Id' ;
    rdfs:comment 'Foreign key linking to order.blanket_order. Business justification: Procurement sourcing rules in industrial manufacturing reference the blanket order/scheduling agreement that governs supply execution terms. Supply planners use this link to validate that sourcing rul' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlanketOrder .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of total demand allocated to this sourcing rule when split sourcing is configured. Used for quota arrangements and multi-supplier strategies.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:automaticPoFlag rdf:type rdf:Property ;
    rdfs:label 'Automatic Po Flag' ;
    rdfs:comment 'Indicates whether MRP is authorized to automatically convert planned orders to purchase orders without manual intervention for this sourcing rule.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Free-text explanation for any exceptions or deviations from standard sourcing policies, such as emergency procurement, single-source justification, or temporary supplier changes.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedLotSize rdf:type rdf:Property ;
    rdfs:label 'Fixed Lot Size' ;
    rdfs:comment 'Fixed quantity that must be ordered when this sourcing rule is applied. MRP will generate orders in exact multiples of this lot size.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grProcessingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Gr Processing Time Days' ;
    rdfs:comment 'Number of days required for goods receipt processing, inspection, and put-away after material arrives at the plant. Included in total procurement lead time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Specific location or port associated with the Incoterms designation, defining the point of delivery or risk transfer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMoqNegotiationDate rdf:type rdf:Property ;
    rdfs:label 'Last Moq Negotiation Date' ;
    rdfs:comment 'Date when the MOQ was last negotiated or reviewed with the supplier, used to track contract refresh cycles and renegotiation schedules.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizeRoundingValue rdf:type rdf:Property ;
    rdfs:label 'Lot Size Rounding Value' ;
    rdfs:comment 'Rounding increment for order quantities. MRP will round calculated requirements up to the nearest multiple of this value to align with packaging or production batch constraints.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makeOrBuyIndicator rdf:type rdf:Property ;
    rdfs:label 'Make Or Buy Indicator' ;
    rdfs:comment 'Strategic decision indicator specifying whether the material is manufactured in-house (make), procured externally (buy), or both options are available.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderUnit rdf:type rdf:Property ;
    rdfs:label 'Order Unit' ;
    rdfs:comment 'Unit of measure in which orders are placed with the supplier (e.g., EA for each, KG for kilogram, M for meter). Must be convertible to base UOM.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Planner Approved Flag' ;
    rdfs:comment 'Indicates whether the sourcing rule has been reviewed and approved by the material planner or supply chain manager for use in MRP runs.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Quota Arrangement Flag' ;
    rdfs:comment 'Indicates whether this sourcing rule is part of a quota arrangement where demand is split across multiple suppliers based on allocation percentages.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business-assigned unique code identifying this sourcing rule for operational reference and reporting.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Descriptive name of the sourcing rule for business user identification and reporting purposes.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the sourcing rule indicating whether it is active and available for MRP, temporarily blocked, awaiting approval, or expired.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingPriority rdf:type rdf:Property ;
    rdfs:label 'Sourcing Priority' ;
    rdfs:comment 'Numeric ranking indicating the preference order when multiple sourcing rules exist for the same material-plant combination. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingType rdf:type rdf:Property ;
    rdfs:label 'Sourcing Type' ;
    rdfs:comment 'Classification of the sourcing method: external procurement from supplier, in-house production, subcontracting, stock transfer between plants, or consignment arrangement.' ;
    rdfs:domain ind:SourcingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDailyDemand rdf:type rdf:Property ;
    rdfs:label 'Average Daily Demand' ;
    rdfs:comment 'Mean daily consumption or usage rate of the material, used as input for reorder point and safety stock calculations.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The methodology used to determine safety stock levels: static (fixed quantity), dynamic (demand-driven), statistical (based on demand variability and service level), or manual (user-defined).' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageProfile rdf:type rdf:Property ;
    rdfs:label 'Coverage Profile' ;
    rdfs:comment 'Six-character code referencing a time-phased coverage profile used in advanced planning systems for dynamic safety stock calculation.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityCode rdf:type rdf:Property ;
    rdfs:label 'Criticality Code' ;
    rdfs:comment 'Business criticality rating indicating the impact of stockout on operations: critical (production stoppage), high (significant disruption), medium (moderate impact), low (minimal impact).' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandVariabilityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Coefficient' ;
    rdfs:comment 'Statistical measure of demand fluctuation (coefficient of variation or standard deviation) used in statistical safety stock calculations.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCostPercentAnnual rdf:type rdf:Property ;
    rdfs:label 'Holding Cost Percent Annual' ;
    rdfs:comment 'Annual inventory carrying cost as a percentage of material value, including warehousing, insurance, obsolescence, and cost of capital.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeVariabilityDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Variability Days' ;
    rdfs:comment 'Standard deviation of supplier lead time in days, used to account for supply uncertainty in safety stock calculations.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level' ;
    rdfs:comment 'The lower inventory threshold below which stock should not fall under normal operating conditions.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or name of the person who last modified this safety stock policy record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqMinimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Moq Minimum Order Quantity' ;
    rdfs:comment 'The smallest order quantity that can be procured from the supplier, constraining replenishment order sizes.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Lead Time Days' ;
    rdfs:comment 'Expected number of calendar days from order placement to material receipt, used in reorder point calculation.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannerCode rdf:type rdf:Property ;
    rdfs:label 'Planner Code' ;
    rdfs:comment 'Three-character code identifying the supply chain planner or buyer responsible for managing this material-plant combination.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNotes rdf:type rdf:Property ;
    rdfs:label 'Policy Notes' ;
    rdfs:comment 'Free-text field for planners to document special considerations, assumptions, or business rules governing this safety stock policy.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the safety stock policy: active (in use), inactive (not applied), suspended (temporarily disabled), under_review (pending approval).' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'Number of days between scheduled reviews of this safety stock policy to ensure continued relevance and accuracy.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyDaysSupply rdf:type rdf:Property ;
    rdfs:label 'Safety Days Supply' ;
    rdfs:comment 'Number of days of average demand that the safety stock quantity is intended to cover.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyTimeDays rdf:type rdf:Property ;
    rdfs:label 'Safety Time Days' ;
    rdfs:comment 'Number of days added to the planned delivery lead time as a time buffer to account for supply uncertainty.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLevelTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Percent' ;
    rdfs:comment 'The target probability of not experiencing a stockout during the lead time, expressed as a percentage (e.g., 95.00 for 95% service level).' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialProcurementKey rdf:type rdf:Property ;
    rdfs:label 'Special Procurement Key' ;
    rdfs:comment 'Two-digit SAP code indicating special procurement scenarios such as subcontracting, consignment, stock transfer, or third-party processing.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockoutCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Stockout Cost Per Unit' ;
    rdfs:comment 'Estimated cost impact per unit of stockout, including lost sales, expediting costs, and production disruption, used in economic safety stock optimization.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:xyzClassification rdf:type rdf:Property ;
    rdfs:label 'Xyz Classification' ;
    rdfs:comment 'Demand variability classification: X (stable demand), Y (moderate variability), Z (highly variable or sporadic demand).' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Reference to the parent demand plan that this version belongs to. Links to the master demand plan entity.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:supersededByVersionDemandPlanVersionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Version Demand Plan Version Id' ;
    rdfs:comment 'Reference to the newer demand plan version that replaces this version. Null if this is the current active version. Maintains version lineage and audit trail for plan evolution tracking.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlanVersion .

ind:approvedFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Flag' ;
    rdfs:comment 'Indicates whether this demand plan version has received formal approval through the S&OP governance process. True if approved for execution, false if still in draft or review.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineVersionFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Version Flag' ;
    rdfs:comment 'Indicates whether this version serves as the baseline reference for variance analysis and scenario comparison. True if this is the authoritative baseline, false for alternative scenarios or working versions.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biasPercentage rdf:type rdf:Property ;
    rdfs:label 'Bias Percentage' ;
    rdfs:comment 'Systematic tendency of this demand plan version to over-forecast (positive bias) or under-forecast (negative bias) actual demand. Calculated as the sum of forecast errors divided by sum of actuals, used to detect and correct persistent forecasting errors.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPercentage rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percentage' ;
    rdfs:comment 'Statistical confidence level associated with the demand forecast in this version. Represents the probability that actual demand will fall within the forecasted range, typically 80%, 90%, or 95% confidence intervals used for safety stock calculations.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percentage' ;
    rdfs:comment 'Measured accuracy of this demand plan version compared to actual demand realization. Calculated as 100 minus the Mean Absolute Percentage Error (MAPE), used for continuous improvement of forecasting methods and model selection.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Planned Demand Quantity' ;
    rdfs:comment 'Aggregate demand quantity across all materials and time buckets within this plan version. Represents the total forecasted demand volume for supply network capacity planning and scenario comparison.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionNotes rdf:type rdf:Property ;
    rdfs:label 'Version Notes' ;
    rdfs:comment 'Free-text commentary and business context for this demand plan version. Captures assumptions, market conditions, promotional events, supply constraints, or other factors influencing the forecast that are relevant for scenario interpretation and decision-making.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of the demand plan version. Tracks the approval workflow state from initial draft through review, approval, and eventual archival or supersession by newer versions.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when this demand plan version was created. Represents the business event timestamp for version instantiation in the S&OP cycle.' ;
    rdfs:domain ind:DemandPlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Financial reporting of sales per SKU needs a dedicated revenue GL account for posting invoices.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:baseUom rdf:type rdf:Property ;
    rdfs:label 'Base Uom' ;
    rdfs:comment 'The fundamental unit of measure for inventory tracking and stock keeping. All other UoM conversions are calculated relative to this base unit. [ENUM-REF-CANDIDATE: EA|PC|KG|LB|M|FT|L|GAL|M2|FT2|M3|FT3|SET|KIT — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialDescription rdf:type rdf:Property ;
    rdfs:label 'Commercial Description' ;
    rdfs:comment 'Marketing-optimized product description for sales and customer communication. Multi-language support maintained in PLM system.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the standard cost. Typically the company\'s base or functional currency for financial reporting.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionUom rdf:type rdf:Property ;
    rdfs:label 'Dimension Uom' ;
    rdfs:comment 'Unit of measure for length, width, and height dimensions. Standardized for consistent warehouse and logistics operations.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when the SKU is discontinued and no longer available for new orders. Supports end-of-life planning and inventory liquidation strategies.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eccnCode rdf:type rdf:Property ;
    rdfs:label 'Eccn Code' ;
    rdfs:comment 'Export Control Classification Number assigned under the U.S. Export Administration Regulations (EAR). Determines export licensing requirements and trade compliance obligations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether the SKU is classified as a hazardous material requiring special handling, storage, and transportation procedures per regulatory requirements.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:htsCode rdf:type rdf:Property ;
    rdfs:label 'Hts Code' ;
    rdfs:comment 'Harmonized Tariff Schedule classification code for customs and international trade. Used to determine import duties, tariffs, and trade statistics reporting.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makeOrBuyCode rdf:type rdf:Property ;
    rdfs:label 'Make Or Buy Code' ;
    rdfs:comment 'Procurement strategy indicator: make (manufactured in-house), buy (purchased from suppliers), or both (dual-sourced). Drives MRP planning logic and sourcing decisions.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'UN packing group classification indicating the degree of danger: I (high danger), II (medium danger), III (low danger). Determines packaging and handling requirements.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of the SKU by manufacturing and inventory treatment. Determines BOM structure, production planning, and inventory valuation methods. [ENUM-REF-CANDIDATE: finished_good|semi_finished|raw_material|component|assembly|service_part|consumable|tool — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionToBaseConversion rdf:type rdf:Property ;
    rdfs:label 'Production To Base Conversion' ;
    rdfs:comment 'Conversion factor to translate production UoM quantities to base UoM. Used for MRP calculations and production planning.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionUom rdf:type rdf:Property ;
    rdfs:label 'Production Uom' ;
    rdfs:comment 'Unit of measure used in manufacturing execution and shop floor control. Aligns with MES work order quantities and production reporting. [ENUM-REF-CANDIDATE: EA|PC|KG|LB|M|FT|L|GAL|M2|FT2|M3|FT3|SET|KIT|BATCH|LOT — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesToBaseConversion rdf:type rdf:Property ;
    rdfs:label 'Sales To Base Conversion' ;
    rdfs:comment 'Conversion factor to translate sales UoM quantities to base UoM. Example: if sales UoM is BOX and base UoM is EA, and one box contains 12 pieces, the factor is 12.000000.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesUom rdf:type rdf:Property ;
    rdfs:label 'Sales Uom' ;
    rdfs:comment 'Unit of measure used for customer orders and sales transactions. May differ from base UoM to accommodate customer ordering preferences. [ENUM-REF-CANDIDATE: EA|PC|KG|LB|M|FT|L|GAL|M2|FT2|M3|FT3|SET|KIT|BOX|PALLET — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsReference rdf:type rdf:Property ;
    rdfs:label 'Sds Reference' ;
    rdfs:comment 'Reference identifier or document number for the Safety Data Sheet (formerly MSDS) containing detailed hazard information, handling instructions, and emergency procedures.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialControlRequired rdf:type rdf:Property ;
    rdfs:label 'Serial Control Required' ;
    rdfs:comment 'Flag indicating whether the SKU requires individual serial number tracking for warranty management, asset tracking, and field service support.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Concise product description for internal operational use, typically 40 characters or less. Used in MES shop floor displays and warehouse picking lists.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'The authoritative, externally-known unique identifier for the SKU. Used across all systems including SAP S/4HANA MM, Siemens Teamcenter PLM, and Siemens Opcenter MES. This is the business key for the product.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure for volume. Used in logistics and warehouse management calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUom rdf:type rdf:Property ;
    rdfs:label 'Weight Uom' ;
    rdfs:comment 'Unit of measure for gross and net weight values. Standardized across the enterprise for consistent logistics and shipping calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Parent Family Id' ;
    rdfs:comment 'Reference to the parent product family in the multi-level hierarchy. Enables nested family structures (e.g., Industrial Automation > Drives > Low Voltage Drives). Null for top-level families.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Name or code of the business unit or division responsible for this product family. Defines ownership for P&L accountability, product management, and strategic roadmap decisions.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Certification Requirements' ;
    rdfs:comment 'Comma-separated list of required certifications and compliance standards for products in this family (e.g., UL, CE, IEC 61131, ISO 9001, ATEX, IECEx). Defines regulatory and safety compliance scope.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitivePositioning rdf:type rdf:Property ;
    rdfs:label 'Competitive Positioning' ;
    rdfs:comment 'Strategic positioning statement describing how this product family competes in the market (e.g., technology leader, cost leader, niche specialist). Used for marketing strategy and sales enablement.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cybersecurityClassification rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Classification' ;
    rdfs:comment 'Cybersecurity risk classification for products in this family based on connectivity, data handling, and criticality to customer operations. Drives security testing, vulnerability management, and compliance with IEC 62443 and NIST Cybersecurity Framework.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary distribution channel for products in this family (e.g., direct sales, distributor, OEM, e-commerce). Influences pricing, logistics, and customer engagement strategy.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCompliance rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance' ;
    rdfs:comment 'Environmental and sustainability compliance standards applicable to this family (e.g., RoHS, REACH, WEEE, ISO 14001, Energy Star). Ensures adherence to environmental regulations and corporate sustainability commitments.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpMaterialGroup rdf:type rdf:Property ;
    rdfs:label 'Erp Material Group' ;
    rdfs:comment 'Material group code assigned in SAP S/4HANA (MATKL). Used for procurement, inventory management, and financial reporting. Links to purchasing conditions and valuation classes.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyCode rdf:type rdf:Property ;
    rdfs:label 'Family Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the product family. Used in SAP S/4HANA SD for catalog navigation and PLM (Siemens Teamcenter) for product classification. Serves as the business identifier for cross-system integration.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyDescription rdf:type rdf:Property ;
    rdfs:label 'Family Description' ;
    rdfs:comment 'Detailed business description of the product family, including its purpose, key characteristics, typical applications, and differentiating features. Used for marketing collateral, sales enablement, and product documentation.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Human-readable name of the product family (e.g., Industrial Drives, Low-Voltage Switchgear, Smart Building Controllers, Programmable Logic Controllers). Primary display label for catalog navigation and reporting.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'Classification of the product family by offering type. Distinguishes between finished goods (end products), components (parts), assemblies (sub-systems), services (maintenance/support), software (embedded/standalone), systems (integrated solutions), and spare parts. [ENUM-REF-CANDIDATE: finished_goods|components|assemblies|services|software|systems|spare_parts — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Comma-separated list of geographic regions or countries where products in this family are available for sale (e.g., EMEA, APAC, Americas, USA, DEU, CHN). Reflects regulatory approvals, distribution network, and go-to-market scope.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationPriority rdf:type rdf:Property ;
    rdfs:label 'Innovation Priority' ;
    rdfs:comment 'Priority level for innovation and new product development within this family. High priority families receive accelerated R&D investment and technology roadmap focus.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotEnabled rdf:type rdf:Property ;
    rdfs:label 'Iot Enabled' ;
    rdfs:comment 'Indicates whether products in this family have embedded IoT (Internet of Things) or IIoT (Industrial Internet of Things) connectivity for remote monitoring, predictive maintenance, or data analytics. Supports digital services and smart infrastructure offerings.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingStrategy rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Strategy' ;
    rdfs:comment 'Primary manufacturing strategy for products in this family. Make-to-stock (MTS) builds to forecast. Make-to-order (MTO) builds to customer orders. Engineer-to-order (ETO) customizes designs. Configure-to-order (CTO) assembles from standard modules. Assemble-to-order (ATO) final assembly from components.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmCategory rdf:type rdf:Property ;
    rdfs:label 'Plm Category' ;
    rdfs:comment 'Classification code or category assigned in the PLM system (Siemens Teamcenter). Used for document management, BOM (Bill of Materials) structure, and engineering change control (ECO/ECN).' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineOwner rdf:type rdf:Property ;
    rdfs:label 'Product Line Owner' ;
    rdfs:comment 'Name or identifier of the product manager or product line owner responsible for this family. Accountable for portfolio strategy, pricing, and lifecycle management.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productPortfolioStrategy rdf:type rdf:Property ;
    rdfs:label 'Product Portfolio Strategy' ;
    rdfs:comment 'Strategic classification of the product family in the corporate portfolio. Invest families receive R&D funding and growth initiatives. Maintain families sustain current market position. Harvest families maximize cash flow with minimal investment. Divest families are candidates for discontinuation or sale.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'Primary sales organization code responsible for selling products in this family. Defines sales territory, pricing authority, and revenue attribution in SAP S/4HANA SD.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelTier rdf:type rdf:Property ;
    rdfs:label 'Service Level Tier' ;
    rdfs:comment 'Default service level tier for products in this family. Defines response time commitments, spare parts availability, and support escalation paths. Influences service pricing and customer expectations.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment' ;
    rdfs:comment 'Primary customer segment or persona targeted by this product family (e.g., large industrial OEMs, mid-size system integrators, building owners, utilities). Guides marketing campaigns and sales territory planning.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Target Margin Percent' ;
    rdfs:comment 'Target gross margin percentage for products in this family, expressed as a percentage (e.g., 35.50 for 35.5%). Used for pricing strategy, product mix optimization, and profitability analysis.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Configuration Id' ;
    rdfs:comment 'Reference to the configuration that replaces this one when it becomes obsolete. Supports product migration and upgrade paths.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Configuration .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Intended application or use case for this configuration. Describes the operational context where the product will be deployed.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Starting price for the base product before configuration options are applied. Expressed in the default currency.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Unique business identifier for the configured product variant. Used in CPQ (Configure-Price-Quote) workflows and order processing systems.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationDescription rdf:type rdf:Property ;
    rdfs:label 'Configuration Description' ;
    rdfs:comment 'Detailed description of the configured product variant, including key features, options selected, and intended use case.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Human-readable name or title for the configured product variant. Describes the specific configuration in business terms.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of the product configuration. Indicates whether the configuration is available for quoting and ordering. [ENUM-REF-CANDIDATE: draft|active|inactive|obsolete|pending_approval|approved|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationType rdf:type rdf:Property ;
    rdfs:label 'Configuration Type' ;
    rdfs:comment 'Classification of the configuration approach. Standard configurations are pre-defined, custom configurations are unique to customer requirements, engineer-to-order requires design work, make-to-order uses existing designs with custom parameters, configure-to-order selects from predefined options, and assemble-to-order combines standard modules.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintRules rdf:type rdf:Property ;
    rdfs:label 'Constraint Rules' ;
    rdfs:comment 'Business rules and constraints that govern valid option combinations for this configuration. Defines incompatibilities, dependencies, and mandatory selections.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionsHeightMm rdf:type rdf:Property ;
    rdfs:label 'Dimensions Height Mm' ;
    rdfs:comment 'Height dimension of the configured product in millimeters. Critical for packaging, shipping, and installation planning.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimensionsLengthMm rdf:type rdf:Property ;
    rdfs:label 'Dimensions Length Mm' ;
    rdfs:comment 'Length dimension of the configured product in millimeters. Critical for packaging, shipping, and installation planning.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimensionsWidthMm rdf:type rdf:Property ;
    rdfs:label 'Dimensions Width Mm' ;
    rdfs:comment 'Width dimension of the configured product in millimeters. Critical for packaging, shipping, and installation planning.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Flag indicating whether this configuration can currently be ordered. Used to control availability in CPQ (Configure-Price-Quote) and order management systems.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuotable rdf:type rdf:Property ;
    rdfs:label 'Is Quotable' ;
    rdfs:comment 'Flag indicating whether this configuration can be included in customer quotes. May be quotable but not yet orderable during pre-launch phases.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingComplexity rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Complexity' ;
    rdfs:comment 'Assessment of the manufacturing complexity for this configuration. Impacts production planning, resource allocation, and lead time.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustment rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment' ;
    rdfs:comment 'Total price adjustment resulting from selected configuration options. Can be positive (upcharge) or negative (discount).' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Pricing approach used for this configuration. Determines how the final price is calculated based on base product and selected options.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalAvailability rdf:type rdf:Property ;
    rdfs:label 'Regional Availability' ;
    rdfs:comment 'Geographic regions or markets where this configuration is available for sale. Comma-separated list of region codes or market identifiers.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresEngineeringReview rdf:type rdf:Property ;
    rdfs:label 'Requires Engineering Review' ;
    rdfs:comment 'Flag indicating whether orders for this configuration require engineering review and approval before production. Common for engineer-to-order configurations.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:selectedOptions rdf:type rdf:Property ;
    rdfs:label 'Selected Options' ;
    rdfs:comment 'Comma-separated or structured list of specific option codes selected for this configuration variant. Represents the actual choices made from the available option set.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecificationDocument rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Document' ;
    rdfs:comment 'Reference to the technical specification document or datasheet that provides detailed engineering specifications for this configuration.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalConfigurationPrice rdf:type rdf:Property ;
    rdfs:label 'Total Configuration Price' ;
    rdfs:comment 'Final calculated price for the configured product variant, including base price and all option adjustments.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voltageRating rdf:type rdf:Property ;
    rdfs:label 'Voltage Rating' ;
    rdfs:comment 'Operating voltage specification for the configured product. Critical for electrical compatibility and safety compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomUsage rdf:type rdf:Property ;
    rdfs:label 'Bom Usage' ;
    rdfs:comment 'Intended application context for this BOM. Defines whether the BOM is used for production runs, prototyping, spare parts management, rework operations, simulation, or testing purposes.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSystemCode rdf:type rdf:Property ;
    rdfs:label 'Erp System Code' ;
    rdfs:comment 'Unique identifier for this BOM in the ERP system (SAP S/4HANA PP). Used for cross-system reconciliation and data lineage tracking.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'Indicates whether this BOM is for a critical product requiring special handling, quality controls, or regulatory compliance. Used to trigger enhanced review and approval workflows.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantom rdf:type rdf:Property ;
    rdfs:label 'Is Phantom' ;
    rdfs:comment 'Indicates whether this is a phantom BOM. Phantom BOMs represent transient assemblies that are not stocked but are consumed immediately in the parent assembly.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productBomLineId rdf:type rdf:Property ;
    rdfs:label 'Product Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the product_bom_line entity.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternativeItemGroup rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Group' ;
    rdfs:comment 'Identifier for a group of interchangeable components that can substitute for each other in the assembly. Used for flexible BOM structures and supply chain resilience.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeItemPriority rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Priority' ;
    rdfs:comment 'Priority ranking for this component within its alternative item group. Lower numbers indicate higher priority for material selection during MRP and production execution.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Flag indicating whether this component is consumed automatically via backflushing when the operation is confirmed (True) or requires manual goods issue (False). Used in lean manufacturing and MES integration.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bulkMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Bulk Material Indicator' ;
    rdfs:comment 'Flag indicating whether this component is a bulk material (liquids, powders, gases) that requires special handling, storage, and measurement during production.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:componentHeightMm rdf:type rdf:Property ;
    rdfs:label 'Component Height Mm' ;
    rdfs:comment 'Height dimension of the component in millimeters. Used for variable-size materials and spatial planning in assembly.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentLengthMm rdf:type rdf:Property ;
    rdfs:label 'Component Length Mm' ;
    rdfs:comment 'Length dimension of the component in millimeters. Used for variable-size materials and spatial planning in assembly.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentOrigin rdf:type rdf:Property ;
    rdfs:label 'Component Origin' ;
    rdfs:comment 'Procurement strategy for this component: make (manufactured in-house), buy (purchased from supplier), make_or_buy (flexible sourcing), subcontract (outsourced manufacturing).' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Component Weight Kg' ;
    rdfs:comment 'Weight of the component in kilograms. Used for calculating total assembly weight, shipping weight, and material handling requirements.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentWidthMm rdf:type rdf:Property ;
    rdfs:label 'Component Width Mm' ;
    rdfs:comment 'Width dimension of the component in millimeters. Used for variable-size materials and spatial planning in assembly.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costRelevanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Relevance Indicator' ;
    rdfs:comment 'Flag indicating whether this component should be included in product costing calculations. Text items and phantom assemblies are typically not cost-relevant.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedQuantityIndicator rdf:type rdf:Property ;
    rdfs:label 'Fixed Quantity Indicator' ;
    rdfs:comment 'Indicates whether the component quantity is fixed regardless of parent assembly batch size (True) or scales proportionally with batch size (False). Used for setup materials and consumables.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Classification of the BOM line item type: stock (regular inventory item), non_stock (direct procurement), phantom (pass-through assembly with no inventory), text (documentation only), variable_size (length/weight variable), co_product (joint output), by_product (secondary output). [ENUM-REF-CANDIDATE: stock|non_stock|phantom|text|variable_size|co_product|by_product — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationSequence rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence' ;
    rdfs:comment 'The routing operation number at which this component is consumed or installed in the manufacturing process. Links BOM to routing for integrated production planning.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productBomLineStatus rdf:type rdf:Property ;
    rdfs:label 'Product Bom Line Status' ;
    rdfs:comment 'Current lifecycle status of this BOM line: active (in use), inactive (temporarily disabled), pending (awaiting approval), obsolete (phased out), blocked (quality hold), released (approved for production).' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percent' ;
    rdfs:comment 'Expected scrap or waste percentage for this component during the manufacturing process. Used by MRP to calculate additional material requirements. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sparePartIndicator rdf:type rdf:Property ;
    rdfs:label 'Spare Part Indicator' ;
    rdfs:comment 'Indicates whether this component is also available as a spare part for after-sales service and maintenance. Used for service parts planning and documentation.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededRevisionProductRevisionId rdf:type rdf:Property ;
    rdfs:label 'Superseded Revision Product Revision Id' ;
    rdfs:comment 'Reference to the previous product revision that this revision replaces. Maintains revision lineage and traceability.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRevision .

ind:bomAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Bom Affected Flag' ;
    rdfs:comment 'Indicates whether this revision includes changes to the product Bill of Materials structure or component list.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Categorization of the primary business reason or driver for this engineering revision.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Indicates whether customers must be formally notified of this revision due to impact on form, fit, function, or regulatory compliance.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drawingAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Drawing Affected Flag' ;
    rdfs:comment 'Indicates whether this revision includes changes to engineering drawings, CAD (Computer-Aided Design) models, or technical documentation.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivitySerialEnd rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial End' ;
    rdfs:comment 'Ending serial number through which this revision is effective, when effectivity is controlled by serial number range.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivitySerialStart rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Start' ;
    rdfs:comment 'Starting serial number from which this revision is effective, when effectivity is controlled by serial number.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ppap Required Flag' ;
    rdfs:comment 'Indicates whether this revision requires a new Production Part Approval Process submission to customers.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Process Affected Flag' ;
    rdfs:comment 'Indicates whether this revision requires changes to manufacturing processes, work instructions, or shop floor procedures.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required Flag' ;
    rdfs:comment 'Indicates whether this revision requires re-certification or approval from regulatory bodies (UL, CE, OSHA, EPA, etc.).' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionCode rdf:type rdf:Property ;
    rdfs:label 'Revision Code' ;
    rdfs:comment 'Engineering revision level identifier (e.g., A, B, C, 01, 02). Represents the sequential version of the product design.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDescription rdf:type rdf:Property ;
    rdfs:label 'Revision Description' ;
    rdfs:comment 'Detailed description of the changes introduced in this revision, including design modifications, material changes, or process improvements.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionStatus rdf:type rdf:Property ;
    rdfs:label 'Revision Status' ;
    rdfs:comment 'Current lifecycle status of the product revision indicating its approval and release state.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Specification Affected Flag' ;
    rdfs:comment 'Indicates whether this revision includes changes to product specifications, performance requirements, or acceptance criteria.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testingAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Testing Affected Flag' ;
    rdfs:comment 'Indicates whether this revision requires changes to quality testing procedures, inspection plans, or validation protocols.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toolingAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Tooling Affected Flag' ;
    rdfs:comment 'Indicates whether this revision requires changes to manufacturing tooling, fixtures, jigs, or molds.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:altitudeRatingMeters rdf:type rdf:Property ;
    rdfs:label 'Altitude Rating Meters' ;
    rdfs:comment 'Maximum operating altitude in meters above sea level. Defines altitude limitations for product operation due to air pressure and cooling considerations.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationSuitability rdf:type rdf:Property ;
    rdfs:label 'Application Suitability' ;
    rdfs:comment 'Intended application areas and use cases. Describes the industrial applications, environments, or processes for which the product is designed and suitable.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorFinish rdf:type rdf:Property ;
    rdfs:label 'Color Finish' ;
    rdfs:comment 'Product color and surface finish. Describes the external appearance and coating (e.g., RAL 7035 light grey, powder coated, anodized aluminum).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'Supported communication protocols for data exchange. Lists the industrial communication standards the product supports (e.g., PROFINET, EtherNet/IP, Modbus TCP, OPC UA).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionType rdf:type rdf:Property ;
    rdfs:label 'Connection Type' ;
    rdfs:comment 'Electrical connection or terminal type. Describes the method for connecting wires or cables to the product (e.g., screw terminals, spring clamp, plug connector).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentRatingAmperes rdf:type rdf:Property ;
    rdfs:label 'Current Rating Amperes' ;
    rdfs:comment 'Maximum continuous current rating in amperes. Defines the electrical current capacity of the product.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:datasheetReference rdf:type rdf:Property ;
    rdfs:label 'Datasheet Reference' ;
    rdfs:comment 'Reference identifier or document number for the associated product datasheet. Links to the detailed technical datasheet managed in the engineering document management system.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyRatingHz rdf:type rdf:Property ;
    rdfs:label 'Frequency Rating Hz' ;
    rdfs:comment 'Operating frequency rating in Hertz. Specifies the electrical frequency the product is designed for (e.g., 50Hz, 60Hz, 50/60Hz).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityRatingPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Rating Percent' ;
    rdfs:comment 'Relative humidity rating or range for product operation. Specifies the acceptable humidity conditions (e.g., 5-95% RH non-condensing).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationManualReference rdf:type rdf:Property ;
    rdfs:label 'Installation Manual Reference' ;
    rdfs:comment 'Reference identifier or document number for the installation manual. Links to the installation instructions managed in the engineering document management system.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipRating rdf:type rdf:Property ;
    rdfs:label 'Ip Rating' ;
    rdfs:comment 'Ingress Protection rating per IEC 60529 standard. Defines the level of protection against solid objects and liquids (e.g., IP65, IP67, IP20).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Primary materials used in product construction. Lists the key materials and their properties (e.g., stainless steel housing, polycarbonate cover, copper conductors).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mountingType rdf:type rdf:Property ;
    rdfs:label 'Mounting Type' ;
    rdfs:comment 'Physical mounting method for the product. Specifies how the product is installed (e.g., DIN rail, panel mount, wall mount).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nemaRating rdf:type rdf:Property ;
    rdfs:label 'Nema Rating' ;
    rdfs:comment 'NEMA enclosure rating for North American markets. Defines environmental protection level (e.g., NEMA1, NEMA4, NEMA4X, NEMA12).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Max C' ;
    rdfs:comment 'Maximum operating ambient temperature in degrees Celsius. Defines the upper temperature limit for safe and reliable product operation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Min C' ;
    rdfs:comment 'Minimum operating ambient temperature in degrees Celsius. Defines the lower temperature limit for safe and reliable product operation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceParameter rdf:type rdf:Property ;
    rdfs:label 'Performance Parameter' ;
    rdfs:comment 'Key performance parameters and metrics. Describes critical performance characteristics such as response time, accuracy, throughput, or efficiency ratings specific to the product type.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerRatingWatts rdf:type rdf:Property ;
    rdfs:label 'Power Rating Watts' ;
    rdfs:comment 'Electrical power rating in watts. Specifies the maximum power consumption or output capacity of the product.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyDataSheetReference rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Reference' ;
    rdfs:comment 'Reference identifier for the Safety Data Sheet. Links to the SDS document for products containing hazardous materials, managed in the engineering document management system.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shockResistance rdf:type rdf:Property ;
    rdfs:label 'Shock Resistance' ;
    rdfs:comment 'Mechanical shock resistance specification. Describes the products ability to withstand mechanical shock per applicable test standards (e.g., IEC 60068-2-27).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationDescription rdf:type rdf:Property ;
    rdfs:label 'Specification Description' ;
    rdfs:comment 'Detailed textual description of the product specification. Provides comprehensive technical and commercial details not captured in structured fields.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationName rdf:type rdf:Property ;
    rdfs:label 'Specification Name' ;
    rdfs:comment 'Human-readable name or title of the product specification. Describes the specification purpose or scope.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of the product specification. Tracks the approval and active state of the specification document.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum storage temperature in degrees Celsius. Defines the upper temperature limit for product storage when not in operation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum storage temperature in degrees Celsius. Defines the lower temperature limit for product storage when not in operation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vibrationResistance rdf:type rdf:Property ;
    rdfs:label 'Vibration Resistance' ;
    rdfs:comment 'Vibration resistance specification. Describes the products ability to withstand mechanical vibration per applicable test standards (e.g., IEC 60068-2-6).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Geographic markets, regions, or countries where this certification enables product sale and distribution (e.g., European Union, North America, APAC). Pipe-separated list of ISO 3166-1 alpha-3 country codes or region identifiers.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'Name of the organization or authority that issued the certification (e.g., Underwriters Laboratories, TUV Rheinland, Notified Body, National Standards Authority).' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cybersecurityCertification rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Certification' ;
    rdfs:comment 'Cybersecurity certification or compliance level achieved by the product (e.g., IEC 62443-4-1, IEC 62443-4-2, NIST Cybersecurity Framework).' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationOfConformityNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Of Conformity Number' ;
    rdfs:comment 'Unique identifier for the manufacturer\'s Declaration of Conformity document associated with this certification, particularly for CE marking.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyEfficiencyRating rdf:type rdf:Property ;
    rdfs:label 'Energy Efficiency Rating' ;
    rdfs:comment 'Energy efficiency classification or rating assigned to the product (e.g., Energy Star, EU Energy Label class A+++, IEC 60034-30-1 efficiency class IE3).' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Environmental management or sustainability certification obtained (e.g., ISO 14001, LEED, BREEAM, Cradle to Cradle).' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalSafetyCertification rdf:type rdf:Property ;
    rdfs:label 'Functional Safety Certification' ;
    rdfs:comment 'Functional safety certification level achieved by the product (e.g., IEC 61508 SIL 2, ISO 13849 PLd, IEC 61511).' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerFacing rdf:type rdf:Property ;
    rdfs:label 'Is Customer Facing' ;
    rdfs:comment 'Indicates whether this certification is typically disclosed to customers in product documentation, datasheets, or sales materials as a market differentiator.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryForMarkets rdf:type rdf:Property ;
    rdfs:label 'Mandatory For Markets' ;
    rdfs:comment 'List of markets or regions where this certification is legally mandatory for product sale (as opposed to voluntary). Pipe-separated ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Description of the product models, configurations, or variants covered under this certification. Defines the boundary of what is certified.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality management system certification under which the product was manufactured (e.g., ISO 9001, IATF 16949, AS9100).' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'Reference number of the test report or assessment documentation that supports the certification issuance.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeeCompliant rdf:type rdf:Property ;
    rdfs:label 'Weee Compliant' ;
    rdfs:comment 'Indicates whether the product complies with WEEE Directive for proper disposal and recycling of electronic waste.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityCheckGroup rdf:type rdf:Property ;
    rdfs:label 'Availability Check Group' ;
    rdfs:comment 'Two-character key that controls which stock types are included in ATP (Available-to-Promise) checks for sales orders and production orders.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagementRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Management Required' ;
    rdfs:comment 'Indicates whether batch/lot tracking is required for this material at this plant. True=Batch management active, False=No batch tracking.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCountingIndicator rdf:type rdf:Property ;
    rdfs:label 'Cycle Counting Indicator' ;
    rdfs:comment 'Single-character code that determines the frequency of cycle counting for this material. Used to schedule physical inventory counts.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveOutDate rdf:type rdf:Property ;
    rdfs:label 'Effective Out Date' ;
    rdfs:comment 'Date from which this plant data record becomes inactive. Used to manage time-dependent plant data changes.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionSetupRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Setup Required' ;
    rdfs:comment 'Indicates whether a quality inspection setup (inspection lot creation) is required for goods receipts of this material at this plant. True=Inspection required, False=No inspection.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Issue Storage Location' ;
    rdfs:comment 'Four-character code identifying the default storage location from which materials are issued to production orders or sales orders.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeProcedure rdf:type rdf:Property ;
    rdfs:label 'Lot Size Procedure' ;
    rdfs:comment 'Lot-sizing procedure used in MRP to determine order quantities. EX=Lot-for-lot, HB=Replenish to maximum stock level, FX=Fixed lot size, WB=Weekly lot size, PK=Period lot size, LS=Lot size key.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negativeStockAllowed rdf:type rdf:Property ;
    rdfs:label 'Negative Stock Allowed' ;
    rdfs:comment 'Indicates whether negative stock balances are permitted for this material at this plant. True=Negative stock allowed, False=System blocks transactions that would create negative stock.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plantStatus rdf:type rdf:Property ;
    rdfs:label 'Plant Status' ;
    rdfs:comment 'Current lifecycle status of this material at this plant. Active=Normal production/sales, Blocked=Temporarily unavailable, Discontinued=End-of-life, Phase_out=Being phased out, New_product_introduction=NPI stage.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Production Storage Location' ;
    rdfs:comment 'Four-character code identifying the default storage location within the plant where finished goods from production are received.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Ten-character code identifying the profit center responsible for this material at this plant. Used for internal profitability analysis.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionType rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Type' ;
    rdfs:comment 'QM inspection type that determines when quality inspections are triggered. 01=Goods receipt from vendor, 02=Goods receipt from production, 03=Goods issue to customer, 04=Stock transfer, 05=Physical inventory, 08=Recurring inspection, 09=Audit inspection. [ENUM-REF-CANDIDATE: 01|02|03|04|05|08|09 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingMarginKey rdf:type rdf:Property ;
    rdfs:label 'Scheduling Margin Key' ;
    rdfs:comment 'Key that defines float times (opening period, float before production, float after production) used in production scheduling to add buffer time.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationLevel rdf:type rdf:Property ;
    rdfs:label 'Serialization Level' ;
    rdfs:comment 'Controls serial number management for this material at this plant. 0=No serial numbers, 1=Serial number at goods receipt, 2=Serial number at goods issue, 3=Serial number at goods receipt and issue, 4=Serial number at production.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Primary key for purchase_requisition' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Level Required' ;
    rdfs:comment 'Number of approval levels required for this requisition based on value thresholds and organizational policy. Higher values require more senior approvals.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether this requisition requires special compliance review (e.g., environmental, safety, export control). True if compliance review is required.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the purchase requisition (quantity × estimated unit price). Used for budget control and approval routing.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit of the requested material or service. Used for budget estimation and approval thresholds. Actual price is determined during sourcing and PO creation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:justificationNotes rdf:type rdf:Property ;
    rdfs:label 'Justification Notes' ;
    rdfs:comment 'Business justification or rationale provided by the requestor for the purchase. Required for high-value or non-standard requisitions.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Po Created Date' ;
    rdfs:comment 'Date when the purchase order was created from this requisition. Marks the transition from requisition to order in the procure-to-pay cycle.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prDate rdf:type rdf:Property ;
    rdfs:label 'Pr Date' ;
    rdfs:comment 'Date when the purchase requisition was created or submitted. Represents the principal business event timestamp for the requisition initiation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prNumber rdf:type rdf:Property ;
    rdfs:label 'Pr Number' ;
    rdfs:comment 'Business identifier for the purchase requisition, externally visible and used in procurement workflows. Typically system-generated in SAP Ariba or SAP MM.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prStatus rdf:type rdf:Property ;
    rdfs:label 'Pr Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the procure-to-pay workflow. Tracks progression from draft through approval, sourcing, and conversion to purchase order. [ENUM-REF-CANDIDATE: draft|submitted|pending_approval|approved|rejected|sourcing_assigned|po_created|cancelled|closed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prType rdf:type rdf:Property ;
    rdfs:label 'Pr Type' ;
    rdfs:comment 'Classification of the purchase requisition based on the nature of the procurement: direct materials for production, indirect materials for operations, MRO (Maintenance, Repair, and Operations) supplies, capital equipment (CapEx), services, or subcontracting work.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'Code identifying the purchasing group or buyer responsible for sourcing this requisition. Used for workload distribution and supplier relationship management.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization Code' ;
    rdfs:comment 'Code identifying the purchasing organization responsible for procurement activities. Defines the organizational unit for supplier contracts and purchase orders.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Quantity of the material or service being requested. Expressed in the unit of measure specified in the UOM field.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestorDepartment rdf:type rdf:Property ;
    rdfs:label 'Requestor Department' ;
    rdfs:comment 'Department or organizational unit of the requestor. Used for spend analysis and budget allocation tracking.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the employee who created the purchase requisition. Captured for audit trail and approval workflow visibility.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requested materials, supplies, or services must be delivered to meet operational or production requirements. Used for MRP (Material Requirements Planning) scheduling and supplier lead time calculation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceDeterminationIndicator rdf:type rdf:Property ;
    rdfs:label 'Source Determination Indicator' ;
    rdfs:comment 'Indicates how the supplier source should be determined: automatic sourcing via system rules, manual buyer selection, contract-based assignment, or preferred supplier list.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyPlanId rdf:type rdf:Property ;
    rdfs:label 'Supply Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.plan. Business justification: Supply plans dictate purchase order creation; linking PO to supply_plan enables the \'Supply Plan Execution\' report.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'Date when the supplier acknowledged the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Status' ;
    rdfs:comment 'Status indicating whether the supplier has acknowledged receipt and acceptance of the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Status indicating whether the purchase order meets all applicable procurement compliance policies and regulatory requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'Status indicating the extent to which ordered goods have been received against this purchase order.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Status' ;
    rdfs:comment 'Status indicating the extent to which supplier invoices have been received and matched against this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCategory rdf:type rdf:Property ;
    rdfs:label 'Material Category' ;
    rdfs:comment 'High-level classification of the type of materials or services being procured. Direct materials are used in production, indirect materials support operations, MRO is maintenance/repair/operations supplies.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPoValue rdf:type rdf:Property ;
    rdfs:label 'Net Po Value' ;
    rdfs:comment 'Net total value of the purchase order after taxes and all adjustments.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the purchase order was created and issued to the supplier. Principal business event timestamp for the transaction.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known unique business identifier for the purchase order. Used in supplier communications and invoice matching.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the procure-to-pay workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|acknowledged|in_progress|partially_received|fully_received|closed|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type. Standard for one-time orders, blanket for recurring orders with release schedules, framework for long-term agreements, subcontracting for external processing, consignment for supplier-owned inventory.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Total gross value of the purchase order including all line items before taxes and charges.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Work breakdown structure element for project-based purchase orders, enabling cost tracking at the project task level.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'Classification determining how procurement costs are allocated in financial accounting (e.g., to cost center, asset, WBS element, or sales order).' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the procurement professional responsible for sourcing and managing this purchase order line item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating this line item has been marked for deletion or cancellation. Prevents further goods receipt and invoice posting.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Requested or committed delivery date for this line item. Used for MRP planning, production scheduling, and supplier performance tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInvoiceIndicator rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Indicator' ;
    rdfs:comment 'Flag indicating the final invoice has been received and no further invoices are expected for this line item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether invoice verification is required for this line item. Controls accounts payable processing workflow.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Total value of this line item calculated as (quantity_ordered / price_unit) * net_price. Excludes taxes and freight charges.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'The negotiated price per unit of measure before taxes and additional charges. Used to calculate line item total value.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'Outstanding quantity still to be delivered, calculated as quantity_ordered minus quantity_received. Used for supplier follow-up and expediting.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'Acceptable percentage by which the supplier may over-deliver beyond the ordered quantity without requiring approval.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityInvoiced rdf:type rdf:Property ;
    rdfs:label 'Quantity Invoiced' ;
    rdfs:comment 'Cumulative quantity invoiced by the supplier against this line item to date. Used for invoice verification and payment processing.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The quantity of material or service units being procured on this line item. Used for goods receipt matching and invoice verification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Cumulative quantity of goods received against this line item to date. Used for partial delivery tracking and open quantity calculation.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the employee or department that originated the purchase requisition leading to this line item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingInstruction rdf:type rdf:Property ;
    rdfs:label 'Shipping Instruction' ;
    rdfs:comment 'Special instructions for packaging, labeling, or delivery requirements specific to this line item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Brief description of the material or service being procured on this line. Provides human-readable context for the line item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Number' ;
    rdfs:comment 'The suppliers own part number or SKU for the material being procured. Used for supplier communication and catalog matching.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'Acceptable percentage by which the supplier may under-deliver below the ordered quantity without penalty or rejection.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of amendments or change orders issued against this contract since its original approval.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract automatically renews upon expiration if not explicitly terminated. True for auto-renewing contracts, False otherwise.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Flag' ;
    rdfs:comment 'Indicates whether the contract includes confidentiality or non-disclosure provisions protecting proprietary information. True if confidentiality terms are present, False otherwise.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractDescription rdf:type rdf:Property ;
    rdfs:label 'Contract Description' ;
    rdfs:comment 'Detailed narrative description of the scope, purpose, and key terms of the procurement contract.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name or title of the procurement contract for easy identification and reference.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or modification to the contract terms. Nullable if no amendments have been made.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceDeescalationMechanism rdf:type rdf:Property ;
    rdfs:label 'Price Deescalation Mechanism' ;
    rdfs:comment 'Formula or methodology for reducing contract prices based on volume commitments, market conditions, or continuous improvement targets.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceEscalationMechanism rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Mechanism' ;
    rdfs:comment 'Formula or methodology for adjusting contract prices over time based on indices (e.g., CPI, commodity indices), exchange rates, or negotiated percentage increases.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRequirements rdf:type rdf:Property ;
    rdfs:label 'Quality Requirements' ;
    rdfs:comment 'Specific quality standards, certifications, inspection criteria, and acceptance testing requirements mandated in the contract (e.g., ISO 9001, PPAP, APQP, specific Cpk targets).' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for target quantity (e.g., EA for each, KG for kilograms, M for meters, HR for hours).' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Release Quantity' ;
    rdfs:comment 'Cumulative quantity already released or called off against this contract through purchase orders or delivery schedules.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseValue rdf:type rdf:Property ;
    rdfs:label 'Release Value' ;
    rdfs:comment 'Cumulative monetary value already released or spent against this contract through purchase orders.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'Quantity still available for release under this contract, calculated as target quantity minus release quantity.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingValue rdf:type rdf:Property ;
    rdfs:label 'Remaining Value' ;
    rdfs:comment 'Monetary value still available for release under this contract, calculated as total contract value minus release value.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months for each automatic renewal period if auto renewal is enabled. Nullable if auto renewal is not applicable.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTerms rdf:type rdf:Property ;
    rdfs:label 'Sla Terms' ;
    rdfs:comment 'Service level commitments and performance targets defined in the contract, such as lead time, on-time delivery rate, quality standards, and response times.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Planned or committed quantity of materials or services to be procured under this contract for quantity-based agreements. Nullable for value-based contracts.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the contract before expiration.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Maximum monetary value committed under this procurement contract for value-based contracts, or estimated total spend for quantity-based contracts.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Flag' ;
    rdfs:comment 'Indicates whether the received goods were damaged during transit or delivery. True if damage was observed; false otherwise. Triggers quality hold and supplier notification.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The externally-known unique document number assigned to this goods receipt transaction. Used for tracking, auditing, and cross-system reconciliation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptValue rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Value' ;
    rdfs:comment 'The total monetary value of the goods received, calculated as received quantity multiplied by the purchase order unit price. Posted to inventory and General Ledger (GL) accounts.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grIrClearingStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Ir Clearing Status' ;
    rdfs:comment 'Indicates the clearing status of the GR/IR account in accounts payable. Open means no invoice received; partially cleared means partial invoice match; fully cleared means invoice fully matched and cleared.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Flag' ;
    rdfs:comment 'Indicates whether an invoice has been received and verified against this goods receipt as part of the three-way match process (PO-GR-Invoice). True if invoice verified; false otherwise.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity originally ordered on the purchase order line. Used to calculate over-delivery or under-delivery variances.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The difference between the received quantity and the ordered quantity. Positive values indicate over-delivery; negative values indicate under-delivery.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingPersonName rdf:type rdf:Property ;
    rdfs:label 'Receiving Person Name' ;
    rdfs:comment 'The name of the individual who physically received and inspected the goods. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Code' ;
    rdfs:comment 'The code of the manufacturing plant or facility that received the goods. Used for multi-plant inventory and cost center allocation.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Flag' ;
    rdfs:comment 'Indicates whether a Return Material Authorization (RMA) has been initiated for the received goods due to quality issues, damage, or incorrect delivery. True if RMA initiated; false otherwise.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which this goods receipt was reversed. Used for audit trail and financial period reconciliation.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this goods receipt has been reversed or cancelled. True if reversed; false otherwise. Reversed GRs do not contribute to inventory or financial balances.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Id' ;
    rdfs:comment 'Unique identifier for the supplier invoice record. Primary key.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The reference date from which payment terms are calculated, typically the invoice date or goods receipt date.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'The reason why the invoice is blocked for payment, such as price variance, quantity variance, or quality issues.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'The freight or shipping charges included in the invoice.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total invoice amount before taxes and adjustments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the invoice was issued by the supplier. This is the principal business event timestamp for the invoice.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The unique invoice number assigned by the supplier. This is the externally-known business identifier for the invoice.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the procure-to-pay workflow. [ENUM-REF-CANDIDATE: parked|posted|blocked|cleared|cancelled|rejected|pending_approval — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'The type or category of the invoice document.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The total invoice amount after all taxes, discounts, and adjustments. This is the amount payable to the supplier.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Flag indicating whether the invoice is blocked for payment.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date the payment was made to the supplier.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which payment must be made to the supplier according to the payment terms.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The reference number assigned to the payment transaction when the invoice is paid.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment status indicating whether the invoice has been paid.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Additional reference number or code provided by the supplier on the invoice document for their internal tracking.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'The tax jurisdiction or authority under which the invoice tax is calculated.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match verification process comparing purchase order, goods receipt, and invoice.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Tolerance Check Status' ;
    rdfs:comment 'Result of the tolerance check comparing invoice amounts against purchase order and goods receipt amounts.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Tolerance Variance Amount' ;
    rdfs:comment 'The amount by which the invoice differs from the expected amount based on the purchase order and goods receipt.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Variance Percentage' ;
    rdfs:comment 'The percentage variance between the invoice amount and the expected amount.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax deducted from the invoice payment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceLineItemId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Item Id' ;
    rdfs:comment 'Unique identifier for the invoice line item. Primary key for this entity.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'The quantity recorded on the goods receipt document. Used to compare against invoiced quantity for quantity variance detection.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'The quantity of material or service units being invoiced on this line. Used for three-way match verification against PO quantity and goods receipt quantity.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'The total amount for this invoice line before taxes. Typically calculated as invoiced quantity multiplied by unit price, adjusted for any line-level discounts or surcharges.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'The three-way match status of this invoice line. Indicates whether the line passed matching validation or has variances requiring resolution. Blocked status prevents payment until resolved.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poQuantity rdf:type rdf:Property ;
    rdfs:label 'Po Quantity' ;
    rdfs:comment 'The quantity specified on the original purchase order line. Used as the baseline for three-way match verification.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Po Unit Price' ;
    rdfs:comment 'The unit price specified on the original purchase order line. Used as the baseline for price variance detection during invoice verification.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVariance rdf:type rdf:Property ;
    rdfs:label 'Price Variance' ;
    rdfs:comment 'The difference between invoiced unit price and PO unit price, multiplied by invoiced quantity. Indicates pricing discrepancies requiring review.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'The storage location within the plant where the material is received or stored. Used for inventory management and warehouse assignment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percent' ;
    rdfs:comment 'The tax rate percentage applied to this line item. Expressed as a percentage (e.g., 7.50 for 7.5% tax rate).' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'The tolerance group that defines acceptable variance thresholds for this line item. Different tolerance groups may apply to different material categories or supplier relationships.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'The current verification status of this invoice line in the approval workflow. Tracks progress through invoice verification and approval process.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryCommodityCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Commodity Category Id' ;
    rdfs:comment 'Reference to the parent category in the hierarchy. Null for top-level (L1) categories.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityCategory .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the commodity category. May align with UNSPSC (United Nations Standard Products and Services Code) or internal taxonomy.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the commodity category scope, including typical materials, services, or products classified under this category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryLevel rdf:type rdf:Property ;
    rdfs:label 'Category Level' ;
    rdfs:comment 'Hierarchical level of the category within the taxonomy structure. L1 represents top-level, L2 sub-category, L3 detailed category, etc.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryManagerName rdf:type rdf:Property ;
    rdfs:label 'Category Manager Name' ;
    rdfs:comment 'Full name of the category manager responsible for strategic sourcing and supplier relationships within this category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full descriptive name of the commodity category (e.g., Electrical Components, Raw Steel, MRO Supplies).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the commodity category within the procurement taxonomy.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Flag' ;
    rdfs:comment 'Indicates whether this category has specific regulatory compliance requirements (e.g., RoHS, REACH, conflict minerals, ISO certifications).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Coverage Flag' ;
    rdfs:comment 'Indicates whether this category is covered by active procurement contracts or framework agreements.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costReductionTargetPct rdf:type rdf:Property ;
    rdfs:label 'Cost Reduction Target Pct' ;
    rdfs:comment 'Annual cost reduction target percentage for this category as part of strategic sourcing initiatives.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeDaysAvg rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days Avg' ;
    rdfs:comment 'Average procurement lead time in days for materials and services within this category, from requisition to delivery.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moqApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Moq Applicable Flag' ;
    rdfs:comment 'Indicates whether suppliers in this category typically enforce minimum order quantity requirements.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationFrequency rdf:type rdf:Property ;
    rdfs:label 'Negotiation Frequency' ;
    rdfs:comment 'Typical frequency of contract negotiations and RFx events for this commodity category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierCount rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Count' ;
    rdfs:comment 'Number of preferred suppliers currently approved and active for this commodity category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceVolatilityIndex rdf:type rdf:Property ;
    rdfs:label 'Price Volatility Index' ;
    rdfs:comment 'Classification of price volatility for commodities in this category based on historical price fluctuations and market dynamics.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Required' ;
    rdfs:comment 'Comma-separated list of required quality certifications for suppliers in this category (e.g., ISO 9001, IATF 16949, AS9100).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Risk classification based on supply chain vulnerability, supplier concentration, geopolitical factors, and material criticality.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy' ;
    rdfs:comment 'Defined sourcing strategy for this category: single-source, dual-source, multi-source, global sourcing, or local sourcing approach.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendType rdf:type rdf:Property ;
    rdfs:label 'Spend Type' ;
    rdfs:comment 'Classification of spend type: direct materials (production inputs), indirect materials (non-production), MRO (Maintenance, Repair, Operations), CapEx (Capital Expenditure), or services.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicSourcingPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Sourcing Priority' ;
    rdfs:comment 'Priority level assigned to this category for strategic sourcing initiatives based on spend volume, supply risk, and business impact.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscClass rdf:type rdf:Property ;
    rdfs:label 'Unspsc Class' ;
    rdfs:comment 'Third-level UNSPSC class name within the family (e.g., Cutting and Forming Machines).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscCode rdf:type rdf:Property ;
    rdfs:label 'Unspsc Code' ;
    rdfs:comment 'Eight-digit UNSPSC classification code for global commodity standardization and cross-industry spend analysis.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscCommodity rdf:type rdf:Property ;
    rdfs:label 'Unspsc Commodity' ;
    rdfs:comment 'Fourth-level UNSPSC commodity name, the most granular classification level (e.g., CNC Milling Machines).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscFamily rdf:type rdf:Property ;
    rdfs:label 'Unspsc Family' ;
    rdfs:comment 'Second-level UNSPSC family name within the segment (e.g., Metalworking Machinery and Equipment).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscSegment rdf:type rdf:Property ;
    rdfs:label 'Unspsc Segment' ;
    rdfs:comment 'Top-level UNSPSC segment name (e.g., Industrial Manufacturing and Processing Machinery and Accessories).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Source Flag' ;
    rdfs:comment 'Indicates whether the supplier is an approved source for the material (true = approved).' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference to an outline agreement or contract that governs this price.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Fixed Source Flag' ;
    rdfs:comment 'True if procurement must always source from this supplier for the material.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Info Record Number' ;
    rdfs:comment 'Business identifier assigned to the purchase info record, used for reference in procurement processes.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infoRecordType rdf:type rdf:Property ;
    rdfs:label 'Info Record Type' ;
    rdfs:comment 'Classification of the info record indicating the sourcing strategy (e.g., standard, subcontracting, pipeline, consignment).' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPriceUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Price Update Timestamp' ;
    rdfs:comment 'Date-time when the price information was last updated in the system.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mrpRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevant Flag' ;
    rdfs:comment 'True if the info record should be considered during MRP runs.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderQuantityMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Quantity Multiple' ;
    rdfs:comment 'Quantity increment that must be respected when ordering (e.g., multiples of 10).' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeDate rdf:type rdf:Property ;
    rdfs:label 'Price Change Date' ;
    rdfs:comment 'Date on which the most recent price change became effective.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Change Indicator' ;
    rdfs:comment 'Indicates whether the price has increased, decreased, or remained unchanged since the previous version.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business justification for the latest price adjustment.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseInfoRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Purchase Info Record Status' ;
    rdfs:comment 'Current lifecycle status of the info record.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Lead Time Days' ;
    rdfs:comment 'Number of days before the planned delivery date when a reminder is generated.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceOfSupplyCategory rdf:type rdf:Property ;
    rdfs:label 'Source Of Supply Category' ;
    rdfs:comment 'Broad classification of the source (e.g., internal, external, third-party).' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePriority rdf:type rdf:Property ;
    rdfs:label 'Source Priority' ;
    rdfs:comment 'Numeric rank indicating preference order among multiple approved sources for the same material.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
