    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityDelivered rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered' ;
    rdfs:comment 'Actual quantity of material that has been delivered (goods issue).' ;
    rdfs:domain ind:DeliveryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityPicked rdf:type rdf:Property ;
    rdfs:label 'Quantity Picked' ;
    rdfs:comment 'Quantity of material that has been physically picked from inventory.' ;
    rdfs:domain ind:DeliveryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberEnd rdf:type rdf:Property ;
    rdfs:label 'Serial Number End' ;
    rdfs:comment 'Ending serial number of the range allocated to this line.' ;
    rdfs:domain ind:DeliveryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberStart rdf:type rdf:Property ;
    rdfs:label 'Serial Number Start' ;
    rdfs:comment 'Starting serial number of the range allocated to this line, when serial-managed.' ;
    rdfs:domain ind:DeliveryItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnFromAddressId rdf:type rdf:Property ;
    rdfs:label 'Return From Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: RMA logistics in industrial manufacturing require the validated physical address from which goods are returned for carrier scheduling, hazmat compliance, and customs documentation. Role-prefix \'return' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:returnStockLocationId rdf:type rdf:Property ;
    rdfs:label 'Return Stock Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_location. Business justification: Returned goods in manufacturing must be directed to a specific stock location (quarantine bin, returns area, inspection zone) for putaway execution and quality inspection workflows. return_plant is a ' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLocation .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'Date the returned items were actually received.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Authorized Quantity' ;
    rdfs:comment 'Quantity of items the system authorizes for return based on the original order.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the logistics carrier handling the return shipment.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Total credit to be applied to the customer\'s account.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoIndicator rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Indicator' ;
    rdfs:comment 'Flag indicating whether a credit memo will be issued for this RMA.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Planned date by which the returned items should arrive at the plant.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:handlingFee rdf:type rdf:Property ;
    rdfs:label 'Handling Fee' ;
    rdfs:comment 'Fee charged for processing the return.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDamaged rdf:type rdf:Property ;
    rdfs:label 'Is Damaged' ;
    rdfs:comment 'True if the returned item was received with damage.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepairable rdf:type rdf:Property ;
    rdfs:label 'Is Repairable' ;
    rdfs:comment 'True if the returned item can be repaired rather than replaced.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWarrantyClaim rdf:type rdf:Property ;
    rdfs:label 'Is Warranty Claim' ;
    rdfs:comment 'True if the return is processed under a warranty agreement.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWrongItem rdf:type rdf:Property ;
    rdfs:label 'Is Wrong Item' ;
    rdfs:comment 'True if the returned item does not match the original order.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderRmaStatus rdf:type rdf:Property ;
    rdfs:label 'Order Rma Status' ;
    rdfs:comment 'Current lifecycle state of the RMA.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Monetary amount to be refunded to the customer before taxes and fees.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementQuantity rdf:type rdf:Property ;
    rdfs:label 'Replacement Quantity' ;
    rdfs:comment 'Quantity of replacement units to be shipped.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the RMA was initially requested by the customer or service team.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code representing why the product is being returned.' ;
    rdfs:domain ind:Order ;
