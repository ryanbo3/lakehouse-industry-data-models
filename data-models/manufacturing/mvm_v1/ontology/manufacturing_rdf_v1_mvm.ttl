    rdfs:range xsd:decimal .

ind:oeeTarget rdf:type rdf:Property ;
    rdfs:label 'Oee Target' ;
    rdfs:comment 'Planned OEE percentage target for the plant.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalSince rdf:type rdf:Property ;
    rdfs:label 'Operational Since' ;
    rdfs:comment 'Date the plant began commercial operations.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plantDescription rdf:type rdf:Property ;
    rdfs:label 'Plant Description' ;
    rdfs:comment 'Free-form textual description of the plant\'s purpose and characteristics.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Human-readable name of the plant.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantType rdf:type rdf:Property ;
    rdfs:label 'Plant Type' ;
    rdfs:comment 'Category of the plant based on its primary function.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Count' ;
    rdfs:comment 'Number of recorded safety incidents in the reporting period.' ;
