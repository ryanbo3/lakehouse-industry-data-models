ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the plant manager.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerPhone rdf:type rdf:Property ;
    rdfs:label 'Manager Phone' ;
    rdfs:comment 'Primary contact phone number for the plant manager.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeActual rdf:type rdf:Property ;
    rdfs:label 'Oee Actual' ;
    rdfs:comment 'Measured OEE percentage achieved.' ;
    rdfs:domain ind:Plant ;
