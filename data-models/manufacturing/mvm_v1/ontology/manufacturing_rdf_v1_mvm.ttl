    rdfs:range xsd:integer .

ind:safetyIncidentLastDate rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Last Date' ;
    rdfs:comment 'Date of the most recent safety incident.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteGeneratedTons rdf:type rdf:Property ;
    rdfs:label 'Waste Generated Tons' ;
    rdfs:comment 'Quantity of waste produced by the plant in metric tons.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterConsumptionM3 rdf:type rdf:Property ;
    rdfs:label 'Water Consumption M3' ;
    rdfs:comment 'Total water usage for the reporting period in cubic metres.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementEquipmentRegisterId rdf:type rdf:Property ;
    rdfs:label 'Measurement Equipment Register Id' ;
    rdfs:comment 'Foreign key linking to asset.equipment_register. Business justification: Inspection characteristics define the gauge/instrument required for measurement. IATF 16949 MSA (Measurement System Analysis) requires traceability from each inspection characteristic to the specific ' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentRegister .

ind:parentInspectionCharacteristicId rdf:type rdf:Property ;
    rdfs:label 'Parent Inspection Characteristic Id' ;
    rdfs:comment 'Self-referencing FK on inspection_characteristic (parent_inspection_characteristic_id)' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionCharacteristic .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Impact level of the characteristic on product quality and compliance.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionSystem rdf:type rdf:Property ;
    rdfs:label 'Data Collection System' ;
    rdfs:comment 'System that records the measurement data (e.g., MES, PLC, manual log).' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyPerShift rdf:type rdf:Property ;
    rdfs:label 'Frequency Per Shift' ;
    rdfs:comment 'Number of times this characteristic is inspected each production shift.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionCharacteristicCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Code' ;
    rdfs:comment 'Unique alphanumeric code assigned by engineering to identify the characteristic across systems.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Description' ;
    rdfs:comment 'Detailed description of what the characteristic measures and why it is important.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicName rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Name' ;
    rdfs:comment 'Human-readable name of the inspection characteristic used in reports and work instructions.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRequired rdf:type rdf:Property ;
    rdfs:label 'Is Required' ;
    rdfs:comment 'Indicates whether the characteristic must be inspected for every unit.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatisticalProcessControl rdf:type rdf:Property ;
    rdfs:label 'Is Statistical Process Control' ;
    rdfs:comment 'True if the characteristic is used in SPC calculations (Cp/Cpk).' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingPlan rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan' ;
    rdfs:comment 'Definition of the sampling approach (e.g., 1-in-5, 100% inspection).' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specSource rdf:type rdf:Property ;
    rdfs:label 'Spec Source' ;
    rdfs:comment 'Origin of the specification limits for the characteristic.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerance rdf:type rdf:Property ;
    rdfs:label 'Tolerance' ;
    rdfs:comment 'Allowed deviation from the target value, expressed in the same unit as measurement_unit.' ;
    rdfs:domain ind:InspectionCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCharacteristicAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Plan Characteristic Assignment Id' ;
    rdfs:comment 'Primary key for the plan_characteristic_assignment association' ;
    rdfs:domain ind:PlanCharacteristicAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characteristicCount rdf:type rdf:Property ;
    rdfs:label 'Characteristic Count' ;
    rdfs:comment 'Total number of inspection characteristics (measurement parameters) defined within this inspection plan. Provides a quick summary of plan complexity for scheduling and resource planning. [Moved from inspection_plan: This is a derived aggregate (count of assigned characteristics) that should be computed from the association table rather than stored as a denormalized field on the plan header. Storing it on the plan creates a maintenance burden and risks inconsistency with the actual assignment records.]' ;
    rdfs:domain ind:PlanCharacteristicAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characteristicUnit rdf:type rdf:Property ;
    rdfs:label 'Characteristic Unit' ;
    rdfs:comment 'Unit of measure for the inspection characteristic tolerance limits and target value (e.g., mm, µm, N, bar, °C, %). Aligns with SAP QM master inspection characteristic unit. [Moved from inspection_plan: The unit of measure for tolerance limits is a property of the specific characteristic being measured, not of the plan as a whole. A plan covers many characteristics with different units (mm, °C, N·m). This attribute belongs on the assignment or on the characteristic master, not on the plan header. If it represents a plan-level default, it is misleading; if it represents a specific characteristic\'s unit, it belongs on the assignment.]' ;
    rdfs:domain ind:PlanCharacteristicAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMethodOverride rdf:type rdf:Property ;
    rdfs:label 'Control Method Override' ;
    rdfs:comment 'Overrides the default inspection method defined on the master characteristic for this plan. For example, a final inspection plan may require CMM measurement where the in-process plan uses a manual gauge. Null if the master control method applies.' ;
    rdfs:domain ind:PlanCharacteristicAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this characteristic must be measured for every unit inspected under this plan. A characteristic may be mandatory in one plan (safety-critical context) and optional in another (reduced inspection scope). Cannot reside on the characteristic master because the obligation is plan-specific.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleSizeOverride rdf:type rdf:Property ;
    rdfs:label 'Sample Size Override' ;
    rdfs:comment 'Overrides the default sampling plan defined on the master inspection_characteristic for this specific plan context. For example, a PPAP plan may require 100% inspection of a characteristic that is normally sampled 1-in-5 in routine production. Null if the characteristic\'s default sampling plan applies.' ;
    rdfs:domain ind:PlanCharacteristicAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceOverride rdf:type rdf:Property ;
    rdfs:label 'Tolerance Override' ;
    rdfs:comment 'Overrides the master characteristic\'s default tolerance value for this specific plan. Allows tightening of tolerances for customer-specific or PPAP requirements without modifying the master characteristic definition. Null if the master tolerance applies.' ;
    rdfs:domain ind:PlanCharacteristicAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobPlanMaterialRequirementId rdf:type rdf:Property ;
    rdfs:label 'Job Plan Material Requirement Id' ;
    rdfs:comment 'Primary key for the job_plan_material_requirement association' ;
    rdfs:domain ind:JobPlanMaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Part Sequence Number' ;
    rdfs:comment 'Sequence number defining the order in which this material is staged or consumed within the job plan task steps. Belongs to the requirement relationship, not to either entity alone.' ;
    rdfs:domain ind:JobPlanMaterialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingOperationId rdf:type rdf:Property ;
    rdfs:label 'Routing Operation Id' ;
    rdfs:comment 'Primary key for the routing_operation association' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Labor Time Minutes' ;
    rdfs:comment 'Standard labor time in minutes per base quantity for this operation step. May differ from machine time when operator and machine run concurrently.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Machine Time Minutes' ;
    rdfs:comment 'Standard machine time in minutes per base quantity for this operation step. Used for machine capacity planning and OEE calculations.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationDescription rdf:type rdf:Property ;
    rdfs:label 'Operation Description' ;
    rdfs:comment 'Short description of the work to be performed at this operation step within this routing. Describes the specific task (e.g., \'Rough mill housing bore\'), not the work center capability in general.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Processing Time Minutes' ;
    rdfs:comment 'Standard machine or processing time in minutes per base quantity for this operation step. Used for capacity planning and standard cost calculation.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardValues rdf:type rdf:Property ;
    rdfs:label 'Standard Values' ;
    rdfs:comment 'Standard value key defining which standard values (setup, machine, labor, teardown) are relevant for this operation and how they are used in costing and scheduling formulas.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedItemId rdf:type rdf:Property ;
    rdfs:label 'Affected Item Id' ;
    rdfs:comment 'Primary key for the affected_item association' ;
    rdfs:domain ind:AffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current implementation status of the change for this specific component. Tracked per affected item to allow partial ECO closure when some components are implemented ahead of others.' ;
    rdfs:domain ind:AffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAffected rdf:type rdf:Property ;
    rdfs:label 'Quantity Affected' ;
    rdfs:comment 'The quantity of this component in existing inventory or WIP that is subject to the disposition action. Belongs to the affected item relationship as it is specific to the ECO-component pairing at the time of change.' ;
    rdfs:domain ind:AffectedItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .
