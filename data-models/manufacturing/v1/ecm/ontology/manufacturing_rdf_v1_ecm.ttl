    rdfs:comment 'Classification of transportation mode and carrier.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdId rdf:type rdf:Property ;
    rdfs:label 'Hold Id' ;
    rdfs:comment 'System-generated unique identifier for the order hold record.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Hold Employee Id' ;
    rdfs:comment 'Identifier of the internal user or system that created the hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:holdReleasingUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Hold Releasing User Employee Id' ;
    rdfs:comment 'Identifier of the user or system that released the hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the hold is required for regulatory compliance (e.g., export control).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdCategory rdf:type rdf:Property ;
    rdfs:label 'Hold Category' ;
    rdfs:comment 'High-level grouping of the hold type for reporting.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Human-readable identifier for the hold, used in communications and reporting.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdSource rdf:type rdf:Property ;
    rdfs:label 'Hold Source' ;
    rdfs:comment 'Origin of the hold – whether it was triggered by an automated system rule or a manual user action.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle state of the hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Category of the hold condition that blocks order fulfillment.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSystemGenerated rdf:type rdf:Property ;
    rdfs:label 'Is System Generated' ;
    rdfs:comment 'True if the hold was automatically created by a system rule; false if manually entered.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Placed Timestamp' ;
    rdfs:comment 'Date-time when the hold became effective.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseConditions rdf:type rdf:Property ;
    rdfs:label 'Release Conditions' ;
    rdfs:comment 'Conditions that must be satisfied for the hold to be released.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteLineId rdf:type rdf:Property ;
    rdfs:label 'Quote Line Id' ;
    rdfs:comment 'Foreign key linking to sales.quote_line. Business justification: Audit trail: order line must reference the originating quote line to validate pricing, configuration, and warranty obligations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteLine .

ind:backorderIndicator rdf:type rdf:Property ;
    rdfs:label 'Backorder Indicator' ;
    rdfs:comment 'True if the line is on backorder, otherwise false.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blanketReleaseNumber rdf:type rdf:Property ;
    rdfs:label 'Blanket Release Number' ;
    rdfs:comment 'Identifier of the blanket order release that generated this line.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Quantity confirmed by the system after availability check.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPrice rdf:type rdf:Property ;
    rdfs:label 'Gross Price' ;
    rdfs:comment 'Total price after taxes and before discounts.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Net price per unit before taxes and discounts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingCondition rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition' ;
    rdfs:comment 'Pricing condition type governing the price calculation.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDate rdf:type rdf:Property ;
    rdfs:label 'Promised Date' ;
    rdfs:comment 'Date promised to the customer for delivery.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Numeric score representing quality assessment (0-100).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Reason provided when the line is rejected or cancelled.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'Quantity originally requested by the customer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaReference rdf:type rdf:Property ;
    rdfs:label 'Rma Reference' ;
    rdfs:comment 'Reference to an RMA record if the line is a return.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrg rdf:type rdf:Property ;
    rdfs:label 'Sales Org' ;
    rdfs:comment 'Organizational unit responsible for the sale.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesPrice rdf:type rdf:Property ;
    rdfs:label 'Sales Price' ;
    rdfs:comment 'Price per unit used for revenue recognition.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesQuantity rdf:type rdf:Property ;
    rdfs:label 'Sales Quantity' ;
    rdfs:comment 'Quantity used for sales reporting, may differ from requested/confirmed units.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleLineDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Date' ;
    rdfs:comment 'Planned date for delivery or production of this line item.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure for volume.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUom rdf:type rdf:Property ;
    rdfs:label 'Weight Uom' ;
    rdfs:comment 'Unit of measure for weight fields.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionId rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Id' ;
    rdfs:comment 'System-generated unique identifier for the pricing condition record.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionTypeId rdf:type rdf:Property ;
    rdfs:label 'Condition Type Id' ;
    rdfs:comment 'Technical identifier linking to the master list of condition types.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConditionType .

ind:calculationBase rdf:type rdf:Property ;
    rdfs:label 'Calculation Base' ;
    rdfs:comment 'Reference base used for the condition calculation (e.g., net price, gross price, quantity).' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'Free-text description of the pricing condition purpose or notes.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionEffectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Condition Effective Timestamp' ;
    rdfs:comment 'Exact timestamp when the condition became effective for the order line.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conditionExpirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Condition Expiration Timestamp' ;
    rdfs:comment 'Exact timestamp when the condition expired or was superseded.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conditionGroup rdf:type rdf:Property ;
    rdfs:label 'Condition Group' ;
    rdfs:comment 'Logical grouping identifier for related conditions (e.g., volume rebate group).' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionNote rdf:type rdf:Property ;
    rdfs:label 'Condition Note' ;
    rdfs:comment 'Additional free-form notes or comments entered by users regarding the condition.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionOrigin rdf:type rdf:Property ;
    rdfs:label 'Condition Origin' ;
    rdfs:comment 'Source of the condition – manually entered, system generated, or derived from a contract.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionPriority rdf:type rdf:Property ;
    rdfs:label 'Condition Priority' ;
    rdfs:comment 'Priority order used when multiple conditions could apply; lower numbers indicate higher priority.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionRate rdf:type rdf:Property ;
    rdfs:label 'Condition Rate' ;
    rdfs:comment 'Percentage or rate applied by the condition (e.g., 5% discount).' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionRateUnit rdf:type rdf:Property ;
    rdfs:label 'Condition Rate Unit' ;
    rdfs:comment 'Unit for the condition rate, such as "%" or "per_unit".' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionSequence rdf:type rdf:Property ;
    rdfs:label 'Condition Sequence' ;
    rdfs:comment 'Sequential number indicating the order of this condition within the pricing procedure for the line.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current lifecycle status of the condition.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Category of the pricing condition, such as base price, discount, surcharge, tax, or rebate.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionValue rdf:type rdf:Property ;
    rdfs:label 'Condition Value' ;
    rdfs:comment 'Monetary value associated with the condition (e.g., discount amount, surcharge amount).' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalConditionReference rdf:type rdf:Property ;
    rdfs:label 'External Condition Reference' ;
    rdfs:comment 'Identifier of the condition in an external system or contract (e.g., supplier agreement reference).' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'Indicates whether the condition relates to an expedited delivery surcharge.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingProcedureStep rdf:type rdf:Property ;
    rdfs:label 'Pricing Procedure Step' ;
    rdfs:comment 'Step number within the pricing procedure where this condition is applied.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scaleQuantity rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity' ;
    rdfs:comment 'Quantity threshold at which a scale-based price or discount becomes applicable.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity Uom' ;
    rdfs:comment 'Unit of measure for the scale quantity break (e.g., EA, KG).' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Monetary surcharge amount added by the condition.' ;
    rdfs:domain ind:PricingCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Date after which the pricing condition is no longer valid.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Date from which the pricing condition becomes valid.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleLineId rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Id' ;
    rdfs:comment 'System-generated unique identifier for the schedule line record.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:splitParentLineId rdf:type rdf:Property ;
    rdfs:label 'Split Parent Line Id' ;
    rdfs:comment 'Reference to the original schedule line when this line is a split part.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:confirmedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity Uom' ;
    rdfs:comment 'Unit of measure for the confirmed quantity.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNetAmount rdf:type rdf:Property ;
    rdfs:label 'Line Net Amount' ;
    rdfs:comment 'Net monetary value of the confirmed quantity before taxes.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Lot identifier for quality and compliance tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpConfirmedAvailabilityDate rdf:type rdf:Property ;
    rdfs:label 'Mrp Confirmed Availability Date' ;
    rdfs:comment 'Date when material availability was confirmed by MRP.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity Uom' ;
    rdfs:comment 'Unit of measure for the requested quantity (e.g., PCS, KG, M3).' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleLineNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Number' ;
    rdfs:comment 'Sequential number of the schedule line within the order line item.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleLineStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Status' ;
    rdfs:comment 'Current processing status of the schedule line.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitIndicator rdf:type rdf:Property ;
    rdfs:label 'Split Indicator' ;
    rdfs:comment 'True if the original order line has been split into multiple schedule lines.' ;
    rdfs:domain ind:ScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderStatusEventId rdf:type rdf:Property ;
    rdfs:label 'Order Status Event Id' ;
    rdfs:comment 'System-generated unique identifier for each immutable status event record.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeredByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Triggered By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory audit of order status changes mandates recording the employee who triggered each event.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:businessReasonCode rdf:type rdf:Property ;
    rdfs:label 'Business Reason Code' ;
    rdfs:comment 'Higher-level business driver for the event (e.g., demand_spike, inventory_shortage).' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequence rdf:type rdf:Property ;
    rdfs:label 'Event Sequence' ;
    rdfs:comment 'Sequential number of the event for the given order, starting at 1.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'Originating system or application that generated the event (e.g., SAP SD, Opcenter MES).' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'Order status after the event was applied. [ENUM-REF-CANDIDATE: created|confirmed|released|scheduled|shipped|delivered|cancelled|on_hold|closed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'Order status before the event was applied. [ENUM-REF-CANDIDATE: created|confirmed|released|scheduled|shipped|delivered|cancelled|on_hold|closed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Id' ;
    rdfs:comment 'System-generated unique identifier for the proof of delivery record.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'Monetary amount invoiced to the customer as a result of the delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryCondition rdf:type rdf:Property ;
    rdfs:label 'Delivery Condition' ;
    rdfs:comment 'Condition of the goods as reported by the recipient at receipt.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text notes describing any differences between ordered and received quantities or condition.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Latitude coordinate of the delivery location captured at proof of delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Longitude coordinate of the delivery location captured at proof of delivery.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Document Url' ;
    rdfs:comment 'Link to the stored electronic proof of delivery document (PDF, image, etc.).' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podNumber rdf:type rdf:Property ;
    rdfs:label 'Pod Number' ;
    rdfs:comment 'External business identifier assigned to the proof of delivery, often used in customer communications.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSource rdf:type rdf:Property ;
    rdfs:label 'Pod Source' ;
    rdfs:comment 'Origin of the POD record (e.g., captured electronically on device, paper form, or carrier EDI).' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pod Timestamp' ;
    rdfs:comment 'Date and time when the proof of delivery was recorded at the delivery site.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proofOfDeliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the proof of delivery record.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientSignature rdf:type rdf:Property ;
    rdfs:label 'Recipient Signature' ;
    rdfs:comment 'Reference (e.g., URL or hash) to the captured signature of the recipient.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderRmaId rdf:type rdf:Property ;
    rdfs:label 'Order Rma Id' ;
    rdfs:comment 'Unique system-generated identifier for the RMA record.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderRma .

ind:primaryOrderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Employee Id' ;
    rdfs:comment 'User identifier of the person who approved the RMA.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOrderUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Order Updated By User Employee Id' ;
    rdfs:comment 'User who performed the most recent update to the RMA.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'Date the returned items were actually received.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Authorized Quantity' ;
    rdfs:comment 'Quantity of items the system authorizes for return based on the original order.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Total credit to be applied to the customer\'s account.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoIndicator rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Indicator' ;
    rdfs:comment 'Flag indicating whether a credit memo will be issued for this RMA.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Planned date by which the returned items should arrive at the plant.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:handlingFee rdf:type rdf:Property ;
    rdfs:label 'Handling Fee' ;
    rdfs:comment 'Fee charged for processing the return.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDamaged rdf:type rdf:Property ;
    rdfs:label 'Is Damaged' ;
    rdfs:comment 'True if the returned item was received with damage.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepairable rdf:type rdf:Property ;
    rdfs:label 'Is Repairable' ;
    rdfs:comment 'True if the returned item can be repaired rather than replaced.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWarrantyClaim rdf:type rdf:Property ;
    rdfs:label 'Is Warranty Claim' ;
    rdfs:comment 'True if the return is processed under a warranty agreement.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWrongItem rdf:type rdf:Property ;
    rdfs:label 'Is Wrong Item' ;
    rdfs:comment 'True if the returned item does not match the original order.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderRmaStatus rdf:type rdf:Property ;
    rdfs:label 'Order Rma Status' ;
    rdfs:comment 'Current lifecycle state of the RMA.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Monetary amount to be refunded to the customer before taxes and fees.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementQuantity rdf:type rdf:Property ;
    rdfs:label 'Replacement Quantity' ;
    rdfs:comment 'Quantity of replacement units to be shipped.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnPlant rdf:type rdf:Property ;
    rdfs:label 'Return Plant' ;
    rdfs:comment 'Plant or warehouse code where the returned items are to be received.' ;
    rdfs:domain ind:OrderRma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code representing why the product is being returned.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Free-text description providing details about the return reason.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Actual number of units received back from the customer.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Business-visible RMA number assigned by the order management system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaType rdf:type rdf:Property ;
    rdfs:label 'Rma Type' ;
    rdfs:comment 'Classification of the RMA (e.g., warranty, non-warranty, repair, replacement).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaLineId rdf:type rdf:Property ;
    rdfs:label 'Rma Line Id' ;
    rdfs:comment 'System-generated unique identifier for the RMA line item.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Code indicating the physical condition of the returned item (e.g., new, damaged, used).' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Reason' ;
    rdfs:comment 'Narrative explanation for the chosen disposition action.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date the returned material was received at the warehouse.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replaceFlag rdf:type rdf:Property ;
    rdfs:label 'Replace Flag' ;
    rdfs:comment 'True if the returned item will be replaced with a new unit.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replacementPartNumber rdf:type rdf:Property ;
    rdfs:label 'Replacement Part Number' ;
    rdfs:comment 'Material number of the replacement part, if a replace action is selected.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockBin rdf:type rdf:Property ;
    rdfs:label 'Restock Bin' ;
    rdfs:comment 'Specific bin or storage location within the warehouse.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockLocation rdf:type rdf:Property ;
    rdfs:label 'Restock Location' ;
    rdfs:comment 'Logical location where the item will be restocked (e.g., plant, zone).' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockQuantity rdf:type rdf:Property ;
    rdfs:label 'Restock Quantity' ;
    rdfs:comment 'Quantity of the item to be returned to inventory after disposition.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restockStatus rdf:type rdf:Property ;
    rdfs:label 'Restock Status' ;
    rdfs:comment 'Current processing status of the restocking operation.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockWarehouse rdf:type rdf:Property ;
    rdfs:label 'Restock Warehouse' ;
    rdfs:comment 'Warehouse identifier for the restocked inventory.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date the customer initiated the return request.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'True if the item requires rework before it can be restocked.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapFlag rdf:type rdf:Property ;
    rdfs:label 'Scrap Flag' ;
    rdfs:comment 'True if the returned item is to be scrapped.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapReason rdf:type rdf:Property ;
    rdfs:label 'Scrap Reason' ;
    rdfs:comment 'Explanation for why the item is being scrapped.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'True if the return is covered under a warranty claim.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Number' ;
    rdfs:comment 'Identifier of the warranty claim associated with this return.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Approval Document Id' ;
    rdfs:comment 'Reference to the document being approved (purchase requisition, purchase order, or sourcing event). Links to the source document requiring approval.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectDocument .

ind:primaryApprovalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Approval Employee Id' ;
    rdfs:comment 'Unique identifier of the individual who performed the approval action. Links to employee or user master data.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalAction rdf:type rdf:Property ;
    rdfs:label 'Approval Action' ;
    rdfs:comment 'Action taken by the approver on the document. Approved indicates authorization granted, rejected indicates denial, escalated indicates forwarding to higher authority, delegated indicates reassignment to another approver, returned indicates sent back for revision.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Free-text comments or notes entered by the approver explaining the approval decision, conditions, or reasons for rejection. Supports audit trail and communication.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Document Number' ;
    rdfs:comment 'Business identifier of the document being approved. Human-readable reference number such as PR number, PO number, or RFQ number.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDocumentType rdf:type rdf:Property ;
    rdfs:label 'Approval Document Type' ;
    rdfs:comment 'Type of procurement document being approved. Indicates whether the approval is for a purchase requisition, purchase order, RFQ (Request for Quotation), RFP (Request for Proposal), contract, or other sourcing event.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDueDate rdf:type rdf:Property ;
    rdfs:label 'Approval Due Date' ;
    rdfs:comment 'Target date by which the approval action should be completed. Used for SLA (Service Level Agreement) tracking and escalation triggers.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalDurationHours rdf:type rdf:Property ;
    rdfs:label 'Approval Duration Hours' ;
    rdfs:comment 'Time elapsed in hours between approval request and approval action completion. Used for cycle time analysis and process optimization.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the approval request notification was successfully sent to the approver. True indicates notification sent, false indicates pending or failed.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalReminderCount rdf:type rdf:Property ;
    rdfs:label 'Approval Reminder Count' ;
    rdfs:comment 'Number of reminder notifications sent to the approver for this pending approval. Used to track follow-up communications and escalation triggers.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Request Timestamp' ;
    rdfs:comment 'Date and time when the approval request was submitted to this approver. Marks the start of the approval cycle for this level.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Sequence Number' ;
    rdfs:comment 'Sequential order number of this approval step within the overall workflow for the document. Used to track the progression through the approval chain.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Approval Source System' ;
    rdfs:comment 'Name of the source system or application from which the approval workflow originated. Examples include SAP Ariba, SAP S/4HANA, custom procurement portal.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Amount' ;
    rdfs:comment 'Monetary threshold amount that defines the approval authority limit for this approver role at this level. Part of Delegation of Authority (DoA) matrix.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the approval threshold amount. Defines the currency in which the approval authority is denominated.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverEmail rdf:type rdf:Property ;
    rdfs:label 'Approver Email' ;
    rdfs:comment 'Email address of the approver. Used for notification and audit trail purposes.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'Functional role or job title of the approver responsible for this approval level. Examples include Purchasing Manager, Plant Manager, Finance Director, VP Procurement, CFO.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationReason rdf:type rdf:Property ;
    rdfs:label 'Delegation Reason' ;
    rdfs:comment 'Reason for delegating the approval to another approver. Examples include out of office, conflict of interest, workload balancing, temporary reassignment.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Document Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the document total amount. Indicates the currency in which the procurement document is denominated.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Document Total Amount' ;
    rdfs:comment 'Total monetary value of the document being approved. Used to determine routing through approval hierarchy based on DoA (Delegation of Authority) thresholds.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Reason for escalating the approval to a higher authority level. Examples include exceeds_authority, requires_executive_review, policy_exception, risk_assessment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Approval Flag' ;
    rdfs:comment 'Indicates whether this approval step is mandatory or optional in the workflow. True indicates required approval, false indicates advisory or optional review.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCategory rdf:type rdf:Property ;
    rdfs:label 'Material Category' ;
    rdfs:comment 'Classification of the materials or services being procured. Examples include direct materials, indirect materials, MRO (Maintenance, Repair, and Operations) supplies, capital equipment, services.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parallelApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Parallel Approval Flag' ;
    rdfs:comment 'Indicates whether this approval step is part of a parallel approval process where multiple approvers at the same level must approve simultaneously. True indicates parallel, false indicates sequential.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyViolationDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Violation Description' ;
    rdfs:comment 'Description of the specific procurement policy or business rule that was violated. Populated when policy violation flag is true.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Policy Violation Flag' ;
    rdfs:comment 'Indicates whether the procurement document violates any procurement policies or business rules. True indicates policy violation detected, false indicates compliant.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Buyer group or team responsible for specific categories of materials or suppliers. Represents the operational procurement team handling the transaction.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Organizational unit responsible for procurement activities. Represents the procurement entity within the enterprise structure (e.g., regional purchasing office, plant purchasing group).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for rejection if the approval action was rejected. Examples include budget_exceeded, supplier_not_approved, specification_incomplete, pricing_issue.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategoryId rdf:type rdf:Property ;
    rdfs:label 'Commodity Category Id' ;
    rdfs:comment 'Primary key for commodity_category' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityCategory .

ind:parentCategoryCommodityCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Commodity Category Id' ;
    rdfs:comment 'Reference to the parent category in the hierarchy. Null for top-level (L1) categories.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityCategory .

ind:primaryCommodityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Commodity Employee Id' ;
    rdfs:comment 'Identifier of the employee or procurement specialist responsible for managing this commodity category and its sourcing strategy.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCommodityLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Commodity Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified this commodity category record.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the commodity category. May align with UNSPSC (United Nations Standard Products and Services Code) or internal taxonomy.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the commodity category scope, including typical materials, services, or products classified under this category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryLevel rdf:type rdf:Property ;
    rdfs:label 'Category Level' ;
    rdfs:comment 'Hierarchical level of the category within the taxonomy structure. L1 represents top-level, L2 sub-category, L3 detailed category, etc.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryManagerName rdf:type rdf:Property ;
    rdfs:label 'Category Manager Name' ;
    rdfs:comment 'Full name of the category manager responsible for strategic sourcing and supplier relationships within this category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full descriptive name of the commodity category (e.g., Electrical Components, Raw Steel, MRO Supplies).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the commodity category within the procurement taxonomy.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Flag' ;
    rdfs:comment 'Indicates whether this category has specific regulatory compliance requirements (e.g., RoHS, REACH, conflict minerals, ISO certifications).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Coverage Flag' ;
    rdfs:comment 'Indicates whether this category is covered by active procurement contracts or framework agreements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costReductionTargetPct rdf:type rdf:Property ;
    rdfs:label 'Cost Reduction Target Pct' ;
    rdfs:comment 'Annual cost reduction target percentage for this category as part of strategic sourcing initiatives.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Indicates whether this category requires environmental compliance certifications such as ISO 14001, RoHS, REACH, or conflict minerals reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDaysAvg rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days Avg' ;
    rdfs:comment 'Average procurement lead time in days for materials and services within this category, from requisition to delivery.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moqApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Moq Applicable Flag' ;
    rdfs:comment 'Indicates whether suppliers in this category typically enforce minimum order quantity requirements.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationFrequency rdf:type rdf:Property ;
    rdfs:label 'Negotiation Frequency' ;
    rdfs:comment 'Typical frequency of contract negotiations and RFx events for this commodity category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierCount rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Count' ;
    rdfs:comment 'Number of preferred suppliers currently approved and active for this commodity category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this category has designated preferred suppliers with negotiated contracts or framework agreements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceVolatilityIndex rdf:type rdf:Property ;
    rdfs:label 'Price Volatility Index' ;
    rdfs:comment 'Classification of price volatility for commodities in this category based on historical price fluctuations and market dynamics.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Required' ;
    rdfs:comment 'Comma-separated list of required quality certifications for suppliers in this category (e.g., ISO 9001, IATF 16949, AS9100).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Risk classification based on supply chain vulnerability, supplier concentration, geopolitical factors, and material criticality.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy' ;
    rdfs:comment 'Defined sourcing strategy for this category: single-source, dual-source, multi-source, global sourcing, or local sourcing approach.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendType rdf:type rdf:Property ;
    rdfs:label 'Spend Type' ;
    rdfs:comment 'Classification of spend type: direct materials (production inputs), indirect materials (non-production), MRO (Maintenance, Repair, Operations), CapEx (Capital Expenditure), or services.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicSourcingPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Sourcing Priority' ;
    rdfs:comment 'Priority level assigned to this category for strategic sourcing initiatives based on spend volume, supply risk, and business impact.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscClass rdf:type rdf:Property ;
    rdfs:label 'Unspsc Class' ;
    rdfs:comment 'Third-level UNSPSC class name within the family (e.g., Cutting and Forming Machines).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscCode rdf:type rdf:Property ;
    rdfs:label 'Unspsc Code' ;
    rdfs:comment 'Eight-digit UNSPSC classification code for global commodity standardization and cross-industry spend analysis.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscCommodity rdf:type rdf:Property ;
    rdfs:label 'Unspsc Commodity' ;
    rdfs:comment 'Fourth-level UNSPSC commodity name, the most granular classification level (e.g., CNC Milling Machines).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscFamily rdf:type rdf:Property ;
    rdfs:label 'Unspsc Family' ;
    rdfs:comment 'Second-level UNSPSC family name within the segment (e.g., Metalworking Machinery and Equipment).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unspscSegment rdf:type rdf:Property ;
    rdfs:label 'Unspsc Segment' ;
    rdfs:comment 'Top-level UNSPSC segment name (e.g., Industrial Manufacturing and Processing Machinery and Accessories).' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReleaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Contract Release Order Id' ;
    rdfs:comment 'Unique identifier for the contract release order record. Primary key for this entity.' ;
    rdfs:domain ind:ContractReleaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAddressId rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Id' ;
    rdfs:comment 'Reference to the delivery address for this release, may differ from the default plant address for direct shipments.' ;
    rdfs:domain ind:ContractReleaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:primaryContractEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Contract Employee Id' ;
    rdfs:comment 'Reference to the employee or user who requested this release order.' ;
    rdfs:domain ind:ContractReleaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:procurementContractId rdf:type rdf:Property ;
    rdfs:label 'Procurement Contract Id' ;
    rdfs:comment 'Reference to the scheduling agreement if this release is drawn against a scheduling agreement rather than a blanket PO.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementContract .

ind:servicePmScheduleId rdf:type rdf:Property ;
    rdfs:label 'Service Pm Schedule Id' ;
    rdfs:comment 'Foreign key linking to service.service_pm_schedule. Business justification: Preventive Maintenance Scheduling: contract release orders include a link to the PM schedule they fulfill.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServicePmSchedule .

ind:contractRemainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Contract Remaining Quantity' ;
    rdfs:comment 'Remaining quantity available under the parent contract after this release is issued, used for tracking contract consumption.' ;
    rdfs:domain ind:ContractReleaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRemainingValue rdf:type rdf:Property ;
    rdfs:label 'Contract Remaining Value' ;
    rdfs:comment 'Remaining monetary value available under the parent contract after this release is issued.' ;
    rdfs:domain ind:ContractReleaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Release Quantity' ;
    rdfs:comment 'Quantity of material or service units being called off in this release order.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseSequence rdf:type rdf:Property ;
    rdfs:label 'Release Sequence' ;
    rdfs:comment 'Sequential ordering of this release within the parent contract or scheduling agreement, used for tracking call-off progression.' ;
    rdfs:domain ind:ContractReleaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseType rdf:type rdf:Property ;
    rdfs:label 'Release Type' ;
    rdfs:comment 'Classification of the release order indicating the nature of the call-off: standard scheduled release, urgent expedited release, partial delivery, final release closing the contract, blanket call-off, or scheduled delivery.' ;
    rdfs:domain ind:ContractReleaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseValue rdf:type rdf:Property ;
    rdfs:label 'Release Value' ;
    rdfs:comment 'Total monetary value of this release order, calculated as release quantity multiplied by unit price.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceLineItemId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Item Id' ;
    rdfs:comment 'Unique identifier for the invoice line item. Primary key for this entity.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poLineItemId rdf:type rdf:Property ;
    rdfs:label 'Po Line Item Id' ;
    rdfs:comment 'Reference to the purchase order line item that this invoice line corresponds to. Used for three-way matching between PO, goods receipt, and invoice.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLineItem .

ind:serviceEntrySheetId rdf:type rdf:Property ;
    rdfs:label 'Service Entry Sheet Id' ;
    rdfs:comment 'Reference to the service entry sheet if this line item corresponds to a service rather than a material. Used for service procurement verification.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceEntrySheet .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Line-item verification is performed by an employee; capturing the verifier supports three-way match audit and compliance reporting.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'The quantity recorded on the goods receipt document. Used to compare against invoiced quantity for quantity variance detection.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'The quantity of material or service units being invoiced on this line. Used for three-way match verification against PO quantity and goods receipt quantity.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'The three-way match status of this invoice line. Indicates whether the line passed matching validation or has variances requiring resolution. Blocked status prevents payment until resolved.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poQuantity rdf:type rdf:Property ;
    rdfs:label 'Po Quantity' ;
    rdfs:comment 'The quantity specified on the original purchase order line. Used as the baseline for three-way match verification.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Po Unit Price' ;
    rdfs:comment 'The unit price specified on the original purchase order line. Used as the baseline for price variance detection during invoice verification.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVariance rdf:type rdf:Property ;
    rdfs:label 'Price Variance' ;
    rdfs:comment 'The difference between invoiced unit price and PO unit price, multiplied by invoiced quantity. Indicates pricing discrepancies requiring review.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The difference between invoiced quantity and goods receipt quantity. Positive values indicate over-invoicing, negative values indicate under-invoicing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'The tolerance group that defines acceptable variance thresholds for this line item. Different tolerance groups may apply to different material categories or supplier relationships.' ;
    rdfs:domain ind:InvoiceLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'The current verification status of this invoice line in the approval workflow. Tracks progress through invoice verification and approval process.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'Classification determining how procurement costs are allocated in financial accounting (e.g., to cost center, asset, WBS element, or sales order).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the procurement professional responsible for sourcing and managing this purchase order line item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating this line item has been marked for deletion or cancellation. Prevents further goods receipt and invoice posting.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalInvoiceIndicator rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Indicator' ;
    rdfs:comment 'Flag indicating the final invoice has been received and no further invoices are expected for this line item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether invoice verification is required for this line item. Controls accounts payable processing workflow.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Total value of this line item calculated as (quantity_ordered / price_unit) * net_price. Excludes taxes and freight charges.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'Outstanding quantity still to be delivered, calculated as quantity_ordered minus quantity_received. Used for supplier follow-up and expediting.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityInvoiced rdf:type rdf:Property ;
    rdfs:label 'Quantity Invoiced' ;
    rdfs:comment 'Cumulative quantity invoiced by the supplier against this line item to date. Used for invoice verification and payment processing.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the employee or department that originated the purchase requisition leading to this line item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingInstruction rdf:type rdf:Property ;
    rdfs:label 'Shipping Instruction' ;
    rdfs:comment 'Special instructions for packaging, labeling, or delivery requirements specific to this line item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Brief description of the material or service being procured on this line. Provides human-readable context for the line item.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfSupply rdf:type rdf:Property ;
    rdfs:label 'Source Of Supply' ;
    rdfs:comment 'Classification of the procurement source type. Determines procurement processing logic and inventory valuation method.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Number' ;
    rdfs:comment 'The suppliers own part number or SKU for the material being procured. Used for supplier communication and catalog matching.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProcurementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Procurement Employee Id' ;
    rdfs:comment 'Reference to the employee or procurement manager responsible for managing and administering this contract.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryProcurementLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Procurement Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user or employee who last modified this contract record.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of amendments or change orders issued against this contract since its original approval.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidentialityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Flag' ;
    rdfs:comment 'Indicates whether the contract includes confidentiality or non-disclosure provisions protecting proprietary information. True if confidentiality terms are present, False otherwise.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractDescription rdf:type rdf:Property ;
    rdfs:label 'Contract Description' ;
    rdfs:comment 'Detailed narrative description of the scope, purpose, and key terms of the procurement contract.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name or title of the procurement contract for easy identification and reference.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Primary delivery destination or plant location for materials or services procured under this contract.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or modification to the contract terms. Nullable if no amendments have been made.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Description of financial penalties or liquidated damages applicable for supplier non-compliance with contract terms, SLA breaches, or quality failures.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDeescalationMechanism rdf:type rdf:Property ;
    rdfs:label 'Price Deescalation Mechanism' ;
    rdfs:comment 'Formula or methodology for reducing contract prices based on volume commitments, market conditions, or continuous improvement targets.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceEscalationMechanism rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Mechanism' ;
    rdfs:comment 'Formula or methodology for adjusting contract prices over time based on indices (e.g., CPI, commodity indices), exchange rates, or negotiated percentage increases.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRequirements rdf:type rdf:Property ;
    rdfs:label 'Quality Requirements' ;
    rdfs:comment 'Specific quality standards, certifications, inspection criteria, and acceptance testing requirements mandated in the contract (e.g., ISO 9001, PPAP, APQP, specific Cpk targets).' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingValue rdf:type rdf:Property ;
    rdfs:label 'Remaining Value' ;
    rdfs:comment 'Monetary value still available for release under this contract, calculated as total contract value minus release value.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months for each automatic renewal period if auto renewal is enabled. Nullable if auto renewal is not applicable.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTerms rdf:type rdf:Property ;
    rdfs:label 'Sla Terms' ;
    rdfs:comment 'Service level commitments and performance targets defined in the contract, such as lead time, on-time delivery rate, quality standards, and response times.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Planned or committed quantity of materials or services to be procured under this contract for quantity-based agreements. Nullable for value-based contracts.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Maximum monetary value committed under this procurement contract for value-based contracts, or estimated total spend for quantity-based contracts.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Warranty coverage and duration provided by the supplier for materials or services under this contract, including defect remediation and replacement terms.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Procurement Goods Receipt Id' ;
    rdfs:comment 'Unique identifier for the goods receipt document. Primary key for the procurement goods receipt entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementGoodsReceipt .

ind:damageFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Flag' ;
    rdfs:comment 'Indicates whether the received goods were damaged during transit or delivery. True if damage was observed; false otherwise. Triggers quality hold and supplier notification.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptValue rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Value' ;
    rdfs:comment 'The total monetary value of the goods received, calculated as received quantity multiplied by the purchase order unit price. Posted to inventory and General Ledger (GL) accounts.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grIrClearingStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Ir Clearing Status' ;
    rdfs:comment 'Indicates the clearing status of the GR/IR account in accounts payable. Open means no invoice received; partially cleared means partial invoice match; fully cleared means invoice fully matched and cleared.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Flag' ;
    rdfs:comment 'Indicates whether an invoice has been received and verified against this goods receipt as part of the three-way match process (PO-GR-Invoice). True if invoice verified; false otherwise.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity originally ordered on the purchase order line. Used to calculate over-delivery or under-delivery variances.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the received goods must undergo quality inspection before being released to unrestricted inventory. True if inspection is required; false otherwise.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The quantity of material or service units physically received and recorded in this goods receipt. Used for inventory update and three-way match validation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingPersonName rdf:type rdf:Property ;
    rdfs:label 'Receiving Person Name' ;
    rdfs:comment 'The name of the individual who physically received and inspected the goods. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Code' ;
    rdfs:comment 'The code of the manufacturing plant or facility that received the goods. Used for multi-plant inventory and cost center allocation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Flag' ;
    rdfs:comment 'Indicates whether a Return Material Authorization (RMA) has been initiated for the received goods due to quality issues, damage, or incorrect delivery. True if RMA initiated; false otherwise.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which this goods receipt was reversed. Used for audit trail and financial period reconciliation.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this goods receipt has been reversed or cancelled. True if reversed; false otherwise. Reversed GRs do not contribute to inventory or financial balances.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseInfoRecordId rdf:type rdf:Property ;
    rdfs:label 'Purchase Info Record Id' ;
    rdfs:comment 'System-generated unique identifier for the purchase info record.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Source Flag' ;
    rdfs:comment 'Indicates whether the supplier is an approved source for the material (true = approved).' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference to an outline agreement or contract that governs this price.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Fixed Source Flag' ;
    rdfs:comment 'True if procurement must always source from this supplier for the material.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Info Record Number' ;
    rdfs:comment 'Business identifier assigned to the purchase info record, used for reference in procurement processes.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infoRecordType rdf:type rdf:Property ;
    rdfs:label 'Info Record Type' ;
    rdfs:comment 'Classification of the info record indicating the sourcing strategy (e.g., standard, subcontracting, pipeline, consignment).' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPriceUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Price Update Timestamp' ;
    rdfs:comment 'Date-time when the price information was last updated in the system.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mrpRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevant Flag' ;
    rdfs:comment 'True if the info record should be considered during MRP runs.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderQuantityMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Quantity Multiple' ;
    rdfs:comment 'Quantity increment that must be respected when ordering (e.g., multiples of 10).' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeDate rdf:type rdf:Property ;
    rdfs:label 'Price Change Date' ;
    rdfs:comment 'Date on which the most recent price change became effective.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Change Indicator' ;
    rdfs:comment 'Indicates whether the price has increased, decreased, or remained unchanged since the previous version.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business justification for the latest price adjustment.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseInfoRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Purchase Info Record Status' ;
    rdfs:comment 'Current lifecycle status of the info record.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Lead Time Days' ;
    rdfs:comment 'Number of days before the planned delivery date when a reminder is generated.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceOfSupplyCategory rdf:type rdf:Property ;
    rdfs:label 'Source Of Supply Category' ;
    rdfs:comment 'Broad classification of the source (e.g., internal, external, third-party).' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePriority rdf:type rdf:Property ;
    rdfs:label 'Source Priority' ;
    rdfs:comment 'Numeric rank indicating preference order among multiple approved sources for the same material.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceLimitPercent rdf:type rdf:Property ;
    rdfs:label 'Tolerance Limit Percent' ;
    rdfs:comment 'Maximum allowed deviation (percentage) from the negotiated price before a tolerance check is triggered.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Material Number' ;
    rdfs:comment 'Supplier\'s own material identifier for the supplied item.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPriceList rdf:type rdf:Property ;
    rdfs:label 'Vendor Price List' ;
    rdfs:comment 'Reference to the supplier\'s price list or catalogue containing this price.' ;
    rdfs:domain ind:PurchaseInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRequirementId rdf:type rdf:Property ;
    rdfs:label 'Material Requirement Id' ;
    rdfs:comment 'Foreign key linking to supply.material_requirement. Business justification: Purchase orders are issued to satisfy material requirements; the link supports the \'Material Requirement Fulfilment\' KPI.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialRequirement .

ind:primaryPurchaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Employee Id' ;
    rdfs:comment 'Reference to the employee or user who created and is responsible for this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Reference to the originating purchase requisition that triggered this purchase order.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Reference to the RFQ or RFP that preceded this purchase order in the sourcing process.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'Date when the supplier acknowledged the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Status' ;
    rdfs:comment 'Status indicating whether the supplier has acknowledged receipt and acceptance of the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the purchase order was administratively closed after all goods were received and invoices processed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Status' ;
    rdfs:comment 'Status indicating the extent to which supplier invoices have been received and matched against this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPoValue rdf:type rdf:Property ;
    rdfs:label 'Net Po Value' ;
    rdfs:comment 'Net total value of the purchase order after taxes and all adjustments.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the purchase order was created and issued to the supplier. Principal business event timestamp for the transaction.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the procure-to-pay workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|acknowledged|in_progress|partially_received|fully_received|closed|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type. Standard for one-time orders, blanket for recurring orders with release schedules, framework for long-term agreements, subcontracting for external processing, consignment for supplier-owned inventory.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Total gross value of the purchase order including all line items before taxes and charges.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Primary key for purchase_requisition' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demandForecastId rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Id' ;
    rdfs:comment 'Foreign key linking to supply.demand_forecast. Business justification: Demand forecasts drive requisitions; the relationship is needed for the \'Forecast-Driven Requisition\' analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandForecast .

ind:fieldServiceOrderId rdf:type rdf:Property ;
    rdfs:label 'Field Service Order Id' ;
    rdfs:comment 'Foreign key linking to service.field_service_order. Business justification: Field Service Order Parts Requisition: each requisition references the field service order it supports.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldServiceOrder .

ind:primaryPurchaseRequestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Requestor Employee Id' ;
    rdfs:comment 'Identifier of the employee who initiated the purchase requisition. Links to the workforce or employee master data.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierContactId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Id' ;
    rdfs:comment 'Foreign key linking to supplier.supplier_contact. Business justification: Needed for Supplier Relationship Management process: requisition records the primary supplier contact for communication and escalation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContact .

ind:tertiaryPurchaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Purchase Employee Id' ;
    rdfs:comment 'User ID of the person who last modified the purchase requisition. Used for audit trail and change tracking.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Level Required' ;
    rdfs:comment 'Number of approval levels required for this requisition based on value thresholds and organizational policy. Higher values require more senior approvals.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the purchase requisition (quantity × estimated unit price). Used for budget control and approval routing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit of the requested material or service. Used for budget estimation and approval thresholds. Actual price is determined during sourcing and PO creation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:justificationNotes rdf:type rdf:Property ;
    rdfs:label 'Justification Notes' ;
    rdfs:comment 'Business justification or rationale provided by the requestor for the purchase. Required for high-value or non-standard requisitions.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'MRP controller responsible for material planning and requisition generation for production materials. Used for MRP-driven procurement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Po Created Date' ;
    rdfs:comment 'Date when the purchase order was created from this requisition. Marks the transition from requisition to order in the procure-to-pay cycle.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prDate rdf:type rdf:Property ;
    rdfs:label 'Pr Date' ;
    rdfs:comment 'Date when the purchase requisition was created or submitted. Represents the principal business event timestamp for the requisition initiation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prNumber rdf:type rdf:Property ;
    rdfs:label 'Pr Number' ;
    rdfs:comment 'Business identifier for the purchase requisition, externally visible and used in procurement workflows. Typically system-generated in SAP Ariba or SAP MM.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prStatus rdf:type rdf:Property ;
    rdfs:label 'Pr Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the procure-to-pay workflow. Tracks progression from draft through approval, sourcing, and conversion to purchase order. [ENUM-REF-CANDIDATE: draft|submitted|pending_approval|approved|rejected|sourcing_assigned|po_created|cancelled|closed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prType rdf:type rdf:Property ;
    rdfs:label 'Pr Type' ;
    rdfs:comment 'Classification of the purchase requisition based on the nature of the procurement: direct materials for production, indirect materials for operations, MRO (Maintenance, Repair, and Operations) supplies, capital equipment (CapEx), services, or subcontracting work.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'Code identifying the purchasing group or buyer responsible for sourcing this requisition. Used for workload distribution and supplier relationship management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization Code' ;
    rdfs:comment 'Code identifying the purchasing organization responsible for procurement activities. Defines the organizational unit for supplier contracts and purchase orders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Quantity of the material or service being requested. Expressed in the unit of measure specified in the UOM field.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedDate rdf:type rdf:Property ;
    rdfs:label 'Rejected Date' ;
    rdfs:comment 'Date when the purchase requisition was rejected by an approver. Null if not rejected.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestorDepartment rdf:type rdf:Property ;
    rdfs:label 'Requestor Department' ;
    rdfs:comment 'Department or organizational unit of the requestor. Used for spend analysis and budget allocation tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the employee who created the purchase requisition. Captured for audit trail and approval workflow visibility.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requested materials, supplies, or services must be delivered to meet operational or production requirements. Used for MRP (Material Requirements Planning) scheduling and supplier lead time calculation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceDeterminationIndicator rdf:type rdf:Property ;
    rdfs:label 'Source Determination Indicator' ;
    rdfs:comment 'Indicates how the supplier source should be determined: automatic sourcing via system rules, manual buyer selection, contract-based assignment, or preferred supplier list.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Buyer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: RFQ process assigns a buyer employee responsible for the event; tracking this employee is required for RFQ ownership reports and compliance.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the RFQ was awarded to one or more suppliers and purchase orders or contracts were issued. Null if not yet awarded.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidBondAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Amount' ;
    rdfs:comment 'Monetary value of the bid bond or financial guarantee required from suppliers, if applicable. Null if no bid bond is required.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidBondRequired rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Required' ;
    rdfs:comment 'Indicates whether suppliers are required to submit a bid bond or financial guarantee as part of their quotation. Common for high-value capital equipment or construction projects.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityAgreementRequired rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Required' ;
    rdfs:comment 'Indicates whether suppliers must sign a non-disclosure agreement (NDA) or confidentiality agreement before accessing RFQ details.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'International Commercial Terms (Incoterms) specifying delivery responsibilities, risk transfer, and cost allocation between buyer and supplier.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Documented criteria and weighting factors used to evaluate and score supplier responses. May include price, quality, delivery, technical capability, and sustainability factors.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitedSupplierCount rdf:type rdf:Property ;
    rdfs:label 'Invited Supplier Count' ;
    rdfs:comment 'Number of suppliers invited to participate in this RFQ. Supports competitive sourcing analysis and supplier engagement metrics.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'High-level classification of the procurement spend category. Aligns with organizational spend taxonomy and sourcing strategy.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseOpeningDate rdf:type rdf:Property ;
    rdfs:label 'Response Opening Date' ;
    rdfs:comment 'Date and time when submitted supplier responses will be opened and made available for evaluation. Used in sealed-bid scenarios.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Response Received Count' ;
    rdfs:comment 'Number of valid quotations received from suppliers by the submission deadline. Used to assess competitive response rate.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqDescription rdf:type rdf:Property ;
    rdfs:label 'Rfq Description' ;
    rdfs:comment 'Detailed description of the materials, services, or capital equipment being sourced, including specifications, scope of work, and any special requirements.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Business identifier for the RFQ document, externally visible to suppliers and internal stakeholders. Typically follows organizational numbering convention.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ. Tracks progression from creation through supplier response collection to award or cancellation. [ENUM-REF-CANDIDATE: draft|published|open|closed|awarded|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingEventType rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Type' ;
    rdfs:comment 'Classification of the sourcing mechanism used for this RFQ. Determines bidding rules, evaluation process, and supplier interaction model.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'Date and time by which suppliers must submit their quotations. No late submissions are typically accepted after this timestamp.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sustainabilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Sustainability Criteria' ;
    rdfs:comment 'Environmental, social, and governance (ESG) criteria or sustainability requirements that suppliers must address in their quotations, such as carbon footprint, ethical sourcing, or circular economy practices.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecificationRequired rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Required' ;
    rdfs:comment 'Indicates whether suppliers must provide detailed technical specifications, certifications, or compliance documentation as part of their response.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the services were formally accepted by the receiving organization.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceNotes rdf:type rdf:Property ;
    rdfs:label 'Acceptance Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the acceptor regarding the service acceptance, quality observations, or deviations.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Quantity of service units accepted and confirmed through this service entry sheet.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptorName rdf:type rdf:Property ;
    rdfs:label 'Acceptor Name' ;
    rdfs:comment 'Full name of the individual who accepted the services for business reference and audit trail.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossValue rdf:type rdf:Property ;
    rdfs:label 'Gross Value' ;
    rdfs:comment 'Total gross monetary value of the accepted services including taxes and all adjustments.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Total net monetary value of the accepted services before taxes and adjustments.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Number' ;
    rdfs:comment 'Line item number on the purchase order to which this service entry sheet applies.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Classification category of the service type for spend analysis and procurement reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed textual description of the services rendered by the supplier and accepted through this service entry sheet.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sesNumber rdf:type rdf:Property ;
    rdfs:label 'Ses Number' ;
    rdfs:comment 'Business document number assigned to the service entry sheet. Externally visible identifier used for tracking and reference in procurement workflows.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sesStatus rdf:type rdf:Property ;
    rdfs:label 'Ses Status' ;
    rdfs:comment 'Current lifecycle status of the service entry sheet indicating its approval and posting state.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sesType rdf:type rdf:Property ;
    rdfs:label 'Ses Type' ;
    rdfs:comment 'Classification of the service entry sheet based on the procurement scenario and service delivery model.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceListId rdf:type rdf:Property ;
    rdfs:label 'Source List Id' ;
    rdfs:comment 'System-generated unique identifier for the source list record.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrpSourceIndicator rdf:type rdf:Property ;
    rdfs:label 'Mrp Source Indicator' ;
    rdfs:comment 'Indicator used by MRP planning to select this source (standard, alternative, or special).' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit' ;
    rdfs:comment 'Unit price agreed with the supplier for the material.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceValidFrom rdf:type rdf:Property ;
    rdfs:label 'Price Valid From' ;
    rdfs:comment 'Date from which the quoted unit price is effective.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidTo rdf:type rdf:Property ;
    rdfs:label 'Price Valid To' ;
    rdfs:comment 'Date until which the quoted unit price remains valid.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceListDescription rdf:type rdf:Property ;
    rdfs:label 'Source List Description' ;
    rdfs:comment 'Free-form description or notes about the source list entry.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceListStatus rdf:type rdf:Property ;
    rdfs:label 'Source List Status' ;
    rdfs:comment 'Current lifecycle status of the source list record.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRating rdf:type rdf:Property ;
    rdfs:label 'Source Rating' ;
    rdfs:comment 'Rating (e.g., 0-5) reflecting supplier performance for this material.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Date from which the source list entry becomes effective.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'Date on which the source list entry expires (null if open-ended).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourcingEventId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Id' ;
    rdfs:comment 'Unique identifier for the sourcing event. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingEvent .

ind:eventOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Event Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sourcing events are owned by a specific employee; the owner ID is needed for event-ownership dashboards and audit trails.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Savings Amount' ;
    rdfs:comment 'Actual cost savings amount achieved through the sourcing event, calculated as the difference between baseline and awarded pricing.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSavingsPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Savings Percentage' ;
    rdfs:comment 'Actual cost savings percentage achieved through the sourcing event, calculated as the percentage reduction from baseline to awarded pricing.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardStrategy rdf:type rdf:Property ;
    rdfs:label 'Award Strategy' ;
    rdfs:comment 'Strategy used to determine award allocation. Lowest price awards to the supplier with the lowest bid, best value considers multiple factors beyond price, weighted score uses a scoring model with multiple criteria, multi-supplier splits award across multiple suppliers, single supplier awards entire volume to one supplier.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Spend Amount' ;
    rdfs:comment 'Total spend amount awarded to suppliers as a result of this sourcing event, representing the contracted value.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardedSupplierCount rdf:type rdf:Property ;
    rdfs:label 'Awarded Supplier Count' ;
    rdfs:comment 'Number of suppliers who received awards or contracts as a result of this sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Spend Amount' ;
    rdfs:comment 'Baseline or incumbent spend amount used as the reference point for calculating savings. Typically represents current or historical pricing.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'Commodity or category being sourced in this event, such as raw materials, components, MRO (Maintenance, Repair, and Operations) supplies, indirect materials, or capital equipment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Months' ;
    rdfs:comment 'Planned duration of the resulting contract in months.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to delivery and lead time criteria in the overall evaluation scoring model.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Spend Amount' ;
    rdfs:comment 'Total estimated spend value for the sourcing event, representing the anticipated contract value or purchase volume across all awarded suppliers.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation End Date' ;
    rdfs:comment 'Date when the evaluation of supplier bids was completed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Date' ;
    rdfs:comment 'Date when the evaluation of supplier bids commenced.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Descriptive name of the sourcing event, typically including commodity or category reference for easy identification.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiRound rdf:type rdf:Property ;
    rdfs:label 'Is Multi Round' ;
    rdfs:comment 'Indicates whether the sourcing event includes multiple rounds of bidding or negotiation. True for multi-round events, false for single-round events.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSealedBid rdf:type rdf:Property ;
    rdfs:label 'Is Sealed Bid' ;
    rdfs:comment 'Indicates whether supplier bids are sealed and confidential until the submission deadline. True for sealed bid events, false for transparent or visible bidding.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Price Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to price in the overall evaluation scoring model. Typically ranges from 0 to 100.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishDate rdf:type rdf:Property ;
    rdfs:label 'Publish Date' ;
    rdfs:comment 'Date when the sourcing event was published and made visible to invited suppliers.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to quality criteria in the overall evaluation scoring model.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:respondingSupplierCount rdf:type rdf:Property ;
    rdfs:label 'Responding Supplier Count' ;
    rdfs:comment 'Number of suppliers who submitted bids or responses to the sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundCount rdf:type rdf:Property ;
    rdfs:label 'Round Count' ;
    rdfs:comment 'Number of bidding or negotiation rounds conducted in this sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:savingsTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Savings Target Amount' ;
    rdfs:comment 'Target cost savings amount that the sourcing event aims to achieve compared to baseline or incumbent pricing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:savingsTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Savings Target Percentage' ;
    rdfs:comment 'Target cost savings percentage that the sourcing event aims to achieve compared to baseline or incumbent pricing.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Technical Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to technical capability and compliance criteria in the overall evaluation scoring model.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcingStrategyId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy Id' ;
    rdfs:comment 'System-generated unique identifier for the sourcing strategy record.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractCoverageTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Coverage Target Amount' ;
    rdfs:comment 'Monetary amount representing the desired contract coverage for the category.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractCoverageTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Contract Coverage Target Percent' ;
    rdfs:comment 'Desired percentage of spend covered by contracts under this strategy.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Expected Lead Time Days' ;
    rdfs:comment 'Anticipated lead time for sourcing items under this strategy.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isGlobalStrategy rdf:type rdf:Property ;
    rdfs:label 'Is Global Strategy' ;
    rdfs:comment 'Indicates whether the strategy applies globally across all sites.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed By' ;
    rdfs:comment 'Name of the person who performed the most recent review.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makeVsBuy rdf:type rdf:Property ;
    rdfs:label 'Make Vs Buy' ;
    rdfs:comment 'Decision whether the organization will make the item internally or buy it from external suppliers.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierIds rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Ids' ;
    rdfs:comment 'Comma-separated list of internal supplier identifiers preferred for this strategy.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Numeric score quantifying the risk level of the strategy (0-100 scale).' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskMitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Plan' ;
    rdfs:comment 'Brief description of actions to mitigate identified risks.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:savingsTargetCurrency rdf:type rdf:Property ;
    rdfs:label 'Savings Target Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the savings target amount.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingStrategyCategory rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy Category' ;
    rdfs:comment 'Spend category or commodity to which the strategy applies.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingStrategyStatus rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy Status' ;
    rdfs:comment 'Current lifecycle status of the sourcing strategy.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicOwner rdf:type rdf:Property ;
    rdfs:label 'Strategic Owner' ;
    rdfs:comment 'Internal stakeholder responsible for the strategy\'s execution.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyCode rdf:type rdf:Property ;
    rdfs:label 'Strategy Code' ;
    rdfs:comment 'External code used to reference the sourcing strategy in procurement systems.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyName rdf:type rdf:Property ;
    rdfs:label 'Strategy Name' ;
    rdfs:comment 'Descriptive name of the sourcing strategy.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyType rdf:type rdf:Property ;
    rdfs:label 'Strategy Type' ;
    rdfs:comment 'Approach used for sourcing the category (e.g., single source, dual source, multi-source, global, local).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSavingsPercent rdf:type rdf:Property ;
    rdfs:label 'Target Savings Percent' ;
    rdfs:comment 'Target savings expressed as a percentage of total spend.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSpendLastYear rdf:type rdf:Property ;
    rdfs:label 'Total Spend Last Year' ;
    rdfs:comment 'Aggregate spend for the category in the most recent fiscal year.' ;
    rdfs:domain ind:SourcingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendRecordId rdf:type rdf:Property ;
    rdfs:label 'Spend Record Id' ;
    rdfs:comment 'Unique identifier for the spend transaction record. Primary key for the spend_record data product.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySpendEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Spend Employee Id' ;
    rdfs:comment 'Identifier of the employee who initiated the purchase requisition. Used for spend accountability and approval workflow tracking.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:commodityCodeL1 rdf:type rdf:Property ;
    rdfs:label 'Commodity Code L1' ;
    rdfs:comment 'Top-level commodity classification code from the United Nations Standard Products and Services Code (UNSPSC) taxonomy. Enables high-level category spend aggregation.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCodeL2 rdf:type rdf:Property ;
    rdfs:label 'Commodity Code L2' ;
    rdfs:comment 'Second-level commodity classification code from UNSPSC taxonomy. Provides family-level categorization for spend cube analytics.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCodeL3 rdf:type rdf:Property ;
    rdfs:label 'Commodity Code L3' ;
    rdfs:comment 'Third-level commodity classification code from UNSPSC taxonomy. Provides class-level categorization for detailed spend analysis.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCodeL4 rdf:type rdf:Property ;
    rdfs:label 'Commodity Code L4' ;
    rdfs:comment 'Fourth-level commodity classification code from UNSPSC taxonomy. Provides commodity-level categorization for granular spend analysis and category management.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account code to which the spend is posted. Used for financial reporting and chart of accounts reconciliation.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maverickSpendFlag rdf:type rdf:Property ;
    rdfs:label 'Maverick Spend Flag' ;
    rdfs:comment 'Indicates whether this spend transaction was executed outside of established contracts or preferred suppliers. True indicates non-compliant spend requiring corrective action.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Item Number' ;
    rdfs:comment 'Line item number within the purchase order that corresponds to this spend transaction. Enables drill-down to specific material or service line.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementChannel rdf:type rdf:Property ;
    rdfs:label 'Procurement Channel' ;
    rdfs:comment 'Channel through which the procurement was executed. Used for maverick spend detection and procurement compliance monitoring.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:savingsAmount rdf:type rdf:Property ;
    rdfs:label 'Savings Amount' ;
    rdfs:comment 'Documented cost savings achieved on this transaction compared to baseline or previous pricing. Used for procurement performance measurement and ROI calculation.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Amount' ;
    rdfs:comment 'Total monetary value of the spend transaction in the transaction currency. Represents the actual expenditure at line-item level before currency conversion.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Spend Amount Usd' ;
    rdfs:comment 'Spend amount converted to US Dollars using the exchange rate at posting date. Enables consolidated spend reporting across global operations.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendCategory rdf:type rdf:Property ;
    rdfs:label 'Spend Category' ;
    rdfs:comment 'High-level classification of spend type: direct materials (production inputs), indirect materials (non-production goods), MRO (Maintenance, Repair, Operations supplies), or CapEx (Capital Expenditure for fixed assets).' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierSegment rdf:type rdf:Property ;
    rdfs:label 'Supplier Segment' ;
    rdfs:comment 'Strategic classification of the supplier based on spend volume, criticality, and performance. Used for supplier relationship management and sourcing strategy.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Id' ;
    rdfs:comment 'Unique identifier for the supplier invoice record. Primary key.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'The freight or shipping charges included in the invoice.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Flag indicating whether the invoice is blocked for payment.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Additional reference number or code provided by the supplier on the invoice document for their internal tracking.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'The tax jurisdiction or authority under which the invoice tax is calculated.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Tolerance Check Status' ;
    rdfs:comment 'Result of the tolerance check comparing invoice amounts against purchase order and goods receipt amounts.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Tolerance Variance Amount' ;
    rdfs:comment 'The amount by which the invoice differs from the expected amount based on the purchase order and goods receipt.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Variance Percentage' ;
    rdfs:comment 'The percentage variance between the invoice amount and the expected amount.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierQuotationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Quotation Id' ;
    rdfs:comment 'Unique identifier for the supplier quotation record. Primary key.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardFlag rdf:type rdf:Property ;
    rdfs:label 'Award Flag' ;
    rdfs:comment 'Indicates whether this quotation was selected and awarded a purchase order (True) or not (False).' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidRank rdf:type rdf:Property ;
    rdfs:label 'Bid Rank' ;
    rdfs:comment 'Numerical ranking of this quotation relative to other quotations received for the same sourcing event, based on evaluation criteria (1 = best).' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commercialComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Compliance Flag' ;
    rdfs:comment 'Indicates whether the quotation meets all commercial terms and conditions defined in the sourcing event (True) or has deviations (False).' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Commercial Compliance Notes' ;
    rdfs:comment 'Detailed notes explaining any commercial deviations, exceptions, or clarifications regarding payment terms, delivery terms, or other commercial conditions.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount offered by the supplier off the list price or baseline price.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'Weighted evaluation score assigned to the quotation based on predefined criteria (price, quality, delivery, service). Scale typically 0-100.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Shipping and freight charges quoted by the supplier for delivery to the specified location.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality certifications or standards compliance declared by the supplier (e.g., ISO 9001, AS9100, IATF 16949).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationNumber rdf:type rdf:Property ;
    rdfs:label 'Quotation Number' ;
    rdfs:comment 'Business identifier for the supplier quotation, typically assigned by the supplier or sourcing system. Externally visible reference number used in communications and documentation.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationStatus rdf:type rdf:Property ;
    rdfs:label 'Quotation Status' ;
    rdfs:comment 'Current lifecycle status of the supplier quotation in the sourcing workflow.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'Price per unit of measure quoted by the supplier for the material or service.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the supplier submitted the quotation to the sourcing event.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Reference Number' ;
    rdfs:comment 'Supplier\'s internal reference or quotation number for tracking and correspondence purposes.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Flag' ;
    rdfs:comment 'Indicates whether the quotation meets all technical specifications and requirements defined in the sourcing event (True) or has deviations (False).' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Notes' ;
    rdfs:comment 'Detailed notes explaining any technical deviations, exceptions, or clarifications regarding compliance with specifications.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCostOfOwnership rdf:type rdf:Property ;
    rdfs:label 'Total Cost Of Ownership' ;
    rdfs:comment 'Comprehensive cost evaluation including quoted price, freight, taxes, quality costs, and other factors used for supplier comparison.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuotedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Quoted Amount' ;
    rdfs:comment 'Total monetary value of the quotation, calculated as quoted unit price multiplied by requested quantity.' ;
    rdfs:domain ind:SupplierQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Duration of warranty coverage in months offered by the supplier for the quoted material or service.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costEstimateId rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Id' ;
    rdfs:comment 'Reference to the most recent cost estimate calculated for this BOM. Links to costing records that roll up material, labor, and overhead costs from BOM components.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostEstimate .

ind:primaryBomEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Bom Employee Id' ;
    rdfs:comment 'Reference to the design engineer or engineering team responsible for maintaining this BOM. Primary contact for BOM-related questions and change requests.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryBomCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Bom Created By Employee Id' ;
    rdfs:comment 'Reference to the user who created this BOM header record. Immutable audit field for accountability and traceability.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryBomLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Bom Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this BOM header record. Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The reference quantity for which the BOM is defined. All component quantities in the BOM lines are specified relative to this base quantity. Typically 1 unit of the finished product.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomUsage rdf:type rdf:Property ;
    rdfs:label 'Bom Usage' ;
    rdfs:comment 'Intended application context for this BOM. Defines whether the BOM is used for production runs, prototyping, spare parts management, rework operations, simulation, or testing purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringChangeNoticeNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Notice Number' ;
    rdfs:comment 'Reference to the ECN that communicated the engineering change. ECNs notify stakeholders of approved changes before implementation.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPhantom rdf:type rdf:Property ;
    rdfs:label 'Is Phantom' ;
    rdfs:comment 'Indicates whether this is a phantom BOM. Phantom BOMs represent transient assemblies that are not stocked but are consumed immediately in the parent assembly.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this BOM is subject to regulatory compliance requirements (CE marking, UL certification, IEC standards, etc.). Triggers additional documentation and validation workflows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Primary key for bundle' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:approvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: REQUIRED: Bundle approval tracking uses approved_by_user_employee_id to identify the employee approving the bundle.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assemblyRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assembly Required Flag' ;
    rdfs:comment 'Indicates whether the bundle requires factory assembly or integration before shipment (True) or is shipped as separate components (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Availability End Date' ;
    rdfs:comment 'Date when this bundle is no longer available for new orders. Null for ongoing offerings. Used for promotional bundles and product phase-out planning.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityStartDate rdf:type rdf:Property ;
    rdfs:label 'Availability Start Date' ;
    rdfs:comment 'Date when this bundle becomes available for sale. Used for new product introduction (NPI) and promotional campaign timing.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Externally-known unique business identifier for the bundle, used in sales orders and quotations. Typically follows company SKU (Stock Keeping Unit) pattern for composite offerings.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed commercial description of the bundle, including key features, benefits, and typical use cases. Used in catalogs, quotations, and sales documentation.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Human-readable commercial name of the bundle as presented to customers and used in sales materials (e.g., \'Automation Cell Starter Kit\', \'Smart Factory Solution Package\').' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Status' ;
    rdfs:comment 'Current lifecycle state of the bundle: draft (under development), active (available for sale), inactive (temporarily unavailable), discontinued (no longer sold but supported), obsolete (end-of-life).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the bundle structure: fixed (pre-defined components, no substitution), configurable (customer can select options), promotional (time-limited marketing offer), solution (engineered system package), service (includes maintenance/support).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Certification Requirements' ;
    rdfs:comment 'List of industry certifications or compliance standards the bundle meets (e.g., \'CE\', \'UL\', \'IEC 61508\', \'ATEX\'). Critical for regulated industries and export compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCount rdf:type rdf:Property ;
    rdfs:label 'Component Count' ;
    rdfs:comment 'Total number of distinct SKU (Stock Keeping Unit) components included in this bundle. Used for complexity assessment and inventory planning.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configurationRules rdf:type rdf:Property ;
    rdfs:label 'Configuration Rules' ;
    rdfs:comment 'Business rules governing component selection and substitution for configurable bundles. Describes constraints, dependencies, and valid option combinations.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eccnCode rdf:type rdf:Property ;
    rdfs:label 'Eccn Code' ;
    rdfs:comment 'Export Control Classification Number assigned to the bundle for U.S. export control compliance. Determines licensing requirements for international shipments.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyEfficiencyRating rdf:type rdf:Property ;
    rdfs:label 'Energy Efficiency Rating' ;
    rdfs:comment 'Energy efficiency classification or rating for the bundle if applicable (e.g., \'A+++\', \'Energy Star\', \'IE4\'). Used for sustainability reporting and customer decision-making.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCompliance rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance' ;
    rdfs:comment 'Environmental compliance certifications and declarations for the bundle (e.g., \'RoHS\', \'REACH\', \'WEEE\', \'ISO 14001\'). Critical for EU and global environmental regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'Hazardous material classification code if the bundle contains components subject to dangerous goods regulations. Used for shipping and handling compliance.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL to the primary product image or rendering of the bundle. Used in e-commerce, catalogs, and sales presentations.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Standard list price for the bundle in the base currency. Represents the published price before any customer-specific discounts or negotiations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketing Description' ;
    rdfs:comment 'Extended marketing copy and value proposition for the bundle, used in promotional materials, web catalogs, and sales presentations. Distinct from technical bundle_description.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingMethod rdf:type rdf:Property ;
    rdfs:label 'Pricing Method' ;
    rdfs:comment 'Method used to calculate bundle price: sum_of_parts (total of component prices), fixed_price (single bundle price regardless of components), discounted (percentage off sum-of-parts), tiered (volume-based pricing), custom (negotiated per deal).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementBundleCode rdf:type rdf:Property ;
    rdfs:label 'Replacement Bundle Code' ;
    rdfs:comment 'Bundle code of the successor or replacement bundle when this bundle is discontinued. Used for product transition planning and customer migration.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelCode rdf:type rdf:Property ;
    rdfs:label 'Service Level Code' ;
    rdfs:comment 'Code identifying the standard service level or SLA (Service Level Agreement) tier included with the bundle (e.g., \'BASIC\', \'PREMIUM\', \'24x7\').' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Technical Documentation Url' ;
    rdfs:comment 'URL or document reference to the technical documentation, installation guides, and specifications for the bundle. Used by sales engineering and customer support.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogEntryId rdf:type rdf:Property ;
    rdfs:label 'Catalog Entry Id' ;
    rdfs:comment 'Primary key for catalog_entry' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementCatalogCatalogEntryId rdf:type rdf:Property ;
    rdfs:label 'Replacement Catalog Catalog Entry Id' ;
    rdfs:comment 'Reference to the catalog entry that replaces this product when it is discontinued or superseded. Supports product transition management and customer migration.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogEntry .

ind:catalogDescription rdf:type rdf:Property ;
    rdfs:label 'Catalog Description' ;
    rdfs:comment 'Detailed commercial description of the product offering including key features, benefits, and applications. Used in sales literature and customer communications.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogImageUrl rdf:type rdf:Property ;
    rdfs:label 'Catalog Image Url' ;
    rdfs:comment 'URL reference to the primary product image for this catalog entry. Used in online catalogs, e-commerce platforms, and sales presentations.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogName rdf:type rdf:Property ;
    rdfs:label 'Catalog Name' ;
    rdfs:comment 'The commercial product name as it appears in sales catalogs, quotations, and customer-facing documentation. May differ from the engineering product name.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogNumber rdf:type rdf:Property ;
    rdfs:label 'Catalog Number' ;
    rdfs:comment 'The externally-facing commercial catalog identifier used in sales orders, quotations, and customer communications. This is the orderable product code visible to customers and distributors.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogStatus rdf:type rdf:Property ;
    rdfs:label 'Catalog Status' ;
    rdfs:comment 'Current lifecycle status of the catalog entry indicating whether the product is available for sale, pending launch, or being phased out.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogVersion rdf:type rdf:Property ;
    rdfs:label 'Catalog Version' ;
    rdfs:comment 'Version identifier for the product catalog publication (e.g., 2024.1, 2024.2). Supports catalog change management and historical tracking.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationMarks rdf:type rdf:Property ;
    rdfs:label 'Certification Marks' ;
    rdfs:comment 'Comma-separated list of certification marks and compliance logos applicable to this catalog entry (e.g., UL, CE, CSA, IEC). Used for regulatory compliance and customer requirements.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurableFlag rdf:type rdf:Property ;
    rdfs:label 'Configurable Flag' ;
    rdfs:comment 'Indicates whether this catalog entry supports customer-specific configuration or customization (e.g., programmable controllers, modular systems with selectable options).' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionChain rdf:type rdf:Property ;
    rdfs:label 'Distribution Chain' ;
    rdfs:comment 'The distribution chain identifier combining sales organization, distribution channel, and division. Used for SAP SD integration and order processing.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPriceUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Price Update Date' ;
    rdfs:comment 'The date when the list price for this catalog entry was last updated. Used for price change tracking and audit trails.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage in the product lifecycle from New Product Introduction (NPI) through end-of-life. Used for portfolio management and strategic planning.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oemOfferingFlag rdf:type rdf:Property ;
    rdfs:label 'Oem Offering Flag' ;
    rdfs:comment 'Indicates whether this catalog entry is an OEM product sold to other manufacturers for integration into their systems, as opposed to a standard commercial offering.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderableFlag rdf:type rdf:Property ;
    rdfs:label 'Orderable Flag' ;
    rdfs:comment 'Indicates whether this catalog entry can be directly ordered by customers. Not all SKUs are orderable; some are components or service parts only.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Price Unit Of Measure' ;
    rdfs:comment 'The unit of measure for pricing (each, piece, set, kilogram, meter, square meter, cubic meter, liter, hour). Defines the quantity basis for the list price. [ENUM-REF-CANDIDATE: EA|PC|SET|KG|M|M2|M3|L|HR — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'High-level product category classification aligning with the business strategic product portfolio segments. [ENUM-REF-CANDIDATE: automation_systems|electrification_solutions|smart_infrastructure|industrial_controls|power_distribution|building_automation|process_automation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamilyCode rdf:type rdf:Property ;
    rdfs:label 'Product Family Code' ;
    rdfs:comment 'Classification code identifying the product family or product line to which this catalog entry belongs (e.g., automation controllers, motor drives, circuit breakers).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalAvailability rdf:type rdf:Property ;
    rdfs:label 'Regional Availability' ;
    rdfs:comment 'Geographic regions or countries where this catalog entry is available for sale. Supports regional product portfolio management and compliance with local regulations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Primary sales channel through which this catalog entry is sold (direct sales force, distributor network, OEM partnerships, online store, or channel partners).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelTier rdf:type rdf:Property ;
    rdfs:label 'Service Level Tier' ;
    rdfs:comment 'The default service level tier associated with this catalog entry, determining response times and support coverage for after-sales service.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'The standard number of days from order receipt to shipment for this catalog entry under normal conditions. Used for customer delivery commitments and order promising.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalDatasheetUrl rdf:type rdf:Property ;
    rdfs:label 'Technical Datasheet Url' ;
    rdfs:comment 'URL reference to the technical datasheet or specification document for this catalog entry. Provides detailed technical information for customers and sales teams.' ;
    rdfs:domain ind:CatalogEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOrderId rdf:type rdf:Property ;
    rdfs:label 'Change Order Id' ;
    rdfs:comment 'Primary key for change_order' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productRevisionId rdf:type rdf:Property ;
    rdfs:label 'Product Revision Id' ;
    rdfs:comment 'Foreign key linking to product.product_revision. Business justification: Change orders often target a specific product revision; linking change_order to product_revision captures this ownership.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRevision .

ind:affectedBomLevel rdf:type rdf:Property ;
    rdfs:label 'Affected Bom Level' ;
    rdfs:comment 'Indicates which level(s) of the BOM hierarchy are impacted by the change: top-level finished goods, sub-assemblies, individual components, raw materials, or all levels.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalWorkflowStage rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Stage' ;
    rdfs:comment 'Current stage in the multi-level approval workflow. Indicates which functional area is currently reviewing the change order. [ENUM-REF-CANDIDATE: engineering|quality|manufacturing|procurement|finance|executive|complete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOwnerName rdf:type rdf:Property ;
    rdfs:label 'Change Owner Name' ;
    rdfs:comment 'Name of the person assigned as the change owner responsible for driving the change through approval and implementation. Accountable for successful execution.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the change is being requested, including background context, problem statement, and business justification.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Status' ;
    rdfs:comment 'Status of customer approval for the change, if customer notification is required. Tracks whether the customer has reviewed and approved the proposed modification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivitySerialNumber rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Number' ;
    rdfs:comment 'Optional serial number or production lot number at which the change becomes effective. Used for mid-production changes where effectivity is tied to specific units rather than a date.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentCost rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Cost' ;
    rdfs:comment 'Estimated financial impact of implementing the change, including tooling, material, labor, and rework costs. Used for cost-benefit analysis and approval decision-making.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactAssessmentInventory rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Inventory' ;
    rdfs:comment 'Assessment of the impact on existing inventory, including obsolete stock quantities, rework requirements, scrap decisions, and transition inventory management strategy.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Lead Time Days' ;
    rdfs:comment 'Estimated impact on product lead time resulting from the change, measured in days. Positive values indicate lead time increase; negative values indicate reduction.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactAssessmentQuality rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Quality' ;
    rdfs:comment 'Assessment of quality implications, including changes to inspection requirements, test procedures, quality control points, and expected quality improvements or risks.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completion Date' ;
    rdfs:comment 'Actual date when the change was fully implemented in production and the new specifications became active.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Implementing Plant Code' ;
    rdfs:comment 'Code identifying the manufacturing plant or facility responsible for implementing the change. May be a single plant or multiple plants for multi-site rollout.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousRevisionLevel rdf:type rdf:Property ;
    rdfs:label 'Previous Revision Level' ;
    rdfs:comment 'The product revision level that existed before this change order. Provides traceability to the prior design state.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedCapaNumber rdf:type rdf:Property ;
    rdfs:label 'Related Capa Number' ;
    rdfs:comment 'Reference to the CAPA record associated with this change order. Links the change to corrective or preventive action initiatives.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedNcrNumber rdf:type rdf:Property ;
    rdfs:label 'Related Ncr Number' ;
    rdfs:comment 'Reference to the Non-Conformance Report that triggered this change order, if applicable. Links the change to quality issues or defects that necessitated the modification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Urgency Flag' ;
    rdfs:comment 'Boolean indicator for expedited processing requirements. True indicates the change requires fast-track approval and implementation due to safety, regulatory, or critical business needs.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Validation Completion Date' ;
    rdfs:comment 'Date when validation testing was completed and results were documented. Marks the final verification of the change implementation.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationRequired rdf:type rdf:Property ;
    rdfs:label 'Validation Required' ;
    rdfs:comment 'Indicates whether post-implementation validation testing is required to verify the change achieved its intended results without introducing new issues.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:classificationId rdf:type rdf:Property ;
    rdfs:label 'Classification Id' ;
    rdfs:comment 'Primary key for classification' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationArea rdf:type rdf:Property ;
    rdfs:label 'Application Area' ;
    rdfs:comment 'The functional application area or use case for the product (e.g., Process Automation, Building Management, Motion Control, Power Distribution).' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedBy rdf:type rdf:Property ;
    rdfs:label 'Assigned By' ;
    rdfs:comment 'User ID or system identifier of the person or process that assigned this classification. Supports audit trail and data quality accountability.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'The date when this classification was originally assigned to the product. Distinct from effective start date; tracks data lineage.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoClassifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Classified Flag' ;
    rdfs:comment 'Indicates whether this classification was assigned automatically by a system or AI/ML model (true) or manually by a human user (false). Supports data quality monitoring and exception handling.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'The specific classification code or identifier within the chosen scheme. For example, UNSPSC segment-family-class-commodity code, eCl@ss class ID, or HS tariff code.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classDescription rdf:type rdf:Property ;
    rdfs:label 'Class Description' ;
    rdfs:comment 'Human-readable description of the classification class. Provides business context for the class code.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classLevel rdf:type rdf:Property ;
    rdfs:label 'Class Level' ;
    rdfs:comment 'The hierarchical level of the classification within the scheme. For example, in UNSPSC: 1=Segment, 2=Family, 3=Class, 4=Commodity. Enables drill-down and roll-up reporting.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Current lifecycle status of the classification assignment. Active classifications are used for procurement, catalog, and export documentation. Deprecated classifications are retained for historical reporting.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'A confidence score (0-100) indicating the certainty or quality of the classification assignment. Used when classifications are assigned by automated systems or AI/ML models.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityStatus rdf:type rdf:Property ;
    rdfs:label 'Data Quality Status' ;
    rdfs:comment 'The data quality status of this classification record. Indicates whether the classification has been verified, requires review, or has quality issues. Supports data stewardship workflows.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentClassCode rdf:type rdf:Property ;
    rdfs:label 'Parent Class Code' ;
    rdfs:comment 'The classification code of the parent node in the hierarchy. Enables navigation of multi-level taxonomies.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryClassificationFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Classification Flag' ;
    rdfs:comment 'Indicates whether this is the primary classification for the product. A product may have multiple classifications across different schemes, but only one primary classification per scheme.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategoryL1 rdf:type rdf:Property ;
    rdfs:label 'Product Category L1' ;
    rdfs:comment 'Top-level product category in the internal product hierarchy. Represents the broadest product grouping (e.g., Automation Systems, Electrification Solutions, Smart Infrastructure).' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryL2 rdf:type rdf:Property ;
    rdfs:label 'Product Category L2' ;
    rdfs:comment 'Second-level product category in the internal product hierarchy. Provides more granular segmentation within L1 categories.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryL3 rdf:type rdf:Property ;
    rdfs:label 'Product Category L3' ;
    rdfs:comment 'Third-level product category in the internal product hierarchy. Provides detailed product family classification.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryL4 rdf:type rdf:Property ;
    rdfs:label 'Product Category L4' ;
    rdfs:comment 'Fourth-level product category in the internal product hierarchy. Represents the most granular product classification level.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSource rdf:type rdf:Property ;
    rdfs:label 'Record Source' ;
    rdfs:comment 'The source system or data feed from which this classification record originated. Supports data lineage and integration troubleshooting.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheme rdf:type rdf:Property ;
    rdfs:label 'Scheme' ;
    rdfs:comment 'The standardized classification system or taxonomy used to categorize the product. Common schemes include UNSPSC (United Nations Standard Products and Services Code), eCl@ss (international product classification standard), ETIM (electro-technical information model), HS Code (Harmonized System for customs), and internal category hierarchies. [ENUM-REF-CANDIDATE: UNSPSC|eCl@ss|ETIM|HS_CODE|INTERNAL_CATEGORY|NAICS|SIC|GTIN — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchKeywords rdf:type rdf:Property ;
    rdfs:label 'Search Keywords' ;
    rdfs:comment 'Comma-separated list of search keywords or tags associated with this classification. Enhances product discoverability in e-commerce catalogs, procurement systems, and internal search applications.' ;
    rdfs:domain ind:Classification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationId rdf:type rdf:Property ;
    rdfs:label 'Configuration Id' ;
    rdfs:comment 'Primary key for configuration' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Configuration .

ind:optionSetId rdf:type rdf:Property ;
    rdfs:label 'Option Set Id' ;
    rdfs:comment 'Identifier for the collection of configuration options and rules that define valid combinations for this configuration.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OptionSet .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Identifier for the manufacturing routing or process plan used to produce this configuration. Defines the sequence of operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:supersededByConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Configuration Id' ;
    rdfs:comment 'Reference to the configuration that replaces this one when it becomes obsolete. Supports product migration and upgrade paths.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Configuration .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Intended application or use case for this configuration. Describes the operational context where the product will be deployed.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Starting price for the base product before configuration options are applied. Expressed in the default currency.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Unique business identifier for the configured product variant. Used in CPQ (Configure-Price-Quote) workflows and order processing systems.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationDescription rdf:type rdf:Property ;
    rdfs:label 'Configuration Description' ;
    rdfs:comment 'Detailed description of the configured product variant, including key features, options selected, and intended use case.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Human-readable name or title for the configured product variant. Describes the specific configuration in business terms.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of the product configuration. Indicates whether the configuration is available for quoting and ordering. [ENUM-REF-CANDIDATE: draft|active|inactive|obsolete|pending_approval|approved|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationType rdf:type rdf:Property ;
    rdfs:label 'Configuration Type' ;
    rdfs:comment 'Classification of the configuration approach. Standard configurations are pre-defined, custom configurations are unique to customer requirements, engineer-to-order requires design work, make-to-order uses existing designs with custom parameters, configure-to-order selects from predefined options, and assemble-to-order combines standard modules.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintRules rdf:type rdf:Property ;
    rdfs:label 'Constraint Rules' ;
    rdfs:comment 'Business rules and constraints that govern valid option combinations for this configuration. Defines incompatibilities, dependencies, and mandatory selections.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Target customer segment or industry vertical for this configuration. Examples include automotive, energy, infrastructure, building automation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionsHeightMm rdf:type rdf:Property ;
    rdfs:label 'Dimensions Height Mm' ;
    rdfs:comment 'Height dimension of the configured product in millimeters. Critical for packaging, shipping, and installation planning.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimensionsLengthMm rdf:type rdf:Property ;
    rdfs:label 'Dimensions Length Mm' ;
    rdfs:comment 'Length dimension of the configured product in millimeters. Critical for packaging, shipping, and installation planning.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimensionsWidthMm rdf:type rdf:Property ;
    rdfs:label 'Dimensions Width Mm' ;
    rdfs:comment 'Width dimension of the configured product in millimeters. Critical for packaging, shipping, and installation planning.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Flag indicating whether this configuration can currently be ordered. Used to control availability in CPQ (Configure-Price-Quote) and order management systems.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuotable rdf:type rdf:Property ;
    rdfs:label 'Is Quotable' ;
    rdfs:comment 'Flag indicating whether this configuration can be included in customer quotes. May be quotable but not yet orderable during pre-launch phases.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingComplexity rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Complexity' ;
    rdfs:comment 'Assessment of the manufacturing complexity for this configuration. Impacts production planning, resource allocation, and lead time.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustment rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment' ;
    rdfs:comment 'Total price adjustment resulting from selected configuration options. Can be positive (upcharge) or negative (discount).' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Pricing approach used for this configuration. Determines how the final price is calculated based on base product and selected options.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresEngineeringReview rdf:type rdf:Property ;
    rdfs:label 'Requires Engineering Review' ;
    rdfs:comment 'Flag indicating whether orders for this configuration require engineering review and approval before production. Common for engineer-to-order configurations.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:selectedOptions rdf:type rdf:Property ;
    rdfs:label 'Selected Options' ;
    rdfs:comment 'Comma-separated or structured list of specific option codes selected for this configuration variant. Represents the actual choices made from the available option set.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecificationDocument rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Document' ;
    rdfs:comment 'Reference to the technical specification document or datasheet that provides detailed engineering specifications for this configuration.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalConfigurationPrice rdf:type rdf:Property ;
    rdfs:label 'Total Configuration Price' ;
    rdfs:comment 'Final calculated price for the configured product variant, including base price and all option adjustments.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voltageRating rdf:type rdf:Property ;
    rdfs:label 'Voltage Rating' ;
    rdfs:comment 'Operating voltage specification for the configured product. Critical for electrical compatibility and safety compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyId rdf:type rdf:Property ;
    rdfs:label 'Family Id' ;
    rdfs:comment 'Primary key for family' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Parent Family Id' ;
    rdfs:comment 'Reference to the parent product family in the multi-level hierarchy. Enables nested family structures (e.g., Industrial Automation > Drives > Low Voltage Drives). Null for top-level families.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:competitivePositioning rdf:type rdf:Property ;
    rdfs:label 'Competitive Positioning' ;
    rdfs:comment 'Strategic positioning statement describing how this product family competes in the market (e.g., technology leader, cost leader, niche specialist). Used for marketing strategy and sales enablement.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cybersecurityClassification rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Classification' ;
    rdfs:comment 'Cybersecurity risk classification for products in this family based on connectivity, data handling, and criticality to customer operations. Drives security testing, vulnerability management, and compliance with IEC 62443 and NIST Cybersecurity Framework.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpMaterialGroup rdf:type rdf:Property ;
    rdfs:label 'Erp Material Group' ;
    rdfs:comment 'Material group code assigned in SAP S/4HANA (MATKL). Used for procurement, inventory management, and financial reporting. Links to purchasing conditions and valuation classes.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyCode rdf:type rdf:Property ;
    rdfs:label 'Family Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the product family. Used in SAP S/4HANA SD for catalog navigation and PLM (Siemens Teamcenter) for product classification. Serves as the business identifier for cross-system integration.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyDescription rdf:type rdf:Property ;
    rdfs:label 'Family Description' ;
    rdfs:comment 'Detailed business description of the product family, including its purpose, key characteristics, typical applications, and differentiating features. Used for marketing collateral, sales enablement, and product documentation.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Human-readable name of the product family (e.g., Industrial Drives, Low-Voltage Switchgear, Smart Building Controllers, Programmable Logic Controllers). Primary display label for catalog navigation and reporting.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'Classification of the product family by offering type. Distinguishes between finished goods (end products), components (parts), assemblies (sub-systems), services (maintenance/support), software (embedded/standalone), systems (integrated solutions), and spare parts. [ENUM-REF-CANDIDATE: finished_goods|components|assemblies|services|software|systems|spare_parts — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Comma-separated list of geographic regions or countries where products in this family are available for sale (e.g., EMEA, APAC, Americas, USA, DEU, CHN). Reflects regulatory approvals, distribution network, and go-to-market scope.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationPriority rdf:type rdf:Property ;
    rdfs:label 'Innovation Priority' ;
    rdfs:comment 'Priority level for innovation and new product development within this family. High priority families receive accelerated R&D investment and technology roadmap focus.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotEnabled rdf:type rdf:Property ;
    rdfs:label 'Iot Enabled' ;
    rdfs:comment 'Indicates whether products in this family have embedded IoT (Internet of Things) or IIoT (Industrial Internet of Things) connectivity for remote monitoring, predictive maintenance, or data analytics. Supports digital services and smart infrastructure offerings.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingStrategy rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Strategy' ;
    rdfs:comment 'Primary manufacturing strategy for products in this family. Make-to-stock (MTS) builds to forecast. Make-to-order (MTO) builds to customer orders. Engineer-to-order (ETO) customizes designs. Configure-to-order (CTO) assembles from standard modules. Assemble-to-order (ATO) final assembly from components.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Primary market segment or vertical industry that this product family serves. Aligns with go-to-market strategy and sales organization structure. Used for revenue reporting, market analysis, and strategic planning. [ENUM-REF-CANDIDATE: industrial_automation|building_automation|energy_management|transportation|process_industries|discrete_manufacturing|infrastructure|oem_solutions — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmCategory rdf:type rdf:Property ;
    rdfs:label 'Plm Category' ;
    rdfs:comment 'Classification code or category assigned in the PLM system (Siemens Teamcenter). Used for document management, BOM (Bill of Materials) structure, and engineering change control (ECO/ECN).' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineOwner rdf:type rdf:Property ;
    rdfs:label 'Product Line Owner' ;
    rdfs:comment 'Name or identifier of the product manager or product line owner responsible for this family. Accountable for portfolio strategy, pricing, and lifecycle management.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productPortfolioStrategy rdf:type rdf:Property ;
    rdfs:label 'Product Portfolio Strategy' ;
    rdfs:comment 'Strategic classification of the product family in the corporate portfolio. Invest families receive R&D funding and growth initiatives. Maintain families sustain current market position. Harvest families maximize cash flow with minimal investment. Divest families are candidates for discontinuation or sale.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment' ;
    rdfs:comment 'Primary customer segment or persona targeted by this product family (e.g., large industrial OEMs, mid-size system integrators, building owners, utilities). Guides marketing campaigns and sales territory planning.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Target Margin Percent' ;
    rdfs:comment 'Target gross margin percentage for products in this family, expressed as a percentage (e.g., 35.50 for 35.5%). Used for pricing strategy, product mix optimization, and profitability analysis.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifecycleStageId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage Id' ;
    rdfs:comment 'Primary key for lifecycle_stage' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleSkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Sku Master Id' ;
    rdfs:comment 'FK to product.sku_master' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:primaryLifecycleSkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Lifecycle Sku Master Id' ;
    rdfs:comment 'Reference to the product in the product master catalog. Links this lifecycle stage record to the specific manufactured product, automation system, electrification solution, or smart infrastructure component.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:actualEolDate rdf:type rdf:Property ;
    rdfs:label 'Actual Eol Date' ;
    rdfs:comment 'Actual date when the product reached end-of-life status. May differ from planned EOL date due to market conditions, inventory levels, or strategic decisions.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerCommunicationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Communication Status' ;
    rdfs:comment 'Status of customer notification and communication activities regarding the lifecycle stage change. Ensures timely and coordinated customer outreach for product discontinuations and transitions.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date when customers were officially notified of the lifecycle stage change, particularly for phase-down and end-of-life transitions. Critical for customer relationship management and contractual obligations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ecoReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Eco Reference Number' ;
    rdfs:comment 'Reference number of the Engineering Change Order that authorized or documented the lifecycle stage transition, if applicable. Links lifecycle decisions to formal engineering change management processes.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Assessment' ;
    rdfs:comment 'Summary of the financial implications of the lifecycle stage transition, including revenue impact, inventory write-offs, cost savings, and investment requirements. Business-confidential information for portfolio management.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Internal Notification Date' ;
    rdfs:comment 'Date when internal stakeholders (sales, service, manufacturing, engineering) were notified of the lifecycle stage change to align cross-functional activities.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryWindDownPlan rdf:type rdf:Property ;
    rdfs:label 'Inventory Wind Down Plan' ;
    rdfs:comment 'Summary of the inventory management strategy for phasing out the product, including target inventory levels, sell-through timelines, and disposition plans for excess stock.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTimeBuyDate rdf:type rdf:Property ;
    rdfs:label 'Last Time Buy Date' ;
    rdfs:comment 'Final date by which customers can place orders for the product before it is discontinued. Critical milestone for customer communication and order management during product phase-out.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTimeShipDate rdf:type rdf:Property ;
    rdfs:label 'Last Time Ship Date' ;
    rdfs:comment 'Final date by which the product will be shipped to customers. Represents the absolute end of product availability and delivery.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleDecisionAuthority rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Decision Authority' ;
    rdfs:comment 'Name or role of the person or committee that authorized the lifecycle stage transition. Supports governance and accountability for product portfolio decisions.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleDecisionRationale rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Decision Rationale' ;
    rdfs:comment 'Business justification and reasoning for the lifecycle stage transition. Documents strategic, market, technical, or regulatory factors driving the lifecycle decision for portfolio rationalization and governance.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleReviewDate rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Review Date' ;
    rdfs:comment 'Date of the most recent lifecycle stage review or assessment. Ensures regular evaluation of product portfolio health and lifecycle progression.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStageCode rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage Code' ;
    rdfs:comment 'Current lifecycle stage of the product. NPI = New Product Introduction (pre-production or early launch), ACTIVE = Full production and sales, MATURE = Established product with stable demand, PHASE_DOWN = Planned reduction in production, EOL = End of Life (discontinued), OBSOLETE = No longer supported or available.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStageName rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage Name' ;
    rdfs:comment 'Human-readable name of the lifecycle stage for reporting and communication purposes.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDiscontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Discontinuation Date' ;
    rdfs:comment 'Date when manufacturing and production of the product will cease. Drives supply chain wind-down, capacity reallocation, and inventory planning.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketDemandTrend rdf:type rdf:Property ;
    rdfs:label 'Market Demand Trend' ;
    rdfs:comment 'Current market demand trend for the product. GROWING = increasing sales and market share, STABLE = consistent demand, DECLINING = decreasing sales, VOLATILE = unpredictable fluctuations, UNKNOWN = insufficient data. Informs lifecycle stage decisions and portfolio strategy.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEolDate rdf:type rdf:Property ;
    rdfs:label 'Planned Eol Date' ;
    rdfs:comment 'Planned date when the product will reach end-of-life status and be discontinued from active production and sales. Critical for supply chain wind-down planning and customer communication.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousLifecycleStageCode rdf:type rdf:Property ;
    rdfs:label 'Previous Lifecycle Stage Code' ;
    rdfs:comment 'The lifecycle stage code that preceded the current stage. Enables lifecycle transition analysis and stage progression tracking.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Impact' ;
    rdfs:comment 'Description of any regulatory or compliance factors influencing the lifecycle stage decision, such as safety standards updates, environmental regulations, or certification requirements for industrial automation and electrification products.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesDiscontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Sales Discontinuation Date' ;
    rdfs:comment 'Date when active sales and marketing efforts for the product will cease. May differ from last-time-buy date to allow for inventory sell-through.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceSupportEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Support End Date' ;
    rdfs:comment 'Date when after-sales service, technical support, and spare parts availability will cease for the product. Critical for customer service planning and SLA management.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sparePartsAvailabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Availability End Date' ;
    rdfs:comment 'Date when spare parts for the product will no longer be available for purchase. Important for maintenance planning and customer communication for automation and electrification systems.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageEffectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stage Effective Timestamp' ;
    rdfs:comment 'Precise timestamp when the lifecycle stage transition became effective in the system. Supports audit trail and change tracking for lifecycle decisions.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stageEntryDate rdf:type rdf:Property ;
    rdfs:label 'Stage Entry Date' ;
    rdfs:comment 'Date when the product entered the current lifecycle stage. Used to track time-in-stage and lifecycle progression analytics.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Notification Date' ;
    rdfs:comment 'Date when suppliers and supply chain partners were notified of the lifecycle stage change to coordinate material procurement wind-down and component availability.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantySupportEndDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Support End Date' ;
    rdfs:comment 'Date when warranty coverage for newly sold units of this product will cease. Affects sales terms and customer commitments during product phase-out.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionSchedulerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Production Scheduler Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: REQUIRED: Production scheduling assigns production_scheduler_employee_id to link the scheduler employee for labor planning.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:availabilityCheckGroup rdf:type rdf:Property ;
    rdfs:label 'Availability Check Group' ;
    rdfs:comment 'Two-character key that controls which stock types are included in ATP (Available-to-Promise) checks for sales orders and production orders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether components are backflushed (automatically issued) when production order confirmations are posted. True=Backflush enabled, False=Manual goods issue required.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchManagementRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Management Required' ;
    rdfs:comment 'Indicates whether batch/lot tracking is required for this material at this plant. True=Batch management active, False=No batch tracking.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCountingIndicator rdf:type rdf:Property ;
    rdfs:label 'Cycle Counting Indicator' ;
    rdfs:comment 'Single-character code that determines the frequency of cycle counting for this material. Used to schedule physical inventory counts.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which this material will be discontinued at this plant. Used for phase-out planning and last-time-buy notifications.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveOutDate rdf:type rdf:Property ;
    rdfs:label 'Effective Out Date' ;
    rdfs:comment 'Date from which this plant data record becomes inactive. Used to manage time-dependent plant data changes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixedLotSize rdf:type rdf:Property ;
    rdfs:label 'Fixed Lot Size' ;
    rdfs:comment 'Fixed order quantity used when lot size procedure is set to fixed lot size. MRP will always propose this quantity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grProcessingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Gr Processing Time Days' ;
    rdfs:comment 'Number of days required for goods receipt processing, quality inspection, and stock placement after physical delivery.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inHouseProductionTimeDays rdf:type rdf:Property ;
    rdfs:label 'In House Production Time Days' ;
    rdfs:comment 'Number of working days required to manufacture this material from raw materials to finished goods at this plant. Used in production scheduling and MRP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionSetupRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Setup Required' ;
    rdfs:comment 'Indicates whether a quality inspection setup (inspection lot creation) is required for goods receipts of this material at this plant. True=Inspection required, False=No inspection.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Issue Storage Location' ;
    rdfs:comment 'Four-character code identifying the default storage location from which materials are issued to production orders or sales orders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeProcedure rdf:type rdf:Property ;
    rdfs:label 'Lot Size Procedure' ;
    rdfs:comment 'Lot-sizing procedure used in MRP to determine order quantities. EX=Lot-for-lot, HB=Replenish to maximum stock level, FX=Fixed lot size, WB=Weekly lot size, PK=Period lot size, LS=Lot size key.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negativeStockAllowed rdf:type rdf:Property ;
    rdfs:label 'Negative Stock Allowed' ;
    rdfs:comment 'Indicates whether negative stock balances are permitted for this material at this plant. True=Negative stock allowed, False=System blocks transactions that would create negative stock.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plantStatus rdf:type rdf:Property ;
    rdfs:label 'Plant Status' ;
    rdfs:comment 'Current lifecycle status of this material at this plant. Active=Normal production/sales, Blocked=Temporarily unavailable, Discontinued=End-of-life, Phase_out=Being phased out, New_product_introduction=NPI stage.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Production Storage Location' ;
    rdfs:comment 'Four-character code identifying the default storage location within the plant where finished goods from production are received.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionType rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Type' ;
    rdfs:comment 'QM inspection type that determines when quality inspections are triggered. 01=Goods receipt from vendor, 02=Goods receipt from production, 03=Goods issue to customer, 04=Stock transfer, 05=Physical inventory, 08=Recurring inspection, 09=Audit inspection. [ENUM-REF-CANDIDATE: 01|02|03|04|05|08|09 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingValue rdf:type rdf:Property ;
    rdfs:label 'Rounding Value' ;
    rdfs:comment 'Rounding value for lot sizes. MRP rounds proposed order quantities up to the nearest multiple of this value.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schedulingMarginKey rdf:type rdf:Property ;
    rdfs:label 'Scheduling Margin Key' ;
    rdfs:comment 'Key that defines float times (opening period, float before production, float after production) used in production scheduling to add buffer time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationLevel rdf:type rdf:Property ;
    rdfs:label 'Serialization Level' ;
    rdfs:comment 'Controls serial number management for this material at this plant. 0=No serial numbers, 1=Serial number at goods receipt, 2=Serial number at goods issue, 3=Serial number at goods receipt and issue, 4=Serial number at production.' ;
    rdfs:domain ind:PlantData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productBomLineId rdf:type rdf:Property ;
    rdfs:label 'Product Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the product_bom_line entity.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternativeItemGroup rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Group' ;
    rdfs:comment 'Identifier for a group of interchangeable components that can substitute for each other in the assembly. Used for flexible BOM structures and supply chain resilience.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeItemPriority rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Priority' ;
    rdfs:comment 'Priority ranking for this component within its alternative item group. Lower numbers indicate higher priority for material selection during MRP and production execution.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bulkMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Bulk Material Indicator' ;
    rdfs:comment 'Flag indicating whether this component is a bulk material (liquids, powders, gases) that requires special handling, storage, and measurement during production.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:componentHeightMm rdf:type rdf:Property ;
    rdfs:label 'Component Height Mm' ;
    rdfs:comment 'Height dimension of the component in millimeters. Used for variable-size materials and spatial planning in assembly.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentLengthMm rdf:type rdf:Property ;
    rdfs:label 'Component Length Mm' ;
    rdfs:comment 'Length dimension of the component in millimeters. Used for variable-size materials and spatial planning in assembly.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentOrigin rdf:type rdf:Property ;
    rdfs:label 'Component Origin' ;
    rdfs:comment 'Procurement strategy for this component: make (manufactured in-house), buy (purchased from supplier), make_or_buy (flexible sourcing), subcontract (outsourced manufacturing).' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Component Weight Kg' ;
    rdfs:comment 'Weight of the component in kilograms. Used for calculating total assembly weight, shipping weight, and material handling requirements.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentWidthMm rdf:type rdf:Property ;
    rdfs:label 'Component Width Mm' ;
    rdfs:comment 'Width dimension of the component in millimeters. Used for variable-size materials and spatial planning in assembly.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costRelevanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Relevance Indicator' ;
    rdfs:comment 'Flag indicating whether this component should be included in product costing calculations. Text items and phantom assemblies are typically not cost-relevant.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedQuantityIndicator rdf:type rdf:Property ;
    rdfs:label 'Fixed Quantity Indicator' ;
    rdfs:comment 'Indicates whether the component quantity is fixed regardless of parent assembly batch size (True) or scales proportionally with batch size (False). Used for setup materials and consumables.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationSequence rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence' ;
    rdfs:comment 'The routing operation number at which this component is consumed or installed in the manufacturing process. Links BOM to routing for integrated production planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productBomLineStatus rdf:type rdf:Property ;
    rdfs:label 'Product Bom Line Status' ;
    rdfs:comment 'Current lifecycle status of this BOM line: active (in use), inactive (temporarily disabled), pending (awaiting approval), obsolete (phased out), blocked (quality hold), released (approved for production).' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percent' ;
    rdfs:comment 'Expected scrap or waste percentage for this component during the manufacturing process. Used by MRP to calculate additional material requirements. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sparePartIndicator rdf:type rdf:Property ;
    rdfs:label 'Spare Part Indicator' ;
    rdfs:comment 'Indicates whether this component is also available as a spare part for after-sales service and maintenance. Used for service parts planning and documentation.' ;
    rdfs:domain ind:ProductBomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: REQUIRED: Certification management assigns responsible_engineer_employee_id to record accountability for each certification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Geographic markets, regions, or countries where this certification enables product sale and distribution (e.g., European Union, North America, APAC). Pipe-separated list of ISO 3166-1 alpha-3 country codes or region identifiers.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date of the most recent audit or inspection conducted by the certifying body to verify ongoing compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Classification or rating level assigned by the certification (e.g., ATEX Zone 1, IP67, Safety Integrity Level SIL 2, Performance Level PLd).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique certificate number or listing identifier issued by the certifying body (e.g., UL file number, CE declaration number, IEC certificate ID).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred to obtain and maintain this certification, including testing fees, audit fees, and certification body charges.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cybersecurityCertification rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Certification' ;
    rdfs:comment 'Cybersecurity certification or compliance level achieved by the product (e.g., IEC 62443-4-1, IEC 62443-4-2, NIST Cybersecurity Framework).' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationOfConformityNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Of Conformity Number' ;
    rdfs:comment 'Unique identifier for the manufacturer\'s Declaration of Conformity document associated with this certification, particularly for CE marking.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Environmental management or sustainability certification obtained (e.g., ISO 14001, LEED, BREEAM, Cradle to Cradle).' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalSafetyCertification rdf:type rdf:Property ;
    rdfs:label 'Functional Safety Certification' ;
    rdfs:comment 'Functional safety certification level achieved by the product (e.g., IEC 61508 SIL 2, ISO 13849 PLd, IEC 61511).' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerFacing rdf:type rdf:Property ;
    rdfs:label 'Is Customer Facing' ;
    rdfs:comment 'Indicates whether this certification is typically disclosed to customers in product documentation, datasheets, or sales materials as a market differentiator.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryForMarkets rdf:type rdf:Property ;
    rdfs:label 'Mandatory For Markets' ;
    rdfs:comment 'List of markets or regions where this certification is legally mandatory for product sale (as opposed to voluntary). Pipe-separated ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next surveillance audit or re-certification assessment by the certifying body.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Description of the product models, configurations, or variants covered under this certification. Defines the boundary of what is certified.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'Reference number of the test report or assessment documentation that supports the certification issuance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeeCompliant rdf:type rdf:Property ;
    rdfs:label 'Weee Compliant' ;
    rdfs:comment 'Indicates whether the product complies with WEEE Directive for proper disposal and recycling of electronic waste.' ;
    rdfs:domain ind:ProductCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededRevisionProductRevisionId rdf:type rdf:Property ;
    rdfs:label 'Superseded Revision Product Revision Id' ;
    rdfs:comment 'Reference to the previous product revision that this revision replaces. Maintains revision lineage and traceability.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRevision .

ind:bomAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Bom Affected Flag' ;
    rdfs:comment 'Indicates whether this revision includes changes to the product Bill of Materials structure or component list.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Indicates whether customers must be formally notified of this revision due to impact on form, fit, function, or regulatory compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drawingAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Drawing Affected Flag' ;
    rdfs:comment 'Indicates whether this revision includes changes to engineering drawings, CAD (Computer-Aided Design) models, or technical documentation.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivitySerialEnd rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial End' ;
    rdfs:comment 'Ending serial number through which this revision is effective, when effectivity is controlled by serial number range.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivitySerialStart rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Start' ;
    rdfs:comment 'Starting serial number from which this revision is effective, when effectivity is controlled by serial number.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ppap Required Flag' ;
    rdfs:comment 'Indicates whether this revision requires a new Production Part Approval Process submission to customers.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Process Affected Flag' ;
    rdfs:comment 'Indicates whether this revision requires changes to manufacturing processes, work instructions, or shop floor procedures.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required Flag' ;
    rdfs:comment 'Indicates whether this revision requires re-certification or approval from regulatory bodies (UL, CE, OSHA, EPA, etc.).' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionCode rdf:type rdf:Property ;
    rdfs:label 'Revision Code' ;
    rdfs:comment 'Engineering revision level identifier (e.g., A, B, C, 01, 02). Represents the sequential version of the product design.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDescription rdf:type rdf:Property ;
    rdfs:label 'Revision Description' ;
    rdfs:comment 'Detailed description of the changes introduced in this revision, including design modifications, material changes, or process improvements.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionStatus rdf:type rdf:Property ;
    rdfs:label 'Revision Status' ;
    rdfs:comment 'Current lifecycle status of the product revision indicating its approval and release state.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Specification Affected Flag' ;
    rdfs:comment 'Indicates whether this revision includes changes to product specifications, performance requirements, or acceptance criteria.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testingAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Testing Affected Flag' ;
    rdfs:comment 'Indicates whether this revision requires changes to quality testing procedures, inspection plans, or validation protocols.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toolingAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Tooling Affected Flag' ;
    rdfs:comment 'Indicates whether this revision requires changes to manufacturing tooling, fixtures, jigs, or molds.' ;
    rdfs:domain ind:ProductRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:altitudeRatingMeters rdf:type rdf:Property ;
    rdfs:label 'Altitude Rating Meters' ;
    rdfs:comment 'Maximum operating altitude in meters above sea level. Defines altitude limitations for product operation due to air pressure and cooling considerations.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationSuitability rdf:type rdf:Property ;
    rdfs:label 'Application Suitability' ;
    rdfs:comment 'Intended application areas and use cases. Describes the industrial applications, environments, or processes for which the product is designed and suitable.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorFinish rdf:type rdf:Property ;
    rdfs:label 'Color Finish' ;
    rdfs:comment 'Product color and surface finish. Describes the external appearance and coating (e.g., RAL 7035 light grey, powder coated, anodized aluminum).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionType rdf:type rdf:Property ;
    rdfs:label 'Connection Type' ;
    rdfs:comment 'Electrical connection or terminal type. Describes the method for connecting wires or cables to the product (e.g., screw terminals, spring clamp, plug connector).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentRatingAmperes rdf:type rdf:Property ;
    rdfs:label 'Current Rating Amperes' ;
    rdfs:comment 'Maximum continuous current rating in amperes. Defines the electrical current capacity of the product.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:datasheetReference rdf:type rdf:Property ;
    rdfs:label 'Datasheet Reference' ;
    rdfs:comment 'Reference identifier or document number for the associated product datasheet. Links to the detailed technical datasheet managed in the engineering document management system.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyRatingHz rdf:type rdf:Property ;
    rdfs:label 'Frequency Rating Hz' ;
    rdfs:comment 'Operating frequency rating in Hertz. Specifies the electrical frequency the product is designed for (e.g., 50Hz, 60Hz, 50/60Hz).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityRatingPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Rating Percent' ;
    rdfs:comment 'Relative humidity rating or range for product operation. Specifies the acceptable humidity conditions (e.g., 5-95% RH non-condensing).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationManualReference rdf:type rdf:Property ;
    rdfs:label 'Installation Manual Reference' ;
    rdfs:comment 'Reference identifier or document number for the installation manual. Links to the installation instructions managed in the engineering document management system.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipRating rdf:type rdf:Property ;
    rdfs:label 'Ip Rating' ;
    rdfs:comment 'Ingress Protection rating per IEC 60529 standard. Defines the level of protection against solid objects and liquids (e.g., IP65, IP67, IP20).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Primary materials used in product construction. Lists the key materials and their properties (e.g., stainless steel housing, polycarbonate cover, copper conductors).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mountingType rdf:type rdf:Property ;
    rdfs:label 'Mounting Type' ;
    rdfs:comment 'Physical mounting method for the product. Specifies how the product is installed (e.g., DIN rail, panel mount, wall mount).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nemaRating rdf:type rdf:Property ;
    rdfs:label 'Nema Rating' ;
    rdfs:comment 'NEMA enclosure rating for North American markets. Defines environmental protection level (e.g., NEMA1, NEMA4, NEMA4X, NEMA12).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Max C' ;
    rdfs:comment 'Maximum operating ambient temperature in degrees Celsius. Defines the upper temperature limit for safe and reliable product operation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Min C' ;
    rdfs:comment 'Minimum operating ambient temperature in degrees Celsius. Defines the lower temperature limit for safe and reliable product operation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceParameter rdf:type rdf:Property ;
    rdfs:label 'Performance Parameter' ;
    rdfs:comment 'Key performance parameters and metrics. Describes critical performance characteristics such as response time, accuracy, throughput, or efficiency ratings specific to the product type.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerRatingWatts rdf:type rdf:Property ;
    rdfs:label 'Power Rating Watts' ;
    rdfs:comment 'Electrical power rating in watts. Specifies the maximum power consumption or output capacity of the product.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyDataSheetReference rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Reference' ;
    rdfs:comment 'Reference identifier for the Safety Data Sheet. Links to the SDS document for products containing hazardous materials, managed in the engineering document management system.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shockResistance rdf:type rdf:Property ;
    rdfs:label 'Shock Resistance' ;
    rdfs:comment 'Mechanical shock resistance specification. Describes the products ability to withstand mechanical shock per applicable test standards (e.g., IEC 60068-2-27).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationDescription rdf:type rdf:Property ;
    rdfs:label 'Specification Description' ;
    rdfs:comment 'Detailed textual description of the product specification. Provides comprehensive technical and commercial details not captured in structured fields.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationName rdf:type rdf:Property ;
    rdfs:label 'Specification Name' ;
    rdfs:comment 'Human-readable name or title of the product specification. Describes the specification purpose or scope.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of the product specification. Tracks the approval and active state of the specification document.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum storage temperature in degrees Celsius. Defines the upper temperature limit for product storage when not in operation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum storage temperature in degrees Celsius. Defines the lower temperature limit for product storage when not in operation.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalDrawingReference rdf:type rdf:Property ;
    rdfs:label 'Technical Drawing Reference' ;
    rdfs:comment 'Reference identifier for associated technical drawings. Links to CAD drawings, dimensional drawings, or assembly drawings managed in the PLM system.' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vibrationResistance rdf:type rdf:Property ;
    rdfs:label 'Vibration Resistance' ;
    rdfs:comment 'Vibration resistance specification. Describes the products ability to withstand mechanical vibration per applicable test standards (e.g., IEC 60068-2-6).' ;
    rdfs:domain ind:ProductSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Financial reporting of sales per SKU needs a dedicated revenue GL account for posting invoices.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:baseUom rdf:type rdf:Property ;
    rdfs:label 'Base Uom' ;
    rdfs:comment 'The fundamental unit of measure for inventory tracking and stock keeping. All other UoM conversions are calculated relative to this base unit. [ENUM-REF-CANDIDATE: EA|PC|KG|LB|M|FT|L|GAL|M2|FT2|M3|FT3|SET|KIT — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialDescription rdf:type rdf:Property ;
    rdfs:label 'Commercial Description' ;
    rdfs:comment 'Marketing-optimized product description for sales and customer communication. Multi-language support maintained in PLM system.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the standard cost. Typically the company\'s base or functional currency for financial reporting.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionUom rdf:type rdf:Property ;
    rdfs:label 'Dimension Uom' ;
    rdfs:comment 'Unit of measure for length, width, and height dimensions. Standardized for consistent warehouse and logistics operations.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htsCode rdf:type rdf:Property ;
    rdfs:label 'Hts Code' ;
    rdfs:comment 'Harmonized Tariff Schedule classification code for customs and international trade. Used to determine import duties, tariffs, and trade statistics reporting.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makeOrBuyCode rdf:type rdf:Property ;
    rdfs:label 'Make Or Buy Code' ;
    rdfs:comment 'Procurement strategy indicator: make (manufactured in-house), buy (purchased from suppliers), or both (dual-sourced). Drives MRP planning logic and sourcing decisions.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of the SKU by manufacturing and inventory treatment. Determines BOM structure, production planning, and inventory valuation methods. [ENUM-REF-CANDIDATE: finished_good|semi_finished|raw_material|component|assembly|service_part|consumable|tool — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionToBaseConversion rdf:type rdf:Property ;
    rdfs:label 'Production To Base Conversion' ;
    rdfs:comment 'Conversion factor to translate production UoM quantities to base UoM. Used for MRP calculations and production planning.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionUom rdf:type rdf:Property ;
    rdfs:label 'Production Uom' ;
    rdfs:comment 'Unit of measure used in manufacturing execution and shop floor control. Aligns with MES work order quantities and production reporting. [ENUM-REF-CANDIDATE: EA|PC|KG|LB|M|FT|L|GAL|M2|FT2|M3|FT3|SET|KIT|BATCH|LOT — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesToBaseConversion rdf:type rdf:Property ;
    rdfs:label 'Sales To Base Conversion' ;
    rdfs:comment 'Conversion factor to translate sales UoM quantities to base UoM. Example: if sales UoM is BOX and base UoM is EA, and one box contains 12 pieces, the factor is 12.000000.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesUom rdf:type rdf:Property ;
    rdfs:label 'Sales Uom' ;
    rdfs:comment 'Unit of measure used for customer orders and sales transactions. May differ from base UoM to accommodate customer ordering preferences. [ENUM-REF-CANDIDATE: EA|PC|KG|LB|M|FT|L|GAL|M2|FT2|M3|FT3|SET|KIT|BOX|PALLET — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsReference rdf:type rdf:Property ;
    rdfs:label 'Sds Reference' ;
    rdfs:comment 'Reference identifier or document number for the Safety Data Sheet (formerly MSDS) containing detailed hazard information, handling instructions, and emergency procedures.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialControlRequired rdf:type rdf:Property ;
    rdfs:label 'Serial Control Required' ;
    rdfs:comment 'Flag indicating whether the SKU requires individual serial number tracking for warranty management, asset tracking, and field service support.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Concise product description for internal operational use, typically 40 characters or less. Used in MES shop floor displays and warehouse picking lists.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'The authoritative, externally-known unique identifier for the SKU. Used across all systems including SAP S/4HANA MM, Siemens Teamcenter PLM, and Siemens Opcenter MES. This is the business key for the product.' ;
    rdfs:domain ind:SkuMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionId rdf:type rdf:Property ;
    rdfs:label 'Substitution Id' ;
    rdfs:comment 'Primary key for substitution' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySkuMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Sku Master Id' ;
    rdfs:comment 'Foreign key linking to product.sku_master. Business justification: Link primary SKU to master record for substitution; removes free-form primary_sku column' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:applicationRestriction rdf:type rdf:Property ;
    rdfs:label 'Application Restriction' ;
    rdfs:comment 'Free-text description of any limitations or restrictions on where the substitute can be used. May reference specific customer segments, geographic regions, or application types.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automaticSubstitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Automatic Substitution Flag' ;
    rdfs:comment 'Indicates whether the substitution can be applied automatically by MRP or order management systems (true) or requires manual approval (false).' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Required Flag' ;
    rdfs:comment 'Indicates whether the substitute product requires additional compliance certifications (UL, CE, IEC) before it can be used in regulated applications.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSegmentRestriction rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Restriction' ;
    rdfs:comment 'Comma-separated list of customer segment codes where this substitution is restricted or not recommended.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formFitFunctionMatch rdf:type rdf:Property ;
    rdfs:label 'Form Fit Function Match' ;
    rdfs:comment 'Indicates the degree of form-fit-function equivalence between primary and substitute. Exact means identical in all dimensions; partial means some differences exist; none means significant differences.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this substitution is NOT permitted due to regulatory, certification, or business policy reasons.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeableFlag rdf:type rdf:Property ;
    rdfs:label 'Interchangeable Flag' ;
    rdfs:comment 'Indicates whether the substitution is bidirectional (true) or unidirectional (false). When true, both SKUs can substitute for each other.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Most recent date when this substitution was applied in a business transaction.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Variance Days' ;
    rdfs:comment 'Difference in standard lead time between substitute and primary SKU, measured in days. Positive values indicate longer lead time for substitute.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Price Variance Percent' ;
    rdfs:comment 'Percentage difference in list price between the substitute and primary SKU. Positive values indicate the substitute is more expensive; negative values indicate cost savings.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric ranking indicating preference order when multiple substitutes exist for the same primary SKU. Lower numbers indicate higher priority. Used by MRP and order management fallback logic.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityEquivalenceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Equivalence Verified Flag' ;
    rdfs:comment 'Indicates whether quality assurance has verified that the substitute meets the same quality standards as the primary SKU through testing or certification.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substituteSku rdf:type rdf:Property ;
    rdfs:label 'Substitute Sku' ;
    rdfs:comment 'The replacement or substitute SKU that can be used in place of the primary SKU.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionStatus rdf:type rdf:Property ;
    rdfs:label 'Substitution Status' ;
    rdfs:comment 'Current lifecycle status of the substitution record. Active indicates the substitution is in effect; pending approval awaits engineering or quality review; approved is authorized but not yet effective; rejected was not approved; expired is no longer valid; suspended is temporarily inactive.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionType rdf:type rdf:Property ;
    rdfs:label 'Substitution Type' ;
    rdfs:comment 'Classification of the substitution relationship. Direct replacement indicates identical form-fit-function; functional equivalent provides same capability with potential differences; upward compatible offers enhanced features; temporary substitute is short-term solution; cross-reference indicates OEM equivalence; alternate is approved alternative.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Notes' ;
    rdfs:comment 'Engineering or technical notes describing differences between primary and substitute SKUs, installation considerations, or compatibility information.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of times this substitution has been applied in order management or MRP processes. Used for analytics and substitution effectiveness tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Bom Consumption Id' ;
    rdfs:comment 'Primary key for bom_consumption' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'The actual quantity of component material issued from inventory to the work order. Represents the real consumption recorded via goods issue or backflush.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionNotes rdf:type rdf:Property ;
    rdfs:label 'Consumption Notes' ;
    rdfs:comment 'Free-text field for additional comments, observations, or special instructions related to the consumption event. Captures operator notes and exception details.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionStatus rdf:type rdf:Property ;
    rdfs:label 'Consumption Status' ;
    rdfs:comment 'Current status of the consumption record: posted (finalized in ERP), pending (awaiting confirmation), reversed (cancelled), cancelled (voided), confirmed (validated by supervisor).' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionType rdf:type rdf:Property ;
    rdfs:label 'Consumption Type' ;
    rdfs:comment 'Classification of the consumption event: planned (per BOM), unplanned (ad-hoc issue), scrap (defective material), rework (reprocessing), or sample (quality testing).' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Number' ;
    rdfs:comment 'The ERP-generated document number for the material goods issue transaction. Typically corresponds to SAP movement type 261 for production consumption.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Timestamp' ;
    rdfs:comment 'The date and time when the material goods issue transaction was posted in the ERP system. Represents the official consumption event time.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'The routing operation sequence number at which the component was consumed. Links consumption to the specific production step in the routing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalGoodsIssueNumber rdf:type rdf:Property ;
    rdfs:label 'Original Goods Issue Number' ;
    rdfs:comment 'If this is a reversal transaction, the goods issue document number of the original transaction being reversed. Enables audit trail for corrections.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The quantity of component material planned to be consumed according to the BOM specification and work order quantity. Basis for variance analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservationItemNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Item Number' ;
    rdfs:comment 'The line item number within the material reservation document. Provides granular linkage to the specific reserved component.' ;
    rdfs:domain ind:BomConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'The ERP reservation document number that allocated the material to the work order. Links consumption to the material requirements planning reservation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'The quantity of component material scrapped or wasted during production. Subset of actual quantity representing non-conforming or damaged material.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'The total cost of the consumption transaction (actual quantity multiplied by actual unit cost). Represents the financial impact of the material issue.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between actual and planned consumption quantity (actual minus planned). Positive values indicate over-consumption; negative values indicate under-consumption.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Order Confirmation Id' ;
    rdfs:comment 'Primary key for order_confirmation' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedConfirmationOrderConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Reversed Confirmation Order Confirmation Id' ;
    rdfs:comment 'Reference to the original confirmation record that this reversal confirmation is canceling. Null if this is not a reversal transaction.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderConfirmation .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The cost accounting activity type for this confirmation (e.g., machine setup, machine run, manual labor, quality inspection). Used for activity-based costing and rate calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualMachineHours rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Hours' ;
    rdfs:comment 'The total machine runtime hours consumed for this operation confirmation. Used for machine cost allocation and OEE (Overall Equipment Effectiveness) calculation.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Business identifier for the confirmation transaction. Externally visible confirmation document number generated by ERP (SAP CO11N/CO15) or MES system.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current lifecycle status of the confirmation record indicating whether it is in draft, submitted for approval, posted to inventory and cost accounting, reversed due to error, or cancelled.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'The precise date and time when the production activity was confirmed on the shop floor. Represents the actual business event time of goods receipt or operation completion.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation transaction indicating whether it represents a final completion, partial progress, automatic backflush, milestone achievement, rework activity, or scrap reporting.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Final Confirmation Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this confirmation represents the final completion of the operation. When true, the operation is closed for further confirmations and the work order may proceed to the next operation or completion.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsMovementType rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Type' ;
    rdfs:comment 'The inventory movement type code triggered by this confirmation (e.g., 101 for goods receipt, 261 for goods issue, 531 for scrap). Aligns with ERP goods movement transaction codes.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Code' ;
    rdfs:comment 'The unique transaction identifier from the source MES system (e.g., Siemens Opcenter) that originated this confirmation. Used for system integration reconciliation and traceability.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'The quantity of output that requires rework or reprocessing due to quality issues. Tracked separately from scrap to measure process capability and rework costs.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaEventReference rdf:type rdf:Property ;
    rdfs:label 'Scada Event Reference' ;
    rdfs:comment 'Reference to the SCADA system event or data collection record that triggered or validated this confirmation. Used for automated confirmation workflows and real-time monitoring integration.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumbers rdf:type rdf:Property ;
    rdfs:label 'Serial Numbers' ;
    rdfs:comment 'Comma-separated list of serial numbers for serialized output units produced in this confirmation. Used for unit-level traceability in high-value or regulated products.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeHours rdf:type rdf:Property ;
    rdfs:label 'Setup Time Hours' ;
    rdfs:comment 'The time spent on machine setup, changeover, and preparation activities before production started. Tracked separately from run time for SMED (Single-Minute Exchange of Die) analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'The standard cost amount for this confirmation based on planned quantities and standard rates. Used as the baseline for variance calculation in cost accounting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teardownTimeHours rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Hours' ;
    rdfs:comment 'The time spent on machine teardown, cleanup, and post-production activities after the operation completed. Used for total cycle time calculation.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceComments rdf:type rdf:Property ;
    rdfs:label 'Variance Comments' ;
    rdfs:comment 'Free-text comments explaining variances, quality issues, or other notable events during the operation. Provides context for exception analysis and CAPA (Corrective and Preventive Action) investigations.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:comment 'The actual quantity of good output produced and confirmed for this operation. Represents conforming units that passed quality inspection and are available for subsequent operations or finished goods inventory.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionDowntimeEventId rdf:type rdf:Property ;
    rdfs:label 'Production Downtime Event Id' ;
    rdfs:comment 'Unique identifier for the production downtime event record. Primary key.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProductionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Employee Id' ;
    rdfs:comment 'Identifier of the maintenance technician or operator assigned to resolve the downtime event. Links to employee master data.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryProductionRecordedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Production Recorded By Employee Id' ;
    rdfs:comment 'Identifier of the operator or technician who initially recorded this downtime event. Links to employee master data.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alarmCode rdf:type rdf:Property ;
    rdfs:label 'Alarm Code' ;
    rdfs:comment 'SCADA or DCS alarm code that triggered the downtime event. Used to correlate downtime with specific equipment faults.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmDescription rdf:type rdf:Property ;
    rdfs:label 'Alarm Description' ;
    rdfs:comment 'Human-readable description of the SCADA alarm that initiated the downtime event.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeEventNumber rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Number' ;
    rdfs:comment 'Business-readable unique identifier for the downtime event, typically generated by MES or SCADA system.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeReason rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason' ;
    rdfs:comment 'Operator or supervisor entered reason for the downtime event. Free-text field capturing immediate observed cause.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnOee rdf:type rdf:Property ;
    rdfs:label 'Impact On Oee' ;
    rdfs:comment 'Calculated percentage impact of this downtime event on the work center or line OEE for the shift or day. Expressed as percentage points lost.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Flag indicating whether this downtime event is part of a recurring pattern at this work center or equipment. True if similar events have occurred within the past 30 days.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mttrMinutes rdf:type rdf:Property ;
    rdfs:label 'Mttr Minutes' ;
    rdfs:comment 'Mean time to repair for this type of downtime event, calculated from historical data. Used for benchmarking and performance tracking.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Flag indicating whether automated notifications were sent to supervisors, maintenance team, or management when this downtime event occurred.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of preventive measures implemented to avoid recurrence of this type of downtime event.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLossUnits rdf:type rdf:Property ;
    rdfs:label 'Production Loss Units' ;
    rdfs:comment 'Estimated quantity of production units lost due to this downtime event. Calculated based on standard cycle time and downtime duration.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionLossValue rdf:type rdf:Property ;
    rdfs:label 'Production Loss Value' ;
    rdfs:comment 'Estimated financial value of production lost due to this downtime event. Calculated using standard cost per unit and production loss units.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recorded Timestamp' ;
    rdfs:comment 'Date and time when this downtime event record was first created in the system. Audit trail field.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recurrenceCount rdf:type rdf:Property ;
    rdfs:label 'Recurrence Count' ;
    rdfs:comment 'Number of times this type of downtime event has occurred at this work center or equipment within the past 30 days. Used for chronic loss identification.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Description of the corrective action taken to resolve the downtime event and restore production.' ;
    rdfs:domain ind:ProductionDowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'Calendar date of the shift during which the downtime occurred. Used for daily OEE reporting and trend analysis.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Production Goods Receipt Id' ;
    rdfs:comment 'Unique identifier for the production goods receipt event. Primary key for this entity.' ;
    rdfs:domain ind:ProductionGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The unique document number generated by the ERP system for this goods receipt transaction. This is the business identifier used for tracking and audit purposes.' ;
    rdfs:domain ind:ProductionGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt document. Indicates whether the receipt has been successfully posted, reversed, cancelled, or is awaiting quality inspection.' ;
    rdfs:domain ind:ProductionGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:note rdf:type rdf:Property ;
    rdfs:label 'Note' ;
    rdfs:comment 'Free-text notes or comments entered by the operator or warehouse personnel regarding the goods receipt. Captures exceptions, observations, or special handling instructions.' ;
    rdfs:domain ind:ProductionGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'The total quantity originally planned to be produced on the work order. Used to calculate yield and completion percentage.' ;
    rdfs:domain ind:ProductionGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingUser rdf:type rdf:Property ;
    rdfs:label 'Posting User' ;
    rdfs:comment 'The system user ID who posted the goods receipt transaction in the ERP system. Used for audit trail and accountability.' ;
    rdfs:domain ind:ProductionGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for reversing the goods receipt (e.g., quantity error, wrong material, quality issue). Used for root cause analysis.' ;
    rdfs:domain ind:ProductionGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that last modified this production line master record.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workCenterGroupId rdf:type rdf:Property ;
    rdfs:label 'Work Center Group Id' ;
    rdfs:comment 'Reference to the work center group that this production line belongs to for capacity planning and resource allocation.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenterGroup .

ind:actualOeePercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Oee Percentage' ;
    rdfs:comment 'Most recent calculated Overall Equipment Effectiveness percentage for this production line based on actual performance data.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation implemented on the production line, ranging from manual operations to fully automated lights-out manufacturing.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Capacity Constraint Flag' ;
    rdfs:comment 'Indicates whether this production line is identified as a bottleneck or capacity constraint in the manufacturing process requiring special attention in scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'Total time from last good piece of previous run to first good piece of new run, including setup and stabilization time.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Seconds' ;
    rdfs:comment 'Actual average time required to complete one production cycle on this line. Used to compare against takt time for performance analysis.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designThroughputRate rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Rate' ;
    rdfs:comment 'Theoretical maximum production rate of the line measured in units per hour under ideal conditions. Used for capacity planning and OEE calculations.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwhPerUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Unit' ;
    rdfs:comment 'Average energy consumption in kilowatt-hours required to produce one unit of output on this production line. Used for energy management and cost analysis.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erpWorkCenterCode rdf:type rdf:Property ;
    rdfs:label 'Erp Work Center Code' ;
    rdfs:comment 'Corresponding work center code in the ERP system for integration with production planning and costing modules.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMajorUpgradeDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Upgrade Date' ;
    rdfs:comment 'Date of the most recent major upgrade or modernization performed on the production line equipment or control systems.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:layoutDiagramUrl rdf:type rdf:Property ;
    rdfs:label 'Layout Diagram Url' ;
    rdfs:comment 'Reference URL or document path to the physical layout diagram or CAD drawing of the production line configuration.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Unique business identifier code for the production line used across MES and ERP systems. Externally-known identifier for scheduling, capacity planning, and shop floor control.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable name of the production line for identification and reporting purposes.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesLineIdentifier rdf:type rdf:Property ;
    rdfs:label 'Mes Line Identifier' ;
    rdfs:comment 'Unique identifier for this production line in the Manufacturing Execution System used for shop floor control and production tracking.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfStations rdf:type rdf:Property ;
    rdfs:label 'Number Of Stations' ;
    rdfs:comment 'Total count of work stations or process steps configured on this production line. Defines the line configuration and complexity.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedAvailabilityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Planned Availability Hours Per Day' ;
    rdfs:comment 'Total hours per day that the production line is scheduled to be available for production, excluding planned maintenance windows.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDecommissionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Decommission Date' ;
    rdfs:comment 'Planned date for decommissioning or retirement of this production line from active service.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Required' ;
    rdfs:comment 'List of safety certifications or compliance requirements applicable to this production line based on the products manufactured and jurisdictional regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaSystemTag rdf:type rdf:Property ;
    rdfs:label 'Scada System Tag' ;
    rdfs:comment 'Unique tag identifier in the SCADA system used to monitor and control this production line in real-time.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Average time required to change over the production line from one product or batch to another, including tooling changes and adjustments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Operating shift pattern configured for this production line defining daily operational hours and crew rotation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardOperatingProcedureUrl rdf:type rdf:Property ;
    rdfs:label 'Standard Operating Procedure Url' ;
    rdfs:comment 'Reference URL or document path to the standard operating procedures governing operation of this production line.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taktTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Takt Time Seconds' ;
    rdfs:comment 'Target time interval between completion of successive units, calculated as available production time divided by customer demand. Critical metric for lean manufacturing and production scheduling.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetOeePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Oee Percentage' ;
    rdfs:comment 'Target Overall Equipment Effectiveness percentage for this production line, representing the goal for availability, performance, and quality combined.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Throughput Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the throughput rate indicating how production output is quantified for this line.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionId rdf:type rdf:Property ;
    rdfs:label 'Version Id' ;
    rdfs:comment 'Unique identifier for the production version record. Primary key.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:versionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Version Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Version ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:versionProductionSchedulerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Version Production Scheduler Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Version ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bomAlternative rdf:type rdf:Property ;
    rdfs:label 'Bom Alternative' ;
    rdfs:comment 'Alternative BOM indicator when multiple BOMs exist for the same material. Allows selection of different component lists for different production scenarios.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionKey rdf:type rdf:Property ;
    rdfs:label 'Distribution Key' ;
    rdfs:comment 'Key that controls how production quantities are distributed across multiple production versions when more than one version is valid for the same material and lot size.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCostingRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Costing Relevant' ;
    rdfs:comment 'Flag indicating whether this production version is used for product costing calculations. True means this version is included in standard cost estimates.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Flag indicating whether this production version is locked and cannot be used for new production orders. True means locked, False means available for use.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMrpRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Mrp Relevant' ;
    rdfs:comment 'Flag indicating whether this production version is considered during MRP (Material Requirements Planning) runs. True means MRP will use this version for planning.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeFrom rdf:type rdf:Property ;
    rdfs:label 'Lot Size From' ;
    rdfs:comment 'Minimum production lot size (quantity) for which this production version is valid. Defines the lower bound of the lot size range.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeTo rdf:type rdf:Property ;
    rdfs:label 'Lot Size To' ;
    rdfs:comment 'Maximum production lot size (quantity) for which this production version is valid. Defines the upper bound of the lot size range. Null indicates no upper limit.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Lot Size Unit' ;
    rdfs:comment 'Unit of measure for the lot size range (e.g., \'EA\' for each, \'KG\' for kilogram, \'L\' for liter). ISO standard unit codes.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVersionCode rdf:type rdf:Property ;
    rdfs:label 'Production Version Code' ;
    rdfs:comment 'Alphanumeric code identifying the production version within the material-plant combination. Typically 1-4 characters. Business identifier for the production version.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVersionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Version Status' ;
    rdfs:comment 'Current lifecycle status of the production version indicating its operational state and usability for production planning and execution.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Receipt Storage Location' ;
    rdfs:comment 'Default storage location where finished goods are received after production completion for this production version. 4-character alphanumeric code.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskListType rdf:type rdf:Property ;
    rdfs:label 'Task List Type' ;
    rdfs:comment 'Type of task list used in this production version. N=Standard routing, R=Rate routing, Q=Inspection plan. Determines the structure of operations.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionDescription rdf:type rdf:Property ;
    rdfs:label 'Version Description' ;
    rdfs:comment 'Textual description of the production version explaining its purpose, characteristics, or usage scenario (e.g., \'Standard Production\', \'High Volume Line\', \'Alternate Routing for Capacity Constraint\').' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Work order supervision requires assigning a supervisor employee for approval and oversight, used in Work Order Approval Report.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when production execution was completed on the shop floor.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when production execution began on the shop floor.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of work order completion based on actual quantity versus planned quantity (0.00 to 100.00).' ;
    rdfs:domain ind:ProductionWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Minutes' ;
    rdfs:comment 'Actual cycle time in minutes to produce one unit, used for OEE calculation and capacity planning.' ;
    rdfs:domain ind:ProductionWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeePercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Percentage' ;
    rdfs:comment 'Calculated OEE percentage for this work order, combining availability, performance, and quality metrics (0.00 to 100.00).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionNotes rdf:type rdf:Property ;
    rdfs:label 'Production Notes' ;
    rdfs:comment 'Free-text notes capturing special instructions, issues, or observations during work order execution.' ;
    rdfs:domain ind:ProductionWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Identifier for the production routing that defines the sequence of operations for this work order.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Rate Percentage' ;
    rdfs:comment 'Percentage of material scrapped or rejected during production (0.00 to 100.00).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taktTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Takt Time Minutes' ;
    rdfs:comment 'Target takt time in minutes per unit, representing the rate at which products must be completed to meet customer demand.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipValue rdf:type rdf:Property ;
    rdfs:label 'Wip Value' ;
    rdfs:comment 'Current financial value of work in progress for this order, including material, labor, and overhead costs.' ;
    rdfs:domain ind:ProductionWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Rate Percentage' ;
    rdfs:comment 'Percentage of good units produced versus total units started, used for OEE quality calculation (0.00 to 100.00).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceToolId rdf:type rdf:Property ;
    rdfs:label 'Resource Tool Id' ;
    rdfs:comment 'Primary key for resource_tool' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Number' ;
    rdfs:comment 'Reference number of the most recent calibration certificate issued by the calibration laboratory. Used for quality audit trails and traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Required Flag' ;
    rdfs:comment 'Indicates whether this production resource tool requires periodic calibration to maintain measurement accuracy and quality compliance. True = calibration required; False = no calibration needed.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentUsageCycles rdf:type rdf:Property ;
    rdfs:label 'Current Usage Cycles' ;
    rdfs:comment 'Cumulative number of production cycles or operations this production resource tool has performed to date. Used to calculate remaining useful life and trigger replacement.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Expected Useful Life Years' ;
    rdfs:comment 'Estimated useful life of the production resource tool in years. Used for depreciation calculations and replacement planning.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date when the production resource tool was last calibrated. Used to calculate next calibration due date and track calibration history.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumUsageCycles rdf:type rdf:Property ;
    rdfs:label 'Maximum Usage Cycles' ;
    rdfs:comment 'Maximum number of production cycles or operations this production resource tool can perform before requiring replacement or refurbishment. Used for preventive maintenance planning.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Date' ;
    rdfs:comment 'Scheduled date for the next calibration event. Used for preventive maintenance planning and tool availability forecasting. Tool may be blocked from use if this date is exceeded.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prtNumber rdf:type rdf:Property ;
    rdfs:label 'Prt Number' ;
    rdfs:comment 'Externally-known unique business identifier for the production resource tool (jig, fixture, mold, die, NC program, or specialized equipment). Used for scheduling, capacity planning, and shop floor control.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prtType rdf:type rdf:Property ;
    rdfs:label 'Prt Type' ;
    rdfs:comment 'Classification of the production resource tool by functional category. Determines usage patterns, calibration requirements, and scheduling logic.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceToolDescription rdf:type rdf:Property ;
    rdfs:label 'Resource Tool Description' ;
    rdfs:comment 'Detailed business description of the production resource tool, including its purpose, specifications, and operational characteristics.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceToolStatus rdf:type rdf:Property ;
    rdfs:label 'Resource Tool Status' ;
    rdfs:comment 'Current lifecycle status of the production resource tool. Determines availability for scheduling and capacity planning. Available = ready for use; In Use = assigned to active work order; Maintenance = under repair; Calibration = undergoing calibration; Retired = no longer in service; Quarantine = blocked pending quality review.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the current safety certification. Tool may be blocked from use if this date is exceeded.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Number' ;
    rdfs:comment 'Reference number of the current safety certification or inspection certificate. Used for regulatory compliance and audit trails.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Required Flag' ;
    rdfs:comment 'Indicates whether this production resource tool requires safety certification or inspection per Occupational Safety and Health Administration (OSHA) or other regulatory requirements. True = certification required; False = no certification needed.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalSpecification rdf:type rdf:Property ;
    rdfs:label 'Technical Specification' ;
    rdfs:comment 'Detailed technical specifications of the production resource tool, including dimensions, tolerances, materials, and performance characteristics. Used for engineering and quality control.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageQuantityPerOperation rdf:type rdf:Property ;
    rdfs:label 'Usage Quantity Per Operation' ;
    rdfs:comment 'Standard quantity of this production resource tool required per routing operation. Used for tool availability checks during scheduling and capacity planning.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Usage Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the usage quantity (e.g., EA for each, SET for set, HR for hour). Aligns with ISO standard UOM codes.' ;
    rdfs:domain ind:ResourceTool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Planner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Routing planning is owned by a planner employee, needed for Routing Change Management report.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:counter rdf:type rdf:Property ;
    rdfs:label 'Counter' ;
    rdfs:comment 'Sequential counter within the routing group. Together with routing_group, forms an alternative business key.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultRouting rdf:type rdf:Property ;
    rdfs:label 'Is Default Routing' ;
    rdfs:comment 'Indicates whether this routing is the default routing for the material. True if this is the primary routing; false if it is an alternative.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantomRouting rdf:type rdf:Property ;
    rdfs:label 'Is Phantom Routing' ;
    rdfs:comment 'Indicates whether this is a phantom routing that is automatically consumed without generating a separate production order. Used for subassemblies that are immediately incorporated into parent assemblies.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingDescription rdf:type rdf:Property ;
    rdfs:label 'Routing Description' ;
    rdfs:comment 'Detailed textual description of the routing purpose, scope, and special instructions. Provides context for production planners and shop floor operators.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingGroup rdf:type rdf:Property ;
    rdfs:label 'Routing Group' ;
    rdfs:comment 'Grouping code for related routings. Used to organize routings by product family, process type, or manufacturing cell.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Draft routings are under development; released routings are approved for use; active routings are currently in production; inactive routings are temporarily suspended; obsolete routings are retired; blocked routings are prohibited from use.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingText rdf:type rdf:Property ;
    rdfs:label 'Routing Text' ;
    rdfs:comment 'Extended free-form text field for detailed routing notes, special handling instructions, safety warnings, and quality requirements.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing purpose. Production routings define standard manufacturing sequences; inspection routings define quality check sequences; rework routings define repair processes; universal routings apply across multiple materials; rate routings define continuous process flows; reference routings serve as templates.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingType rdf:type rdf:Property ;
    rdfs:label 'Scheduling Type' ;
    rdfs:comment 'Scheduling strategy for this routing. Forward scheduling starts from the earliest start date; backward scheduling works back from the required finish date; midpoint scheduling balances around a target date.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Labor Time Minutes' ;
    rdfs:comment 'Total cumulative labor time in minutes across all operations for the base quantity. Labor time may scale differently than machine time.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Lead Time Hours' ;
    rdfs:comment 'Total cumulative lead time in hours required to complete all operations in this routing for the base quantity. Includes setup, machine, labor, and queue times.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Machine Time Minutes' ;
    rdfs:comment 'Total cumulative machine processing time in minutes across all operations for the base quantity. Machine time scales with lot size.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperationCount rdf:type rdf:Property ;
    rdfs:label 'Total Operation Count' ;
    rdfs:comment 'Total number of operations (steps) defined in this routing. Derived from routing operation line items.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Setup Time Minutes' ;
    rdfs:comment 'Total cumulative setup time in minutes across all operations for the base quantity. Setup time is independent of lot size.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runId rdf:type rdf:Property ;
    rdfs:label 'Run Id' ;
    rdfs:comment 'Primary key for run' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:availabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Availability Percentage' ;
    rdfs:comment 'Equipment availability during the production run, calculated as (operating time / planned production time) * 100.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performancePercentage rdf:type rdf:Property ;
    rdfs:label 'Performance Percentage' ;
    rdfs:comment 'Equipment performance efficiency during the production run, calculated as (actual output / target output) * 100.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Timestamp' ;
    rdfs:comment 'Scheduled date and time when the production run is planned to complete execution.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled date and time when the production run is planned to begin execution.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Percentage' ;
    rdfs:comment 'Quality rate during the production run, calculated as (good units / total units produced) * 100.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business identifier for the production run campaign, externally visible and used for tracking and reporting purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the production run indicating its operational state.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the production run indicating the purpose or nature of the execution (standard production, pilot run, rework campaign, validation run, trial batch, or extended campaign).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputRate rdf:type rdf:Property ;
    rdfs:label 'Throughput Rate' ;
    rdfs:comment 'Average throughput rate achieved during the production run, measured as units produced per hour.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Cycle Time Minutes' ;
    rdfs:comment 'Total cycle time for the production run, representing the sum of all processing time across all operations, measured in minutes.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Downtime Minutes' ;
    rdfs:comment 'Total unplanned downtime during the production run, measured in minutes.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Id' ;
    rdfs:comment 'Unique identifier for the production schedule record. Primary key.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when this schedule was cancelled. Null if the schedule was not cancelled.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capacityRequirementHours rdf:type rdf:Property ;
    rdfs:label 'Capacity Requirement Hours' ;
    rdfs:comment 'Total machine or labor hours required to complete this schedule. Used for capacity planning and load leveling.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Timestamp when production for this schedule was completed. Used for schedule performance analysis and cycle time measurement.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firmedFlag rdf:type rdf:Property ;
    rdfs:label 'Firmed Flag' ;
    rdfs:comment 'Indicates whether this schedule is firmed (locked) and should not be automatically rescheduled by planning systems. True means the schedule is manually controlled; false means it can be adjusted by MRP/APS.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freezeHorizonDate rdf:type rdf:Property ;
    rdfs:label 'Freeze Horizon Date' ;
    rdfs:comment 'Date beyond which this schedule is frozen and cannot be changed without formal approval. Protects near-term execution from planning volatility.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizingRule rdf:type rdf:Property ;
    rdfs:label 'Lot Sizing Rule' ;
    rdfs:comment 'Algorithm used to determine production lot sizes. Fixed lot uses a constant quantity; lot-for-lot matches demand exactly; EOQ optimizes ordering costs; POQ aggregates demand over periods.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peggingReference rdf:type rdf:Property ;
    rdfs:label 'Pegging Reference' ;
    rdfs:comment 'Reference to the demand source (sales order, forecast, safety stock) that this schedule is pegged to. Enables traceability from supply to demand.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningBucket rdf:type rdf:Property ;
    rdfs:label 'Planning Bucket' ;
    rdfs:comment 'Time granularity of the schedule planning horizon. Daily for short-term detailed scheduling, weekly for medium-term planning, monthly for long-term capacity planning.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonWeeks rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Weeks' ;
    rdfs:comment 'Number of weeks into the future that this schedule covers. Defines the forward visibility window for production planning.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runTimeHours rdf:type rdf:Property ;
    rdfs:label 'Run Time Hours' ;
    rdfs:comment 'Estimated time required to produce the planned quantity, excluding setup and teardown. Used for cycle time analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleSource rdf:type rdf:Property ;
    rdfs:label 'Schedule Source' ;
    rdfs:comment 'System or process that generated this schedule. MRP run for material requirements planning; APS optimization for advanced planning and scheduling; manual planning for planner-created schedules; demand forecast for forecast-driven schedules; customer order for order-driven schedules.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the schedule by planning level. MPS for top-level finished goods; FAS for final assembly operations; RCCP for high-level capacity validation; MRP for detailed component planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date when production for this schedule is expected to be completed. Used for order promising and delivery planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledFinishTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Time' ;
    rdfs:comment 'Precise timestamp when production execution is scheduled to finish, used for detailed capacity loading and sequencing.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftAssignment rdf:type rdf:Property ;
    rdfs:label 'Shift Assignment' ;
    rdfs:comment 'Shift during which this production schedule is assigned to run. Used for labor planning and shift-level capacity allocation.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarId rdf:type rdf:Property ;
    rdfs:label 'Calendar Id' ;
    rdfs:comment 'Reference to the factory calendar that defines working days, holidays, and plant shutdowns for this shift. Used to exclude non-working days from capacity calculations.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Calendar .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Sum of all scheduled break periods (lunch, rest breaks) within the shift, in minutes. Subtracted from gross duration to calculate net available time for production.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakSchedule rdf:type rdf:Property ;
    rdfs:label 'Break Schedule' ;
    rdfs:comment 'Textual description of the break structure, including start times and durations (e.g., \'10:00-10:15 (15 min), 12:00-12:30 (30 min)\'). Used for communication to shop floor personnel and HMI display.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverAllowanceMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Allowance Minutes' ;
    rdfs:comment 'Standard time reserved within the shift for product changeovers, tool changes, or setup activities. Used to adjust net available time for multi-product shifts and to calculate planned downtime for OEE.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Days Of Week' ;
    rdfs:comment 'Comma-separated list of weekday codes (MON, TUE, WED, THU, FRI, SAT, SUN) indicating which days this shift pattern applies to. Used for weekly capacity planning and workforce rostering.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Time of day when the shift ends, in HH:mm:ss format (24-hour clock). May be less than start_time for shifts that cross midnight. Used to calculate gross shift duration.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Gross Duration Minutes' ;
    rdfs:comment 'Total elapsed time of the shift from start to end, in minutes, including all breaks and non-productive time. Used as the denominator for availability calculations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handoverDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Handover Duration Minutes' ;
    rdfs:comment 'Planned overlap time between consecutive shifts for handover communication, equipment status review, and safety briefing. Subtracted from net available time if included in shift boundaries. Nullable for non-continuous operations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isContinuousOperation rdf:type rdf:Property ;
    rdfs:label 'Is Continuous Operation' ;
    rdfs:comment 'Indicates whether this shift is part of a 24/7 continuous manufacturing operation (True) or a discrete batch operation (False). Used to determine handover requirements and WIP tracking rules.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to base labor rates for this shift type (e.g., 1.0 for regular, 1.5 for overtime, 2.0 for holiday). Used for labor cost calculation and variance analysis.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAvailableMinutes rdf:type rdf:Property ;
    rdfs:label 'Net Available Minutes' ;
    rdfs:comment 'Net productive time available for manufacturing execution, calculated as gross_duration_minutes minus break_duration_minutes. Used as the planned production time for OEE availability calculation and takt time planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfBreaks rdf:type rdf:Property ;
    rdfs:label 'Number Of Breaks' ;
    rdfs:comment 'Count of distinct break periods scheduled within the shift (e.g., 2 for a shift with one lunch break and one rest break). Used for workforce scheduling and labor compliance reporting.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOutputQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Output Quantity' ;
    rdfs:comment 'Target production volume for this shift, in base unit of measure. Used as the denominator for performance OEE calculation and as input to takt time calculation. Nullable for non-production shifts.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationPattern rdf:type rdf:Property ;
    rdfs:label 'Rotation Pattern' ;
    rdfs:comment 'Description of the multi-day or multi-week rotation cycle this shift belongs to (e.g., \'2-2-3 Continental\', \'4-on-4-off\', \'DuPont 12-hour\'). Used for long-term workforce scheduling and fatigue management.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCategory rdf:type rdf:Property ;
    rdfs:label 'Shift Category' ;
    rdfs:comment 'Broad categorization of shift purpose. Production shifts are used for manufacturing execution and OEE calculation; non-production shifts (e.g., maintenance, training) are excluded from throughput metrics; mixed shifts include both activities.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Human-readable name of the shift (e.g., Day Shift, Night Shift, Morning Shift). Used for display in reports and HMI screens.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle state of the shift definition. Active shifts are available for scheduling; inactive shifts are temporarily disabled; draft shifts are under review; archived shifts are retained for historical reference only.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift pattern indicating the nature of the working period. Regular shifts are standard production periods; overtime, weekend, and holiday shifts may carry premium labor rates; maintenance and emergency shifts are non-production periods.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Time of day when the shift begins, in HH:mm:ss format (24-hour clock). Used to calculate shift boundaries for production tracking and OEE reporting.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftReportId rdf:type rdf:Property ;
    rdfs:label 'Shift Report Id' ;
    rdfs:comment 'Unique identifier for the shift report record. Primary key.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualGoodQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Good Quantity' ;
    rdfs:comment 'Actual quantity of conforming units produced during the shift that passed quality inspection.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualProductionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Production Time Minutes' ;
    rdfs:comment 'Actual time the work center was actively producing during the shift, excluding downtime.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverCount rdf:type rdf:Property ;
    rdfs:label 'Changeover Count' ;
    rdfs:comment 'Number of production changeovers or setups performed during the shift.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialConsumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Material Consumed Quantity' ;
    rdfs:comment 'Total quantity of raw materials or components consumed during the shift.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialWasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Material Waste Quantity' ;
    rdfs:comment 'Quantity of material wasted or lost during production beyond normal scrap allowances.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorCount rdf:type rdf:Property ;
    rdfs:label 'Operator Count' ;
    rdfs:comment 'Number of operators assigned to the work center during this shift.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedProductionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Production Time Minutes' ;
    rdfs:comment 'Total planned available production time for the shift, excluding scheduled breaks and maintenance windows.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether production output from this shift is on quality hold pending inspection or investigation.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Closed Timestamp' ;
    rdfs:comment 'Timestamp when the shift report was officially closed and finalized in the MES system.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Created Timestamp' ;
    rdfs:comment 'Timestamp when the shift report record was first created in the system.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Business identifier for the shift report, typically formatted as YYYYMMDD-SHIFT-WORKCENTER.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Shift Duration Minutes' ;
    rdfs:comment 'Total duration of the shift in minutes, calculated from start to end timestamp.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift End Timestamp' ;
    rdfs:comment 'Actual timestamp when the shift ended production activities.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the shift started production activities.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:throughputRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Throughput Rate Per Hour' ;
    rdfs:comment 'Average number of units produced per hour during the shift.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProducedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Produced Quantity' ;
    rdfs:comment 'Total quantity produced during the shift, including good, scrap, and rework units.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipLotId rdf:type rdf:Property ;
    rdfs:label 'Wip Lot Id' ;
    rdfs:comment 'Unique identifier for the work-in-progress lot or batch. Primary key for the WIP lot tracking entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WipLot .

ind:currentWorkCenterId rdf:type rdf:Property ;
    rdfs:label 'Current Work Center Id' ;
    rdfs:comment 'Reference to the work center or production resource where this lot is currently located and being processed.' ;
    rdfs:domain ind:WipLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:parentLotWipLotId rdf:type rdf:Property ;
    rdfs:label 'Parent Lot Wip Lot Id' ;
    rdfs:comment 'Reference to the parent WIP lot if this lot was split or derived from another lot. Enables genealogy and traceability tracking.' ;
    rdfs:domain ind:WipLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WipLot .

ind:currentOperationSequence rdf:type rdf:Property ;
    rdfs:label 'Current Operation Sequence' ;
    rdfs:comment 'Sequence number of the operation currently being performed on this lot within the routing. Used to track progress through the production process.' ;
    rdfs:domain ind:WipLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentOperationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Current Operation Start Timestamp' ;
    rdfs:comment 'Date and time when the lot arrived at and began processing at the current operation. Used for operation cycle time tracking.' ;
    rdfs:domain ind:WipLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Creation Timestamp' ;
    rdfs:comment 'Date and time when this WIP lot record was created in the MES system, marking the start of lot tracking.' ;
    rdfs:domain ind:WipLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the WIP lot. Indicates whether the lot is released for production, actively in process, on hold, completed, scrapped, or cancelled.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalLotNumber rdf:type rdf:Property ;
    rdfs:label 'Original Lot Number' ;
    rdfs:comment 'Lot number of the original lot if this is a rework or split lot. Maintains traceability to the source lot for genealogy purposes.' ;
    rdfs:domain ind:WipLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production Start Timestamp' ;
    rdfs:comment 'Date and time when physical production of this lot began at the first operation. Used for lead time and cycle time calculation.' ;
    rdfs:domain ind:WipLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:projectNumber rdf:type rdf:Property ;
    rdfs:label 'Project Number' ;
    rdfs:comment 'Project identifier if this lot is being produced for a specific engineering or customer project. Used for project-based manufacturing tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnHold rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hold' ;
    rdfs:comment 'Quantity of material in this lot that is currently on hold pending quality inspection, engineering review, or other disposition decision.' ;
    rdfs:domain ind:WipLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Date' ;
    rdfs:comment 'Planned date by which this lot is scheduled to complete all operations and be available for goods receipt. Used for capacity planning and delivery commitment.' ;
    rdfs:domain ind:WipLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scrapReasonCode rdf:type rdf:Property ;
    rdfs:label 'Scrap Reason Code' ;
    rdfs:comment 'Code indicating the primary reason for any scrapped quantity in this lot. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:WipLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityPerShift rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Per Shift' ;
    rdfs:comment 'Standard available capacity of the work center per shift, measured in the capacity category unit.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'Unit of measure for capacity planning (e.g., machine hours, labor hours, throughput units).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPlanningGroup rdf:type rdf:Property ;
    rdfs:label 'Capacity Planning Group' ;
    rdfs:comment 'Grouping code for aggregating work centers in capacity planning and leveling activities.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlKey rdf:type rdf:Property ;
    rdfs:label 'Control Key' ;
    rdfs:comment 'Control key defining how operations are processed at this work center (e.g., internal processing, external processing, inspection).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Efficiency Rate Percent' ;
    rdfs:comment 'Standard efficiency rate of the work center expressed as a percentage, representing the ratio of actual output to theoretical maximum output.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulaKey rdf:type rdf:Property ;
    rdfs:label 'Formula Key' ;
    rdfs:comment 'Formula key used for calculating operation times and capacity requirements at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Mes Integration Enabled' ;
    rdfs:comment 'Indicates whether this work center is integrated with the MES for real-time shop floor control and data collection.' ;
