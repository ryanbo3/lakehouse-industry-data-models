    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'Accounting period identifier (e.g., 2024M03) for the posting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External document number (e.g., invoice, purchase order) linked to the transaction.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'Code of the legal entity sending the intercompany amount.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'External business identifier assigned to the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSubtype rdf:type rdf:Property ;
    rdfs:label 'Transaction Subtype' ;
    rdfs:comment 'Additional categorisation of the transaction type when needed.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the intercompany transaction occurred in the business process.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferPrice rdf:type rdf:Property ;
    rdfs:label 'Transfer Price' ;
    rdfs:comment 'Unit price applied for the intercompany transfer.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'Method used to determine the intercompany price.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexFlag rdf:type rdf:Property ;
    rdfs:label 'Capex Flag' ;
    rdfs:comment 'True if the internal order is classified as capital expenditure.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Costs that have been committed (e.g., purchase orders) but not yet posted.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalClosureDate rdf:type rdf:Property ;
    rdfs:label 'Final Closure Date' ;
    rdfs:comment 'Date when the internal order was finally closed and settled.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Internal Order Description' ;
    rdfs:comment 'Free-text description of the purpose, scope, or details of the internal order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Internal Order Status' ;
    rdfs:comment 'Current lifecycle status of the internal order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opexFlag rdf:type rdf:Property ;
    rdfs:label 'Opex Flag' ;
    rdfs:comment 'True if the internal order is classified as operating expenditure.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Timestamp when the internal order was initially created in the business process.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'External business identifier assigned to the internal order, used in finance and controlling processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the internal order indicating its purpose such as maintenance, capital project, research, or service.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'Forecasted costs for the internal order based on planning.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Identifier of the profit center to which the internal order\'s results are allocated.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCostCenter rdf:type rdf:Property ;
    rdfs:label 'Responsible Cost Center' ;
    rdfs:comment 'Cost center assigned as the primary owner for budgeting and settlement of the internal order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'Rule that defines how costs of the internal order are settled to receivers (e.g., cost centers, projects).' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Technical Completion Date' ;
    rdfs:comment 'Date when technical completion of the order was confirmed.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:variancePercent rdf:type rdf:Property ;
    rdfs:label 'Variance Percent' ;
    rdfs:comment 'Percentage variance between budgeted and actual costs.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'System-generated unique identifier for the journal entry record.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Identifier of the ledger (e.g., primary, secondary) where the entry is posted.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:postedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Posted By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Audit requirement to trace each journal entry to the employee who posted it.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:batchReference rdf:type rdf:Property ;
    rdfs:label 'Batch Reference' ;
    rdfs:comment 'Identifier of the processing batch for mass postings.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'Date on the original source document (e.g., invoice date).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Header description of the journal document.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'Date when the journal entry was entered into the system.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Indicator of the exchange rate calculation method (e.g., average, spot).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gaap Compliance Flag' ;
    rdfs:comment 'True if the posting complies with local GAAP reporting standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs Compliance Flag' ;
    rdfs:comment 'True if the posting complies with IFRS reporting standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'SAP posting key indicating debit or credit nature of the line.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingText rdf:type rdf:Property ;
    rdfs:label 'Posting Text' ;
    rdfs:comment 'Free-form text entered by the user describing the posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTime rdf:type rdf:Property ;
    rdfs:label 'Posting Time' ;
    rdfs:comment 'Exact timestamp when the entry was posted to the ledger.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'External document number referenced by this journal entry (e.g., purchase order).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Document number of the original entry that this entry reverses.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmountTotal rdf:type rdf:Property ;
    rdfs:label 'Tax Amount Total' ;
    rdfs:comment 'Aggregate tax amount calculated for the posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'Sum of credit line amounts for the journal entry in local currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'Sum of debit line amounts for the journal entry in local currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Amount' ;
    rdfs:comment 'Total amount of the posting in the transaction currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Identifier of the immediate parent profit center in the hierarchy, if any.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:actualProfit rdf:type rdf:Property ;
    rdfs:label 'Actual Profit' ;
    rdfs:comment 'Realized profit for the profit center in the reporting period.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialReportingLine rdf:type rdf:Property ;
    rdfs:label 'Financial Reporting Line' ;
    rdfs:comment 'Line of financial reporting hierarchy (e.g., segment, division, business unit) used for IFRS segment reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Code of the legal entity that owns the profit center, aligning with statutory reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percent' ;
    rdfs:comment 'Target Overall Equipment Effectiveness percentage assigned to the profit center for performance benchmarking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProfit rdf:type rdf:Property ;
    rdfs:label 'Planned Profit' ;
    rdfs:comment 'Profit amount planned for the profit center at the start of the reporting period.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Free-text description providing context about the profit center\'s purpose and scope.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Profit Center Group' ;
    rdfs:comment 'Logical grouping name used for consolidated reporting across multiple profit centers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Human-readable name of the profit center used in reports and dashboards.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region where the profit center primarily operates.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Currency code used for external financial reporting of the profit center.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the cycle count event. Primary key for the cycle count record.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:primaryCycleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cycle Employee Id' ;
    rdfs:comment 'Employee or user identifier of the person who performed the physical count. Used for accountability and quality tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryCycleCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Cycle Created By User Employee Id' ;
    rdfs:comment 'System user identifier who created the cycle count record. Used for audit trail and data governance.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryCycleLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Cycle Last Modified By User Employee Id' ;
    rdfs:comment 'System user identifier who last updated the cycle count record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCycleApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Cycle Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the supervisor or manager who approved the count results. Required for audit trail and segregation of duties.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'ABC classification of materials included in this count. A=high-value/high-frequency, B=medium, C=low-value/low-frequency, X=unclassified. Drives cycle count frequency per ABC methodology.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percentage' ;
    rdfs:comment 'Inventory accuracy rate for this count, calculated as (items with zero variance / total items counted) × 100. Key Performance Indicator (KPI) for inventory management.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The actual date when the physical count was performed. Principal business event timestamp for the cycle count activity.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Count Document Number' ;
    rdfs:comment 'Business identifier for the cycle count document. Externally-known unique reference number used in SAP WM and warehouse operations.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'Precise timestamp when the physical counting activity was completed. Used to calculate count duration and resource utilization.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Technology or method used to perform the physical count. Impacts count accuracy and efficiency metrics.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countScope rdf:type rdf:Property ;
    rdfs:label 'Count Scope' ;
    rdfs:comment 'Defines the breadth of the counting activity. Indicates whether count covers entire warehouse, specific zones, material categories, or individual items.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the physical counting activity began. Used for labor tracking and cycle time analysis.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count event. Tracks progression from planning through execution, approval, and posting to inventory ledger. [ENUM-REF-CANDIDATE: Planned|In Progress|Completed|Approved|Posted|Cancelled|On Hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count event. Defines the counting methodology and business purpose (ABC-based frequency, annual compliance, variance investigation, or continuous counting program).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countZone rdf:type rdf:Property ;
    rdfs:label 'Count Zone' ;
    rdfs:comment 'Physical zone or area within the warehouse designated for this count. Used to organize counting activities by geographic sections or material groupings.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterName rdf:type rdf:Property ;
    rdfs:label 'Counter Name' ;
    rdfs:comment 'Full name of the employee who performed the physical count. Used for operational visibility and audit trail.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeBookInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Freeze Book Inventory Flag' ;
    rdfs:comment 'Indicates whether book inventory was frozen (locked from transactions) during the count to ensure data integrity. True=frozen, False=not frozen.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'SAP Material Management (MM) document number generated when inventory adjustments are posted. Links cycle count to inventory movement transactions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCountDate rdf:type rdf:Property ;
    rdfs:label 'Planned Count Date' ;
    rdfs:comment 'The originally scheduled date for the cycle count. Used to track adherence to ABC cycle count schedules and annual physical inventory calendars.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recountReason rdf:type rdf:Property ;
    rdfs:label 'Recount Reason' ;
    rdfs:comment 'Business reason or justification for requiring a recount. Populated when recount_required_flag is True.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether a recount is required due to significant variances exceeding tolerance thresholds. True=recount needed, False=count accepted.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage' ;
    rdfs:comment 'Acceptable variance threshold as a percentage of book quantity. Variances within tolerance may auto-approve; exceeding tolerance triggers recount or management review.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalItemsCounted rdf:type rdf:Property ;
    rdfs:label 'Total Items Counted' ;
    rdfs:comment 'Total number of distinct Stock Keeping Units (SKUs) or material numbers included in this cycle count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Variance Quantity' ;
    rdfs:comment 'Aggregate quantity variance across all materials in this count (sum of absolute differences between book and physical quantities). Measured in base unit of measure.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVarianceValue rdf:type rdf:Property ;
    rdfs:label 'Total Variance Value' ;
    rdfs:comment 'Aggregate financial value of inventory variances in this count. Calculated as sum of (variance quantity × standard cost) across all materials. Used for materiality assessment and financial impact analysis.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Variance Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total variance value. Typically plant or company code default currency.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseNumber rdf:type rdf:Property ;
    rdfs:label 'Warehouse Number' ;
    rdfs:comment 'Warehouse Management (WM) number for complex warehouse structures. Used when storage location has multiple warehouse subdivisions.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountLineId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Line Id' ;
    rdfs:comment 'Unique identifier for the cycle count line item. Primary key for the cycle count line entity.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plantDataId rdf:type rdf:Property ;
    rdfs:label 'Plant Data Id' ;
    rdfs:comment 'Foreign key reference to the manufacturing plant or facility where the cycle count is being performed. Supports multi-site inventory management and consolidation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlantData .

ind:accountingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Number' ;
    rdfs:comment 'Reference number of the financial accounting document generated when the variance was posted. Links the physical inventory adjustment to General Ledger (GL) entries in SAP Financial Accounting (FI).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookQuantity rdf:type rdf:Property ;
    rdfs:label 'Book Quantity' ;
    rdfs:comment 'System-recorded quantity of material in the storage bin at the time of cycle count initiation. Represents the expected quantity per Enterprise Resource Planning (ERP) records before physical verification.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Actual physical quantity counted by warehouse personnel during the cycle count execution. This is the verified on-hand quantity observed in the storage bin.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Counted Timestamp' ;
    rdfs:comment 'Date and time when the physical count was completed by warehouse personnel. Represents the actual business event time of inventory verification.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:differenceQuantity rdf:type rdf:Property ;
    rdfs:label 'Difference Quantity' ;
    rdfs:comment 'Variance between book quantity and counted quantity. Calculated as counted_quantity minus book_quantity. Positive values indicate surplus, negative values indicate shortage. Critical for inventory accuracy Key Performance Indicator (KPI) measurement.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freezeBookInventoryIndicator rdf:type rdf:Property ;
    rdfs:label 'Freeze Book Inventory Indicator' ;
    rdfs:comment 'Flag indicating whether the book inventory quantity was frozen at the time of count initiation to prevent changes during the count period. True if frozen, false if dynamic.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingIndicator rdf:type rdf:Property ;
    rdfs:label 'Posting Indicator' ;
    rdfs:comment 'Flag indicating whether the variance on this line has been posted to inventory and financial ledgers. True if posted, false if pending approval or recount.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountIndicator rdf:type rdf:Property ;
    rdfs:label 'Recount Indicator' ;
    rdfs:comment 'Flag indicating whether this line item requires or has undergone a recount due to variance exceeding tolerance thresholds. True if recount is required or completed, false otherwise.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountReasonCode rdf:type rdf:Property ;
    rdfs:label 'Recount Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason a recount was triggered. Used for root cause analysis and Corrective and Preventive Action (CAPA) processes per ISO 9001.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Indicator for special stock categories that require separate tracking. Consignment stock is vendor-owned, project stock is allocated to specific projects, sales order stock is reserved for customer orders.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of inventory stock status at the time of count. Unrestricted stock is available for use, quality inspection stock is pending Quality Management (QM) approval, blocked stock is unavailable due to quality or legal holds.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBin rdf:type rdf:Property ;
    rdfs:label 'Storage Bin' ;
    rdfs:comment 'Specific bin, shelf, or rack location within the storage location where the material is stored. Enables precise physical location tracking for Warehouse Management System (WMS) operations.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Split valuation indicator for materials managed with multiple valuation types. Examples include origin-based valuation, quality-based valuation. Null for materials without split valuation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Root cause classification for inventory variance identified during cycle count. Enables variance analysis and process improvement initiatives. Required when difference_quantity is non-zero and exceeds tolerance. [ENUM-REF-CANDIDATE: counting_error|theft|damage|obsolescence|system_error|goods_receipt_not_posted|goods_issue_not_posted|transfer_not_posted|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Date and time when the count result was verified by a supervisor or second counter. Null if verification is not required or not yet completed.' ;
    rdfs:domain ind:CycleCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:kanbanCardId rdf:type rdf:Property ;
    rdfs:label 'Kanban Card Id' ;
    rdfs:comment 'Unique identifier for the kanban card record. Primary key for the kanban card entity.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlCycleId rdf:type rdf:Property ;
    rdfs:label 'Control Cycle Id' ;
    rdfs:comment 'Reference to the kanban control cycle that governs this card. Defines the replenishment loop parameters.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlCycle .

ind:primaryKanbanStockLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Kanban Stock Location Id' ;
    rdfs:comment 'Reference to the current physical location of the kanban card container. Enables real-time material tracking.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLocation .

ind:supplyAreaId rdf:type rdf:Property ;
    rdfs:label 'Supply Area Id' ;
    rdfs:comment 'Reference to the supply area or warehouse location from which material is replenished.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyArea .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this kanban card is currently active in the control cycle. Inactive cards are excluded from replenishment processing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Barcode value printed on the physical kanban card for scanning and automated signal processing.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Free-text explanation for why the kanban card is blocked or locked. Used for quality holds, safety issues, or process exceptions.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionAreaCode rdf:type rdf:Property ;
    rdfs:label 'Consumption Area Code' ;
    rdfs:comment 'Reference to the consumption area or work center where material is used.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerQuantity rdf:type rdf:Property ;
    rdfs:label 'Container Quantity' ;
    rdfs:comment 'Standard quantity of material held in one container for this kanban card. Represents the pull signal quantity.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Type of physical container used to hold the material quantity for this kanban card.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kanbanCardNumber rdf:type rdf:Property ;
    rdfs:label 'Kanban Card Number' ;
    rdfs:comment 'Externally visible unique kanban card number used for identification on the shop floor. Typically barcode or RFID-encoded for scanning.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kanbanCardStatus rdf:type rdf:Property ;
    rdfs:label 'Kanban Card Status' ;
    rdfs:comment 'Current lifecycle status of the kanban card. Empty triggers replenishment signal, in_transit indicates material movement, full indicates ready for consumption, in_use indicates active consumption, locked prevents usage, blocked indicates quality or safety hold.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kanbanLoopTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Kanban Loop Time Minutes' ;
    rdfs:comment 'Expected cycle time in minutes for one complete kanban loop from consumption signal to replenishment completion.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastConsumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Consumption Timestamp' ;
    rdfs:comment 'Timestamp when material was last consumed from this kanban card. Used for demand pattern analysis.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReplenishmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Timestamp' ;
    rdfs:comment 'Timestamp when material was last replenished for this kanban card. Used for consumption rate analysis.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastStatusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Status Change Timestamp' ;
    rdfs:comment 'Timestamp when the kanban card status was last changed. Critical for tracking loop time performance and identifying bottlenecks.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumLotSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Lot Size' ;
    rdfs:comment 'Maximum order quantity for replenishment. Prevents over-stocking and excess WIP inventory.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLotSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Lot Size' ;
    rdfs:comment 'Minimum order quantity (MOQ) for replenishment. Ensures economic order quantities are maintained.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfContainers rdf:type rdf:Property ;
    rdfs:label 'Number Of Containers' ;
    rdfs:comment 'Total number of containers in the kanban control cycle for this card. Determines the total inventory in the loop.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Replenishment Strategy' ;
    rdfs:comment 'Strategy for material replenishment. Pull is pure JIT demand-driven, push is forecast-driven, hybrid combines both.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'RFID tag identifier for automated tracking and real-time location monitoring of the kanban card.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'The current unrestricted quantity of this batch available for use in production or shipment. Updated in real-time based on goods movements, consumption, and quality status changes.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchClassification rdf:type rdf:Property ;
    rdfs:label 'Batch Classification' ;
    rdfs:comment 'The material type classification for this batch indicating its stage in the production process. Used for inventory segmentation and MRP planning logic.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchCostAmount rdf:type rdf:Property ;
    rdfs:label 'Batch Cost Amount' ;
    rdfs:comment 'The total production or procurement cost for this batch in the company currency. Used for inventory valuation, cost of goods sold calculation, and financial reporting per IFRS/GAAP standards.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch indicating its usability. Unrestricted: available for use; Quality Inspection: under QA review; Restricted: limited use with approval; Blocked: not available for use due to quality or compliance issues.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Quantity' ;
    rdfs:comment 'The quantity of this batch that is blocked and not available for any use. Set when batch fails quality inspection or is subject to hold for investigation per CAPA or NCR processes.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The user ID or username of the person who created this batch record. Audit field for accountability and data governance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerBatchRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Batch Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this batch must be tracked and reported to customers on shipping documents and certificates of analysis. True when customer contracts require batch-level traceability.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date when this batch was received into inventory via goods receipt posting. Marks the start of inventory availability and shelf life tracking for purchased materials.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Movement Date' ;
    rdfs:comment 'The date of the most recent goods movement transaction for this batch (receipt, issue, transfer, or adjustment). Used for inventory aging analysis and slow-moving stock identification.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The user ID or username of the person who last modified this batch record. Audit field for accountability and change management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'The date on which this batch was produced or manufactured. Critical for shelf life calculation, expiry determination, and lot traceability per ISO 9001 and PPAP requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country of origin for this batch. Required for customs, trade compliance, and country-of-origin labeling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Certificate Number' ;
    rdfs:comment 'The certificate number or document identifier for the quality certificate issued for this batch. Required for customer shipments and regulatory compliance documentation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDecision rdf:type rdf:Property ;
    rdfs:label 'Quality Decision' ;
    rdfs:comment 'The final quality decision for this batch based on inspection results. Accepted: meets all specifications; Rejected: fails quality criteria; Conditional: accepted with restrictions; Pending: awaiting inspection completion.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:comment 'The total quantity of material produced in this batch, expressed in the base unit of measure for the material. Used for inventory valuation and yield analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedQuantity rdf:type rdf:Property ;
    rdfs:label 'Restricted Quantity' ;
    rdfs:comment 'The quantity of this batch that is restricted and requires special approval for use. Typically set during quality inspection or when quality issues are identified.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Date' ;
    rdfs:comment 'The calculated shelf life expiration date based on manufacturing date and material-specific shelf life duration. Used in SAP MM for automatic batch determination and FEFO (First Expired First Out) logic.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Batch Number' ;
    rdfs:comment 'The batch or lot number assigned by the supplier or vendor for raw materials and purchased components. Used for upstream traceability and supplier quality management.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Batch Management Indicator' ;
    rdfs:comment 'Flag indicating whether the material requires batch or lot tracking. When active, all inventory transactions must reference a batch number for full traceability and quality control.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the material master record was first created in the system. Used for audit trail and material lifecycle tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionUnit rdf:type rdf:Property ;
    rdfs:label 'Dimension Unit' ;
    rdfs:comment 'Unit of measure for length, width, and height dimensions. Examples: MM (millimeter), CM (centimeter), M (meter), IN (inch).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptProcessingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Processing Time Days' ;
    rdfs:comment 'Time required for quality inspection and goods receipt posting after physical delivery. Added to planned delivery time for total procurement lead time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the material including all packaging. Used for logistics planning, freight calculation, and warehouse capacity management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'Classification of hazardous material type per UN/DOT regulations. Examples: flammable liquid, corrosive, toxic, oxidizer. Determines packaging, labeling, and shipping requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Flag indicating whether the material is classified as hazardous. Triggers additional safety, handling, storage, and transportation requirements per OSHA and EPA regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:height rdf:type rdf:Property ;
    rdfs:label 'Height' ;
    rdfs:comment 'Height dimension of the material. Used for storage bin assignment, handling equipment selection, and transportation planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionSetupIndicator rdf:type rdf:Property ;
    rdfs:label 'Inspection Setup Indicator' ;
    rdfs:comment 'Flag indicating whether incoming goods require quality inspection before stock placement. Triggers QM (Quality Management) inspection lot creation at goods receipt.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the material master record was last changed. Used for audit trail and change management tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:length rdf:type rdf:Property ;
    rdfs:label 'Length' ;
    rdfs:comment 'Length dimension of the material. Used for storage bin assignment, handling equipment selection, and transportation planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Full textual description of the material including key characteristics, specifications, and usage. Used for identification and communication across procurement, production, and sales.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Hierarchical classification code grouping materials with similar characteristics for procurement, planning, and reporting purposes. Used in MRP (Material Requirements Planning) and purchasing strategies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material master record. Controls whether the material can be procured, produced, or sold. Blocked materials cannot be used in new transactions.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the material based on its role in the manufacturing and supply chain process. Determines procurement, production, and inventory management rules. [ENUM-REF-CANDIDATE: raw_material|semi_finished|finished_good|trading_good|spare_part|consumable|packaging_material|service — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum remaining shelf life required at goods receipt. Materials with less remaining shelf life are rejected. Ensures adequate usable life for production and customer delivery.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Weighted average cost per base unit of measure, recalculated with each goods receipt. Used when price control is set to moving average price.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'MRP procedure code controlling how the material is planned. Determines reorder point planning, forecast-based planning, or time-phased planning methods.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Weight of the material itself excluding packaging. Used for production planning, yield calculations, and material consumption tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Days' ;
    rdfs:comment 'Expected lead time in days from order placement to goods receipt. Used by MRP to calculate order release dates. Includes supplier lead time and internal processing time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Control Indicator' ;
    rdfs:comment 'Defines material valuation method. S = standard price (fixed cost), V = moving average price (recalculated with each goods receipt). Determines inventory valuation approach.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'Quantity unit for which the price is maintained. Example: if price is $100 per 1000 units, price unit is 1000. Allows fractional pricing for low-cost materials.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productHierarchy rdf:type rdf:Property ;
    rdfs:label 'Product Hierarchy' ;
    rdfs:comment 'Multi-level classification structure organizing materials into product families and categories. Used for sales reporting, forecasting, and product portfolio management.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStock rdf:type rdf:Property ;
    rdfs:label 'Safety Stock' ;
    rdfs:comment 'Minimum inventory buffer maintained to protect against demand variability and supply disruptions. Never falls below this level under normal planning. Used in safety stock optimization algorithms.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberProfile rdf:type rdf:Property ;
    rdfs:label 'Serial Number Profile' ;
    rdfs:comment 'Configuration code defining serial number management requirements. Determines whether material requires unique serial number tracking for traceability, warranty, and asset management.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeExpirationDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Days' ;
    rdfs:comment 'Total shelf life of the material from production or goods receipt date. After this period, material expires and cannot be used. Critical for perishable materials and chemicals.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Fixed valuation price per base unit of measure. Used when price control is set to standard price. Updated periodically through cost accounting processes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required environmental conditions for material storage. Examples: temperature range, humidity control, light protection, hazardous material segregation. Used for warehouse bin assignment and handling instructions.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureConditions rdf:type rdf:Property ;
    rdfs:label 'Temperature Conditions' ;
    rdfs:comment 'Specific temperature range requirements for storage and transportation. Examples: ambient, refrigerated (2-8°C), frozen (-20°C), controlled room temperature (15-25°C).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Physical volume occupied by the material. Used for warehouse space planning, container loading optimization, and transportation planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for volume field. Examples: L (liter), M3 (cubic meter), GAL (gallon).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:width rdf:type rdf:Property ;
    rdfs:label 'Width' ;
    rdfs:comment 'Width dimension of the material. Used for storage bin assignment, handling equipment selection, and transportation planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineStockId rdf:type rdf:Property ;
    rdfs:label 'Quarantine Stock Id' ;
    rdfs:comment 'Unique identifier for the quarantine stock record. Primary key. Inferred role: MASTER_RESOURCE (quarantine stock is a resource state/container with lifecycle). No canonical skip needed.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleQualityEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Quality Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory compliance requires a qualified quality engineer to approve quarantine releases; linking to employee provides traceability for audits.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'Actual date when the quarantine was lifted and the material was released, reworked, returned, or scrapped.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Approval Date' ;
    rdfs:comment 'Date when the disposition decision was formally approved by the authorized quality or management personnel.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved By' ;
    rdfs:comment 'Name or identifier of the authorized person who approved the disposition decision, ensuring accountability and traceability.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final disposition decision made by the quality team regarding the quarantined material. Options include release to stock, use as-is with deviation, rework, return to vendor, scrap, or pending decision.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionJustification rdf:type rdf:Property ;
    rdfs:label 'Disposition Justification' ;
    rdfs:comment 'Detailed justification and rationale for the disposition decision, documenting the quality assessment, risk analysis, and approval basis.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSystemCode rdf:type rdf:Property ;
    rdfs:label 'Erp System Code' ;
    rdfs:comment 'Code or identifier of the source ERP system (e.g., SAP S/4HANA, Microsoft Dynamics 365) from which the quarantine record originated.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact' ;
    rdfs:comment 'Estimated financial impact or cost associated with the quarantined stock, including material value, potential rework costs, or scrap loss.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Release Date' ;
    rdfs:comment 'Anticipated date by which the quarantine investigation and disposition decision are expected to be completed, allowing for release or other action.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Initiating Document Number' ;
    rdfs:comment 'Reference number of the document that initiated the quarantine, enabling traceability to the root cause investigation or quality event.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingDocumentType rdf:type rdf:Property ;
    rdfs:label 'Initiating Document Type' ;
    rdfs:comment 'Type of document that triggered the quarantine action, such as NCR (Non-Conformance Report), CAPA (Corrective and Preventive Action), inspection report, customer complaint, supplier notification, or regulatory notice.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Inspection lot number from SAP QM or quality management system that tracks the inspection activity associated with the quarantined material.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineNotes rdf:type rdf:Property ;
    rdfs:label 'Quarantine Notes' ;
    rdfs:comment 'Free-text field for additional notes, observations, or instructions related to the quarantine case, supporting investigation and disposition activities.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineQuantity rdf:type rdf:Property ;
    rdfs:label 'Quarantine Quantity' ;
    rdfs:comment 'Quantity of material placed under quarantine, expressed in the base unit of measure for the material.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for placing the material under quarantine. Values include incoming inspection, in-process failure, customer complaint, NCR (Non-Conformance Report), regulatory hold, or shelf life expiry.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason Description' ;
    rdfs:comment 'Detailed textual description of the reason for quarantine, providing additional context beyond the reason code.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Quarantine Record Number' ;
    rdfs:comment 'Business identifier for the quarantine record, externally visible and used for traceability and audit purposes. Typically follows a structured format for easy reference.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineStartDate rdf:type rdf:Property ;
    rdfs:label 'Quarantine Start Date' ;
    rdfs:comment 'Date when the material was placed under quarantine and blocked from use or shipment.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Current lifecycle status of the quarantine record. Values include open, under investigation, pending approval, released, or closed.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Boolean flag indicating whether the quarantine is due to a regulatory hold imposed by FDA, EPA, or other governing body.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiry Date' ;
    rdfs:comment 'Expiry or best-before date of the material, relevant when quarantine is due to approaching or exceeded shelf life.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageBinLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Bin Location' ;
    rdfs:comment 'Specific bin or rack location within the storage area where the quarantined stock is placed for physical segregation.' ;
    rdfs:domain ind:QuarantineStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Storage location code within the warehouse where the quarantined material is held, as defined in SAP WM or WMS.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique identifier for the replenishment order record. Primary key for this entity.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReplenishmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Replenishment Employee Id' ;
    rdfs:comment 'Reference to the MRP controller or planner responsible for managing the replenishment of this material.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryReplenishmentApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Replenishment Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved this replenishment order for execution.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryReplenishmentModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Replenishment Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user or system process that last modified this replenishment order record.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when this replenishment order was closed after complete fulfillment or cancellation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'Actual confirmed delivery date provided by the supplier or internal source, may differ from requested date based on availability and lead time.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated total cost for fulfilling this replenishment order, including material cost, freight, and handling charges.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfilledQuantity rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Quantity' ;
    rdfs:comment 'Actual quantity of material that has been delivered and received against this replenishment order.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code to which the replenishment cost or inventory value will be posted for financial reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether incoming quality inspection is required before the replenished material can be released for use.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Size Quantity' ;
    rdfs:comment 'Standard or economic order quantity used for replenishment, may be based on MOQ (Minimum Order Quantity), EOQ (Economic Order Quantity), or fixed lot size rules.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the replenishment order indicating its progress through the fulfillment workflow. [ENUM-REF-CANDIDATE: draft|open|in_progress|partially_fulfilled|fulfilled|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Order Number' ;
    rdfs:comment 'Reference to the consuming order that requires this replenishment (e.g., production order, sales order, maintenance order). Used to link demand to supply.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceOrderType rdf:type rdf:Property ;
    rdfs:label 'Reference Order Type' ;
    rdfs:comment 'Classification of the reference order type that is consuming or requiring this replenishment.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level threshold that triggers automatic replenishment when stock falls below this point, used in min-max and reorder point planning strategies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentType rdf:type rdf:Property ;
    rdfs:label 'Replenishment Type' ;
    rdfs:comment 'Classification of the replenishment trigger mechanism: planning-driven (MRP-based), kanban (pull-based), min-max (reorder point), JIT (Just In Time), manual reservation, or safety stock replenishment.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target date by which the replenished material is required to be available at the storage location to meet production or demand requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredQuantity rdf:type rdf:Property ;
    rdfs:label 'Required Quantity' ;
    rdfs:comment 'Total quantity of material required to meet the replenishment target or reservation commitment, expressed in the base unit of measure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of material currently reserved or committed against this replenishment order, used for available-to-promise (ATP) calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberRequired rdf:type rdf:Property ;
    rdfs:label 'Serial Number Required' ;
    rdfs:comment 'Indicates whether individual serial number tracking is required for the replenished material items.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'Reference number of the originating document that triggered or fulfills this replenishment order (e.g., purchase requisition number, production order number, stock transfer order number).' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Classification of the source from which the material will be replenished: purchase requisition (external procurement), production order (internal manufacturing), stock transfer (inter-plant), external procurement, or internal transfer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProcurementType rdf:type rdf:Property ;
    rdfs:label 'Special Procurement Type' ;
    rdfs:comment 'Classification of special procurement arrangements such as consignment stock, subcontracting, pipeline materials, or inter-plant stock transfers.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventorySafetyStockPolicyId rdf:type rdf:Property ;
    rdfs:label 'Inventory Safety Stock Policy Id' ;
    rdfs:comment 'Unique identifier for the safety stock policy record.' ;
    rdfs:domain ind:InventorySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The methodology used to determine the safety stock quantity: fixed quantity, fixed days of supply, statistical (using demand variability), forecast error-based, or hybrid approach.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageProfile rdf:type rdf:Property ;
    rdfs:label 'Coverage Profile' ;
    rdfs:comment 'The time horizon unit used to express inventory coverage targets (days of supply, weeks of supply, or months of supply).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandVariabilityFactor rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Factor' ;
    rdfs:comment 'Statistical measure of demand fluctuation expressed as coefficient of variation or standard deviation factor, used to calculate safety stock buffer size.' ;
    rdfs:domain ind:InventorySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastModel rdf:type rdf:Property ;
    rdfs:label 'Forecast Model' ;
    rdfs:comment 'The demand forecasting model used to calculate expected consumption and variability for safety stock determination.' ;
    rdfs:domain ind:InventorySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingCostPerUnitPerYear rdf:type rdf:Property ;
    rdfs:label 'Holding Cost Per Unit Per Year' ;
    rdfs:comment 'The annual cost to hold one unit of this material in inventory, including warehousing, insurance, obsolescence, and capital cost.' ;
    rdfs:domain ind:InventorySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jitEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Jit Enabled Flag' ;
    rdfs:comment 'Indicates whether this material-plant combination follows Just In Time (JIT) inventory principles with minimal or zero safety stock.' ;
    rdfs:domain ind:InventorySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeRule rdf:type rdf:Property ;
    rdfs:label 'Lot Size Rule' ;
    rdfs:comment 'The rule governing replenishment order quantities: fixed quantity, Economic Order Quantity (EOQ), lot-for-lot matching demand, period-based batching, weekly, or monthly aggregation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'The upper inventory limit for this material-plant combination to prevent overstocking and excess capital tied up in inventory.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningStrategy rdf:type rdf:Property ;
    rdfs:label 'Planning Strategy' ;
    rdfs:comment 'The inventory planning methodology applied: Material Requirements Planning (MRP), Manufacturing Resource Planning (MRP II), Distribution Requirements Planning (DRP), Kanban pull system, or manual planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Business identifier code for the safety stock policy, typically combining material, plant, and policy version identifiers.' ;
    rdfs:domain ind:InventorySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNotes rdf:type rdf:Property ;
    rdfs:label 'Policy Notes' ;
    rdfs:comment 'Free-text field for planners to document special considerations, exceptions, business rationale, or historical context for this safety stock policy.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the safety stock policy indicating whether it is actively used in Material Requirements Planning (MRP) calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the safety stock policy approach: fixed buffer, dynamic calculation, seasonal adjustment, Just In Time (JIT) minimal stock, zero stock strategy, or consignment inventory.' ;
    rdfs:domain ind:InventorySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleDays rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Days' ;
    rdfs:comment 'The frequency in days at which inventory levels are reviewed and replenishment decisions are made for periodic review policies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyTimeDays rdf:type rdf:Property ;
    rdfs:label 'Safety Time Days' ;
    rdfs:comment 'Additional time buffer in days added to the replenishment lead time to protect against supply delays and schedule variability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Flag' ;
    rdfs:comment 'Indicates whether this policy includes seasonal demand pattern adjustments that modify safety stock levels throughout the year.' ;
    rdfs:domain ind:InventorySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Percent' ;
    rdfs:comment 'The target probability of not experiencing a stockout during the replenishment lead time, typically expressed as a percentage (e.g., 95%, 99%).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockoutCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Stockout Cost Per Unit' ;
    rdfs:comment 'The estimated business cost incurred per unit when a stockout occurs, including lost sales, expediting costs, and customer dissatisfaction impact.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCoverageValue rdf:type rdf:Property ;
    rdfs:label 'Target Coverage Value' ;
    rdfs:comment 'The target number of coverage periods (days, weeks, or months) that the safety stock should protect against stockouts.' ;
    rdfs:domain ind:InventorySafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:xyzClassification rdf:type rdf:Property ;
    rdfs:label 'Xyz Classification' ;
    rdfs:comment 'Demand variability classification: X (stable demand), Y (moderate variability), Z (highly variable or sporadic demand).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializedUnitId rdf:type rdf:Property ;
    rdfs:label 'Serialized Unit Id' ;
    rdfs:comment 'Unique identifier for the serialized unit record. Primary key for individual unit tracking across inventory lifecycle.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SerializedUnit .

ind:parentUnitSerializedUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Unit Serialized Unit Id' ;
    rdfs:comment 'Reference to the parent handling unit (pallet, container, tote) that contains this serialized unit. Enables hierarchical packing structure and nested unit tracking for warehouse operations.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SerializedUnit .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, rack, or storage position identifier within the warehouse where this serialized unit is physically located. Enables precise picking and putaway operations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where this serialized unit was manufactured or assembled. Required for customs declarations and trade compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsTariffCode rdf:type rdf:Property ;
    rdfs:label 'Customs Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) code or Harmonized Tariff Schedule (HTS) code for customs classification and duty calculation. Required for international shipments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the serialized unit including packaging and contents, measured in kilograms. Used for logistics planning and transportation compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'United Nations (UN) hazard classification code for hazardous materials (e.g., Class 3 Flammable Liquids, Class 8 Corrosives). Required for transportation and storage compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Boolean indicator whether this serialized unit contains hazardous materials requiring special handling, storage, and transportation compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Height dimension of the serialized unit or handling unit in centimeters. Used for warehouse space planning and transportation optimization.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent inventory movement transaction for this serialized unit. Used for inventory aging analysis and cycle count prioritization.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastMovementType rdf:type rdf:Property ;
    rdfs:label 'Last Movement Type' ;
    rdfs:comment 'Type of the most recent inventory movement transaction for this serialized unit (e.g., goods receipt, goods issue, transfer posting, physical inventory). Provides audit trail context.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Length dimension of the serialized unit or handling unit in centimeters. Used for warehouse space planning and transportation optimization.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'Net weight of the material contents excluding packaging, measured in kilograms. Used for material valuation and yield calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates the legal ownership of the serialized unit. Distinguishes between company-owned inventory, customer consignment, vendor consignment, and third-party logistics (3PL) owned stock.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current quality inspection status of the serialized unit. Indicates whether the unit has passed quality checks and is approved for use or shipment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal number applied to handling units (containers, pallets) for tamper detection and customs compliance. Required for international shipments and high-value goods.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current lifecycle status of the serialized unit indicating its position in the inventory and production workflow. Drives availability for Material Requirements Planning (MRP) and order fulfillment. [ENUM-REF-CANDIDATE: in_stock|in_production|in_transit|shipped|delivered|returned|blocked|scrapped|consumed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN number identifying the hazardous substance for transportation and emergency response (e.g., UN1203 for gasoline). Required for hazmat shipping documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the serialized unit indicating whether it is a serialized component part, assembly, finished good, or handling unit (pallet, container, tote, drum, reel) used for material handling and logistics. [ENUM-REF-CANDIDATE: serialized_part|assembly|finished_good|pallet|container|tote|drum|reel|handling_unit — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Monetary valuation of this serialized unit for inventory accounting and financial reporting. Represents standard cost, moving average price, or actual cost depending on valuation method.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volume of the serialized unit or handling unit in cubic meters. Used for warehouse capacity planning and freight cost calculation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Width dimension of the serialized unit or handling unit in centimeters. Used for warehouse space planning and transportation optimization.' ;
    rdfs:domain ind:SerializedUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockBalanceId rdf:type rdf:Property ;
    rdfs:label 'Stock Balance Id' ;
    rdfs:comment 'Unique identifier for the stock balance record. Primary key for the stock balance entity.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockedReasonCode rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason Code' ;
    rdfs:comment 'Code indicating the reason why stock is blocked from use. Examples include quality hold, pending investigation, customer return, damaged goods, regulatory hold. Null if stock is not blocked.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Consignment Indicator' ;
    rdfs:comment 'Flag indicating whether this stock is consignment stock owned by the supplier but held at the customer location. True for consignment stock; false for own stock.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryTurnoverDays rdf:type rdf:Property ;
    rdfs:label 'Inventory Turnover Days' ;
    rdfs:comment 'Average number of days this material remains in stock before being consumed or sold. Calculated as (quantity on hand / average daily usage). Used for inventory performance KPI tracking.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCountVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Last Count Variance Quantity' ;
    rdfs:comment 'Difference between book quantity and physical count quantity from the last inventory count. Positive values indicate surplus; negative values indicate shortage.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Issue Date' ;
    rdfs:comment 'Date of the most recent goods issue transaction that decreased stock for this material at this location. Used for inventory turnover analysis.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt transaction that increased stock for this material at this location. Used for inventory aging analysis.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count performed for this material at this location. Used to track count frequency and compliance.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obsoleteIndicator rdf:type rdf:Property ;
    rdfs:label 'Obsolete Indicator' ;
    rdfs:comment 'Flag indicating whether this material is classified as obsolete and should be phased out or written off. True if material is no longer used in production or sales.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndSnapshotDate rdf:type rdf:Property ;
    rdfs:label 'Period End Snapshot Date' ;
    rdfs:comment 'Date representing the period-end for which this stock balance snapshot was captured. Used for month-end, quarter-end, and year-end inventory reporting and financial close processes.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slowMovingIndicator rdf:type rdf:Property ;
    rdfs:label 'Slow Moving Indicator' ;
    rdfs:comment 'Flag indicating whether this material is classified as slow-moving based on consumption patterns. True if no movement in the defined threshold period (e.g., 90 days).' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialStockType rdf:type rdf:Property ;
    rdfs:label 'Special Stock Type' ;
    rdfs:comment 'Classification of special stock scenarios. Standard is regular stock; consignment is supplier-owned; project stock is allocated to specific projects; sales order stock is customer-specific; subcontracting is at vendor location; returnable packaging is reusable containers.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockCategory rdf:type rdf:Property ;
    rdfs:label 'Stock Category' ;
    rdfs:comment 'Classification of stock availability status. Unrestricted stock is available for use; quality inspection stock is pending QA approval; blocked stock cannot be used; in-transit stock is moving between locations; reserved stock is allocated to specific orders or production.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'Total financial value of the stock on hand, calculated as quantity on hand multiplied by valuation price. Used for inventory valuation reporting and balance sheet preparation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the valuation price. Typically the plant or company code currency.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationPrice rdf:type rdf:Property ;
    rdfs:label 'Valuation Price' ;
    rdfs:comment 'Standard or moving average price used to value the stock for financial reporting. Price per base unit of measure.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Batch Number' ;
    rdfs:comment 'Batch or lot number assigned by the supplier for purchased materials. Used for supplier traceability and quality issue resolution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseBinLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Bin Location' ;
    rdfs:comment 'Specific bin, rack, or shelf location within the storage location where the material is physically stored. Used for warehouse picking and putaway operations.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Access Equipment Required' ;
    rdfs:comment 'Type of material handling equipment required to access this storage location. Determines labor and equipment resource planning for put-away and picking operations. Influences cycle time calculations and warehouse operational efficiency metrics (OEE). [ENUM-REF-CANDIDATE: none|forklift|reach_truck|order_picker|crane|agv|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleNumber rdf:type rdf:Property ;
    rdfs:label 'Aisle Number' ;
    rdfs:comment 'Aisle identifier within the warehouse zone. Aisles are the primary navigation paths for material handlers and automated guided vehicles (AGVs). Used for directed put-away and optimized picking routes.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binPosition rdf:type rdf:Property ;
    rdfs:label 'Bin Position' ;
    rdfs:comment 'Horizontal bin position within the shelf level. Represents the finest granularity of storage location addressing. Used for precise material placement and retrieval in high-density storage environments.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Capacity Pallet Positions' ;
    rdfs:comment 'Number of standard pallet positions that can be stored in this location. Used for pallet storage locations to calculate available capacity and optimize warehouse space utilization. Assumes standard pallet dimensions (e.g., 1200mm x 1000mm EUR pallet or 1219mm x 1016mm North American pallet).' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume M3' ;
    rdfs:comment 'Maximum volumetric capacity of the storage location measured in cubic meters. Used for space utilization analysis, slotting optimization, and warehouse capacity planning. Constrains the physical size of materials that can be stored in this location.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location measured in kilograms. Enforces structural load limits for racks and shelves. Critical for safety compliance and preventing equipment damage. Used in slotting algorithms to match heavy materials with appropriate locations.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Frequency at which this storage location is scheduled for cycle counting inventory verification. High-value or high-velocity locations typically have higher cycle count frequencies. Used to generate cycle count schedules and ensure inventory accuracy per ISO 9001 quality management requirements.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when this storage location was deactivated or retired from operational use. Deactivated locations are no longer available for material placement but may retain historical inventory transaction data. Used for warehouse reconfiguration tracking and capacity planning analysis.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fifoEnforced rdf:type rdf:Property ;
    rdfs:label 'Fifo Enforced' ;
    rdfs:comment 'Boolean flag indicating whether this location enforces First In First Out (FIFO) inventory rotation. FIFO ensures older materials are consumed before newer materials, critical for perishable goods, time-sensitive components, and materials with shelf-life constraints. Used by warehouse management systems (WMS) to generate FIFO-compliant pick instructions.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireZone rdf:type rdf:Property ;
    rdfs:label 'Fire Zone' ;
    rdfs:comment 'Fire safety zone identifier for this storage location. Fire zones group locations by fire suppression system coverage and emergency response protocols. Critical for safety compliance, emergency planning, and hazardous material segregation per OSHA and NFPA standards.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityControlled rdf:type rdf:Property ;
    rdfs:label 'Humidity Controlled' ;
    rdfs:comment 'Boolean flag indicating whether this location maintains controlled humidity levels. Humidity control is critical for materials susceptible to moisture damage, corrosion, or degradation such as electronics, metal components, and hygroscopic materials.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humidityMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Max Percent' ;
    rdfs:comment 'Maximum allowable relative humidity percentage for this storage location. Enforces upper humidity boundary to prevent condensation, corrosion, or mold growth. Typically ranges from 50% to 70% for general storage, lower for electronics.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityMinPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Min Percent' ;
    rdfs:comment 'Minimum allowable relative humidity percentage for this storage location. Enforces lower humidity boundary to prevent static electricity buildup or material desiccation. Typically ranges from 20% to 40% for electronics and sensitive components.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Approved' ;
    rdfs:comment 'Boolean flag indicating whether this location is certified and approved for storing hazardous materials. Hazmat-approved locations must meet specific safety, ventilation, containment, and regulatory requirements per OSHA and EPA standards. Used to enforce material placement rules for dangerous goods.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPickingLocation rdf:type rdf:Property ;
    rdfs:label 'Is Picking Location' ;
    rdfs:comment 'Boolean flag indicating whether this location is designated as a primary picking location for order fulfillment. Picking locations are typically positioned in ergonomic zones with high accessibility and are replenished from reserve locations. Used by warehouse management systems (WMS) to optimize pick path generation.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReplenishmentLocation rdf:type rdf:Property ;
    rdfs:label 'Is Replenishment Location' ;
    rdfs:comment 'Boolean flag indicating whether this location serves as a reserve or bulk storage location that feeds picking locations through replenishment processes. Replenishment locations typically have higher capacity and lower accessibility than picking locations.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the most recent cycle count was performed for this storage location. Used to track cycle count compliance, identify overdue counts, and calculate inventory accuracy metrics. Critical for maintaining inventory integrity and meeting audit requirements.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotControlRequired rdf:type rdf:Property ;
    rdfs:label 'Lot Control Required' ;
    rdfs:comment 'Boolean flag indicating whether materials stored in this location must be tracked by lot or batch number. Lot control is mandatory for materials subject to traceability requirements, expiration date management, or quality recall procedures per ISO 9001 and industry-specific regulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixedSkuAllowed rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed' ;
    rdfs:comment 'Boolean flag indicating whether this location can store multiple different SKUs simultaneously. Single-SKU locations simplify picking and inventory accuracy but reduce space utilization. Mixed-SKU locations increase storage density but require more sophisticated inventory tracking and picking processes.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Date when this storage location record was last modified. Tracks changes to location attributes such as capacity, status, or environmental requirements. Used for change management, audit compliance, and data quality monitoring.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pickSequence rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence' ;
    rdfs:comment 'Numeric sequence number used to optimize picking routes within the warehouse. Lower numbers indicate locations that should be visited earlier in the pick path. Used by warehouse management systems (WMS) to generate efficient pick lists and minimize travel distance for order fulfillment.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rackNumber rdf:type rdf:Property ;
    rdfs:label 'Rack Number' ;
    rdfs:comment 'Rack or bay identifier within the aisle. Racks are vertical storage structures containing multiple shelf levels. Critical for coordinate-based bin addressing and warehouse layout optimization.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLevel rdf:type rdf:Property ;
    rdfs:label 'Shelf Level' ;
    rdfs:comment 'Vertical shelf or tier position within the rack (e.g., 1, 2, 3 or A, B, C). Shelf level determines accessibility, ergonomics, and suitability for different material handling equipment. Lower shelves typically used for high-velocity or heavy items.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Boolean flag indicating whether this location is within a temperature-controlled environment. Temperature-controlled locations are required for materials sensitive to heat, cold, or humidity such as chemicals, electronics, pharmaceuticals, and certain raw materials.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum allowable temperature for this storage location measured in degrees Celsius. Enforces upper temperature boundary for temperature-sensitive materials. Exceeding this threshold may trigger quality alerts and material quarantine procedures.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum allowable temperature for this storage location measured in degrees Celsius. Enforces lower temperature boundary for temperature-sensitive materials. Used in conjunction with maximum temperature to define the acceptable storage environment range.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:xCoordinate rdf:type rdf:Property ;
    rdfs:label 'X Coordinate' ;
    rdfs:comment 'Horizontal X-axis coordinate of the storage location within the warehouse floor plan. Used for warehouse mapping, route optimization, and integration with warehouse automation systems and AGVs. Measured in meters or feet from a defined origin point.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yCoordinate rdf:type rdf:Property ;
    rdfs:label 'Y Coordinate' ;
    rdfs:comment 'Horizontal Y-axis coordinate of the storage location within the warehouse floor plan. Used in conjunction with X coordinate for precise location mapping and automated material handling system navigation.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zCoordinate rdf:type rdf:Property ;
    rdfs:label 'Z Coordinate' ;
    rdfs:comment 'Vertical Z-axis coordinate representing the height of the storage location above the warehouse floor. Critical for automated storage and retrieval systems (AS/RS) and crane operations. Measured in meters or feet.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'High-level zone identifier within the warehouse (e.g., A, B, C or NORTH, SOUTH). Zones group locations by physical area, product category, or operational function to optimize picking routes and material flow.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique identifier for each stock movement transaction. Primary key for the stock movement data product.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Foreign key reference to the outbound delivery document when this movement is part of a shipment to customer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Delivery .

ind:sourceStockLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Stock Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_location. Business justification: Link stock movement to its source location for traceability; replace free-text code with FK.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLocation .

ind:destinationBinLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Bin Location' ;
    rdfs:comment 'Specific bin, shelf, or warehouse location identifier to which the material was placed or moved.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location Code' ;
    rdfs:comment 'For transfer movements, the receiving storage location to which the material was moved.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The precise date and time when this stock movement record was created in the system, capturing the moment of transaction entry.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goodsIssueIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this movement decreases inventory (goods issue scenario).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this movement increases inventory (goods receipt scenario).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Material Document Item' ;
    rdfs:comment 'Line item number within the material document, representing the sequence of this movement within a multi-line transaction.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'Fiscal year of the material document posting, used in combination with material document number for unique identification in SAP systems.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementIndicator rdf:type rdf:Property ;
    rdfs:label 'Movement Indicator' ;
    rdfs:comment 'High-level classification of the movement direction: receipt (inbound), issue (outbound), transfer (location-to-location), or adjustment (correction/write-off).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'Code explaining the business reason for the movement (e.g., damaged goods, quality defect, process scrap, customer return, inventory correction). Used for root cause analysis and continuous improvement.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the stock movement transaction: posted (completed and effective), pending (awaiting confirmation), cancelled (voided before posting), or reversed (corrected after posting).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'Three-digit SAP movement type code that classifies the nature of the inventory transaction (e.g., 101=Goods Receipt from PO, 261=Goods Issue to Production Order, 311=Transfer Posting, 551=Scrapping). This code determines the accounting impact and stock ledger behavior.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Reference Document Item' ;
    rdfs:comment 'Line item number within the reference document that corresponds to this stock movement.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that triggered this stock movement (e.g., purchase order for goods receipt, production order for goods issue, delivery for shipment). [ENUM-REF-CANDIDATE: purchase_order|production_order|sales_order|delivery|transfer_order|physical_inventory|reservation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedMaterialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Material Document Number' ;
    rdfs:comment 'The material document number of the original transaction that this movement reverses, establishing audit trail linkage for corrections.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceBinLocation rdf:type rdf:Property ;
    rdfs:label 'Source Bin Location' ;
    rdfs:comment 'Specific bin, shelf, or warehouse location identifier from which the material was picked or moved, enabling precise warehouse management and cycle count accuracy.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockValuationId rdf:type rdf:Property ;
    rdfs:label 'Stock Valuation Id' ;
    rdfs:comment 'Unique identifier for the stock valuation record. Primary key for the stock valuation entity.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryAccountingMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Accounting Method' ;
    rdfs:comment 'Cost flow assumption method used for inventory valuation. FIFO (First In First Out), LIFO (Last In First Out), weighted average, or specific identification.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryWriteDownAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Write Down Amount' ;
    rdfs:comment 'Amount by which inventory value has been written down due to obsolescence, damage, or net realizable value being lower than cost. Required for IFRS and GAAP compliance.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isConsignmentStock rdf:type rdf:Property ;
    rdfs:label 'Is Consignment Stock' ;
    rdfs:comment 'Boolean flag indicating whether this stock is held on consignment from a vendor. Consignment stock is not valued on the balance sheet until it is withdrawn for use.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpecialStock rdf:type rdf:Property ;
    rdfs:label 'Is Special Stock' ;
    rdfs:comment 'Boolean flag indicating whether this is special stock (e.g., project stock, sales order stock, returnable packaging). Special stock may have different valuation rules.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPriceChangeDate rdf:type rdf:Property ;
    rdfs:label 'Last Price Change Date' ;
    rdfs:comment 'Date when the standard price or moving average price was last changed. Used for price history tracking and audit purposes.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialOverheadAmount rdf:type rdf:Property ;
    rdfs:label 'Material Overhead Amount' ;
    rdfs:comment 'Total material overhead amount included in the stock valuation. Calculated by applying the material overhead rate to the base material cost.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialOverheadRate rdf:type rdf:Property ;
    rdfs:label 'Material Overhead Rate' ;
    rdfs:comment 'Percentage rate applied to material cost to account for procurement overhead, handling, and storage costs. Used in full costing calculations.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRealizableValue rdf:type rdf:Property ;
    rdfs:label 'Net Realizable Value' ;
    rdfs:comment 'Estimated selling price in the ordinary course of business less estimated costs of completion and estimated costs necessary to make the sale. Used to determine lower of cost or NRV per IAS 2.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousPeriodPrice rdf:type rdf:Property ;
    rdfs:label 'Previous Period Price' ;
    rdfs:comment 'Price per unit from the previous fiscal period. Used for period-over-period variance analysis and price trend tracking.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Price Change Amount' ;
    rdfs:comment 'Absolute change in price per unit compared to the previous period. Calculated as current price minus previous period price.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Price Change Percentage' ;
    rdfs:comment 'Percentage change in price compared to the previous period. Used for inflation tracking and cost variance analysis.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceControlMethod rdf:type rdf:Property ;
    rdfs:label 'Price Control Method' ;
    rdfs:comment 'Indicator determining whether material is valued using standard price (S) or moving average price (V). Standard price remains fixed until manually changed; moving average price recalculates with each goods receipt.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'Total price variance amount for the period, representing the difference between standard price and actual purchase price multiplied by quantity received. Used in standard costing variance analysis.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionForObsolescence rdf:type rdf:Property ;
    rdfs:label 'Provision For Obsolescence' ;
    rdfs:comment 'Reserve amount set aside for slow-moving, obsolete, or excess inventory. Reduces the carrying value of inventory on the balance sheet.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Stock Quantity' ;
    rdfs:comment 'Total quantity of material in stock at the valuation area, including unrestricted, quality inspection, and blocked stock. Expressed in base unit of measure.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Valuation Adjustment Reason' ;
    rdfs:comment 'Free-text explanation for any manual valuation adjustments made during the period. Used for audit trail and management review.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Area Code' ;
    rdfs:comment 'Code identifying the organizational unit for which material is valued. Typically corresponds to plant or company code level valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationCategory rdf:type rdf:Property ;
    rdfs:label 'Valuation Category' ;
    rdfs:comment 'High-level category classifying the type of inventory being valued. Aligns with balance sheet presentation and inventory management strategy.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'Date on which this valuation snapshot was taken. Typically corresponds to period-end closing date for financial reporting.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current status of the valuation record indicating whether the material is actively valued, blocked from transactions, restricted use, or flagged for write-off.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when the warehouse facility became operational and available for inventory storage. Marks the start of the facility lifecycle.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'Date when the warehouse facility ceased operations or was decommissioned. Null for currently active facilities. Used for historical reporting and capacity planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the warehouse facility. First line of the physical location address.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as building number, suite, or floor. Optional additional address detail.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedStorageFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Storage Flag' ;
    rdfs:comment 'Indicates whether the warehouse uses automated storage and retrieval systems (AS/RS). Impacts throughput rates, labor requirements, and integration with WMS and MES.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:climateControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Climate Controlled Flag' ;
    rdfs:comment 'Indicates whether the warehouse has climate control capabilities for temperature and humidity-sensitive materials. Critical for pharmaceutical, electronic component, and chemical storage compliance.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for warehouse operational communication. Used for shipment notifications, inventory alerts, and administrative correspondence.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary contact phone number for the warehouse facility. Used for carrier coordination, emergency contact, and operational communication.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBondedFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Flag' ;
    rdfs:comment 'Indicates whether the warehouse is a customs-bonded facility authorized to store imported goods before duty payment. Critical for international supply chain and duty deferral strategies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the warehouse based on the primary type of inventory stored. Determines storage requirements, handling procedures, and integration with MRP and MES systems.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionSystemType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System Type' ;
    rdfs:comment 'Type of fire suppression system installed in the warehouse. Critical for insurance, safety compliance, and determining storage eligibility for flammable materials.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the warehouse is certified to store hazardous materials. Determines eligibility for storing chemicals, flammables, and regulated substances per OSHA and EPA requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatStorageClasses rdf:type rdf:Property ;
    rdfs:label 'Hazmat Storage Classes' ;
    rdfs:comment 'Comma-separated list of hazardous material storage classes the warehouse is certified to handle (e.g., Class 3 Flammable Liquids, Class 8 Corrosives). Based on UN hazard classification system.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified Flag' ;
    rdfs:comment 'Indicates whether the warehouse facility holds ISO 14001 environmental management system certification. Demonstrates commitment to environmental sustainability and regulatory compliance.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the warehouse facility holds ISO 9001 quality management system certification. Impacts supplier qualification and customer audit requirements.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the warehouse lease agreement expires. Null for owned facilities. Used for facility planning and contract renewal management.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfLoadingDocks rdf:type rdf:Property ;
    rdfs:label 'Number Of Loading Docks' ;
    rdfs:comment 'Total count of loading and unloading dock positions. Determines receiving and shipping throughput capacity.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfStorageBins rdf:type rdf:Property ;
    rdfs:label 'Number Of Storage Bins' ;
    rdfs:comment 'Total count of discrete storage bin locations within the warehouse. Used for bin location management and inventory tracking granularity in SAP WM.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHoursDescription rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Description' ;
    rdfs:comment 'Textual description of standard operating hours and shift patterns (e.g., 24/7, Monday-Friday 8am-5pm, Three-shift operation). Used for carrier scheduling and labor planning.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Identifier of the source system that created or owns this warehouse master record (e.g., SAP_S4HANA, DYNAMICS_365_SCM, MDM). Used for data lineage and system-of-record identification.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageAreaSquareMeters rdf:type rdf:Property ;
    rdfs:label 'Storage Area Square Meters' ;
    rdfs:comment 'Floor area dedicated to inventory storage in square meters. Excludes receiving docks, shipping areas, and administrative space.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum temperature that can be maintained in climate-controlled zones, measured in Celsius. Used for material storage requirement validation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum temperature that can be maintained in climate-controlled zones, measured in Celsius. Used for material storage requirement validation.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Cubic Meters' ;
    rdfs:comment 'Total storage capacity of the warehouse measured in cubic meters. Represents maximum volumetric storage capability for inventory planning and capacity utilization analysis.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFloorAreaSquareMeters rdf:type rdf:Property ;
    rdfs:label 'Total Floor Area Square Meters' ;
    rdfs:comment 'Total floor area of the warehouse facility in square meters. Includes storage, receiving, shipping, and administrative areas.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usableCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Usable Capacity Cubic Meters' ;
    rdfs:comment 'Actual usable storage capacity after accounting for aisles, equipment, and operational space. Used for realistic inventory allocation and safety stock calculations.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the warehouse facility. Used in SAP WM and Microsoft Dynamics 365 SCM for warehouse identification and cross-system integration.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseName rdf:type rdf:Property ;
    rdfs:label 'Warehouse Name' ;
    rdfs:comment 'Full business name of the warehouse facility. Human-readable identifier used in operational documentation and reporting.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Wms System Code' ;
    rdfs:comment 'Code identifying the WMS system deployed at this warehouse (e.g., SAP_WM, DYNAMICS_365_SCM, MANHATTAN). Used for system integration routing and data synchronization.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipStockId rdf:type rdf:Property ;
    rdfs:label 'Wip Stock Id' ;
    rdfs:comment 'Unique identifier for the work-in-progress inventory record. Primary key for the WIP stock entity.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWipEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Wip Employee Id' ;
    rdfs:comment 'Reference to the production operator or worker currently responsible for processing this WIP stock. Used for labor tracking and quality accountability.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual timestamp when this WIP stock completed all production operations. Null if production is still in progress. Used for lead time analysis and schedule adherence tracking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version number of the bill of materials used for producing this WIP stock. Tracks which BOM configuration was applied, important for engineering change management and traceability.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Order Number' ;
    rdfs:comment 'Customer sales order number for which this WIP stock is being produced, if applicable. Used for make-to-order production tracking and customer-specific inventory management. Null for make-to-stock production.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Completion Date' ;
    rdfs:comment 'Planned or scheduled date when this WIP stock is expected to complete all production operations and be ready for transfer to finished goods inventory. Used for production planning and delivery commitment.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Code indicating the reason why this WIP stock is on hold, if applicable. Values: quality_issue (failed inspection), material_shortage (awaiting components), equipment_failure (machine breakdown), engineering_change (ECO/ECN pending), customer_request (order change), other (miscellaneous reasons). Null if not on hold.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Accumulated direct labor cost incurred in producing this WIP stock up to the current operation. Includes operator wages and benefits allocated to this production activity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCost rdf:type rdf:Property ;
    rdfs:label 'Material Cost' ;
    rdfs:comment 'Accumulated cost of raw materials and components consumed in producing this WIP stock up to the current operation. Component of total WIP valuation.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence Number' ;
    rdfs:comment 'Current operation step or routing sequence number in the production process where this WIP stock is located. Indicates the specific manufacturing stage within the overall production routing.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation Start Timestamp' ;
    rdfs:comment 'Timestamp when processing began at the current operation step. Used for cycle time tracking and operation-level performance analysis.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overheadCost rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost' ;
    rdfs:comment 'Accumulated manufacturing overhead cost allocated to this WIP stock up to the current operation. Includes indirect costs such as utilities, depreciation, and facility expenses.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Production priority level assigned to this WIP stock. Values: urgent (expedited processing required), high (priority customer order), normal (standard production), low (fill-in work). Used for shop floor scheduling and resource allocation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStartDate rdf:type rdf:Property ;
    rdfs:label 'Production Start Date' ;
    rdfs:comment 'Date when production of this WIP stock began. Marks the start of the manufacturing process for this batch or lot.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityCompleted rdf:type rdf:Property ;
    rdfs:label 'Quantity Completed' ;
    rdfs:comment 'Quantity of the material or assembly that has completed processing at the current operation step and is ready to move to the next stage. Used for tracking operation-level progress and yield.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityInProcess rdf:type rdf:Property ;
    rdfs:label 'Quantity In Process' ;
    rdfs:comment 'Current quantity of the material or assembly in work-in-progress status, measured in the base unit of measure. Represents the number of units currently being manufactured at this operation step.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityScrapped rdf:type rdf:Property ;
    rdfs:label 'Quantity Scrapped' ;
    rdfs:comment 'Quantity of the material or assembly that was scrapped or rejected during processing at the current operation. Used for scrap rate calculation and quality analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkOperationSequence rdf:type rdf:Property ;
    rdfs:label 'Rework Operation Sequence' ;
    rdfs:comment 'Operation sequence number to which this WIP stock must be returned for rework, if rework is required. Null if no rework is needed. Used for routing rework items back through the production process.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkRequired rdf:type rdf:Property ;
    rdfs:label 'Rework Required' ;
    rdfs:comment 'Boolean flag indicating whether this WIP stock requires rework or reprocessing due to quality issues. True if rework is needed, false otherwise. Used for quality management and cost tracking.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Version' ;
    rdfs:comment 'Version number of the production routing or process plan used for manufacturing this WIP stock. Tracks which manufacturing process was followed, important for process control and traceability.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range End' ;
    rdfs:comment 'Ending serial number in the range assigned to this WIP stock batch, if serialized tracking is required. Used for individual unit traceability in high-value or regulated products. Null if not serialized.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range Start' ;
    rdfs:comment 'Starting serial number in the range assigned to this WIP stock batch, if serialized tracking is required. Used for individual unit traceability in high-value or regulated products. Null if not serialized.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Code identifying the production shift during which this WIP stock is being processed. Used for shift-level performance tracking and labor allocation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Wip Batch Number' ;
    rdfs:comment 'Unique batch or lot number assigned to this work-in-progress inventory for traceability and quality control purposes. Used for tracking materials through production stages.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipStatus rdf:type rdf:Property ;
    rdfs:label 'Wip Status' ;
    rdfs:comment 'Current lifecycle status of the WIP stock. Values: in_process (actively being manufactured), on_hold (production paused), awaiting_inspection (pending quality check), ready_to_move (completed operation, awaiting transfer), scrapped (rejected), completed (finished all operations).' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Valuation Amount' ;
    rdfs:comment 'Total valuation amount of this WIP stock in the company\'s base currency. Represents the accumulated cost of materials, labor, and overhead consumed up to the current production stage. Used for inventory valuation and financial reporting.' ;
    rdfs:domain ind:WipStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Calculated yield percentage for this WIP stock at the current operation, representing the ratio of good output to total input. Used for process performance monitoring and OEE calculation. Formula: (quantity_completed / (quantity_completed + quantity_scrapped)) * 100.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billOfLadingId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Id' ;
    rdfs:comment 'Unique identifier for the bill of lading record. Primary key.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBillCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Bill Customer Account Id' ;
    rdfs:comment 'Reference to the party (supplier or internal plant) sending the cargo.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date when the cargo was delivered to the consignee and signed for.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billOfLadingStatus rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Status' ;
    rdfs:comment 'Current lifecycle status of the BOL document and associated shipment.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'Externally-known unique document number issued by the carrier for this shipment. Required for customs and proof of delivery.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolType rdf:type rdf:Property ;
    rdfs:label 'Bol Type' ;
    rdfs:comment 'Classification of the BOL document type indicating transferability and ownership terms.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Detailed description of the goods being shipped, including product names, materials, and characteristics.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Consignee Address Line1' ;
    rdfs:comment 'Primary street address of the consignee destination location.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeCity rdf:type rdf:Property ;
    rdfs:label 'Consignee City' ;
    rdfs:comment 'City where the consignee destination is located.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Consignee Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the consignee destination.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Legal name of the consignee party receiving the cargo.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneePostalCode rdf:type rdf:Property ;
    rdfs:label 'Consignee Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the consignee destination.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeStateProvince rdf:type rdf:Property ;
    rdfs:label 'Consignee State Province' ;
    rdfs:comment 'State or province code for the consignee destination.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Value Amount' ;
    rdfs:comment 'Monetary value of the cargo declared by the shipper for liability and insurance purposes.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the declared value amount.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Planned or estimated date when the cargo is expected to be delivered to the consignee.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight transportation charges for this shipment.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the freight charge amount.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightClass rdf:type rdf:Property ;
    rdfs:label 'Freight Class' ;
    rdfs:comment 'NMFC freight class code (50-500) used to determine LTL shipping rates based on density, handling, stowability, and liability.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Payment terms indicating who is responsible for freight charges (prepaid by shipper, collect from consignee, or third party).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingUnitCount rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Count' ;
    rdfs:comment 'Total number of handling units (pallets, crates, boxes, drums) in the shipment.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlingUnitType rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Type' ;
    rdfs:comment 'Type of packaging or handling unit used for the cargo.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatUnNumber rdf:type rdf:Property ;
    rdfs:label 'Hazmat Un Number' ;
    rdfs:comment 'Four-digit UN number identifying the hazardous material classification (e.g., UN1203 for gasoline).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupDate rdf:type rdf:Property ;
    rdfs:label 'Pickup Date' ;
    rdfs:comment 'Scheduled or actual date when the carrier picked up the cargo from the shipper.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proofOfDeliverySignature rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Signature' ;
    rdfs:comment 'Name of the person who signed for receipt of the cargo at the destination.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipper Address Line1' ;
    rdfs:comment 'Primary street address of the shipper location.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperCity rdf:type rdf:Property ;
    rdfs:label 'Shipper City' ;
    rdfs:comment 'City where the shipper location is situated.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipper Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the shipper location.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'Legal name of the shipper party originating the cargo.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipper Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the shipper location.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipper State Province' ;
    rdfs:comment 'State or province code for the shipper location.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for special handling, loading, or delivery instructions for the carrier.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether the shipment requires temperature-controlled transportation (refrigerated or heated).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalWeight rdf:type rdf:Property ;
    rdfs:label 'Total Weight' ;
    rdfs:comment 'Total gross weight of the shipment including packaging.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL for the carriers API integration for real-time rate quotes, shipment booking, and tracking. Used for TMS connectivity.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'The full legal name of the transportation carrier or freight forwarder as registered with regulatory authorities.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current operational status of the carrier in the approved carrier network. Controls whether carrier can be selected for new shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Classification of the carrier based on primary mode of transportation. Determines applicable regulations and service capabilities.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsRatio rdf:type rdf:Property ;
    rdfs:label 'Claims Ratio' ;
    rdfs:comment 'Ratio of cargo claims to total shipments handled by the carrier. Used for carrier quality assessment and risk evaluation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the current carrier contract becomes effective. Used for rate validation and contract compliance tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Date when the current carrier contract expires. Triggers contract renewal workflow and rate renegotiation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Contractual relationship status with the carrier. Determines pricing structure and service level commitments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Flag' ;
    rdfs:comment 'Indicates whether the carrier provides customs brokerage services for international shipments. True if customs brokerage available.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'US Department of Transportation identification number assigned to commercial motor carriers. Required for interstate commerce in the United States.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capability Flag' ;
    rdfs:comment 'Indicates whether the carrier supports EDI transactions for shipment tendering, status updates, and invoicing. True if EDI-enabled.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediVersion rdf:type rdf:Property ;
    rdfs:label 'Edi Version' ;
    rdfs:comment 'EDI standard version supported by the carrier (e.g., ANSI X12 4010, EDIFACT D96A). Required for EDI integration setup.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Physical street address of the carriers corporate headquarters. Used for legal correspondence and contract administration.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the carriers corporate headquarters is located.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the carriers headquarters location. Used for regulatory compliance and tax jurisdiction.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the carriers headquarters address.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State or province where the carriers corporate headquarters is located. Two-letter code preferred.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment 'IATA numeric airline code for air cargo carriers. Used for air waybill processing and cargo tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoCode rdf:type rdf:Property ;
    rdfs:label 'Icao Code' ;
    rdfs:comment 'Three-letter airline designator assigned by ICAO for air carriers. Used in flight operations and air traffic control.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number for the carriers liability insurance certificate. Required for carrier qualification and risk management.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Motor Carrier operating authority number issued by FMCSA for carriers transporting regulated commodities for hire in interstate commerce.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryPercentage rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Percentage' ;
    rdfs:comment 'Percentage of shipments delivered within the committed delivery window. Key performance indicator for carrier performance management.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredLanes rdf:type rdf:Property ;
    rdfs:label 'Preferred Lanes' ;
    rdfs:comment 'Geographic lanes or routes where the carrier has preferred capacity, competitive rates, or specialized expertise. Comma-separated origin-destination pairs.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the carrier for operational coordination and issue resolution.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Phone number of the primary carrier contact for urgent shipment issues and operational escalation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'FMCSA safety fitness rating based on compliance review and safety performance history. Impacts carrier selection and risk assessment.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Unique two-to-four letter code used to identify transportation companies. Required for EDI transactions and customs documentation in North America.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCoverageArea rdf:type rdf:Property ;
    rdfs:label 'Service Coverage Area' ;
    rdfs:comment 'Geographic regions or countries where the carrier provides service. Used for carrier selection based on shipment origin and destination.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'Primary service mode offered by the carrier. LTL (Less Than Truckload), FTL (Full Truckload), or other specialized services.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmsIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Tms Integration Status' ;
    rdfs:comment 'Current status of the carriers integration with the enterprise TMS. Determines availability for automated shipment tendering and tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Tracking Url Template' ;
    rdfs:comment 'URL template for shipment tracking on the carriers website. Placeholder tokens replaced with tracking number for customer self-service.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Internal vendor identifier for the carrier in the ERP system. Used for purchase order creation and invoice matching.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierContractId rdf:type rdf:Property ;
    rdfs:label 'Carrier Contract Id' ;
    rdfs:comment 'Unique identifier for the carrier contract. Primary key.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierContract .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Contract Ownership Tracking links the employee responsible for negotiating and managing the carrier contract, essential for governance and audit.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessorialChargesIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges Included Flag' ;
    rdfs:comment 'Indicates whether accessorial charges (liftgate, inside delivery, residential) are included in base rates or charged separately.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract automatically renews upon expiry if not terminated.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRateType rdf:type rdf:Property ;
    rdfs:label 'Base Rate Type' ;
    rdfs:comment 'Primary rate basis used in this contract for freight charges. CWT (hundredweight).' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierContactEmail rdf:type rdf:Property ;
    rdfs:label 'Carrier Contact Email' ;
    rdfs:comment 'Primary email address for the carrier contact.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierContactName rdf:type rdf:Property ;
    rdfs:label 'Carrier Contact Name' ;
    rdfs:comment 'Primary contact name at the carrier organization for this contract.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierContactPhone rdf:type rdf:Property ;
    rdfs:label 'Carrier Contact Phone' ;
    rdfs:comment 'Primary phone number for the carrier contact.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the signed contract document stored in the document management system.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the carrier contract, used in communications with carriers and internal references.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the carrier contract based on its structure and commitment level.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageClaimLiabilityLimit rdf:type rdf:Property ;
    rdfs:label 'Damage Claim Liability Limit' ;
    rdfs:comment 'Maximum liability amount per shipment that the carrier accepts for damage or loss claims.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detentionChargePerHour rdf:type rdf:Property ;
    rdfs:label 'Detention Charge Per Hour' ;
    rdfs:comment 'Hourly detention charge applied after free time expires.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detentionFreeTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Detention Free Time Minutes' ;
    rdfs:comment 'Number of minutes allowed for loading/unloading before detention charges apply.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelIndexSource rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Source' ;
    rdfs:comment 'External fuel price index used as the basis for fuel surcharge calculation, e.g., DOE National Diesel Average.' ;
